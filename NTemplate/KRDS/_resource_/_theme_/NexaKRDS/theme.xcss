<?xml version="1.0" encoding="utf-8"?>
<XCSS version="1.1">
  <Predefines>
    <Group id="Background_Color">
      <Define id="Primary" value="#256EF4"/>
      <Define id="Bg" value="#FFFFFF"/>
      <Define id="Bg_graysubtler" value="#F4F5F6"/>
      <Define id="Bg_dis" value="#CDD1D5"/>
      <Define id="Sur_graysubtle" value="#E6E8EA"/>
      <Define id="Sur_secsubtler" value="#EEF2F7"/>
      <Define id="Ele_prilit" value="#D8E5FD"/>
      <Define id="Ele_seclit" value="#D6E0EB"/>
      <Define id="Ele_graylit" value="#E6E8EA"/>
      <Define id="Ele_gray" value="#6D7882"/>
      <Define id="Ele_disdark" value="#8A949E"/>
      <Define id="Act_sechov" value="#EEF2F7"/>
      <Define id="Act_secpres" value="#D6E0EB"/>
      <Define id="Act_secohov" value="#FFFFFF"/>
      <Define id="Act_secact" value="#063A74"/>
      <Define id="Act_dis" value="#CDD1D5"/>
    </Group>
    <Group id="Input">
      <Define id="Input_sur" value="#FFFFFF"/>
      <Define id="Input_surdis" value="#CDD1D5"/>
      <Define id="Input_nm" value="1px solid #58616A"/>
      <Define id="Input_mo" value="2px solid #256EF4"/>
      <Define id="Input_dis" value="1px solid #B1B8BE"/>
      <Define id="Input_err" value="2px solid #DE3412"/>
      <Define id="Input_garylitnm" value="1px solid #CDD1D5"/>
    </Group>
    <Group id="Font">
      <Define id="H2_pc" value="700 40px/150% &quot;GOV&quot;"/>
      <Define id="H3_pc" value="700 32px/150% &quot;GOV&quot;"/>
      <Define id="H4_pc" value="700 24px/150% &quot;GOV&quot;"/>
      <Define id="H2_m" value="700 28px/150% &quot;GOV&quot;"/>
      <Define id="H3_m" value="700 24px/150% &quot;GOV&quot;"/>
      <Define id="H4_m" value="700 22px/150% &quot;GOV&quot;"/>
      <Define id="H4" value="700 24px/150% &quot;GOV&quot;"/>
      <Define id="H5" value="700 19px/150% &quot;GOV&quot;"/>
      <Define id="H6" value="700 17px/150% &quot;GOV&quot;"/>
      <Define id="Subtitle" value="700 15px/150% &quot;GOV&quot;"/>
      <Define id="Lg" value="400 19px/150% &quot;GOV&quot;"/>
      <Define id="Md" value="400 17px/150% &quot;GOV&quot;"/>
      <Define id="Sm" value="400 15px/150% &quot;GOV&quot;"/>
      <Define id="Xs" value="400 13px/150% &quot;GOV&quot;"/>
      <Define id="Lg_b" value="700 19px/150% &quot;GOV&quot;"/>
      <Define id="Md_b" value="700 17px/150% &quot;GOV&quot;"/>
      <Define id="Sm_b" value="700 15px/150% &quot;GOV&quot;"/>
      <Define id="Xs_b" value="700 13px/150% &quot;GOV&quot;"/>
    </Group>
    <Group id="Button">
      <Define id="Btn_nm" value="1px solid #58616A"/>
      <Define id="Btn_fo" value="2px solid #0B50D0"/>
      <Define id="Btn_dis" value="1px solid #CDD1D5"/>
      <Define id="Btn_nmfill" value="#FFFFFF"/>
      <Define id="Btn_fofill" value="#F4F5F6"/>
      <Define id="Btn_pufill" value="#E6E8EA"/>
      <Define id="Btn_disfill" value="#CDD1D5"/>
      <Define id="Btn_Txtfofill" value="#EEF2F7"/>
      <Define id="Btn_Txtpufill" value="#D6E0EB"/>
      <Define id="Btn_Cusnmfill" value="#ECF2FE"/>
      <Define id="Btn_Cusfofill" value="#D8E5FD"/>
      <Define id="Btn_Cuspufill" value="#B1CEFB"/>
    </Group>
    <Group id="Text_Color">
      <Define id="Txt_bas" value="#1E2124"/>
      <Define id="Txt_bd" value="#131416"/>
      <Define id="Txt_pri" value="#0B50D0"/>
      <Define id="Txt_sub" value="#464C53"/>
      <Define id="Txt_sec" value="#052B57"/>
      <Define id="Txt_dis" value="#8A949E"/>
      <Define id="Txt_disB" value="#6D7882"/>
      <Define id="Txt_inv" value="#FFFFFF"/>
      <Define id="Txt_info" value="#096AB3"/>
      <Define id="Txt_succ" value="#267337"/>
      <Define id="Txt_dang" value="#BD2C0F"/>
    </Group>
  </Predefines>
  <CSSData><![CDATA[/***************************************************************/
/***** PROJECT NAME : 투비소프트 템플릿			********/
/***** CREATION DATES : 2025.03.11     			********/
/***** DRAFTER : TOBESOFT UX Team 			********/
/***** DISTRIBUTION DATE : 2025.02			********/
/***************************************************************/

/*******************************************************************/
/*******************	FRAME START	****************************/
/*******************************************************************/
/***** TitleBarControl *****/
.TitleBarControl,
.TitleBarControl[status=deactivate],.TitleBarControl[status=disabled]
{
	background 		: #223A58;
}
.TitleBarControl .titleicon,
.TitleBarControl .titleicon[status=mouseover],.TitleBarControl .titleicon[status=deactivate],
.TitleBarControl .titleicon[status=disabled]
{
	-nexa-icon 		: URL("theme://images/titlebar_icon.png");
	-nexa-padding 		: 0px 0px 0px 16px;
	-nexa-text-padding      : 0px 0px 0px 8px; 
	color 			: #FFFFFF;
	font 			: -nexa-define(--Lg_b);
}
.TitleBarControl .minbutton,
.TitleBarControl .minbutton[status=focused],.TitleBarControl .minbutton[userstatus=selected],
.TitleBarControl .minbutton[status=deactivate]
{
	-nexa-icon 		: URL("theme://images/tib_WF_Min.png");
}
.TitleBarControl .minbutton[status=mouseover],.TitleBarControl .minbutton[userstatus=pushed]
{
	-nexa-icon 		: URL("theme://images/tib_WF_MinO.png");
}
.TitleBarControl .minbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/tib_WF_MinD.png");
}
.TitleBarControl .maxbutton,
.TitleBarControl .maxbutton[status=focused],.TitleBarControl .maxbutton[userstatus=selected],
.TitleBarControl .maxbutton[status=deactivate]
{
	-nexa-icon 		: URL("theme://images/tib_WF_MaxO.png");
}
.TitleBarControl .maxbutton[status=mouseover],.TitleBarControl .maxbutton[userstatus=pushed]
{
	-nexa-icon 		: URL("theme://images/tib_WF_Max.png");
}
.TitleBarControl .maxbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/tib_WF_MaxD.png");
}
.TitleBarControl .normalbutton,
.TitleBarControl .normalbutton[status=focused],.TitleBarControl .normalbutton[userstatus=selected],
.TitleBarControl .normalbutton[status=deactivate]
{
	-nexa-icon 		: URL("theme://images/tib_WF_Normal.png");
}
.TitleBarControl .normalbutton[status=mouseover],.TitleBarControl .normalbutton[userstatus=pushed]
{
	-nexa-icon 		: URL("theme://images/tib_WF_NormalO.png");
}
.TitleBarControl .normalbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/tib_WF_NormalD.png");
}
.TitleBarControl .closebutton,
.TitleBarControl .closebutton[status=focused],.TitleBarControl .closebutton[userstatus=selected],
.TitleBarControl .closebutton[status=deactivate]
{
	-nexa-icon 		: URL("theme://images/tib_WF_Close.png");
}
.TitleBarControl .closebutton[status=mouseover],.TitleBarControl .closebutton[userstatus=pushed]
{
	-nexa-icon 		: URL("theme://images/tib_WF_CloseO.png");
}
.TitleBarControl .closebutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/tib_WF_CloseD.png");
}
/***** HScrollBarControl *****/
.HScrollBarControl,
.HScrollBarControl[status=mouseover]
{
	-nexa-border 		: 1px solid #E6E8EA, 0px none, 0px none, 0px none;
	-nexa-padding 		: 1px 1px 1px 1px;
	background 		: -nexa-define(--Bg_graysubtler);
}
.HScrollBarControl[status=disabled]
{
	-nexa-border 		: 1px solid #CDD1D5, 0px none, 0px none, 0px none;
	background 		: -nexa-define(--Bg_dis);
}
.HScrollBarControl .decbutton,
.HScrollBarControl .decbutton[status=mouseover],.HScrollBarControl .decbutton[status=focused],
.HScrollBarControl .decbutton[userstatus=pushed],.HScrollBarControl .decbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/btn_WF_Hdec.png");
}
.HScrollBarControl .decbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/btn_WF_HdecD.png");
}
.HScrollBarControl .incbutton,
.HScrollBarControl .incbutton[status=mouseover],.HScrollBarControl .incbutton[status=focused],
.HScrollBarControl .incbutton[userstatus=pushed],.HScrollBarControl .incbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/btn_WF_Hinc.png");
}
.HScrollBarControl .incbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/btn_WF_HincD.png");
}
.HScrollBarControl .trackbar,
.HScrollBarControl .trackbar[status=focused]
{
	background 		: -nexa-define(--Ele_graylit);
}
.HScrollBarControl .trackbar[status=mouseover],
.HScrollBarControl .trackbar[userstatus=pushed],.HScrollBarControl .trackbar[userstatus=selected]
{
	background 		: -nexa-define(--Ele_gray);
}
.HScrollBarControl .trackbar[status=disabled]
{
	background 		: -nexa-define(--Ele_disdark);
}
/***** VScrollBarControl *****/
.VScrollBarControl,
.VScrollBarControl[status=mouseover]
{
	-nexa-border 		: 0px none, 0px none, 0px none, 1px solid #E6E8EA;
	-nexa-padding 		: 1px 1px 1px 1px;
	background 		: -nexa-define(--Bg_graysubtler)/*#F4F5F6*/;
}
.VScrollBarControl[status=disabled]
{
	-nexa-border 		: 0px none, 0px none, 0px none, 1px solid #CDD1D5;
	background 		: -nexa-define(--Bg_dis);
}
.VScrollBarControl .decbutton,
.VScrollBarControl .decbutton[status=mouseover],.VScrollBarControl .decbutton[status=focused],
.VScrollBarControl .decbutton[userstatus=pushed],.VScrollBarControl .decbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/btn_WF_Vdec.png");
}
.VScrollBarControl .decbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/btn_WF_VdecD.png");
}
.VScrollBarControl .incbutton,
.VScrollBarControl .incbutton[status=mouseover],.VScrollBarControl .incbutton[status=focused],
.VScrollBarControl .incbutton[userstatus=pushed],.VScrollBarControl .incbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/btn_WF_Vinc.png");
}
.VScrollBarControl .incbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/btn_WF_VincD.png");
}
.VScrollBarControl .trackbar,
.VScrollBarControl .trackbar[status=focused]
{
	background 		: -nexa-define(--Ele_graylit);
}
.VScrollBarControl .trackbar[status=mouseover],
.VScrollBarControl .trackbar[userstatus=pushed],.VScrollBarControl .trackbar[userstatus=selected]
{
	background 		: -nexa-define(--Ele_gray);
}
.VScrollBarControl .trackbar[status=disabled]
{
	background 		: -nexa-define(--Ele_disdark);
}
/***** VScrollIndicatorControl *****/
.VScrollIndicatorControl
{
	background 		: transparent;	
}
.VScrollIndicatorControl .trackbar,
.VScrollIndicatorControl .trackbar[status=focused]
{
	background 		: transparent;	
/*	background 		: #B1B8BE;*/
}
.VScrollIndicatorControl .trackbar[status=mouseover],
.VScrollIndicatorControl .trackbar[userstatus=pushed],.VScrollIndicatorControl .trackbar[userstatus=selected]
{
	background 		: transparent;	
	/*background 		: #58616A;*/
}
.VScrollIndicatorControl .trackbar[status=disabled]
{
	background 		: -nexa-define(--Ele_disdark);
}
/***** HScrollIndicatorControl *****/
.HScrollIndicatorControl
{
	background 		: transparent;		
}
.HScrollIndicatorControl .trackbar,
.HScrollIndicatorControl .trackbar[status=focused]
{
	background 		: transparent;	
	/*background 		: #B1B8BE;*/
}
.HScrollIndicatorControl .trackbar[status=mouseover],
.HScrollIndicatorControl .trackbar[userstatus=pushed],.HScrollIndicatorControl .trackbar[userstatus=selected]
{
	background 		: transparent;	
	/*background 		: #58616A;*/
}
.HScrollIndicatorControl .trackbar[status=disabled]
{
	background 		: -nexa-define(--Ele_disdark);
}
/***** Form *****/
.Form
{
	-nexa-border 		: 0px none;
	background 		: -nexa-define(--Bg);
	color 			: -nexa-define(--Txt_bas);
	font 			: -nexa-define(--Md);
}
.Form[userstatus=contents]
{
	background 		: transparent;
}
/***************************************************************************/
/************************	FRAME END	****************************/
/***************************************************************************/

/***************************************************************************/
/*******************	BASE COMPONENT START	****************************/
/***************************************************************************/

/***** Button *****/
/*** tertiary = default button ***/
.Button
{
	-nexa-border 		: -nexa-define(--Btn_nm);
	-nexa-padding 		: 2px 15px 1px 15px;
	background 		: transparent;
	border-radius 		: 6px;
	color 			: -nexa-define(--Txt_bas);
	cursor 			: pointer;
}
.Button[status=mouseover]
{
	background		: -nexa-define(--Btn_fofill);
}
.Button[status=focused]
{
	-nexa-border 		: -nexa-define(--Btn_fo);
	-nexa-padding 		: 1px 0px 0px 0px;
	background		: -nexa-define(--Btn_fofill);	
}
.Button[userstatus=pushed],.Button[userstatus=selected]
{
	background		: -nexa-define(--Btn_pufill);
}
.Button[status=disabled]
{
	-nexa-border		: 0px none;
	background 		: -nexa-define(--Btn_disfill);
	color			: -nexa-define(--Txt_disB);
	cursor 			: default;
}
/***** Calendar *****/
.Calendar,
.CalendarControl
{
	-nexa-border 		: -nexa-define(--Input_nm);
	-nexa-padding 		: 1px;	
	background 		: -nexa-define(--Input_sur);
	border-radius		: 6px;
}
.Calendar[status=mouseover],.Calendar[status=focused],
.CalendarControl[status=mouseover],.CalendarControl[status=focused]
{
	-nexa-border 		: -nexa-define(--Input_mo);
	-nexa-padding 		: 0px;
}
.Calendar[status=readonly],
.CalendarControl[status=readonly]
{
	-nexa-border 		: -nexa-define(--Input_dis);
	color 			: -nexa-define(--Txt_sub);
	background 		: -nexa-define(--Input_surdis);
}
.Calendar[status=disabled],
.CalendarControl[status=disabled]
{
	-nexa-border 		: -nexa-define(--Input_dis);
	color 			: -nexa-define(--Txt_disB);
	background 		: -nexa-define(--Input_surdis);
}
.Calendar .calendaredit,
.Calendar .calendaredit[status=mouseover],.Calendar .calendaredit[status=focused],
.Calendar .calendaredit[status=readonly],.Calendar .calendaredit[status=disabled],
.CalendarControl .calendaredit,
.CalendarControl .calendaredit[status=mouseover],.CalendarControl .calendaredit[status=focused],
.CalendarControl .calendaredit[status=readonly],.CalendarControl .calendaredit[status=disabled]
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 1px 0px 0px 14px;	
	background 		: transparent;
}
.Calendar .calendaredit[userstatus=nulltext],
.CalendarControl .calendaredit[userstatus=nulltext]
{
	color          		: -nexa-define(--Txt_dis);
}
.Calendar .dropbutton,
.Calendar .dropbutton[status=mouseover],.Calendar .dropbutton[status=focused],
.Calendar .dropbutton[userstatus=pushed],.Calendar .dropbutton[userstatus=selected],
.CalendarControl .dropbutton,
.CalendarControl .dropbutton[status=mouseover],.CalendarControl .dropbutton[status=focused],
.CalendarControl .dropbutton[userstatus=pushed],.CalendarControl .dropbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/cal_WF_DropBtn.png");
}
.Calendar .dropbutton[status=disabled],
.CalendarControl .dropbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/cal_WF_DropBtnD.png");
}
.Calendar .calendarspindownbutton,
.Calendar .calendarspindownbutton[status=mouseover],.Calendar .calendarspindownbutton[status=focused],
.Calendar .calendarspindownbutton[userstatus=pushed],.Calendar .calendarspindownbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/spn_WF_DownBtn.png");
}
.Calendar .calendarspindownbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/spn_WF_DownBtnD.png");
}
.Calendar .calendarspinupbutton,
.Calendar .calendarspinupbutton[status=mouseover],.Calendar .calendarspinupbutton[status=focused],
.Calendar .calendarspinupbutton[userstatus=pushed],.Calendar .calendarspinupbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/spn_WF_UpBtn.png");
}
.Calendar .calendarspinupbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/spn_WF_UpBtnD.png");
}
.Calendar .datepicker,
.Calendar .datepicker[status=focused],.Calendar .datepicker[status=mouseover],
.Calendar .datepicker[status=readonly],
.CalendarControl .datepicker,
.CalendarControl .datepicker[status=focused],.CalendarControl .datepicker[status=mouseover],
.CalendarControl .datepicker[status=readonly]
{
	-nexa-padding 		: 15px;
	-nexa-border 		: 1px solid #D6E0EB;
	background 		: -nexa-define(--Sur_secsubtler);
	border-radius 		: 6px;
}
.Calendar .datepicker .body,
.Calendar .datepicker .body[status=mouseover],.Calendar .datepicker .body[status=focused],
.Calendar .datepicker .body[status=readonly],
.CalendarControl .datepicker .body,
.CalendarControl .datepicker .body[status=mouseover],.CalendarControl .datepicker .body[status=focused],
.CalendarControl .datepicker .body[status=readonly]
{
	background 		: -nexa-define(--Act_sechov);
}
.Calendar .datepicker .body[status=disabled],
.CalendarControl .datepicker .body[status=disabled]
{
	background 		: -nexa-define(--Act_dis);
}
.Calendar .datepicker .body .monthitem,
.Calendar .datepicker .body .monthitem[status=focused],
.CalendarControl .datepicker .body .monthitem,
.CalendarControl .datepicker .body .monthitem[status=focused]
{	
	background 		: -nexa-define(--Act_sechov);
	border-radius 		: 22px;	
	color 			: -nexa-define(--Txt_bas);
}
.Calendar .datepicker .body .monthitem[status=mouseover],
.CalendarControl .datepicker .body .monthitem[status=mouseover]
{
	background 		: -nexa-define(--Act_secohov);
	color 			: -nexa-define(--Txt_bas);
}
.Calendar .datepicker .body .monthitem[userstatus=pushed],
.Calendar .datepicker .body .monthitem[userstatus=selected],
.CalendarControl .datepicker .body .monthitem[userstatus=pushed],
.CalendarControl .datepicker .body .monthitem[userstatus=selected]
{
	background 		: -nexa-define(--Act_secact);
	color 			: -nexa-define(--Txt_inv);
} 
.Calendar .datepicker .body .yearitem,
.Calendar .datepicker .body .yearitem[status=focused],
.CalendarControl .datepicker .body .yearitem,
.CalendarControl .datepicker .body .yearitem[status=focused]
{	
	background 		: -nexa-define(--Act_sechov);
	border-radius 		: 22px;
	color 			: -nexa-define(--Txt_bas);
}
.Calendar .datepicker .body .yearitem[status=mouseover],
.CalendarControl .datepicker .body .yearitem[status=mouseover]
{
	background 		: -nexa-define(--Act_secohov);
	color 			: -nexa-define(--Txt_bas);
}
.Calendar .datepicker .body .yearitem[userstatus=selected],
.CalendarControl .datepicker .body .yearitem[userstatus=selected]
{
	background 		: -nexa-define(--Act_secact);
	color 			: -nexa-define(--Txt_inv);
}
/***** CheckBox *****/
.CheckBox
{
	-nexa-icon 		: URL("theme://images/chk_WF_BoxN.png");
	-nexa-padding		: 2px;
	-nexa-text-padding 	: 0px 15px 0px 8px;
	border-radius 		: 6px;
	font 			: -nexa-define(--Md);
}
.CheckBoxControl
{
	-nexa-icon 		: URL("theme://images/chk_WF_BoxN.png");
	-nexa-text-padding 	: 0px 15px 0px 8px;
	font 			: -nexa-define(--Md);
}
.CheckBox[status=focused]
{
	-nexa-border		: -nexa-define(--Input_mo);
	-nexa-icon 		: URL("theme://images/chk_WF_BoxN.png");
	-nexa-padding		: 0px;
}
/*
Focused 영향으로 생략 - checkset/Grid checkbox - 
.CheckBoxControl[status=focused]
{
	-nexa-border		: -nexa-define(--Input_mo);
	-nexa-icon 		: URL("theme://images/chk_WF_BoxF.png");
	-nexa-padding		: 0px;
}
.CheckBoxControl[status=focused][userstatus=selected]
{
	-nexa-border		: -nexa-define(--Input_mo);
	-nexa-icon 		: URL("theme://images/chk_WF_BoxFS.png");
	-nexa-padding		: 0px;
	border-radius 		: 6px;
}
*/
.CheckBox[status=mouseover],
.CheckBoxControl[status=mouseover]
{
	-nexa-icon 		: URL("theme://images/chk_WF_BoxO.png");
}
.CheckBox[status=mouseover][userstatus=selected],.CheckBox[userstatus=selected],
.CheckBoxControl[status=mouseover][userstatus=selected],.CheckBoxControl[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/chk_WF_BoxS.png");
}
.CheckBox[status=readonly],
.CheckBoxControl[status=readonly]
{
	-nexa-icon 		: URL("theme://images/chk_WF_BoxD.png");
}
.CheckBox[status=readonly][userstatus=selected],
.CheckBoxControl[status=readonly][userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/chk_WF_BoxDS.png");
}
.CheckBox[status=disabled],
.CheckBoxControl[status=disabled]
{
	-nexa-icon 		: URL("theme://images/chk_WF_BoxD.png");
	color			: -nexa-define(--Txt_dis);	
}
.CheckBox[status=disabled][userstatus=selected],
.CheckBoxControl[status=disabled][userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/chk_WF_BoxDS.png");
	color			: -nexa-define(--Txt_dis);
}
/***** CheckBoxSet *****/

.CheckBoxSet .checkboxsetitem,
.CheckBoxSetControl .checkboxsetitem
{
	-nexa-icon 		: URL("theme://images/chk_WF_BoxN.png");
	-nexa-padding 		: 11px 2px 11px 2px;
	-nexa-text-padding 	: 0px 15px 0px 8px;
}
.CheckBoxSet .checkboxsetitem[status=focused],
.CheckBoxSetControl .checkboxsetitem[status=focused]
{
	-nexa-icon 		: URL("theme://images/chk_WF_BoxO.png");
	-nexa-border		: -nexa-define(--Input_mo);
	-nexa-padding 		: 9px 0px 9px 0px;
}
.CheckBoxSet .checkboxsetitem[status=mouseover],
.CheckBoxSetControl .checkboxsetitem[status=mouseover]
{
	-nexa-icon 		: URL("theme://images/chk_WF_BoxO.png");
}
.CheckBoxSet .checkboxsetitem[status=mouseover][userstatus=selected],.CheckBoxSet .checkboxsetitem[userstatus=selected],
