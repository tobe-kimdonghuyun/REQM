.FileUpload .fileuploaditem .fileuploaditembutton[status=disabled]
{
	-nexa-border		: -nexa-define(--Btn_dis);
	background 		: -nexa-define(--Btn_disfill);
	color			: -nexa-define(--Txt_disB);
	cursor 			: default;
}

/***** Grid *****/
.Grid
{
	-nexa-border		: 0px none, 0px none, 1px solid #CDD1D5, 0px none;
	background 		: -nexa-define(--Input_sur);
}
.Grid .head
{
	-nexa-border		: 0px none, 0px none, 1px solid #D6E0EB, 0px none;
	background 		: -nexa-define(--Sur_secsubtler);
}
.Grid .head .row .cell
{
	-nexa-padding		: 0px 16px;
	color 			: -nexa-define(--Txt_bd);
	font 			: -nexa-define(--Sm_b);
}
.Grid .body .row .cell
{
	-nexa-border		: 0px none, 0px none, 1px solid #CDD1D5, 0px none;
	-nexa-padding		: 4px 2px;
	color			: -nexa-define(--Txt_sub);
}
.Grid .body .row .cell[status=mouseover]
{
	background		: -nexa-define(--Bg_graysubtler);
}
.Grid .body .row .cell[userstatus=selected]
{
	background		: -nexa-define(--Ele_prilit);
}
.Grid .summary
{
	-nexa-border		: 0px none, 0px none, 1px solid #D6E0EB, 0px none;
	background 		: -nexa-define(--Ele_seclit);
}
.Grid .summary .row .cell
{
	-nexa-padding		: 0px 16px;
	color 			: -nexa-define(--Txt_sub);
	font 			: -nexa-define(--Md_b);
}
/*cellcontrol Start*/
.GridCellControl .cellselection,
.GridSelectionControl
{
	-nexa-border 		: 2px dotted #000000;
	border-radius 		: 6px;
}
.GridCellControl .cellbutton
{
	-nexa-border 		: -nexa-define(--Input_nm);
	-nexa-padding 		: 0px 15px;
	background 		: -nexa-define(--Input_sur);
	border-radius 		: 6px;
	color 			: -nexa-define(--Txt_bas);
	cursor 			: pointer;
}
.GridCellControl .cellbutton[status=mouseover]
{
	background		: -nexa-define(--Btn_fofill);
}
.GridCellControl .cellbutton[userstatus=pushed],
.GridCellControl .cellbutton[userstatus=selected]
{
	background		: -nexa-define(--Btn_pufill);
}
.GridCellControl .cellbutton[status=disabled]
{
	-nexa-border		: -nexa-define(--Btn_dis);
	background 		: -nexa-define(--Btn_disfill);
	color			: -nexa-define(--Txt_disB);
}
.GridCellControl .cellexpandbutton,
.GridCellControl .cellexpandbutton[status=mouseover],
.GridCellControl .cellexpandbutton[userstatus=pushed],.GridCellControl .cellexpandbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/btn_WF_Sch.png");
}
.GridCellControl .cellexpandbutton[status=focused]
{
	-nexa-border		: -nexa-define(--Btn_fo);
	border-radius 		: 6px;
}
.GridCellControl .cellexpandbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/btn_WF_SchD.png");
}
/*
.GridCellControl .cellcheckbox[status=focused]
{
	-nexa-padding		: 0px;
	-nexa-icon 		: URL("theme://images/chk_WF_BoxF.png");
}
.GridCellControl .cellcheckbox[status=focused][userstatus=selected]
{
	-nexa-padding		: 0px;
	-nexa-icon 		: URL("theme://images/chk_WF_BoxFS.png");
}
*/
.GridCellControl .cellradioitem,.GridCellControl .cellradioitem[status=readonly]
{
	-nexa-icon 		: URL("theme://images/rdo_WF_Item.png");
	-nexa-text-padding 	: 0px 24px 0px 8px;	
}
.GridCellControl .cellradioitem[status=mouseover]
{
	-nexa-icon 		: URL("theme://images/rdo_WF_ItemO.png");
}
.GridCellControl .cellradioitem[status=mouseover][userstatus=selected],.GridCellControl .cellradioitem[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/rdo_WF_ItemS.png");
}
.GridCellControl .cellradioitem[status=disabled]
{
	-nexa-icon 		: URL("theme://images/rdo_WF_ItemD.png");
}
.GridCellControl .cellradioitem[status=disabled][userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/rdo_WF_ItemSD.png");
}
.GridCellControl .celltreeitem .treeitembutton[userstatus=expand]
{
	-nexa-icon 		: URL("theme://images/grd_WF_TreeClose.png");
}
.GridCellControl .celltreeitem .treeitembutton[userstatus=expand][status=disabled]
{
	-nexa-icon 		: URL("theme://images/grd_WF_TreeCloseD.png");
}
.GridCellControl .celltreeitem .treeitembutton[userstatus=collapse]
{
	-nexa-icon 		: URL("theme://images/grd_WF_TreeOpen.png");
}
.GridCellControl .celltreeitem .treeitembutton[userstatus=collapse][status=disabled]
{
	-nexa-icon 		: URL("theme://images/grd_WF_TreeOpenD.png");
}
.GridCellControl .celltreeitem .treeitemimage[userstatus=expand]
{
	-nexa-icon 		: URL("theme://images/grd_WF_TreeCloseImg.png");
}
.GridCellControl .celltreeitem .treeitemimage[userstatus=expand][status=disabled]
{
	-nexa-icon 		: URL("theme://images/grd_WF_TreeCloseImgD.png");
}
.GridCellControl .celltreeitem .treeitemimage[userstatus=collapse]
{
	-nexa-icon 		: URL("theme://images/grd_WF_TreeOpenImg.png");
}
.GridCellControl .celltreeitem .treeitemimage[userstatus=collapse][status=disabled]
{
	-nexa-icon 		: URL("theme://images/grd_WF_TreeOpenImgD.png");
}
.GridCellControl .celltreeitem .treeitemimage[userstatus=leaf]
{
	-nexa-icon 		: URL("theme://images/grd_WF_TreeLeafImg.png");
}
.GridCellControl .celltreeitem .treeitemimage[userstatus=leaf][status=disabled]
{
	-nexa-icon 		: URL("theme://images/grd_WF_TreeLeafImg.png");
}
.GridCellControl .celltreeline
{
	-nexa-border 		: 1px dotted #8A949E;
}
.GridCellControl .celltreeline[status=disabled]
{
	-nexa-border 		: -nexa-define(--Input_garylitnm)/*1px dotted #CDD1D5*/;
}
/***** GropBox *****/
.GroupBox .groupboxtitle
{
	-nexa-text-padding 	: 0px 5px 0px 5px;
	background 		: -nexa-define(--Bg);
	border-radius 		: 4px;
	color 			: -nexa-define(--Txt_sub);
}
.GroupBox .groupboxtitle[status=disabled]
{
	background 		: -nexa-define(--Bg_graysubtler);
	color 			: -nexa-define(--Txt_disB);
}
.GroupBox .groupboxcontents
{
	-nexa-border 		: -nexa-define(--Input_dis);
	background 		: -nexa-define(--Input_sur);
	border-radius 		: 6px;
}
.GroupBox .groupboxcontents[status=disabled]
{
	-nexa-border 		: -nexa-define(--Input_dis);
	background 		: -nexa-define(--Input_surdis);	
}
/***** ImageViewer *****/
.ImageViewer,.ImageViewer[status=disabled]
{
	-nexa-border 		: 0px none;
	background 		: -nexa-define(--Bg_graysubtler);
}
/***** ListBox *****/
.ListBox
{
	-nexa-border 		: -nexa-define(--Input_nm);
	-nexa-padding 		: 8px;	
	background 		: -nexa-define(--Input_sur);
	border-radius 		: 8px;
	box-shadow 		: 0px 4px 8px 0px rgba(0, 0, 0, 0.08);	
}
.ListBox[status=readonly],.ListBox[status=disabled]
{
	-nexa-border 		: -nexa-define(--Input_dis);
	background 		: -nexa-define(--Input_surdis);
}
.ListBox .listboxitem[status=mouseover]
{
	background 		: -nexa-define(--Sur_secsubtler);
}
.ListBox .listboxitem,.ListBox .listboxitem[status=focused]
{
	-nexa-padding 		: 8px;
	border-radius 		: 6px;	
}
.ListBox .listboxitem[userstatus=selected]
{
	background 		: -nexa-define(--Sur_secsubtler);
	color 			: -nexa-define(--Txt_sec);
}
.ListBox .listboxitem[status=readonly]
{
	color 			: -nexa-define(--Txt_sub);
}
.ListBox .listboxitem[status=disabled]
{
	color 			: -nexa-define(--Txt_disB);
}
/***** ListView *****/  
.ListView,
.ListView[status=mouseover],.ListView[status=focused],
.ListView[status=disabled],.ListView[status=readonly]
{
}
.ListView .body,
.ListView .body[status=focused],.ListView .body[status=readonly],
.ListView .body[status=disabled]
{
	background 		: -nexa-define(--Input_sur);
	border-radius 		: 10px;
	font 			: -nexa-define(--Lg_b);
}
.ListView .body[status=mouseover]
{
	background 		: -nexa-define(--Sur_secsubtler);
}
.ListView .body[userstatus=selected]
{
	background 		: -nexa-define(--Sur_secsubtler);
	border-radius 		: 10px 10px 0px 0px;
	color 			: -nexa-define(--Txt_sec);
}
.ListView .body .expandbar,.ListView .body .expandbar[userstatus=expand]
{
	-nexa-icon 		: URL("theme://images//pmnu_WF_Prev.png");
}
.ListView .body .expandbar[userstatus=collapse]
{
	-nexa-icon 		: URL("theme://images//pmnu_WF_Next.png");
}
.ListView .detail
{
	background		: -nexa-define(--Sur_secsubtler);
	border-radius 		: 0px 0px 10px 10px;	
}
.ListView .body .cell .cellprogressbar,.ListView .detail .cell .cellprogressbar
{
	color 			: transparent;
}
.ListView .body .cell .cellbutton,.ListView .detail .cell .cellbutton
{
	-nexa-border 		: -nexa-define(--Input_nm);
	-nexa-padding 		: 1px;
	background 		: -nexa-define(--Input_sur);
	border-radius 		: 6px;
	color 			: -nexa-define(--Txt_bas);
	cursor 			: pointer;
}
.ListView .body .cell .cellbutton[status=focused],
.ListView .detail .cell .cellbutton[status=focused]
{
	-nexa-border 		: -nexa-define(--Btn_fo);
	-nexa-padding 		: 0px;	
}
.ListView .body .cell .cellbutton[status=mouseover],
.ListView .detail .cell .cellbutton[status=mouseover]
{
	background		: -nexa-define(--Btn_fofill);
}
.ListView .body .cell .cellbutton[userstatus=selected],
.ListView .detail .cell .cellbutton[userstatus=selected]
{
	background		: -nexa-define(--Btn_pufill);
}
.ListView .body .cell .cellbutton[status=disabled],
.ListView .detail .cell .cellbutton[status=disabled]
{
	-nexa-border		: -nexa-define(--Btn_dis);
	background 		: -nexa-define(--Btn_disfill);
	color			: -nexa-define(--Txt_disB);
	cursor 			: default;
}
.ListView .body .cell .cellimage
{
	-nexa-border		: -nexa-define(--Input_garylitnm);
	border-radius 		: 50px;
}
/***** MaskEdit *****/
.MaskEdit,
.MaskEditControl
{
	-nexa-border 		: -nexa-define(--Input_nm);
        -nexa-padding 		: 2px 15px 1px 15px;
	background 		: -nexa-define(--Input_sur);
	border-radius 		: 6px;
}
.MaskEdit[status=mouseover],.MaskEdit[status=focused],
.MaskEditControl[status=mouseover],.MaskEditControl[status=focused]
{
	-nexa-border 		: -nexa-define(--Input_mo);
	-nexa-padding 		: 1px 14px 0px 14px;
}
.MaskEdit[status=readonly],
.MaskEditControl[status=readonly]
{
	-nexa-border 		: -nexa-define(--Input_dis);
	background 		: -nexa-define(--Input_surdis);
	color 			: -nexa-define(--Txt_sub);
}
.MaskEdit[userstatus=nulltext],
.MaskEditControl[userstatus=nulltext]
{
	color          		: -nexa-define(--Txt_dis);
}
.MaskEdit[status=disabled],
.MaskEditControl[status=disabled]
{
	-nexa-border 		: -nexa-define(--Input_dis);
	background 		: -nexa-define(--Input_surdis);
	color 			: -nexa-define(--Txt_disB);
}
/***** Menu *****/
.Menu,
.Menu[status=mouseover],.Menu[status=focused]
{
	-nexa-border 		: 1px solid #CDD1D5, 0px none;
	background 		: -nexa-define(--Input_sur);
}
.Menu .prevbutton,
.Menu .prevbutton[status=focused]
{
	background 		: URL("theme://images/mnu_WF_Prev.png") no-repeat center center #FFFFFF;
}
.Menu .prevbutton[status=mouseover],.Menu .prevbutton[userstatus=pushed],
.Menu .prevbutton[userstatus=selected]
{
	background 		: URL("theme://images/mnu_WF_Prev.png") no-repeat center center #D6E0EB;
}
.Menu .prevbutton[status=disabled]
{
	background 		: URL("theme://images/mnu_WF_Prev.png") no-repeat center center #CDD1D5;
}
.Menu .nextbutton,
.Menu .nextbutton[status=focused]
{
	background 		: URL("theme://images/mnu_WF_Next.png") no-repeat center center #FFFFFF;
}
.Menu .nextbutton[status=mouseover],.Menu .nextbutton[userstatus=pushed],
.Menu .nextbutton[userstatus=selected]
{
	background 		: URL("theme://images/mnu_WF_Next.png") no-repeat center center #D6E0EB;
}
.Menu .nextbutton[status=disabled]
{
	background 		: URL("theme://images/mnu_WF_Next.png") no-repeat center center #CDD1D5;
}
.Menu .menuitem
{
	-nexa-border 		: 0px none, 0px none, 4px solid #FFFFFF, 0px none;
	-nexa-padding 		: 0px 16px 0px 16px;
	color 			: -nexa-define(--Txt_sub);
	font 			: -nexa-define(--Lg_b);
}
.Menu .menuitem[status=mouseover],
.Menu .menuitem[status=focused],.Menu .menuitem[userstatus=selected]
{
	-nexa-border 		: 0px none, 0px none, 4px solid #052B57, 0px none;
	color 			: -nexa-define(--Txt_sec);
}
.Menu .menuitem[status=disabled]
{
	-nexa-border 		: 0px none, 0px none, 4px solid #CDD1D5, 0px none;
	background 		: -nexa-define(--Input_surdis);
	color 			: -nexa-define(--Txt_disB);
}
/***** MultiCombo *****/
.MultiCombo,
.MultiComboControl
{
	-nexa-border 		: -nexa-define(--Input_nm);
	-nexa-padding 		: 1px;
	background 		: -nexa-define(--Input_sur);
	border-radius 		: 6px;
}
.MultiCombo[status=mouseover],.MultiCombo[status=focused],
.MultiComboControl[status=mouseover],.MultiComboControl[status=focused]
{
	-nexa-border 		: -nexa-define(--Input_mo);
	-nexa-padding 		: 0px;
}
.MultiCombo[status=readonly],
.MultiComboControl[status=readonly]
{
	-nexa-border 		: -nexa-define(--Input_dis);
	background 		: -nexa-define(--Input_surdis);
	color 			: -nexa-define(--Txt_sub);
}
.MultiCombo[status=disabled],
.MultiComboControl[status=disabled]
{
	-nexa-border 		: -nexa-define(--Input_dis);
	background 		: -nexa-define(--Input_surdis);
	color 			: -nexa-define(--Txt_disB);
}
.MultiCombo .multicombotext,
.MultiCombo .multicombotext[status=mouseover],.MultiCombo .multicombotext[status=focused],
.MultiCombo .multicombotext[status=readonly],.MultiCombo .multicombotext[status=disabled],
.MultiCombo .multicombotext[userstatus=nulltext],
.MultiComboControl .multicombotext,
.MultiComboControl .multicombotext[status=mouseover],.MultiComboControl .multicombotext[status=focused],
.MultiComboControl .multicombotext[status=readonly],.MultiComboControl .multicombotext[status=disabled],
.MultiComboControl .multicombotext[userstatus=nulltext]
{
	-nexa-border		: 0px none;
	-nexa-padding 		: 1px 8px 0px 14px;	
}
.MultiCombo .multicombolist,
.MultiComboControl .multicombolist
{
	background 		: -nexa-define(--Input_sur);
}
.MultiCombo .multicombolist .multicomboedit,
.MultiComboControl .multicombolist .multicomboedit
{
/***** same as .Edit,.EditControl *****/
}
.MultiCombo .dropbutton,
.MultiCombo .dropbutton[status=mouseover],.MultiCombo .dropbutton[status=focused],
.MultiCombo .dropbutton[userstatus=pushed],.MultiCombo .dropbutton[userstatus=selected],
.MultiCombo .dropbutton[status=disabled],
.MultiComboControl .dropbutton,
.MultiComboControl .dropbutton[status=mouseover],.MultiComboControl .dropbutton[status=focused],
.MultiComboControl .dropbutton[userstatus=pushed],.MultiComboControl .dropbutton[userstatus=selected],
.MultiComboControl .dropbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/btn_WF_Drop.png");
	-nexa-padding 		: 0px;	
}
.MultiCombo .multicombotagbox,
.MultiComboControl .multicombotagbox
{
	-nexa-padding 		: 7px 15px 7px 15px;
}
.MultiComboTagBoxControl
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 7px 15px 7px 15px;
}
.MultiComboTagBoxControl .tagboxitem
{
	-nexa-padding 		: 3px 9px 3px 9px;
	background 		: -nexa-define(--Input_sur);
	border-radius 		: 24px;
}
.MultiComboTagBoxControl .tagboxitem[status=mouseover]
{
	background 		: -nexa-define(--Act_sechov);
}
.MultiComboTagBoxControl .tagboxitem[userstatus=selected]
{
	background 		: -nexa-define(--Act_secpres);
}
.MultiComboTagBoxControl .tagboxitem[status=disabled]
{
	-nexa-border		: -nexa-define(--Input_dis);
	background 		: transparent;
}
.MultiComboTagBoxControl .tagboxedit
{	
	-nexa-border		: -nexa-define(--Input_garylitnm);
}
.MultiComboListControl
{
	-nexa-border 		: -nexa-define(--Input_nm);
	-nexa-padding 		: 10px 8px;	
	background 		: -nexa-define(--Input_sur);
	border-radius 		: 8px;
}
.MultiComboListControl[status=mouseover]
{
	-nexa-border 		: -nexa-define(--Input_nm);
}
.MultiComboListControl[status=disabled]
{
	-nexa-border 		: -nexa-define(--Input_dis);
	background 		: -nexa-define(--Input_surdis);
}
.MultiComboListControl .checkboxset
{
	-nexa-border 		: 1px solid #CDD1D5, 0px none, 0px none, 0px none;
	-nexa-padding 		: 4px 0px 0px 0px;
	background 		: -nexa-define(--Input_sur);
	color 			: -nexa-define(--Txt_bas);
	font 			: -nexa-define(--Md);
}
.MultiComboListControl .checkboxset .checkboxsetitem,
.MultiComboListControl .checkboxset .checkboxsetitem[status=focused]
{
	-nexa-padding 		: 10px 8px;
	-nexa-vertical-align 	: middle;	
	background 		: -nexa-define(--Input_sur);
	border-radius 		: 6px;
}
.MultiComboListControl .checkboxset .checkboxsetitem[status=mouseover]
{
	background 		: -nexa-define(--Act_sechov);
}
.MultiComboListControl .checkboxset .checkboxsetitem[userstatus=selected],
.MultiComboListControl .checkboxset .checkboxsetitem[status=mouseover][userstatus=selected]
{
	color 			: -nexa-define(--Txt_sec);
}
.MultiComboListControl .selectallcheckbox
{
	-nexa-padding 		: 10px 8px;
	border-radius 		: 8px;	
}
.MultiComboListControl .selectallcheckbox[status=mouseover]
{
	background 		: -nexa-define(--Act_secpres);
}
.MultiComboListControl .selectallcheckbox[userstatus=selected]
{
	background 		: -nexa-define(--Act_sechov);
	color 			: -nexa-define(--Txt_sec);
}
.MultiComboListControl .selectallcheckbox[status=disabled]
{
	color 			: -nexa-define(--Txt_disB);
} 

/***** MultiLineTextField *****/
.MultiLineTextField .box
{
	-nexa-border 		: -nexa-define(--Input_nm);
	-nexa-padding 		: 7px 15px 7px 15px;
	-nexa-vertical-align	: top;
	-nexa-word-wrap		: char;	
	background 		: -nexa-define(--Input_sur);
	border-radius 		: 6px;
}
.MultiLineTextField .box[status=mouseover],.MultiLineTextField .box[status=focused]
{
	-nexa-border 		: -nexa-define(--Input_mo);
	-nexa-padding 		: 6px 14px 6px 14px;
}
.MultiLineTextField .box[status=readonly]
{
	-nexa-border 		: -nexa-define(--Input_dis);
	background 		: -nexa-define(--Input_surdis);
	color 			: -nexa-define(--Txt_sub);
}
.MultiLineTextField .box[status=disabled]
{
	-nexa-border 		: -nexa-define(--Input_dis);
	background 		: -nexa-define(--Input_surdis);
	color 			: -nexa-define(--Txt_disB);
}
.MultiLineTextField .charcounttext
{
	-nexa-padding 		: 8px 0px 0px 0px;
	-nexa-text-align 	: right;
	font 			: -nexa-define(--Sm);
}
.MultiLineTextField .helpertext
{
	-nexa-padding 		: 8px 0px 0px 20px;
	background 		: URL("theme://images/txtf_WF_Infor.png") no-repeat left center;
	color 			: -nexa-define(--Txt_info);
	font 			: -nexa-define(--Xs);
}
.MultiLineTextField .helpertext[userstatus=invalid]
{	
	background 		: URL("theme://images/txtf_WF_invalid.png") no-repeat left center;
	color 			: -nexa-define(--Txt_dang);	
}
.MultiLineTextField .helpertext[userstatus=valid]
{	
	background 		: URL("theme://images/txtf_WF_valid.png") no-repeat left center;
	color 			: -nexa-define(--Txt_succ);	
}
.MultiLineTextField .label
{
	-nexa-padding 		: 1px 15px 0px 8px;
	background 		: transparent;
	color 			: -nexa-define(--Txt_bas);
	font 			: -nexa-define(--Sm);
}
.MultiLineTextField .label[userstatus=floating]
{
	-nexa-padding 		: 0px 0px 8px 0px;
	background 		: transparent;	
}
.MultiLineTextField .label[status=focused][userstatus=floating],.MultiLineTextField .label[status=mouseover][userstatus=floating],
.MultiLineTextField .label[userstatus=floatingvalid],.MultiLineTextField .label[userstatus=floatinginvalid],
.MultiLineTextField .label[status=disabled]
{
	/***** same as userstatus=floating *****/
}
.MultiLineTextField .nulltext
{
	-nexa-padding 		: 7px 15px 7px 15px;
	-nexa-vertical-align	: top;
	color          		: -nexa-define(--Txt_dis);
}
/***** Plugin *****/
.Plugin
{
}
/***** PopupDiv *****/
.PopupDiv
{
	background 		: transparent;
}
/***** PopupMenu *****/
.PopupMenu
{
	-nexa-border 		: -nexa-define(--Input_garylitnm);
	-nexa-padding 		: 16px;
	background 		: -nexa-define(--Input_sur);
	border-radius 		: 8px;
}
.PopupMenu .prevbutton,
.PopupMenu .prevbutton[status=focused]
{
	background 		: URL("theme://images/pmnu_WF_Prev.png") no-repeat center center #FFFFFF;
}
.PopupMenu .prevbutton[status=mouseover],.PopupMenu .prevbutton[userstatus=pushed],
.PopupMenu .prevbutton[userstatus=selected]
{ 
	background 		: URL("theme://images/pmnu_WF_Prev.png") no-repeat center center #D6E0EB;
}
.PopupMenu .prevbutton[status=disabled]
{
	background 		: URL("theme://images/pmnu_WF_Prev.png") no-repeat center center #CDD1D5;
}
.PopupMenu .nextbutton,
.PopupMenu .nextbutton[status=focused]
{
	background 		: URL("theme://images/pmnu_WF_Next.png") no-repeat center center #FFFFFF;
}
.PopupMenu .nextbutton[status=mouseover],.PopupMenu .nextbutton[userstatus=pushed],
.PopupMenu .nextbutton[userstatus=selected]
{
	background 		: URL("theme://images/pmnu_WF_Next.png") no-repeat center center #D6E0EB;
}
.PopupMenu .nextbutton[status=disabled]
{
	background 		: URL("theme://images/pmnu_WF_Next.png") no-repeat center center #CDD1D5;
}
.PopupMenu .popupmenuitem,
.PopupMenu .popupmenuitem[status=focused]
{
	-nexa-padding 		: 10px 16px;
	border-radius 		: 8px;
}
.PopupMenu .popupmenuitem[status=disabled],
.PopupMenuControl .popupmenuitem[status=disabled]
{
	color 			: -nexa-define(--Txt_disB);
}
.PopupMenu .popupmenuitem[status=mouseover]
{
	background 		: -nexa-define(--Act_sechov);
}
.PopupMenu .popupmenuitem[userstatus=selected]
{
	background 		: -nexa-define(--Act_sechov);
	color 			: -nexa-define(--Txt_sec);
	font 			: -nexa-define(--Md);
}
.PopupMenu .popupmenuitem .popupmenuitemcheckbox,
.PopupMenu .popupmenuitem .popupmenuitemcheckbox[status=mouseover], 
.PopupMenu .popupmenuitem .popupmenuitemcheckbox[status=disabled]
{
	-nexa-icon 		: URL("theme://images/chk_WF_BoxO.png");
	-nexa-padding 		: 0px;
}
.PopupMenu .popupmenuitem .popupmenuitemhotkeytext,
.PopupMenu .popupmenuitem .popupmenuitemhotkeytext[status=mouseover],.PopupMenu .popupmenuitem .popupmenuitemhotkeytext[status=disabled]
{
	-nexa-padding 		: 0px 0px 0px 15px;
	color 			: -nexa-define(--Txt_disB);
	font 			: -nexa-define(--Xs);
}
.PopupMenu .popupmenuitem .popupmenuitemtext,
.PopupMenu .popupmenuitem .popupmenuitemtext[status=mouseover],.PopupMenu .popupmenuitem .popupmenuitemtext[status=disabled]
{
	-nexa-text-align 	: left;
	color 			: -nexa-define(--Txt_bas);
}
.PopupMenu .popupmenuitem .popupmenuitemexpandimage,
.PopupMenu .popupmenuitem .popupmenuitemexpandimage[status=mouseover],.PopupMenu .popupmenuitem .popupmenuitemexpandimage[status=disabled]
{
	-nexa-icon 		: URL("theme://images/pmnu_WF_SelBtn.png");
	-nexa-vertical-align 	: middle;
}
/***** PopupMenuControl(=.Menu .menupopupmenu) *****/
.PopupMenuControl,
.PopupMenuControl[status=mouseover],.PopupMenuControl[status=disabled]
{
	-nexa-border 		: -nexa-define(--Input_garylitnm);
	-nexa-padding 		: 16px;
	background 		: -nexa-define(--Input_sur);
	border-radius 		: 8px;
}
.PopupMenuControl .popupmenuitem,
.PopupMenuControl .popupmenuitem[status=focused]
{
	-nexa-padding 		: 10px 16px;
	border-radius 		: 8px;
}
.PopupMenuControl .popupmenuitem[status=mouseover]
{
	background 		: -nexa-define(--Act_sechov);
}
.PopupMenuControl .popupmenuitem[userstatus=selected]
{
	background 		: -nexa-define(--Act_secpres);
	color 			: -nexa-define(--Txt_sec);
	font 			: -nexa-define(--Md_b);	
}
.PopupMenuControl .popupmenuitem .popupmenuitemcheckbox,
.PopupMenuControl .popupmenuitem .popupmenuitemcheckbox[status=mouseover],.PopupMenuControl .popupmenuitem .popupmenuitemcheckbox[status=disabled]
{
	-nexa-icon 		: URL("theme://images/chk_WF_BoxO.png");
	-nexa-padding 		: 0px;
}
.PopupMenuControl .popupmenuitem .popupmenuitemtext,
.PopupMenuControl .popupmenuitem .popupmenuitemtext[status=mouseover],.PopupMenuControl .popupmenuitem .popupmenuitemtext[status=disabled]
{
	-nexa-text-align 	: left;
	color 			: -nexa-define(--Txt_bas);
}
.PopupMenuControl .popupmenuitem .popupmenuitemhotkeytext,
.PopupMenuControl .popupmenuitem .popupmenuitemhotkeytext[status=mouseover],.PopupMenuControl .popupmenuitem .popupmenuitemhotkeytext[status=disabled]
{
	-nexa-padding 		: 0px 0px 0px 15px;
	color 			: -nexa-define(--Txt_disB);
	font 			: -nexa-define(--Xs);	
}
/****** ProgressBar ****/
.ProgressBar,
.ProgressBar[status=mouseover],.ProgressBar[status=focused],
.ProgressBar[status=disabled],
.ProgressBarControl,
.ProgressBarControl[status=mouseover],.ProgressBarControl[status=focused],
.ProgressBarControl[status=disabled]
{
	background 		: -nexa-define(--Bg_dis);
	border-radius 		: 4px;
}
.ProgressBar .progressbaritem,
.ProgressBar .progressbaritem[status=mouseover],
.ProgressBarControl .progressbaritem,
.ProgressBarControl .progressbaritem[status=mouseover]
{
	background 		: -nexa-define(--Primary);
}
.ProgressBar .progressbaritem[status=disabled],
.ProgressBarControl .progressbaritem[status=disabled]
{
	background 		: -nexa-define(--Input_surdis);
}
.ProgressBar .progressbartext,
.ProgressBar .progressbartext[status=mouseover],.ProgressBar .progressbartext[status=disabled],
.ProgressBarControl .progressbartext,
.ProgressBarControl .progressbartext[status=mouseover],.ProgressBarControl .progressbartext[status=disabled]
{
	-nexa-padding 		: 0px 10px 0px 10px;
	color 			: -nexa-define(--Txt_inv);
	font 			: -nexa-define(--Sm);	
}
.ProgressBar .progressstartcap,
.ProgressBar .progressstartcap[status=mouseover],
.ProgressBarControl .progressstartcap,
.ProgressBarControl .progressstartcap[status=mouseover]
{
	background 		: -nexa-define(--Primary);
}
.ProgressBar .progressstartcap[status=disabled],
.ProgressBarControl .progressstartcap[status=disabled]
{
	background 		: -nexa-define(--Input_surdis);
}
.ProgressBar .progressendcap,
.ProgressBar .progressendcap[status=mouseover],
.ProgressBarControl .progressendcap,
.ProgressBarControl .progressendcap[status=mouseover]
{
	background 		: -nexa-define(--Primary);
}
.ProgressBar .progressendcap[status=disabled],
.ProgressBarControl .progressendcap[status=disabled]
{
	background 		: -nexa-define(--Input_surdis);
}
/***** Radio *****/
/*
.Radio
{
	-nexa-padding		: 2px;
}
.Radio[status=focused]
{
	-nexa-border 		: 2px solid #0B50D0;
	-nexa-padding		: 0px;
	border-radius 		: 6px;
}
*/
.Radio .radioitem
{
	-nexa-icon 		: URL("theme://images/rdo_WF_Item.png");
	-nexa-text-padding 	: 0px 24px 0px 8px;
}
.Radio .radioitem[status=mouseover],
.Radio .radioitem[status=mouseover][userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/rdo_WF_ItemO.png");
}
.Radio .radioitem[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/rdo_WF_ItemS.png");
}
.Radio .radioitem[status=readonly]
{
	-nexa-icon 		: URL("theme://images/rdo_WF_ItemD.png");
}
.Radio .radioitem[status=readonly][userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/rdo_WF_ItemSD.png");
}
.Radio .radioitem[status=disabled]
{
	-nexa-icon 		: URL("theme://images/rdo_WF_ItemD.png");
	color 			: -nexa-define(--Txt_dis);
}
.Radio .radioitem[status=disabled][userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/rdo_WF_ItemSD.png");
	color 			: -nexa-define(--Txt_dis);	
}
/***** Sketch *****/
.Sketch
{
}
/***** Spin *****/
.Spin
{
	-nexa-border 		: -nexa-define(--Input_nm);
	-nexa-padding 		: 1px;
	background 		: -nexa-define(--Input_sur);
	border-radius 		: 6px;
}
.Spin[status=mouseover],.Spin[status=focused]
{
	-nexa-border 		: -nexa-define(--Input_mo);
	-nexa-padding 		: 0px;
}
.Spin[status=readonly]
{
	-nexa-border 		: -nexa-define(--Input_dis);
	background 		: -nexa-define(--Input_surdis);
}
.Spin[status=disabled]
{
	-nexa-border 		: -nexa-define(--Input_dis);
	background 		: -nexa-define(--Input_surdis);
}
.Spin .spinedit,
.Spin .spinedit[status=mouseover],.Spin .spinedit[status=focused]
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 1px 8px 0px 14px;
	background 		: transparent;
}
.Spin .spinedit[userstatus=nulltext]
{
	color          		: -nexa-define(--Txt_dis);
}
.Spin .spinedit[status=readonly]
{
	-nexa-border 		: 0px none;
	color 			: -nexa-define(--Txt_sub);
}
.Spin .spinedit[status=disabled]
{
	-nexa-border 		: 0px none;
	color 			: -nexa-define(--Txt_disB);
}
.Spin .spindownbutton,
.Spin .spindownbutton[status=mouseover],.Spin .spindownbutton[status=focused],
.Spin .spindownbutton[userstatus=pushed],.Spin .spindownbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/spn_WF_DownBtn.png");
	-nexa-padding 		: 0px 0px 2px 0px;	
}
.Spin .spindownbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/spn_WF_DownBtnD.png");
}
.Spin .spinupbutton,
.Spin .spinupbutton[status=mouseover],.Spin .spinupbutton[status=focused],
.Spin .spinupbutton[userstatus=pushed],.Spin .spinupbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/spn_WF_UpBtn.png");
	-nexa-padding 		: 2px 0px 0px 0px;		
}
.Spin .spinupbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/spn_WF_UpBtnD.png");
}
.SpinControl,
.SpinControl[status=mouseover],.SpinControl[status=focused]
{
	-nexa-border 		: 0px none;
	background 		: -nexa-define(--Input_sur);
}
.SpinControl[status=disabled]
{
	background 		: -nexa-define(--Input_surdis);
}
.SpinControl .spindownbutton,
.SpinControl .spindownbutton[status=mouseover],.SpinControl .spindownbutton[status=focused],
.SpinControl .spindownbutton[userstatus=pushed],.SpinControl .spindownbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/spn_WF_DownBtn.png");
}
.SpinControl .spindownbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/spn_WF_DownBtnD.png");
}
.SpinControl .spinupbutton,
.SpinControl .spinupbutton[status=mouseover],.SpinControl .spinupbutton[status=focused],
.SpinControl .spinupbutton[userstatus=pushed],.SpinControl .spinupbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/spn_WF_UpBtn.png");
}
.SpinControl .spinupbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/spn_WF_UpBtnD.png");
}
.SpinControl .spinedit,
.SpinControl .spinedit[status=mouseover],.SpinControl .spinedit[status=focused],
.SpinControl .spinedit[status=readonly]
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px 4px 0px 0px;
	font 			: -nexa-define(--Md);
}
.SpinControl .spinedit[userstatus=nulltext]
{
	color          		: -nexa-define(--Txt_dis);
}
.SpinControl .spinedit[status=disabled]
{
	-nexa-border 		: 0px none;
	color 			: -nexa-define(--Txt_disB);
}

/***** Static *****/
.Static
{
	-nexa-word-wrap 	: char;
}
.Static[status=disabled]
{
	color 			: -nexa-define(--Txt_disB);
}
/***** Step *****/
.StepControl
{
	-nexa-padding 		: 0px 16px 20px 16px;
}
.StepControl .stepitem
{	
	background 		: #E6E8EA;
	border-radius 		: 10px;
}
.StepControl .stepitem[userstatus=selected]
{	
	background 		: -nexa-define(--Primary);
	color 			: -nexa-define(--Input_sur);
}
/***** Tab *****/
.Tab .prevbutton,
.Tab .prevbutton[status=focused]
{
	-nexa-icon 		: URL("theme://images/tab_WF_PreBtn.png");
	-nexa-padding 		: 10px;
	border-radius 		: 6px;
}
.Tab .prevbutton[status=mouseover],.Tab .prevbutton[userstatus=pushed],
.Tab .prevbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/tab_WF_PreBtn.png");
	background 		: -nexa-define(--Btn_Txtpufill);
}
.Tab .nextbutton,
.Tab .nextbutton[status=focused]
{
	-nexa-icon 		: URL("theme://images/tab_WF_NxtBtn.png");
	-nexa-padding 		: 10px;
	border-radius 		: 6px;	
}
.Tab .nextbutton[status=mouseover],.Tab .nextbutton[userstatus=pushed],
.Tab .nextbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/tab_WF_NxtBtn.png");
	background 		: -nexa-define(--Btn_Txtpufill);	
}
.Tab .tabbuttonitem,
.Tab .tabbuttonitem[status=focused],.Tab .tabbuttonitem[status=mouseover]
{
	-nexa-border 		: 0px none, 0px none, 1px solid #B1B8BE, 0px none;
	-nexa-padding 		: 0px 0px 1px 0px;
	background 		: -nexa-define(--Input_sur);
}
.Tab .tabbuttonitem[userstatus=selected]
{
	-nexa-border 		: 0px none, 0px none, 2px solid #063A74, 0px none;
	-nexa-padding 		: 0px;	
	background 		: -nexa-define(--Input_sur);
	color 			: -nexa-define(--Txt_sec);
}
.Tab .tabbuttonitem[status=disabled]
{
	background 		: -nexa-define(--Input_sur);
}
.Tab .tabbuttonitem .tabbuttonitemtext,
.Tab .tabbuttonitem .tabbuttonitemtext[status=mouseover]
{
	-nexa-padding 		: 0px 20px 0px 20px;
	-nexa-text-align 	: center;
	color 			: -nexa-define(--Txt_sub);
	font 			: -nexa-define(--Lg_b);
}
.Tab .tabbuttonitem .tabbuttonitemtext[status=disabled]
{
	color			: -nexa-define(--Txt_dis);
}
.Tab .tabbuttonitem .extrabutton,
.Tab .tabbuttonitem .extrabutton[status=mouseover],.Tab .tabbuttonitem .extrabutton[status=focused],
.Tab .tabbuttonitem .extrabutton[userstatus=pushed],.Tab .tabbuttonitem .extrabutton[userstatus=selected],
.Tab .tabbuttonitem .extrabutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/tag_WF_X.png");
	-nexa-icon-position	: top;
	-nexa-padding 		: 2px 10px 0px 0px;
}
.Tab .tabpage,
.Tab .tabpage[status=mouseover],.Tab .tabpage[status=focused],
.Tab .tabpage[status=disabled]
{
	-nexa-border 		: 0px none;
	background 		: -nexa-define(--Input_sur);
}
/***** TagBoxControl *****/
.TagBoxControl
{
	-nexa-border 		: -nexa-define(--Input_garylitnm);
	-nexa-padding 		: 8px 10px 8px 10px;
	border-radius		: 12px;
}
.TagBoxControl .tagbutton
{
	-nexa-border		: 0px none;
	-nexa-icon 		: URL("theme://images/tag_WF_X.png");
	-nexa-padding 		: 0px;
	background 		: transparent;
	border-radius		: 12px;
}
.TagBoxControl .tagbutton[status=mouseover]
{
	-nexa-icon 		: URL("theme://images/tag_WF_X.png");
	background 		: transparent;
}
.TagBoxControl .tagtext[status=disabled]
{
	color 			: -nexa-define(--Txt_disB);
}
/***** TextArea *****/
.TextArea,
.TextAreaControl
{
	-nexa-border 		: -nexa-define(--Input_nm);
	-nexa-padding 		: 7px 15px 7px 15px;
	-nexa-word-wrap		: char;
	background 		: -nexa-define(--Input_sur);
	border-radius 		: 6px;
}
.TextArea[status=mouseover],.TextArea[status=focused],
.TextAreaControl[status=mouseover],.TextAreaControl[status=focused]
{
	-nexa-border 		: -nexa-define(--Input_mo);
	-nexa-padding 		: 6px 14px 6px 14px;	
}
.TextArea[status=readonly],
.TextAreaControl[status=readonly]
{
	-nexa-border		: -nexa-define(--Input_dis);
	background 		: -nexa-define(--Input_surdis);
	color 			: -nexa-define(--Txt_sub);
}
.TextArea[userstatus=nulltext],
.TextAreaControl[userstatus=nulltext]
{
        color          		: -nexa-define(--Txt_dis);
}
.TextArea[status=disabled],
.TextAreaControl[status=disabled]
{
	-nexa-border 		: -nexa-define(--Input_dis);
	background 		: -nexa-define(--Input_surdis);
	color 			: -nexa-define(--Txt_disB);
}
/***** TextField *****/
.TextField .box
{
	-nexa-border 		: -nexa-define(--Input_nm);
	-nexa-padding 		: 2px 15px 1px 15px;
	background 		: -nexa-define(--Input_sur);
	border-radius 		: 6px;
}
.TextField .box[status=focused],.TextField .box[status=mouseover]
{
	-nexa-border 		: -nexa-define(--Input_mo);
	-nexa-padding 		: 1px 14px 0px 14px;	
}
.TextField .box[status=readonly]
{
	-nexa-border 		: -nexa-define(--Input_dis);
	background 		: -nexa-define(--Input_surdis);
	color 			: -nexa-define(--Txt_sub);
}
.TextField .box[status=disabled]
{
	-nexa-border 		: -nexa-define(--Input_dis);
	background 		: -nexa-define(--Input_surdis);
	color 			: -nexa-define(--Txt_disB);
}
.TextField .box[userstatus=invalid]
{
	-nexa-border 		: 2px solid #DE3412;	
}
.TextField .box .leadingbutton
{
	-nexa-padding 		: 0px 0px 0px 0px;
	background 		: URL("theme://images/sta_WF_Comment.png") no-repeat center center;
}
.TextField .box .trailingbutton
{
	background 		: URL("theme://images/txtf_WF_Cancel.png") no-repeat center center;
}
.TextField .box .trailingbutton[userstatus=invalid],
.TextField .box .trailingbutton[userstatus=invalid][status=focused],
.TextField .box .trailingbutton[userstatus=invalid][status=mouseover]
{
	background 		: URL("theme://images/img_WF_Invalid.png") no-repeat center center;
}
.TextField .box .trailingbutton[userstatus=valid],
.TextField .box .trailingbutton[userstatus=valid][status=focused],
.TextField .box .trailingbutton[userstatus=valid][status=mouseover]
{
	background 		: URL("theme://images/img_WF_Valid.png") no-repeat center center;
}
.TextField .charcounttext					
{									
	-nexa-padding 		: 8px 0px 0px 0px;
	-nexa-text-align 	: right;
	font 			: -nexa-define(--Sm);
}
.TextField .helpertext
{
	-nexa-padding 		: 8px 0px 0px 20px;
	background 		: URL("theme://images/txtf_WF_Infor.png") no-repeat left center;
	color 			: -nexa-define(--Txt_info);
	font 			: -nexa-define(--Xs);
}
.TextField .helpertext[userstatus=invalid]
{	
	background 		: URL("theme://images/txtf_WF_invalid.png") no-repeat left center;
	color 			: -nexa-define(--Txt_dang);		
}
.TextField .helpertext[userstatus=valid]
{	
	background 		: URL("theme://images/txtf_WF_valid.png") no-repeat left center;
	color 			: -nexa-define(--Txt_succ);
}
.TextField .label
{
	-nexa-padding 		: 1px 15px 0px 8px;
	background 		: transparent;
	color 			: -nexa-define(--Txt_bas);
	font 			: -nexa-define(--Sm);
}
.TextField .label[userstatus=floating]
{
	-nexa-padding 		: 0px 0px 8px 0px;	
	background 		: transparent;	
}
.TextField .label[status=focused][userstatus=floating],.TextField .label[status=mouseover][userstatus=floating],
.TextField .label[userstatus=floatingvalid],.TextField .label[userstatus=floatinginvalid]
{
	/***** same as userstatus=floating *****/
}
.TextField .label[status=disabled]
{
	-nexa-padding 		: 2px;
	color 			: -nexa-define(--Txt_disB);
}
.TextField .nulltext
{
	-nexa-padding 		: 1px 15px 0px 15px;
	color          		: -nexa-define(--Txt_dis);
}
/***** TimePickerControl *****/
.TimePickerControl
{	
	-nexa-padding 		: 10px 10px 10px 10px;
	background 		: -nexa-define(--Input_sur);
}
.TimePickerControl .ampmspinner
{	
	-nexa-padding 		: 0px 5px 0px 5px;
}
.TimePickerControl .delimiter
{
	-nexa-text-align 	: center;
}
.TimePickerControl .hourspinner .spinneritem,
.TimePickerControl .minspinner .spinneritem,
.TimePickerControl .secspinner .spinneritem
{
	-nexa-text-align 	: center;
}
.TimePickerControl .ampmspinner .spinneritem[userstatus=selected],
.TimePickerControl .hourspinner .spinneritem[userstatus=selected],
.TimePickerControl .minspinner .spinneritem[userstatus=selected],
.TimePickerControl .secspinner .spinneritem[userstatus=selected]
{
	font 			: -nexa-define(--Md_b);
}
.TimePickerControl .ampmspinner .overlaytop, 
.TimePickerControl .hourspinner .overlaytop, 
.TimePickerControl .minspinner .overlaytop, 
.TimePickerControl .secspinner .overlaytop
{
	-nexa-border 		: 0px none, 0px none, 1px solid #cccccc, 0px none;
	background 		: linear-gradient(to top,rgba(255,255,255, 0) 0%,#ffffff);
}
.TimePickerControl .ampmspinner .overlaybottom, 
.TimePickerControl .hourspinner .overlaybottom, 
.TimePickerControl .minspinner .overlaybottom, 
.TimePickerControl .secspinner .overlaybottom
{
	-nexa-border 		: 1px solid #cccccc, 0px none, 0px none, 0px none;        
	background 		: linear-gradient(to bottom,rgba(255,255,255, 0) 0%,#ffffff);	
}
/***** WebBrowser *****/
.WebBrowser
{
}
