        </Div>
        <Static id="Static00_00" taborder="5" text="전달받은 메시지" left="0" top="divSend:40" width="200" height="38" cssclass="sta_WF_H4_pc"/>
        <Grid id="grd00" taborder="6" left="0" top="Static00_00:16" right="0" binddataset="dsMessage" autofittype="col" bottom="0">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="80"/>
                <Column size="272"/>
              </Columns>
              <Rows>
                <Row size="39" band="head"/>
                <Row size="57"/>
              </Rows>
              <Band id="head">
                <Cell text="TOPIC_ID"/>
                <Cell col="1" text="MSG"/>
              </Band>
              <Band id="body">
                <Cell text="bind:TOPIC_ID"/>
                <Cell col="1" text="bind:MSG"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
