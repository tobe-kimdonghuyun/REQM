              <Combo id="cboTopicType" taborder="3" text="공지사항" left="112" top="5" width="180" height="48" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" value="0000" index="0">
                <Dataset id="innerdataset">
                  <ColumnInfo>
