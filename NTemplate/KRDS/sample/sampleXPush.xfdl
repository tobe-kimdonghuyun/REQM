              </Panel>
              <Static id="staTitle04_00_00" taborder="5" text="Topic Id" left="294" top="0" width="120" height="48" cssclass="sta_WF_SchDetail"/>
              <Combo id="cboTopicId" taborder="6" text="공지사항" left="406" top="5" width="180" height="48" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" value="0000" index="0">
                <Dataset id="innerdataset">
                  <ColumnInfo>
