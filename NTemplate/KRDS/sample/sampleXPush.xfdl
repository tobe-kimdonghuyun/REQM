    </Layouts>
    <Objects>
      <Dataset id="dsMessage">
        <ColumnInfo>
          <Column id="TOPIC_TYPE" type="STRING" size="256"/>
          <Column id="TOPIC_ID" type="STRING" size="256"/>
          <Column id="MSG" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <XPush id="XPush" layouturl="xpushUrl::pushMessageLayout.xml" onerror="XPush_onerror" onsuccess="XPush_onsuccess" protocolversion="3" debug="true"/>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  devPro
*  @FileName 	sampleXPush.xfdl
