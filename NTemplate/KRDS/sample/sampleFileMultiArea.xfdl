        <Static id="Static01" taborder="1" left="Static00:15" top="20" width="1" height="21" cssclass="sta_WF_line"/>
        <Static id="Static00_02" taborder="2" text="Upload" left="Static01:15" top="0" width="159" height="60" cssclass="sta_WF_ParaH4_pc"/>
        <Div id="divSearch" taborder="3" cssclass="div_WF_SchBar" text="" visible="false" left="0" top="100" height="128" right="0" fittocontents="height" accessibilityenable="false">
          <Layouts>
            <Layout type="horizontal" flexwrap="wrap" horizontalgap="24" verticalgap="16" spacing="40px 40px 40px 40px ">
              <Panel id="Panel00" taborder="0" left="0" top="0" width="226" height="48" flexgrow="1" visible="false">
                <Contents>
