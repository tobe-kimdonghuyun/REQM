          </Formats>
        </Grid>
        <Static id="staTitle00" taborder="6" text="이미지업로드" top="grdList:32" height="38" cssclass="sta_WF_H4_pc" left="0" flexgrow="1" accessibilityrole="heading3" right="0"/>
        <Panel id="Panel01" taborder="7" top="staTitle00:16" height="342" verticalgap="16" horizontalgap="24" left="0" right="0" spacing="40px 40px 40px 40px" fittocontents="height" flexwrap="wrap" cssclass="pnl_WF_Detailbox">
          <Contents>
            <PanelItem id="PanelItem00" componentid="div1"/>
            <PanelItem id="PanelItem01" componentid="div2"/>
