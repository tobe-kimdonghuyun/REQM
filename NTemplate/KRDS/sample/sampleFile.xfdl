        <Grid id="grdList" flexgrow="1"/>
        <Panel id="Panel02" flexgrow="1"/>
        <Panel id="Panel00" left="0" top="253" width="300" height="476"/>
        <Static id="Static00" cssclass="sta_WF_H2_m" width="52" left="0" top="0" height="60"/>
        <Static id="Static00_02" right="0" left="Static01:15" top="0" height="60" cssclass="sta_WF_ParaH4_m"/>
