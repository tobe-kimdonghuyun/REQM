        <Button id="btnFileSelect" taborder="12" text="파일선택" visible="true" onclick="btnFileupload_onclick" right="133" width="100" height="48" bottom="440"/>
        <Button id="btnFileSave" taborder="13" text="파일저장" width="100" right="0" onclick="btnFileSave_onclick" height="48" bottom="440"/>
        <Div id="Div00" taborder="14" text="Div00" left="0" top="0" width="100%" height="420">
          <Layouts>
            <Layout>
              <Grid id="grdUpload" taborder="0" top="0" binddataset="dsUpload" autofittype="col" oncellclick="grdUpload_oncellclick" ondrop="grdUpload_ondrop" left="0" ondragenter="grdUpload_ondragenter" ondragleave="grdUpload_ondragleave" bottom="0" right="0">
                <Formats>
