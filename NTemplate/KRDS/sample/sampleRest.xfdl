<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sampleRest" width="888" height="1500" titletext="Rest API 통신" onload="form_onload">
    <Layouts>
      <Layout height="1500" mobileorientation="landscape" width="888" screenid="Desktop_screen">
        <Static id="Static00" taborder="0" text="Rest API 통신" left="0" top="0" width="254" height="60" cssclass="sta_WF_H2_pc" fittocontents="width" accessibilityrole="heading2"/>
        <Static id="Static01" taborder="1" left="Static00:15" top="20" width="1" height="21" cssclass="sta_WF_line" accessibilityenable="false"/>
        <Static id="Static00_02" taborder="2" text="Rest API" left="Static01:15" top="0" width="115" height="60" cssclass="sta_WF_ParaH4_pc"/>
        <Div id="divSearch" taborder="3" left="0" top="100" height="128" cssclass="div_WF_SchBar" text="" right="0" accessibilityenable="false" tabstop="false" fittocontents="height">
          <Layouts>
            <Layout type="horizontal" flexwrap="wrap" spacing="40px 40px 40px 40px" horizontalgap="24" verticalgap="24">
              <Panel id="Panel02" taborder="0" left="0" top="0" width="520" height="48" flexwrap="wrap" horizontalgap="24" verticalgap="16" flexgrow="1" fittocontents="height">
                <Contents>
                  <PanelItem id="PanelItem00" componentid="Panel00"/>
                  <PanelItem id="PanelItem01" componentid="Panel01"/>
                </Contents>
              </Panel>
              <Panel id="Panel00" taborder="1" left="0" top="0" width="230" height="48" flexgrow="1">
                <Contents>
                  <PanelItem id="PanelItem00" componentid="staSearchTitle00"/>
                  <PanelItem id="PanelItem01" componentid="edtId"/>
                </Contents>
              </Panel>
              <Static id="staSearchTitle00" taborder="2" text="아이디" left="24" top="24" width="80" height="48" cssclass="sta_WF_SchDetail"/>
              <Edit id="edtId" taborder="3" left="80" top="24" width="160" height="48" accessibilitylabel="[@staSearchTitle00]" flexgrow="1"/>
              <Panel id="Panel01" taborder="4" left="274" top="0" width="230" height="48" flexgrow="1">
                <Contents>
                  <PanelItem id="PanelItem00" componentid="staSearchTitle01"/>
                  <PanelItem id="PanelItem01" componentid="edtName"/>
                </Contents>
              </Panel>
              <Static id="staSearchTitle01" taborder="5" text="성명" left="edtId:24" top="24" width="80" height="48" cssclass="sta_WF_SchDetail"/>
              <Edit id="edtName" taborder="6" left="80" top="24" width="160" height="48" accessibilitylabel="[@staSearchTitle01]" flexgrow="1"/>
              <Button id="btnSearch" taborder="7" text="조회" top="24" width="120" height="48" cssclass="btn_WF_Sch" onclick="divSearch_btnSearch_onclick" visible="true" left="743" flexgrow="0"/>
            </Layout>
            <Layout name="Layout0" spacing="23px 15px">
              <Panel id="Panel00" flexgrow="1"/>
              <Edit id="edtId" flexgrow="1"/>
              <Panel id="Panel02" left="0" top="0" width="100%" height="48"/>
              <Panel id="Panel01" flexgrow="1"/>
              <Edit id="edtName" flexgrow="1"/>
              <Button id="btnSearch" flexgrow="1"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staTitle" taborder="4" text="사용자 정보 조회" left="0" top="divSearch:40" width="342" height="38" cssclass="sta_WF_H4_pc"/>
        <Grid id="grdList" taborder="5" left="0" top="staTitle:16" binddataset="dsList" bottom="0" right="0" autoenter="select" cellsizingtype="col" uFunction="filterNew,sort" tabstop="false">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="84"/>
                <Column size="290"/>
                <Column size="217"/>
                <Column size="229"/>
                <Column size="414"/>
              </Columns>
              <Rows>
                <Row size="39" band="head"/>
                <Row size="57"/>
              </Rows>
              <Band id="head">
                <Cell displaytype="checkboxcontrol" edittype="checkbox"/>
                <Cell col="1" text="아이디"/>
                <Cell col="2" text="성명"/>
                <Cell col="3" text="부서"/>
                <Cell col="4" text="비고"/>
              </Band>
              <Band id="body">
                <Cell edittype="checkbox" displaytype="checkboxcontrol" text="bind:CHK"/>
                <Cell col="1" text="bind:SAMPLE_ID" displaytype="expr:dataset.getRowType(currow)=='2'?'editcontrol':'normal'" edittype="expr:dataset.getRowType(currow)=='2'?'text':'none'" editautoselect="true"/>
                <Cell col="2" text="bind:SAMPLE_NM" edittype="text" displaytype="editcontrol" editautoselect="true"/>
                <Cell col="3" text="bind:SAMPLE_DEPT_NM" edittype="text" displaytype="editcontrol" editautoselect="true"/>
                <Cell col="4" text="bind:SAMPLE_DESC" edittype="text" displaytype="editcontrol" editautoselect="true"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Div id="div00" taborder="6" text="div00" left="0" top="790" width="487" height="400" visible="true" tabstop="false" accessibilityenable="false" cssclass="div_WF_Detailbox">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" text=" Transaction 방식 TEST" left="12" top="4" width="460" height="39" cssclass="sta_WF_H4_pc"/>
              <Grid id="grdTr" taborder="1" left="12" top="49" autofittype="col" binddataset="dsList4" height="224" right="12">
                <Formats>
                  <Format id="default">
                    <Columns>
                      <Column size="80"/>
                      <Column size="80"/>
                      <Column size="80"/>
                      <Column size="80"/>
                      <Column size="80"/>
                      <Column size="80"/>
                    </Columns>
                    <Rows>
                      <Row size="39" band="head"/>
                      <Row size="57"/>
                    </Rows>
                    <Band id="head">
                      <Cell text="ID"/>
                      <Cell col="1" text="DESCRIPTION"/>
                      <Cell col="2" text="NAME"/>
                      <Cell col="3" text="ROWTYPE"/>
                      <Cell col="4" text="DEPARTMENT"/>
                      <Cell col="5" text="CHK"/>
                    </Band>
                    <Band id="body">
                      <Cell text="bind:SAMPLE_ID" edittype="normal"/>
                      <Cell col="1" text="bind:SAMPLE_DESC" edittype="normal"/>
                      <Cell col="2" text="bind:SAMPLE_NM" edittype="normal"/>
                      <Cell col="3" text="bind:ROWTYPE" edittype="normal"/>
                      <Cell col="4" text="bind:SAMPLE_DEPT_NM" edittype="normal"/>
                      <Cell col="5" text="bind:CHK" edittype="normal"/>
