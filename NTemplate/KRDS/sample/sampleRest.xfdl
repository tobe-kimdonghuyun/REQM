                  </Format>
                </Formats>
              </Grid>
              <Button id="btnSelectTr" taborder="2" text="select" left="12" top="282" width="100" height="105" onclick="btnSelectTr_onclick" cssclass="btn_WF_Custom" flexgrow="1"/>
              <Button id="btnAddTr" taborder="3" text="add" left="120" top="283" width="109" height="48" onclick="btnAddTr_onclick" flexgrow="1"/>
              <Button id="btnDelTr" taborder="4" text="delete" left="120" top="339" width="109" height="48" onclick="btnDelTr_onclick" flexgrow="1"/>
              <Button id="btnUpdate" taborder="5" text="updateSave" left="237" top="283" width="127" height="48" onclick="btnUpdate_onclick" flexgrow="1"/>
              <Button id="btnDelete" taborder="6" text="deleteSave" left="237" top="339" width="127" height="48" onclick="btnDelete_onclick" flexgrow="1"/>
              <Panel id="Panel00" taborder="7" left="120" top="283" width="109" height="104" type="horizontal" flexwrap="wrap" verticalgap="8" horizontalgap="8" flexgrow="1">
                <Contents>
                  <PanelItem id="PanelItem00" componentid="btnAddTr"/>
                  <PanelItem id="PanelItem01" componentid="btnDelTr"/>
