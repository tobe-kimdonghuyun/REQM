              <Band id="body">
                <Cell text="bind:Column0"/>
                <Cell col="1" text="bind:Column1"/>
                <Cell col="2" text="bind:Column2"/>
                <Cell row="1" colspan="2" text="bind:Column3"/>
                <Cell row="1" col="2" text="bind:Column4"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="Static05" taborder="9" text="열고정, 행고정" left="0" top="Panel01:40" height="36" cssclass="sta_WF_ParaH4_pc" fittocontents="height" right="0" accessibilityrole="heading4"/>
