    <Script type="xscript5.1"><![CDATA[this.Component_02_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.fnTest();
};

this.fnTest = function()
{
	let nNumWidth = 240;
	let nHeight = 46;
	let nTermBtn = 1;
	let nTop = 0;
	
	
	let oFocusBtn = null;
	for(let i=0; i<4; i++ )
	{
		objBtnPage = new Button("btnPage"+i,  0, nTop, nNumWidth, nHeight, null, null);   
		this.Div00.form.Div00.form.addChild(objBtnPage.name, objBtnPage);
		objBtnPage.cssclass = "btn_TF_Lastdep";
		objBtnPage.text = "btnPage"+i;
		objBtnPage.show();

		//부모div 에  flexgrow="1"  border="1px solid red" fittocontents="height type="horizontal" flexwrap="wrap" horizontalgap="24" verticalgap="8"
		
  		objBtnPage.fittocontents = "height";
  		objBtnPage.minheight = 46;	
 		objBtnPage.verticalAlign = "middle";

		nTop = nTop + nHeight + nTermBtn;
	}    

};
]]></Script>
  </Form>
</FDL>
