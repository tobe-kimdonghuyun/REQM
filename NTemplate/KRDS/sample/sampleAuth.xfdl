this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.gfnFormOnload(obj,e); //필수함수
	
	// 엑셀 버튼 권한 제어
	this.gfnSetCommBtn(this.divCmmnBtn);
};

