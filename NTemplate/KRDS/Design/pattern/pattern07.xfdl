<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="pattern07" width="888" height="1480" titletext="오류" onload="pattern07_onload">
    <Layouts>
      <Layout height="1480" mobileorientation="landscape" width="888" screenid="Desktop_screen">
        <Static id="staH2" taborder="0" text="오류" left="0" top="0" width="70" height="60" cssclass="sta_WF_H2_pc" fittocontents="width" accessibilityrole="heading2"/>
        <Static id="staDivider" taborder="1" left="staH2:15" top="20" width="1" height="21" cssclass="sta_WF_line"/>
        <Static id="staEtit" taborder="2" text="User Feedback" left="staDivider:15" top="15" height="30" cssclass="sta_WF_ParaH4_pc" right="0"/>
        <Static id="Static00" taborder="3" text="오류는 사용자가 요청한 작업을 시스템이 완료하지 못하는 문제가 발생했을 때 제공된다. 발생 가능한 문제를 사전에 안내하는 경고와는 달리, 오류는 이미 발생한 문제에 관한 정보를 사용자에게 알려준다. 오류 정보는 단순히 사용자에게 문제가 발생했음을 알려주는 데 그치지 않고 본래 수행하고자 했던 행동을 완수할 수 있게 유도해야 한다. 오류 정보를 제공하기 위해 별도의 모달을 사용하거나 오류가 발생한 지점에 직접 메시지를 전달할 수 있다." left="0" top="85" height="178" cssclass="sta_WF_Descript" right="0" fittocontents="height"/>
        <Static id="Static00_00" taborder="4" text="유형" left="0" top="Static00:80" height="60" cssclass="sta_WF_H2_pc" accessibilityrole="heading3" right="0"/>
        <Static id="Static00_00_00" taborder="5" text="인라인 메시지" left="0" top="Static00_00:24" height="24" cssclass="sta_WF_H5" accessibilityrole="heading4" right="0"/>
        <Div id="Div00" taborder="6" text="Div00" left="0" top="Static00_00_00:24" height="300" right="0" cssclass="div_GUIDE_SubBg" accessibilityenable="false" tabstop="false">
          <Layouts>
            <Layout type="vertical" verticalgap="8" flexmainaxisalign="center" flexcrossaxisalign="center">
              <Static id="Static01_01_02_01" taborder="0" text="레이블" left="84" top="47" width="280" height="23" cssclass="sta_WF_Lable15R"/>
