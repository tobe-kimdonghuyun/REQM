    <Layouts>
      <Layout height="3030" mobileorientation="landscape" width="888" screenid="Desktop_screen">
        <Static id="staH2" taborder="0" text="상세 정보 확인" left="0" top="0" width="235" height="60" cssclass="sta_WF_H2_pc" fittocontents="width" accessibilityrole="heading2"/>
        <Static id="staDivider" taborder="1" left="staH2:15" top="20" width="1" height="21" cssclass="sta_WF_line" accessibilityenable="false"/>
        <Static id="staEtit" taborder="2" text="Check Detail" left="staDivider:15" top="15" height="30" cssclass="sta_WF_ParaH4_pc" right="0"/>
        <Static id="Static00" taborder="3" text="상세 정보는 특정한 주제에 관한 정보를 제공하는 패턴으로, 효과적인 정보 전달을 위해 텍스트 이외에 다양한 시각적 요소들이 활용된다. 사용자들은 콘텐츠 목록에서 콘텐츠 제목이나 요약 정보를 포함한 링크를 통해 상세 정보에 접근하기 때문에, 사용자가 예상하는 정보를 명확하고 간결하게 전달할 수 있어야 한다." left="0" top="85" height="126" cssclass="sta_WF_Descript" right="0" fittocontents="height"/>
        <Static id="Static00_01" taborder="4" text="구조" left="0" top="Static00:80" width="150" height="60" cssclass="sta_WF_H2_pc" accessibilityrole="heading3" fittocontents="width"/>
