                <Layouts>
                  <Layout>
                    <Static id="Static04" taborder="0" text="의견을 남겨주셔서 감사합니다." left="16" top="18" width="300" height="26" cssclass="sta_POP_SuccTxt"/>
                    <Static id="Static00" taborder="1" text="보내주신 소중한 의견은 페이지 개선에 도움이 됩니다." left="48" top="52" height="26" fittocontents="height" cssclass="sta_WF_aliTop" right="40"/>
