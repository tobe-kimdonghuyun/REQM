                  <PanelItem id="PanelItem02" componentid="CheckBox00_01"/>
                  <PanelItem id="PanelItem03" componentid="CheckBox00_02"/>
                </Contents>
              </Panel>
              <Static id="Static06_01_00" taborder="12" text="2.   기타 제안 사항이 있다면 작성해주세요. (선택 입력)" left="50" top="162" width="100%" height="26" onclick="Static06_01_onclick" cssclass="sta_WF_AliTop" fittocontents="height"/>
              <MultiLineTextField id="MultiLineTextField03" taborder="13" left="0" top="897" width="100%" height="190" labelposition="overlap" displaynulltext="내용을 입력하세요" usecharcount="true" maxlength="300" readonly="false"/>
              <Button id="Button00_01" taborder="14" text="취소" left="514" top="16" width="112" height="48"/>
              <Button id="Button00_00_00" taborder="15" text="평가완료" cssclass="btn_WF_Crud01" left="600" top="16" width="112" height="48"/>
