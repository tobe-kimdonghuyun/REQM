                    <Static id="Static06_00" taborder="3" text="약관동의" left="39" top="Static00:20" height="29" positionstep="0" maxwidth="" cssclass="sta_WF_H5" tablecellarea="0/0" flexgrow="1" right="39" accessibilityrole="heading5"/>
                    <Panel id="Panel00" taborder="4" left="39" top="Static06_00:20" height="220" cssclass="pnl_WF_Gbox" spacing="39px 39px 39px 39px" type="vertical" verticalgap="16" right="39">
                      <Contents>
                        <PanelItem id="PanelItem00" componentid="CheckBox00"/>
                        <PanelItem id="PanelItem01" componentid="Static02"/>
                      </Contents>
                    </Panel>
                    <CheckBox id="CheckBox00" taborder="5" text="모두 동의합니다." left="62" top="211" width="160" height="38" cssclass="chk_WF_Agree"/>
                    <Static id="Static02" taborder="6" text="민간정보 수집이용, 개인정보의 수집 및 이용, 온라인신청 서비스 정책, 고유식별정보 수집 및 이용 항목에 대해 모두 동의합니다. 각 사항에 대한 동의 여부를 개별적으로 선택하실 수 있으며, 선택 동의 사항에 대한 동의를 거부하여도 서비스를 이용하실 수 있습니다." left="16" top="16" width="100%" height="126" cssclass="sta_WF_Top"/>
                    <Static id="StaH5" taborder="7" text="[필수] 민감정보 수집이용" left="39" top="Panel00:16" height="26" positionstep="0" maxwidth="" cssclass="sta_WF_Txt17B" tablecellarea="0/0" flexgrow="1" right="39" accessibilityrole="heading5"/>
                    <Panel id="Panel01" taborder="8" left="39" top="StaH5:16" height="372" cssclass="pnl_WF_Detailbox" type="vertical" verticalgap="2" right="39" fittocontents="height" spacing="39px 39px 39px 39px">
                      <Contents>
                        <PanelItem id="PanelItem00" componentid="Static03"/>
                        <PanelItem id="PanelItem01" componentid="Static06_01"/>
