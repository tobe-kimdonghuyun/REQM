                        <PanelItem id="PanelItem03" componentid="Static06_01_00_00"/>
                        <PanelItem id="PanelItem04" componentid="Static06_01_00_00_00"/>
                      </Contents>
                    </Panel>
                    <Static id="Static03" taborder="9" text="약관동의 및 개인정보수집이용동의" left="100" top="524" width="100%" height="32" cssclass="sta_WF_H4" fittocontents="height"/>
                    <Static id="Static06_01" taborder="10" text="1.   수집이용하는 개인정보의 항목 :  장애정보&#13;&#10;2.   민감정보의 보유 및 이용기간 :" left="86" top="534" width="100%" height="72" cssclass="sta_WF_TxtlstOL01" onclick="Static06_01_onclick" fittocontents="height"/>
                    <Static id="Static06_01_00" taborder="11" text="⦁   보유근거 : 사회보장급여의 이용제공 및 수급권자 발굴에 관한 법률 7조&#13;&#10;⦁   보존기간:" left="49" top="86" width="100%" height="64" cssclass="sta_WF_TxtlstLv02" onclick="Static06_01_onclick" fittocontents="height"/>
                    <Static id="Static06_01_00_00" taborder="12" text="-   신청정보(신청 상세정보) : 결과통보일로부터 90일&#13;&#10;-   신청이력(신청 결과 내역) : 5년" left="49" top="169" width="100%" height="64" cssclass="sta_WF_TxtlstLv03" onclick="Static06_01_onclick" fittocontents="height"/>
                    <Static id="Static06_01_00_00_00" taborder="13" text="이용자는 온라인 신청의 민감정보 수집 및 이용 동의를 거부할 권리가 있습니다. 다만, 민감정보의 수집 및 이용을 거부할 경우 해당 서비스를 이용할 수 없음을 알려드립니다." left="49" top="303" width="100%" height="52" onclick="Static06_01_onclick" cssclass="sta_WF_AliTop" fittocontents="height"/>
                    <Panel id="Panel02" taborder="14" left="39" top="Panel01:24" height="74" cssclass="pnl_WF_Agreebox" spacing="24px" flexwrap="wrap" verticalgap="16" right="39" flexmainaxisalign="spacebetween" fittocontents="height">
