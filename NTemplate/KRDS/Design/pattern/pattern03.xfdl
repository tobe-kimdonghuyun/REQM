      <Layout height="3000" width="888" screenid="Desktop_screen">
        <Static id="staH2" taborder="0" text="동의" left="0" top="0" width="70" height="60" cssclass="sta_WF_H2_pc" fittocontents="width" accessibilityrole="heading2"/>
        <Static id="staDivider" taborder="1" left="staH2:15" top="20" width="1" height="21" cssclass="sta_WF_line" accessibilityenable="false"/>
        <Static id="staEtit" taborder="2" text="Agree" left="staDivider:15" top="0" height="60" cssclass="sta_WF_ParaH4_pc" right="0"/>
        <Static id="staDescript" taborder="3" text="동의는 웹사이트의 이용 조건 및 절차 등을 명시한 내용을 읽고 동의 여부나 안내 사항의 확인 여부를 확인하는 데 사용되는 패턴이다. 대개 동의가 필요한 약관은 일반적으로 잘 사용되지 않는 용어로 작성되며 양이 매우 방대하므로 사용자의 이해를 도울 수 있도록 요소들을 알기 쉽게 구조화해야 한다." left="0" top="85" height="126" cssclass="sta_WF_Descript" right="0" fittocontents="height"/>
        <Static id="staTit" taborder="4" text="구조" left="0" top="staDescript:80" height="60" cssclass="sta_WF_H2_pc" accessibilityrole="heading3" right="0"/>
        <Div id="Div00" taborder="5" text="Div00" left="0" top="staTit:24" height="1120" right="0" cssclass="div_GUIDE_SubBg" fittocontents="height" accessibilityenable="false" tabstop="false">
          <Layouts>
            <Layout type="vertical" flexmainaxisalign="start" flexcrossaxisalign="center" spacing="40px 0px">
