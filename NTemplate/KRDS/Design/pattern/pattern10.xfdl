        <Static id="Static07" taborder="78" text="고용노동부, 정부혁신과 적극행정 우수사례를 확산하고, 일하는 방식 개선을 통해 정부혁신을 속도감 있게 추진" left="351" top="4571" height="52" cssclass="sta_WF_Txt19B" width="100%" fittocontents="height"/>
        <Static id="Static07_00" taborder="79" left="351" top="4635" height="108" text="또 다른 최우수 사례로 선정된 “외국인 근로자 퇴직금 자동환급제”는 외국인 근로자가 최초 입국 시 사전 등록한 계좌에 퇴직금(출국만기보험)을 자동 지급함으로써 송출국가의 열악한 금융환경 등으로 퇴직금(출국만기보험)이 미지급되는 문제점을 개선하여 외국인 근로자의 권리구제에" cssclass="sta_WF_Para17RG" width="100%"/>
        <ImageViewer id="ImageViewer00" taborder="80" left="353" top="4749" width="180" height="110" cssclass="img_WF_Radius" image="url('theme::NexaKRDS/images/img_WF_Thumbnail.png')" accessibilitylabel="고용노동부 현장 이미지"/>
