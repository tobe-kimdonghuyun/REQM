        <Static id="Static03" taborder="13" text="통합 로그인을 사용해 보세요. 통합 로그인은 한 번의 회원가입과 로그인으로 연계된 모든 공공 서비스를 이용할 수 있는 인증 서비스입니다. &#13;&#10;한 번 로그인으로 모든 정부기관의 서비스를 이용하실 수 있습니다. " left="0" top="Static00_01_01:24" height="87" cssclass="sta_WF_Para19RTop" right="0"/>
        <CheckBox id="CheckBox01" taborder="14" text="통합 로그인 사용" left="154" top="266" width="168" height="30" cssclass="chk_WF_Switch"/>
