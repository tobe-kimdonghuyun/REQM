        <Static id="staEtit" taborder="2" text="Confirm" left="staDivider:15" top="15" width="129" height="30" cssclass="sta_WF_ParaH4_pc"/>
        <Static id="Static00" taborder="3" text="확인은 사용자가 요청한 행위가 쉽게 취소할 수 없는 결과로 이어지거나, 행동의 효과 또는 부작용을 사용자가 인지해야 하는 경우에 사용한다. 사용자가 작업 내용을 확인하거나 수행을 승인하도록 함으로써, 어떤 작업이 수행될 것인지에 관한 불확실성을 감소시키고 내용을 한 번 더 점검할 수 있어 오류를 예방할 수 있다." left="0" top="85" height="126" cssclass="sta_WF_Descript" right="0" fittocontents="height"/>
        <Static id="Static00_00" taborder="4" text="유형" left="0" top="Static00:80" height="60" cssclass="sta_WF_H2_pc" accessibilityrole="heading3" right="0"/>
