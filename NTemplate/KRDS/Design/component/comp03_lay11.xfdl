                <Cell col="1" text="제목"/>
                <Cell col="2" text="제목"/>
              </Band>
              <Band id="body">
                <Cell text="bind:content01"/>
                <Cell col="1" text="bind:content02"/>
                <Cell col="2" text="bind:context"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Grid id="Grid00_00" taborder="5" left="0" top="Grid00:60" height="560" binddataset="ds_gridSample" right="0" accessibilitylabel="데이플 제목 : 체크박스, 에디트, 마스크, 콤보, 버튼, 익스펜드, 에센셜, 캘린더, 포인트로 구성된 표입니다" showcellselection="true" showselection="false">
