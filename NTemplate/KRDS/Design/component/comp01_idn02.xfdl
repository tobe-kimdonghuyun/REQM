        <Panel id="Panel02" taborder="9" left="0" top="Panel01:80" height="40" right="0" cssclass="pnl_BF_IdentiB" type="horizontal" fittocontents="height" flexwrap="wrap" flexcrossaxiswrapalign="center" spacing="8px 16px 8px 16px" horizontalgap="8" verticalgap="4">
