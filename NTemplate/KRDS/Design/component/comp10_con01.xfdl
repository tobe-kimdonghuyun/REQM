<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="con01" width="888" height="880" titletext="콘텐츠_접근 가능한 미디어" onload="con01_onload">
    <Layouts>
      <Layout height="880" width="888" screenid="Desktop_screen">
        <Static id="staDivider" taborder="0" left="316" top="19" width="1" height="21" cssclass="sta_WF_line" accessibilityenable="false" visible="true"/>
        <Static id="staEtit" taborder="1" text="Accessible Multimedia" left="staDivider:15" top="0" width="279" height="60" cssclass="sta_WF_ParaH4_pc" onclick="Div01_01_Static00_02_onclick"/>
        <Static id="staH2" taborder="2" text="접근 가능한 미디어" left="0" top="0" width="300" height="60" cssclass="sta_WF_H2_pc" fittocontents="width" accessibilityrole="heading2"/>
        <Panel id="Panel00" taborder="3" left="0" top="0" height="60" flexcrossaxisalign="center" flexwrap="wrap" verticalgap="0" horizontalgap="16" right="0">
          <Contents>
            <PanelItem id="PanelItem00" componentid="staH2"/>
            <PanelItem id="PanelItem01" componentid="staDivider"/>
            <PanelItem id="PanelItem02" componentid="staEtit"/>
          </Contents>
        </Panel>
        <Static id="Static00_01_00_02" taborder="4" text="미디어 콘텐츠에 설명이 필요한 경우에 사용하는 컴포넌트이다. 정지된 이미지에 설명을 제공할 때에는 숨김 콘텐츠를, 오디오/비디오/멀티미디어 콘텐츠에 설명을 제공할 때는 접근 가능한 미디어 컴포넌트를 사용한다." left="0" top="Panel00:25" height="100" cssclass="sta_WF_Descript" fittocontents="height" right="0"/>
        <Static id="Static00_02_00" taborder="5" text="유형" left="0" top="Static00_01_00_02:80" height="60" cssclass="sta_WF_ParaH2_pc" onclick="Div01_01_Static00_02_onclick" right="0" accessibilityrole="heading3"/>
        <Static id="Static00_02" taborder="6" text="콘텐츠" left="0" top="Static00_02_00:24" height="48" cssclass="sta_WF_ParaH3_pc" onclick="Div01_01_Static00_02_onclick" right="0" accessibilityrole="heading4"/>
        <Static id="Static00_02_01" taborder="7" text="오디오 콘텐츠" left="0" top="Static00_02:16" height="36" cssclass="sta_WF_ParaH5" onclick="Div01_01_Static00_02_onclick" right="0" accessibilityrole="heading5"/>
        <Static id="Static00" taborder="8" text="청각적 정보만으로 구성된 미디어 콘텐츠이다. 만약 비디오가 포함되었다고 하더라도 해당 비디오가 단순 커버 이미지인 경우, 오디오 콘텐츠로 간주한다. 캡션 또는 단순 원고(Simple transcripts)를 대체 정보로 제공해야 한다." left="0" top="Static00_02_01:11" height="50" right="0" fittocontents="height"/>
        <Static id="Static00_02_01_00" taborder="9" text="비디오 콘텐츠" left="0" top="Static00:24" width="233" height="36" cssclass="sta_WF_ParaH5" onclick="Div01_01_Static00_02_onclick" accessibilityrole="heading5"/>
        <Static id="Static00_00" taborder="10" text="소리 없이 화면만으로 구성된 미디어 콘텐츠이다. 만약 오디오가 포함되었다고 하더라도 단순 배경음인 경우, 비디오 콘텐츠로 간주한다. 화면 해설 또는 설명적 원고를 대체 정보로 제공해야 한다." left="0" top="Static00_02_01_00:16" height="50" right="0" fittocontents="height"/>
        <Static id="Static00_02_01_00_00" taborder="11" text="멀티미디어 콘텐츠" left="0" top="Static00_00:24" width="233" height="36" cssclass="sta_WF_ParaH5" onclick="Div01_01_Static00_02_onclick" accessibilityrole="heading5"/>
        <Static id="Static00_00_00" taborder="12" text="오디오, 비디오를 모두 포함한 미디어 콘텐츠이다. 콘텐츠의 복잡성, 중요도에 따라 여러 가지 대체 정보를 복합적으로 제공해야 한다." left="0" top="Static00_02_01_00_00:16" height="24" right="0" fittocontents="height"/>
      </Layout>
      <Layout height="990" mobileorientation="Landscape" name="Layout0" type="default" width="480" screenid="Desktop_screen,mobile_small">
        <Static id="Static00_01_00_02" left="0" top="staEtit:25" height="152" right="0"/>
        <Static id="staEtit" left="1" top="60" width="279" height="60" text="Accessible Multimedia"/>
        <Static id="staDivider" visible="false"/>
        <Static id="Static00_00_00" left="0" top="Static00_02_01_00_00:11" height="78" right="10"/>
        <Static id="Static00_00" left="0" top="Static00_02_01_00:11" height="104" right="0"/>
        <Static id="staH2" cssclass="sta_WF_H2_m" width="210" left="0" top="0" height="60"/>
        <Panel id="Panel00" left="0" top="0" height="120" right="0"/>
        <Static id="Static00_02_00" cssclass="sta_WF_ParaH2_m" top="Static00_01_00_02:60" left="0" height="60" right="0"/>
        <Static id="Static00_02" cssclass="sta_WF_ParaH3_m"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
this.con01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.gfnFormOnload(obj,e); //필수함수
};
]]></Script>
  </Form>
</FDL>
