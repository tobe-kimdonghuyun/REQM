<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="con02" width="888" height="720" titletext="콘텐츠_숨긴 콘텐츠" onload="con02_onload">
    <Layouts>
      <Layout height="720" width="888" screenid="Desktop_screen">
        <Static id="staH2" taborder="0" text="숨긴 콘텐츠" left="0" top="0" width="190" height="60" cssclass="sta_WF_H2_pc" fittocontents="width" accessibilityrole="heading2"/>
        <Static id="staDivider" taborder="1" left="staH2:15" top="20" width="1" height="21" cssclass="sta_WF_line" accessibilityenable="false"/>
        <Static id="staEtit" taborder="2" left="staDivider:15" top="0" width="199" height="60" cssclass="sta_WF_ParaH4_pc" onclick="Div01_01_Static00_02_onclick" text="Visually hidden"/>
        <Static id="Static00_01_00_02" taborder="3" text="숨긴 콘텐츠는 화면에는 보이지 않지만, 스크린 리더 사용자는 읽을 수 있도록 설계된 컴포넌트이다. 정안 사용자에게는 불필요한 설명을 제공하지 않으면서 스크린 리더 사용자에게는 시각적 콘텐츠, 상호작용 상태 등에 대한 추가적인 정보를 전달할 수 있다." left="0" top="85" height="126" cssclass="sta_WF_Descript" fittocontents="height" right="0"/>
        <Static id="Static00_02_00" taborder="6" text="용례" left="0" top="Static00_01_00_02:80" height="48" cssclass="sta_WF_ParaH2_pc" onclick="Div01_01_Static00_02_onclick" right="0" accessibilityrole="heading3"/>
        <Static id="Static00_02" taborder="4" text="사용하기 적합한 경우" left="0" top="Static00_02_00:48" height="40" cssclass="sta_WF_ParaH3_pc" onclick="Div01_01_Static00_02_onclick" right="0" accessibilityrole="heading4"/>
        <Static id="Static06" taborder="5" text="⦁   텍스트가 아닌 콘텐츠에 대한 복잡한 설명을 제공하는 경우&#13;&#10;⦁   지시 사항을 전달하거나 조작 방식을 설명하는 경우&#13;&#10;⦁   요소나 화면의 상태 변화에 대한 정보를 전달하는 경우" left="0" top="Static00_02:16" height="114" cssclass="sta_WF_TxtlstULv01" right="0" fittocontents="height"/>
      </Layout>
      <Layout height="720" mobileorientation="Landscape" name="Layout0" type="default" width="480" screenid="mobile_small,Desktop_screen">
        <Static id="staH2" cssclass="sta_WF_H2_m" width="132" left="0" top="0" height="60"/>
        <Static id="staEtit" cssclass="sta_WF_ParaH4_m" right="0" left="staDivider:15" top="0" height="60"/>
        <Static id="Static00_01_00_02" left="0" top="85" height="178" right="0"/>
        <Static id="Static00_02_00" text="용례" cssclass="sta_WF_ParaH2_m"/>
        <Static id="Static00_02" top="Static00_02_00:24" left="0" height="40" right="0" cssclass="sta_WF_ParaH3_m"/>
        <Static id="Static06" top="Static00_02:12" left="0" height="114" right="0"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
this.con02_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
