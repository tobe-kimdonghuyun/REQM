        <CheckBox id="CheckBox00_01_01" taborder="16" text="체크박스" left="0" top="CheckBox00_01:40" width="200" height="30" cssclass="chk_WF_Boxind" value="true"/>
        <CheckBox id="CheckBox00_01_00_00" taborder="17" text="체크박스" left="0" top="CheckBox00_01_01:40" width="200" height="30" cssclass="chk_WF_Boxind" value="true" readonly="true"/>
