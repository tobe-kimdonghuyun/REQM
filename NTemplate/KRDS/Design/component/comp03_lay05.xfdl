<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="lay05" width="888" height="1600" titletext="레이아웃 및 표현_모달" cssclass="btn_WF_Txt" onload="lay05_onload">
    <Layouts>
      <Layout height="1600" width="888" screenid="Desktop_screen">
        <Static id="staH2" taborder="0" text="모달" left="0" top="0" width="70" height="60" cssclass="sta_WF_H2_pc" fittocontents="width" accessibilityrole="heading2" tabstop="false"/>
        <Static id="staDivider" taborder="1" left="staH2:15" top="20" width="1" height="21" cssclass="sta_WF_line" accessibilityenable="false"/>
        <Static id="staEtit" taborder="2" text="Modal" left="staDivider:15" top="0" width="90" height="60" cssclass="sta_WF_ParaH4_pc" onclick="Div01_01_Static00_02_onclick" fittocontents="width"/>
        <Static id="Static00_01_00" taborder="3" text="모달은 대화창의 한 종류로 기본 창에 종속된 요소이다. 기본 창과 겹쳐져 가장 상단에 표시되며, 이때 기본 창은 비활성 상태로 전환되어 상호작용이 불가능하므로 사용자는 모달에서의 단일한 과업 또는 메시지에 집중할 수 있다." left="0" top="85" height="126" cssclass="sta_WF_Descript" fittocontents="height" right="0"/>
        <Div id="Div00" taborder="4" text="Div00" left="0" top="Static00_01_00:100" width="760" height="340">
          <Layouts>
            <Layout>
              <Static id="Static01_01" taborder="0" left="0" top="0" cssclass="sta_POP_Bg" text="" right="0" bottom="0"/>
              <Static id="Static00_00" taborder="1" text="타이틀" left="40" top="56" height="36" cssclass="sta_WF_H4" right="40" accessibilityrole="heading2"/>
              <TextArea id="TextArea00" taborder="2" left="40" top="108" height="142" cssclass="output" value="대화 상자는 사용자에게 작업에 대해 알리고 중요한 정보를 포함하거나 결정이 필요하거나 여러 작업을 포함할 수 있습니다. 대화 상자는 사용자에게 작업에 대해 알리고 중요한 정보를 포함하거나 결정이 필요하거나 여러 작업을 포함할 수 있습니다. " right="40"/>
              <Button id="Button01_00_00" taborder="3" text="확인" height="48" cssclass="btn_WF_Crud01" top="252" right="142" width="90"/>
              <Button id="Button01_01" taborder="4" text="취소" width="90" height="48" right="40" top="252"/>
              <Button id="Button00_01" taborder="5" top="24" height="40" cssclass="btn_POP_Cancel" width="40" right="24"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="Static01_01" left="0" top="0" right="0" bottom="0"/>
