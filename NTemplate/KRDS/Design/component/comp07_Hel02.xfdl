<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="hel02" width="888" height="1400" titletext="도움_따라하기 패널" onload="hel02_onload">
    <Layouts>
      <Layout height="1400" width="888" screenid="Desktop_screen">
        <Static id="staH2" taborder="0" text="따라하기 패널" left="0" top="0" width="220" height="60" cssclass="sta_WF_H2_pc" fittocontents="width" accessibilityrole="heading2"/>
        <Static id="staDivider" taborder="1" left="staH2:15" top="20" width="1" height="21" cssclass="sta_WF_line" accessibilityenable="false"/>
        <Static id="staEtit" taborder="2" text="Tutorial panel" left="staDivider:15" top="15" width="200" height="30" cssclass="sta_WF_ParaH4_pc" onclick="Div01_01_Static00_02_onclick"/>
        <Static id="Static00_01_00_02" taborder="3" text="따라하기 패널은 본문 콘텐츠와 관련된 이용 방법을 실제 이용 절차에 따라 단계적으로 수행할 수 있도록 도와주며 코치마크를 실행하는 데 사용되는 사이드 패널이다." left="0" top="85" height="100" cssclass="sta_WF_Descript" fittocontents="height" right="0"/>
        <Button id="Button00" taborder="4" text="도움말" left="0" top="Static00_01_00_02:80" width="91" height="40" cssclass="btn_WF_OpenHelp"/>
        <Div id="Div00_00" taborder="5" left="0" top="Button00:40" width="390" height="960" cssclass="div_WF_PoPpnl" text="" tabstop="false" accessibilityenable="false">
          <Layouts>
            <Layout>
              <Button id="Button00" taborder="0" text="접어두기" top="40" width="106" height="40" right="40" cssclass="btn_WF_Fold"/>
              <Button id="Button01" taborder="1" text="도움" left="40" top="Button00:0" width="60" height="40" cssclass="btn_WF_TabLsmall" accessibilityrole="tab"/>
              <Button id="Button01_00" taborder="2" text="따라하기" left="Button01:8" top="80" width="94" height="40" cssclass="btn_WF_TabLsmallS" enable="true" accessibilityrole="tab"/>
              <Div id="Div00" taborder="3" left="40" top="152" height="768" text="" width="309" accessibilityenable="false" tabstop="false">
                <Layouts>
                  <Layout>
                    <Static id="Static00" taborder="0" text="타이틀영역입니다." left="0" top="0" width="157" height="29" cssclass="sta_WF_Para19B" accessibilityrole="heading3"/>
                    <Static id="Static00_00" taborder="1" text="선택한 신청 내용을 단계별로 알려드립니다." left="0" top="Static00:16" height="29" cssclass="sta_WF_Para17RG" right="0" fittocontents="height"/>
                    <ListView id="ListView00" taborder="2" left="0" top="130" height="288" right="0" binddataset="ds_accodian" cssclass="lstv_WF_Line">
                      <Formats>
                        <Format id="default">
                          <Band id="body" width="100%" height="58" expandbarsize="24 24" expandbartype="true">
                            <Cell id="Cell01" left="0" top="4" text="bind:BODY_TITLE" right="0" bottom="4"/>
                          </Band>
                          <Band id="detail" width="100%" height="140">
                            <Cell id="Cell03" left="0" top="0" text="bind:DETAIL_CON" right="0" bottom="20"/>
                          </Band>
                        </Format>
                      </Formats>
                    </ListView>
                    <Static id="Static02" taborder="3" left="0" top="442" height="32" cssclass="sta_WF_Divider" right="0"/>
                    <Button id="Button00" taborder="4" text="그만 따라하기" left="0" top="Static02:0" width="140" height="48" cssclass="btn_WF_Custom"/>
                  </Layout>
                  <Layout name="Layout0">
                    <ListView id="ListView00" top="Static00_00:56" left="0" height="288" right="0"/>
