  <Form id="lay07" width="888" height="1010" titletext="레이아웃 및 표현_아코디언" cssclass="btn_WF_Txt" onload="lay07_onload">
    <Layouts>
      <Layout height="1010" width="888" screenid="Desktop_screen">
        <Static id="staH2" taborder="0" text="아코디언" left="0" top="0" width="140" height="60" cssclass="sta_WF_H2_pc" fittocontents="width" accessibilityrole="heading2"/>
        <Static id="staDivider" taborder="1" left="staH2:15" top="20" width="1" height="21" cssclass="sta_WF_line" accessibilityenable="false"/>
        <Static id="staEtit" taborder="2" text="Accordion" left="staDivider:15" top="0" width="119" height="60" cssclass="sta_WF_ParaH4_pc" onclick="Div01_01_Static00_02_onclick" fittocontents="width"/>
        <Static id="Static00_01_00" taborder="3" text="아코디언은 한 페이지에서 관련 있는 여러 콘텐츠 섹션을 확인할 수 있도록 하는 컴포넌트로 콘텐츠 섹션의 헤더 목록이 수직으로 쌓여 있는 형태로 표현된다. 일반적으로 헤더 목록은 컨트롤 요소로 활용되며 사용자는 필요에 따라 헤더를 선택하여 하위 콘텐츠 섹션을 표시하거나 숨길 수 있다." left="0" top="85" height="126" cssclass="sta_WF_Descript" fittocontents="height" right="0"/>
        <ListView id="ListView00_00" taborder="4" left="0" top="Static00_01_00:80" height="314" binddataset="ds_accodian" cssclass="lstv_WF_Line" bandexpandtype="accordion" bandinitstatus="expand" width="309">
          <Formats>
            <Format id="default">
              <Band id="body" width="100%" height="58" expandbarsize="24 24" expandbartype="true">
