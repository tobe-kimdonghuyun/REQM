          <Layouts>
            <Layout>
              <Button id="Button01" taborder="0" text="간편 인증" left="31" top="31" height="40" cssclass="btn_WF_LoginOpt03" right="31" accessibilityrole="heading4"/>
              <Static id="Static04" taborder="1" text="네이버, 카카오, 또는 금융기관등 민간 전자서명 사업자가 제공하는 전자서명을 이용하여 로그인하기" left="95" top="84" height="78" right="71" cssclass="sta_WF_aliTop" fittocontents="height"/>
              <Button id="Button02" taborder="2" text="이용 가능한 간편 인증 서비스 목록보기" left="95" top="Static04:8" height="26" cssclass="btn_WF_DiscExpand" fittocontents="height" right="31"/>
