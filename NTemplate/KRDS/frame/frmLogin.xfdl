        </Panel>
        <Div id="Div03_01" taborder="8" text="Div03" left="2" top="472" width="100%" height="204" cssclass="div_WF_LoginOpt" accessibilityenable="false" fittocontents="height" flexgrow="1">
          <Layouts>
            <Layout>
              <Button id="Button01" taborder="0" text="모바일 신분증" left="31" top="31" height="40" cssclass="btn_WF_LoginOpt01" right="31" accessibilityrole="heading4"/>
              <Static id="Static04" taborder="1" text="행정안전부에서 제공하는 모바일 신분증 앱을 이용하여 로그인하기" left="95" top="84" height="52" right="71" cssclass="sta_WF_aliTop" fittocontents="height"/>
              <Button id="Button00" taborder="2" text="모바일 신분증 발급하러 가기" left="95" top="Static04:8" height="26" cssclass="btn_WF_More" right="71"/>
