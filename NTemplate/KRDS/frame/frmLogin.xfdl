        <Div id="Div00" taborder="17" text="Div00" left="0" top="Panel03:40" height="185" cssclass="div_WF_StartInfor" right="0" fittocontents="height">
          <Layouts>
            <Layout>
              <Static id="Static00" taborder="0" text="로그인에 어려움이 있으신가요?" left="24" top="16" height="26" cssclass="sta_WF_InforboxBL" right="24"/>
              <Static id="Static03_06" taborder="1" text="이전에 이용한 로그인 수단이 안 보인다면 상단 통합 로그인 사용을 꺼보세요." left="51" top="Static00:12" height="38" onclick="Static03_06_onclick" fittocontents="height" right="0" cssclass="sta_WF_UL01"/>
              <Static id="Static03_06_00" taborder="2" text="로그인 관련 도움말이나 다른 사용자가 자주 찾는 질문을 확인해보세요." left="51" top="Static03_06:0" height="38" cssclass="sta_WF_UL01" onclick="Static03_06_onclick" fittocontents="height" right="0"/>
              <Static id="Static03_06_00_00" taborder="3" left="51" top="Static03_06_00:0" height="38" cssclass="sta_WF_UL01" onclick="Static03_06_onclick" fittocontents="height" text="02-3703-2500 (내선번호 4번)으로 전화주세요. 서비스에 로그인할 수 있도록 도와드리겠습니다." right="0"/>
