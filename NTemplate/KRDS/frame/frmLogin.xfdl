<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Form_Login" width="888" height="1510" titletext="로그인" onload="Form_Login_onload">
    <Layouts>
      <Layout height="1510" mobileorientation="landscape" width="888" screenid="Desktop_screen">
        <Static id="Static00" taborder="0" text="대한민국 디지털정부 사용자 로그인" left="0" top="10" height="23" cssclass="sta_WF_Subtit15" right="0"/>
        <Static id="Static01" taborder="1" text="로그인 방식을 선택해주세요." left="0" top="Static00:16" height="60" cssclass="sta_WF_H2_pc" right="0" accessibilityrole="heading2" fittocontents="height"/>
        <Static id="Static02" taborder="2" text="통합 로그인을 사용해 보세요. 통합 로그인은 한 번의 회원가입과 로그인으로 연계된 모든 공공 서비스를 이용할 수 있는 인증 서비스입니다. &#13;&#10;한 번 로그인으로 모든 정부기관의 서비스를 이용하실 수 있습니다. " left="0" top="Static01:24" height="87" cssclass="sta_WF_Para19RLeft" right="0" fittocontents="height"/>
        <CheckBox id="CheckBox01" taborder="3" text="통합 로그인 사용" left="154" top="266" width="170" cssclass="chk_WF_Switch" height="30"/>
        <CheckBox id="CheckBox01_01" taborder="4" text="키보드 보안 프로그램 사용" left="336" top="266" width="222" cssclass="chk_WF_Switch" value="true" height="30"/>
        <Button id="Button01" taborder="5" left="543" top="266" width="30" height="30" cssclass="btn_WF_HelpEx"/>
        <Panel id="Panel00_00" taborder="6" left="182" top="259" width="270" height="30" flexcrossaxisalign="center">
          <Contents>
            <PanelItem id="PanelItem00" componentid="CheckBox01_01"/>
            <PanelItem id="PanelItem01" componentid="Button01"/>
          </Contents>
        </Panel>
        <Panel id="Panel01" taborder="7" left="0" top="Static02:48" height="30" verticalgap="16" flexwrap="wrap" right="0" fittocontents="height" horizontalgap="24">
          <Contents>
            <PanelItem id="PanelItem00" componentid="CheckBox01"/>
            <PanelItem id="PanelItem01" componentid="Panel00_00"/>
