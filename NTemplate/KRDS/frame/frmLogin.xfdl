          <Layouts>
            <Layout>
              <Button id="Button01" taborder="0" text="소셜(SNS)계정으로 로그인" left="31" top="31" height="40" cssclass="btn_WF_LoginOpt04" right="31" accessibilityrole="heading4"/>
              <Static id="Static04" taborder="1" text="네이버, 카카오, 페이코 계정 등 자주 사용하는 소셜·포털사이트 계정으로 로그인하기" left="95" top="84" height="52" right="71" cssclass="sta_WF_aliTop" fittocontents="height"/>
              <Static id="Static03" taborder="2" left="141" top="Static04:0" width="119" height="31" accessibilityenable="false"/>
