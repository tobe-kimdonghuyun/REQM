<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="cmmToast" width="720" height="118" titletext="토스트 메세지">
    <Layouts>
      <Layout height="118" width="720">
        <Div id="divToast" taborder="0" text="div00" left="10" top="10" bottom="10" right="10" cssclass="div_WF_ToastInfor" accessibilityenable="false">
          <Layouts>
            <Layout>
              <Static id="staToastTitle" taborder="0" text="Information" left="28" top="18" width="160" height="26" cssclass="sta_POP_InforTxt"/>
              <Static id="staToast" taborder="1" text="토스트 메세지입니다." left="60" top="staToastTitle:8" height="20" cssclass="sta_WF_Toast" fittocontents="width" right="80"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="Static05_00" taborder="1" left="12" top="138" cssclass="sta_POP_Infor" text="" height="118" width="720"/>
        <Static id="Static05" taborder="2" text="메시지 타이틀" left="28" top="154" width="300" height="26" cssclass="sta_POP_InforTxt"/>
        <TextArea id="TextArea05" taborder="3" left="60" top="Static05:8" cssclass="output" width="656" height="52" value="콘텐츠 내 알럿은 최대 2줄 이내로 작성합니다  콘텐츠 내 알럿은 최대 2줄 이내로 작성합니다  콘텐츠 내 알럿은 최대 2줄 이내로 작성합니다" scrolltype="none" scrollbartype="none none"/>
      </Layout>
    </Layouts>
