<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="form" width="500" height="495" titletext="글자화면 표시설정" background="transparent" onload="form_onload" onclose="form_onclose">
    <Layouts>
      <Layout height="495" mobileorientation="landscape" width="500">
        <Static id="Static02" taborder="0" left="0" top="0" cssclass="sta_POP_Utildropbg" text="" right="0" bottom="0"/>
        <Static id="Static00" taborder="1" text="글자·화면 표시 설정" left="40" top="56" width="363" height="36" cssclass="sta_WF_H4"/>
        <Panel id="Panel02" taborder="2" left="40" top="116" height="271" horizontalgap="24" flexwrap="wrap" verticalgap="24" fittocontents="height" right="40">
          <Contents>
            <PanelItem id="PanelItem00" componentid="Panel00"/>
          </Contents>
        </Panel>
        <Panel id="Panel03" taborder="3" left="40" top="395" horizontalgap="8" flexmainaxisalign="end" flexcrossaxisalign="start" spacing="16px 0px 48px 0px" height="92" right="40">
          <Contents>
            <PanelItem id="PanelItem00" componentid="btnReset"/>
            <PanelItem id="PanelItem01" componentid="btnSetUp"/>
          </Contents>
        </Panel>
        <Button id="btnReset" taborder="4" text="초기화" left="514" top="16" width="78" height="48" onclick="btnReset_onclick"/>
        <Button id="btnSetUp" taborder="5" text="설정" cssclass="btn_WF_Crud01" left="600" top="16" width="78" height="48" onclick="btnSetUp_onclick"/>
        <Button id="btnClose" taborder="6" top="28" height="40" cssclass="btn_POP_Cancel" enable="true" width="40" onclick="btnClose_onclick" right="28"/>
        <Static id="Static00_00" taborder="7" text="글자·화면 표시 설정" left="44" top="0" width="230" height="23" cssclass="sta_WF_Subtit15B" accessibilityrole="heading4"/>
        <Radio id="Radio00" taborder="8" left="47" top="20" width="250" height="210" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" onitemchanged="Radio00_onitemchanged" text="" index="-1">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row>
                <Col id="codecolumn">0</Col>
                <Col id="datacolumn">작게</Col>
              </Row>
              <Row>
                <Col id="codecolumn">1</Col>
                <Col id="datacolumn">보통</Col>
              </Row>
              <Row>
                <Col id="codecolumn">2</Col>
                <Col id="datacolumn">조금 크게</Col>
              </Row>
              <Row>
                <Col id="codecolumn">3</Col>
                <Col id="datacolumn">크게</Col>
              </Row>
              <Row>
                <Col id="codecolumn">4</Col>
                <Col id="datacolumn">가장 크게</Col>
              </Row>
            </Rows>
          </Dataset>
        </Radio>
        <Panel id="Panel00" taborder="9" left="0" top="0" width="240" height="249" type="vertical" enableevent="false" verticalgap="16">
          <Contents>
            <PanelItem id="PanelItem00" componentid="Static00_00"/>
            <PanelItem id="PanelItem01" componentid="Radio00"/>
          </Contents>
        </Panel>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  KRDS
*  @FileName 	cmmUtilView2.xfdl
*  @Creator 	TOBESOFT
*  @CreateDate 	2025/03/24
*  @Description
************** 소스 수정 이력 ***********************************************
* Date					Modifier					Description
*******************************************************************************
* 2025/03/24			TOBESOFT					최초생성
*******************************************************************************
*/

/*******************************************************************************************************************************
 * FORM 변수 선언 영역
*******************************************************************************************************************************/
this.fvZoom = "";
this.objApp = nexacro.getApplication();
/*******************************************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose..)
*******************************************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.Radio00.value = this.objApp.gvZoom;
};

this.form_onclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	
};

this.Radio00_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	switch(e.postvalue) {
		case "0":
			document.body.style.zoom = 0.9;
			this.fvZoom = 0.9;
			break;
		case "1":
			document.body.style.zoom = 1;
			this.fvZoom = 1;
			break;
		case "2":
		    document.body.style.zoom = 1.1;
			this.fvZoom = 1.1;
			break;
		case "3":
		    document.body.style.zoom = 1.2;
			this.fvZoom = 1.2;
			break;
		case "4":
		    document.body.style.zoom = 1.3;
			this.fvZoom = 1.3;
			break;
		default:
	}
};

this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.objApp.gvZoom = this.Radio00.value;
	this.close();
};

this.btnReset_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.Radio00.value = "1";
	document.body.style.zoom = 1;
	this.objApp.gvZoom = 1;
};

this.btnSetUp_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.objApp.gvZoom = this.Radio00.value;
	this.close();
};
]]></Script>
  </Form>
</FDL>
