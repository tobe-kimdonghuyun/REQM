{
    "name": "nexacro-accessibility-validator",
    "rules": {
        "a11y/ignore-form-serviceprefix-ids": [],
        "a11y/ignore-screen-ids": [],
        "a11y/ignore-component-type": [],
        "a11y/use-component-not-enable": false,
        "a11y/use-component-not-visble": false,
        "a11y/use-component-not-tabstop": false,
        "a11y/use-popup-component": false,
        "a11y/match-contents-tab-order": "on",
        "a11y/require-contents-heading": {
            "passconds": [
                {
                    "anyOftypes": [],
                    "anyOfprops": [
                        {
                            "key": "cssclass",
                            "value": "sta_WF_H2_pc"
                        },
                        {
                            "key": "accessibilityrole",
                            "value": "/heading/"
                        }
                    ]
                },
                {
                    "anyOftypes": [],
                    "anyOfprops": [
                        {
                            "key": "cssclass",
                            "value": "sta_WF_H2_pc"
                        }
                    ]
                }
            ],
            "ignores": [
                {
                    "anyOfprops": [
                        {
                            "key": "cssclass",
                            "value": "/^(?!.*sta_WF_H2_pc).*$/"
                        }
                    ]
                }
            ]
        },
        "a11y/require-component-alt-text-props": "on",
        "a11y/recommand-component-a11yaction": "on",
        "a11y/require-component-a11yenable": "off",
        "a11y/require-component-a11yrole": "off",
        "a11y/require-component-style-highcontrast": "off",
        "a11y/require-grid-a11y-props": {
            "subrules": {
                "sub/validate-grid-props-createrowstype": "on",
                "sub/validate-grid-formats-band": "on",
                "sub/validate-grid-props-autoenter": "on",
                "sub/validate-grid-props-tabstop": "on",
                "sub/validate-grid-props-expr": "on",
                "sub/validate-grid-cell-displaytype": "on",
                "sub/validate-grid-cell-expandshow": "on",
                "sub/validate-grid-event-oncellcllick": "on",
                "sub/validate-grid-cell-props-accessibility": "on"
            }
        },
        "a11y/require-listview-a11y-props": {
            "subrules": {
                "sub/validate-listview-props-createrowstype": "on",
                "sub/validate-listview-props-autoenter": "on",
                "sub/validate-listview-props-tabstop": "on",
                "sub/validate-listview-props-expr": "on",
                "sub/validate-listview-cell-expandshow": "on",
                "sub/validate-listview-event-oncellcllick": "on",
                "sub/validate-listview-cell-props-accessibility": "on"
            }
        },
        "a11y-plugin/validate-imageviewer-tabstop": "on",
        "a11y-plugin/validate-static-clickevent": "on",
        "a11y-plugin/validate-static-spchar-text": "on",
        "a11y-plugin/validate-comp-size": "on",
        "a11y-plugin/validate-comp-font-size": "on"
    }
}