.Button.btn_TF_Menu,
.Button.btn_TF_Menu[userstatus=pushed],.Button.btn_TF_Menu[userstatus=selected]
{
	-nexa-border : 0px none;
	background : URL("theme://images/btn_TF_Menu.png") no-repeat center transparent;
}
.Button.btn_TF_Pre,
.Button.btn_TF_Pre[userstatus=pushed],.Button.btn_TF_Pre[userstatus=selected]
{
	-nexa-border : 0px none;
	background : URL("theme://images/btn_TF_Pre.png") no-repeat center transparent;
}
.Button.btn_TF_Close,
.Button.btn_TF_Close[userstatus=pushed],.Button.btn_TF_Close[userstatus=selected]
{
	-nexa-border : 0px none;
	background : URL("theme://images/btn_TF_Close.png") no-repeat center transparent;
}
.Button.btn_TF_CloseB,
.Button.btn_TF_CloseB[userstatus=pushed],.Button.btn_TF_CloseB[userstatus=selected]
{
	-nexa-border : 0px none;
	background : URL("theme://images/btn_TF_CloseB.png") no-repeat center transparent;
}
.Div.div_TF_Bg
{
	background : #212529;
}
.Static.sta_TF_Title
{
	-nexa-text-align : center;
	color : #FFFFFF;
	font : 22px "-apple-system","BlinkMacSystemFont","Roboto","Helvetica","Arial","Apple SD Gothic Neo","sans-serif";
}
