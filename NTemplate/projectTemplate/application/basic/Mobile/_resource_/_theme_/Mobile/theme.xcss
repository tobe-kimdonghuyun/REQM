<?xml version="1.0" encoding="utf-8"?>
<XCSS version="1.1">
  <CSSData><![CDATA[/***************************************************************/
/***** PROJECT NAME : 투비소프트 템플릿			********/
/***** CREATION DATES : 2023.10.11     			********/
/***** DRAFTER : TOBESOFT UX Team 			********/
/***** DISTRIBUTION DATE : 2023.10.30 			********/
/***************************************************************/

/*******************************************************************/
/*******************	FRAME START	****************************/
/*******************************************************************/
.Form
{
	-nexa-border : 0px none;
	background : #FFFFFF;
	color : #28282C;
	font : 22px "-apple-system","BlinkMacSystemFont","Roboto","Helvetica","Arial","Apple SD Gothic Neo","sans-serif";
}
.Form[userstatus=contents]
{
	background : transparent;
}
.TitleBarControl,
.TitleBarControl[status=deactivate],.TitleBarControl[status=disabled]
{
	background : #413c3c;
}
.TitleBarControl .titleicon,
.TitleBarControl .titleicon[status=mouseover],.TitleBarControl .titleicon[status=deactivate],
.TitleBarControl .titleicon[status=disabled]
{
	-nexa-padding : 0px 0px 0px 16px;
	color : #FFFFFF;
	font : bold 14px "-apple-system","BlinkMacSystemFont","Roboto","Helvetica","Arial","Apple SD Gothic Neo","sans-serif";
}
.TitleBarControl .minbutton,
.TitleBarControl .minbutton[status=focused],.TitleBarControl .minbutton[userstatus=selected],
.TitleBarControl .minbutton[status=deactivate]
{
	-nexa-icon : URL("theme://images/tib_WF_Min.png");
}
.TitleBarControl .minbutton[status=mouseover],.TitleBarControl .minbutton[userstatus=pushed]
{
	-nexa-icon : URL("theme://images/tib_WF_MinO.png");
}
.TitleBarControl .minbutton[status=disabled]
{
	-nexa-icon : URL("theme://images/tib_WF_MinD.png");
}
.TitleBarControl .maxbutton,
.TitleBarControl .maxbutton[status=focused],.TitleBarControl .maxbutton[userstatus=selected],
.TitleBarControl .maxbutton[status=deactivate]
{
	-nexa-icon : URL("theme://images/tib_WF_Max.png");
}
.TitleBarControl .maxbutton[status=mouseover],.TitleBarControl .maxbutton[userstatus=pushed]
{
	-nexa-icon : URL("theme://images/tib_WF_Max.png");
}
.TitleBarControl .maxbutton[status=disabled]
{
	-nexa-icon : URL("theme://images/tib_WF_MaxD.png");
}
.TitleBarControl .normalbutton,
.TitleBarControl .normalbutton[status=focused],.TitleBarControl .normalbutton[userstatus=selected],
.TitleBarControl .normalbutton[status=deactivate]
{
	-nexa-icon : URL("theme://images/tib_WF_Normal.png");
}
.TitleBarControl .normalbutton[status=mouseover],.TitleBarControl .normalbutton[userstatus=pushed]
{
	-nexa-icon : URL("theme://images/tib_WF_NormalO.png");
}
.TitleBarControl .normalbutton[status=disabled]
{
	-nexa-icon : URL("theme://images/tib_WF_NormalD.png");
}
.TitleBarControl .closebutton,
.TitleBarControl .closebutton[status=focused],.TitleBarControl .closebutton[userstatus=selected],
.TitleBarControl .closebutton[status=deactivate]
{
	-nexa-icon : URL("theme://images/tib_WF_Close.png");
}
.TitleBarControl .closebutton[status=mouseover],.TitleBarControl .closebutton[userstatus=pushed]
{
	-nexa-icon : URL("theme://images/tib_WF_CloseO.png");
}
.TitleBarControl .closebutton[status=disabled]
{
	-nexa-icon : URL("theme://images/tib_WF_CloseD.png");
}

.VScrollIndicatorControl
{
	-nexa-padding : 5px 2px 5px 2px;
	background : transparent;
}
.VScrollIndicatorControl .trackbar
{
	background : #42454e;
	border-radius : 5px;
}
/*******************************************************************/
/*******************	FRAME END	****************************/
/*******************************************************************/

/*******************************************************************/
/*******************	BASE COMPONENT START	********************/
/*******************************************************************/
/***** Button *****/
.Button
{
	-nexa-border : 2px solid #CED8DB;
	-nexa-padding : 0px 12px;
	-nexa-text-align : center;
	background : #FFFFFF;
	border-radius : 12px;
	color : #585858;
	font : bold 18px "-apple-system","BlinkMacSystemFont","Roboto","Helvetica","Arial","Apple SD Gothic Neo","sans-serif";
	letter-spacing : -1px;
}
.Button[userstatus=pushed],.Button[userstatus=selected]
{
	background : #F2F2F2;
	color : #585858;
}
.Button[status=disabled]
{
	opacity : 0.3;
}
/***** Calendar *****/
.Calendar,
.CalendarControl
{
	-nexa-border : 1px solid #D6DFE2;
	background : #FFFFFF;
	border-radius : 12px;
}
.Calendar[status=focused],
.CalendarControl[status=focused]
{
	-nexa-border : 1px solid #000000;
	background : #FFFFFF;
	color : #000000;
}
.Calendar[status=readonly],
.CalendarControl[status=readonly]
{
	background : #F9F9F9;
}
.Calendar[status=disabled],
.CalendarControl[status=disabled]
{
	-nexa-border : 1px solid #EBEBEB;
	background : #F9F9F9;
	color : #AEAEAE;
}
.Calendar .calendaredit,
.Calendar .calendaredit[status=focused],.Calendar .calendaredit[status=readonly],
.Calendar .calendaredit[status=disabled],
.CalendarControl .calendaredit,
.CalendarControl .calendaredit[status=focused],.CalendarControl .calendaredit[status=readonly],
.CalendarControl .calendaredit[status=disabled]
{
	-nexa-border : 0px none;
	-nexa-padding : 0px 15px;
	-nexa-text-align : left;
	background : transparent;
}
.Calendar .calendaredit[userstatus=nulltext],
.CalendarControl .calendaredit[userstatus=nulltext]
{
	color : #AEAEAE;
}
.Calendar .dropbutton,
.Calendar .dropbutton[status=focused],.Calendar .dropbutton[userstatus=pushed],
.Calendar .dropbutton[userstatus=selected],
.CalendarControl .dropbutton,
.CalendarControl .dropbutton[status=focused],.CalendarControl .dropbutton[userstatus=pushed],
.CalendarControl .dropbutton[userstatus=selected]
{
	-nexa-icon : URL("theme://images/cal_WF_DropBtn.png");
}
.Calendar .dropbutton[status=disabled],
.CalendarControl .dropbutton[status=disabled]
{
	opacity : 0.5;
}
.CalendarControl .calendarspindownbutton,
.CalendarControl .calendarspindownbutton[status=focused],.Calendar .calendarspindownbutton[userstatus=pushed],
.CalendarControl .calendarspindownbutton[userstatus=selected]
{
	-nexa-icon : URL("theme://images/cal_WF_SpnDnBtn.png");
}
.CalendarControl .calendarspindownbutton[status=disabled]
{
	-nexa-icon : URL("theme://images/cal_WF_SpnDnBtn.png");
}
.CalendarControl .calendarspinupbutton,
.CalendarControl .calendarspinupbutton[status=focused],.Calendar .calendarspinupbutton[userstatus=pushed],
.CalendarControl .calendarspinupbutton[userstatus=selected]
{
	-nexa-icon : URL("theme://images/cal_WF_SpnUpBtn.png");
}
.CalendarControl .calendarspinupbutton[status=disabled]
{
	-nexa-icon : URL("theme://images/cal_WF_SpnUpBtn.png");
}
.Calendar .datepicker,
.CalendarControl .datepicker
{
	-nexa-border : 1px solid #646982;	
}
.Calendar .datepicker .body .monthitem,
.Calendar .datepicker .body .monthitem[status=focused],
.CalendarControl .datepicker .body .monthitem,
.CalendarControl .datepicker .body .monthitem[status=focused]
{	
	background : #ffffff;
	color : #333333;
}
.Calendar .datepicker .body .monthitem[userstatus=pushed],
.Calendar .datepicker .body .monthitem[userstatus=selected],
.CalendarControl .datepicker .body .monthitem[userstatus=pushed],
.CalendarControl .datepicker .body .monthitem[userstatus=selected]
{
	background : #445BEC;
	color : #ffffff;
}
.Calendar .datepicker .body .yearitem,
.Calendar .datepicker .body .yearitem[status=focused],
.CalendarControl .datepicker .body .yearitem,
.CalendarControl .datepicker .body .yearitem[status=focused]
{	
	background : #ffffff;
	color : #333333;
}
.Calendar .datepicker .body .yearitem[userstatus=selected],
.CalendarControl .datepicker .body .yearitem[userstatus=selected]
{
	background : #445BEC;
	color : #ffffff;
}
/***** CheckBox *****/
.CheckBox,
.CheckBox[status=focused],.CheckBox[status=readonly],
.CheckBoxControl,
.CheckBoxControl[status=focused],.CheckBoxControl[status=readonly]
{
	-nexa-icon : URL("theme://images/chk_WF_box.png");
	-nexa-text-padding : 0px 0px 0px 12px;
}
.CheckBox[userstatus=selected],
.CheckBoxControl[userstatus=selected]
{
	-nexa-icon : URL("theme://images/chk_WF_boxS.png");
}
.CheckBox[status=disabled],
.CheckBoxControl[status=disabled]
{
	opacity : 0.5;
}
.CheckBox[status=disabled][userstatus=selected],
.CheckBoxControl[status=disabled][userstatus=selected]
{
	opacity : 0.5;
}
/***** Combo *****/
.Combo,
.ComboControl
{
	-nexa-border : 1px solid #D6DFE2;
	background : #FFFFFF;
	border-radius : 12px;
}
.Combo[status=mouseover],.Combo[status=focused],
.ComboControl[status=mouseover],.ComboControl[status=focused]
{
	-nexa-border : 1px solid #000000;
	background : #FFFFFF;
	color : #000000;
}
.Combo[status=readonly],
.ComboControl[status=readonly]
{
	background : #F9F9F9;
}
.Combo[status=disabled],
.ComboControl[status=disabled]
{
	-nexa-border : 1px solid #EBEBEB;
	background : #F9F9F9;
}
.Combo .comboedit,
.Combo .comboedit[status=focused],.Combo .comboedit[status=readonly],
.ComboControl .comboedit,
.ComboControl .comboedit[status=focused],.ComboControl .comboedit[status=readonly]
{
	-nexa-border : 0px none;
	-nexa-padding : 0px 15px;
	background : transparent;
}
.Combo .comboedit[status=disabled],.Combo .comboedit[userstatus=nulltext],
.ComboControl .comboedit[status=disabled],.ComboControl .comboedit[userstatus=nulltext]
{
	-nexa-border : 0px none;
	color : #AEAEAE;
}
.Combo .dropbutton,
.ComboControl .dropbutton,
.Combo .dropbutton[userstatus=pushed],.Combo .dropbutton[userstatus=selected],
.ComboControl .dropbutton[userstatus=pushed],.ComboControl .dropbutton[userstatus=selected]
{
	-nexa-icon : URL("theme://images/cbo_WF_Drop.png");
	background : transparent;
}
.Combo .dropbutton[status=disabled],
.ComboControl .dropbutton[status=disabled]
{	
	opacity : 0.5;
}
.Combo .combolist,
.ComboControl .combolist
{
	-nexa-border : 1px solid #D4D4D4;
	background : #FFFFFF;
}
.Combo .combolist .listboxitem,
.ComboControl .combolist .listboxitem
{
	-nexa-padding : 10px 0px 10px 15px;
	color : #000000;
}
.Combo .combolist .listboxitem[userstatus=selected],
.ComboControl .combolist .listboxitem[userstatus=selected]
{
	background : #F1F3FF;
}
/***** DateField *****/
.DateField .box
{
	-nexa-border : 1px solid #D6DFE2;
	-nexa-padding : 0px 0px 0px 15px;
	background : #FFFFFF;
	border-radius : 12px;
}
.DateField .box[status=focused]
{
	-nexa-border : 1px solid #000000;
	background : #FFFFFF;
	color : #000000;
}
.DateField .box[status=readonly]
{
	background : #F9F9F9;
}
.DateField .box[status=disabled]
{
	-nexa-border : 1px solid #EBEBEB;
	background : #F9F9F9;
	color : #AEAEAE;
}
.DateField .box[userstatus=invalid]
{
	-nexa-border : 1px solid #ee5555;
}
.DateField .box .dropbutton,
.DateField .box .dropbutton[status=focused],.DateField .box .dropbutton[userstatus=pushed],
.DateField .box .dropbutton[userstatus=selected]
{
	background : URL("theme://images/cal_WF_DropBtn.png") no-repeat center center;	
}
.DateField .box .dropbutton[status=disabled]
{
	opacity : 0.5;
}
.DateField .helpertext
{
	-nexa-padding : 5px 0px 0px 5px;
	color : #555555;	
}
.DateField .helpertext[userstatus=invalid]
{	
	color : #ee5555;	
	font : 18px "-apple-system","BlinkMacSystemFont","Roboto","Helvetica","Arial","Apple SD Gothic Neo","sans-serif";
}
.DateField .label
{
	-nexa-padding : 0px 0px 0px 15px;
	background : transparent;
	color : #89929B;	
}
.DateField .label[status=focused][userstatus=floating],.DateField .label[userstatus=floatinginvalid],
.DateField .label[userstatus=floatingvalid]
{
	-nexa-padding : 2px 4px;
	background : #ffffff;	
	color : #000000;
}
.DateField .label[userstatus=floating]
{
	-nexa-padding : 2px 4px;
	background : #ffffff;	
}
.DateField .label[status=disabled]
{
	-nexa-padding : 2px 4px;
	background : #aeaeae;
}
.DateField .nulltext
{
	-nexa-padding : 8px 0px 8px 15px;
	color : #aeaeae;
}
/***** DatePickerControl *****/
.DatePickerControl
{
	background : #FFFFFF;
}
.DatePickerControl .head
{
	background : #FFFFFF;
	color : #333333;
	font : bold 24px "-apple-system","BlinkMacSystemFont","Roboto","Helvetica","Arial","Apple SD Gothic Neo","sans-serif";
}
.DatePickerControl .head .prevbutton,
.DatePickerControl .head .prevbutton[status=focused],.DatePickerControl .head .prevbutton[userstatus=pushed],
.DatePickerControl .head .prevbutton[userstatus=selected]
{
	-nexa-icon : URL("theme://images/cal_WF_PreBtn.png");
}
.DatePickerControl .head .prevbutton[status=disabled]
{
	opacity : 0.5;
}
.DatePickerControl .head .nextbutton,
.DatePickerControl .head .nextbutton[status=focused],.DatePickerControl .head .nextbutton[userstatus=pushed],
.DatePickerControl .head .nextbutton[userstatus=selected]
{
	-nexa-icon : URL("theme://images/cal_WF_NxtBtn.png");
}
.DatePickerControl .head .nextbutton[status=disabled]
{
	opacity : 0.5;
}
.DatePickerControl .head .yearstatic,
.DatePickerControl .head .monthstatic
{
	font : bold 18px "-apple-system","BlinkMacSystemFont","Roboto","Helvetica","Arial","Apple SD Gothic Neo","sans-serif";
}
.DatePickerControl .head .yearspin,.DatePickerControl .head .yearspin[status=focused],
.DatePickerControl .head .monthspin,.DatePickerControl .head .monthspin[status=focused]
{
	-nexa-border : 0px none;
	font : bold 18px "-apple-system","BlinkMacSystemFont","Roboto","Helvetica","Arial","Apple SD Gothic Neo","sans-serif";
}
.DatePickerControl .body
{
	background : #FFFFFF;
}
.DatePickerControl .body .weekband
{
	background : #f7f8fa;
}
.DatePickerControl .body .weekitem
{
	color : #666666;
}
.DatePickerControl .body .weekitem[userstatus=saturday]
{
	color : #127ED1;
}
.DatePickerControl .body .weekitem[userstatus=sunday]
{
	color : #EE5555;
}
.DatePickerControl .body .dayitem
{
	color : #333333;
	font : 18px "-apple-system","BlinkMacSystemFont","Roboto","Helvetica","Arial","Apple SD Gothic Neo","sans-serif";
}
.DatePickerControl .body .dayitem[userstatus=selected]
{
	background : #445BEC;
	border-radius : 30px;
	color : #FFFFFF;
	font : bold 18px "-apple-system","BlinkMacSystemFont","Roboto","Helvetica","Arial","Apple SD Gothic Neo","sans-serif";
}
.DatePickerControl .body .dayitem[userstatus=day]
{
	color : #333333;
}
.DatePickerControl .body .dayitem[userstatus=today]
{
	background : #B0B7FB;
	border-radius : 30px;
	color : #333333;
	font : bold 18px "-apple-system","BlinkMacSystemFont","Roboto","Helvetica","Arial","Apple SD Gothic Neo","sans-serif";
}
.DatePickerControl .body .dayitem[userstatus=saturday]
{
	color : #127ED1;
}
.DatePickerControl .body .dayitem[userstatus=sunday]
{
	color : #EE5555;
}
.DatePickerControl .body .dayitem[userstatus=trailingday]
{
	color : #aaaaaa;
}
.DatePickerControl .body .selection
{
	background : #E3E6FB;
}
/***** DateRangePicker, PopupDateRangePicker *****/
.DateRangePicker
{
	-nexa-border : 1px solid #646982;	
	background : #ffffff;
}
.DateRangePickerControl,
.PopupDateRangePicker
{
	-nexa-border : 1px solid #646982;
	background : #eaeaea;
}
.DateRangePicker .datetabbutton, 
.PopupDateRangePicker .datetabbutton
{
	-nexa-border : 0px none, 0px none, 0px none, 1px solid #dddddd;
	-nexa-icon : url('theme://images/img_WF_Daterange.png');	
	background : #eaeaea;	
}
.DateRangePicker .timetabbutton, 
.PopupDateRangePicker .timetabbutton
{
	-nexa-border : 0px none, 0px none, 0px none, 1px solid #dddddd;
	-nexa-icon : url('theme://images/img_WF_Timerange.png');
	background : #eaeaea;	
}
.DateRangePicker .datetabbutton[userstatus=selected],
.PopupDateRangePicker .datetabbutton[userstatus=selected],
.DateRangePicker .timetabbutton[userstatus=selected],
.PopupDateRangePicker .timetabbutton[userstatus=selected]
{
	-nexa-border : 0px none;
	background : #ffffff;		
}
.DateRangePicker .headline, 
.PopupDateRangePicker .headline
{
	-nexa-padding : 15px;
	background : #125dae;	
}
.DateRangePicker .headline .splitline, 
.PopupDateRangePicker .headline .splitline
{
	-nexa-border : 1px solid #dddddd;
}
.DateRangePicker .headline .startdate, 
.DateRangePicker .headline .startdate[status=focused],
.PopupDateRangePicker .headline .startdate, 
.PopupDateRangePicker .headline .startdate[status=focused]
{
	-nexa-border : 0px none;
	-nexa-text-align : center;
	-nexa-vertical-align : bottom;
	background : transparent;
	color : #ffffff;
	font : bold 22px "-apple-system","BlinkMacSystemFont","Roboto","Helvetica","Arial","Apple SD Gothic Neo","sans-serif";
}
.DateRangePicker .headline .enddate, 
.DateRangePicker .headline .enddate[status=focused], 
.PopupDateRangePicker .headline .enddate, 
.PopupDateRangePicker .headline .enddate[status=focused]
{
	-nexa-border : 0px none;
	-nexa-text-align : center;
	-nexa-vertical-align : bottom;
	background : transparent;
	color : #ffffff;
	font : bold 22px "-apple-system","BlinkMacSystemFont","Roboto","Helvetica","Arial","Apple SD Gothic Neo","sans-serif";
}
.DateRangePicker .headline .startsubdate, 
.DateRangePicker .headline .startsubdate[status=focused],
.PopupDateRangePicker .headline .startsubdate, 
.PopupDateRangePicker .headline .startsubdate[status=focused]
{
	-nexa-border : 0px none;
	-nexa-text-align : center;
	-nexa-vertical-align : top;	
	background : transparent;
	color : #ffffff;
	font : 18px "-apple-system","BlinkMacSystemFont","Roboto","Helvetica","Arial","Apple SD Gothic Neo","sans-serif";
}
.DateRangePicker .headline .endsubdate, 
.DateRangePicker .headline .endsubdate[status=focused],
.PopupDateRangePicker .headline .endsubdate, 
.PopupDateRangePicker .headline .endsubdate[status=focused]
{
	-nexa-border : 0px none;
	-nexa-text-align : center;
	-nexa-vertical-align : top;
	background : transparent;
	color : #ffffff;
	font : 18px "-apple-system","BlinkMacSystemFont","Roboto","Helvetica","Arial","Apple SD Gothic Neo","sans-serif";
}
.DateRangePicker .datepickergroup .datepicker .body .monthitem,
.DateRangePicker .datepickergroup .datepicker .body .monthitem[status=focused],
.DateRangePickerControl .datepickergroup .datepicker .body .monthitem,
.DateRangePickerControl .datepickergroup .datepicker .body .monthitem[status=focused],
.PopupDateRangePicker .datepickergroup .datepicker .body .monthitem,
.PopupDateRangePicker .datepickergroup .datepicker .body .monthitem[status=focused]
{	
	background : #ffffff;
	color : #333333;
}
.DateRangePicker .datepickergroup .datepicker .body .monthitem[userstatus=pushed],
.DateRangePicker .datepickergroup .datepicker .body .monthitem[userstatus=selected],
.DateRangePickerControl .datepickergroup .datepicker .body .monthitem[userstatus=pushed],
.DateRangePickerControl .datepickergroup .datepicker .body .monthitem[userstatus=selected],
.PopupDateRangePicker .datepickergroup .datepicker .body .monthitem[userstatus=pushed],
.PopupDateRangePicker .datepickergroup .datepicker .body .monthitem[userstatus=selected]
{
	background : #445BEC;
	color : #ffffff;
}
.DateRangePicker .datepickergroup .datepicker .body .yearitem,
.DateRangePicker .datepickergroup .datepicker .body .yearitem[status=focused],
.DateRangePickerControl .datepickergroup .datepicker .body .yearitem,
.DateRangePickerControl .datepickergroup .datepicker .body .yearitem[status=focused],
.PopupDateRangePicker .datepickergroup .datepicker .body .yearitem,
.PopupDateRangePicker .datepickergroup .datepicker .body .yearitem[status=focused]
{	
	background : #ffffff;
	color : #333333;
}
.DateRangePicker .datepickergroup .datepicker .body .yearitem[userstatus=selected],
.DateRangePickerControl .datepickergroup .datepicker .body .yearitem[userstatus=selected],
.PopupDateRangePicker .datepickergroup .datepicker .body .yearitem[userstatus=selected]
{
	background : #445BEC;
	color : #ffffff;
}
.DateRangePickerControl .closebutton,
.PopupDateRangePicker .closebutton
{
	-nexa-padding : 5px;	
	font : 15px "-apple-system","BlinkMacSystemFont","Roboto","Helvetica","Arial","Apple SD Gothic Neo","sans-serif";
}
.DateRangePickerControl .datetabbutton
{
	-nexa-border : 0px none;
	-nexa-icon : url('theme://images/img_WF_Daterange.png');	
	background : #eaeaea;
}
.DateRangePickerControl .timetabbutton
{
	-nexa-border : 0px none;
	-nexa-icon : url('theme://images/img_WF_Timerange.png');
	background : #eaeaea;	
}
.DateRangePickerControl .datetabbutton[userstatus=selected],
.DateRangePickerControl .timetabbutton[userstatus=selected]
{
	-nexa-border : 0px none;
	background : #ffffff;	
}
/***** Div *****/
.Div
{
	background : transparent;
}
/***** Edit *****/
.Edit,
.EditControl
{
	-nexa-border : 1px solid #D6DFE2;
	-nexa-padding : 0px 15px;
	background : #FFFFFF;
	border-radius : 12px;
}
.Edit[status=focused],
.EditControl[status=focused]
{
	-nexa-border : 1px solid #000000;
	background : #FFFFFF;
}
.Edit[status=readonly],
.EditControl[status=readonly]
{
	background : #F9F9F9;
}
.Edit[userstatus=nulltext],
.EditControl[userstatus=nulltext]
{
	color : #AEAEAE;
}
.Edit[status=disabled],
.EditControl[status=disabled]
{
	-nexa-border : 1px solid #EBEBEB;
	background : #F9F9F9;
	color : #AEAEAE;
}
/***** Grid *****/
.Grid
{
	-nexa-border : 2px solid #D6DFE2, 0px none, 0px none, 0px none;
}
.Grid .head
{
	background : #E7EAEB;
}
.Grid .head .row .cell
{
	-nexa-border : 1px solid #D6DFE2;
	-nexa-text-align : center;
	color : #89929B;
	font : bold 16px "-apple-system","BlinkMacSystemFont","Roboto","Helvetica","Arial","Apple SD Gothic Neo","sans-serif";
}
.Grid .body .row .cell
{
	-nexa-border : 1px solid #D6DFE2;
	-nexa-padding : 5px;
	-nexa-text-align : center;
}
.Grid .body .row .cell[userstatus=selected]
{
	background : #F1F6FF;
}
/*cellcontrol Start*/
.GridCellControl .cellcombo,
.GridCellControl .cellmaskedit,
.GridCellControl .cellcalendar,
.GridCellControl .celledit
{
