  <Form id="Temp03" width="480" height="700" titletext="ListDetail(List)" onload="form_onload">
    <Layouts>
      <Layout height="700" mobileorientation="portrait" screenid="mobile" width="480">
        <Button id="Button00" taborder="0" text="행추가" top="30" width="110" height="44" cssclass="btn_WF_RowAdd" right="30"/>
