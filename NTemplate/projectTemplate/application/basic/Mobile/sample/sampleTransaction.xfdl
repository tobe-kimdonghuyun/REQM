<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sampleTransaction" width="480" height="900" titletext="트랜잭션 샘플" onload="form_onload">
    <Layouts>
      <Layout height="900" mobileorientation="landscape" width="480">
        <Grid id="grdList" taborder="0" left="30" top="412" binddataset="dsList" bottom="0" autofittype="col" right="30" autoenter="select">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="50" band="head"/>
                <Row size="54"/>
              </Rows>
              <Band id="head">
                <Cell text="아이디"/>
                <Cell col="1" text="성명"/>
                <Cell col="2" text="부서"/>
                <Cell col="3" text="비고"/>
              </Band>
              <Band id="body">
                <Cell text="bind:ID" displaytype="expr:dataset.getRowType(currow)=='2'?'editcontrol':'normal'" edittype="expr:dataset.getRowType(currow)=='2'?'text':'none'" editautoselect="true"/>
                <Cell col="1" text="bind:NAME" edittype="text" displaytype="editcontrol" editautoselect="true"/>
                <Cell col="2" text="bind:DEPARTMENT" edittype="text" displaytype="editcontrol" editautoselect="true"/>
                <Cell col="3" text="bind:DESCRIPTION" edittype="text" displaytype="editcontrol" editautoselect="true"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="Static03_00" taborder="7" left="0" top="330" height="12" cssclass="sta_WF_Boundary" right="0"/>
        <Static id="staTitle" taborder="1" text="사용자 정보 조회" left="30" top="Static03_00:30" height="40" cssclass="sta_WF_SubTitle" right="30"/>
        <Static id="staSearchTitle00" taborder="3" text="아이디" left="30" top="30" width="160" height="40" cssclass="sta_WF_Label" fittocontents="width"/>
        <Edit height="50" text="투비" id="edt00" left="30" top="70" taborder="2" right="30"/>
        <Static id="staSearchTitle00_00" taborder="4" text="성명" left="30" top="130" width="160" height="40" cssclass="sta_WF_Label" fittocontents="width"/>
        <Edit height="50" text="투비" id="edt00_00" left="30" top="170" taborder="5" right="30"/>
        <Button id="btnSearch" taborder="6" text="조회" left="30" top="edt00_00:20" height="60" cssclass="btn_WF_Full" right="30" onclick="btnSearch_onclick"/>
      </Layout>
    </Layouts>
