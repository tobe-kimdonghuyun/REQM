        </Grid>
        <Button id="Button00" taborder="0" text="Button00" left="53" top="41" width="120" height="50"/>
        <Grid id="Grid00" taborder="2" useinputpanel="false" selecttype="cell" cellsizingtype="col" treeinitstatus="expand,all" left="25" top="105" width="1287" height="289" binddataset="ds_Data" autoenter="select" visible="true">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="172"/>
                <Column size="52"/>
                <Column size="138"/>
                <Column size="169"/>
                <Column size="100"/>
                <Column size="112"/>
                <Column size="48"/>
                <Column size="40"/>
                <Column size="64"/>
                <Column size="93"/>
                <Column size="59"/>
                <Column size="98"/>
                <Column size="52"/>
                <Column size="88"/>
              </Columns>
              <Rows>
                <Row size="62" band="head"/>
                <Row size="40"/>
                <Row size="34" band="summ"/>
              </Rows>
              <Band id="head">
                <Cell text="tree"/>
                <Cell col="1" text="button" displaytype="button" edittype="button"/>
                <Cell col="2" text="combo" edittype="" displaytype="" combodataset="ds_Data" combodisplay="display" combodatacol="data" combocodecol="code"/>
                <Cell col="3" text="date"/>
                <Cell col="4" text="expand"/>
                <Cell col="5" text="mask"/>
                <Cell col="6" text="masknumber"/>
                <Cell col="7" text="none"/>
                <Cell col="8" text="normal"/>
                <Cell col="9" text="text"/>
                <Cell col="10" text="textarea" edittype="textarea" displaytype="text"/>
                <Cell col="11" text="exp"/>
                <Cell col="12" text="checkbox" displaytype="checkbox" edittype="checkbox"/>
                <Cell col="13" text="image"/>
              </Band>
              <Band id="body">
                <Cell displaytype="tree" edittype="tree" text="bind:data" mask="###.###" expandshow="hide" treelevel="bind:level" treecheck="bind:check" verticalAlign="" textAlign=""/>
                <Cell col="1" displaytype="button" edittype="button" text="bind:BTN" verticalAlign=""/>
                <Cell col="2" combodataset="ds_Data" combocodecol="CMB" combodatacol="BTN" combodisplay="display" displaytype="combo" edittype="combo" verticalAlign="" combotype="dropdown" text="bind:CMB"/>
                <Cell col="3" displaytype="date" text="bind:DATE" edittype="date" calendartype="spin" calendardisplay="display"/>
                <Cell col="4" displaytype="normal" edittype="normal" text="bind:EXPAND" expandshow="show" expandsize="50"/>
                <Cell col="5" edittype="mask" text="bind:MASK" mask="#-##-#" editdisplay="display" displaytype="normal"/>
                <Cell col="6" edittype="masknumber" text="bind:MASKNUMBER" editdisplay="display"/>
                <Cell col="7" displaytype="none" edittype="none" text="bind:NONE"/>
                <Cell col="8" displaytype="normal" text="bind:NORMAL" expandshow="hide" expandimage="URL('testImage')"/>
                <Cell col="9" displaytype="text" edittype="text" text="bind:TEXT" editdisplay="display"/>
                <Cell col="10" text="bind:TXTAERE" wordwrap="true" edittype="textarea" displaytype="text" editdisplay="edit"/>
                <Cell col="11" edittype="none" text="bind:EXP" expr="3*4"/>
                <Cell col="12" displaytype="checkbox" edittype="checkbox" text="bind:check" verticalAlign=""/>
                <Cell col="13" displaytype="image" text="bind:IMG"/>
              </Band>
              <Band id="summary">
                <Cell text="bind:data"/>
                <Cell col="1" text="bind:BTN"/>
                <Cell col="2" text="bind:CMB"/>
                <Cell col="3"/>
                <Cell col="4"/>
                <Cell col="5"/>
                <Cell col="6"/>
                <Cell col="7"/>
                <Cell col="8"/>
                <Cell col="9"/>
                <Cell col="10"/>
                <Cell col="11"/>
                <Cell col="12"/>
                <Cell col="13"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
      </Layout>
