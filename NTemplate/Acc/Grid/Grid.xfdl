                <Cell col="12" text="TXTAERE"/>
                <Cell col="13" text="EXP"/>
                <Cell col="14" text="IMG"/>
              </Band>
              <Band id="body" accessibilitylabel="바디라벨" accessibilityaction="바디액션" accessibilitydescription="바디디스크립션">
                <Cell text="bind:data"/>
                <Cell col="1" text="bind:level"/>
                <Cell col="2" text="bind:check"/>
                <Cell col="3" text="bind:BTN"/>
                <Cell col="4" text="bind:CMB"/>
                <Cell col="5" text="bind:DATE"/>
                <Cell col="6" text="bind:EXPAND"/>
                <Cell col="7" text="bind:MASK"/>
                <Cell col="8" text="bind:MASKNUMBER"/>
                <Cell col="9" text="bind:NONE"/>
                <Cell col="10" text="bind:NORMAL"/>
                <Cell col="11" text="bind:TEXT" edittype="normal" editdisplay="edit"/>
                <Cell col="12" text="bind:TXTAERE"/>
                <Cell col="13" text="bind:EXP"/>
                <Cell col="14" text="bind:IMG"/>
              </Band>
              <Band id="summary" accessibilitylabel="서머리라벨" accessibilityaction="서머리액션" accessibilitydescription="서머리디스크립션">
