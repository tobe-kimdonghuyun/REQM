                <Cell text="data"/>
                <Cell col="1" text="level"/>
                <Cell col="2" text="check"/>
                <Cell col="3" text="BTN"/>
                <Cell col="4" text="CMB"/>
                <Cell col="5" text="DATE"/>
                <Cell col="6" text="EXPAND"/>
                <Cell col="7" text="MASK"/>
                <Cell col="8" text="MASKNUMBER"/>
                <Cell col="9" text="NONE"/>
                <Cell col="10" text="NORMAL"/>
