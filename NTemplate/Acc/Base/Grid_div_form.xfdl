  <Form id="div_form" width="400" height="700" titletext="Test" onload="div_form_onload" onkeydown="div_form_onkeydown">
    <Layouts>
      <Layout height="700" mobileorientation="landscape" width="400">
        <Button id="Button00" taborder="0" text="focus" left="266" top="77" width="120" height="32" onclick="Button00_onclick"/>
        <Div id="Div00" taborder="1" height="496" left="6" top="125" width="380" text="" async="false"/>
        <Button id="Button01" taborder="2" text="focus" left="266" top="629" width="120" height="32"/>
        <Button id="Button00_00" taborder="3" text="검색" left="314" top="43" width="53" height="27" onclick="Button00_00_onclick"/>
        <Static id="Static00" taborder="4" text="Search : " left="28" top="43" width="57" height="26" onclick="Static00_onclick"/>
        <Static id="Static01" taborder="5" text="&lt;Grid&gt;" left="10" top="10" width="172" height="19" onclick="Static01_onclick"/>
        <Combo id="Combo00" taborder="6" text="" left="87" top="43" width="218" height="25" innerdataset="grd" codecolumn="code" datacolumn="Desc" onitemchanged="Combo00_onitemchanged"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[var nRow;

this.Combo00_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	nRow = this.grd.findRow("code", this.Combo00.value);
	trace(nRow);
};

this.Button00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	var cindex=this.grd.getColumn(nRow,"code");
	trace(cindex);
	this.Div00.set_url(this.grd.getColumn(cindex,"url"));
	trace(this.grd.getColumn(cindex,"url"));
	


};
]]></Script>
