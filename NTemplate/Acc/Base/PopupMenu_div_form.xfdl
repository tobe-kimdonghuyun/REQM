        <Static id="Static01" taborder="5" text="&lt;PopupMenu&gt;" left="10" top="10" width="172" height="19" onclick="Static01_onclick"/>
        <Combo id="Combo00" taborder="6" text="" left="87" top="43" width="218" height="25" innerdataset="poupmenu" codecolumn="code" datacolumn="Desc" onitemchanged="Combo00_onitemchanged"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[var nRow;

this.Combo00_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	nRow = this.poupmenu.findRow("code", this.Combo00.value);
	trace(nRow);
};

this.Button00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	var cindex=this.poupmenu.getColumn(nRow,"code");
	trace(cindex);
	this.Div00.set_url(this.poupmenu.getColumn(cindex,"url"));
	trace(this.poupmenu.getColumn(cindex,"url"));
	


};
]]></Script>
