<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Btn_div_form" width="400" height="700" titletext="Test" onload="div_form_onload" onkeydown="div_form_onkeydown">
    <Layouts>
      <Layout height="700" mobileorientation="landscape" width="400">
        <Button id="Button00_00" taborder="0" text="검색" left="60" top="297" width="280" height="113" onclick="Button00_00_onclick"/>
        <Combo id="Combo00" taborder="1" text="선택" left="60" top="250" width="280" height="30" innerdataset="Main" codecolumn="code" datacolumn="Desc" type="dropdown" onitemchanged="Combo00_onitemchanged"/>
        <Static id="Static01" taborder="2" text="&lt;Main&gt;" left="10" top="10" width="172" height="19" onclick="Static01_onclick"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[var nRow;

this.Combo00_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	nRow = this.Main.findRow("code", this.Combo00.value);

};

 	
this.Button00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
 	var cindex=this.Main.getColumn(nRow,"code");
	this.getOwnerFrame().set_formurl(this.Main.getColumn(cindex,"url"));
	
};


]]></Script>
