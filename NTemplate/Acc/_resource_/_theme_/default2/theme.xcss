<?xml version="1.0" encoding="utf-8"?>
<XCSS version="1.0"><![CDATA[/*
* 아이콘 규칙
   icon 에 패딩을 주는 경우 클리핑 처리 방식이 넥사브라우저와 웹브라우저가 다름
   icon 은 스트레치 처리되지 않음
   icon 크기를 폰트+페딩 에 맞게 조정필요
* 하위컨트롤 이벤트 전파 ( selected 등이 전달되지 않음 )
* 프로그래스바에 라운드보더 제거 ( 매뉴얼 제약도 명시 필요 )
* Tabbutton 버튼하단 none border 처리를 직접해야함


정식출시전까지 아래 변경이력 주석으로 관리함
20160831
   1. Form추가 [RP68483]
   2. Grid .checkbox추가 [RP68497]
   3. DatePicker수정 [RP없음]
   4. menu/popupmenu .spinUp/Down Button 추가 [RP69135]
20160913
  1. Flash Player삭제 [RP69386]
  2. next/prev button으로 명칭 변경 [RP69450,68873]
  3. Grid .head .button추가 [RP69335]
20160930
   1. Tab next/prev Button CSS 및 이미지명 수정 - RP69490
   2. Menu next/prev Button CSS 및 이미지명 수정 - RP69490
   3. PopUP Menu next/prev Button CSS 및 이미지명 수정 - RP69490
   4. Div의 -nexa-text-align 삭제 -RP69539
   5. Grid .cell .expandbutton추가 -RP68632
20161006
   1. border => -nexa-border 명칭 변경 [RP68646]
20161012
   1. Edit계열 nexa-padding 10px => 3px로 변경
   2. Edit계열 background컬러 추가 - RP69777
20161208
   1. popupmenuitemicon Style 설정 제거
20161222
   1. Menu / PopupMenu  navigationbutton  이미지 표시 오류 : RP71095
20170125
   1. nexatreeline 부분 제거 : 변경 가능한 컨트롤이 아니라 고정 값을 가지는 컨트롤임 [RP71432]
20170302
   1. fileuploaditemedit nexa-text-align의 left 로 변경[RP71925]
20170315
   1. Plugin, WebBrowser, PluginControl, WebBrowserControl의 속성 -nexa-border만 남기고 삭제함 [RP71782]
20170403
   1. .Grid .body .row .cell .celltreeline의 속성 -nexa-border 추가함 [RP72421]
20170412
   1. Calendar 하위 컨트롤 명칭 변경
   - spinupbutton -> calendarspinupbutton
   - spindownbutton -> calendarspindownbutton [RP72490]
*/


/**********************Frame/Form***********************************************/
.Form
{
	background : transparent;
	-nexa-border : 0px none;
}

.FrameSet,.VFrameSet,.HFrameSet,.ChildFrame,.TileFrameSet
{
	background : #ffffff;
	-nexa-border : 0px none;
}

.MainFrame
{
	background : transparent;
	-nexa-border : 1px solid #0078d6;
}

.MainFrame[status=deactivate]
{
	-nexa-border : 1px solid #e5e5e5;
}


/**********************TitleBar***********************************************/
.TitleBarControl
{
	background : #f5f5f5;
	-nexa-border : 1px solid #cccccc;
	-nexa-padding : 0px 0px 0px 10px;
}

.TitleBarControl .titleicon
{
	font : bold 10pt "맑은 고딕";
	color : #000000;
	-nexa-text-align : left;
	-nexa-icon : URL("theme://images/ico_title.png");
	-nexa-icon-position : left;
	-nexa-text-padding : 0px 0px 0px 10px;
}

.TitleBarControl .titleicon[status=deactivate]
{
	color : #adadad;
}

.TitleBarControl .minbutton
{
	background : transparent;
	-nexa-border : 0px none;
	border-radius : 0px;
	-nexa-icon : URL("theme://images/btn_min_N.png");
	-nexa-text-align : center;
}

.TitleBarControl .maxbutton
{
	background : transparent;
	-nexa-border : 0px none;
	border-radius : 0px;
	-nexa-icon : url("theme://images/btn_max_N.png");
	-nexa-text-align : center;
}

.TitleBarControl .normalbutton
{
	background : transparent;
	-nexa-border : 0px none;
	border-radius : 0px;
	-nexa-icon : URL("theme://images/btn_normal_N.png");
	-nexa-text-align : center;
}

.TitleBarControl .closebutton
{
	background : transparent;
	-nexa-border : 0px none;
	border-radius : 0px;
	-nexa-icon : URL("theme://images/btn_close_N.png");
	-nexa-text-align : center;
}

.TitleBarControl .maxbutton[status=mouseover],.TitleBarControl .minbutton[status=mouseover],.TitleBarControl .normalbutton[status=mouseover]
{
	background : #e5e5e5;
	-nexa-border : 0px none;
}

.TitleBarControl .closebutton[status=mouseover]
{
	background : #e81223;
	-nexa-border : 0px none;
	-nexa-icon : URL("theme://images/btn_close_O.png");
}

.TitleBarControl .maxbutton[userstatus=pushed],.TitleBarControl .minbutton[userstatus=pushed],.TitleBarControl .normalbutton[userstatus=pushed]
{
	background : #cccccc;
	-nexa-border : 0px none;
}

.TitleBarControl .closebutton[userstatus=pushed]
{
	background : #f1717b;
	-nexa-border : 0px none;
	-nexa-icon : URL("theme://images/btn_close_O.png");
}

.TitleBarControl .closebutton[status=disabled]
{
	-nexa-border : 0px none;
	-nexa-icon : URL("theme://images/btn_close_D.png");
}

.TitleBarControl .maxbutton[status=disabled]
{
	-nexa-border : 0px none;
	-nexa-icon : URL("theme://images/btn_max_D.png");
}

.TitleBarControl .minbutton[status=disabled]
{
	-nexa-border : 0px none;
	-nexa-icon : URL("theme://images/btn_min_D.png");
}

.TitleBarControl .normalbutton[status=disabled]
{
	-nexa-border : 0px none;
	-nexa-icon : URL("theme://images/btn_normal_D.png");
}


/**********************StatusBar***********************************************/
.StatusBarControl
{
	background : #f2f2f2;
	-nexa-border : 1px solid #cccccc;
	-nexa-padding : 0px 0px 0px 10px;
	-nexa-text-align : left;
}

.StatusBarControl .statustext
{
	background : transparent;
	-nexa-border : 0px none;
	border-radius : 0px;
	font : 8pt "맑은 고딕";
	color : #000000;
}

.StatusBarControl .progressbar
{
	background : #f2f2f2;
	-nexa-border : 1px solid #e5e5e5;
	border-radius : 0px;
	color : #ffffff;
	-nexa-text-align : center;
	-nexa-padding : 5px 5px 5px 5px;
}

.StatusBarControl .progressbar .progressbaritem
{
	background : #4ca0e2;
}

.StatusBarControl .resizegrip
{
	background : transparent;
	-nexa-border : 0px none;
	-nexa-icon : URL("theme://images/img_grip.png");
	-nexa-vertical-align : bottom;
}


/**********************Static***********************************************/
.Static,.StaticControl
{
	background : transparent;
	-nexa-border : 0px none;
	font : 10pt "맑은 고딕";
	color : #000000;
	-nexa-text-align : left;
}

.Static[status=disabled],.StaticControl[status=disabled]
{
	color : #999999;
}


/**********************Button***********************************************/
.Button
{
	background : #e5e5e5;
	-nexa-border : 1px solid #cccccc;
	border-radius : 0px;
	font : 10pt "맑은 고딕";
	color : #000000;
	-nexa-text-padding : 0px 3px 0px 3px;
	-nexa-text-align : center;
}

.Button[status=mouseover]
{
	background : #cccccc;
	-nexa-border : 1px solid #666666;
}

.Button[userstatus=pushed]
{
	background : #606060;
	-nexa-border : 0px none;
	color : #ffffff;
}

.Button[userstatus=selected],.Button[status=focused]
{
	background : #e5e5e5;
	-nexa-border : 2px solid #0078d6;
}

.Button[status=disabled]
{
	background : #cccccc;
	-nexa-border : 0px none;
	color : #999999;
}


/**********************Edit/MaskEdit/TextArea***********************************************/
.Edit
{
	background : #ffffff;
	-nexa-border : 1px solid #999999;
	font : 10pt "맑은 고딕";
	color : #000000;
	-nexa-padding : 0px 3px 0px 3px;
	-nexa-text-align : left;
}

.MaskEdit
{
	background : #ffffff;
	-nexa-border : 1px solid #999999;
	font : 10pt "맑은 고딕";
	color : #000000;
	-nexa-padding : 0px 3px 0px 3px;
	-nexa-text-align : right;
}

.TextArea,.TextAreaControl
{
	background : #ffffff;
	-nexa-border : 1px solid #999999;
	font : 10pt "맑은 고딕";
	color : #000000;
	-nexa-padding : 3px 3px 3px 3px;
	-nexa-text-align : left;
}

.Edit[status=disabled],.MaskEdit[status=disabled],.TextArea[status=disabled],.TextAreaControl[status=disabled]
{
	color : #999999;
	background : #f2f2f2;
	-nexa-border : 1px solid #cccccc;
}

.Edit[status=focused],.MaskEdit[status=focused],.TextArea[status=focused],.TextAreaControl[status=focused]
{
	-nexa-border : 1px solid #0078d6;
	background : #ffffff;
}

.Edit[status=readonly],.MaskEdit[status=readonly],.TextArea[status=readonly],.TextAreaControl[status=readonly]
{
	background : #f9f9f9;
	-nexa-border : 1px solid #cccccc;
}

.Edit[status=mouseover],.MaskEdit[status=mouseover],.TextArea[status=mouseover],.TextAreaControl[status=mouseover]
{
	-nexa-border : 1px solid #0078d6;
	background : #ffffff;
}


/**********************Spin***********************************************/
.Spin
{
	background : #ffffff;
	-nexa-border : 1px solid #999999;
}

.Spin[status=readonly]
{
	background : #f9f9f9;
	-nexa-border : 1px solid #cccccc;
}

.Spin[status=disabled]
{
	-nexa-border : 1px solid #cccccc;
}

.Spin[status=mouseover],.Spin[userstatus=pushed]
{
	-nexa-border : 1px solid #0078d6;
}

.Spin .spinedit
{
	background : transparent;
	-nexa-border : 0px none;
	font : 10pt "맑은 고딕";
	color : #000000;
	-nexa-padding : 0px 3px 0px 3px;
	-nexa-text-align : right;
}

.Spin .spinedit[status=disabled]
{
	color : #999999;
	background : #f2f2f2;
}

.Spin .spinupbutton
{
	background : #f2f2f2;
	-nexa-border : 1px solid #f2f2f2;
	border-radius : 0px;
	-nexa-icon : URL("theme://images/btn_SpinUp_N.png");
	-nexa-text-align : center;
}

.Spin .spinupbutton[userstatus=pushed]
{
	background : #999999;
	-nexa-icon : URL("theme://images/btn_SpinUp_P.png");
}

.Spin .spinupbutton[status=disabled]
{
	background : #f2f2f2;
	-nexa-icon : URL("theme://images/btn_SpinUp_D.png");
}

.Spin .spinupbutton[status=mouseover]
{
	background : #e5e5e5;
	-nexa-icon : URL("theme://images/btn_SpinUp_N.png");
}

.Spin .spindownbutton
{
	background : #f2f2f2;
	-nexa-border : 1px solid #f2f2f2;
	border-radius : 0px;
	-nexa-icon : URL("theme://images/btn_SpinDown_N.png");
	-nexa-text-align : center;
}

.Spin .spindownbutton[userstatus=pushed]
{
	background : #999999;
	-nexa-icon : URL("theme://images/btn_SpinDown_P.png");
}

.Spin .spindownbutton[status=disabled]
{
	background : #f2f2f2;
	-nexa-icon : URL("theme://images/btn_SpinDown_D.png");
}

.Spin .spindownbutton[status=mouseover]
{
	background : #e5e5e5;
	-nexa-icon : URL("theme://images/btn_SpinDown_N.png");
}


/**********************Tab***********************************************/
.Tab
{
	background : transparent;
	-nexa-border : 0px none;
}

.Tab .tabpage
{
	background : #ffffff;
	-nexa-border : 1px solid #cccccc;
}

.Tab .tabbuttonitem
{
	background : #e5e5e5;
	-nexa-border : 1px solid #cccccc;
	border-radius : 0px;
	-nexa-padding : 3px 5px 3px 5px;
	font : 10pt "맑은 고딕";
	color : #000000;
}

.Tab .tabbuttonitem[userstatus=selected],.Tab .tabbuttonitem[status=focused][userstatus=selected]
{
	background : #ffffff;
	-nexa-border : 1px solid #cccccc, 1px solid #cccccc, 1px solid transparent, 1px solid #cccccc;
	color : #000000;
}

.Tab .tabbuttonitem[status=mouseover]
{
	background : #e0effa;
	-nexa-border : 1px solid #4ca0e2;
}

.Tab .tabbuttonitem[status=disabled]
{
	background : #f2f2f2;
	-nexa-border : 1px solid #e5e5e5;
	color : #999999;
}

.Tab .tabbuttonitem .extrabutton
{
	background : transparent;
	-nexa-border : 0px none;
	-nexa-icon : url("theme://images/btn_tabExtra_N.png");
	-nexa-icon-position : right;
}

.Tab .tabbuttonitem .extrabutton[status=mouseover]
{
	-nexa-icon : url("theme://images/btn_tabExtra_O.png");
}

.Tab .tabbuttonitem .extrabutton[status=disabled]
{
	-nexa-icon : url("theme://images/btn_tabExtra_D.png");
}

.Tab .nextbutton[status=disabled]
{
	background : #d9d9d9;
	-nexa-border : 1px solid #f0f0f0;
	-nexa-icon : url("theme://images/btn_tabnext_P.png");
	-nexa-text-align : center;
}

.Tab .prevbutton[status=disabled]
{
	background : #d9d9d9;
	-nexa-border : 1px solid #f0f0f0;
	-nexa-icon : url("theme://images/btn_tabprev_P.png");
	-nexa-text-align : center;
}

.Tab .nextbutton,.Tab .nextbutton[status=focused]
{
	background : #e5e5e5;
	-nexa-border : 1px solid #cccccc;
	border-radius : 0px;
	-nexa-icon : url("theme://images/btn_tabnext_N.png");
	-nexa-text-align : center;
}

.Tab .prevbutton,.Tab .prevbutton[status=focused]
{
	background : #e5e5e5;
	-nexa-border : 1px solid #cccccc;
	border-radius : 0px;
	-nexa-icon : url("theme://images/btn_tabprev_N.png");
	-nexa-text-align : center;
}

.Tab .nextbutton[status=mouseover]
{
	background : #cccccc;
	-nexa-border : 1px solid #666666;
	-nexa-icon : url("theme://images/btn_tabnext_N.png");
}

.Tab .prevbutton[status=mouseover]
{
	background : #cccccc;
	-nexa-border : 1px solid #666666;
	-nexa-icon : url("theme://images/btn_tabprev_N.png");
}

.Tab .nextbutton[userstatus=pushed]
{
	background : #606060;
	-nexa-border : 1px solid #606060;
	-nexa-icon : url("theme://images/btn_tabnext_P.png");
}

.Tab .prevbutton[userstatus=pushed]
{
	background : #606060;
	-nexa-border : 1px solid #606060;
	-nexa-icon : url("theme://images/btn_tabprev_P.png");
}


/**********************CheckBox***********************************************/
.CheckBox
{
	background : transparent;
	-nexa-border : 0px none;
	border-radius : 0px;
	font : 10pt "맑은 고딕";
	color : #000000;
	-nexa-text-align : left;
	-nexa-text-padding : 0px 0px 0px 3px;
	-nexa-icon : URL("theme://images/img_check_NN.png");
	-nexa-icon-position : left;
}

.CheckBox[userstatus=selected]
{
	-nexa-icon : URL("theme://images/img_check_NS.png");
}

.CheckBox[status=mouseover]
{
	-nexa-icon : URL("theme://images/img_check_ON.png");
}
.CheckBox[status=focused]
{
	-nexa-border : 1px solid blue;
}

.CheckBox[status=mouseover][userstatus=selected]
{
	-nexa-icon : URL("theme://images/img_check_OS.png");
}

.CheckBox[status=disabled]
{
	color : #999999;
	-nexa-icon : URL("theme://images/img_check_DN.png");
}

.CheckBox[status=disabled][userstatus=selected]
{
	color : #999999;
	-nexa-icon : URL("theme://images/img_check_DS.png");
}


/**********************Radio***********************************************/
.Radio
{
	background : transparent;
	-nexa-border : 0px none;
}

.Radio .radioitem
{
	background : transparent;
	-nexa-border : 0px none;
	border-radius : 0px;
	font : 10pt "맑은 고딕";
	color : #000000;
	-nexa-text-align : left;
	-nexa-text-padding : 0px 0px 0px 3px;
	-nexa-icon : URL("theme://images/img_Radio_NN.png");
	-nexa-icon-position : left;
}

.Radio .radioitem[userstatus=selected]
{
	-nexa-icon : URL("theme://images/img_Radio_NS.png");
}

.Radio .radioitem[status=mouseover]
{
	-nexa-icon : URL("theme://images/img_Radio_ON.png");
}

.Radio .radioitem[status=mouseover][userstatus=selected]
{
	-nexa-icon : URL("theme://images/img_Radio_OS.png");
}

.Radio .radioitem[status=disabled]
{
	color : #999999;
	-nexa-icon : URL("theme://images/img_Radio_DN.png");
}

.Radio .radioitem[status=disabled][userstatus=selected]
{
	color : #999999;
	-nexa-icon : URL("theme://images/img_Radio_DS.png");
}


/**********************Calendar***********************************************/
.Calendar,.CalendarControl
{
	background : #ffffff;
	-nexa-border : 1px solid #999999;
}
.Calendar[status=focused]
{
	-nexa-border : 1px solid red;
}

.Calendar .calendaredit,.CalendarControl .calendaredit
{
	background : transparent;
	-nexa-border : 0px none;
	font : 10pt "맑은 고딕";
	color : #000000;
	-nexa-padding : 0px 3px 0px 3px;
	-nexa-text-align : left;
}

.Calendar .calendaredit[status=disabled],.CalendarControl .calendaredit[status=disabled]
{
	color : #999999;
}

.Calendar .dropbutton,.CalendarControl .dropbutton
{
	background : #f2f2f2;
	-nexa-border : 0px none;
	border-radius : 0px;
	-nexa-icon : url("theme://images/btn_CalDrop_N.png");
	-nexa-text-align : center;
}

.Calendar .dropbutton[status=mouseover],.CalendarControl .dropbutton[status=mouseover]
{
	background : #e5e5e5;
}

.Calendar .dropbutton[userstatus=pushed],.CalendarControl .dropbutton[userstatus=pushed]
{
	background : #999999;
	-nexa-icon : url("theme://images/btn_CalDrop_P.png");
}

.Calendar .dropbutton[status=disabled],.CalendarControl .dropbutton[status=disabled]
{
	background : #f0f0f0;
	-nexa-icon : url("theme://images/btn_CalDrop_D.png");
}

.Calendar .calendarspinupbutton,.CalendarControl .calendarspinupbutton
{
	background : #f2f2f2;
	-nexa-border : 0px none;
	border-radius : 0px;
	-nexa-icon : URL("theme://images/btn_SpinUp_N.png");
	-nexa-text-align : center;
}

.Calendar .calendarspinupbutton[userstatus=pushed],.CalendarControl .calendarspinupbutton[userstatus=pushed]
{
	background : #999999;
	-nexa-icon : URL("theme://images/btn_SpinUp_P.png");
}

.Calendar .calendarspinupbutton[status=disabled],.CalendarControl .calendarspinupbutton[status=disabled]
{
	background : #f0f0f0;
	-nexa-icon : URL("theme://images/btn_SpinUp_D.png");
}

.Calendar .calendarspinupbutton[status=mouseover],.CalendarControl .calendarspinupbutton[status=mouseover]
{
	background : #e5e5e5;
	-nexa-icon : URL("theme://images/btn_SpinUp_N.png");
}

.Calendar .calendarspindownbutton,.CalendarControl .calendarspindownbutton
{
	background : #f2f2f2;
	-nexa-border : 0px none;
	border-radius : 0px;
	-nexa-icon : URL("theme://images/btn_SpinDown_N.png");
	-nexa-text-align : center;
}

.Calendar .calendarspindownbutton[userstatus=pushed],.CalendarControl .calendarspindownbutton[userstatus=pushed]
{
	background : #999999;
	-nexa-icon : URL("theme://images/btn_SpinDown_P.png");
}

.Calendar .calendarspindownbutton[status=disabled],.CalendarControl .calendarspindownbutton[status=disabled]
{
	background : #f0f0f0;
	-nexa-icon : URL("theme://images/btn_SpinDown_D.png");
}

.Calendar .calendarspindownbutton[status=mouseover],.CalendarControl .calendarspindownbutton[status=mouseover]
{
	background : #e5e5e5;
	-nexa-icon : URL("theme://images/btn_SpinDown_N.png");
}


/**********************DatePickerControl***********************************************/
.DatePickerControl
{
	background : #ffffff;
	-nexa-border : 1px solid #e5e5e5;
}

.DatePickerControl .head
{
	background : transparent;
	-nexa-border : 0px none, 0px none, 1px solid #e5e5e5, 0px none;
	font : 12pt "맑은 고딕";
	color : #000000;
	-nexa-text-align : center;
}

.DatePickerControl .head .monthstatic,.DatePickerControl .head .yearstatic
{
	background : transparent;
	-nexa-border : px none;
	font : 12pt "맑은 고딕";
	color : #000000;
	-nexa-text-align : center;
}

.DatePickerControl .head .nextbutton
{
	background : #ffffff;
	-nexa-border : 0px none;
	-nexa-icon : URL("theme://images/btn_next_N.png");
	-nexa-text-align : center;
	-nexa-padding : 3px;
}

.DatePickerControl .head .prevbutton
{
	background : #ffffff;
	-nexa-border : 0px none;
	-nexa-icon : URL("theme://images/btn_prev_N.png");
	-nexa-text-align : center;
	-nexa-padding : 3px;
}

.DatePickerControl .head .prevbutton[userstatus=pushed]
{
	background : #999999;
	-nexa-border : 0px none;
	-nexa-icon : url("theme://images/btn_prev_P.png");
}

.DatePickerControl .head .nextbutton[userstatus=pushed]
{
	background : #999999;
	-nexa-border : 0px none;
	-nexa-icon : url("theme://images/btn_next_P.png");
}

.DatePickerControl .head .nextbutton[status=mouseover]
