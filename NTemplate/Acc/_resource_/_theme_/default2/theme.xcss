.Grid .head .row .cell .cellbutton[status=mouseover]
{
	background : #cccccc;
	-nexa-border : 1px solid #666666;
}

.Grid .head .row .cell .cellbutton[userstatus=pushed]
{
	background : #606060;
	-nexa-border : 0px none;
	color : #ffffff;
}

.Grid .head .row .cell .cellbutton[userstatus=selected],.Grid .body .row .cell .cellbutton[status=focused]
{
	background : #e5e5e5;
	-nexa-border : 2px solid #0078d6;
}

.Grid .head .row .cell .cellbutton[status=disabled]
{
	background : #cccccc;
	-nexa-border : 0px none;
	color : #999999;
}

.Grid .summary
{
	background : transparent;
	-nexa-border : 0px none;
}

/*---------------------------------------------------------------summary---------------------------------------------------------------------*/
.Grid .summary .row .cell
{
	background : #f7d09d;
	-nexa-border : 1px solid #e5e5e5;
	font : 10pt "맑은 고딕";
	color : #000000;
	-nexa-text-align : center;
}

/*---------------------------------------------------------------body---------------------------------------------------------------------*/
.Grid .body
{
	background : transparent;
	-nexa-border : 0px none;
}

.Grid .body .row .cell
{
	background : #ffffff;
	-nexa-border : 1px solid #e5e5e5;
	font : 10pt "맑은 고딕";
	color : #000000;
	-nexa-text-align : center;
	-nexa-background-odd : #f7f7f7;
	-nexa-padding : 2px;
}

.Grid .body .row .cell[userstatus=selected]
{
	background : #99c9ef;
	/*-nexa-background-odd : #99c9ef;*/
}

/*-----------------------------------cellbutton------------------------------------*/
.Grid .body .row .cell .cellbutton
{
	background : #e5e5e5;
	-nexa-border : 1px solid #cccccc;
	border-radius : 0px;
	font : 10pt "맑은 고딕";
	color : #000000;
	-nexa-text-padding : 0px 3px 0px 3px;
	-nexa-text-align : center;
}

.Grid .body .row .cell .cellbutton[status=mouseover]
{
	background : #cccccc;
	-nexa-border : 1px solid #666666;
}

.Grid .body .row .cell .cellbutton[userstatus=pushed]
{
	background : #606060;
	-nexa-border : 0px none;
	color : #ffffff;
}

.Grid .body .row .cell .cellbutton[userstatus=selected],.Grid .body .row .cell .cellbutton[status=focused]
{
	background : #e5e5e5;
	-nexa-border : 2px solid #0078d6;
}

.Grid .body .row .cell .cellbutton[status=disabled]
{
	background : #cccccc;
	-nexa-border : 0px none;
	color : #999999;
}

/*------------------------------------------------------------------cellexpandbutton--------------------------------------------------------------------------------------*/
.Grid .body .row .cell .cellexpandbutton,.Grid .body .row .cell .cellexpandbutton[userstatus=selected],.Grid .body .row .cell .cellexpandbutton[status=focused]
{
	background : transparent;
	-nexa-border : 0px none;
	border-radius : 0px;
	font : 10pt "맑은 고딕";
	color : #ffffff;
	-nexa-icon : URL("theme://images/btn_GridExpand_N.png");
	-nexa-text-align : center;
}

.Grid .body .row .cell .cellexpandbutton[status=mouseover],.Grid .body .row .cell .cellexpandbutton[userstatus=pushed]
{
	background : #4ca0e2;
	-nexa-icon : URL("theme://images/btn_GridExpand_P.png");
}

.Grid .body .row .cell .cellexpandbutton[status=disabled]
{
	opacity : 0.40;
}

/*---------------------------------------------------------------celleidt/cellmaskedit/celltextarea---------------------------------------------------------------------*/
.Grid .body .row .cell .celledit
{
	background : #ffffff;
	-nexa-border : 1px solid #999999;
	font : 10pt "맑은 고딕";
	color : #000000;
	-nexa-padding : 0px 3px 0px 3px;
	-nexa-text-align : left;
}

.Grid .body .row .cell .cellmaskedit
{
	background : #ffffff;
	-nexa-border : 1px solid #999999;
	font : 10pt "맑은 고딕";
	color : #000000;
	-nexa-padding : 0px 3px 0px 3px;
	-nexa-text-align : right;
}

.Grid .body .row .cell .celltextarea
{
	background : #ffffff;
	-nexa-border : 1px solid #999999;
	font : 10pt "맑은 고딕";
	color : #000000;
	-nexa-padding : 3px 3px 3px 3px;
	-nexa-text-align : left;
}

.Grid .body .row .cell .celledit[status=disabled],.Grid .body .row .cell .cellmaskEdit[status=disabled],.Grid .body .row .cell .celltextarea[status=disabled]
{
	color : #999999;
	background : #f2f2f2;
	-nexa-border : 1px solid #cccccc;
}

.Grid .body .row .cell .celledit[status=focused],.Grid .body .row .cell .cellmaskedit[status=focused],.Grid .body .row .cell .celltextarea[status=focused]
{
	-nexa-border : 1px solid #0078d6;
	background : #ffffff;
}

.Grid .body .row .cell .celledit[status=readonly],.Grid .body .row .cell .cellmaskedit[status=readonly],.Grid .body .row .cell .celltextarea[status=readonly]
{
	background : #f9f9f9;
	-nexa-border : 1px solid #cccccc;
}

.Grid .body .row .cell .celledit[status=mouseover],.Grid .body .row .cell .cellmaskedit[status=mouseover],.Grid .body .row .cell .celltextarea[status=mouseover]
{
	-nexa-border : 1px solid #0078d6;
	background : #ffffff;
}

/*---------------------------------------------------------------cellcheckbox---------------------------------------------------------------------*/
.Grid .body .row .cell .cellcheckbox
{
	background : transparent;
	-nexa-icon : URL("theme://images/img_check_NN.png");
}

.Grid .body .row .cell .cellcheckbox[userstatus=selected]
{
	-nexa-icon : URL("theme://images/img_check_NS.png");
}

.Grid .body .row .cell .cellcheckbox[status=mouseover]
{
	-nexa-icon : URL("theme://images/img_check_ON.png");
}

.Grid .body .row .cell .cellcheckbox[status=mouseover][userstatus=selected]
{
	-nexa-icon : URL("theme://images/img_check_OS.png");
}

.Grid .body .row .cell .cellcheckbox[status=disabled]
{
	-nexa-icon : URL("theme://images/img_check_DN.png");
}

.Grid .body .row .cell .cellcheckbox[status=disabled][userstatus=selected]
{
	-nexa-icon : URL("theme://images/img_check_DS.png");
}

/*--------------------------------------celltreeitem-----------------------------------------------------*/
.Grid .body .row .cell .celltreeitem .treeitembutton[userstatus=expand]
{
	background : transparent;
	-nexa-border : 0px none;
	-nexa-icon : URL("theme://images/img_TreeCollapse.png");
}

.Grid .body .row .cell .celltreeitem .treeitembutton[userstatus=collapse]
{
	background : transparent;
	-nexa-border : 0px none;
	-nexa-icon : URL("theme://images/img_TreeExpand.png");
}

.Grid .body .row .cell .celltreeitem .treeitemimage[userstatus=leaf]
{
	-nexa-icon : URL("theme://images/img_TreeItem.png");
}

.Grid .body .row .cell .celltreeitem .treeitemimage[userstatus=collapse]
{
	-nexa-icon : URL("theme://images/img_TreeClose.png");
}

.Grid .body .row .cell .celltreeitem .treeitemimage[userstatus=expand]
{
	-nexa-icon : URL("theme://images/img_TreeOpen.png");
}

.Grid .body .row .cell .celltreeitem .treeitemcheckbox
{
	-nexa-icon : URL("theme://images/img_TreeCheck_N.png");
}

.Grid .body .row .cell .celltreeitem .treeitemcheckbox[userstatus=selected]
{
	-nexa-icon : URL("theme://images/img_TreeCheck_S.png");
}

.Grid .body .row .cell .celltreeline
{
	-nexa-border : 1px dotted #999999;
}


/**********************Plugin/WebBrowser***********************************************/
.Plugin,.PluginControl,.WebBrowser,.WebBrowserControl
{
	-nexa-border : 1px solid #e5e5e5;
}


/**********************Sketch***********************************************/
.Sketch
{
	background : #ffffff;
	-nexa-border : 1px solid #e5e5e5;
	border-radius : 0px;
	font : 10pt "맑은 고딕";
	color : #666666;
	-nexa-text-align : center;
}

.Sketch[status=disabled]
{
	background : #f2f2f2;
	-nexa-border : 1px solid #e5e5e5;
	color : #999999;
}
]]></XCSS>
