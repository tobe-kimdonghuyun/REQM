        <Static id="Static11" taborder="4" text="Static11" left="200" top="518" height="1" background="#333333" right="200" accessibilityenable="false"/>
        <Static id="Static10" taborder="5" text="이용약관 및 개인정보 수집/이용안내를 확인해주세요." left="200" top="519" height="55" right="200" padding="0px 0px 0px 50px" background="url('theme://images/ico_Info.png') no-repeat left center #f6f7f9" accessibilitydescription="*"/>
        <CheckBox id="CheckBox00" taborder="6" left="215" top="611" width="30" height="30" cssclass="chk_WF_AgreeFull" text="" accessibilitylabel="전체동의 투비소프트 이용약관, 개인정보 수집 및 이용, 위치기반서비스 이용약관(선택), 프로모션 정보 수신(선택)에 모두 동의합니다." initvalueid="iv_CheckBox0"/>
        <Static id="Static05" taborder="7" text="투비소프트 이용약관, 개인정보 수집 및 이용, 위치기반서비스 이용약관(선택), &#13;&#10;프로모션 정보 수신(선택)에 모두 동의합니다." left="250" top="590" height="80" right="200" usedecorate="true" color="#555555" font="normal 13pt/24px &quot;Malgun Gothic&quot;"/>
        <Static id="Static06" taborder="8" text="투비소프트 이용약관 동의 &lt;fc v='#F03061'&gt;&lt;b v='true'&gt;(필수)&lt;/b&gt;&lt;/fc&gt;" left="200" top="680" height="60" right="200" cssclass="sta_WF_TermsLabel" usedecorate="true"/>
        <Div id="Div00" taborder="9" left="200" top="Static06:-1" height="150" accessibilityenable="false" cssclass="div_MF_Terms" right="200">
          <Layouts>
            <Layout>
              <Static id="Static00" taborder="0" text="여러분을 환영합니다." left="20" top="16" height="40" right="20" cssclass="sta_WF_TextTerms"/>
              <Static id="Static01" taborder="1" text="투비소프트 서비스 및 제품(이하 ‘서비스’)을 이용해 주셔서 감사합니다. 본 약관은 다양한 투비소프트 서비스의 이용과 관련하여 투비소프트 서비스를 제공하는 투비소프트 주식회사(이하 ‘투비소프트’)와 이를 이용하는 투비소프트 서비스 회원(이하 ‘회원’) 또는 비회원과의 관계를 설명하며, 아울러 여러분의 투비소프트 서비스 이용에 도움이 될 수 있는 유익한 정보를 포함하고 있습니다." left="20" top="68" height="70" right="20" cssclass="sta_WF_TextTerms"/>
              <Static id="Static02" taborder="2" text="투비소프트 서비스를 이용하시거나 투비소프트 서비스 회원으로 가입하실 경우 여러분은 본 약관 및 관련 운영 정책을 확인하거나 동의하게 되므로, 잠시 시간을 내시어 주의 깊게 살펴봐 주시기 바랍니다." left="20" top="153" height="60" right="20" cssclass="sta_WF_TextTerms"/>
              <Static id="Static03" taborder="3" text="공지 일자: 2022년 12월 5일&#13;&#10;적용 일자: 2022년 12월 5일&#13;&#10;투비소프트 서비스와 관련하여 궁금하신 사항이 있으시면 고객센터(대표번호: 0000 – 0000/ 평일 10:00~17:00)로 문의 주시기 바랍니다." left="20" top="230" height="70" right="20" cssclass="sta_WF_TextTerms"/>
            </Layout>
            <Layout name="mobile">
              <Static id="Static00" left="20" top="11" height="40" right="70"/>
              <Static id="Static02" left="20" top="379" height="170" right="20"/>
              <Static id="Static03" left="20" top="569" height="170" right="20"/>
              <Static id="Static01" left="20" top="68" height="290" right="20"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="Static14" taborder="10" left="200" top="Div00:-1" height="60" cssclass="sta_WF_TermsLabelBg" right="200" text="&lt;fc v='#F03061'&gt;&lt;b v='true'&gt;(필수)&lt;/b&gt;&lt;/fc&gt;위와 같이 이용약관에 동의하십니까?" usedecorate="true"/>
        <Radio id="Radio00" taborder="11" top="Div00:10" height="38" accessibilitylabel="필수선택 투비소프트이용약관동의" initvalueid="iv_Radio0" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" rowcount="1" right="220" width="209" cssclass="rdo_WF_Agree" value="0" text="동의함" index="0">
          <Dataset id="innerdataset">
