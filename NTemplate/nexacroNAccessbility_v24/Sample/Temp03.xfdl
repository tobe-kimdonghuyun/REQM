        </Radio>
        <Static id="Static07" taborder="12" text="개인정보 수집 및 이용 동의 &lt;fc v='#F03061'&gt;&lt;b v='true'&gt;(필수)&lt;/b&gt;&lt;/fc&gt;" top="Static14:40" height="60" right="200" cssclass="sta_WF_TermsLabel" usedecorate="true" left="200"/>
        <Div id="Div01" taborder="13" left="200" top="Static07:-1" height="150" accessibilityenable="false" text="" cssclass="div_MF_Terms" right="200">
          <Layouts>
            <Layout>
              <Static id="Static00" taborder="0" text="개인정보보호법에 따라 투비소프트에 회원가입 신청하시는 분께 수집하는 개인정보의 항목, 개인정보의 수집 및 이용목적, 개인정보의 보유 및 이용기간, 동의 거부권 및 동의 거부 시 불이익에 관한 사항을 안내 드리오니 자세히 읽은 후 동의하여 주시기 바랍니다." left="20" top="23" height="60" right="20" cssclass="sta_WF_TextTerms"/>
              <Static id="Static01" taborder="1" text="1. 수집하는 개인정보" left="20" top="113" height="40" right="20" cssclass="sta_WF_TextTerms"/>
              <Static id="Static02" taborder="2" text="2. 수집한 개인정보의 이용" left="20" top="166" height="40" right="20" cssclass="sta_WF_TextTerms"/>
              <Static id="Static03" taborder="3" text="3. 개인정보의 보관기간" left="20" top="219" height="40" right="20" cssclass="sta_WF_TextTerms"/>
              <Static id="Static04" taborder="4" text="4. 개인정보 수집 및 이용 동의를 거부할 권리" left="20" top="272" height="40" right="20" cssclass="sta_WF_TextTerms"/>
            </Layout>
