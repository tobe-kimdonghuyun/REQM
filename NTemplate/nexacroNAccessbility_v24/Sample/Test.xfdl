    <Script type="xscript5.1"><![CDATA[/**
*  Nexacro Accessibility
*  @FileName 	Test.xfdl 
*  @Creator 	TOBESOFT
*  @CreateDate 	2022.12.15
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.12.15     		TOBESOFT		 		최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
//this.objApp = this.gfnGetApplication();

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.gfnFormOnLoad(obj);

	var sUrl = window.location.protocol + "//" + window.location.host;

	if (sUrl.indexOf("mobiletong.tobesoft.com") > -1)
	{
		var sHtml = sUrl + "/nexacroNAccessbility/html/web.html";
	}
	else if (sUrl.indexOf("172.10.11.92") > -1 || sUrl.indexOf("localhost") > -1)
	{
		var sHtml = sUrl + "/npN/accessbility/html/web.html";
	}	
	else
	{
		var sHtml = sUrl + "/accessbility/html/web.html";
	}
	
	this.WebBrowser00.set_url(sHtml);
};

/*******************************************************************************************************************************
 * Transaction 서비스호출 처리 영역
*******************************************************************************************************************************/

/*******************************************************************************************************************************
 * Callback 영역 (Transaction, popup, message..)
*******************************************************************************************************************************/

/*******************************************************************************************************************************
 * 사용자 Function 영역
*******************************************************************************************************************************/

/*******************************************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
*******************************************************************************************************************************/


this.btnPopup_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (nexacro._isMobile())
	{
		this.gfnOpenPopupM("test", "Sample::TempPop01.xfdl", "", "fnPopCallback", "");
	}
	else
	{
		this.gfnOpenPopup("test", "Sample::TempPop01.xfdl", "", "fnPopCallback", "");
	}
};
]]></Script>
