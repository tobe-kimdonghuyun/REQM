*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.objApp = this.gfnGetApplication();

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.gfnFormOnLoad(obj);
	
	var sUrl = "";
	var sHtml = "";
	
	if (system.navigatorname == "nexacro" )
	{		
		sUrl = nexacro.getProjectPath();		
		
		if (sUrl.indexOf("file://") > -1)
		{	//file://C:\web.html	
			sHtml = sUrl + "html\\web.html";
		}
		else
		{
			sHtml = sUrl + "html/web.html";
		}
	}
	else
	{
		sUrl = window.location.protocol + "//" + window.location.host;
		if (sUrl.indexOf("mobiletong.tobesoft.com") > -1)
		{
			sHtml = sUrl + "/nexacroNAccessbility/html/web.html";
		}
		else if (sUrl.indexOf("172.10.11.92") > -1 || sUrl.indexOf("localhost") > -1)
		{
			sHtml = sUrl + "/npN/accessbility/html/web.html";
		}	
		else
		{
			sHtml = sUrl + "/html/web.html";
		}		
	}
//trace(sHtml);
	this.WebBrowser00.set_url(sHtml);
};

/*******************************************************************************************************************************
 * Transaction 서비스호출 처리 영역
*******************************************************************************************************************************/

/*******************************************************************************************************************************
 * Callback 영역 (Transaction, popup, message..)
*******************************************************************************************************************************/

/*******************************************************************************************************************************
 * 사용자 Function 영역
*******************************************************************************************************************************/

/*******************************************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
*******************************************************************************************************************************/
this.Tab01_onextrabuttonclick = function(obj:nexacro.Tab,e:nexacro.TabMouseEventInfo)
{
	//ctrl + backspace
	trace("Tab01_onextrabuttonclick");
};


//RP 101592 그리드 head의 checkbox 셀 스페이스 키로 선택/해제 하기 위한 설정	 (화면 별로 진행 혹은 공통 함수 작성 필요)
this.Div00_Grid01_onkeydown = function(obj:nexacro.Grid,e:nexacro.KeyEventInfo)
{
	//space && head && checkbox
	if (e.keycode == 32 && obj.currentrow == -1 && obj.getCellProperty("head", obj.currentcell, "edittype") == "checkbox") 
	{
		var v = obj.getHeadValue(obj.currentcell);
		if (v)
		{
			obj.setHeadValue(obj.currentcell, false);
		}
		else
		{
			obj.setHeadValue(obj.currentcell, true);
		}
		
	   //스페이스 눌렀을 때 onheadclick 이벤트를 타지 않음.
	   this._fnGridSelectAllCheckbox(obj); //스페이스 선택 시 전체선택/해제 로직 호출
	}    
};

this._fnGridSelectAllCheckbox = function (objGrid)
{
	if (objGrid.readonly == true) return true;
	var nCell = objGrid.currentcell;
	var nCol = objGrid.currentcol;
	
	if (objGrid.getCellProperty("head", nCell, "edittype") != "checkbox") return false;
	if (objGrid.getCellProperty("body", nCol, "edittype") != "checkbox") return false;
	
	var dsObj = objGrid.getBindDataset();
	var strChkCol = objGrid.getCellProperty("body", nCol, "text");

	if(!strChkCol || strChkCol == "" || (strChkCol.indexOf("bind:") < 0)) return false;
	strChkCol = strChkCol.split("bind:").join("");
	
	var strVal;
	var sTxt = objGrid.getCellProperty("head", nCell, "text");
	if(	!sTxt || sTxt == "" || sTxt == "0" ) {
		strVal = "1";
	} else {
		strVal = "0";
	}

	objGrid.setCellProperty( "head", nCell, "text", strVal);
	
	dsObj.set_enableevent(false); 
	for ( var r = 0 ; r < dsObj.getRowCount() ; r++ ) {
		dsObj.setColumn(r, strChkCol, strVal);  
	}
	dsObj.set_enableevent(true);	
	dsObj = null;
	
	return true;
}; 



this.Div00_Grid01_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if (e.cell == 0) {
		this._fnGridSelectAllCheckbox(obj);
	}	
};

]]></Script>
