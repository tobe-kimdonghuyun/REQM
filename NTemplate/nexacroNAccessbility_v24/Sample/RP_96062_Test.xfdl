        <Button id="btnPopup" taborder="1" text="팝업" left="140" top="9" width="148" height="61" onclick="btnPopup_onclick"/>
        <Button id="btnSearch" taborder="2" text="조회" left="339" top="13" width="142" height="57" onclick="btnSearch_onclick"/>
        <Div id="Div00" taborder="3" text="Div00" left="2" top="93" width="1058" height="287" accessibilityenable="false">
          <Layouts>
            <Layout>
              <Grid id="grdList" taborder="0" left="0" top="3" autofittype="col" autoenter="select" uFunction="filter,sort,!colfix,!initial,find" minheight="250" maxheight="" height="277" accessibilitylabel="사용자" nodatatext="NO DATA" width="1058">
                <Formats>
                  <Format id="default">
                    <Columns>
                      <Column size="31"/>
                      <Column size="100"/>
                      <Column size="110"/>
                      <Column size="100"/>
                      <Column size="100"/>
                      <Column size="100"/>
                      <Column size="92"/>
                    </Columns>
                    <Rows>
                      <Row size="32" band="head"/>
                      <Row size="32"/>
                    </Rows>
                    <Band id="head">
                      <Cell text="선택"/>
                      <Cell col="1" text="사용자 ID"/>
                      <Cell col="2" text="사번/ID"/>
                      <Cell col="3" text="사용자명"/>
                      <Cell col="4" text="부서"/>
                      <Cell col="5" text="입사일"/>
                      <Cell col="6" text="수정"/>
                    </Band>
                    <Band id="body">
                      <Cell displaytype="checkboxcontrol" edittype="checkbox" text="bind:CHK"/>
                      <Cell col="1" text="bind:USER_ID" displaytype="editcontrol" edittype="text"/>
                      <Cell col="2" text="bind:EMP_NO" edittype="text" editimemode="hangul" editmaxlength="10" displaytype="editcontrol"/>
                      <Cell col="3" text="bind:KORN_NM" displaytype="editcontrol" edittype="text" editinputtype="digit"/>
                      <Cell col="4" text="bind:DEPT_NM" edittype="combo" combodataset="dsDept" combodatacol="NAME" combocodecol="CODE" displaytype="combocontrol"/>
                      <Cell col="5" text="bind:HIRE_DATE" edittype="date" displaytype="calendarcontrol" calendardateformat="yyyy-MM-dd"/>
                      <Cell col="6" displaytype="buttoncontrol" edittype="button" text="수정"/>
                    </Band>
                  </Format>
                  <Format id="format00">
                    <Columns>
                      <Column size="100"/>
                      <Column size="110"/>
                      <Column size="100"/>
                      <Column size="100"/>
                      <Column size="100"/>
                      <Column size="100"/>
                    </Columns>
                    <Rows>
                      <Row size="50" band="head"/>
                      <Row size="50"/>
                    </Rows>
                    <Band id="head">
                      <Cell text="사용자 ID"/>
                      <Cell col="1" text="사번/ID"/>
                      <Cell col="2" text="사용자명"/>
                      <Cell col="3" text="부서"/>
                      <Cell col="4" text="재직상태"/>
                      <Cell col="5" text="수정"/>
                    </Band>
                    <Band id="body">
