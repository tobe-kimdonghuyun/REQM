    <Script type="xscript5.1"><![CDATA[/**
*  Nexacro Accessibility
*  @FileName 	Temp03_2.xfdl 
*  @Creator 	TOBESOFT
*  @CreateDate 	2022.12.15
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.12.15     		TOBESOFT		 		최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.objApp = this.gfnGetApplication();

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.gfnFormOnLoad(obj);
	nexacro.getApplication().mainframe.titletext = "가입완료|회원가입|템플릿01|접근성지원시스템";
	
	if (this.objApp.gvOs.indexOf("WINDOWS") > -1)
	{	
		this.setEventHandler("onsize", this.form_onsize, this);
		this.fnCenterMove();
	}
};

this.form_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnCenterMove();
};

/*******************************************************************************************************************************
 * Transaction 서비스호출 처리 영역
*******************************************************************************************************************************/

/*******************************************************************************************************************************
 * Callback 영역 (Transaction, popup, message..)
*******************************************************************************************************************************/

/*******************************************************************************************************************************
 * 사용자 Function 영역
*******************************************************************************************************************************/
this.fnCenterMove = function()
{
	var nLeft = nexacro.round((this.getOffsetWidth() - this.divMove.width ) /2);
	this.divMove.move(nLeft, 337);
}
/*******************************************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
*******************************************************************************************************************************/
this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.objApp.nexacroBase.divContents.form.divCenter.set_url("Sample::Temp03_1.xfdl");	
	var firstComp = this.objApp.nexacroBase.divTop.form.getFirstAccessibilityComponent(true);
	firstComp.setFocus();
};
]]></Script>
  </Form>
