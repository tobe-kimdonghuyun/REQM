    <Script type="xscript5.1"><![CDATA[/**
*  Nexacro Accessibility
*  @FileName 	Temp01.xfdl 
*  @Creator 	TOBESOFT
*  @CreateDate 	2022.12.15
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.12.15     		TOBESOFT		 		최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.objApp = this.gfnGetApplication();

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.gfnFormOnLoad(obj);
	
	//readonly css 추가 (접근성 대응)
	this.fnSetReadonlyCss();
};

/*******************************************************************************************************************************
 * Transaction 서비스호출 처리 영역
*******************************************************************************************************************************/

/*******************************************************************************************************************************
 * Callback 영역 (Transaction, popup, message..)
*******************************************************************************************************************************/

/*******************************************************************************************************************************
 * 사용자 Function 영역
*******************************************************************************************************************************/
this.fnSetReadonlyCss = function()
{
	var nCnt = this.components.length;
	for (var i = 0; i < nCnt; i++) 
	{
		var comp = this.components[i];
		if (comp.readonly) {
			comp.addEventHandler("onsetfocus",this.readonly_setfocus,obj);
			comp.addEventHandler("onkillfocus",this.readonly_killfocus,obj);
		}
	}
}

this.readonly_setfocus = function(obj, e)
{
	obj.cssclass = (obj.cssclass? obj.cssclass+"," : "") + "readonly";
}

this.readonly_killfocus = function(obj, e)
{
	obj.cssclass = obj.cssclass.replace(",readonly","").replace("readonly","");
}
/*******************************************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
*******************************************************************************************************************************/]]></Script>
  </Form>
</FDL>
