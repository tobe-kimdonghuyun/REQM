        <Static id="Static36" taborder="46" text="그리드 내 현재 위치 기준 첫번째 또는 마지막 컬럼 이동" left="720" top="1723" height="90" right="100" cssclass="sta_WF_DetailBg"/>
        <Static id="Static28" taborder="47" left="386" top="1812" width="335" height="90" cssclass="sta_WF_DetailLabel" accessibilityenable="false"/>
