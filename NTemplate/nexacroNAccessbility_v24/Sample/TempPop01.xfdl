                      <Cell col="1" text="성명"/>
                      <Cell col="2" text="부서"/>
                      <Cell col="3" text="직급"/>
                    </Band>
                    <Band id="body">
                      <Cell text="bind:ID" displaytype="text"/>
                      <Cell col="1" text="bind:NAME" displaytype="text"/>
                      <Cell col="2" text="bind:DEPARTMENT" displaytype="text"/>
                      <Cell col="3" text="bind:DESCRIPTION" displaytype="text"/>
                    </Band>
                  </Format>
                  <Format id="default_00">
                    <Columns>
                      <Column size="150"/>
                      <Column size="150"/>
                      <Column size="150"/>
                      <Column size="150"/>
