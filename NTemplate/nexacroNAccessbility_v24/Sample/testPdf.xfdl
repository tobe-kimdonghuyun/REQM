        <Button id="Button00" taborder="1" text="Button00" left="862" top="56" width="143" height="59" onclick="Button00_onclick"/>
        <Button id="Button01" taborder="2" text="Button01" left="869" top="148" width="130" height="72" onclick="Button01_onclick"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
