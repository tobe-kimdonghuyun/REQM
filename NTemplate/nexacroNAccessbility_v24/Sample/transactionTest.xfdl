// 	this.dsSearch.setColumn(nRow,"SECTDATE"	, "123");
// 	this.dsSearch.setColumn(nRow,"SCD_CD", this.gfnGetArgument("parm"));
// 	this.dsSearch.setColumn(nRow,"SCD_CD2", this.dsMenu.getColumn(5, "PARM"));
// 	this.dsSearch.setColumn(nRow,"YYYYMM"	, "20230213");
	
		this.transaction("test4"
					   , "http://localhost:8080/npN/jsp/select_noDb_SSV.jsp"
					   , "dsSearch=dsSearch"
					   , "gds_employees=ds_employees ds_total=ds_total"
					   , ""
					   , "fncallback"
					   , true, 2);
};


this.gfnGetArgument = function(sName)
{
	var ret;
	
	if (this.gfnIsNull(sName))
	{
		ret = this.getOwnerFrame().arguments["menuParam"];
	} else 
	{
		ret = this.getOwnerFrame().arguments[sName];
	}
	
	return ret;
};

this.Button03_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsSearch.clearData();
	var nRow = this.dsSearch.addRow();
	this.dsSearch.setColumn(nRow,"SECTDATE"	, "123");
	this.dsSearch.setColumn(nRow,"SCD_CD", nexacro.getApplication().gds_employees.getColumn(0, "GENDER"));
	this.dsSearch.setColumn(nRow,"YYYYMM"	, "20230213");
	
		this.transaction("test5"
					   , "http://localhost:8080/npN/jsp/select_noDb_SSV.jsp"
					   , "dsSearch=dsSearch"
					   , "gds_employees=ds_employees ds_total=ds_total"
					   , ""
					   , "fncallback"
					   , true, 2);
};

this.Button04_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.transaction("test6"
				   , "http://localhost:8080/npN/jsp/selectOra.jsp"
				   , ""
				   , "dsList=outDs3"
				   , ""
				   , "fncallback"
				   , true, 0);
};

this.Button05_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.transaction("test4"
				   , "http://localhost:8080/npN/jsp/selectOra_SSV.jsp"
				   , ""
				   , "dsList=outDs3"
				   , ""
				   , "fncallback"
				   , true, 2);
};

this.fncallback = function(svcId, nErrcd, sErrMsg)
{
	trace("================== ");
}]]></Script>
