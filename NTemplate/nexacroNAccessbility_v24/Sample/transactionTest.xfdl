    <Script type="xscript5.1"><![CDATA[
this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
		this.transaction("test1"
					   , "http://localhost:8080/npN/jsp/select_noDb.jsp"
					   , ""
					   , "ds_employees=ds_employees ds_total=ds_total"
					   , "param=ALL"
					   , "fncallback"
					   , true, 0);
};

this.Button00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
		this.transaction("test2"
					   , "http://localhost:8080/npN/jsp/select_noDb.jsp"
					   , ""
					   , "ds_employees=ds_employees ds_total=ds_total"
					   , "param=NO"
					   , "fncallback"
					   , true, 0);
};


this.Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
