// 	this.dsSearch.setColumn(nRow,"YYYYMM", "20230213");

		this.transaction("test3"
					   , "http://localhost:8080/npN/jsp/select_noDb_XML.jsp"
					   , "dsSearch=dsSearch"
					   , "gds_employees=ds_employees ds_total=ds_total"
					   , ""
					   , "fncallback"
					   , true, 0);
};

this.Button02_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

// 	this.getOwnerFrame().arguments = [];
// 	this.getOwnerFrame().arguments["PARM"] = this.dsMenu.getColumn(4, "PARM");
// 	
