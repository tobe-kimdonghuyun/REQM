<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Test" width="1280" height="800" titletext="테스트" background="#F4F4F4" onload="form_onload">
    <Layouts>
      <Layout height="800" width="1280" screenid="Desktop_screen">
        <Button id="btnPopup" taborder="1" text="VOC" left="118" top="8" width="148" height="61" onclick="btnPopup_onclick"/>
        <Button id="Button00" taborder="1" text="모달" left="306" top="12" width="139" height="60" onclick="Button00_onclick"/>
      </Layout>
      <Layout height="768" name="mobile" width="480" screenid="Mobile_screen">
        <Button id="btnPopup" taborder="0" text="팝업모바일" left="128" top="8" width="148" height="61"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  Nexacro Accessibility
*  @FileName 	Test.xfdl 
*  @Creator 	TOBESOFT
*  @CreateDate 	2022.12.15
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.12.15     		TOBESOFT		 		최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
//this.objApp = this.gfnGetApplication();
this.sServerUrl = "http://localhost:8080/npN/accessbility/";
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	if (system.navigatorname != "nexacro"){

		this.fnJsInclude(this.sServerUrl+"js/html2canvas.js");
	}
};


/*******************************************************************************************************************************
 * Transaction 서비스호출 처리 영역
*******************************************************************************************************************************/

/*******************************************************************************************************************************
 * Callback 영역 (Transaction, popup, message..)
*******************************************************************************************************************************/

/*******************************************************************************************************************************
 * 사용자 Function 영역
*******************************************************************************************************************************/

this.fnJsInclude = function(FileDir, strIntegrity, strCrossorigin) 
{ 
    var includejs = document.createElement("script");
    includejs.src = FileDir;
    
    if (strIntegrity)includejs.integrity = strIntegrity;
    if (strCrossorigin)includejs.crossOrigin = strCrossorigin;
    
    document.head.appendChild(includejs);
};

/*******************************************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
*******************************************************************************************************************************/


this.btnPopup_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var popupId = "addBoard";
	var popupUrl = "Sample::boardPu.xfdl";
	var oArg   = { };
	var sPopupCallBack = "fnPopupCallback";
	var sTitle = "게시글";
	var oOption = {title:sTitle
					,titlebar:true
					, popuptype:"modeless"
					};
	this.gfnOpenPopup(popupId, popupUrl, oArg, sPopupCallBack, oOption);


};


this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.gfnOpenPopup("test", "Sample::TestSavePop.xfdl", "", "fnPopCallback", "");
};
]]></Script>
