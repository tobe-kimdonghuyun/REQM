}
,
.Calendar.essential[status=focused]
{
	-nexa-border        : 2px dashed #313340;
}
.Calendar.essential[status=readonly]
{
	background 		: URL("theme://images/essential.png") no-repeat left top #f9f9f9;
}
.Calendar.error,
.Calendar.error[status=mouseover],.Calendar.error[status=focused],
.Calendar.error[status=readonly],.Calendar.error[status=disabled]
{
	-nexa-border 		: 1px solid #ff2d4b;
}

/***** Spin *****/
