/***** Edit *****/
.Edit.essential
{
	-nexa-border 		: 1px solid #f6e5bf;
	background 		: URL("theme://images/essential.png") no-repeat left top #fffdf4;
}
.Edit.essential[status=readonly]
{
	background 		: URL("theme://images/essential.png") no-repeat left top #f9f9f9;
}
.Edit.essentialSub
{
	-nexa-border 		: 1px solid #f6e5bf;
	background 		: #fffdf4;
}
.Edit.edt_WF_SearchEssential
{
	-nexa-border 		: 1px solid #f6e5bf;
	-nexa-padding 		: 0px 30px 0px 8px;
	background 		: URL("theme://images/essential.png") no-repeat left top #fffdf4;
}
.Edit.edt_WF_SearchEssential[status=readonly]
{
	background 		: URL("theme://images/essential.png") no-repeat left top #f9f9f9;
}
.Edit.edt_WF_SearchEssential[userstatus=nulltext]
{
	color          		: #aaaaaa;
}
.Edit.edt_WF_SearchEssential[status=disabled]
{
	-nexa-border 		: 1px solid #dddddd;
	color 			: #aaaaaa;
}
.Edit.output,
.Edit.output[status=mouseover],.Edit.output[status=focused],
.Edit.output[status=readonly],.Edit.output[status=disabled],
.MaskEdit.output,
.MaskEdit.output[status=mouseover],.MaskEdit.output[status=focused],
.MaskEdit.output[status=disabled],
.TextArea.output,
.TextArea.output[status=mouseover],.TextArea.output[status=focused],
.TextArea.output[status=readonly],.TextArea.output[status=disabled]
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px;
	background 		: transparent;
}
.Edit.error,
.Edit.error[userstatus=nulltext],.Edit.error[status=mouseover],
.Edit.error[status=focused],.Edit.error[status=readonly],
.Edit.error[status=disabled]
{
	-nexa-border 		: 1px solid #ee5555;
}

