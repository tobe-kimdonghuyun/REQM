.MaskEdit.error[userstatus=nulltext],.MaskEdit.error[status=mouseover],
.MaskEdit.error[status=focused],.MaskEdit.error[status=readonly],
.MaskEdit.error[status=disabled]
{
	-nexa-border 		: 1px solid #ee5555;
}

/***** Combo *****/
.Combo.essential
{
	-nexa-border 		: 1px solid #f6e5bf;
	background 		: URL("theme://images/essential.png") no-repeat left top #fffdf4;
}
.Combo.essential[status=readonly]
{
	background 		: URL("theme://images/essential.png") no-repeat left top #f9f9f9;
}
.Combo.error,
.Combo.error[status=mouseover],.Combo.error[status=focused],
.Combo.error[status=readonly],.Combo.error[status=disabled]
{
	-nexa-border 		: 1px solid #ff2d4b;
}

/***** Calendar *****/
