<?xml version="1.0" encoding="utf-8"?>
<XCSS version="1.1">
  <CSSData><![CDATA[.Form
{
	-nexa-border 		: 0px none;
	background 		: #ffffff;
	color 			: #333333;
	font 			: 13px "Malgun Gothic";
}

.Form[userstatus=contents]
{
	background 		: transparent;
}
.HScrollBarControl,
.HScrollBarControl[status=mouseover]
{
	-nexa-border 		: 1px solid #e1e2e7, 0px none, 0px none, 0px none;
	-nexa-padding 		: 1px 1px 1px 1px;
	background 		: #ffffff;
}
.HScrollBarControl[status=disabled]
{
	-nexa-border 		: 1px solid #efefef, 0px none, 0px none, 0px none;
	background		: #f9f9f9;
}
.HScrollBarControl .decbutton
{
	-nexa-icon 		: URL("theme://images/btn_WF_Hdec.png");
}
.HScrollBarControl .decbutton[status=mouseover],.HScrollBarControl .decbutton[status=focused],
.HScrollBarControl .decbutton[userstatus=pushed],.HScrollBarControl .decbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/btn_WF_HdecO.png");
}
.HScrollBarControl .decbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/btn_WF_HdecD.png");
}
.HScrollBarControl .incbutton
{
	-nexa-icon 		: URL("theme://images/btn_WF_Hinc.png");
}
.HScrollBarControl .incbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/btn_WF_HincD.png");
}
.HScrollBarControl .incbutton[status=mouseover],.HScrollBarControl .incbutton[status=focused],
.HScrollBarControl .incbutton[userstatus=pushed],.HScrollBarControl .incbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/btn_WF_HincO.png");
}
.HScrollBarControl .trackbar,
.HScrollBarControl .trackbar[status=focused]
{
	background 		: #dcdee2;
}
.HScrollBarControl .trackbar[status=mouseover]
{
	background 		: #e9ebef;
}
.HScrollBarControl .trackbar[userstatus=pushed],.HScrollBarControl .trackbar[userstatus=selected]
{
	background 		: #c0c1c5;
}
.HScrollBarControl .trackbar[status=disabled]
{
	background 		: #e4e4e4;
}
.VScrollBarControl,
.VScrollBarControl[status=mouseover]
{
	-nexa-border 		: 0px none, 0px none, 0px none, 1px solid #e1e2e7;
	-nexa-padding 		: 1px 1px 1px 1px;
	background 		: #ffffff;
}
.VScrollBarControl[status=disabled]
{
	-nexa-border 		: 0px none, 0px none, 0px none, 1px solid #efefef;
	background		: #f9f9f9;
}
.VScrollBarControl .decbutton
{
	-nexa-icon 		: URL("theme://images/btn_WF_Vdec.png");
}
.VScrollBarControl .decbutton[status=mouseover],.VScrollBarControl .decbutton[status=focused],
.VScrollBarControl .decbutton[userstatus=pushed],.VScrollBarControl .decbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/btn_WF_VdecO.png");
}
.VScrollBarControl .decbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/btn_WF_VdecD.png");
}
.VScrollBarControl .incbutton
{
	-nexa-icon 		: URL("theme://images/btn_WF_Vinc.png");
}
.VScrollBarControl .incbutton[status=mouseover],.VScrollBarControl .incbutton[status=focused],
.VScrollBarControl .incbutton[userstatus=pushed],.VScrollBarControl .incbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/btn_WF_VincO.png");
}
.VScrollBarControl .incbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/btn_WF_VincD.png");
}
.VScrollBarControl .trackbar,
.VScrollBarControl .trackbar[status=focused]
{
	background 		: #dcdee2;
}
.VScrollBarControl .trackbar[status=mouseover]
{
	background 		: #e9ebef;
}
.VScrollBarControl .trackbar[userstatus=pushed],.VScrollBarControl .trackbar[userstatus=selected]
{
	background 		: #c0c1c5;
}
.VScrollBarControl .trackbar[status=disabled]
{
	background 		: #e4e4e4;
}

.FrameSet,.VFrameSet,.HFrameSet,.ChildFrame,.TileFrameSet
{
	cursor : auto;
	background : #ffffff;
	-nexa-border : 0px none;
}
.MainFrame
{
	cursor : auto;
	background : transparent;
	-nexa-border : 1px solid #0078d6;
}
.MainFrame[status=deactivate]
{
	-nexa-border : 1px solid #e5e5e5;
}
.TitleBarControl,.TitleBarControl[status=disabled],.TitleBarControl[status=deactivate]
{
	-nexa-border : ;
	-nexa-edge : ;
	-nexa-padding : 0px 0px 0px 30px;
	background : #3c72dc;
	border-radius : ;
	color : #ffffff;
	cursor : ;
	font : 20px "Gulim";
	letter-spacing : ;
	opacity : ;
	word-spacing : ;
}
.TitleBarControl .closebutton,.TitleBarControl .closebutton[status=deactivate],.TitleBarControl .closebutton[status=disabled]
{
	-nexa-border : ;
	-nexa-padding : ;
	-nexa-text-align : ;
	-nexa-vertical-align : ;
	background : ;
	border-radius : ;
	box-shadow : ;
	cursor : pointer;
	opacity : ;
}
.TitleBarControl .closebutton[status=focused],.TitleBarControl .closebutton[status=mouseover]
{
	background : #2a5dc1;
}
.TitleBarControl .closebutton[userstatus=pushed],.TitleBarControl .closebutton[userstatus=selected]
{
	-nexa-padding : 1px 0px 0px 1px;
	background : #2a5dc1;
}
/***************************************************************************/
/*******************	BASE COMPONENT START	****************************/
/***************************************************************************/
/***** Button *****/
.Button
{
	-nexa-border 		: 1px solid #c8cdd7;
	-nexa-padding 		: 0px 12px 0px 12px;
	background 		: #ffffff;
	cursor 			: pointer;
	color 			: #636981;
	letter-spacing 		: -1px;
}
.Button[status=mouseover],
.Button[userstatus=pushed],.Button[userstatus=selected]
{
	-nexa-border 		: 2px solid #313340;
}
.Button[status=focused]
{
	-nexa-border 		: 2px dashed #313340;
	-nexa-padding 		: 0px 11px 0px 11px;
}
.Button[status=disabled]
{
	opacity 		: 0.5;
}

/***** Calendar *****/
.Calendar,
.CalendarControl
{
	-nexa-border 		: 1px solid #dddddd;
	background 		: #ffffff;
}
.Calendar[status=mouseover],.CalendarControl[status=mouseover]
{
	-nexa-border 		: 1px solid #313340;
}
.Calendar[status=focused],.CalendarControl[status=focused]
{
	-nexa-border 		: 2px dashed #313340;
}
.Calendar[status=readonly],
.CalendarControl[status=readonly]
{
	background 		: #f2f2f2;
}
.Calendar[status=disabled],
.CalendarControl[status=disabled]
{
	-nexa-border 		: 1px solid #efefef;
	background 		: #f9f9f9;
	color 			: #aeaeae;
}
.Calendar .calendaredit,
.Calendar .calendaredit[status=mouseover],.Calendar .calendaredit[status=focused],
.Calendar .calendaredit[status=readonly],.Calendar .calendaredit[status=disabled],
.CalendarControl .calendaredit,
.CalendarControl .calendaredit[status=mouseover],.CalendarControl .calendaredit[status=focused],
.CalendarControl .calendaredit[status=readonly],.CalendarControl .calendaredit[status=disabled]
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px 8px 0px 8px;
	background 		: transparent;
}
.Calendar .calendaredit[userstatus=nulltext],
.CalendarControl .calendaredit[userstatus=nulltext]
{
	color          		: #aeaeae;
}
.Calendar .dropbutton,
.Calendar .dropbutton[status=focused],
.CalendarControl .dropbutton,
.CalendarControl .dropbutton[status=focused]
{
	-nexa-icon 		: URL("theme://images/cal_WF_DropBtn.png");
}
.Calendar .dropbutton[status=mouseover],.Calendar .dropbutton[userstatus=pushed],
.Calendar .dropbutton[userstatus=selected],
.CalendarControl .dropbutton[status=mouseover],.CalendarControl .dropbutton[userstatus=pushed],
.CalendarControl .dropbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/cal_WF_DropBtnO.png");
}
.Calendar .dropbutton[status=disabled],
.CalendarControl .dropbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/cal_WF_DropBtnD.png");
}
.Calendar .calendarspindownbutton,
.Calendar .calendarspindownbutton[status=focused]
{
	-nexa-icon 		: URL("theme://images/spn_WF_DownBtn.png");
}
.Calendar .calendarspindownbutton[status=mouseover],.Calendar .calendarspindownbutton[userstatus=pushed],
.Calendar .calendarspindownbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/spn_WF_DownBtnO.png");
}
.Calendar .calendarspindownbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/spn_WF_DownBtnD.png");
}
.Calendar .calendarspinupbutton,
.Calendar .calendarspinupbutton[status=focused]
{
	-nexa-icon 		: URL("theme://images/spn_WF_UpBtn.png");
}
.Calendar .calendarspinupbutton[status=mouseover],.Calendar .calendarspinupbutton[userstatus=pushed],
.Calendar .calendarspinupbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/spn_WF_UpBtnO.png");
}
.Calendar .calendarspinupbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/spn_WF_UpBtnD.png");
}
/***** DatePickerControl *****/
.DatePickerControl
{
	-nexa-border 		: 1px solid #646982;
	background 		: #ffffff;
}
.DatePickerControl .head
{
	background 		: #ffffff;
	color 			: #333333;
	font 			: bold 14px "Malgun Gothic";
}
.DatePickerControl .head .prevbutton,
.DatePickerControl .head .prevbutton[status=focused]
{
	-nexa-icon 		: URL("theme://images/cal_WF_PreBtn.png");
}
.DatePickerControl .head .prevbutton[status=mouseover],.DatePickerControl .head .prevbutton[userstatus=pushed],
.DatePickerControl .head .prevbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/cal_WF_PreBtnO.png");
}
.DatePickerControl .head .prevbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/cal_WF_PreBtnD.png");
}
.DatePickerControl .head .nextbutton,
.DatePickerControl .head .nextbutton[status=focused]
{
	-nexa-icon 		: URL("theme://images/cal_WF_NxtBtn.png");
}
.DatePickerControl .head .nextbutton[status=mouseover],.DatePickerControl .head .nextbutton[userstatus=pushed],
.DatePickerControl .head .nextbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/cal_WF_NxtBtnO.png");
}
.DatePickerControl .head .nextbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/cal_WF_NxtBtnD.png");
}
.DatePickerControl .head .yearstatic
{
	font 			: bold 14px "Malgun Gothic";
}
.DatePickerControl .body
{
	background 		: #ffffff;
}
.DatePickerControl .body .weekband
{
	background 		: #f7f8fa;
}
.DatePickerControl .body .weekitem
{
	color 			: #666666;
}
.DatePickerControl .body .weekitem[userstatus=saturday]
{
	color 			: #239cf0;
}
.DatePickerControl .body .weekitem[userstatus=sunday]
{
	color 			: #ee5555;
}
.DatePickerControl .body .dayitem
{
	color 			: #333333;
}
.DatePickerControl .body .dayitem[status=mouseover]
{
	background 		: #e4f0fe;
}
.DatePickerControl .body .dayitem[userstatus=selected]
{
	background 		: #38c2d8;
	color 			: #ffffff;
	font 			: bold 13px "Malgun Gothic";
}
.DatePickerControl .body .dayitem[userstatus=day]
{
	color 			: #333333;
}
.DatePickerControl .body .dayitem[userstatus=today]
{
	background 		: #3683e2;
	color 			: #ffffff;
	font 			: bold 13px "Malgun Gothic";
}
.DatePickerControl .body .dayitem[userstatus=saturday]
{
	color 			: #239cf0;
}
.DatePickerControl .body .dayitem[userstatus=sunday]
{
	color 			: #ee5555;
}
.DatePickerControl .body .dayitem[userstatus=trailingday]
{
	color 			: #aaaaaa;
}
/***** CheckBox *****/
.CheckBox,
.CheckBoxControl
{
	-nexa-icon : URL("theme://images/chk_WF_box.png");
	-nexa-text-padding : 0px 16px 0px 6px;
}
.CheckBox[status=mouseover],
.CheckBoxControl[status=mouseover],.CheckBoxControl[status=focused]
{
	-nexa-icon : URL("theme://images/chk_WF_boxO.png");
}
.CheckBox[status=focused]
{
	-nexa-border        : 2px dashed #313340;
}
.CheckBox[status=mouseover][userstatus=selected],.CheckBox[status=focused][userstatus=selected],
.CheckBoxControl[status=mouseover][userstatus=selected],.CheckBoxControl[status=focused][userstatus=selected]
{
	-nexa-icon : URL("theme://images/chk_WF_boxSO.png");
}
.CheckBox[userstatus=selected],
.CheckBoxControl[userstatus=selected]
{  
	-nexa-icon : URL("theme://images/chk_WF_boxS.png");
}
.CheckBox[status=disabled],.CheckBox[status=readonly],
.CheckBoxControl[status=disabled],.CheckBoxControl[status=readonly]
{
	-nexa-icon : URL("theme://images/chk_WF_boxD.png");
}
.CheckBox[status=disabled][userstatus=selected],
.CheckBoxControl[status=disabled][userstatus=selected],
.CheckBox[status=readonly][userstatus=selected],
.CheckBoxControl[status=readonly][userstatus=selected]
{
	-nexa-icon : URL("theme://images/chk_WF_boxDS.png");
}

/***** Combo *****/
.Combo,
.ComboControl
{
	-nexa-border 		: 1px solid #dddddd;
	background 		: #ffffff;
}
.Combo[status=mouseover],
.ComboControl[status=mouseover]
{
	-nexa-border 		: 1px solid #313340;
}
.Combo[status=focused],
.ComboControl[status=focused]
{
	-nexa-border 		: 2px dashed #313340; 
}
.Combo[status=readonly],
.ComboControl[status=readonly]
{
	background 		: #f2f2f2;
}
.Combo[status=disabled],
.ComboControl[status=disabled]
{
	-nexa-border 		: 1px solid #efefef;
	background 		: #f9f9f9;
}
.Combo .comboedit,
.Combo .comboedit[status=focused],.Combo .comboedit[status=mouseover],
.Combo .comboedit[status=readonly],
.ComboControl .comboedit,
.ComboControl .comboedit[status=focused],.ComboControl .comboedit[status=mouseover],
.ComboControl .comboedit[status=readonly]
{
	-nexa-border		: 0px none;
	-nexa-padding 		: 0px 0px 0px 8px;
	background 		: transparent;
}
.Combo .comboedit[status=disabled],.Combo .comboedit[userstatus=nulltext],
.ComboControl .comboedit[status=disabled],.ComboControl .comboedit[userstatus=nulltext]
{
	-nexa-border		: 0px none;
	color 			: #aeaeae;
}
.Combo .dropbutton,
.ComboControl .dropbutton
{
	-nexa-icon 		: URL("theme://images/cbo_WF_Drop.png");
}
.Combo .dropbutton[status=mouseover],.Combo .dropbutton[userstatus=pushed],
.Combo .dropbutton[userstatus=selected],
.ComboControl .dropbutton[status=mouseover],.ComboControl .dropbutton[userstatus=pushed],
.ComboControl .dropbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/cbo_WF_DropO.png");
}
.Combo .dropbutton[status=disabled],
.ComboControl .dropbutton[status=disabled]
{	
	-nexa-icon 		: URL("theme://images/cbo_WF_DropD.png");
}
.Combo .combolist,
.ComboControl .combolist
{
	-nexa-border 		: 1px solid #646982;
	background 		: #ffffff;
}
.Combo .combolist .listboxitem,
.ComboControl .combolist .listboxitem
{
	-nexa-padding 		: 4px 0px 4px 8px;
	color 			: #333333;
}
.Combo .combolist .listboxitem[status=mouseover],
.ComboControl .combolist .listboxitem[status=mouseover]
{
	background 		: #e4f0fe;
}
.Combo .combolist .listboxitem[userstatus=selected],
.ComboControl .combolist .listboxitem[userstatus=selected]
{
	background 		: #8ec2ff;
}

/***** Div *****/
.Div
{
	-nexa-border 		: 0px none;
	background 		: transparent;
}

/***** Edit *****/
.Edit,
.EditControl
{
	-nexa-border 		: 1px solid #dddddd;
	-nexa-padding 		: 0px 0px 0px 8px;
	background 		: #ffffff;
}
.Edit[status=mouseover],
.EditControl[status=mouseover]
{
	-nexa-border 		: 1px solid #313340;
}
.Edit[status=focused],
.EditControl[status=focused]
{
	-nexa-border 		: 2px dashed #313340;
	-nexa-padding 		: 0px 0px 0px 7px;
}
.Edit[status=readonly],
.EditControl[status=readonly]
{
	background 		: #f2f2f2;
}
.Edit[userstatus=nulltext],
.EditControl[userstatus=nulltext]
{
	color          		: #aeaeae;
}
.Edit[status=disabled],
.EditControl[status=disabled]
{
	-nexa-border 		: 1px solid #efefef;
	background 		: #f9f9f9;
	color 			: #aeaeae;
}

/***** FileDownload *****/
.FileDownload
{
	-nexa-border 		: 0px none;
	background 		: #646982;
	color 			: #ffffff;
	font 			: bold 13px "Malgun Gothic";
}
.FileDownload[status=mouseover],.FileDownload[userstatus=pushed],
.FileDownload[status=focused]
{
	background 		: #313340;
}
.FileDownload[status=disabled]
{
	opacity 		: 0.5;
}

/***** FileUpload *****/
.FileUpload,
.FileUpload[status=mouseover],.FileUpload[status=focused],
.FileUpload[userstatus=selected]
{
	-nexa-border 		: 0px none;
}
.FileUpload[status=disabled]
{
	opacity 		: 0.5;
}
.FileUpload .fileuploaditem,
.FileUpload .fileuploaditem[status=focused]
{
	-nexa-border 		: 0px none;
}
.FileUpload .fileuploaditem .fileuploaditemedit,
.FileUpload .fileuploaditem .fileuploaditemedit[status=mouseover],.FileUpload .fileuploaditem .fileuploaditemedit[status=focused],
.FileUpload .fileuploaditem .fileuploaditemedit[status=readonly]
{
	background 		: #ffffff;
}
.FileUpload .fileuploaditem .fileuploaditemedit[userstatus=nulltext]
{
	color          		: #aeaeae;
}
.FileUpload .fileuploaditem .fileuploaditembutton
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px 12px 0px 12px;
	background 		: #646982;
	border-radius 		: 0px;
	color 			: #ffffff;
	font 			: bold 13px "Malgun Gothic";
}
.FileUpload .fileuploaditem .fileuploaditembutton[status=mouseover],.FileUpload .fileuploaditem .fileuploaditembutton[userstatus=pushed],
.FileUpload .fileuploaditem .fileuploaditembutton[userstatus=selected],.FileUpload .fileuploaditem .fileuploaditembutton[status=focused]
{
	background 		: #313340;
}

/***** Grid *****/
.Grid
{
	-nexa-border 		: 1px solid #313340, 1px solid #e1e2e7, 1px solid #e1e2e7, 1px solid #e1e2e7;
	background 		: #ffffff;
}
.Grid .head
{
	background 		: #f7f8fa;
}
.Grid .head .row .cell
{
	-nexa-border 		: 1px solid #e1e2e7;
	-nexa-text-align 	: center;
	color 			: #666666;
	font 			: bold 13px "Malgun Gothic";
}
.Grid .head .row .cell[status=focused]
{
	-nexa-text-decoration 	: underline;
}
.Grid .body .row .cell
{
	-nexa-border 		: 1px solid #eeeeee;
	-nexa-padding 		: 4px 4px 4px 4px;
}
.Grid .body .row .cell[status=mouseover].Grid .body .row .cell[status=focused]
{
	background 		: #fffdf1;
}
.Grid .body .row .cell[userstatus=selected]
{
	background 		: #fff7e5;
}
.Grid .body .row .cell .cellselection
{
	-nexa-border : 2px dashed #000000;
}
.Grid .summary
{
	background 		: #b2b9c6;
}
.Grid .summary .row .cell
{
	-nexa-border 		: 1px solid #c8cdd7;
	-nexa-padding 		: 4px 10px 4px 10px;
	color 			: #ffffff;
	font 			: bold 14px "Malgun Gothic";
}
/*cellcontrol Start*/
.GridCellControl .cellbutton
{
	-nexa-border 		: 1px solid #dddddd;
	background 		: linear-gradient(to bottom,#ffffff,#f6f7f8);
	border-radius 		: 1px;
	color 			: #646982;
	cursor 			: pointer;
	font 			: bold 13px "Malgun Gothic";
}
.GridCellControl .cellbutton[status=mouseover],.GridCellControl .cellbutton[userstatus=pushed],
.GridCellControl .cellbutton[userstatus=selected]
{
	-nexa-border 		: 1px solid #313340;
}
.GridCellControl .cellbutton[status=disabled]
{
	-nexa-border 		: 1px solid #eeeeee;
	color 			: #aaaaaa;
}
.GridCellControl .cellbutton[status=focused]
{
	-nexa-text-decoration 	: underline;
	-nexa-border 		: 1px solid #dddddd;
	background 		: linear-gradient(to bottom,#ffffff,#f6f7f8);
	border-radius 		: 1px;
	color 			: #646982;
	cursor 			: pointer;
	font 			: bold 13px "Malgun Gothic";
}
.GridCellControl .cellexpandbutton,
.GridCellControl .cellexpandbutton[status=focused],.GridCellControl .cellexpandbutton[status=mouseover],
.GridCellControl .cellexpandbutton[userstatus=pushed],.GridCellControl .cellexpandbutton[userstatus=selected],
.GridCellControl .cellexpandbutton[status=disabled]
{
	background 		: URL("theme://images/btn_WF_Search.png") no-repeat center transparent;
}
.GridCellControl .celltreeitem .treeitembutton[userstatus=expand]
{
	-nexa-icon 		: URL("theme://images/grd_WF_TreeClose.png");
}
.GridCellControl .celltreeitem .treeitembutton[userstatus=collapse]
{
	-nexa-icon 		: URL("theme://images/grd_WF_TreeOpen.png");
}
.GridCellControl .celltreeitem .treeitemimage[userstatus=expand]
{
	-nexa-icon 		: URL("theme://images/grd_WF_TreeCloseImg.png");
}
.GridCellControl .celltreeitem .treeitemimage[userstatus=collapse]
{
	-nexa-icon 		: URL("theme://images/grd_WF_TreeOpenImg.png");
}
.GridCellControl .celltreeitem .treeitemimage[userstatus=leaf]
{
	-nexa-icon 		: URL("theme://images/grd_WF_TreeLeafImg.png");
}
.GridCellControl .celltreeline
{
	-nexa-border 		: 1px dotted #999999;
}
.GridCellControl .celltreeline[status=disabled]
{
	-nexa-border 		: 1px dotted #aeaeae;
}
.GridCellControl .celledit[status=focused],
