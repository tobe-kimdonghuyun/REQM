	background : #d5d8e1;
}
.Static.sta_WF_GuideVer,.Static.sta_WF_GuideVer[status=mouseover],.Static.sta_WF_GuideVer[status=disabled]
{
	-nexa-edge : url("theme://images/bg_WF_GuideVer.png") 3px 3px;
}
.Static.sta_WF_GuideHor,.Static.sta_WF_GuideHor[status=mouseover],.Static.sta_WF_GuideHor[status=disabled]
{
	-nexa-edge : url("theme://images/bg_WF_GuideHor.png") 3px 3px;
}
.Static.sta_WF_GuideRed,.Static.sta_WF_GuideRed[status=mouseover],.Static.sta_WF_GuideRed[status=disabled]
{
	-nexa-text-align : center;
	-nexa-vertical-align : middle;
	background : #eb5252;
	color : #ffffff;
	font : 12px "Dotum";
	opacity : 0.80;
}
.Static.sta_WF_GuideBlue,.Static.sta_WF_GuideBlue[status=mouseover],.Static.sta_WF_GuideBlue[status=disabled]
{
	-nexa-text-align : center;
	-nexa-vertical-align : middle;
	background : #5198d4;
	color : #ffffff;
	font : 12px "Dotum";
	opacity : 0.80;
}
.Static.sta_WF_Text01,.Static.sta_WF_Text01[status=mouseover],.Static.sta_WF_Text01[status=disabled]
{
	-nexa-word-wrap : char;
	color : #999999;
	font : 12px "Dotum";
}
.Static.sta_WF_Text02,.Static.sta_WF_Text02[status=mouseover],.Static.sta_WF_Text02[status=disabled]
{
	-nexa-word-wrap : char;
	color : #333333;
	font : 12px "Dotum";
}
.Static.sta_WF_TextRed,.Static.sta_WF_TextRed[status=mouseover],.Static.sta_WF_TextRed[status=disabled]
{
	color : #eb5252;
	font : 12px "Dotum";
}
.Static.sta_WF_TextBlue,.Static.sta_WF_TextBlue[status=mouseover],.Static.sta_WF_TextBlue[status=disabled]
{
	color : #5198d4;
	font : 12px "Dotum";
}

/******************************** Guide ********************************/
.Static.sta_WF_GSize
{
	-nexa-text-align : center;
	background : #ff0000;
	color : #000000;
	opacity : 0.3;
}
.Static.sta_WF_GBar
{
	-nexa-padding : 0px 0px 0px 55px;
	background : #f4f5f9;
	color : #23273c;
	font : bold 35px "Tahoma";
}
.Static.sta_WF_GTxt01
{
	font : bold 20px "Tahoma";
}
.Static.sta_WF_GTxt02
{
	-nexa-text-decoration : underline;
	font : bold 12px "Dotum";
}
.Static.sta_WF_GTxt02B
{
	-nexa-text-decoration : underline;
	color : #333333;
	font : bold 12px "Tahoma";
}
.Static.sta_WF_GTxt03
{
	color : #636981;
	font : 11px "Tahoma";
}
.Static.sta_WF_GTxt04
{
	color : #ff000c;
	font : 11px "Tahoma";
}
.Static.sta_WF_GTxt05
{
	color : #919399;
	font : bold 12px/20px "Verdana";
}
.Static.sta_WF_GTxt06
{
	color : #ee5555;
	font : 12px/20px "Dotum";
}
.Static.sta_WF_GLineV
{
	-nexa-edge : URL('theme://images/sta_WF_GLineV.png') 5px 2px;
}
.Static.sta_WF_GLineH
{
	-nexa-edge : URL('theme://images/sta_WF_GLineH.png') 5px 2px;
}
.Static.sta_WF_GNum
{
	-nexa-text-align : right;
	color : #3683e2;
	font : bold 30px "Tahoma";
}
.Static.sta_WF_Box
{
	background : #FFFFFF;
	border-radius : 5px;
	box-shadow : 3px 3px 10px 0px #e7e8f1;
}
.Static.sta_WF_GBg01
{
	background : #f4f5f9;
}
.Static.sta_WF_GBg02
{
	-nexa-border : 1px solid #333333;
	-nexa-padding : 8px;
	-nexa-vertical-align : top;
	background : #fff9ca;
}]]></XCSS>
