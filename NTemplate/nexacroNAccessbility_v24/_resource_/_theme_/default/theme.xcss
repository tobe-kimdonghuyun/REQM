/********************************************Component********************************************/
/**********Button**********/
.Button
{
	-nexa-border : 1px solid #ababab;
	-nexa-edge : ;
	-nexa-icon : ;
	-nexa-icon-position : ;
	-nexa-padding : ;
	-nexa-text-align : ;
	-nexa-text-decoration : ;
	-nexa-text-padding : ;
	-nexa-vertical-align : ;
	-nexa-word-wrap : ;
	background : #ffffff;
	border-radius : ;
	box-shadow : ;
	color : #222222;
	cursor : pointer;
	font : 14px "Gulim";
	letter-spacing : ;
	opacity : ;
	word-spacing : ;
}
.Button[status=focused]
{
	-nexa-border : 1px solid #005378;
	background : linear-gradient(to bottom, #ffffff, #b7b8b8);
	color : #000000;
}
.Button[status=mouseover]
{
	-nexa-border : 1px solid #2b86af;
	background : linear-gradient(to bottom, #fefefe, #e3e4e5);
}
.Button[userstatus=pushed],.Button[userstatus=selected]
{
	-nexa-border : 1px solid #2b86af;
	-nexa-padding : 1px 0px 0px 1px;
	background : linear-gradient(to bottom, #e3e4e5, #fefefe);
}
.Button[status=disabled]
{
	-nexa-border : 1px solid #d4d4d4;
	background : #f8f8f8;
	color : #666666;
}
/****Class****/
/*Top프레임*/
.Button.btn_TF_Logo,.Button.btn_TF_Logo[status=disabled]
{
	-nexa-border : 1px solid #2157c0;
	background : url("theme://images/img_TF_Logo_TOBE.png") no-repeat center center #3c72dc;
}
