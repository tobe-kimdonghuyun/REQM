<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sample11" width="973" height="763" titletext="헤딩" onload="form_onload">
    <Layouts>
      <Layout height="763" width="973">
        <Div id="div_0" taborder="0" text="Div00" left="36" top="8" width="910" height="129" background="azure" accessibilityenable="false">
          <Layouts>
            <Layout>
              <Static id="Static00" taborder="0" text="진입 시&#13;&#10; 안읽음" left="21" top="22" width="137" height="52"/>
              <Div id="divTopBtn" taborder="1" text="여기도 안 읽음" left="88" top="14" width="721" height="87" border="1px solid red" accessibilityenable="false"/>
              <Button id="Button00" taborder="2" text="Button00" left="838" top="17" width="55" height="48" onclick="div_0_Button00_onclick"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btn_1" taborder="1" text="첫번째" left="5" top="286" width="105" height="34" onclick="Button_onclick"/>
        <Button id="btn_2" taborder="2" text="두번째" left="5" top="324" width="105" height="34" onclick="Button_onclick"/>
        <Button id="btn_3" taborder="3" text="세번째" left="5" top="362" width="105" height="34" onclick="Button_onclick"/>
        <Div id="Div00" taborder="4" text="본문영역 안읽음" left="50" top="164" width="923" height="536" border="1px solid black" accessibilityenable="false">
          <Layouts>
            <Layout>
              <Div id="div_1" taborder="0" text="Div01" left="12" top="12" width="931" height="498" background="pink" accessibilitydescription="첫번째">
                <Layouts>
                  <Layout>
                    <Static id="Static00" taborder="0" text="111" left="41" top="22" width="157" height="52"/>
                    <Button id="Button00" taborder="1" text="Button00" left="221" top="12" width="145" height="68"/>
                  </Layout>
                </Layouts>
              </Div>
              <Div id="div_2" taborder="1" text="Div02" left="13" top="517" width="933" height="463" background="antiquewhite" accessibilitydescription="두번째">
                <Layouts>
                  <Layout>
                    <Static id="Static00" taborder="0" text="222" left="41" top="22" width="157" height="52"/>
                    <Button id="Button00" taborder="1" text="Button00" left="221" top="12" width="145" height="68"/>
                  </Layout>
                </Layouts>
              </Div>
              <Div id="div_3" taborder="2" text="Div02" left="13" top="986" width="933" height="463" background="chocolate" accessibilitydescription="세번째">
                <Layouts>
                  <Layout>
                    <Static id="Static00" taborder="0" text="333" left="41" top="22" width="157" height="52"/>
                    <Button id="Button00" taborder="1" text="Button00" left="221" top="12" width="145" height="68"/>
                  </Layout>
                </Layouts>
              </Div>
              <Div id="div_4" taborder="3" text="Div00" left="18" top="1459" width="910" height="129" background="azure" accessibilitydescription="네번째">
                <Layouts>
                  <Layout>
                    <Static id="Static00" taborder="0" text="444" left="41" top="22" width="157" height="52"/>
                    <Button id="Button00" taborder="1" text="Button00" left="221" top="12" width="145" height="68"/>
