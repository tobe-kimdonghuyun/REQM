      <Layout height="763" mobileorientation="landscape" width="973">
        <Static id="Static09" taborder="0" text="신청자 정보 입력" left="0" top="1" height="63" cssclass="sta_WF_SubTitle01" width="973" accessibilityenable="true"/>
        <Button id="btnCombo" taborder="1" text="열기" left="236" top="20" width="106" height="45" accessibilitylabel="열림" onclick="btnCombo_onclick" onmouseenter="btnCombo_onmouseenter" onmouseleave="btnCombo_onmouseleave" background="pink"/>
        <Grid id="grdCombo" taborder="2" left="346" top="20" binddataset="Dataset00" autofittype="col" visible="false" onsetfocus="grdCombo_onsetfocus" onkillfocus="grdCombo_onkillfocus" accessibilityenable="false" width="104" height="92">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="30"/>
              </Rows>
              <Band id="body">
                <Cell text="bind:Column1"/>
