        <Button id="Button00" taborder="5" text="조회" left="831" top="89" width="106" height="42" onclick="Button00_onclick"/>
        <Grid id="Grid00" taborder="6" left="12" top="149" width="948" height="330" binddataset="ds_employees" selecttype="cell">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="24" band="head"/>
                <Row size="24"/>
              </Rows>
              <Band id="head">
                <Cell text="EMPL_ID"/>
                <Cell col="1" text="FULL_NAME"/>
                <Cell col="2" text="DEPT_ID"/>
                <Cell col="3" text="GENDER"/>
                <Cell col="4" text="HIRE_DATE"/>
                <Cell col="5" text="MARRIED"/>
                <Cell col="6" text="SALARY"/>
                <Cell col="7" text="EMPL_MEMO"/>
                <Cell col="8" text="RANK"/>
                <Cell col="9" text="EMAIL"/>
              </Band>
              <Band id="body">
                <Cell text="bind:EMPL_ID" accessibilitylabel="expr:comp.parent.fnAccessibility(currow)"/>
                <Cell col="1" text="bind:FULL_NAME"/>
                <Cell col="2" text="bind:DEPT_ID"/>
                <Cell col="3" text="bind:GENDER"/>
                <Cell col="4" text="bind:HIRE_DATE"/>
                <Cell col="5" text="bind:MARRIED"/>
                <Cell col="6" text="bind:SALARY"/>
                <Cell col="7" text="bind:EMPL_MEMO"/>
                <Cell col="8" text="bind:RANK"/>
                <Cell col="9" text="bind:EMAIL"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="Button01" taborder="7" text="test1" left="468" top="84" width="84" height="44" onclick="Button01_onclick"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
this.Sample13_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
//	this.fnSerch();	

	
	
	
	
};

this.fnCallback = function()
{
	trace(this.ds_employees.saveXML());

}

this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSerch();
};


this.fnSerch = function()
{
	this.transaction("test"
				   , "http://localhost:8080/npN/jsp/select_noDb.jsp"
				   , ""
				   , "ds_employees=ds_employees"
				   , ""
				   , "fnCallback");
}

this.fnAccessibility = function(nRow)
{
	return (nRow % 2) ? "링크" : "팝업";
}

this.Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var aa = this.getFirstAccessibilityComponent(true);
	trace(aa.name);
	aa.setFocus();
};

this.btnCombo_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
	var elem = this.grdCombo.getElement();
	if (obj.text == "열기")
	{
		obj.set_text("닫기");
		obj.set_accessibilitylabel("닫음");
		this.grdCombo.set_visible(true);

		if(elem)
		{
			elem.setElementZIndex(1);
		}	

	}
	else
	{
		obj.set_text("열기");
		obj.set_accessibilitylabel("열림");
		this.grdCombo.set_visible(false);
// 		if(elem)
// 		{
// 			elem.setElementZIndex("");
// 		}			
	}	
};

this.btnCombo_onmouseenter = function(obj:nexacro.Button,e:nexacro.MouseEventInfo)
{
	this.grdCombo.set_visible(true);
};

this.btnCombo_onmouseleave = function(obj:nexacro.Button,e:nexacro.MouseEventInfo)
{
	this.grdCombo.set_visible(false);
};

this.grdCombo_onsetfocus = function(obj:nexacro.Grid,e:nexacro.SetFocusEventInfo)
{
	trace("grdCombo_onsetfocus");
};

this.grdCombo_onkillfocus = function(obj:nexacro.Grid,e:nexacro.KillFocusEventInfo)
{
	this.btnCombo.set_text("열기");
	this.btnCombo.set_accessibilitylabel("열림");
		
	trace("grdCombo_onkillfocus");
	obj.set_visible(false);

};
]]></Script>
