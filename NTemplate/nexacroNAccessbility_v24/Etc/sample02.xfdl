<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sample02" width="1045" height="760" titletext="웹브라우져" onload="sample02_onload">
    <Layouts>
      <Layout height="760" mobileorientation="landscape" width="1045">
        <WebBrowser id="WebBrowser00" taborder="1" left="10" top="105" height="275" onloadcompleted="WebBrowser00_onloadcompleted" accessibilityrole="webbrowser" right="50" accessibilityaction="웹브라우저 진입 시 필요한 액션" accessibilityleavemessage="웹브라우저 나갈때 필요한 액션"/>
        <Button id="Button00" taborder="2" text="넥사크로 영역" left="280" top="393" width="254" height="57"/>
        <ImageViewer id="ImageViewer00" taborder="0" text="화면3 웹브라우져" left="4" top="1" width="307" height="46" cssclass="img_WF_Acc" font="normal bold 20px/normal &quot;Gulim&quot;" accessibilityrole="none"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
this.sample02_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.WebBrowser00.set_url("http://localhost:8080/npN/accessbility/html/web.html");
};

this.WebBrowser00_onloadcompleted = function(obj:nexacro.WebBrowser,e:nexacro.WebLoadCompEventInfo)
{
	// 웹브라우져 콤퍼넌트가 있는 화면이 로드될때는 자동으로 가상커서가 해제됨
	// 웹 컨텐츠가 로드가 완료된 시점에 가상커서 해제 안내를 위해
	// 포커스 이동시킴
//	nexacroBase.fn_setFirstFocus();
};
]]></Script>
  </Form>
</FDL>
