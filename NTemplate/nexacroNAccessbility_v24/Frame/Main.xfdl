    <Script type="xscript5.1"><![CDATA[this.fvFirstGap 		= 0;
this.fvBtnGap 			= 10;
this.fvBtnHeight 		= 50;
this.fvTopBtnPrefix 	= "TOP_";

this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{


};



this.Button_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sID = obj.name.split("_")[1];
	
	switch(sID) 
	{
		case "1" :
			this.Div00.form.vscrollbar.set_pos(0);
			break;
		case "2" :
			this.Div00.form.vscrollbar.set_pos(500);
			break;
		case "3" :
			this.Div00.form.vscrollbar.set_pos(1000);
			break;
	}
	
};
]]></Script>
