  <Form id="Base" width="1280" height="720" titletext="기본메인창" onload="Base_onload" onkeydown="Base_onkeydown">
    <Layouts>
      <Layout width="1280" height="720" screenid="Desktop_screen">
        <Div id="divTop" taborder="0" left="10" top="10" height="80" border="1px solid" right="35" accessibilityrole="heading" accessibilitylabel="상단 메인메뉴" url="Frame::Top1.xfdl" text=""/>
