    <Script type="xscript5.1"><![CDATA[/**
*  Nexacro Accessibility
*  @FileName 	Main.xfdl 
*  @Creator 	TOBESOFT
*  @CreateDate 	2022.12.15
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.12.15     		TOBESOFT		 		최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.objApp = this.gfnGetApplication();
this.fvnRollingTime    = 2000;		//배너 롤링 time
this.fvnRollingTimerId = 10;		//배너 롤링 timer ID
this.fvnRollingIndex   = 0;			//배너 롤링 index
this.fvbRollingState   = true;      //배너 롤링 자동여부

this.fvbRollingFlag   = false;     //키보드 방향키로 롤링 확인
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.gfnFormOnLoad(obj);
	
	if (this.objApp.gvOs.indexOf("WINDOWS") > -1)
	{	
		this.setEventHandler("onsize", this.form_onsize, this);
		this.fnCenterMove();
	}
	
	//this.divNews.form.divMove.form.divBanner.form.divStep.form.stepselector.set_visible(false);
	

	//배너 롤링
	this.setTimer(this.fvnRollingTimerId, this.fvnRollingTime);		
	
	this.dsNews.copyData(this.dsNewsAll, true);
	this.dsNews.filter("currow < 5");	
	this.dsNews.rowposition = -1;
};

this.form_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnCenterMove();
};

this.form_ontimer = function(obj:nexacro.Form,e:nexacro.TimerEventInfo)
{
	if (e.timerid == this.fvnRollingTimerId)
	{
		this.killTimer(e.timerid);

		if ( this.fvnRollingIndex < 3 ) {
			this.fvnRollingIndex++;
		} else {
			this.fvnRollingIndex = 0;
		}

		this.fnChangeAction();	
	
		this.setTimer(this.fvnRollingTimerId, this.fvnRollingTime);
	}
};
/*******************************************************************************************************************************
 * Transaction 서비스호출 처리 영역
*******************************************************************************************************************************/

/*******************************************************************************************************************************
 * Callback 영역 (Transaction, popup, message..)
*******************************************************************************************************************************/

/*******************************************************************************************************************************
 * 사용자 Function 영역
*******************************************************************************************************************************/
this.fnChangeAction = function()
{	
	var objDiv = this.divNews.form.divMove.form.divBanner.form;

	objDiv.divStep.form.stepselector.stepindex = this.fvnRollingIndex;
	objDiv.staBanner.text = "<b v='true'><fc v='#303030'><fs v='14'>" + (this.fvnRollingIndex+1) + "</fs></fc></b>" + "<fc v='#777777'><fs v='12'> / 4</fs></fc>";	
}

//divStep 에서 호출. 스텝이 변경될때 발생하는 이벤트 처리를 위함
this.fnStepChange = function(nIndex)
{
	this.fvnRollingIndex = nIndex;	
}

this.fnCenterMove = function()
{
	var nLeft = nexacro.round((this.getOffsetWidth() - this.divN.form.divMove.width ) /2);
	this.divN.form.divMove.move(nLeft, 270);
	this.divNews.form.divMove.move(nLeft, 210);
}

/*******************************************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
*******************************************************************************************************************************/
// play/pause 버튼 클릭
this.divNews_divBanner_btnPalyPause_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (obj.cssclass == "btn_MF_Play")
	{	
		obj.cssclass = "btn_MF_Pause";
		obj.accessibilitylabel = "슬라이드 멈춤";
		this.killTimer(this.fvnRollingTimerId);
		this.setTimer(this.fvnRollingTimerId, this.fvnRollingTime);
		this.fvbRollingState = true;
	}
	else if (obj.cssclass == "btn_MF_Pause")
	{
		obj.cssclass = "btn_MF_Play";
		obj.accessibilitylabel = "슬라이드 시작";
		this.killTimer(this.fvnRollingTimerId);
		this.fvbRollingState = false;
	}	
};

this.divNews_divBanner_btnPrevNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.killTimer(this.fvnRollingTimerId);
	
	 
	if (obj.name == "btnPrev") 
	{
		if (this.fvnRollingIndex == 0)
		{
			this.fvnRollingIndex = 3;
		}
		else
		{
			this.fvnRollingIndex--;		
		}
	} 
	else if (obj.name == "btnNext" ) 
	{
		if (this.fvnRollingIndex == 3)
		{
			this.fvnRollingIndex = 0;
		}	
		else
		{
			this.fvnRollingIndex++;	
		}
	}	 
	 
	this.fnChangeAction();
    
	if (this.fvbRollingState) 
	{
        this.setTimer(this.fvnRollingTimerId, this.fvnRollingTime);
	} 
};

//[접근성 대응] 방향키로 배너 전환 시 onstepchanged 이벤트 타지 않음. getStepIndex() 처음 값만 가져옴.
this.divNews_divMove_divBanner_divStep_onkeydown = function(obj:nexacro.Div,e:nexacro.KeyEventInfo)
{
	if (this.fvbRollingFlag) 
	{
		if (e.keycode == 38) 
		{
			if (this.fvnRollingIndex == 3)
			{
				this.fvnRollingIndex = 0;
			}	
			else
			{
				this.fvnRollingIndex++;	
			}						
		}
		else if (e.keycode == 40) 
		{
			if (this.fvnRollingIndex == 0)
			{
				this.fvnRollingIndex = 3;
			}
			else
			{
				this.fvnRollingIndex--;		
			}
		}
		this.divNews.form.divMove.form.divBanner.form.staBanner.text = "<b v='true'><fc v='#303030'><fs v='14'>" + (this.fvnRollingIndex+1) + "</fs></fc></b>" + "<fc v='#777777'><fs v='12'> / 4</fs></fc>";				
	} else {
		this.fvbRollingFlag = true;
	}
};

this.Button_onsetfocus_rolling = function(obj:nexacro.Button,e:nexacro.SetFocusEventInfo)
{
	this.fvbRollingFlag = false;
};
	



//Div에 포커스 시 타이머 중지
this.divNews_divMove_divBanner_divStep_onsetfocus = function(obj:nexacro.Div,e:nexacro.SetFocusEventInfo)
{
	this.divNews.form.divMove.form.divBanner.form.btnPause.cssclass = "btn_MF_Play";
	this.divNews.form.divMove.form.divBanner.form.btnPause.accessibilitylabel = "시작";
	
	this.killTimer(this.fvnRollingTimerId);
	this.fvbRollingState = false;	
};
this.divNews_divMove_divBanner_divStep_onkillfocus = function(obj:nexacro.Div,e:nexacro.KillFocusEventInfo)
{
	this.divNews.form.divMove.form.divBanner.form.btnPause.cssclass = "btn_MF_Pause";
	this.divNews.form.divMove.form.divBanner.form.btnPause.accessibilitylabel = "멈춤";
	
	this.setTimer(this.fvnRollingTimerId, this.fvnRollingTime);
	this.fvbRollingState = true;	
};


this.btnNews_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objDiv = this.divNews.form.divMove.form.divNewsList.form;
	objDiv.btnAll.accessibilitylabel = "링크"; 
	objDiv.btnNoti.accessibilitylabel = "링크";
	objDiv.btnPr.accessibilitylabel = "링크";
	objDiv.btnAll.cssclass = "btn_MF_grdTitle";
	objDiv.btnNoti.cssclass = "btn_MF_grdTitle";
	objDiv.btnPr.cssclass = "btn_MF_grdTitle";

	var sBtn = obj.name.substr(3);
	obj.accessibilitylabel = "선택됨";
	obj.cssclass = "btn_MF_grdTitleS";
	objDiv.Button03.accessibilitylabel = "링크 " + obj.text + " 더보기";
	
	switch (sBtn) 
	{
		case "All" :
			this.dsNewsAll.filter("");
			break;
		case "Noti" :
			this.dsNewsAll.filter("Column0 == 'cell_Noti'");
			break;
		case "Pr" :
			this.dsNewsAll.filter("Column0 == 'cell_PR'");
			break;
	}
	this.dsNews.copyData(this.dsNewsAll, true);
	this.dsNews.filter("currow < 5");
};


this.divNews_divMove_divNewsList_grdNews_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
   if (e.col == 1) {
		alert("제목 클릭-> 상세조회 이동");
   }
};


]]></Script>
  </Form>
</FDL>
