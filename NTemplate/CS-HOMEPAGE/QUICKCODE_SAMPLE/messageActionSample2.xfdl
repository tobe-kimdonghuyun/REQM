<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="messageActionSample2" width="1280" height="720" titletext="New Form">
    <Layouts>
      <Layout height="720" width="1280">
        <Button id="Button00" taborder="0" text="Button00" left="10" top="15" width="120" height="50"/>
        <Button id="Button01" taborder="1" text="Button01" left="10" top="75" width="120" height="50" onclick="Button01_onclick"/>
      </Layout>
    </Layouts>
    <Objects>
      <MessageAction id="MessageAction00" messagetype="alert" messagecode="MSG_000011" messageparam="10">
        <Contents/>
      </MessageAction>
      <MessageAction id="MessageAction01" messagetype="alert" messagecode="MSG_000011" messageparam="1">
        <Contents/>
      </MessageAction>
    </Objects>
    <Trigger>
      <TriggerItem id="item0" triggertype="Click" triggerview="messageActionSample2" triggerobj="Button00" targetaction="MessageAction00" condition=""/>
    </Trigger>
    <Script type="xscript5.1"><![CDATA[
this.Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.MessageAction01.set_messagetype("confirm");
	this.MessageAction01.set_messagecode("MSG_000012");
	var bRtn = this.MessageAction01.run();
	trace(bRtn);
};
]]></Script>
  </Form>
</FDL>
