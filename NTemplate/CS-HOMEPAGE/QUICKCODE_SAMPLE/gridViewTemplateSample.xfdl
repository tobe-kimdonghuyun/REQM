<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="gridViewTemplateSample" width="1280" height="720" titletext="New Form">
    <Layouts>
      <Layout height="720" width="1280">
        <View id="View00" taborder="0" text="View00" viewdataset="viewdataset" left="20" top="20" width="800" height="300">
          <Layouts>
            <Layout>
              <Grid id="grdList" left="0" top="0" right="0" bottom="0" binddataset="viewdataset" autoenter="select" autofittype="col">
                <Formats>
                  <Format id="default">
                    <Columns>
                      <Column size="80" band="body"/>
                      <Column size="80" band="body"/>
                      <Column size="80" band="body"/>
                      <Column size="80" band="body"/>
                      <Column size="80" band="body"/>
                      <Column size="80" band="body"/>
                      <Column size="80" band="body"/>
                      <Column size="80" band="body"/>
                    </Columns>
                    <Rows>
                      <Row size="55" band="head"/>
                      <Row size="40" band="body"/>
                    </Rows>
                    <Band id="head">
                      <Cell id="cell_field0" col="0" row="0" text=" "/>
                      <Cell id="cell_field1" col="1" row="0" text="교육회차"/>
                      <Cell id="cell_field2" col="2" row="0" text="교육과정"/>
                      <Cell id="cell_field3" col="3" row="0" text="교육시작일"/>
                      <Cell id="cell_field4" col="4" row="0" text="교육종료일"/>
                      <Cell id="cell_field5" col="5" row="0" text="지역"/>
                      <Cell id="cell_field6" col="6" row="0" text="교육구분"/>
                      <Cell id="cell_field7" col="7" row="0" text="정보수정"/>
                    </Band>
                    <Band id="body">
                      <Cell id="cell_field0" col="0" row="0" text="bind:field0" displaytype="normal" edittype="none"/>
                      <Cell id="cell_field1" col="1" row="0" text="bind:field1" displaytype="normal" edittype="none"/>
                      <Cell id="cell_field2" col="2" row="0" text="bind:field2" displaytype="normal" edittype="none"/>
                      <Cell id="cell_field3" col="3" row="0" text="bind:field3" displaytype="normal" edittype="none"/>
                      <Cell id="cell_field4" col="4" row="0" text="bind:field4" displaytype="normal" edittype="none"/>
                      <Cell id="cell_field5" col="5" row="0" text="bind:field5" displaytype="normal" edittype="none"/>
                      <Cell id="cell_field6" col="6" row="0" text="bind:field6" displaytype="normal" edittype="none"/>
                      <Cell id="cell_field7" col="7" row="0" text="bind:field7" displaytype="buttoncontrol" edittype="button"/>
                    </Band>
                    <Band id="summary"/>
                  </Format>
                </Formats>
              </Grid>
            </Layout>
          </Layouts>
          <Objects>
            <Dataset id="viewdataset">
              <ColumnInfo>
                <Column id="field0" type="STRING" size="80"/>
                <Column id="field1" type="STRING" size="80"/>
                <Column id="field2" type="STRING" size="80"/>
                <Column id="field3" type="STRING" size="80"/>
                <Column id="field4" type="STRING" size="80"/>
                <Column id="field5" type="STRING" size="80"/>
                <Column id="field6" type="STRING" size="80"/>
                <Column id="field7" type="STRING" size="80"/>
              </ColumnInfo>
              <Rows>
                <Row/>
              </Rows>
            </Dataset>
          </Objects>
          <ModelInfo modelserviceid="MODEL" serviceid="" modelid="grid001" filepath="SAMPLE.xmodel">
            <Fields>
              <Field id="field0" description="" displaytype="normal" edittype="none" fieldwidth="80" cssclass="" summprop="none"/>
              <Field id="field1" description="" displaytype="normal" edittype="none" fieldwidth="80" cssclass="" summprop="none"/>
              <Field id="field2" description="" displaytype="normal" edittype="none" fieldwidth="80" cssclass="" summprop="none"/>
              <Field id="field3" description="" displaytype="normal" edittype="none" fieldwidth="80" cssclass="" summprop="none"/>
              <Field id="field4" description="" displaytype="normal" edittype="none" fieldwidth="80" cssclass="" summprop="none"/>
              <Field id="field5" description="" displaytype="normal" edittype="none" fieldwidth="80" cssclass="" summprop="none"/>
              <Field id="field6" description="" displaytype="normal" edittype="none" fieldwidth="80" cssclass="" summprop="none"/>
              <Field id="field7" description="" displaytype="buttoncontrol" edittype="button" fieldwidth="80" cssclass="" summprop="none"/>
            </Fields>
            <Components>
              <Component id="grdList" fields="field0,field1,field2,field3,field4,field5,field6,field7"/>
            </Components>
          </ModelInfo>
          <ViewTemplateInfo filepath="NormalGridViewTemplate.xviewgen">
            <Attribute id="headbandsize" value="55"/>
            <Attribute id="bodybandsize" value="40"/>
            <Attribute id="summbandsize" value="-1"/>
          </ViewTemplateInfo>
        </View>
        <View id="View01" taborder="1" text="View00" viewdataset="viewdataset" left="20" top="330" width="800" height="370">
          <Layouts>
            <Layout>
              <Grid id="grdList" left="0" top="0" right="0" bottom="0" binddataset="viewdataset" autoenter="select" autofittype="col" cssclass="grd_WF_list">
                <Formats>
                  <Format id="default">
                    <Columns>
                      <Column size="845" band="body"/>
                      <Column size="100" band="body"/>
                    </Columns>
                    <Rows>
                      <Row size="80" band="body"/>
                      <Row size="5" band="body"/>
                    </Rows>
                    <Band id="head"/>
                    <Band id="body">
                      <Cell id="cell_Title" col="0" row="0" text="bind:Title" displaytype="normal" edittype="none" cssclass="grd_WF_serverTitle"/>
                      <Cell id="cell_Date" col="1" row="0" text="bind:Date" displaytype="normal" edittype="none" cssclass="grd_WF_num"/>
                      <Cell id="cell_line" row="1" colspan="2" cssclass="grd_WF_line"/>
                    </Band>
                    <Band id="summary"/>
                  </Format>
                </Formats>
              </Grid>
            </Layout>
          </Layouts>
          <Objects>
            <Dataset id="viewdataset">
              <ColumnInfo>
                <Column id="Title" type="STRING" size="80"/>
                <Column id="Date" type="STRING" size="80"/>
              </ColumnInfo>
              <Rows>
                <Row/>
              </Rows>
            </Dataset>
          </Objects>
          <ModelInfo modelserviceid="MODEL" serviceid="" modelid="grid002" filepath="SAMPLE.xmodel">
            <Fields>
              <Field id="Title" description="" displaytype="normal" edittype="none" fieldwidth="845" cssclass="grd_WF_serverTitle" summprop="none"/>
              <Field id="Date" description="" displaytype="normal" edittype="none" fieldwidth="100" cssclass="grd_WF_num" summprop="none"/>
            </Fields>
            <Components>
              <Component id="grdList" fields="Title,Date"/>
            </Components>
          </ModelInfo>
          <ViewTemplateInfo filepath="ListGridViewTemplate.xviewgen">
            <Attribute id="headbandsize" value="-1"/>
            <Attribute id="bodybandsize" value="80"/>
            <Attribute id="summbandsize" value="-1"/>
          </ViewTemplateInfo>
        </View>
      </Layout>
    </Layouts>
  </Form>
</FDL>
