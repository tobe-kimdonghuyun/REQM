<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="freeformViewTemplateSample2" width="1280" height="720" titletext="New Form">
    <Layouts>
      <Layout height="720" width="1280">
        <View id="View00" taborder="0" text="View00" viewdataset="viewdataset" left="10" top="10" width="880" height="239">
          <Layouts>
            <Layout>
              <Static id="staProduct_Label" left="0" top="0" width="200" height="30" text="제품명" cssclass="sta_WF_writeTitle" usedecorate="true"/>
              <Combo id="cmbProduct" left="0" top="39" width="400" height="50" itemheight="40"/>
              <Static id="staEmail_Label" left="440" top="0" width="200" height="30" text="이메일 &lt;fc v='#fb6d3a'&gt;&lt;b v='true'&gt;*&lt;/b&gt;&lt;/fc&gt;" cssclass="sta_WF_writeTitle" usedecorate="true"/>
              <Edit id="edtEmail" left="440" top="39" width="400" height="50"/>
              <Static id="staFileType_Label" left="0" top="150" width="200" height="30" text="파일타입 &lt;fc v='#fb6d3a'&gt;&lt;b v='true'&gt;*&lt;/b&gt;&lt;/fc&gt;" cssclass="sta_WF_writeTitle" usedecorate="true"/>
              <Edit id="edtFileType" left="0" top="189" width="840" height="50"/>
            </Layout>
          </Layouts>
          <Objects>
            <Dataset id="viewdataset">
              <ColumnInfo>
                <Column id="Product" type="STRING" size="80"/>
                <Column id="Email" type="STRING" size="80"/>
                <Column id="FileType" type="STRING" size="80"/>
              </ColumnInfo>
              <Rows>
                <Row/>
              </Rows>
            </Dataset>
          </Objects>
          <Bind>
            <BindItem id="bind_cmbProduct" compid="cmbProduct" propid="value" datasetid="viewdataset" columnid="Product"/>
            <BindItem id="bind_edtEmail" compid="edtEmail" propid="value" datasetid="viewdataset" columnid="Email"/>
            <BindItem id="bind_edtFileType" compid="edtFileType" propid="value" datasetid="viewdataset" columnid="FileType"/>
          </Bind>
          <ModelInfo modelserviceid="MODEL" serviceid="" modelid="freeform001" filepath="SAMPLE.xmodel">
            <Fields>
              <Field id="Product" description="" comptype="combo" compwidth="100%" compheight="50px" labelwidth="200" labelheight="30" comppadding="0 9 40 25" labelpadding="0 0 0 0" cssclass="" labelcssclass="sta_WF_writeTitle" userequired="false" labeltype="top"/>
              <Field id="Email" description="" comptype="edit" compwidth="100%" compheight="50px" labelwidth="200" labelheight="30" comppadding="0 9 40 25" labelpadding="0 0 0 0" cssclass="" labelcssclass="sta_WF_writeTitle" userequired="true" labeltype="top"/>
              <Field id="FileType" description="" comptype="edit" compwidth="100%" compheight="50px" labelwidth="200" labelheight="30" comppadding="0 9 40 25" labelpadding="0 0 0 0" cssclass="" labelcssclass="sta_WF_writeTitle" userequired="true" labeltype="top"/>
            </Fields>
            <Components>
              <Component id="staProduct_Label" fields="Product"/>
              <Component id="cmbProduct" fields="Product"/>
              <Component id="staEmail_Label" fields="Email"/>
              <Component id="edtEmail" fields="Email"/>
              <Component id="staFileType_Label" fields="FileType"/>
              <Component id="edtFileType" fields="FileType"/>
            </Components>
          </ModelInfo>
          <ViewTemplateInfo filepath="FreeformViewTemplate3050.xviewgen">
            <Attribute id="direction" value="horizontal"/>
            <Attribute id="halign" value="left"/>
            <Attribute id="valign" value="top"/>
            <Attribute id="format" value="{&quot;columnsize&quot;:[440,440],&quot;rowsize&quot;:[150,150],&quot;celllist&quot;:[{&quot;col&quot;:&quot;0&quot;,&quot;row&quot;:&quot;0&quot;,&quot;halign&quot;:&quot;left&quot;,&quot;valign&quot;:&quot;middle&quot;,&quot;direction&quot;:&quot;horizontal&quot;,&quot;fieldlist&quot;:[&quot;Product&quot;]},{&quot;col&quot;:&quot;1&quot;,&quot;row&quot;:&quot;0&quot;,&quot;halign&quot;:&quot;left&quot;,&quot;valign&quot;:&quot;middle&quot;,&quot;direction&quot;:&quot;horizontal&quot;,&quot;fieldlist&quot;:[&quot;Email&quot;]},{&quot;col&quot;:&quot;0&quot;,&quot;row&quot;:&quot;1&quot;,&quot;halign&quot;:&quot;left&quot;,&quot;valign&quot;:&quot;middle&quot;,&quot;direction&quot;:&quot;horizontal&quot;,&quot;fieldlist&quot;:[&quot;FileType&quot;],&quot;colspan&quot;:&quot;2&quot;}]}"/>
          </ViewTemplateInfo>
        </View>
      </Layout>
    </Layouts>
  </Form>
</FDL>
