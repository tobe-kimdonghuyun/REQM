전체선택(파란색)만드록 입력하면 새로 입력할수 있기 때문입니다.</Col>
            <Col id="disp_SUBJECT">Grid 콤보 드랍다운 문의</Col>
            <Col id="INSERT_DATE">2022/01/26</Col>
            <Col id="gridLevelImage">theme://images\img_WF_GridReply0.png</Col>
            <Col id="STATUS_CODE">C</Col>
            <Col id="user_cnt">18</Col>
            <Col id="user_cnt1">0</Col>
            <Col id="user_cnt2">0</Col>
            <Col id="BookMark_FLAG">null</Col>
          </Row>
          <Row>
            <Col id="rowNum">16</Col>
            <Col id="QL_SEQ">509816</Col>
            <Col id="INSERT_USER_NAME">***</Col>
            <Col id="PRODUCT_CODE">033</Col>
            <Col id="qc_no"/>
            <Col id="SUBJECT">그리드row별 색넣기</Col>
            <Col id="CONTENTS">안녕하세요

해결이 안되어 재문의 드립니다.


첨부와 같이 월별 피벗으로 뿌려줄때,
잔액 row에만 진하게 (또는 색변경) 하고싶습니다.
(ds_List =&gt; 본 테이블의 데이터
ds_ListPivot =&gt; 월별 피벗용 데이터)

하기와 같이 fn_setGrid 함수를 만들어서 값을 넣어주는데요..

소스의 // 헤더 타이틀 변경 
쪽에서
		strBody = grd_List.getCellProperty(\"body\", i, \"text\");
		nFRow = ds_List.findRowExpr(\"String(잔액).indexOf(''\" + strTitle + \"'')&gt;=0\");
이렇게 하려고 하니 strBody가 bind(ITEMGU)로 뜨더라구요..
어떻게 하면 해당 잔액 row를 알아내서 해당 row전체의 font를 bold로 할수 있을까요..
도와주세요

감사합니다.

function fn_setGrid()
{
	this.setWaitCursor(true);
	
	// 합계생성
//	grd_List.appendContentsRow(\"summ\");
	
	var strColId;
	var objCol;
	var nRow;
	var qqq = grd_List.getCellCount(\"body\");
	for(var i=0; i&lt;grd_List.getCellCount(\"body\"); i++) {
		strColId = grd_List.getCellProperty(\"body\", i, \"text\").split(\":\")[1];
		//trace(strColId);
		objCol = ds_list.getColumnInfo(strColId);	
		
		if (date_gubun.value == \"ALL\"){
			ds_list.updateSortGroup([\"NA\"]);
		}else{
			ds_list.updateSortGroup([\"ITEMGU\"]);
		}
		
		
		if(objCol &lt;&gt; null) {
			nRow = ds_GridSet.findRow(\"COL_ID\", strColId);
				
			if(nRow &gt;= 0) {
				grd_List.setFormatColProperty(i, \"size\", ds_GridSet.getColumn(nRow, \"COL_SIZE\"));
				grd_List.setCellProperty(\"body\", i, \"displaytype\", ds_GridSet.getColumn(nRow, \"COL_DISPLAY\"));
				grd_List.setCellProperty(\"body\", i, \"suppress\", nRow);
				if(!Base.isEmpty(ds_GridSet.getColumn(nRow, \"COL_ALIGN\"))) {
					grd_List.setCellProperty(\"body\", i, \"style\", \"align:\" + ds_GridSet.getColumn(nRow, \"COL_ALIGN\") + \";\");
					grd_List.setCellProperty(\"Body\", i, \"font\", ''EXPR(getRowLevel(currow)==4?\"arial,12,bold\":\"arial,12,bold\")'');
				}	
			} else {		    
				if(objCol.type == \"STRING\") {
			        grd_List.setCellProperty(\"body\", i, \"displaytype\", \"text\");
					grd_List.setFormatColProperty(i, \"size\", 150);
			    			
				} else {
					grd_List.setFormatColProperty(i, \"size\", 100);
					grd_List.setCellProperty(\"body\", i, \"displaytype\", \"number\");
					grd_List.setCellProperty(\"body\", i, \"style\", \"align:right;\");
					grd_List.setCellProperty(\"body\", i, \"text\", \"expr:isNaN(Math.round(\" + strColId + \", 2))?0:Math.round(\" + strColId + \", 2)\");
					grd_List.setCellProperty(\"Body\", i, \"font\", ''EXPR(getRowLevel(currow)==4?\"arial,12,bold\":\"\")'');
					
				}
				
			} 
				grd_List.setCellProperty(\"body\", 1, \"suppress\", \"1\");
				
			grd_List.setCellProperty(\"body\", i, \"font\", ''EXPR(grd_List.getRowLevel(currow)==4?\"bold\":\"bold\")'');	
			//trace(currow);
		}

	}
	
	// 헤더 타이틀 변경
	var strTitle;
	var nFRow;
	for(var i=0; i&lt;grd_List.getCellCount(\"head\"); i++) {
		strTitle = grd_List.getCellProperty(\"head\", i, \"text\");
		nFRow = ds_ListPivot.findRowExpr(\"String(MONTH).indexOf(''\" + strTitle + \"'')&gt;=0\");
		if(nFRow &gt;= 0) {		
			grd_List.setCellProperty(\"head\", i, \"text\", ds_ListPivot.getColumn(nFRow, \"MONTH\").substr(1,7).replace(''/'',''년 '')+''월'');
		}else {
			grd_List.setCellProperty(\"head\", i, \"style\", \"background:bisque\");
		}
	}

	
	grd_List.setCellProperty(\"head\", 0, \"text\", \"대분류\");
	grd_List.setCellProperty(\"head\", 1, \"text\", \"대분류\");
	grd_List.setCellProperty(\"head\", 2, \"text\", \"구  분\");
	grd_List.setCellProperty(\"head\", 3, \"text\", \"총금액\");
	//grd_List.setCellProperty(\"body\", 1, \"text\", \"EXPR(getRowLevel(currow) &amp;gt; 0 ? ''소계'' : ''''\");
	
	// Col 삭제 처리
	var nRow;
	if(ds_GridSet.getCaseCount(\"COL_FIX==''D''\") &gt; 0) {
		for(var i=0; i&lt;=ds_GridSet.getRowCount(); i++) {
			if(ds_GridSet.getColumn(i, \"COL_FIX\") == \"D\") {
				nRow = grd_List.getBindCellIndex(\"body\", ds_GridSet.getColumn(i, \"COL_ID\"));
				if(nRow &gt;= 0) {
				 //if(gubun2 == \"N\"){
					grd_List.deleteContentsCol(nRow);
					}
				//}
			}
		}
	}
	
	// Col Fix 처리
	if(ds_GridSet.getCaseCount(\"COL_FIX==''Y''\") &gt; 0) {
		for(var i=0; i&lt;=ds_GridSet.getRowCount(); i++) {
			if(ds_GridSet.getColumn(i, \"COL_FIX\") == \"Y\") {
				nRow = grd_List.getBindCellIndex(\"body\", ds_GridSet.getColumn(i, \"COL_ID\"));
				if(nRow &gt;= 0) {
					grd_List.setFormatColProperty(nRow, \"band\", \"left\");
				}  
			}
		}
	}
	
	grd_List.setFormatRowProperty(0, \"size\", 28);
	grd_List.setFormatRowProperty(1, \"size\", 26);
	grd_List.setFormatRowProperty(2, \"size\", 26);
	//grd_List.deleteRow(5);
	this.setWaitCursor(false);
}</Col>
            <Col id="CONTENTS_TEXT">안녕하세요

해결이 안되어 재문의 드립니다.


첨부와 같이 월별 피벗으로 뿌려줄때,
잔액 row에만 진하게 (또는 색변경) 하고싶습니다.
(ds_List =&gt; 본 테이블의 데이터
ds_ListPivot =&gt; 월별 피벗용 데이터)

하기와 같이 fn_setGrid 함수를 만들어서 값을 넣어주는데요..

소스의 // 헤더 타이틀 변경 
쪽에서
		strBody = grd_List.getCellProperty(\"body\", i, \"text\");
		nFRow = ds_List.findRowExpr(\"String(잔액).indexOf(''\" + strTitle + \"'')&gt;=0\");
이렇게 하려고 하니 strBody가 bind(ITEMGU)로 뜨더라구요..
어떻게 하면 해당 잔액 row를 알아내서 해당 row전체의 font를 bold로 할수 있을까요..
도와주세요

감사합니다.

function fn_setGrid()
{
	this.setWaitCursor(true);
	
	// 합계생성
//	grd_List.appendContentsRow(\"summ\");
	
	var strColId;
	var objCol;
	var nRow;
	var qqq = grd_List.getCellCount(\"body\");
	for(var i=0; i&lt;grd_List.getCellCount(\"body\"); i++) {
		strColId = grd_List.getCellProperty(\"body\", i, \"text\").split(\":\")[1];
		//trace(strColId);
		objCol = ds_list.getColumnInfo(strColId);	
		
		if (date_gubun.value == \"ALL\"){
			ds_list.updateSortGroup([\"NA\"]);
		}else{
			ds_list.updateSortGroup([\"ITEMGU\"]);
		}
		
		
		if(objCol &lt;&gt; null) {
			nRow = ds_GridSet.findRow(\"COL_ID\", strColId);
				
			if(nRow &gt;= 0) {
				grd_List.setFormatColProperty(i, \"size\", ds_GridSet.getColumn(nRow, \"COL_SIZE\"));
				grd_List.setCellProperty(\"body\", i, \"displaytype\", ds_GridSet.getColumn(nRow, \"COL_DISPLAY\"));
				grd_List.setCellProperty(\"body\", i, \"suppress\", nRow);
				if(!Base.isEmpty(ds_GridSet.getColumn(nRow, \"COL_ALIGN\"))) {
					grd_List.setCellProperty(\"body\", i, \"style\", \"align:\" + ds_GridSet.getColumn(nRow, \"COL_ALIGN\") + \";\");
					grd_List.setCellProperty(\"Body\", i, \"font\", ''EXPR(getRowLevel(currow)==4?\"arial,12,bold\":\"arial,12,bold\")'');
				}	
			} else {		    
				if(objCol.type == \"STRING\") {
			        grd_List.setCellProperty(\"body\", i, \"displaytype\", \"text\");
					grd_List.setFormatColProperty(i, \"size\", 150);
			    			
				} else {
					grd_List.setFormatColProperty(i, \"size\", 100);
					grd_List.setCellProperty(\"body\", i, \"displaytype\", \"number\");
					grd_List.setCellProperty(\"body\", i, \"style\", \"align:right;\");
					grd_List.setCellProperty(\"body\", i, \"text\", \"expr:isNaN(Math.round(\" + strColId + \", 2))?0:Math.round(\" + strColId + \", 2)\");
					grd_List.setCellProperty(\"Body\", i, \"font\", ''EXPR(getRowLevel(currow)==4?\"arial,12,bold\":\"\")'');
					
				}
				
			} 
				grd_List.setCellProperty(\"body\", 1, \"suppress\", \"1\");
				
			grd_List.setCellProperty(\"body\", i, \"font\", ''EXPR(grd_List.getRowLevel(currow)==4?\"bold\":\"bold\")'');	
			//trace(currow);
		}

	}
	
	// 헤더 타이틀 변경
	var strTitle;
	var nFRow;
	for(var i=0; i&lt;grd_List.getCellCount(\"head\"); i++) {
		strTitle = grd_List.getCellProperty(\"head\", i, \"text\");
		nFRow = ds_ListPivot.findRowExpr(\"String(MONTH).indexOf(''\" + strTitle + \"'')&gt;=0\");
		if(nFRow &gt;= 0) {		
			grd_List.setCellProperty(\"head\", i, \"text\", ds_ListPivot.getColumn(nFRow, \"MONTH\").substr(1,7).replace(''/'',''년 '')+''월'');
		}else {
			grd_List.setCellProperty(\"head\", i, \"style\", \"background:bisque\");
		}
	}

	
	grd_List.setCellProperty(\"head\", 0, \"text\", \"대분류\");
	grd_List.setCellProperty(\"head\", 1, \"text\", \"대분류\");
	grd_List.setCellProperty(\"head\", 2, \"text\", \"구  분\");
	grd_List.setCellProperty(\"head\", 3, \"text\", \"총금액\");
	//grd_List.setCellProperty(\"body\", 1, \"text\", \"EXPR(getRowLevel(currow) &amp;gt; 0 ? ''소계'' : ''''\");
	
	// Col 삭제 처리
	var nRow;
	if(ds_GridSet.getCaseCount(\"COL_FIX==''D''\") &gt; 0) {
		for(var i=0; i&lt;=ds_GridSet.getRowCount(); i++) {
			if(ds_GridSet.getColumn(i, \"COL_FIX\") == \"D\") {
				nRow = grd_List.getBindCellIndex(\"body\", ds_GridSet.getColumn(i, \"COL_ID\"));
				if(nRow &gt;= 0) {
				 //if(gubun2 == \"N\"){
					grd_List.deleteContentsCol(nRow);
					}
				//}
			}
		}
	}
	
	// Col Fix 처리
	if(ds_GridSet.getCaseCount(\"COL_FIX==''Y''\") &gt; 0) {
		for(var i=0; i&lt;=ds_GridSet.getRowCount(); i++) {
			if(ds_GridSet.getColumn(i, \"COL_FIX\") == \"Y\") {
				nRow = grd_List.getBindCellIndex(\"body\", ds_GridSet.getColumn(i, \"COL_ID\"));
				if(nRow &gt;= 0) {
					grd_List.setFormatColProperty(nRow, \"band\", \"left\");
				}  
			}
		}
	}
	
	grd_List.setFormatRowProperty(0, \"size\", 28);
	grd_List.setFormatRowProperty(1, \"size\", 26);
	grd_List.setFormatRowProperty(2, \"size\", 26);
	//grd_List.deleteRow(5);
	this.setWaitCursor(false);
}</Col>
