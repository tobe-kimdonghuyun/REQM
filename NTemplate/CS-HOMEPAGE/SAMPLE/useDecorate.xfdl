    <Script type="xscript5.1"><![CDATA[
this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sKeyWord = "그리드 문의";
	sKeyWord = sKeyWord.replaceAll(" ", "|");
	var objRegExp = new RegExp('('+sKeyWord+')', 'gi');
	
	var sSubject;
	var sContents;
	
	this.grdInquireList.set_enableredraw(false);
	this.ds_hotlist.set_enableevent(false);
	
	// 키워드강조하기
	if (!this.gfnIsNull(sKeyWord))
	{
		for (var i = 0; i < this.ds_hotlist.rowcount; i++)
		{
			sSubject = this.ds_hotlist.getColumn(i, "SUBJECT");
			sContents = this.ds_hotlist.getColumn(i, "CONTENTS");
			
			sSubject = sSubject.toString().replace(objRegExp, "<fc v='#fb6d3a'>"+"$&"+"</fc>");
			sContents = sContents.toString().replace(objRegExp, "<fc v='#fb6d3a'>"+"$&"+"</fc>");
			
			this.ds_hotlist.setColumn(i, "SUBJECT", sSubject);
			this.ds_hotlist.setColumn(i, "CONTENTS", sContents);
		}
	}
	this.ds_hotlist.set_enableevent(true);
	this.grdInquireList.set_enableredraw(true);
};

// expr : 그리드의 expr로 제품 선택
this.fnProductCodeIcon = function(sPdCd)
{
/*
 *	N     043
 *	17    039
 *	14    024 025 026 027 034
 *	XP    010 011 019 020 021 022 023 030 031 032 033
 *	MP    001 002 003 004 005 006 007 008 009 017 018 028 029 030
 *  URL('theme://images/grd_WF_iconN.png')
 *  URL('theme://images/grd_WF_icon17.png')
 *  URL('theme://images/grd_WF_icon14.png')
 *  URL('theme://images/grd_WF_iconXP.png')
 *  URL('theme://images/grd_WF_iconMI.png')
 */
	var sRtn = "";
	switch(sPdCd) {
	case "043":
		sRtn = "URL('theme://images/grd_WF_iconN.png')";
		break;
	case "039":
		sRtn = "URL('theme://images/grd_WF_icon17.png')";
		break;
	case "024": case "025": case "026": case "027": case "034":
		sRtn = "URL('theme://images/grd_WF_icon14.png')";
		break;
	case "010": case "011": case "019": case "020": case "021": case "022": case "023": case "030": case "031": case "032": case "033":
		sRtn = "URL('theme://images/grd_WF_iconXP.png')";
		break;
	case "001": case "002": case "003": case "004": case "005": case "006": case "007": case "008": case "009": case "017": case "018": case "028": case "029": case "030":
		sRtn = "URL('theme://images/grd_WF_iconMI.png')";
		break;
	default:
	}
	return sRtn;
};

this.fnProductCode = function(sPdCd)
{
/*
 *	N     043
 *	17    039
 *	14    024 025 026 027 034
 *	XP    010 011 019 020 021 022 023 031 032 033
 *	MP    001 002 003 004 005 006 007 008 009 017 018 028 029 030
 *  URL('theme://images/grd_WF_iconN.png')
 *  URL('theme://images/grd_WF_icon17.png')
 *  URL('theme://images/grd_WF_icon14.png')
 *  URL('theme://images/grd_WF_iconXP.png')
 *  URL('theme://images/grd_WF_iconMI.png')
 *  NexacroN
 *  Nexacro17
 *  Nexacro14
 *  Xplatform
 *  MiPlatform
 */
	var sRtn = "";
	switch(sPdCd) {
	case "043":
		sRtn = "NexacroN";
		break;
	case "039":
		sRtn = "Nexacro17";
		break;
	case "024": case "025": case "026": case "027": case "034":
		sRtn = "Nexacro14";
		break;
	case "010": case "011": case "019": case "020": case "021": case "022": case "023": case "031": case "032": case "033":
		sRtn = "Xplatform";
		break;
	case "001": case "002": case "003": case "004": case "005": case "006": case "007": case "008": case "009": case "017": case "018": case "028": case "029": case "030":
		sRtn = "MiPlatform";
		break;
	default:
	}
	return sRtn;
};

// expr : 그리드의 내용을 3줄까지 제한
this.fnGrdContentLimit = function(sContent)
{
	sContent = nexacro.replaceAll(sContent, "<fc v='#fb6d3a'>", "##DECORATE##");
	sContent = nexacro.replaceAll(sContent, "</fc>", "$$DECORATE$$");
	sContent = this.fn_deleteTag(sContent);
	sContent = nexacro.replaceAll(sContent, "##DECORATE##", "<fc v='#fb6d3a'>");
	sContent = nexacro.replaceAll(sContent, "$$DECORATE$$", "</fc>");
	sContent = sContent.replaceAll("&#10;", "\n");
	sContent = sContent.replaceAll("&#39;", " ");
	sContent = sContent.replaceAll("\n\n", "\n");
	sContent = sContent.split("\n");
	var s0 = "";
	var s1 = "";
	var s2 = "";
	if (sContent[0])
	{
		s0 = sContent[0];
	}
	if (sContent[1])
	{
		s1 = "\n"+sContent[1];
	}
	if (sContent[2])
	{
		s2 = "\n"+sContent[2];
	}
	return s0+s1+s2;
};

// expr : html태그 제거
this.fn_deleteTag = function(sStr)
{
	sStr = nexacro.replaceAll(sStr, "&nbsp;", "");
	
	//trace("##################################");
	sStr = nexacro.replaceAll(sStr, "<br>", "\n\n");
	sStr = nexacro.replaceAll(sStr, "<BR>", "\n\n");
	sStr = sStr.replace(/(<([^>]+)>)/ig,"");
	//trace("::"+sStr+"::");// .substr(0,1)
	if (sStr.indexOf("\n") == 0)
	{
		sStr = nexacro.replace("\n", "");
	}
	
	return sStr;
};]]></Script>
  </Form>
