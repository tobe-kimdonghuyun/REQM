<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="useDecorate" width="1280" height="720" titletext="New Form">
    <Layouts>
      <Layout height="720" width="1280">
        <Grid id="grdInquireList" taborder="0" left="0" top="50" width="945" height="1045" cssclass="grd_WF_list" binddataset="ds_hotlist" scrollbartype="none none" autosizingtype="row" extendsizetype="row" autofittype="col" oncellclick="grdInquireList_oncellclick">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="30"/>
                <Column size="86"/>
                <Column size="14"/>
                <Column size="86"/>
                <Column size="14"/>
                <Column size="70"/>
                <Column size="14"/>
                <Column size="635"/>
              </Columns>
              <Rows>
                <Row size="60"/>
                <Row size="40"/>
                <Row size="40"/>
                <Row size="20"/>
              </Rows>
              <Band id="body">
                <Cell text="expr:comp.parent.fnProductCodeIcon(PRODUCT_CODE)" displaytype="imagecontrol" autosizerow="none"/>
                <Cell col="1" text="expr:comp.parent.fnProductCode(PRODUCT_CODE)" cssclass="grd_WF_product" autosizerow="none"/>
                <Cell col="2" displaytype="imagecontrol" text="URL('theme://images/grd_WF_dot.png')" autosizerow="none"/>
                <Cell col="3" text="expr:INSERT_DATE.replaceAll(&quot;/&quot;, &quot;-&quot;)" autosizerow="none" cssclass="grd_WF_date"/>
                <Cell col="4" text="URL('theme://images/grd_WF_dot.png')" autosizerow="none" displaytype="imagecontrol"/>
                <Cell col="5" cssclass="grd_WF_date" text="bind:user_cnt1" autosizerow="none" textAlign="center"/>
                <Cell col="6" autosizerow="none" displaytype="imagecontrol" text="URL('theme://images/grd_WF_dot.png')"/>
                <Cell col="7" text="expr:comp.parent.gfnIsNull(qc_no)==false?'RC '+qc_no:'' " autosizerow="none" cssclass="expr:comp.parent.fn_statusCss(STATUS_CODE,qc_no)"/>
                <Cell row="1" colspan="8" text="expr:comp.parent.gfn_makeEllipse(SUBJECT, comp)" cssclass="grd_WF_title0" wordWrap="char" autosizerow="none" tooltiptext="bind:SUBJECT" displaytype="decoratetext"/>
                <Cell row="2" colspan="8" text="expr:comp.parent.fnGrdContentLimit(CONTENTS)" wordWrap="char" cssclass="grd_WF_content" autosizerow="limitmin" displaytype="decoratetext"/>
                <Cell row="3" colspan="8" cssclass="grd_WF_line" autosizerow="none"/>
              </Band>
            </Format>
            <Format id="title">
              <Columns>
                <Column size="30"/>
                <Column size="86"/>
                <Column size="14"/>
                <Column size="86"/>
                <Column size="14"/>
                <Column size="70"/>
                <Column size="14"/>
                <Column size="635"/>
              </Columns>
              <Rows>
                <Row size="60"/>
                <Row size="40"/>
                <Row size="20"/>
              </Rows>
              <Band id="body">
                <Cell text="expr:comp.parent.fnProductCodeIcon(PRODUCT_CODE)" displaytype="imagecontrol" autosizerow="none"/>
                <Cell col="1" text="expr:comp.parent.fnProductCode(PRODUCT_CODE)" cssclass="grd_WF_product" autosizerow="none"/>
                <Cell col="2" displaytype="imagecontrol" text="URL('theme://images/grd_WF_dot.png')" autosizerow="none"/>
                <Cell col="3" text="expr:INSERT_DATE.replaceAll(&quot;/&quot;, &quot;-&quot;)" autosizerow="none" cssclass="grd_WF_date"/>
                <Cell col="4" text="URL('theme://images/grd_WF_dot.png')" autosizerow="none" displaytype="imagecontrol"/>
                <Cell col="5" cssclass="grd_WF_date" text="bind:user_cnt1" autosizerow="none" textAlign="center"/>
                <Cell col="6" autosizerow="none" displaytype="imagecontrol" text="expr:STATUS_CODE!=&quot;C&quot;||comp.parent.gfnIsNull(qc_no)==false?&quot;URL('theme://images/grd_WF_dot.png')&quot;:&quot;&quot;"/>
                <Cell col="7" text="expr:comp.parent.gfnIsNull(qc_no)==false?'RC '+qc_no:'' " autosizerow="none" cssclass="expr:STATUS_CODE!='C'?comp.parent.gfnIsNull(qc_no)?'grd_WF_status1':'grd_WF_status2':''"/>
                <Cell row="1" colspan="8" text="expr:comp.parent.gfn_makeEllipse(SUBJECT, comp)" cssclass="grd_WF_title0" wordWrap="char" tooltiptext="bind:SUBJECT" displaytype="decoratetext"/>
                <Cell row="2" colspan="8" cssclass="grd_WF_line" autosizerow="none"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="Button00" taborder="1" text="Button00" left="1085" top="34" width="120" height="50" onclick="Button00_onclick"/>
      </Layout>
    </Layouts>
    <Objects>
