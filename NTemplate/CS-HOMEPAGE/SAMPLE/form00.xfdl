    <Objects>
      <Dataset id="ds_NoticeList" firefirstcount="0" firenextcount="0" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="rowNum" type="INT" size="20"/>
          <Column id="BL_SEQ" type="BIGDECIMAL" size="19"/>
          <Column id="user_cnt" type="INT" size="11"/>
          <Column id="boardid" type="STRING" size="255"/>
          <Column id="SUBJECT" type="STRING" size="255"/>
          <Column id="INSERT_DATE" type="STRING" size="255"/>
          <Column id="CONTENTS" type="STRING" size="255"/>
          <Column id="CONTENTS_TEXT" type="STRING" size="256"/>
          <Column id="goods_gbn" type="STRING" size="255"/>
          <Column id="SUBJECT_COLOR" type="STRING" size="255"/>
          <Column id="BOLD_FLAG" type="STRING" size="255"/>
          <Column id="HOT_FLAG" type="STRING" size="255"/>
          <Column id="IMPORTANT_FLAG" type="STRING" size="255"/>
          <Column id="NOTICE_FLAG" type="STRING" size="255"/>
          <Column id="BookMark_cnt" type="STRING" size="11"/>
          <Column id="BookMark_FLAG" type="STRING" size="256"/>
          <Column id="FILENAME" type="STRING" size="256"/>
          <Column id="FILE_CNT" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="ds_SearchParam" firefirstcount="0" firenextcount="0" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="loginAcc" type="STRING" size="256"/>
          <Column id="dispGubun" type="STRING" size="256"/>
          <Column id="PCategory2" type="STRING" size="256"/>
          <Column id="display_cnt" type="STRING" size="256"/>
          <Column id="page" type="STRING" size="256"/>
          <Column id="searchfield" type="STRING" size="256"/>
          <Column id="searchgubun" type="STRING" size="256"/>
          <Column id="keyword" type="STRING" size="256"/>
          <Column id="search_resort" type="STRING" size="256"/>
          <Column id="keywordall" type="STRING" size="256"/>
          <Column id="BusinessSection" type="STRING" size="256"/>
          <Column id="statusType" type="STRING" size="256"/>
          <Column id="User_id" type="STRING" size="256"/>
          <Column id="bookMark" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="dispGubun"/>
            <Col id="BusinessSection">000</Col>
            <Col id="searchgubun">OR</Col>
            <Col id="searchfield">200</Col>
            <Col id="search_resort">N</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  게시판 리스트(Notice, Tip 등)
*
*  @MenuPath 
*  @FileName 		BOARD::frmBoardList.xfdl 
*  @Creator 		김광호
*  @CreateDate 		2022.01.01
*  @LastModifier  
*  @LastModifyDate  
*  @Version 		1.0
*  @Outline 		게시판 리스트(Notice, Tip 등)
*  @Desction 
************** 소스 수정 이력 *************************************************
*    date          Modifier            Description
*******************************************************************************
*  2022.01.01      김광호	           최초 생성 
*******************************************************************************
*/

// 그리드 제어
this.grd1 = null;
this.grd2 = null;
this.rowNum = 0;  

this.keywordall = "";
   
this.divDetailSize = "";
this.divReqSize = "";
this.txtReqRemarkSize = "";
this.iWebHeight = 200;
this.nDivRightHeight = 0;
this.iWebSizeCnt=0;

this.nGrdSize = 0;

this.fvImportantCnt = 3;	//상단에 보여줄 중요 공지사항 개수

this.fvBookCD = 0;


this.form00_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 페이징 초기화
	nexacro.getApplication().gv_mainFrame.QA_Cond_Page = 1;    
	nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = 0;
	
	// History에 기억된 keyword나 page가 있으면 셋팅
	if (!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.param.keyword))
	{
		this.divCondition.form.edtKeyword.set_value(nexacro.getApplication().gv_mainFrame.param.keyword);
	}
	if (!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.param.page))
	{
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = nexacro.getApplication().gv_mainFrame.param.page;
		nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = nexacro.floor(nexacro.getApplication().gv_mainFrame.QA_Cond_Page/10);
	}

	// 통합검색에서 들어왔을 경우 return;
	if (!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.SearchEngineFlag))
	{
		this.divCondition.set_visible(false);
		this.viewList.set_top(40);
		this.divRight.set_top(40);
		
		if (nexacro.getApplication().gv_mainFrame.SearchEngineFlag == "Tip")
		{
			this.cboListType.set_visible(true);
		}
	
		// 페이징 교체
		this.divPageExpr.set_visible(false);
		this.viewPaging.set_visible(true);
		//this.fn_searchEngineCall();
		nexacro.getApplication().gv_searchEngine.fn_search(nexacro.getApplication().gv_mainFrame.QA_Cond_Page);
		return;
	}

	var sData = {};
	sData = nexacro.getApplication().gv_mainFrame.gfnGetHistoryData();
	// 히스토리 sData에서 불러오기
	if (!this.gfnIsNull(sData))
	{
		if (!this.gfnIsNull(sData.cmbSearchField)){	this.divCondition.form.cmbSearchField.set_value(sData.cmbSearchField); }
		if (!this.gfnIsNull(sData.rdoSearchgubun)){	this.divCondition.form.rdoSearchgubun.set_value(sData.rdoSearchgubun); }
	}

	// 그리드 포멧 변경
	switch(nexacro.getApplication().gv_mainFrame.PCategory2) {
	case "Notice":
		this.viewList.form.grdNoticeList.setFormat("notice");
		break;
	case "Tip_N":
	case "Tip_17":
	case "Tip_14":
	case "Tip_XP":
	case "Tip_MP":
		this.viewList.form.grdNoticeList.setFormat("tip");
		break;
	case "Education_information":
		this.viewList.form.grdNoticeList.setFormat("notice");
		break;
	case "Education_material":
		this.viewList.form.grdNoticeList.setFormat("notice");
		break;
	case "Education_Review":
		this.grdNoticeList.setFormat("notice");
		break;
	default:
	}
	
	//this.nDivRightHeight = this.divRight.getOffsetHeight();
	// 메인 사이즈 초기화
	this.divPageExpr.set_visible(false);
	
	var PCategoryGubun = "";
	// PCategoryGubun 셋팅
	switch(nexacro.getApplication().gv_mainFrame.PCategory2) {
	case "Notice":
		
		break;
	case "Tip_N":
		PCategoryGubun = "009";
		break;
	case "Tip_17":
		PCategoryGubun = "008";
		break;
	case "Tip_14":
		PCategoryGubun = "006";
		break;
	case "Tip_XP":
		PCategoryGubun = "002";
		break;
	case "Tip_MP":
		PCategoryGubun = "001";
		break;
	default:
	}
	
	nexacro.getApplication().gv_mainFrame.BoardCategoryID = PCategoryGubun;
		
 	this.ds_SearchParam.clearData();
 	this.ds_SearchParam.addRow();
 	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition,"display_cnt",nexacro.getApplication().gv_mainFrame.Board_Cond_DisplayCnt);
 	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition,"page",nexacro.getApplication().gv_mainFrame.Board_Cond_Page);
 	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition,"searchfield",nexacro.getApplication().gv_mainFrame.Board_Cond_Searchfield);
 	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition,"searchgubun",nexacro.getApplication().gv_mainFrame.Board_Cond_Searchgubun);
 	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition,"BusinessSection",nexacro.getApplication().gv_mainFrame.Board_Cond_BusinessSection);
 	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition,"search_resort",nexacro.getApplication().gv_mainFrame.Board_Cond_Resort);
 	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition,"keyword",nexacro.getApplication().gv_mainFrame.Board_Cond_Keyword);
 	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition,"keywordall",nexacro.getApplication().gv_mainFrame.Board_Cond_Keyword);
 	
 	// 페이지 제어 초기화
 	this.divPageExpr.form.fn_PageInit(this.ds_NoticeList, "", this, "fn_CallTrans()", "fn_SetInitSize()");
 	nexacro.getApplication().changeflg = false;
 	nexacro.getApplication().oldRowNum = "";
 	// "등록자, 번호" 항목은 제외
  	nexacro.getApplication().gds_SearchField.filter("");
  	nexacro.getApplication().gds_SearchField.filter("currow < 3 || currow > 4");

	this.fvBookCD = nexacro.getApplication().gv_BookmarkTipCd;
	var objTab = nexacro.getApplication().gv_mainFrame.divMain.form.divBookmark.form.tabProduct;
	if(!this.gfnIsNull(nexacro.getApplication().gv_BookmarkTipCd))
	{
		var sBookCD = this.fvBookCD;
		objTab.set_tabindex(sBookCD);
		nexacro.getApplication().gv_BookmarkTipCd=0;
	}
	else
	{
		objTab.set_tabindex(sBookCD);
		nexacro.getApplication().gv_BookmarkTipCd=0;
	}
	// 데이터 취득
 	this.fn_CallTrans();	
};


// 조회
this.fn_CallTrans = function() {

	// 검색조건
	this.ds_SearchParam.setColumn(0, "keywordall", this.keywordall);
	this.ds_SearchParam.setColumn(0, "display_cnt", this.divPageExpr.form.unitSelRowNo);
	this.ds_SearchParam.setColumn(0, "page", this.divPageExpr.form.startPageNo + 1);
	this.ds_SearchParam.setColumn(0, "User_id", nexacro.getApplication().gds_UserInfo.getColumn(nexacro.getApplication().gds_UserInfo.rowposition,"User_id"));    
	this.ds_SearchParam.setColumn(0, "searchfield", "");
	this.ds_SearchParam.setColumn(0, "searchgubun", "");

	nexacro.getApplication().com_SetParam(this.ds_SearchParam);
	
	// filter된 상태로 삭제후 값이 들어가면 rowcount가 0이되는 에러가 있음
	// 상기에 대한 회피책으로 우선 filter를 되돌리고 나서 처리
 	this.ds_NoticeList.filter("");
 	this.ds_NoticeList.deleteAll();

	// 인수 설정     
	var strBoardId="A06";
	//var PCategoryGubun=nexacro.wrapQuote("'%'");
	var PCategoryGubun = "%";

	// strBoardId 셋팅
	switch(nexacro.getApplication().gv_mainFrame.PCategory2) {
	case "Notice":
		strBoardId="A06";
		break;
	case "Tip_N":
	case "Tip_17":
	case "Tip_14":
	case "Tip_XP":
	case "Tip_MP":
		strBoardId="A05";
		break;
	case "Education_information":
		strBoardId="A14";
		break;
	case "Education_material":
		strBoardId="A09";
		break;
	case "Education_Review":
		strBoardId="A16";
		break;
	default:
	}
	
	// PCategoryGubun 셋팅
	switch(nexacro.getApplication().gv_mainFrame.PCategory2) {
	case "Notice":
		
		break;
	case "Tip_N":
		PCategoryGubun = nexacro.wrapQuote("'010','009'");
		break;
	case "Tip_17":
		PCategoryGubun = nexacro.wrapQuote("'008'");
		break;
	case "Tip_14":
		PCategoryGubun = nexacro.wrapQuote("'006'");
		break;
	case "Tip_XP":
		PCategoryGubun = nexacro.wrapQuote("'002'");
		break;
	case "Tip_MP":
		PCategoryGubun = nexacro.wrapQuote("'001'");
		break;
	default:
	}
	
	// 나의메뉴 > 북마크 일경우
	var nRow = nexacro.getApplication().gv_mainFrame.dsScreenUrl.findRow("subCatgy", nexacro.getApplication().gv_mainFrame.param.menu);
	var sLayout = nexacro.getApplication().gv_mainFrame.dsScreenUrl.getColumn(nRow, "Layout");
	if (sLayout == "BOOKMARK")
	{
		this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition,"bookMark", "OK");
		nexacro.getApplication().gds_SearchParam.setColumn(0,"bookMark", "OK");
		strBoardId="A05";
		var nTabIndex = nexacro.getApplication().gv_mainFrame.divMain.form.divBookmark.form.tabProduct.tabindex
		// PCategoryGubun 셋팅
		this.divCondition.set_visible(false);
		this.viewList.set_top(50);
		this.cboListType.set_visible(true);
		
		switch(nTabIndex) {
		case 0:
			PCategoryGubun = "%";	// 전체
			nexacro.getApplication().gds_SearchParam.setColumn(0, "PCategory2", "Nexacro N,nexacro platform17,nexacro platform14,XPLATFORM,MiPlatform");
			break;
		case 1:
			PCategoryGubun = "009";	// N
			nexacro.getApplication().gds_SearchParam.setColumn(0, "PCategory2", "Nexacro N");
			break;
		case 2:
			PCategoryGubun = "008";	// 17
			nexacro.getApplication().gds_SearchParam.setColumn(0, "PCategory2", "nexacro platform17");
			break;
		case 3:
			PCategoryGubun = "006";	// 14
			nexacro.getApplication().gds_SearchParam.setColumn(0, "PCategory2", "nexacro platform14");
			break;
		case 4:
			PCategoryGubun = "002";	// XP
			nexacro.getApplication().gds_SearchParam.setColumn(0, "PCategory2", "XPLATFORM");
			break;
		case 5:
			PCategoryGubun = "001";	// MP
			nexacro.getApplication().gds_SearchParam.setColumn(0, "PCategory2", "MiPlatform");
			break;
		default:
		}
		
		this.ds_SearchParam.setColumn(0, "dispGubun", "All");
		nexacro.getApplication().gds_SearchParam.setColumn(0, "dispGubun", "All");
	}
	
	var strArgs = "RTYPE=XML DB='CS' sessionChk=false BoardID=" + strBoardId + " PCategoryGubun=" + PCategoryGubun +" nationCd=" +  nexacro.getApplication().gv_NationCd + "' JSESSIONID='"+nexacro.getApplication().JSESSIONID+"'";
	if(strBoardId == "A37")
	{
		var strUrl = "SVC_JSP::Next_JSP/Board/SearchBoard2.jsp?";
	}
	else
	{
		var strUrl = "SVC_JSP::Next_JSP/Board/SearchBoard_new.jsp?";
	}
	var strDsInput = "input1=gds_SearchParam";
	var strDsOutput = "ds_totalCnt=output1 ds_NoticeList=output2";  
	this.com_TransSend("noticeList",strUrl,strDsInput,strDsOutput,strArgs,"fn_NoticeListCallBack");
}

// 조회 후 콜백
this.fn_NoticeListCallBack = function (svcid,errCode,errMsg)
{
return;
	this.ds_ImportantList.filter("");
	if (svcid == "noticeList") 
	{
 		// 데이터가 있을경우
 		if (this.ds_NoticeList.rowcount > 0) 
		{
			//trace(this.ds_NoticeList.saveXML());
			//전문가 양성과정 조회시에만 소트 적용
			if( nexacro.getApplication().gv_mainFrame.PCategory2 == "Education_Review" )
			{
				this.viewList.form.grdNoticeList.set_formatid("notice_Edu");	
			}
			// 키워드강조하기
			if (!this.gfnIsNull(this.keywordall))
			{
				var sKeyWord = this.keywordall.replaceAll(" ", "|");
				var objRegExp = new RegExp('('+sKeyWord+')', 'gi');
				
				var sSubject;
				var sContents;
				
				this.viewList.form.grdNoticeList.set_enableredraw(false);
				this.ds_NoticeList.set_enableevent(false);
				
				// 키워드강조하기
				if (!this.gfnIsNull(sKeyWord))
				{
					if (this.divCondition.form.cmbSearchField.value == 200)		// 제목만
					{
						for (var i = 0; i < this.ds_NoticeList.rowcount; i++)
						{
							sSubject = this.ds_NoticeList.getColumn(i, "SUBJECT");
							sSubject = sSubject.toString().replace(objRegExp, "<fc v='#ff0000'>"+"$&"+"</fc>");
							this.ds_NoticeList.setColumn(i, "SUBJECT", sSubject);
						}
					}
					else if (this.divCondition.form.cmbSearchField.value == 300)	// 내용만
					{
						for (var i = 0; i < this.ds_NoticeList.rowcount; i++)
						{
							sContents = this.ds_NoticeList.getColumn(i, "CONTENTS");
							sContents = sContents.toString().replace(objRegExp, "<fc v='#ff0000'>"+"$&"+"</fc>");
							this.ds_NoticeList.setColumn(i, "CONTENTS", sContents);
						}
					}
					else 																// 제목+내용
					{
						for (var i = 0; i < this.ds_NoticeList.rowcount; i++)
						{
							sSubject = this.ds_NoticeList.getColumn(i, "SUBJECT");
							sContents = this.ds_NoticeList.getColumn(i, "CONTENTS");

							sSubject = sSubject.toString().replace(objRegExp, "<fc v='#ff0000'>"+"$&"+"</fc>");
							sContents = sContents.toString().replace(objRegExp, "<fc v='#ff0000'>"+"$&"+"</fc>");
							
							
							this.ds_NoticeList.setColumn(i, "SUBJECT", sSubject);
							this.ds_NoticeList.setColumn(i, "CONTENTS", sContents);
						}
					}
				}
				this.ds_NoticeList.set_enableevent(true);
				this.viewList.form.grdNoticeList.set_enableredraw(true);
			}
		
			// 공지사항일 경우 중요항목 3개를 상위에 뿌려준다.
			if (nexacro.getApplication().gv_mainFrame.PCategory2 == "Notice")
			{
				this.grdImportantList.set_formatid("notice");
				
				this.ds_ImportantList.copyData(this.ds_NoticeList);
				this.ds_ImportantList.filter("IMPORTANT_FLAG=='1'");
				
				for(var i=this.ds_ImportantList.rowcount-1; i>this.fvImportantCnt-1; i--){
					this.ds_ImportantList.deleteRow(i);
				}
				var nCnt = this.ds_ImportantList.rowcount;
				
				this.grdImportantList.set_height(nCnt*85);
				this.grdImportantList.set_visible(true);
	
				// from 나D
				this.divPageExpr.form.fn_SetHistoryData();
				
				this.viewList.set_top(this.grdImportantList.getOffsetBottom());
			}
			
			
			this.divPageExpr.form.serverRowCount = this.ds_NoticeList.getRowCount();
			// 검색되는 총건수
			var nRow = nexacro.getApplication().gv_mainFrame.dsScreenUrl.findRow("subCatgy", nexacro.getApplication().gv_mainFrame.param.menu);
			if(nexacro.getApplication().gv_mainFrame.dsScreenUrl.getColumn(nRow, "Layout") == "BOOKMARK"){   //북마크일 경우
				this.ds_totalCnt.setColumn(0,"totalCnt",this.ds_NoticeList.rowcount);
			}
			this.divPageExpr.form.totalCount = this.ds_totalCnt.getColumn(0, "totalCnt");
			
			var iLastRow = this.divPageExpr.form.startPageNo * this.divPageExpr.form.unitSelRowNo;

			// 페이지 처리  
			this.divPageExpr.form.fn_SetPageNo();    
			this.divPageExpr.form.fn_indexBtnSet(nexacro.toNumber(nexacro.getApplication().gv_mainFrame.QA_Cond_Page));
			this.divPageExpr.set_visible(true);
 		} else {   
			var strMsg = "msg_nation1"
			if(nexacro.getApplication().gv_NationCd == "002") 
			{
				strMsg = "msg_nation2"
			} else if(nexacro.getApplication().gv_NationCd == "003") 
			{
				strMsg = "msg_nation3";
			}
			if (nexacro.getApplication().gv_mainFrame.PCategory2 == "Notice")
			{
				this.grdImportantList.set_formatid("notice");
				
				this.ds_ImportantList.filter("IMPORTANT_FLAG=='1'");
				
				for(var i=this.ds_ImportantList.rowcount-1; i>this.fvImportantCnt-1; i--)
				{
					this.ds_ImportantList.deleteRow(i);
				}
				var nCnt = this.ds_ImportantList.rowcount;
				
				this.grdImportantList.set_height(nCnt*85);
				this.grdImportantList.set_visible(true);
				
				this.viewList.set_top(this.grdImportantList.getOffsetBottom());
			}
			this.viewList.form.grdNoticeList.set_nodatatext(nexacro.getApplication().gds_MessageCd.lookup("msg_code_id","MSG_000029",strMsg));
			this.divPageExpr.set_visible(false);
			//this.viewList.set_height(this.nDivRightHeight-300);
			//this.set_height(this.nDivRightHeight);//      		
			//this.parent.set_height(this.nDivRightHeight);//
			var nSize = 246;
			//this.divRight.set_height(this.nDivRightHeight);
			//nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, this.nDivRightHeight + nSize);
			
 		}
		this.resetScroll();
		
		// 저장된 스크롤 위치가 있으면 이동
		nexacro.getApplication().gv_mainFrame.vscrollbar.set_pos(nexacro.getApplication().gv_mainFrame.SCROLL_POS);
		nexacro.getApplication().gv_mainFrame.SCROLL_POS = 0;
	}              
}
]]></Script>
  </Form>
</FDL>
