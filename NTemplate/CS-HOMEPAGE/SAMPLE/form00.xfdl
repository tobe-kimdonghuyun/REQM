<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="form00" width="1300" height="1400" titletext="New Form" onload="form00_onload">
    <Layouts>
      <Layout height="1400" width="1300">
        <Div id="divPageExpr" taborder="1" url="COMMFORM::frmPageCtrl.xfdl" left="0" visible="true" top="1330" height="40" background="transparent" width="945" text=""/>
        <Grid id="grdNoticeList" left="0" top="0" right="335" bottom="80" autoenter="select" autofittype="col" cssclass="grd_WF_list" oncellclick="viewList_grdNoticeList_oncellclick" nodatatext="검색된 데이터가 없습니다." binddataset="ds_NoticeList" visible="true" taborder="1" border="1px solid black">
          <Formats>
            <Format id="tip">
              <Columns>
                <Column size="25"/>
                <Column size="80"/>
                <Column size="95"/>
                <Column size="36"/>
                <Column size="80"/>
                <Column size="36"/>
                <Column size="80"/>
                <Column size="36"/>
                <Column size="479"/>
              </Columns>
              <Rows>
                <Row size="20"/>
                <Row size="40"/>
                <Row size="96"/>
                <Row size="50"/>
                <Row size="20"/>
              </Rows>
              <Band id="body">
                <Cell/>
                <Cell col="1"/>
                <Cell col="2" colspan="7" autosizerow="none"/>
                <Cell row="1" colspan="9" text="expr:comp.parent.parent.parent.gfn_makeEllipse(SUBJECT, comp)" cssclass="grd_WF_title0" wordWrap="none" autosizerow="none" tooltiptext="expr:SUBJECT.replaceAll(&quot;&lt;fc v='#fb6d3a'&gt;&quot;,&quot;&quot;).replaceAll(&quot;&lt;/fc&gt;&quot;,&quot;&quot;)" displaytype="decoratetext"/>
                <Cell row="2" colspan="9" text="bind:CONTENTS" cssclass="grd_WF_content" displaytype="decoratetext"/>
                <Cell row="3" text="No." cssclass="grd_WF_numberTip" autosizerow="none"/>
                <Cell row="3" col="1" text="bind:BL_SEQ" cssclass="grd_WF_numberTip" autosizerow="none" displaytype="number"/>
                <Cell row="3" col="2" text="expr:INSERT_DATE.replaceAll(&quot;/&quot;,&quot;-&quot;)" cssclass="grd_WF_num" autosizerow="limitmin"/>
                <Cell row="3" col="3" autosizerow="none" text="URL('theme://images/grd_WF_click.png')" displaytype="imagecontrol" padding="10px 0px 0px 0px"/>
                <Cell row="3" col="4" text="bind:user_cnt" cssclass="grd_WF_num"/>
                <Cell row="3" col="5" displaytype="imagecontrol" text="URL('theme://images/btn_WF_link_S.png')" autosizerow="limitmin" padding="10px 0px 0px 0px" cursor="pointer"/>
                <Cell row="3" col="6" text="링크복사" cssclass="grd_WF_num" autosizerow="limitmin" cursor="pointer"/>
                <Cell row="3" col="7" text="expr:comp.parent.parent.parent.gfnIsNull(FILENAME)?&quot;&quot;:&quot;URL('theme://images/sta_WF_viewAttach_S.png')&quot;" displaytype="imagecontrol" autosizerow="limitmin" padding="10px 0px 0px 0px"/>
                <Cell row="3" col="8" text="expr:FILENAME+(FILE_CNT&gt;1?' ('+FILE_CNT+')':'')" cssclass="grd_WF_num" autosizerow="limitmin"/>
                <Cell row="4" colspan="9" cssclass="grd_WF_line" autosizerow="none"/>
              </Band>
            </Format>
            <Format id="notice">
              <Columns>
                <Column size="685"/>
                <Column size="30"/>
                <Column size="55"/>
                <Column size="80"/>
