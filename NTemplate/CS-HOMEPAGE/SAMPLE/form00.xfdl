                <Column size="60"/>
              </Columns>
              <Rows>
                <Row size="80"/>
                <Row size="5"/>
              </Rows>
              <Band id="body">
                <Cell text="bind:SUBJECT" cssclass="grd_WF_serverTitle" wordWrap="char" displaytype="decoratetext"/>
                <Cell col="1" cssclass="grd_WF_num" text="No." textAlign="right" padding="0px"/>
                <Cell col="2" cssclass="grd_WF_num" text="bind:BL_SEQ" padding="0px"/>
                <Cell col="3" text="bind:INSERT_DATE" cssclass="grd_WF_num" displaytype="date" calendardateformat="yyyy-MM-dd" padding="0px"/>
                <Cell col="4" cssclass="grd_WF_click"/>
                <Cell col="5" text="bind:user_cnt" cssclass="grd_WF_num" padding="0px"/>
