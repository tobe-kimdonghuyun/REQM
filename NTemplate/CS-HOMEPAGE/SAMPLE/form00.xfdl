              </Band>
            </Format>
            <Format id="title">
              <Columns>
                <Column size="25"/>
                <Column size="80"/>
                <Column size="86"/>
                <Column size="36"/>
                <Column size="80"/>
                <Column size="36"/>
                <Column size="80"/>
                <Column size="36"/>
                <Column size="487"/>
              </Columns>
              <Rows>
                <Row size="20"/>
                <Row size="40"/>
                <Row size="50"/>
                <Row size="20"/>
              </Rows>
              <Band id="body">
                <Cell/>
                <Cell col="1"/>
                <Cell col="2" colspan="7" autosizerow="none"/>
                <Cell row="1" colspan="9" text="expr:comp.parent.parent.parent.gfn_makeEllipse(SUBJECT, comp)" cssclass="grd_WF_title0" wordWrap="none" autosizerow="none" tooltiptext="expr:SUBJECT.replaceAll(&quot;&lt;fc v='#fb6d3a'&gt;&quot;,&quot;&quot;).replaceAll(&quot;&lt;/fc&gt;&quot;,&quot;&quot;)" displaytype="decoratetext"/>
                <Cell row="2" text="No." cssclass="grd_WF_numberTip" autosizerow="none"/>
                <Cell row="2" col="1" text="bind:BL_SEQ" cssclass="grd_WF_numberTip" autosizerow="none" displaytype="number"/>
                <Cell row="2" col="2" text="expr:INSERT_DATE.replaceAll(&quot;/&quot;,&quot;-&quot;)" cssclass="grd_WF_num" autosizerow="limitmin"/>
                <Cell row="2" col="3" autosizerow="none" text="URL('theme://images/grd_WF_click.png')" displaytype="imagecontrol" padding="10px 0px 0px 0px"/>
                <Cell row="2" col="4" text="bind:user_cnt" cssclass="grd_WF_num"/>
                <Cell row="2" col="5" displaytype="imagecontrol" text="URL('theme://images/btn_WF_link_S.png')" autosizerow="limitmin" padding="10px 0px 0px 0px" cursor="pointer"/>
                <Cell row="2" col="6" text="링크복사" cssclass="grd_WF_num" autosizerow="limitmin" cursor="pointer"/>
                <Cell row="2" col="7" text="expr:comp.parent.parent.parent.gfnIsNull(FILENAME)?&quot;&quot;:&quot;URL('theme://images/sta_WF_viewAttach_S.png')&quot;" displaytype="imagecontrol" autosizerow="limitmin" padding="10px 0px 0px 0px"/>
                <Cell row="2" col="8" text="expr:FILENAME+(FILE_CNT&gt;1?' ('+FILE_CNT+')':'')" cssclass="grd_WF_num" autosizerow="limitmin"/>
                <Cell row="3" colspan="9" cssclass="grd_WF_line" autosizerow="none"/>
              </Band>
            </Format>
            <Format id="notice_Edu">
              <Columns>
                <Column size="685"/>
                <Column size="30"/>
                <Column size="55"/>
                <Column size="80"/>
                <Column size="36"/>
                <Column size="60"/>
              </Columns>
              <Rows>
                <Row size="80"/>
                <Row size="95"/>
                <Row size="5"/>
              </Rows>
              <Band id="body">
                <Cell text="bind:SUBJECT" cssclass="grd_WF_serverTitle" wordWrap="char" displaytype="decoratetext"/>
                <Cell col="1" cssclass="grd_WF_num" text="No." textAlign="right" padding="0px"/>
                <Cell col="2" cssclass="grd_WF_num" text="bind:BL_SEQ" padding="0px"/>
                <Cell col="3" text="bind:INSERT_DATE" cssclass="grd_WF_num" displaytype="date" calendardateformat="yyyy-MM-dd" padding="0px"/>
                <Cell col="4" cssclass="grd_WF_click"/>
                <Cell col="5" text="bind:user_cnt" cssclass="grd_WF_num" padding="0px"/>
                <Cell row="1" colspan="6" text="bind:CONTENTS_TEXT" displaytype="decoratetext" cssclass="grd_WF_content"/>
