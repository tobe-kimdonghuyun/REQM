    </Objects>
    <Script type="xscript5.1"><![CDATA[
this.Grid00_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var a = this.Dataset00.getColumn(e.row, "WAIT_TIME");
	this.Edit00.set_value(this.gfnIsNull2(a));	
};

this.gfnIsNull2 = function(sValue)
{
	
	if (new String(sValue).valueOf() == "undefined") return true;
    if (sValue == null ) return true;
    
    var ChkStr = new String(sValue);
	trace("ChkStr:"+ChkStr);
    if (ChkStr == "null") return true;
    if (ChkStr.toString().length == 0 ) return true;
    return false;
};
this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	trace(this.Grid00.griduserproperty);
	this.Grid00.griduserproperty="checkbox,!sort,!rowfix,!colfix,!filter,!initial";
	trace(this.Grid00.griduserproperty);
}


this.fn_getThisWeek = function (inputDateStr) {
    var value = [];
    
    var formatDate = function(date) {
        var myMonth = date.getMonth() + 1; 
        var myWeekDay = date.getDate();
        
        var addZero = function(num) {
            if (num < 10) {
                num = "0" + num;
            }
            return num;
        }
        
        var md = addZero(myMonth) + addZero(myWeekDay);
        return md;
    }
    
    var inputDate = new Date(inputDateStr);
    var inputDayOfWeek = inputDate.getDay(); 
    var inputDay = inputDate.getDate(); 
    var inputMonth = inputDate.getMonth(); 
    var inputYear = inputDate.getFullYear(); 
    
    // 입력된 날짜를 기준으로 이번 주의 시작일과 종료일을 계산
    var weekStartDate = new Date(inputYear, inputMonth, inputDay - inputDayOfWeek + (inputDayOfWeek === 0 ? -6 : 1)); // 일요일인 경우 시작일을 6일 전으로 설정
    var weekEndDate = new Date(inputYear, inputMonth, inputDay + (7 - inputDayOfWeek)); // 일요일은 7일 후로 설정
    
    value.push(formatDate(weekStartDate));
    value.push(formatDate(weekEndDate));
    
    return value;
}]]></Script>
  </Form>
</FDL>
