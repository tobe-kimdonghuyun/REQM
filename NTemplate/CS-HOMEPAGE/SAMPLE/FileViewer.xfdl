<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <TypeDefinition url="..\default_typedef.xml"/>
  <Form id="FileViewer" classname="FileViewer" left="0" top="0" width="1027" height="767" onload="FileViewer_onload">
    <Layouts>
      <Layout>
        <Static id="Static00" taborder="1" text="X" left="991" top="7" height="32" style="font:bold 20 Gulim;" onclick="Static00_onclick" width="27" visible="false"/>
        <Grid id="Grid00" taborder="2" useinputpanel="false" left="0.88%" top="3" right="50%" height="83" binddataset="ds_File" oncellclick="Grid00_oncellclick" visible="false">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="484"/>
              </Columns>
              <Rows>
                <Row size="24" band="head"/>
                <Row size="24"/>
              </Rows>
              <Band id="head">
                <Cell text="FILE_NAME"/>
              </Band>
              <Band id="body">
                <Cell text="bind:FILE_NAME"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <TextArea id="TextArea00" taborder="3" left="10" top="10" right="10" bottom="10"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="ds_File" firefirstcount="0" firenextcount="0" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="FM_SEQ" type="BIGDECIMAL" size="19"/>
          <Column id="FILE_NAME" type="STRING" size="255"/>
          <Column id="SAVE_FILE_NAME" type="STRING" size="255"/>
          <Column id="SAVE_PATH" type="STRING" size="255"/>
          <Column id="SOURCE_CD" type="STRING" size="255"/>
          <Column id="SOURCE_SEQ" type="BIGDECIMAL" size="19"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsRtn">
        <ColumnInfo>
          <Column id="contents" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="TextArea00" propid="value" datasetid="dsRtn" columnid="contents"/>
    </Bind>
