this.get_FlieExt = function(filename)
{
	var fileSplit = filename.split('.');
	var fileExt = '';
	if (fileSplit.length > 1) {
		fileExt = fileSplit[fileSplit.length - 1];
	} 
	return fileExt;
}]]></Script>
