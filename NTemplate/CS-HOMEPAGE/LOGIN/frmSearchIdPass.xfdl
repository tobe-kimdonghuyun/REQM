<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="searchIdPass" width="1300" height="653" onload="searchIdPass_onload" onsize="searchIdPass_onsize" background="white">
    <Layouts>
      <Layout width="1300" height="653">
        <Tab id="tabSearchIdPass" taborder="6" tabindex="0" left="0" top="0" width="1300" cssclass="tab_WF_license" height="653" initvalueid="iv_Tab0" accessibilitylabel="아이디비밀번호찾기 탭">
          <Tabpages>
            <Tabpage id="tabpage1" text="아이디찾기">
              <Layouts>
                <Layout>
                  <Static id="Static00_00_00_00" taborder="0" text="• 회원가입 시 입력하신 ID, 성명, 이메일 주소를 입력하시기 바랍니다.&#13;&#10;• ID, 성명, 이메일 주소가 없는 경우는 1588-7895로 문의하시기 바랍니다.&#13;" left="0" top="40" height="72" cssclass="sta_WF_viewDetail" wordWrap="char" width="1300"/>
                  <Static id="Static00_00_01" taborder="1" text="성명 &lt;fc v='#fb6d3a'&gt;&lt;b v='true'&gt;*&lt;/b&gt;&lt;/fc&gt;" left="0" top="140" height="30" cssclass="sta_WF_writeTitle" wordWrap="char" width="140" usedecorate="true" initvalueid="iv_StaticE"/>
                  <Edit id="edtUserNm" taborder="2" left="0" top="179" width="626" height="50" cssclass="edt_WF_reply" displaynulltext="공백없이 입력해주세요.(예:홍길동)" accessibilitylabel="필수입력 성명" initvalueid="iv_EditE"/>
                  <Static id="Static00_00_01_00" taborder="3" text="이메일 &lt;fc v='#fb6d3a'&gt;&lt;b v='true'&gt;*&lt;/b&gt;&lt;/fc&gt;" left="666" top="140" height="30" cssclass="sta_WF_writeTitle" wordWrap="char" width="140" usedecorate="true" initvalueid="iv_StaticE"/>
                  <Edit id="edtEmail" taborder="4" left="666" top="179" width="626" height="50" cssclass="edt_WF_reply" displaynulltext="회원가입 시 입력한 메일주소를 입력해주세요" accessibilitylabel="필수입력 이메일" initvalueid="iv_EditE"/>
                  <Button id="btnbtnCancel" taborder="5" text="취소" left="496" top="289" width="150" height="65" cssclass="btn_WF_ask" onclick="tabSearchIdPass_tabpage1_btnbtnCancel_onclick"/>
                  <Button id="btnbtnSave" taborder="6" top="289" width="150" height="65" cssclass="btn_WF_list" left="656" onclick="tabSearchIdPass_tabpage1_btnbtnSave_onclick" text="확인"/>
                </Layout>
              </Layouts>
            </Tabpage>
            <Tabpage id="tabpage2" text="비밀번호찾기">
              <Layouts>
                <Layout>
                  <Static id="Static00_00_00_00" taborder="0" text="• 회원가입 시 입력하신 ID, 성명, 이메일 주소를 입력하시기 바랍니다.    &#13;&#10;• ID, 성명, 이메일 주소가 없는 경우는 1588-7895로 문의하시기 바랍니다.&#13;" left="0" top="40" height="72" cssclass="sta_WF_viewDetail" wordWrap="char" width="1300"/>
                  <Static id="Static00_00_01" taborder="1" text="회원ID &lt;fc v='#fb6d3a'&gt;&lt;b v='true'&gt;*&lt;/b&gt;&lt;/fc&gt;" left="0" top="140" height="30" cssclass="sta_WF_writeTitle" wordWrap="char" width="140" usedecorate="true" accessibilitylabel="회원아이디" initvalueid="iv_StaticE"/>
                  <Edit id="edtUserId" taborder="2" left="0" top="179" width="626" height="50" cssclass="edt_WF_reply" displaynulltext="공백없이 입력해주세요.(예:홍길동)" accessibilitylabel="필수입력 회원아이디" initvalueid="iv_EditE"/>
                  <Static id="Static00_00_01_00" taborder="3" text="성명 &lt;fc v='#fb6d3a'&gt;&lt;b v='true'&gt;*&lt;/b&gt;&lt;/fc&gt;" left="666" top="140" height="30" cssclass="sta_WF_writeTitle" wordWrap="char" width="140" usedecorate="true" initvalueid="iv_StaticE"/>
                  <Edit id="edtUserNm" taborder="4" left="666" top="179" width="626" height="50" cssclass="edt_WF_reply" displaynulltext="공백없이 입력해주세요.(예:홍길동)" accessibilitylabel="필수입력 성명" initvalueid="iv_EditE"/>
                  <Static id="Static00_00_01_01" taborder="5" text="이메일 &lt;fc v='#fb6d3a'&gt;&lt;b v='true'&gt;*&lt;/b&gt;&lt;/fc&gt;" left="0" top="254" height="30" cssclass="sta_WF_writeTitle" wordWrap="char" width="140" usedecorate="true" initvalueid="iv_StaticE"/>
                  <Edit id="edtEmailId" taborder="6" left="0" top="293" width="626" height="50" cssclass="edt_WF_reply" displaynulltext="회원가입 시 입력한 메일주소를 입력해주세요" accessibilitylabel="필수입력 이메일" initvalueid="iv_EditE"/>
                  <Static id="Static00_00_01_00_00" taborder="7" text="휴대폰번호 &lt;fc v='#fb6d3a'&gt;&lt;b v='true'&gt;*&lt;/b&gt;&lt;/fc&gt;" left="670" top="254" height="30" cssclass="sta_WF_writeTitle" wordWrap="char" width="140" usedecorate="true" initvalueid="iv_StaticE"/>
                  <Edit id="edtTelHp" taborder="8" top="293" width="626" height="50" cssclass="edt_WF_reply" displaynulltext="회원가입 시 입력한 전화번호를 입력해주세요. 숫자만 입력해주세요.(예:01012345678)" left="670" accessibilitylabel="필수입력 휴대폰번호" initvalueid="iv_EditE"/>
                  <Static id="Static00_00_01_00_00_00" taborder="9" text="임시번호 수신방법 &lt;fc v='#fb6d3a'&gt;&lt;b v='true'&gt;*&lt;/b&gt;&lt;/fc&gt;" left="0" top="368" height="30" cssclass="sta_WF_writeTitle" wordWrap="char" width="190" usedecorate="true" initvalueid="iv_StaticE"/>
                  <Radio id="radReciveType" taborder="10" left="220" top="368" width="240" height="30" innerdataset="ds_TempReciv" codecolumn="code" datacolumn="name" direction="vertical" cssclass="rdo_WF_search" index="0" text="이메일" value="email" accessibilitylabel="필수입력 임시번호 수신방법"/>
                  <Button id="btnbtnCancel" taborder="11" text="취소" left="496" top="458" width="150" height="65" cssclass="btn_WF_ask" onclick="tabSearchIdPass_tabpage1_btnbtnCancel_onclick"/>
                  <Button id="btnbtnSave" taborder="12" text="확인" top="458" width="150" height="65" cssclass="btn_WF_list" left="656" onclick="tabSearchIdPass_tabpage1_btnbtnSave_onclick"/>
                </Layout>
              </Layouts>
            </Tabpage>
          </Tabpages>
        </Tab>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="ds_TempReciv" firefirstcount="0" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="code" type="STRING" size="256"/>
          <Column id="name" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="code">email</Col>
            <Col id="name">이메일</Col>
          </Row>
          <Row>
            <Col id="code">telNum</Col>
            <Col id="name">휴대폰번호</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="ds_ParamId" firefirstcount="0" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="user_nm" type="STRING" size="256"/>
          <Column id="email_id" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="ds_OutParam" firefirstcount="0" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="user_nm" type="STRING" size="256"/>
          <Column id="user_id" type="STRING" size="256"/>
          <Column id="email_id" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="ds_ParamPass" firefirstcount="0" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="user_nm" type="STRING" size="256"/>
          <Column id="email_id" type="STRING" size="256"/>
          <Column id="user_id" type="STRING" size="256"/>
          <Column id="tel_hp" type="STRING" size="256"/>
          <Column id="receive_type" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item29" compid="tabSearchIdPass.tabpage1.form.edtUserNm" propid="value" datasetid="ds_ParamId" columnid="user_nm"/>
      <BindItem id="item30" compid="tabSearchIdPass.tabpage1.form.edtEmail" propid="value" datasetid="ds_ParamId" columnid="email_id"/>
      <BindItem id="item31" compid="tabSearchIdPass.tabpage2.form.edtTelHp" propid="value" datasetid="ds_ParamPass" columnid="tel_hp"/>
      <BindItem id="item32" compid="tabSearchIdPass.tabpage2.form.edtEmailId" propid="value" datasetid="ds_ParamPass" columnid="email_id"/>
      <BindItem id="item33" compid="tabSearchIdPass.tabpage2.form.edtUserNm" propid="value" datasetid="ds_ParamPass" columnid="user_nm"/>
      <BindItem id="item34" compid="tabSearchIdPass.tabpage2.form.edtUserId" propid="value" datasetid="ds_ParamPass" columnid="user_id"/>
      <BindItem id="item35" compid="tabSearchIdPass.tabpage2.form.radReciveType" propid="value" datasetid="ds_ParamPass" columnid="receive_type"/>
    </Bind>
    <Script type="xscript5.1"><![CDATA[/**
*  ID/PASS 찾기
*
*  @MenuPath 
*  @FileName 		LOGIN::frmSearchIdPass.xfdl 
*  @Creator 		김광호
*  @CreateDate 		2022.01.01
*  @LastModifier  
*  @LastModifyDate  
*  @Version 		1.0
*  @Outline 		ID/PASS 찾기
*  @Desction 
************** 소스 수정 이력 *************************************************
*    date          Modifier            Description
*******************************************************************************
*  2022.01.01      김광호	           최초 생성 
*******************************************************************************
*/

this.searchIdPass_onload = function (obj:Form, e:nexacro.LoadEventInfo)
{
	nexacro.getApplication().gv_mainFrame.TargetUrl = "home";
	
	this.ds_ParamPass.setColumn(0, "receive_type", "0");

	this.set_height(653+200);
	this.parent.set_height(653+200);
	nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, 653+300);
	this.tabSearchIdPass.tabpage2.form.radReciveType.set_value("email");
};

this.radval = "";
this.tabSearchIdPass_tabpage1_btnbtnSave_onclick = function (obj:Button, e:nexacro.ClickEventInfo)
{
	var strArgs = "";
	var strDsInput = "";
	var strServ = "";
	var userID;
	var userEmail;

	// User Id 찾기인 경우
	if (this.tabSearchIdPass.tabindex == 0) 
	{
		// 이름 체크
		userID = this.tabSearchIdPass.tabpage1.form.edtUserNm.value;
		if (nexacro.getApplication().com_IsEmpty(userID)) 
		{
			// 이름을 입력해 주세요 : MSG_000005
			nexacro.getApplication().com_SetMessage("MSG_000005", false);
			return;
		}

		// Email 체크
		userEmail = this.tabSearchIdPass.tabpage1.form.edtEmail.value;
		if (nexacro.getApplication().com_IsEmpty(userEmail)) 
		{
			// 이메일주소를 입력해 주세요 : MSG_000010
			nexacro.getApplication().com_SetMessage("MSG_000010", false);
			return;
		}

		strArgs = "RTYPE=XML DB='CS' SEARCHTYPE=SearchId DBUSER='POTAL_USER' lang='" + nexacro.getApplication().gv_NationCd + "'";
		strDsInput = "input=ds_ParamId";
		strServ = "SearchId";
	}
	else 
	{
		// ID 체크
		if (nexacro.getApplication().com_IsEmpty(this.tabSearchIdPass.tabpage2.form.edtUserId.value)) 
		{
			// 아이디를 입력해 주십시요 : MSG_000016
			nexacro.getApplication().com_SetMessage("MSG_000016", false);
			return;
		}
		// 이름 체크
		if (nexacro.getApplication().com_IsEmpty(this.tabSearchIdPass.tabpage2.form.edtUserNm.value)) 
		{
			// 이름을 입력해 주세요 : MSG_000005
			nexacro.getApplication().com_SetMessage("MSG_000005", false);
			return;
		}

		this.radval = this.tabSearchIdPass.tabpage2.form.radReciveType.value;
		// 수신 방법이 이메일인 경우
		if (this.radval == "email") 
		{
			// 이메일 체크
			if (nexacro.getApplication().com_IsEmpty(this.tabSearchIdPass.tabpage2.form.edtEmailId.value)) 
			{
				// 이메일주소를 입력해 주세요 : MSG_000010
				nexacro.getApplication().com_SetMessage("MSG_000010", false);
				return;
			}
			// 수신 방법이 휴대폰인 경우
		}
		else 
		{
			// 휴대폰번호 체크
			if (nexacro.getApplication().com_IsEmpty(this.tabSearchIdPass.tabpage2.form.edtTelHp.value)) 
			{
				// 핸드폰번호를 입력해 주세요 : MSG_000039
				nexacro.getApplication().com_SetMessage("MSG_000039", false);
				return;
			}
		}

		strArgs = "RTYPE=XML DB='CS' SEARCHTYPE=SearchPass DBUSER='POTAL_USER' lang='" + nexacro.getApplication().gv_NationCd + "'";
		strDsInput = "input=ds_ParamPass";
		strServ = "SearchPass";
	}
	var strUrl = "SVC_JSP::Next_JSP/Login/SearchIdPass_new.jsp";
	var strDsOutput = "ds_OutParam=output";

	this.com_TransSend(strServ, strUrl, strDsInput, strDsOutput, strArgs, "fn_SearchId_CallBack");
};

this.fn_SearchId_CallBack = function (svcid, errCode, errMsg)
{
	if (svcid == "SearchId") 
	{
		// 데이터가 있는 경우
		if (this.ds_OutParam.rowcount > 0) 
		{
			var user_id = this.ds_OutParam.getColumn(0, "user_id");
			var repMsgArr = new Array(user_id);
			// 고객님의 ID는 XX입니다. : MSG_000040
			nexacro.getApplication().com_SetMessage("MSG_000040", true, repMsgArr);
		}
		else 
		{
			// 등록된 정보가 없습니다. : MSG_000038
			nexacro.getApplication().com_SetMessage("MSG_000038", false);
		}
	}
	else if (svcid == "SearchPass") 
	{
		// 데이터가 있는 경우
		if (this.ds_OutParam.rowcount > 0) 
		{
			// 수신 방법이 이메일인 경우
			if (this.tabSearchIdPass.tabpage2.form.radReciveType.value == "email") 
			{
				// 조회된 정보는 이메일을 통해 전달되었습니다.... : MSG_000034
				nexacro.getApplication().com_SetMessage("MSG_000034", false);
			}
			else 
			{
				// 조회된 정보는 핸드폰을 통해 전달되었습니다.... : MSG_000037
				nexacro.getApplication().com_SetMessage("MSG_000037", false);
			}
			nexacro.getApplication().gv_mainFrame.param = {
				'menu': "login",
				'keyword': "",
				'page': 1,
				'postId': ""
			};
			nexacro.getApplication().gv_mainFrame.gfnGoMain();
		}
		else 
		{
			// 등록된 정보가 없습니다. : MSG_000038
			nexacro.getApplication().com_SetMessage("MSG_000038", false);
		}
	}
};

// 취소 클릭시
this.tabSearchIdPass_tabpage1_btnbtnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	nexacro.getApplication().gv_mainFrame.param = {
		'menu': "login",
		'keyword': "",
		'page': 1,
		'postId': ""
		};
	nexacro.getApplication().gv_mainFrame.gfnGoMain();
};

]]></Script>
  </Form>
</FDL>
