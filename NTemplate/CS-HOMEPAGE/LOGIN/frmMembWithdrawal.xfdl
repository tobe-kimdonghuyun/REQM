<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="membInfoWrite" width="1300" height="1100" onload="membInfoWrite_onload" background="#f8f8f8">
    <Layouts>
      <Layout width="1300" height="1100">
        <Static id="Static00_00_00" taborder="0" left="10" top="10" cssclass="sta_WF_writeBg" right="10" wordWrap="char" height="720" onclick="divResult_Static00_00_00_onclick" text="" accessibilityenable="false"/>
        <Static id="Static00_00_01" taborder="1" text="탈퇴사유 &lt;fc v='#fb6d3a'&gt;&lt;b v='true'&gt;*&lt;/b&gt;&lt;/fc&gt;" left="90" top="70" height="30" cssclass="sta_WF_writeTitle" wordWrap="char" width="140" usedecorate="true" initvalueid="iv_StaticE"/>
        <Combo id="cmbReason" taborder="2" left="90" top="109" height="50" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" index="0" value="0" cssclass="cmb_WF_product" itemheight="40" right="90" onitemchanged="cmbReason_onitemchanged" accessibilitylabel="필수입력 탈퇴사유" initvalueid="iv_ComboE">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row>
                <Col id="codecolumn">0</Col>
                <Col id="datacolumn">탈퇴사유를 선택해 주세요.</Col>
              </Row>
              <Row>
                <Col id="codecolumn">1</Col>
                <Col id="datacolumn">제품종료 검토</Col>
              </Row>
              <Row>
                <Col id="codecolumn">2</Col>
                <Col id="datacolumn">투입된 프로젝트 종료</Col>
              </Row>
              <Row>
                <Col id="codecolumn">3</Col>
                <Col id="datacolumn">원하는 정보부족</Col>
              </Row>
              <Row>
                <Col id="codecolumn">4</Col>
                <Col id="datacolumn">사이트 이용 안함</Col>
              </Row>
              <Row>
                <Col id="codecolumn">5</Col>
                <Col id="datacolumn">기타</Col>
              </Row>
            </Rows>
          </Dataset>
        </Combo>
        <TextArea id="txtReason" taborder="3" left="90" top="169" width="1120" height="337" cssclass="txt_WF_apply" enable="false" accessibilitylabel="탈퇴사유"/>
        <Static id="Static00_00_00_00" taborder="4" text="• 사용하고 계신 &lt;fc v='#fb6d3a'&gt;&lt;b v='true'&gt;아이디는 탈퇴할 경우 재가입이 불가능합니다.&lt;/b&gt;&lt;/fc&gt;&#13;&#10;• 아이디는 &lt;fc v='#fb6d3a'&gt;&lt;b v='true'&gt;재가입방지를 위해 영구보관&lt;/b&gt;&lt;/fc&gt;됩니다.&#13;&#10;• 등록한 글은 탈퇴 시 자동삭제되지 않고 그대로 남아 있습니다.&#13;&#10;• 삭제를 원하는 게시글이 있다면 &lt;fc v='#fb6d3a'&gt;&lt;b v='true'&gt;반드시 탈퇴 전 삭제하시기 바랍니다.&lt;/b&gt;&lt;/fc&gt;&#13;&#10;  (요청에 의한 등록글 삭제는 불가합니다.)" left="90" top="530" height="162" cssclass="sta_WF_viewDetail" wordWrap="char" width="1120" usedecorate="true"/>
        <View id="View02_00" taborder="5" text="View02" viewdataset="viewdataset" left="0" top="770" width="1300" height="65" accessibilityenable="false">
          <Layouts>
            <Layout>
              <Button id="btnbtnCancel" left="496" top="0" width="150" height="65" text="취소" cssclass="btn_WF_ask" onclick="View02_00_btnbtnCancel_onclick" taborder="0"/>
              <Button id="btnbtnSave" left="656" top="0" width="150" height="65" text="확인" cssclass="btn_WF_list" onclick="View02_00_btnbtnSave_onclick" taborder="1"/>
            </Layout>
          </Layouts>
          <ModelInfo modelserviceid="MODEL" serviceid="" modelid="button" filepath="COMMON.xmodel">
            <Fields>
              <Field id="btnCancel" description=""/>
              <Field id="btnSave" label="확인" description=""/>
            </Fields>
            <Components>
              <Component id="btnbtnCancel" fields="btnCancel"/>
              <Component id="btnbtnSave" fields="btnSave"/>
            </Components>
          </ModelInfo>
          <ViewTemplateInfo filepath="CommonButtonViewTemplate.xviewgen">
            <Attribute id="direction" value="horizontal"/>
            <Attribute id="halign" value="center"/>
            <Attribute id="valign" value="top"/>
          </ViewTemplateInfo>
        </View>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="ds_InParam" firefirstcount="0" useclientlayout="true" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="User_id" type="STRING" size="256"/>
          <Column id="Passwd" type="STRING" size="256"/>
          <Column id="PassCirm" type="STRING" size="256"/>
          <Column id="User_nm" type="STRING" size="256"/>
          <Column id="Email_id" type="STRING" size="256"/>
          <Column id="Comp_nm" type="STRING" size="256"/>
          <Column id="Comp_dept" type="STRING" size="256"/>
          <Column id="Comp_position" type="STRING" size="256"/>
          <Column id="Tel_office" type="STRING" size="256"/>
          <Column id="Tel_hp" type="STRING" size="256"/>
          <Column id="User_status" type="STRING" size="256"/>
          <Column id="Dept_cd" type="STRING" size="256"/>
          <Column id="CONSULTING_FLAG" type="STRING" size="256"/>
          <Column id="MARKETING_FLAG" type="STRING" size="256"/>
          <Column id="REPLY_METHOD" type="STRING" size="256"/>
          <Column id="WITHDRAWAL_REASON" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="ds_OutParam" firefirstcount="0" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="recordCount" type="INT" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="ds_Withdrawal">
        <ColumnInfo>
          <Column id="CD" type="STRING" size="256"/>
          <Column id="VAL" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item1" compid="cmbReason" propid="value" datasetid="ds_InParam" columnid="WITHDRAWAL_REASON"/>
    </Bind>
    <Script type="xscript5.1"><![CDATA[/**
*  회원탈퇴
*
*  @MenuPath 
*  @FileName 		LOGIN::frmMembWithdrawal.xfdl 
*  @Creator 		김광호
*  @CreateDate 		2022.01.01
*  @LastModifier  
*  @LastModifyDate  
*  @Version 		1.0
*  @Outline 		회원탈퇴
*  @Desction 
************** 소스 수정 이력 *************************************************
*    date          Modifier            Description
*******************************************************************************
*  2022.01.01      김광호	           최초 생성 
*******************************************************************************
*/

this.idChkFlg = false;
this.MemberStatus = "Write";

this.membInfoWrite_onload = function (obj:Form, e:nexacro.LoadEventInfo)
{
	// ds_InParam에 기본데이터 셋팅
	this.ds_InParam.setColumn(0, "User_id", nexacro.getApplication().gds_UserInfo.getColumn(0, "User_id"));
	this.ds_InParam.setColumn(0, "User_nm", nexacro.getApplication().gds_UserInfo.getColumn(0, "User_nm"));
	this.ds_InParam.setColumn(0, "Email_id", nexacro.getApplication().gds_UserInfo.getColumn(0, "Email_id"));
	this.ds_InParam.setColumn(0, "Comp_nm", nexacro.getApplication().gds_UserInfo.getColumn(0, "Comp_nm"));
	this.ds_InParam.setColumn(0, "Comp_dept", nexacro.getApplication().gds_UserInfo.getColumn(0, "Comp_dept"));
	this.ds_InParam.setColumn(0, "Comp_position", nexacro.getApplication().gds_UserInfo.getColumn(0, "Comp_position"));
	this.ds_InParam.setColumn(0, "Tel_hp", nexacro.getApplication().gds_UserInfo.getColumn(0, "Tel_hp"));
	this.ds_InParam.setColumn(0, "Tel_office", nexacro.getApplication().gds_UserInfo.getColumn(0, "Tel_office"));
	this.ds_InParam.setColumn(0, "CONSULTING_FLAG", nexacro.getApplication().gds_UserInfo.getColumn(0, "CONSULTING_FLAG"));
	this.ds_InParam.setColumn(0, "MARKETING_FLAG", nexacro.getApplication().gds_UserInfo.getColumn(0, "MARKETING_FLAG"));
	this.ds_InParam.setColumn(0, "REPLY_METHOD", nexacro.getApplication().gds_UserInfo.getColumn(0, "REPLY_METHOD"));

	//탈퇴사유 값 설정
	this.cmbReason.set_value(0);
	
	nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, 970+100);
};

this.fn_MemberInfo_CallBack = function (svcid, errCode, errMsg)
{
	if (svcid == "MemberLeave") 
	{
		// 탈퇴 되었습니다.
		nexacro.getApplication().com_SetMessage("MSG_000028", false);

		nexacro.setPrivateProfile("cstop_nexacro_seq", "");
		nexacro.setPrivateProfile("cstop_nexacro_user_id", "");
		nexacro.setPrivateProfile("cstop_nexacro_user_nm", "");
		nexacro.setPrivateProfile("cstop_nexacro_email_id", "");
		nexacro.setPrivateProfile("cstop_nexacro_dept_cd", "");
		nexacro.setPrivateProfile("cstop_nexacro_gubun", "");
		nexacro.setPrivateProfile("cstop_nexacro_tel_hp", "");
		nexacro.setPrivateProfile("cstop_nexacro_user_status", "");

		nexacro.getApplication().gds_UserInfo.clearData();
		nexacro.getApplication().gv_mainFrame.divTop.form.btnLogin.set_visible(true);
		nexacro.getApplication().gv_mainFrame.divTop.form.btnLogout.set_visible(false);
		nexacro.getApplication().gv_mainFrame.divTop.form.btnSignin.set_visible(true);
		nexacro.getApplication().gv_mainFrame.divTop.form.btnMypage.set_visible(false);
		nexacro.getApplication().gv_mainFrame.divTop.form.staMypage.set_visible(false);
		
		// 초기화면
		nexacro.getApplication().gv_mainFrame.param = {
			'menu': "home",
			'keyword': "",
			'page': 1,
			'postId': ""
			};
		nexacro.getApplication().gv_mainFrame.gfnGoMain();
	}
};

// 확인 버튼
this.View02_00_btnbtnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var nReason = this.cmbReason.value;
	if(nReason <= 0)
	{
		//탈퇴사유를 선택해 주세요.
		nexacro.getApplication().com_SetMessage("MSG_000116", false);
		return false;
	}
	if(nexacro.getApplication().com_ConfirmMessage("MSG_000111", false)) 
	{
		var	strServ     = "MemberLeave";
		var strUrl      = "SVC_JSP::Next_JSP/Login/MemberLeave_new.jsp";
		var	strDsInput  = "input=ds_InParam";  
		var strDsOutput = "ds_InParam=output1";   
		var	strArgs     = "RTYPE=XML DB='CS' REGISTTYPE=Search DBUSER='POTAL_USER'";
		
		if( this.ds_InParam.getColumn(0, "WITHDRAWAL_REASON") == 5 )
			this.ds_InParam.setColumn(0, "WITHDRAWAL_REASON", this.txtReason.value)
		    
		this.com_TransSend(strServ,strUrl,strDsInput,strDsOutput,strArgs,"fn_MemberInfo_CallBack");	
	}
};

// 취소버튼
this.View02_00_btnbtnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	nexacro.getApplication().gv_mainFrame.param = {
		'menu': "home",
		'keyword': "",
		'page': 1,
		'postId': ""
		};
	nexacro.getApplication().gv_mainFrame.gfnGoMain();
};

// 탈퇴사유 콤보 이벤트
this.cmbReason_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.txtReason.set_accessibilityaction("");
	this.txtReason.set_accessibilitydescription("");	
	
	if( e.postindex == 0 ){
		this.txtReason.set_enable(false);
		//this.txtReason.set_initvalueid("iv_TextArea0");		
	} else if( e.postindex == 1 ) {
		this.txtReason.set_enable(false);
		//this.txtReason.set_initvalueid("iv_TextArea0");		
	} else if( e.postindex == 2 ) {
		this.txtReason.set_enable(false);
		//this.txtReason.set_initvalueid("iv_TextArea0");		
	} else if( e.postindex == 3 ) {
		this.txtReason.set_enable(false);
		//this.txtReason.set_initvalueid("iv_TextArea0");		
	} else {
		this.txtReason.set_enable(true);
		//TextArea 가 화면에 표시된 후에는 속성값을 설정하거나 변경 할 수 없음.
		//this.txtReason.set_initvalueid("iv_TextAreaE");
		this.txtReason.set_accessibilityaction("입력하려면 엔터 키를 누릅니다. 텍스트 입력 완료 후 ESC 키를 누른 후 다음으로 이동합니다.");
		this.txtReason.set_accessibilitydescription("필수입력");
		//this.txtReason.setFocus();
	}	
};
]]></Script>
  </Form>
</FDL>
