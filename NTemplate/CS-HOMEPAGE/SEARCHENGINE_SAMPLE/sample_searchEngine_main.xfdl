        <Static id="Static02" taborder="11" text="''에 대한 개 검색결과입니다." left="419" top="193" width="440" height="37" textAlign="center"/>
        <Div id="div_autoCompleteResult" taborder="12" left="1293" top="5" width="367" height="327" border="1px solid #00bca8" background="white" visible="false"/>
        <Grid id="Grid00" taborder="13" left="1300" top="359" width="355" height="541" binddataset="ds_bbsResult">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="156"/>
                <Column size="115"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="24" band="head"/>
                <Row size="24"/>
              </Rows>
              <Band id="head">
                <Cell text="COLLECTION_CODE"/>
                <Cell col="1" text="COLLECTION_NAME"/>
                <Cell col="2" text="CNT"/>
              </Band>
              <Band id="body">
                <Cell text="bind:COLLECTION_CODE"/>
                <Cell col="1" text="bind:COLLECTION_NAME"/>
                <Cell col="2" text="bind:CNT"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
      </Layout>
