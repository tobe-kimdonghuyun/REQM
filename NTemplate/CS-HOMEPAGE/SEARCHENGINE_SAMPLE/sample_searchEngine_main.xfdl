    <Script type="xscript5.1"><![CDATA[//this.collection = "ALL";
this.collection = "mng_nexacroN,mng_nexacro17,mng_nexacro14,mng_xplatform,mng_miplatform,bbs_tip,bbs_edu_notice,bbs_edu_resource,bbs_notice";
var objEnv = nexacro.getEnvironment();
this.Search_query = ""; 
this.Search_oquery = ""; 
//this.url = nexacro.getEnvironmentVariable("gv_SearchEngine");
//this.url = nexacro.getApplication().gv_SearchEngine;
this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fn_search();
};

this.fn_search = function()
{
	this.showAutoCompleteResult(false);
	
	// 검색
	//var strUrl = "url=" + this.url + ":10005/tobe_list&zip=false";
	//var strUrl = "url=http://172.10.10.71:10005/tobe_list&zip=false";
	var strUrl = "url=" + nexacro.getEnvironmentVariable("gv_SearchEngine") + ":10005/tobe_list&zip=false";
	////trace("strUrl : " + strUrl);
	////trace("this.Search_oquery:"+this.Search_oquery);
	var strkeyword = this.Edit00.value;

	if( this.com_IsEmpty(strkeyword) ) strkeyword = "";
	
	var arg = 	"query='" + strkeyword + "'" ; //검색어	
		arg +=	" collection=" + this.collection; //ALL, bbs_notice, mng_nexacro14, mng_nexacro14, mng_xplatform, mng_nexacroN 등등 - 게시판 단일, n개, 전체
		arg +=	" oquery=" + this.Search_oquery; //이전 검색어 - 연관 검색어 관련 필요!
		arg +=	" startDate=" + this.Cal_Start.text; // 시작 날짜 - 2021-01-01 
		arg +=	" endDate=" + this.Cal_End.text; // 끝 날짜 - 2022-08-01 
		arg +=	" operator=" + this.Rdo_operator.value; //and, or 택1 조회조건2 연산자 - and = true, or = false 				
		arg +=	" field=" + this.Rdo_field.value; // 제목+내용, 제목, 번호 택1 조회조건 - 제목+내용 = all, 제목 = title, 번호 = num				
		arg +=	" listSize=20"; // 페이지 목록 개수 - 화면에 표출되는 해당 페이지에 나올 목록 개수
		arg +=	" pageNum=1"; // 페이지 - 1, 2 화면에 표출되는 해당 페이지 번호
//trace(arg);
	var strDsOutput = "ds_bbsResult=ds_bbsResult ";
	strDsOutput += "ds_bbs_edu_resource=bbs_edu_resource ds_bbs_notice=bbs_notice ds_bbs_tip=bbs_tip ds_bbs_edu_notice=bbs_edu_notice ";
	strDsOutput += "ds_mng_miplatform=mng_miplatform ds_mng_xplatform=mng_xplatform ds_mng_nexacro14=mng_nexacro14 ds_mng_nexacro17=mng_nexacro17 ds_mng_nexacroN=mng_nexacroN ";
	strDsOutput += "ds_condition=ds_condition";

 	this.transaction("select",nexacro.getEnvironment().services["SVC_JSP"].url + "Next_JSP/SearchEngine/Service/url.jsp?" + strUrl, "", strDsOutput, arg, "callbackSearchComplete");
}

this.callbackSearchComplete = function(id, code, msg)
{
	if( id == "select" ){
		this.Search_oquery = this.Search_query;
		var totalCnt = this.ds_bbsResult.getCaseSum("COLLECTION_CODE=='mng_nexacroN'||COLLECTION_CODE=='mng_nexacro17'||COLLECTION_CODE=='mng_nexacro14'||COLLECTION_CODE=='mng_xplatform'||COLLECTION_CODE=='mng_miplatform'||COLLECTION_CODE=='bbs_tip'||COLLECTION_CODE=='bbs_edu_notice'||COLLECTION_CODE=='bbs_edu_resource'||COLLECTION_CODE=='bbs_notice'","CNT");
		this.Static02.set_text("'" + this.Edit00.value +"'에 대한" + totalCnt  +  "개 검색결과입니다.");
		
		this.Tab00.Tabpage1.set_text("NexacroN("+ this.ds_bbsResult.lookup("COLLECTION_CODE","mng_nexacroN","CNT") +")");
		this.Tab00.Tabpage2.set_text("Nexacro17("+ this.ds_bbsResult.lookup("COLLECTION_CODE","mng_nexacro17","CNT") +")");
		this.Tab00.Tabpage3.set_text("Nexacro14("+ this.ds_bbsResult.lookup("COLLECTION_CODE","mng_nexacro14","CNT") +")");
		this.Tab00.Tabpage4.set_text("Xplatform("+ this.ds_bbsResult.lookup("COLLECTION_CODE","mng_xplatform","CNT") +")");
		this.Tab00.Tabpage5.set_text("Miplatform("+ this.ds_bbsResult.lookup("COLLECTION_CODE","mng_miplatform","CNT") +")");
		this.Tab00.Tabpage6.set_text("Tip("+ this.ds_bbsResult.lookup("COLLECTION_CODE","bbs_tip","CNT") +")");
		this.Tab00.Tabpage7.set_text("교육공지("+ this.ds_bbsResult.lookup("COLLECTION_CODE","bbs_edu_notice","CNT") +")");
		this.Tab00.Tabpage8.set_text("교육자료("+ this.ds_bbsResult.lookup("COLLECTION_CODE","bbs_edu_resource","CNT") +")");
		this.Tab00.Tabpage9.set_text("공지사항("+ this.ds_bbsResult.lookup("COLLECTION_CODE","bbs_notice","CNT") +")");
	}
}

this.Grid_onmousemove = function(obj:nexacro.Grid,e:nexacro.GridMouseEventInfo)
{	
	obj.set_tooltiptext(obj.getCellValue(e.row, e.cell));
};


this.Edit00_onkeyup = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if( e.keycode == 13 ){
		this.fn_search();
	}
	this.fn_SearchKey_onkeyup(obj, e);
};

this.fn_SearchKey_onkeyup = function(obj, e)
{
	if(e.keycode == 40)
	{	
		var cnt = this.ds_autoResult.rowcount;
		if ( cnt > 0 )
		{
				if(this.Search_keywordIdx == (cnt-1)){
					this.showAutoCompleteResult(false);
					this.Search_keywordIdx =-1;
					return; 
				} else {
					this.showAutoCompleteResult(true);
				}
				this.Search_keywordIdx++;
				this.searchEdt.set_value(eval("this.div_autoCompleteResult.Static_" + this.Search_keywordIdx).text);
				this.setDeSelectItem();//기존 select를 초기화 한다. 
				eval("this.div_autoCompleteResult.Static_" + this.Search_keywordIdx).setCurrentPseudo("mouseover");	
				this.div_autoCompleteResult.form.resetScroll();
		}
		return;
	} else if(e.keycode == 38)  {  
	
		var cnt = this.ds_autoResult.rowcount;
		if ( cnt > 0 )
		{
				if(this.Search_keywordIdx <= 0){
					this.showAutoCompleteResult(false);
					this.Search_keywordIdx =-1;
					return;
				} else {
					this.showAutoCompleteResult(true);
				}
				this.Search_keywordIdx--;
				this.searchEdt.set_value(eval("this.div_autoCompleteResult.Static_" + this.Search_keywordIdx).text);

				this.setDeSelectItem();//기존 select를 초기화 한다. 
				eval("this.div_autoCompleteResult.Static_" + this.Search_keywordIdx).setCurrentPseudo("mouseover");	
				this.div_autoCompleteResult.form.resetScroll();
		}
		return;
	} else if(e.keycode == 13)  {	  	
         return;
			this.fn_openSearchScreen("SearchEngine", "Search");
			//this.Search_query = obj.text;
			this.Search_query = this.ds_autoResult.lookup( "hkeyword", obj.text, "keyword" );
			this.Search_keywordIdx =-1;
			this.Search_keyEnter=true;
			
			this.setTimer(1,500);
	
	  	 this.showAutoCompleteResult(false);
	} else {  	
		
		this.Search_query = obj.text;		
		//this.Search_query = this.ds_autoResult.lookup( "hkeyword", obj.text, "keyword" );
		this.Search_keywordIdx =-1;
		this.Search_keyEnter=false;		
		objEnv.set_usewaitcursor(false);		
		////trace("before fn_callData >> " + this.Search_query);
		this.fn_callData();
	}
}

this.fn_callData = function()
{
	//var strUrl = "url=http://172.10.10.71:10005/tobe_autoList&zip=false";
	//var strUrl = "nexacro/tobe_autoList&zip=false";
	//var strUrl = "url=http://172.10.10.71:10005/tobe_autoList&zip=false";
	var strUrl = "url=" + nexacro.getEnvironmentVariable("gv_SearchEngine") + "/tobe_autoList&zip=false";
	////trace("fn_callData >> " + this.Search_query);
	var arg = "query='" + this.Search_query +"' ";
	
	this.showAutoCompleteResult(false);
	this.ds_autoComplete.clearData();      
	this.ds_autoResult.clearData();    
	
	
	this.transaction("select", nexacro.getEnvironment().services["SVC_JSP"].url + "Next_JSP/SearchEngine/Service/url.jsp?" + strUrl,"","ds_autoComplete=ds_auto",arg,"callbackAutoComplete"); 
}

this.callbackAutoComplete = function(id, code, msg)
{
	objEnv.set_usewaitcursor(true);	
	this.Search_keywordIdx = -1;
	if (code >= 0) {
 		var ds = this.ds_autoComplete;  		
 		var strRecvData = ds.getColumn(0, "rtn");
		////trace(strRecvData);
 		if ( String(strRecvData).length > 0 )
 		{
			strRecvData = String(strRecvData).trim();
			strRecvData = strRecvData.replace(/&quot;/g, '"');
			var revcJsonObj = JSON.parse(strRecvData);
			var count = revcJsonObj.result.length;
			var datas = [];
				
			var resultDs = this.ds_autoResult;
			resultDs.clearData();
			var nRow;
			for (var i = 0 ; i < count; i++)
			{
				var eachResult = revcJsonObj.result[i];				
				var inCount = eachResult.totalcount;
				var jObj;
				var txt;
				for (var j = 0 ; j < inCount ; j++) 
				{
					jObj = eachResult.items[j];

					nRow = resultDs.addRow();
					txt = jObj.hkeyword;
					////trace(txt);
					//txt = nexacro.replaceAll(txt,"&lt;font style=&apos;color:#ff0000&apos;&gt;","<fc v='#ff0000'>");
					//txt = nexacro.replaceAll(txt,"&lt;/font&gt;","</fc>");
					//txt = nexacro.replaceAll(txt,"&lt;/font&gt;","</fs>");	
					resultDs.setColumn(nRow, "hkeyword", txt);
					resultDs.setColumn(nRow, "keyword", jObj.keyword);
					datas.push({   
						'KEYWORD': [jObj.hkeyword, jObj.keyword]
					});
				}  
				////trace(resultDs.saveXML());
			}             
			resultDs.set_rowposition(0);
			var div = this.div_autoCompleteResult;
			if ( datas.length == 0 )
			{
				//this.showAutoCompleteResult(false);
				var msg = "해당 단어로 시작하는 검색어가 없습니다.";
				var height = 30;
			}
			else
			{
			}
			if(this.Search_keyEnter == false)
			{
				this.showAutoCompleteResult(true);
			} else {
				this.showAutoCompleteResult(false);
			}	   
 		}
 		else 		
 		{
			this.showAutoCompleteResult(false);
 		}
 		
	} else if  (code < 0) {
		this.showAutoCompleteResult(false);
		//키워드가 없을 경우에는 code에 -4와 msg는 "Parameter is invalid"가 전달됨.
	}
}


this.showAutoCompleteResult = function(show)
{
	var div = this.div_autoCompleteResult;
	if ( show )
	{
		if(this.ds_autoResult.getRowCount() > 0)
		{
			div.set_visible(true);
			div.bringToFront();
			var rtn =  this.removeChild("div_autoCompleteResult");  
			// Destroy Object  
			rtn.destroy(); 
			rtn = null;
    
		  
			this.objDiv = new Div();         
			this.objDiv.init("div_autoCompleteResult",  55, 80, 318, 463, null, null);
			this.addChild("div_autoCompleteResult", this.objDiv);
			this.objDiv.set_border("1px solid #00bca8ff");   
			this.objDiv.set_background("white");  

			this.objDiv.show();
	//		this.div_autoCompleteResult.bringToFront();
			var iDivHeight=10;
			for(var i = 0; i < this.ds_autoResult.getRowCount() ;i++)
			{			   
				iDivHeight+=20;
				this.objStatic = new Static();
				if(i == 0)
				{
					this.objStatic.init("Static_" + i,  2, 0, 300, 20, null, null);
				} else {
					this.objStatic.init("Static_" + i,  2, (i * 20), 300, 20, null, null);
				}	
				this.objStatic.set_usedecorate(true);
				this.div_autoCompleteResult.addChild("Static_" + i, this.objStatic); 		 			
				this.objStatic.show();
   
				this.objStatic.set_text(this.ds_autoResult.getColumn(i,"hkeyword"));			
				this.objStatic.keyword = this.ds_autoResult.getColumn(i,"keyword");
				var rtn = this.objStatic.addEventHandler("onclick", this.div_autoCompleteResult_Static_onclick, this);

			}  
			this.div_autoCompleteResult.set_height(iDivHeight);
			this.div_autoCompleteResult.form.resetScroll();			
		}	
	}
	else
	{   
		div.set_visible(false);
	}
}  

this.div_autoCompleteResult_Static_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	//trace("click :: " + obj.keyword);	
	this.Edit00.set_value(obj.keyword);
	this.showAutoCompleteResult(false);
	this.fn_search();
}

this.com_IsEmpty = function (inVal)
{	
	if (new String(inVal).valueOf() == "undefined") return true;
    if (inVal == null) return true;
    
    var v_ChkStr = new String(inVal);		
    if (v_ChkStr == null) return true;
    if (v_ChkStr.toString().length == 0 ) return true;
    return false;
} 


this.sample_searcEngine_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	//alert("1111");
	nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, 1500);
};
