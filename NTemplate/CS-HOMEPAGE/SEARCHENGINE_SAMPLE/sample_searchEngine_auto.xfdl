<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sample_searchEngine_자동완성" width="1280" height="720" titletext="New Form">
    <Layouts>
      <Layout height="720" mobileorientation="landscape" width="1280">
        <Edit id="searchEdt" taborder="0" left="26" top="20" width="369" height="42" oneditclick="searchEdt_oneditclick" onkeyup="searchEdt_onkeyup" onkillfocus="searchEdt_onkillfocus" border="3px solid #1fb5ad" borderRadius="20px 20px" onchanged="searchEdt_onchanged"/>
        <Div id="div_autoCompleteResult" taborder="1" left="26" top="64" width="367" height="327" border="1px solid #00bca8" background="white" visible="false"/>
        <Grid id="Grid00" taborder="2" left="590" top="20" width="350" height="370" binddataset="ds_autoResult" autofittype="col">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="327"/>
                <Column size="200"/>
              </Columns>
              <Rows>
                <Row size="24" band="head"/>
                <Row size="24"/>
              </Rows>
              <Band id="head">
                <Cell text="hkeyword"/>
                <Cell col="1" text="keyword"/>
              </Band>
              <Band id="body">
                <Cell text="bind:hkeyword" displaytype="decoratetext"/>
                <Cell col="1" text="bind:keyword"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="Button00" taborder="3" text="Button00" left="408" top="21" width="84" height="39" onclick="Button00_onclick"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[var objEnv = nexacro.getEnvironment();
this.Search_query = ""; 
//this.url = nexacro.getEnvironmentVariable("gv_SearchEngine");
this.searchEdt_onkeyup = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	this.fn_SearchKey_onkeyup(obj, e);
};

this.searchEdt_onkillfocus = function(obj:nexacro.Edit,e:nexacro.KillFocusEventInfo)
{
	//this.fn_SearchKey_onkillfocus(obj, e);
};

this.fn_SearchKey_onkeyup = function(obj, e)
{
	if(e.keycode == 40)
	{	
		var cnt = this.ds_autoResult.rowcount;
		if ( cnt > 0 )
		{
				if(this.Search_keywordIdx == (cnt-1)){
					this.showAutoCompleteResult(false);
					this.Search_keywordIdx =-1;
					return; 
				} else {
					this.showAutoCompleteResult(true);
				}
				this.Search_keywordIdx++;
				this.searchEdt.set_value(eval("this.div_autoCompleteResult.Static_" + this.Search_keywordIdx).text);
				this.setDeSelectItem();//기존 select를 초기화 한다. 
				eval("this.div_autoCompleteResult.Static_" + this.Search_keywordIdx).setCurrentPseudo("mouseover");	
				this.div_autoCompleteResult.form.resetScroll();
		}
		return;
	} else if(e.keycode == 38)  {  
	
		var cnt = this.ds_autoResult.rowcount;
		if ( cnt > 0 )
		{
				if(this.Search_keywordIdx <= 0){
					this.showAutoCompleteResult(false);
					this.Search_keywordIdx =-1;
					return;
				} else {
					this.showAutoCompleteResult(true);
				}
				this.Search_keywordIdx--;
				this.searchEdt.set_value(eval("this.div_autoCompleteResult.Static_" + this.Search_keywordIdx).text);

				this.setDeSelectItem();//기존 select를 초기화 한다. 
				eval("this.div_autoCompleteResult.Static_" + this.Search_keywordIdx).setCurrentPseudo("mouseover");	
				this.div_autoCompleteResult.form.resetScroll();
		}
		return;
	} else if(e.keycode == 13)  {	  	
         return;
			this.fn_openSearchScreen("SearchEngine", "Search");
			//this.Search_query = obj.text;
			this.Search_query = this.ds_autoResult.lookup( "hkeyword", obj.text, "keyword" );
			this.Search_keywordIdx =-1;
			this.Search_keyEnter=true;
			
			this.setTimer(1,500);
	
	  	 this.showAutoCompleteResult(false);
	} else {  	
		
		this.Search_query = obj.text;
		//this.Search_query = this.ds_autoResult.lookup( "hkeyword", obj.text, "keyword" );
		this.Search_keywordIdx =-1;
		this.Search_keyEnter=false;		
		objEnv.set_usewaitcursor(false);		
		////trace("before fn_callData >> " + this.Search_query);
		this.fn_callData();
	}
}

this.fn_callData = function()
{
	//var strUrl = "url=http://172.10.10.71:10005/tobe_autoList&zip=false";
	var strUrl = "url=" + nexacro.getEnvironmentVariable("gv_SearchEngine") + "/tobe_autoList&zip=false";
	////trace("fn_callData >> " + this.Search_query);
	var arg = "query='" + this.Search_query +"' ";
	
	this.showAutoCompleteResult(false);
	this.ds_autoComplete.clearData();      
	this.ds_autoResult.clearData();    
	
	
	this.transaction("select", nexacro.getEnvironment().services["SVC_JSP"].url + "Next_JSP/SearchEngine/Service/url.jsp?" + strUrl,"","ds_autoComplete=ds_auto",arg,"callbackAutoComplete"); 
}

this.callbackAutoComplete = function(id, code, msg)
{
	objEnv.set_usewaitcursor(true);
	this.Search_keywordIdx = -1;
	if (code >= 0) {
 		var ds = this.ds_autoComplete;  				
 		var strRecvData = ds.getColumn(0, "rtn");
		////trace(strRecvData);
 		if ( String(strRecvData).length > 0 )
 		{
			strRecvData = String(strRecvData).trim();
			strRecvData = strRecvData.replace(/&quot;/g, '"');
			var revcJsonObj = JSON.parse(strRecvData);
			var count = revcJsonObj.result.length;
			var datas = [];
				
			var resultDs = this.ds_autoResult;
			resultDs.clearData();
			var nRow;
			for (var i = 0 ; i < count; i++)
			{
				var eachResult = revcJsonObj.result[i];				
				var inCount = eachResult.totalcount;
				var jObj;
				var txt;
				for (var j = 0 ; j < inCount ; j++) 
				{
					jObj = eachResult.items[j];

					nRow = resultDs.addRow();
					txt = jObj.hkeyword;
					////trace(txt);
					//txt = nexacro.replaceAll(txt,"&lt;font style=&apos;color:#ff0000&apos;&gt;","<fc v='#ff0000'>");
					//txt = nexacro.replaceAll(txt,"&lt;/font&gt;","</fc>");
					//txt = nexacro.replaceAll(txt,"&lt;/font&gt;","</fs>");	
					resultDs.setColumn(nRow, "hkeyword", txt);
					resultDs.setColumn(nRow, "keyword", jObj.keyword);
					datas.push({   
						'KEYWORD': [jObj.hkeyword, jObj.keyword]
					});
				}  
				//trace(resultDs.saveXML());
			}             
			resultDs.set_rowposition(0);
			var div = this.div_autoCompleteResult;
			if ( datas.length == 0 )
			{
				//this.showAutoCompleteResult(false);
				var msg = "해당 단어로 시작하는 검색어가 없습니다.";
				var height = 30;
			}
			else
			{
			}
			if(this.Search_keyEnter == false)
			{
				this.showAutoCompleteResult(true);
			} else {
				this.showAutoCompleteResult(false);
			}	   
 		}
 		else 		
 		{
			this.showAutoCompleteResult(false);
 		}
 		
	} else if  (code < 0) {
		this.showAutoCompleteResult(false);
		//키워드가 없을 경우에는 code에 -4와 msg는 "Parameter is invalid"가 전달됨.
	}
}


this.showAutoCompleteResult = function(show)
{
	var div = this.div_autoCompleteResult;
	if ( show )
	{
		if(this.ds_autoResult.getRowCount() > 0)
		{
			div.set_visible(true);
			div.bringToFront();
			var rtn =  this.removeChild("div_autoCompleteResult");  
			// Destroy Object  
			rtn.destroy(); 
			rtn = null;
    
		  
			this.objDiv = new Div();         
			this.objDiv.init("div_autoCompleteResult",  30, 60, 318, 463, null, null);
			this.addChild("div_autoCompleteResult", this.objDiv);
			this.objDiv.set_border("1px solid #00bca8ff");   
			this.objDiv.set_background("white");  

			this.objDiv.show();
	//		this.div_autoCompleteResult.bringToFront();
			var iDivHeight=10;
			for(var i = 0; i < this.ds_autoResult.getRowCount() ;i++)
			{			   
				iDivHeight+=20;
				this.objStatic = new Static();
				if(i == 0)
				{
					this.objStatic.init("Static_" + i,  2, 0, 300, 20, null, null);
				} else {
					this.objStatic.init("Static_" + i,  2, (i * 20), 300, 20, null, null);
				}	
				this.objStatic.set_usedecorate(true);
				this.div_autoCompleteResult.addChild("Static_" + i, this.objStatic); 		 			
				this.objStatic.show();
   
				this.objStatic.set_text(this.ds_autoResult.getColumn(i,"hkeyword"));			
				this.objStatic.keyword = this.ds_autoResult.getColumn(i,"keyword");
				var rtn = this.objStatic.addEventHandler("onclick", this.div_autoCompleteResult_Static_onclick, this);

			}  
			this.div_autoCompleteResult.set_height(iDivHeight);
			this.div_autoCompleteResult.form.resetScroll();			
		}	
	}
	else
	{   
		div.set_visible(false);
	}
}  

this.div_autoCompleteResult_Static_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	//trace("click :: " + obj.keyword);	
	this.searchEdt.set_value(obj.keyword);
	this.showAutoCompleteResult(false);
}

this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//var strUrl = "url=http://172.10.10.71:10005/tobe_autoList&zip=false";
	var strUrl = "url=" + nexacro.getEnvironmentVariable("gv_SearchEngine") + "/tobe_autoList&zip=false";
	var arg = "query='" + this.searchEdt.value +"' ";

	this.ds_autoComplete.clearData();      
	this.ds_autoResult.clearData();    
	
	this.transaction("select", nexacro.getEnvironment().services["SVC_JSP"].url + "Next_JSP/SearchEngine/Service/url.jsp?" + strUrl,"","ds_autoComplete=ds_auto",arg,"callbackAutoComplete"); 	
};
]]></Script>
    <Objects>
      <Dataset id="ds_autoComplete">
        <ColumnInfo>
          <Column id="hkeyword" type="STRING" size="256"/>
          <Column id="keyword" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="ds_autoResult">
        <ColumnInfo>
          <Column id="hkeyword" type="STRING" size="256"/>
          <Column id="keyword" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="Dataset00">
        <ColumnInfo>
          <Column id="Column0" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="Column0">{"result":[{"totalcount":10,"items":[{"hkeyword":"&lt;font style='font-size:16px'&gt;&lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt; 콤보&lt;/font&gt;","keyword":"그리드 콤보","count":84,"type":2,"linkname":"","linkurl":""},{"hkeyword":"&lt;font style='font-size:16px'&gt;&lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;&lt;/font&gt;","keyword":"그리드","count":73,"type":2,"linkname":"","linkurl":""},{"hkeyword":"&lt;font style='font-size:16px'&gt;&lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt; 체크박스&lt;/font&gt;","keyword":"그리드 체크박스","count":51,"type":2,"linkname":"","linkurl":""},{"hkeyword":"&lt;font style='font-size:16px'&gt;&lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt; 필터&lt;/font&gt;","keyword":"그리드 필터","count":39,"type":2,"linkname":"","linkurl":""},{"hkeyword":"&lt;font style='font-size:16px'&gt;&lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt; 색상&lt;/font&gt;","keyword":"그리드 색상","count":28,"type":2,"linkname":"","linkurl":""},{"hkeyword":"&lt;font style='font-size:16px'&gt;&lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt; 합계&lt;/font&gt;","keyword":"그리드 합계","count":25,"type":2,"linkname":"","linkurl":""},{"hkeyword":"&lt;font style='font-size:16px'&gt;&lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt; 복사&lt;/font&gt;","keyword":"그리드 복사","count":24,"type":2,"linkname":"","linkurl":""},{"hkeyword":"&lt;font style='font-size:16px'&gt;&lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt; mask&lt;/font&gt;","keyword":"그리드 mask","count":21,"type":2,"linkname":"","linkurl":""},{"hkeyword":"&lt;font style='font-size:16px'&gt;&lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt; 페이징&lt;/font&gt;","keyword":"그리드 페이징","count":17,"type":2,"linkname":"","linkurl":""},{"hkeyword":"&lt;font style='font-size:16px'&gt;&lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt; 드래그&lt;/font&gt;","keyword":"그리드 드래그","count":16,"type":2,"linkname":"","linkurl":""}]},{"totalcount":5,"items":[{"hkeyword":"&lt;font style='font-size:16px'&gt;동적 &lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;&lt;/font&gt;","keyword":"동적 그리드","count":38,"type":2,"linkname":"","linkurl":""},{"hkeyword":"&lt;font style='font-size:16px'&gt;동적&lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;&lt;/font&gt;","keyword":"동적그리드","count":13,"type":2,"linkname":"","linkurl":""},{"hkeyword":"&lt;font style='font-size:16px'&gt;피벗 &lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;&lt;/font&gt;","keyword":"피벗 그리드","count":8,"type":2,"linkname":"","linkurl":""},{"hkeyword":"&lt;font style='font-size:16px'&gt;달력 &lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;&lt;/font&gt;","keyword":"달력 그리드","count":7,"type":2,"linkname":"","linkurl":""},{"hkeyword":"&lt;font style='font-size:16px'&gt;마우스 휠 &lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;&lt;/font&gt;","keyword":"마우스 휠 그리드","count":6,"type":2,"linkname":"","linkurl":""}]}]}</Col>
          </Row>
          <Row>
            <Col id="Column0">{"result":[{"totalcount":10, "items":[{"keyword":"&lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;상에서 &lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt; 클릭했을때 &lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;행" , "couunt":"1", "linkname":"", "linkurl":""}, {"keyword":"&lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;와 &lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;사이의" , "couunt":"2", "linkname":"", "linkurl":""}, {"keyword":"&lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;에 &lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;를 ", "couunt":"3", "linkname":"", "linkurl":""}, {"keyword":"&lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;와 &lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;사이에" , "couunt":"4", "linkname":"", "linkurl":""}, {"keyword":"&lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;의 &lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;인" , "couunt":"5", "linkname":"", "linkurl":""}, {"keyword":"&lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;에서 &lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;에" , "couunt":"6", "linkname":"", "linkurl":""}, {"keyword":"&lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt; &lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;속서잉빠지는경우" , "couunt":"7", "linkname":"", "linkurl":""}, {"keyword":"&lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;에 &lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;의" , "couunt":"8", "linkname":"", "linkurl":""}, {"keyword":"&lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;에서 &lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;위에" , "couunt":"9", "linkname":"", "linkurl":""}, {"keyword":"&lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;와 &lt;font style='color:#ff0000'&gt;그리드&lt;/font&gt;" , "couunt":"10", "linkname":"", "linkurl":""}]}],"responsestatus":0}</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
  </Form>
</FDL>
