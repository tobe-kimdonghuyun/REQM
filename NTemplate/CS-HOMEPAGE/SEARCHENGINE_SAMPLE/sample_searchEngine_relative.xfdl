<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sample_searchEngine_자동완성" width="1280" height="720" titletext="New Form">
    <Layouts>
      <Layout height="720" mobileorientation="landscape" width="1280">
        <Edit id="searchEdt" taborder="0" left="26" top="20" width="369" height="42" oneditclick="searchEdt_oneditclick" onkeyup="searchEdt_onkeyup" onkillfocus="searchEdt_onkillfocus" border="3px solid #1fb5ad" borderRadius="20px 20px" onchanged="searchEdt_onchanged"/>
        <Button id="Button00" taborder="1" text="Button00" left="407" top="19" width="143" height="43" onclick="Button00_onclick"/>
        <Grid id="Grid00" taborder="2" left="584" top="22" width="492" height="498" binddataset="ds_autoResult">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="446"/>
              </Columns>
              <Rows>
                <Row size="24" band="head"/>
                <Row size="24"/>
              </Rows>
              <Band id="head">
                <Cell text="keyword"/>
              </Band>
              <Band id="body">
                <Cell text="bind:keyword"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[var objEnv = nexacro.getEnvironment();
this.Search_query = ""; 
//this.url = nexacro.getEnvironmentVariable("gv_SearchEngine");
this.fn_callData = function()
{
	//var strUrl = "url=http://172.10.10.71:10005/tobe_relationList&zip=false";
	var strUrl = "url=" + nexacro.getEnvironmentVariable("gv_SearchEngine") + "/tobe_relationList&zip=false";
	//trace("fn_callData >> " + this.searchEdt.value);
	var arg = "query='" + this.searchEdt.value +"' ";
  
	this.ds_autoComplete.clearData();      
	this.ds_autoResult.clearData();     
	this.transaction("select", nexacro.getEnvironment().services["SVC_JSP"].url + "Next_JSP/SearchEngine/Service/url.jsp?" + strUrl,"","ds_autoComplete=ds_auto",arg,"callback"); 
}


this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fn_callData();
};

this.callback = function(id, code, msg)
{
	if (code >= 0) {
 		var ds = this.ds_autoComplete;  				
 		var strRecvData = ds.getColumn(0, "rtn");
 		if ( String(strRecvData).length > 0 )
 		{
			strRecvData = String(strRecvData).trim();
			strRecvData = strRecvData.replace(/&quot;/g, '"');
			var revcJsonObj = JSON.parse(strRecvData);
			var count = revcJsonObj.result.length;
			var datas = [];
				
			var resultDs = this.ds_autoResult;
			resultDs.clearData();
			var nRow;
			for (var i = 0 ; i < count; i++)
			{
				var eachResult = revcJsonObj.result[i];				
				var inCount = eachResult.totalcount;
				var jObj;
				var txt;
				for (var j = 0 ; j < inCount ; j++) 
				{
					jObj = eachResult.items[j];

					nRow = resultDs.addRow();
					resultDs.setColumn(nRow, "keyword", jObj.keyword);
				}  
				//trace(resultDs.saveXML());
			}             
			resultDs.set_rowposition(0);
	
  
 		}
 		else 		
 		{
			this.showAutoCompleteResult(false);
 		}
 		
	} else if  (code < 0) {
		this.showAutoCompleteResult(false);
		//키워드가 없을 경우에는 code에 -4와 msg는 "Parameter is invalid"가 전달됨.
	}
}]]></Script>
    <Objects>
      <Dataset id="ds_Result">
        <ColumnInfo>
          <Column id="keyword" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
