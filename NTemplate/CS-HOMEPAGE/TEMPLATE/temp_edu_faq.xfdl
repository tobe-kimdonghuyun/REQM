<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmWork" width="1920" titletext="교육관련FAQ" scrolltype="none" height="1820" cssclass="frm_WF_bgW" onload="frmWork_onload">
    <Layouts>
      <Layout height="1820" width="1920">
        <Div id="divHistory" taborder="1" left="310" top="0" width="1300" height="148" text="" formscrolltype="none">
          <Layouts>
            <Layout>
              <Button id="Button00" taborder="0" left="0" top="39" width="30" height="50" cssclass="btn_WF_history"/>
              <Static id="Static00_00" taborder="2" left="Button00:30" top="40" width="13" height="50" cssclass="sta_WF_historyPart"/>
              <Static id="Static00" taborder="1" left="Static00_00:0" top="37" width="188" height="50" cssclass="sta_WF_history" text="Education" fittocontents="width"/>
              <Static id="Static00_00_00" taborder="3" left="Static00:0" top="40" width="13" height="50" cssclass="sta_WF_historyPart"/>
              <Button id="Button00_00" taborder="4" text="교육관련FAQ" left="Static00_00_00:20" top="32" width="270" height="60" cssclass="btn_WF_hisMenu" fittocontents="width"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divResult" taborder="1" left="310" top="divHistory:0" width="1300" text="" formscrolltype="none" bottom="0">
          <Layouts>
            <Layout>
              <Div id="Div00" taborder="0" left="0" top="0" width="1300" height="590" cssclass="div_WF_faq" formscrolltype="none">
                <Layouts>
                  <Layout>
                    <Static id="Static00" taborder="0" text="투비소프트 교육신청방법 변경 안내" left="0" top="0" width="1300" height="90" cssclass="sta_WF_faq"/>
                    <Button id="Button00" taborder="1" left="1230" top="20" width="50" height="50" cssclass="btn_WF_faqClose"/>
                    <WebBrowser id="WebBrowser00" taborder="2" left="30" top="120" width="1240" height="440"/>
                  </Layout>
                </Layouts>
              </Div>
              <Div id="Div00_00" taborder="1" left="0" top="590" width="1300" height="90" cssclass="div_WF_faq" formscrolltype="none">
                <Layouts>
                  <Layout>
                    <Static id="Static00" taborder="0" text="다음 회차 교육은 언제 신청할 수 있나요?" left="0" top="0" width="1300" height="90" cssclass="sta_WF_faq"/>
                    <Button id="Button00" taborder="1" left="1230" top="20" width="50" height="50" cssclass="btn_WF_faqOpen"/>
                    <WebBrowser id="WebBrowser00" taborder="2" left="30" top="120" width="1240" height="440"/>
                  </Layout>
                </Layouts>
              </Div>
            </Layout>
          </Layouts>
        </Div>
        <PopupDiv id="PopupDiv00" left="605" top="100" width="230" height="300" cssclass="pop_TF_mypage">
          <Layouts>
            <Layout>
              <Grid id="Grid01" taborder="0" left="20" top="10" binddataset="Dataset01_00_00" autofittype="col" right="20" bottom="10" cssclass="grd_WF_hisMenu">
                <Formats>
                  <Format id="default">
                    <Columns>
                      <Column size="118"/>
                    </Columns>
                    <Rows>
                      <Row size="40"/>
                    </Rows>
                    <Band id="body">
                      <Cell text="bind:Column0"/>
                    </Band>
                  </Format>
                </Formats>
              </Grid>
            </Layout>
          </Layouts>
        </PopupDiv>
        <ListView id="ListView00" taborder="2" left="1962" top="148" binddataset="Dataset01" right="-1342" bottom="0" bandexpandtype="expand" bandinitstatus="expand" visible="false">
          <Formats>
            <Format id="default">
              <Band id="body" width="100%" height="92" expandbartype="true" expandbarsize="50 92">
                <Cell id="Cell01" left="0" top="0" width="60" text="bind:Icon" height="92" displaytype="imagecontrol"/>
                <Cell id="Cell05" left="60" top="0" text="bind:Title" height="92" right="0" padding="0px 0px 0px 10px"/>
              </Band>
              <Band id="detail" width="100%" height="500">
                <Cell id="Cell00" left="-14" top="0" width="100.00%" height="100.00%" text="bind:Detail" padding="20px 40px" verticalAlign="top"/>
              </Band>
            </Format>
          </Formats>
        </ListView>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
this.frmWork_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	 this.Dataset00.set_rowposition(-1); 
};
]]></Script>
    <Objects>
      <Dataset id="Dataset01">
        <ColumnInfo>
          <Column id="Icon" type="STRING" size="256"/>
          <Column id="Title" type="STRING" size="256"/>
          <Column id="Detail" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="Icon">URL('theme://images/img_WF_question.png')</Col>
            <Col id="Title">투비소프트 교육신청방법 변경 안내</Col>
            <Col id="Detail">안녕하세요.
투비소프트 교육서비스팀입니다.
당사는 2020년 10월부터 정기교육 신청방법이 변경되어 안내드립니다.
자세한 내용은 아래 내용을 참고시기 바랍니다.

 [ 변경 전 ]
1. 회원가입 및 로그인 과정없이 모든 교육 신청 가능
2. 교육비 : 무료

[ 변경 후 ]
1. 회원가입 및 로그인 후 교육 신청 가능
2. 교육비 : 무료

회원가입 시 작성된 내용은 교육 신청 및 교육 출결처리를 위한 목적으로 사용되며,
교육생의 수강 이력 및 수료증 등을 직접 관리 할 수 있도록 변경된 사항이니
교육 참여를 희망하시는 분은 회원가입 후 신청하시기 바랍니다.
기타 관련 문의는 02) 2140 - 7224로 연락해주시기 바랍니다.</Col>
          </Row>
          <Row>
            <Col id="Icon">URL('theme://images/img_WF_question.png')</Col>
            <Col id="Title">다음 회차 교육은 언제 신청할 수 있나요?&#13;</Col>
            <Col id="Detail">안녕하세요.
홈페이지를 통한 신청 이외 추가 등록은 되지 않습니다.
유선상으로 교육신청은 접수되지 않으니 이점 양해 부탁드립니다..</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="Dataset01_00_00">
        <ColumnInfo>
          <Column id="Column0" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="Column0">교육공지</Col>
          </Row>
          <Row>
            <Col id="Column0">교육자료</Col>
          </Row>
          <Row>
            <Col id="Column0">교육일정</Col>
          </Row>
          <Row>
            <Col id="Column0">교육신청</Col>
          </Row>
          <Row>
            <Col id="Column0">접수현황</Col>
          </Row>
          <Row>
            <Col id="Column0">교육관련FAQ</Col>
          </Row>
          <Row>
            <Col id="Column0">온라인교육</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
