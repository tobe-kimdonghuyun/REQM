        <Static id="Static28" taborder="45" left="386" top="1812" width="335" height="90" cssclass="sta_WF_DetailLabel" accessibilityenable="false"/>
        <ImageViewer id="ImageViewer09" taborder="46" left="404" top="1827" width="300" height="62" image="url('theme://images/img_WA10.png')" imagealign="left middle" accessibilitylabel="컨트롤 + 알트 + 홈 키 또는 컨트롤 + 알트 + 엔드 키"/>
        <Static id="Static37" taborder="47" text="그리드 내 현재 위치 기준 첫번째 또는 마지막 행 이동" left="720" top="1812" height="90" right="100" cssclass="sta_WF_DetailBg"/>
        <Static id="Static17" taborder="48" text="청각 장애인을 위한&#13;&#10;홈페이지 이용안내" left="50" top="1980" width="290" height="330" cssclass="sta_WF_WACon" accessibilityrole="heading"/>
        <Static id="Static18" taborder="49" left="340" top="1980" cssclass="sta_WF_WATxt" right="50" text="청각이나 언어장애를 가지고 있는 분이 비장애인과 전화로 의사 소통하는데 어려움이 있는 경우 &lt;fc v='#3E61D7'&gt;107 손말이음센터&lt;/fc&gt;를 통해 도움을 받을 수 있습니다.&#13;&#10;&lt;fc v='#3E61D7'&gt;107 손말이음센터&lt;/fc&gt;는 한국정보화진흥원에서 운영하는 실시간 통신중계서비스로 , 영상통화, 음성통화를 지원하고 있으며, 각종 문의, 쇼핑, 예약, 구직활동을 비롯하여 회사 업무와 통화, 가족, 친구와의 통화 시에도 이용할 수 있습니다.&#13;&#10;&#13;&#10;&#13;&#10;107 손말이음센터&#13;&#10;(&lt;a href=”https://107.relaycall.or.kr/ target=”_blank”&gt;https://107.relaycall.or.kr/&lt;/a&gt;)" height="330" usedecorate="true"/>
        <Button id="Button00" taborder="50" text="바로가기" top="2220" width="200" height="45" right="100" accessibilitydescription="새 창으로 열기"/>
        <Static id="zStaLastComponent" taborder="51" left="0" top="Static17:0" width="50" height="50" accessibilityenable="false"/>
