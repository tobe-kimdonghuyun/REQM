<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Temp_guide" width="1280" height="2360" titletext="웹 접근성 안내" background="#F4F4F4" onload="form_onload">
    <Layouts>
      <Layout height="2360" width="1280">
        <Static id="sta00" taborder="0" left="0" top="0" height="151" cssclass="sta_WF_GBar" text="웹 접근성 정책 및 컴퓨터 환경안내" right="0" usedecorate="true" accessibilityrole="heading"/>
        <Static id="Static00" taborder="1" text="웹 접근성 정책 안내" left="50" top="151" width="290" height="150" cssclass="sta_WF_WATitle"/>
        <Static id="Static01" taborder="2" left="340" top="151" cssclass="sta_WF_WATxt" right="50" text="모든 인터넷 사용자가 (장애인, 고령자 등이 포함된) 웹 사이트에서 제공하는 정보에 접근하고 이해할 수 있도록 웹 접근성 정책을 준수하고 있습니다." height="150"/>
        <Static id="Static02" taborder="3" text="바로접근 (Accessibility)&#13;&#10;링크" left="50" top="331" width="290" height="150" cssclass="sta_WF_WATitle"/>
        <Static id="Static03" taborder="4" left="340" top="331" cssclass="sta_WF_WATxt" right="50" text="서비스 문서 시작 부분에 반복되는 링크가 많은 페이지를 효율적으로 이용하기 위한 스킵 네비게이션(바로가기) 링크를 제공하고 있습니다." height="150"/>
        <Static id="Static12" taborder="5" text="이용가능&#13;&#10;브라우저 종류" left="50" top="511" width="290" height="150" cssclass="sta_WF_WATitle"/>
        <Static id="Static13" taborder="6" left="340" top="511" cssclass="sta_WF_WATxt" right="50" text="엣지, 크롬 브라우저에 최적화 되어 있습니다." height="150" padding="0px 40px 0px 260px"/>
        <ImageViewer id="ImageViewer10" taborder="7" left="398" top="543" width="60" height="60" image="url('theme://images/img_Edge.png')" stretch="fit" accessibilitylabel="엣지" accessibilityenable="false"/>
        <Static id="Static04" taborder="8" text="엣지" left="368" top="609" width="120" height="25" textAlign="center" color="#4f4f4f" accessibilityenable="false"/>
        <ImageViewer id="ImageViewer11" taborder="9" left="494" top="541" width="71" height="65" image="url('theme://images/img_Chrome.gif')" stretch="fit" accessibilitylabel="크롬" accessibilityenable="false"/>
        <Static id="Static04_00" taborder="10" text="크롬" left="489" top="609" width="80" height="25" textAlign="center" color="#4f4f4f" accessibilityenable="false"/>
        <Static id="Static14" taborder="11" text="화면 해상도" left="50" top="691" width="290" height="150" cssclass="sta_WF_WATitle"/>
        <Static id="Static15" taborder="12" left="340" top="691" cssclass="sta_WF_WATxt" right="50" text="화면 해상도는 &lt;b v='true'&gt;&lt;fc v='#3E61D7'&gt;1280 X 768 px&lt;/fc&gt;&lt;/b&gt;에 최적화 되어 있습니다." height="150" usedecorate="true"/>
        <Static id="Static08" taborder="13" text="※ 웹 접근성 향상을 위해 여러분의 제안이나 의견을 환영합니다. 언제든 서비스에 관해 보완해야 할 사항이나 불편한 점이 있으면 의견을 주시기 바랍니다." left="50" top="Static15:10" height="50" right="50" cssclass="sta_WF_Point"/>
        <Static id="Static09" taborder="14" text="시각 장애인을 위한&#13;&#10;홈페이지 이용안내" left="50" top="950" width="290" height="1000" cssclass="sta_WF_WACon" accessibilityrole="heading"/>
        <Static id="Static16" taborder="15" left="340" top="950" cssclass="sta_WF_WATxt" right="50" height="1000" usedecorate="false" accessibilityenable="false"/>
        <Static id="Static05" taborder="16" text="웹 접근성을 준수한 CSS(cascading style sheets)로 구축된 홈페이지로, 시각장애인을 위한 음성 서비스가 가능하도록 지원하고 있습니다. 다만, 음성 서비스 기능을 이용하려면 화면을 읽어주는 별도의 스크린 리더 프로그램이 필요합니다.&#13;&#10;&#13;&#10;※ 스크린 리더 및 기타 보조기기 이용 관련 자세한 내용은 &lt;fc v='#3E61D7'&gt;정보통신보조기기&lt;/fc&gt; 웹사이트 (http://www.at4u.or.kr) &lt;fc v='#3E61D7'&gt;중앙보조기구센터&lt;/fc&gt; (http://knat.go.kr)에서 확인할 수 있습니다.&#13;&#10;" left="380" top="1010" height="195" usedecorate="true" cssclass="sta_WF_WATxt2" right="90"/>
        <Static id="Static06" taborder="17" text="&lt;b v='true'&gt;&lt;fs v='14'&gt;키보드 이용방법&lt;/fs&gt;&lt;/b&gt;" left="390" top="1205" width="175" height="60" usedecorate="true"/>
        <Static id="Static20" taborder="18" left="386" top="1275" width="335" height="57" cssclass="sta_WF_DetailLabel" accessibilityenable="false"/>
        <ImageViewer id="ImageViewer00" taborder="19" left="404" top="1290" width="300" height="27" image="url('theme://images/img_WA01.png')" imagealign="left middle" accessibilitylabel="상하 방향키"/>
        <Static id="Static21" taborder="20" left="720" top="1275" height="57" cssclass="sta_WF_DetailBg" accessibilityenable="true" text="화면 내 항목 이동" wordWrap="none" right="100"/>
        <Static id="Static22" taborder="21" left="386" top="1331" width="335" height="57" cssclass="sta_WF_DetailLabel" accessibilityenable="false"/>
        <ImageViewer id="ImageViewer01" taborder="22" left="404" top="1346" width="300" height="27" image="url('theme://images/img_WA02.png')" imagealign="left middle" accessibilitylabel="탭 키 또는 쉬프트 + 탭 키"/>
