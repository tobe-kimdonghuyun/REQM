        <Static id="Static31" taborder="29" text="헤딩 이동" left="720" top="1443" height="57" right="100" cssclass="sta_WF_DetailBg"/>
        <Static id="Static25" taborder="30" left="386" top="1499" width="335" height="57" cssclass="sta_WF_DetailLabel" accessibilityenable="false"/>
        <ImageViewer id="ImageViewer04" taborder="31" left="404" top="1514" width="300" height="27" image="url('theme://images/img_WA05.png')" imagealign="left middle" accessibilitylabel="T 키"/>
        <Static id="Static32" taborder="32" text="테이블 이동" left="720" top="1499" height="57" right="100" cssclass="sta_WF_DetailBg"/>
        <Static id="Static26" taborder="33" left="386" top="1555" width="335" height="57" cssclass="sta_WF_DetailLabel" accessibilityenable="false"/>
        <ImageViewer id="ImageViewer05" taborder="34" left="404" top="1570" width="300" height="27" image="url('theme://images/img_WA06.png')" imagealign="left middle" accessibilitylabel="컨트롤 + 위쪽 방향키 또는 컨트롤 + 아래쪽 방향키"/>
        <Static id="Static33" taborder="35" text="가상커서해제(브라우저라고 음성출력됨)" left="720" top="1555" height="57" right="100" cssclass="sta_WF_DetailBg"/>
        <Static id="Static7" taborder="36" left="386" top="1611" width="335" height="57" cssclass="sta_WF_DetailLabel" accessibilityenable="false"/>
        <ImageViewer id="ImageViewer06" taborder="37" left="404" top="1626" width="300" height="27" image="url('theme://images/img_WA07.png')" imagealign="left middle" accessibilitylabel="Esc 키 또는 탭 키"/>
        <Static id="Static34" taborder="38" text="가상커서선택" left="720" top="1611" height="57" right="100" cssclass="sta_WF_DetailBg"/>
        <Static id="Static27" taborder="39" left="386" top="1667" width="335" height="57" cssclass="sta_WF_DetailLabel" accessibilityenable="false"/>
        <ImageViewer id="ImageViewer07" taborder="40" left="404" top="1682" width="300" height="27" image="url('theme://images/img_WA08.png')" imagealign="left middle" accessibilitylabel="컨트롤 + 알트 + 방향키"/>
        <Static id="Static35" taborder="41" text="그리드 내 컬럼 이동" left="720" top="1667" height="57" right="100" cssclass="sta_WF_DetailBg"/>
        <Static id="Static19" taborder="42" left="386" top="1723" width="335" height="90" cssclass="sta_WF_DetailLabel" accessibilityenable="false"/>
