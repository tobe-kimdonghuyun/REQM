  <Form id="Pop" width="600" height="600" titletext="New Form" dragscrolltype="none" cssclass="sta_POP_foot" scrolltype="none" background="#49506d">
    <Layouts>
      <Layout height="600" width="600">
        <Static id="Static00" taborder="0" left="0" top="0" width="600" height="134" cssclass="sta_POP_topGray"/>
        <Static id="Static02" taborder="1" text="시스템 공지사항" left="20" top="45" height="45" cssclass="sta_POP_title" width="560"/>
        <Static id="Static03" taborder="2" top="20" width="65" height="20" cssclass="sta_POP_logo" left="20"/>
        <CheckBox id="CheckBox00" taborder="8" text="오늘 하루 이 창을 띄우지 않음" left="20" top="566" width="190" height="25" onclick="CheckBox00_onclick" cssclass="check_POP_notToday" value="true"/>
        <Button id="Button00" taborder="9" text="닫기" top="566" width="55" height="25" cssclass="btn_POP_close" left="525"/>
        <Static id="Static09" taborder="7" left="10" top="114" cssclass="sta_POP_txtBox" height="436" width="580" text=""/>
        <Static id="Static06" taborder="3" left="40" top="145" width="95" height="30" cssclass="sta_POP_dateGray" onclick="Static06_onclick" text="작업내용"/>
        <Static id="Static06_00_00" taborder="5" text="홈페이지 리뉴얼 및 안정화" left="155" top="145" cssclass="sta_POP_dateInfo" height="30" width="405"/>
        <Static id="Static06_00" taborder="4" text="작업일시" left="40" top="185" width="95" height="30" cssclass="sta_POP_dateGray"/>
        <Static id="Static06_00_00_00" taborder="6" text="4월 15일(금) 16:00 - 24:00 (6시간 예정)" left="155" top="185" height="30" cssclass="sta_POP_dateInfo" width="405"/>
        <TextArea id="TextArea00" taborder="10" left="30" top="235" height="300" cssclass="txt_POP_mainText" value="안녕하세요&#10;투비소프트 교육서비스팀 입니다.&#10;8월 23일 0시를 기준으로 코로나19 사회적 거리두기 2단계 격상 전국 확대 시행에 따라&#10;당사에서도 부득이하게 8월 25일 정기교육부터 9월 정기교육까지 모두 취소가 되었음을 알려드립니다.&#10;&#10; &#10;&#10;[ 취소 대상 교육 ]&#10;1. 8월 25~27 교육 해당&#10;2. 9월 정기교육 및 퍼블리싱(디자인) 교육 모두 해당&#10;&#10; &#10;&#10;참고로 10월 정기교육에 대해서는 등록 예정이나, 코로나19 진행사항에 따라 취소될 수 있음을 알려드리며,&#10;일정에 착오 없으시길 바랍니다.&#10;&#10; &#10;&#10;추신 : support.tobesoft.co.kr-&gt; Education-&gt;온라인교육 메뉴를 통해 제품 기본교육 및 컴포넌트 활용에 대한&#10;&#10;        동영상이 준비되어 있으니 참고하시기 바랍니다.&#10;&#10; &#10;&#10;기타 교육관련 문의사항은 : 02-2140-7224로 연락주시기 바랍니다.&#10;&#10; &#10;&#10;감사합니다." readonly="true" width="560" wordWrap="char" scrollbartype="none auto" scrollbardecbuttonsize="0" scrollbarincbuttonsize="0" scrollbarsize="10"/>
      </Layout>
    </Layouts>
