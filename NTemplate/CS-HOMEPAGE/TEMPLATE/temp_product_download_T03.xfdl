                <Cell row="3" colspan="5" cssclass="grd_WF_line"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Combo id="Combo00" taborder="0" text="타이틀+상세" top="40" width="76" height="30" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" index="0" value="0" cssclass="cmb_WF_view" right="0">
