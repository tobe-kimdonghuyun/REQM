<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmWork" width="1300" titletext="etc" scrolltype="none" height="1620" onload="frmWork_onload">
    <Layouts>
      <Layout height="1620" width="1300">
        <Grid id="grdList" taborder="1" left="0" top="84" height="1025" cssclass="grd_WF_server" binddataset="Dataset00" scrollbartype="none none" right="0">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="34"/>
                <Column size="500"/>
                <Column size="34"/>
                <Column size="200"/>
                <Column size="532"/>
