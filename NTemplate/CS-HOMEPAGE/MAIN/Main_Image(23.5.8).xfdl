              <ImageViewer id="ImageViewer00" taborder="0" left="0" top="0" width="960" height="480" cssclass="img_MF_banner" image="url('theme://images/sta_MF_banner05.png')" onclick="divBanner05_ImageViewer00_onclick"/>
              <Static id="Static03" taborder="1" text="MiPlatform" left="0" top="524" width="81" height="27" cssclass="sta_MF_copy02" fittocontents="width"/>
              <Static id="Static02_00_00" taborder="2" text="한 번의 개발로 웹, C/S 등 다양한 멀티채널을 통한 통합 서비스를 지원" left="0" top="575" width="960" height="50" cssclass="sta_MF_copy03" fittocontents="width" onclick="divBanner05_ImageViewer00_onclick"/>
              <Static id="Static02_00_00_00" taborder="3" text="Multi-Tier 기반의 UI 통합 플랫폼 및 개발툴로서 유무선 환경에 최적화시켜 Presentaion Tier의 풍부한 사용자 인터페이스(Rich User &#13;&#10;Interface)와 용이한 개발환경(Easy To Implement)을 제공합니다." left="0" top="636" width="960" height="60" cssclass="sta_MF_copy04" usedecorate="true" onclick="divBanner05_ImageViewer00_onclick"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divBanner06" taborder="5" left="2020" top="1510" width="960" height="687" formscrolltype="none" visible="false">
          <Layouts>
            <Layout>
              <ImageViewer id="ImageViewer00" taborder="0" left="0" top="0" width="960" height="480" image="url('theme://images/sta_MF_banner06.png')" onclick="divBanner06_ImageViewer00_onclick" cssclass="img_MF_banner2"/>
              <Static id="Static03" taborder="1" text="교육" left="0" top="524" width="81" height="27" cssclass="sta_MF_copy02" fittocontents="width"/>
              <Static id="Static02_00_00" taborder="2" text="프로젝트형 넥사크로 전문가 양성과정 – 4기" left="0" top="575" width="960" height="50" cssclass="sta_MF_copy03" fittocontents="width" onclick="divBanner06_ImageViewer00_onclick"/>
              <Static id="Static02_00_00_00" taborder="3" text="넥사크로 개발 이론부터 프로젝트 실습까지 진행하는 교육으로 전문가 수준의 넥사크로 사용방법과 &#13;&#10;UI 공통 수행에 필요한 개발지식, 프로젝트 수행 시 이슈 대응과 노하우까지 학습할 수 있는 교육 과정입니다." left="0" top="636" width="960" height="60" cssclass="sta_MF_copy04" usedecorate="true" onclick="divBanner06_ImageViewer00_onclick"/>
