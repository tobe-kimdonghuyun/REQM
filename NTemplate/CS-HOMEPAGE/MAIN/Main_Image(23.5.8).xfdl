        </Div>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  매인화면의 제품배너
*
*  @MenuPath 
*  @FileName 		MAIN::Main_Image.xfdl 
*  @Creator 		김광호
*  @CreateDate 		2022.01.01
*  @LastModifier  
*  @LastModifyDate  
*  @Version 		1.0
*  @Outline 		매인화면의 제품배너
*  @Desction 
************** 소스 수정 이력 *************************************************
*    date          Modifier            Description
*******************************************************************************
*  2022.01.01      김광호	           최초 생성 
*******************************************************************************
*/


/* 
배너 추가하는 법.

1. 배너 Div를 만듭니다.
 - 모든 배너는 Div 안에 존재해야 하고, 아이디는 'divBanner + 숫자' 형식으로 맞춰야 합니다.
 - 사이즈는 width:960, height:687의 고정 사이즈로 맞춥니다.
 - left가 0이 되지 않도록 주의합니다.
 
2. 폼변수 this.AryProd 배열에 배너 Div 번호를 추가합니다.
 - 첫번째로 보여줄 배너부터 순서대로 추가합니다.
 - ex) this.AryProd = new Array("06", "01", "02", "03", "04", "05");   // 배너 표시 순서 6 > 1 > 2 > 3 > 4 > 5 > ...
 
3. 폼변수 this.MainImage와 this.SubImage에 배너 Div 콤포넌트를 세팅합니다.
 - this.MainImage는 첫번째로 보여줄 배너Div 입니다.
 - this.SubImage는 두번째로 보여줄 배너Div 입니다.

4. 추가한 배너 Div 안에 표시할 내용물을 배치합니다.

*/

//this.AryProd = new Array("07","06", "01", "02", "03", "04", "05");		//배너 DIV의 배열.
//this.AryProd = new Array("06", "01", "02", "03", "04", "05");		//배너 DIV의 배열.
this.AryProd = new Array("01", "02", "03", "04", "05");		//배너 DIV의 배열.
this.rollCount = 0;	
//this.MainImage = this.divBanner07;									//첫번째로 보여줄 배너
//this.MainImage = this.divBanner06;									//첫번째로 보여줄 배너
this.MainImage = this.divBanner01;									//첫번째로 보여줄 배너

this.SubImage = this.divBanner06;									//두번째로 보여줄 배너
//this.SubImage = this.divBanner01;									//두번째로 보여줄 배너
//this.SubImage = this.divBanner02;									//두번째로 보여줄 배너

this.Main_Image_onload = function (obj:Form, e:nexacro.LoadEventInfo)
{
	for(var i=0;i<this.AryProd.length;i++){
		eval("this.divBanner"+this.AryProd[i]+".set_visible(false)");
	}

	this.MainImage.set_left(0);
	this.MainImage.set_top(0);
	this.MainImage.set_visible(true);

	this.setTimer(1, 5000);
};

this.set_roll = function ()
{
	var subProd;
	var mainProd = this.AryProd[this.rollCount];
	if ((this.rollCount + 1) == this.AryProd.length) 
	{
		subProd = this.AryProd[0];
	}
	else 
	{
		subProd = this.AryProd[this.rollCount + 1];
	}

	this.MainImage = eval("this.divBanner" + mainProd);
	this.SubImage = eval("this.divBanner" + subProd);
	this.setTimer(0, 15);
};

this.Main_Image_ontimer = function (obj:Form, e:nexacro.TimerEventInfo)
{
	if (e.timerid == 0) 
	{
		// 이미지 다음 페이지
		if (this.SubImage.getOffsetLeft() == 0 && this.SubImage.getOffsetTop() == 0) 
		{
			this.killTimer(0);
			if (this.rollCount ==  this.AryProd.length - 1) 
			{
				this.rollCount = 0;
			}
			else 
			{
				this.rollCount++;
			}
		}
		else 
		{
			this.SubImage.set_visible(true);
			var nX = this.MainImage.left - 50;
			var nX_1 = nX + 1009;
			if (nX_1 <= 0) 
			{
				nX_1 = 0;
			}
			this.MainImage.move(nX, 0, 1009, 687);
			this.SubImage.move(nX_1, 0, 1009, 687);
		}
	}
	else if (e.timerid == 2) 
	{
		// 이미지 이전 페이지
		if (this.SubImage.left == 0) 
		{
			this.killTimer(2);
			if (this.rollCount == 0) 
			{
				this.rollCount =  this.AryProd.length-1;
			}
			else 
			{
				this.rollCount--;
			}
		}
		else 
		{
			this.SubImage.set_visible(true);
			var nX = this.MainImage.left + 50;
			var nX_1 = nX - 1009;
			if (nX_1 >= 0) 
			{
				nX_1 = 0;
			}
			this.MainImage.move(nX, 0, 1009, 687);
			this.SubImage.move(nX_1, 0, 1009, 687);
		}
	}
	else if (e.timerid == 1) 
	{
		// 이미지 재생
		this.set_roll();
	}
};

// 다음 이미지로 이동
this.set_PageNext = function ()
{
	this.set_roll();
	this.killTimer(1);
	this.setTimer(1, 5000);
};

// 이전 이미지로 이동
this.set_PagePre = function ()
{
	var subProd;
	var mainProd = this.AryProd[this.rollCount];
	if ((this.rollCount - 1) < 0) 
	{
		subProd = this.AryProd[this.AryProd.length-1];
	}
	else 
	{
		subProd = this.AryProd[this.rollCount - 1];
	}
	this.MainImage = eval("this.divBanner" + mainProd);
	this.SubImage = eval("this.divBanner" + subProd);
	this.setTimer(2, 15);
	this.killTimer(1);
};

// 이미지 멈춤
this.set_PageStop = function ()
{
	this.killTimer(1);
};
// 이미지 재생
this.set_PagePlay = function ()
{
	this.killTimer(1);
	this.setTimer(1, 5000);
};

// 배너 클릭 시 이동
this.divBanner01_ImageViewer00_onclick = function(obj:nexacro.ImageViewer,e:nexacro.ClickEventInfo)
{
	nexacro.getApplication().gv_mainFrame.param = {
		'menu': "Download_N",
		'keyword': "",
		'page': 1,
		'postId': ""
		};
	nexacro.getApplication().gv_mainFrame.gfnGoMain();
};

this.divBanner02_ImageViewer00_onclick = function(obj:nexacro.ImageViewer,e:nexacro.ClickEventInfo)
{
	nexacro.getApplication().gv_mainFrame.param = {
		'menu': "Download_17",
		'keyword': "",
		'page': 1,
		'postId': ""
		};
	nexacro.getApplication().gv_mainFrame.gfnGoMain();
};

this.divBanner03_ImageViewer00_onclick = function(obj:nexacro.ImageViewer,e:nexacro.ClickEventInfo)
{
