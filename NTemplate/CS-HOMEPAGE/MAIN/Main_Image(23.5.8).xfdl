        <Div id="divBanner07" taborder="6" left="3020" top="1510" width="960" height="687" formscrolltype="none" visible="false">
          <Layouts>
            <Layout>
              <ImageViewer id="ImageViewer00" taborder="0" left="0" top="0" width="960" height="480" image="url('theme://images/sta_MF_banner07.png')" onclick="divBanner06_ImageViewer00_onclick" cssclass="img_MF_banner2"/>
              <Static id="Static03" taborder="1" text="교육" left="0" top="524" width="81" height="27" cssclass="sta_MF_copy02" fittocontents="width"/>
              <Static id="Static02_00_00" taborder="2" text="프로젝트형 UX 실무 전문가 양성 과정 - 1기" left="0" top="575" width="960" height="50" cssclass="sta_MF_copy03" fittocontents="width" onclick="divBanner07_ImageViewer00_onclick"/>
              <Static id="Static02_00_00_00" taborder="3" text="업계 최초 국내 1위 UI/UX 개발 플랫폼 회사인 투비소프트의 현장 중심의 20년 실무 노하우가 &#13;&#10;담긴 실무형 UX 기획자 교육 과정입니다." left="0" top="636" width="960" height="60" cssclass="sta_MF_copy04" usedecorate="true" onclick="divBanner07_ImageViewer00_onclick"/>
