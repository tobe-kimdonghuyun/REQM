        <Div id="divBanner08" taborder="7" left="4020" top="1510" width="960" height="687" formscrolltype="none" visible="false">
          <Layouts>
            <Layout>
              <ImageViewer id="ImageViewer00" taborder="0" left="0" top="0" width="960" height="480" cssclass="img_MF_banner2" image="url('theme://images/sta_MF_bannerDevPro.png')" text=""/>
              <Static id="Static03" taborder="1" text="TOBESOFT DevPro" left="0" top="524" width="81" height="27" cssclass="sta_MF_copy02" fittocontents="width"/>
              <Static id="Static02_00_00" taborder="2" text="투비소프트 DevPro 서비스 출시" left="0" top="575" width="960" height="50" cssclass="sta_MF_copy03" fittocontents="width" onclick="divBanner06_ImageViewer00_onclick"/>
              <Static id="Static02_00_00_00" taborder="3" left="0" top="636" width="960" height="60" cssclass="sta_MF_copy04" usedecorate="true" onclick="divBanner06_ImageViewer00_onclick" text="검증된 기술력으로 완성된 통합 개발 환경 솔루션 DevPro 서비스가 출시되었습니다.       "/>
              <Static id="Static00" taborder="4" left="49" top="351" width="154" height="49" onclick="divBanner06_ImageViewer00_onclick" cursor="pointer"/>
              <Div id="divBanner06" taborder="5" left="2020" top="1510" width="960" height="687" formscrolltype="none" visible="false">
                <Layouts>
                  <Layout>
                    <ImageViewer id="ImageViewer00" taborder="0" left="0" top="0" width="960" height="480" onclick="divBanner06_ImageViewer00_onclick" cssclass="img_MF_banner2" image="url('theme://images/sta_MF_banner06.png')"/>
                    <Static id="Static03" taborder="1" text="교육" left="0" top="524" width="81" height="27" cssclass="sta_MF_copy02" fittocontents="width"/>
                    <Static id="Static02_00_00" taborder="2" text="프로젝트형 넥사크로 N 전문가 양성과정 – 5기" left="0" top="575" width="960" height="50" cssclass="sta_MF_copy03" fittocontents="width" onclick="divBanner06_ImageViewer00_onclick"/>
                    <Static id="Static02_00_00_00" taborder="3" text="넥사크로 개발 이론부터 프로젝트 실습까지 진행하는 교육으로 전문가 수준의 넥사크로 사용방법과 &#13;&#10;UI 공통 수행에 필요한 개발지식, 프로젝트 수행 시 이슈 대응과 노하우까지 학습할 수 있는 교육 과정입니다." left="0" top="636" width="960" height="60" cssclass="sta_MF_copy04" usedecorate="true" onclick="divBanner06_ImageViewer00_onclick"/>
                    <Static id="Static00" taborder="4" left="55" top="369" width="259" height="59" onclick="divBanner06_ImageViewer00_onclick" cursor="pointer"/>
                  </Layout>
