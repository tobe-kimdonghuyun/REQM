// BestTip 조회
this.fn_bestTipCallTrans = function() 
{
	nexacro.getApplication().gds_MiWizard.clearData();
	nexacro.getApplication().com_AddMiWizard("","output","","CS,cs_request_proc,37");	
	this.com_CallService("selectBestTip", "", "", "ds_List=output", "callback", "CS", false);	
}

// 인기검색어 조회
this.fn_popularCallData = function()
{
	var strUrl = "url=" + nexacro.getEnvironmentVariable("gv_SearchEngine") + "/tobe_topList&zip=false";
	this.ds_autoComplete.clearData();      
	this.ds_autoResult.clearData();     
	
	this.transaction("selectPopular", nexacro.getEnvironment().services["SVC_JSP"].url + "Next_JSP/SearchEngine/Service/url.jsp?" + strUrl,"","ds_autoComplete=ds_auto","","callback");
}

this.numberWithCommas = function(x) {
	//trace(x.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ','));
  return x.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
}

this.callback = function(id, code, msg)
{
	if (id == "selectBestTip") {
		// 화면에 셋팅
		var i;
		for (i = 0; i < 5; i++)
		{
			eval("this.divBestTip"+i+".form.staBestTipProd"+i+".set_text('"+this.ds_List.getColumn(i, "product_nm")+"');");
			eval("this.divBestTip"+i+".form.staBestTip"+i+".set_text('"+this.ds_List.getColumn(i, "SUBJECT")+"');");
			//eval("this.divBestTip"+i+".form.staUserCnt"+i+".set_text('"+this.ds_List.getColumn(i, "user_cnt").toString().replace(/\B(?<!\.\d*)(?=(\d{3})+(?!\d))/g, ",")+"');");
			eval("this.divBestTip"+i+".form.staUserCnt"+i+".set_text('"+this.numberWithCommas(this.ds_List.getColumn(i, "user_cnt"))+"');");
		}
    } else if (id == "selectPopular") {
		if (code >= 0) {
			var ds = this.ds_autoComplete;  				
			var strRecvData = ds.getColumn(0, "rtn");
			if ( String(strRecvData).length > 0 )
			{
				strRecvData = String(strRecvData).trim();
				strRecvData = strRecvData.replace(/&quot;/g, '"');
				var revcJsonObj = JSON.parse(strRecvData);
				var count = revcJsonObj.result.length;
				var datas = [];
					
				var resultDs = this.ds_autoResult;
				resultDs.clearData();
				var nRow;
				var i;
				for (i = 0 ; i < count; i++)
				{
					var eachResult = revcJsonObj.result[i];				
					var inCount = eachResult.totalcount;
					var jObj;
					var txt;
					for (var j = 0 ; j < inCount ; j++) 
					{
						jObj = eachResult.items[j];

						nRow = resultDs.addRow();
						resultDs.setColumn(nRow, "keyword", jObj.keyword);
					}  
				}
				resultDs.set_rowposition(0);
				// 인기검색어 셋팅
				var j = 0;
				for (i = 0; i < resultDs.rowcount; i++)
				{
					if (i > 7) {break;}
					if (!this.gfnIsNull(resultDs.getColumn(i, "keyword")))
					{
						eval("this.divMain.form.divTag.form.btn"+j+".set_text('"+resultDs.getColumn(i, "keyword")+"');");
						eval("this.divMain.form.divTag.form.btn"+j+".set_tooltiptext('"+resultDs.getColumn(i, "keyword")+"');");
						eval("this.divMain.form.divTag.form.btn"+j+".set_visible(true);");
						if (eval("this.divMain.form.divTag.form.btn"+j+".width") > 120)
						{
							eval("this.divMain.form.divTag.form.btn"+j+".set_width(120);")
						}
						j++;
					}
				}
				this.divMain.form.divTag.set_accessibilityenable(true);
				this.divMain.form.divTag.set_accessibilitylabel("인기 검색어 목록");
				this.divMain.form.divTag.form.resetScroll();
			}
			else
			{
			}
			
		} else if  (code < 0) {
			//키워드가 없을 경우에는 code에 -4와 msg는 "Parameter is invalid"가 전달됨.
		}
	}
}

// BestTip 게시물 이동
this.divBestTip_staBestTip_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	var sMenu = "";
	switch(this.ds_List.getColumn(obj.name.substr(10, 1), "product_nm")) {
	case "Nexacro N":
		sMenu = "Tip_View_N";
		break;
	case "nexacro 17":
		sMenu = "Tip_View_17";
		break;
	case "nexacro 14":
		sMenu = "Tip_View_14";
		break;
	default:
	}
	nexacro.getApplication().gv_mainFrame.param = {
		'menu': sMenu,
		'keyword': "",
		'page': 1,
		'postId': this.ds_List.getColumn(obj.name.substr(10, 1), "bl_seq")
		};
	nexacro.getApplication().gv_mainFrame.gfnGoMain();
};

