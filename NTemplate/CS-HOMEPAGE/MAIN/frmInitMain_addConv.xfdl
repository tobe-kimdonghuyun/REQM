// 컨버전체험
this.divMain_staConvExpr_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	// 새 창을 엽니다.
	const newWindow = window.open('', 'newWindow', 'width=600,height=400');
	
	// 새 창을 최대화합니다.
	newWindow.moveTo(0, 0);
	newWindow.resizeTo(screen.width, screen.height);
	
	// 폼을 동적으로 생성합니다.
	const form = document.createElement('form');
	form.method = 'POST';
	form.action = 'http://172.10.13.60:9090/test/postdata_test.jsp'; // 데이터를 보낼 URL
	form.target = 'newWindow'; // 새 창에 제출
	
	// 폼에 전송할 데이터를 추가합니다.
	const inputData = {
		uid: 'UserID',
		mail: 'shbaek@tobesoft.com',
		phone: '01063917768'
	};
	
	for (const key in inputData) {
		if (inputData.hasOwnProperty(key)) {
			const input = document.createElement('input');
			input.type = 'hidden';
			input.name = key;
			input.value = inputData[key];
			form.appendChild(input);
		}
	}
	
	// 폼을 문서에 추가하고 제출합니다.
	document.body.appendChild(form);
	form.submit();
	
	// 폼을 제출한 후, 문서에서 폼을 제거합니다.
	document.body.removeChild(form);
};

// 교육신청
this.divMain_staEduRegi_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
