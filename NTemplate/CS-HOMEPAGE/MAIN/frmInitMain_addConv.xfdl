this.fn_NoticePop = function(id, strUrl){

	var objFrame = new ChildFrame();
	var objParentFrame = this.getOwnerFrame();

	var nLeft = nexacro.getApplication().gv_mainFrame.getOffsetWidth()/2 - 400;
	var nTop = 300;
	objFrame.init( id, 0, 0, 450, 629 );
	objFrame.set_titlebarheight(40);
	objFrame.set_showtitlebar(true);
	objFrame.titlebar.set_background("#49506d");
	objFrame.set_dragmovetype("all");
	objFrame.set_openalign("center middle");
	objFrame.set_formurl( strUrl );
	var vRtn = objFrame.showModal( objParentFrame, "", this, this.fn_callback );
	
	if(vRtn){
		this.gvFrame = objFrame;
	}
}

this.fn_callback = function(svcid)
{
	if(svcid == "modalContent1")
	{
		//var mDate2 = this.gfnGetDate();
		//if(mDate2 != nexacro.getPrivateProfile("mTodayPop3")){
			//this.fn_NoticePop("modalContent","SUPPORT::frmNoticePOP3.xfdl");		//팝업 함수 호출
		//}	
	}
}

this.fn_NoticePop2 = function(id, strUrl, nLeft, nTop, nWidth, nHeight)
{
	var curX = window.screenLeft;
	var curY = window.screenTop;
	var curWidth = document.body.clientWidth;
	var curHeight = document.body.clientHeight;
	
	if(curY < 0) curY = 0;
	  
	var nLeft2 = curX + (curWidth / 2) - (nWidth / 2) - 325;
	var nTop = curY + (curHeight / 2) - (nHeight / 2);

	var objOwnerFrame = this.getOwnerFrame();
	nexacro.open(id, strUrl,  objOwnerFrame,"", "showtitlebar=true openalign='center middle'", nLeft+nLeft2, nTop, nWidth, nHeight);
}


