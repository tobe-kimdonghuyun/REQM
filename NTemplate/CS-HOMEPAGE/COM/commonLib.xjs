nexacro.getApplication().changeflg = false;
nexacro.getApplication().oldRowNum = "";

// 문자열 길이 체크
// nexacro.getTextSize로 구할수 있으므로 임시로 사용(06/03현재는 지원하고 있지 않음)
nexacro.getApplication().chkStrLength = function (str, num)
{
	if (str === undefined) 
	{
		return;
	}

	var r = 0;
	var i = 0;
	for (i = 0; i < str.length; i++) 
	{
		var c = str.charCodeAt(i);
		if ((c >= 0x0 && c < 0x81) || (c == 0xf8f0) || (c >= 0xff61 && c < 0xffa0) || (c >= 0xf8f1 && c < 0xf8f4)) 
		{
			r += 1;
		}
		else 
		{
			r += 2;
		}

		if (num < r) 
		{
			break;
		}
	}

	if (num < r) 
	{
		str = str.substr(0, i) + "...";
	}

	return str;
};


// 설정 언어에 따른 언어 설정
nexacro.getApplication().com_SetLanguage = function (strLang)
{
	// 한국어
	if (nexacro.getApplication().gv_Language.toUpperCase() == "KO") 
	{
		// 국가코드설정[한국:001]
		nexacro.getApplication().gv_NationCd = "001";
		nexacro.getApplication().gv_MsgNaCol = "msg_nation1";
		nexacro.getApplication().gds_CompLang.set_rowposition(0);
		nexacro.getApplication().gds_CodeLang.set_rowposition(0);
		//trace("KO");

		// 영어
	}
	else if (nexacro.getApplication().gv_Language.toUpperCase() == "EN") 
	{
		// 국가코드설정[영어:002]
		nexacro.getApplication().gv_NationCd = "002";
		nexacro.getApplication().gv_MsgNaCol = "msg_nation2";
		nexacro.getApplication().gds_CompLang.set_rowposition(1);
		nexacro.getApplication().gds_CodeLang.set_rowposition(1);
		//trace("EN");

		// 일본어
	}
	else if (nexacro.getApplication().gv_Language.toUpperCase() == "JA") 
	{
		// 국가코드설정[일본:003]
		nexacro.getApplication().gv_NationCd = "003";
		nexacro.getApplication().gv_MsgNaCol = "msg_nation3";
		nexacro.getApplication().gds_CompLang.set_rowposition(2);
		nexacro.getApplication().gds_CodeLang.set_rowposition(2);
		//trace("JA");

		// 그외
	}
	else 
	{
		// 국가코드설정[영어:002]
		nexacro.getApplication().gv_Language == "EN";
		nexacro.getApplication().gv_NationCd = "002";
		nexacro.getApplication().gv_MsgNaCol = "msg_nation2";
		nexacro.getApplication().gds_CompLang.set_rowposition(1);
		nexacro.getApplication().gds_CodeLang.set_rowposition(1);
		//trace("EN");
	}
};


nexacro.getApplication().com_SetQuote = function (argString)
{
	if (nexacro.getApplication().com_IsEmpty(argString)) 
	{
		argString = "";
	}

	var strVal = new String(argString);
	var strRet = new String("'");

	for (var i = 0; i < strVal.length; i++) 
	{
		if (strVal.substr(i, 1) == "'") 
		{
			strRet += '"';
		}
		else if (strVal.substr(i, 1) == '"') 
		{
			strRet += '"';
		}
		else 
		{
			strRet += strVal.substr(i, 1);
		}
	}

	strRet += "'";
	return strRet;
};

nexacro.getApplication().com_IsEmpty = function (inVal)
{
	if (new String(inVal).valueOf() == "undefined") 
	{
		return true;
	}
	if (inVal == null) 
	{
		return true;
	}

	var v_ChkStr = new String(inVal);
	if (v_ChkStr == null) 
	{
		return true;
	}
	if (v_ChkStr.toString().length == 0) 
	{
		return true;
	}
	return false;
};


nexacro.getApplication().com_AddMiWizard = function (inDs, outDs, args, sqlSel, sqlIns, sqlUpd, sqlDel)
{
	var aRow = nexacro.getApplication().gds_MiWizard.addRow();
	nexacro.getApplication().gds_MiWizard.setColumn(aRow, "inputDs", inDs);
	nexacro.getApplication().gds_MiWizard.setColumn(aRow, "outDs", outDs);
	nexacro.getApplication().gds_MiWizard.setColumn(aRow, "parameters", args);
	nexacro.getApplication().gds_MiWizard.setColumn(aRow, "sql_select", sqlSel);
	nexacro.getApplication().gds_MiWizard.setColumn(aRow, "sql_insert", sqlIns);
	nexacro.getApplication().gds_MiWizard.setColumn(aRow, "sql_update", sqlUpd);
	nexacro.getApplication().gds_MiWizard.setColumn(aRow, "sql_delete", sqlDel);
};

