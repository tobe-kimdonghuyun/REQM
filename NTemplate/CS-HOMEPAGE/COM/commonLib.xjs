	nexacro.getApplication().gds_SearchParam.setColumn(aRow, "keywordall", dsParamObj.getColumn(0, "keywordall"));
	nexacro.getApplication().gds_SearchParam.setColumn(aRow, "PCategory2", dsParamObj.getColumn(0, "PCategory2"));
	nexacro.getApplication().gds_SearchParam.setColumn(aRow, "display_cnt", dsParamObj.getColumn(0, "display_cnt"));
	nexacro.getApplication().gds_SearchParam.setColumn(aRow, "page", dsParamObj.getColumn(0, "page"));
	nexacro.getApplication().gds_SearchParam.setColumn(aRow, "searchfield", dsParamObj.getColumn(0, "searchfield"));
	nexacro.getApplication().gds_SearchParam.setColumn(aRow, "searchgubun", dsParamObj.getColumn(0, "searchgubun"));
	nexacro.getApplication().gds_SearchParam.setColumn(aRow, "keyword", dsParamObj.getColumn(0, "keyword"));
	nexacro.getApplication().gds_SearchParam.setColumn(aRow, "search_resort", dsParamObj.getColumn(0, "search_resort"));
	nexacro.getApplication().gds_SearchParam.setColumn(aRow, "BusinessSection", dsParamObj.getColumn(0, "BusinessSection"));
	nexacro.getApplication().gds_SearchParam.setColumn(aRow, "loginAcc", dsParamObj.getColumn(0, "loginAcc"));
	nexacro.getApplication().gds_SearchParam.setColumn(aRow, "statusType", dsParamObj.getColumn(0, "statusType"));
	nexacro.getApplication().gds_SearchParam.setColumn(aRow, "User_id", dsParamObj.getColumn(0, "User_id"));
	nexacro.getApplication().gds_SearchParam.setColumn(aRow, "ProjectCd", dsParamObj.getColumn(0, "ProjectCd"));
	nexacro.getApplication().gds_SearchParam.setColumn(aRow, "bookMark", dsParamObj.getColumn(0, "bookMark"));
	nexacro.getApplication().gds_SearchParam.setColumn(aRow, "period", dsParamObj.getColumn(0, "period"));
