nexacro.getApplication().com_OpenSubScreen = function (screenId)
{
	var parentObj = nexacro.getApplication().MainFrame.childFrame;

	var nRow = nexacro.getApplication().gds_SubInfo.addRow();
	nexacro.getApplication().gds_SubInfo.setColumn(nRow, "screenId", screenId);
	nexacro.getApplication().gds_SubInfo.setColumn(nRow, "myDiv", parentObj.name + ".form.DivSub_" + screenId);
	nexacro.getApplication().gds_SubInfo.setColumn(nRow, "mySta", parentObj.name + ".form.StaSub_" + screenId);

	// Static으로 배경 설정
	var newSta = new Static("StaSub_" + screenId, "absolute", 0, 0, null, null, 0, 0);
	parentObj.form.addChild(newSta.name, newSta);

	newSta.style.set_border_width(0);
	newSta.style.set_background_color("#000000c0");

	newSta.show();

	// Div으로 화면 설정
	var nWidth = nexacro.getApplication().gds_ScreenUrl.lookup("screenId", screenId, "width");
	var nHeight = nexacro.getApplication().gds_ScreenUrl.lookup("screenId", screenId, "height");
	var scrUrl = nexacro.getApplication().gds_ScreenUrl.lookup("screenId", screenId, "scrUrl");

	var newDiv = new Div("DivSub_" + screenId, "absolute", 0, 0);
	parentObj.form.addChild(newDiv.name, newDiv);

	newDiv.set_width(nWidth);
	newDiv.set_height(nHeight);

	newDiv.set_url(scrUrl);
	newDiv.set_scrollbars("none");
	newDiv.style.set_border_width(0);

	newDiv.show();
};

nexacro.getApplication().com_CloseSubScreen = function ()
{
	var parentFrm = nexacro.getApplication().MainFrame.childFrame.form;

	var targetDiv = eval("application.mainFrame." + nexacro.getApplication().gds_SubInfo.getColumn(0, "myDiv"));
	var targetSta = eval("application.mainFrame." + nexacro.getApplication().gds_SubInfo.getColumn(0, "mySta"));

	parentFrm.removeChild(targetDiv.name);
	parentFrm.removeChild(targetSta.name);

	targetDiv.destroy();
	targetSta.destroy();

	nexacro.getApplication().gds_SubInfo.clearData();
};

// 화면 중앙에 표시
nexacro.getApplication().com_SetScreenPos = function (frmObj)
{
	var leftSize = (frmObj.parent.getOffsetWidth() - frmObj.getOffsetWidth()) / 2;
	var topSize = (frmObj.parent.getOffsetHeight() - frmObj.getOffsetHeight()) / 2;
	frmObj.set_left(leftSize);
	frmObj.set_top(topSize);
};


nexacro.getApplication().com_ExpGridDetail = function (gridObj1, gridObj2, divObj, frmObj, rowNum, plsLeft, plsTop)
{
	var dsData1 = gridObj1.getBindDataset();
	var dsData2 = gridObj2.getBindDataset();

	// 닫는 처리
	if (nexacro.getApplication().oldRowNum == rowNum && nexacro.getApplication().changeflg == false) 
	{
		dsData2.filter("");

		divObj.set_visible(false);
		gridObj2.set_visible(false);

		nexacro.getApplication().changeflg = true;

		// 표시 처리
	}
	else 
	{
		var headSize = nexacro.toNumber(gridObj1.getFormatRowProperty(0, "size"));
		var cellSize = nexacro.toNumber(gridObj1.getFormatRowProperty(1, "size"));

		var grdTop = gridObj1.getOffsetTop();
		var grdCus = headSize + cellSize;
		var resize = 0;
		if ((rowNum % 10) == 0) 
		{
			resize = (10 * cellSize) + headSize + grdTop;
		}
		else 
		{
			resize = (((rowNum % 10) - 1) * cellSize) + grdCus + grdTop;
		}

		divObj.set_left(gridObj1.getOffsetLeft() + plsLeft);
		divObj.set_top(resize + plsTop);
		divObj.bringToFront();
		divObj.set_visible(true);

		dsData2.filter("rowNum > '" + rowNum + "'");

		gridObj2.set_left(gridObj1.getOffsetLeft());
		gridObj2.set_top(resize + divObj.getOffsetHeight());
		gridObj2.set_height(dsData2.rowcount * cellSize);
		gridObj2.bringToFront();
		gridObj2.set_visible(true);

		if (!nexacro.getApplication().com_IsEmpty(dsData1.lookup("rowNum", rowNum, "rowNum"))) 
		{
			dsData1.set_rowposition((rowNum % 10) - 1);
			dsData2.set_rowposition(-1);
		}
		else 
		{
			dsData1.set_rowposition(-1);
			dsData2.set_rowposition((rowNum % 10) - 1);
		}

		nexacro.getApplication().oldRowNum = rowNum;
		nexacro.getApplication().changeflg = false;
	}

	frmObj.resetScroll();
};

nexacro.getApplication().com_SetMessage = function (msgCd, repFlg, repMsgArr)
{
	// 메세지 취득
	var expErrorMsg = nexacro.getApplication().gds_MessageCd.lookup("msg_code_id", msgCd, nexacro.getApplication().gv_MsgNaCol);
	// 문자 변환
	if (repFlg) 
	{
		for (var i = 0; i < repMsgArr.length; i++) 
		{
			// 문자 Replace
			expErrorMsg = expErrorMsg.replace("XX", repMsgArr[i]);
		}
	}

	if (expErrorMsg == null) 
	{
		return;
	}

	expErrorMsg = expErrorMsg.replace(/\\n/g, String.fromCharCode(10));

	alert(expErrorMsg);
};

nexacro.getApplication().com_ConfirmMessage = function (msgCd, repFlg, repMsgArr)
{
	// 메세지 취득
	var expErrorMsg = nexacro.getApplication().gds_MessageCd.lookup("msg_code_id", msgCd, nexacro.getApplication().gv_MsgNaCol);
	// 문자 변환
	if (repFlg) 
	{
		for (var i = 0; i < repMsgArr.length; i++) 
		{
			// 문자 Replace
			expErrorMsg = expErrorMsg.replace("XX", repMsgArr[i]);
		}
	}

	if (expErrorMsg == null) 
	{
		return;
	}
	expErrorMsg.replace(/\\n/g, String.fromCharCode(10));
	var retVal = confirm(expErrorMsg);
	return retVal;
};

nexacro.getApplication().com_SetGridText = function (strColNm, tarGrid, tarArr)
{
	var txtGridHead = nexacro.getApplication().gds_CompLang.getColumn(nexacro.getApplication().gds_CompLang.rowposition, strColNm);
	var arrTxtHead = txtGridHead.split("/");


	// Grid Header 설정
	for (var i = 0; i < arrTxtHead.length; i++) 
	{
		// //trace("tarArr[i].value = "+tarArr[i]);
		// //trace("tarArr[i].idx = "+arrTxtHead[i]);
		tarGrid.setCellProperty("Head", tarArr[i], "text", arrTxtHead[i]);
	}
};

nexacro.getApplication().com_Today = function ()
{
	var sToday = "";
	var objDate = new Date();
	var sToday = objDate.getFullYear().toString();
	sToday += nexacro.getApplication().com_Right("0" + (objDate.getMonth() + 1), 2);
	sToday += nexacro.getApplication().com_Right("0" + objDate.getDate(), 2);

	return sToday;
};

nexacro.getApplication().com_Right = function (sOrg, nSize)
{
	if (sOrg == null) 
	{
		return "";
	}
	if (sOrg.length < nSize) 
	{
		return sOrg;
	}
	else 
	{
		return sOrg.substr(sOrg.length - nSize, nSize);
	}
};]]></Script>
