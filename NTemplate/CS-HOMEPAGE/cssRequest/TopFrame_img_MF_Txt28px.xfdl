this.TopFrame_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	//this.fn_setTopMidSize(e.cx);
	//MainFrame에서 this.width로 사이즈를 조절하기 때문에, e.cx를 파라미터로 넘기면 위치가 달라짐.
	this.fn_setTopMidSize(this.parent.parent.width);
};

this.fn_setTopMidSize = function (nWidth)
{
	var leftSize = (nWidth - this.divTop.width) / 2;

	if (leftSize > 0) 
	{
		this.divTop.set_left(leftSize);
		this.divMenu.set_left(leftSize);
	}
	else 
	{
		this.divTop.set_left(0);
		this.divTop.set_left(0);
	}
};

