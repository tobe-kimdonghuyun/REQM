    <Script type="xscript5.1"><![CDATA[/**
*  탑프레임
*
*  @MenuPath 
*  @FileName 		FRAME::TopFrame.xfdl 
*  @Creator 		김광호
*  @CreateDate 		2022.01.01
*  @LastModifier  
*  @LastModifyDate  
*  @Version 		1.0
*  @Outline 		탑프레임
*  @Desction 
************** 소스 수정 이력 *************************************************
*    date          Modifier            Description
*******************************************************************************
*  2022.01.01      김광호	           최초 생성 
*******************************************************************************
*/


this.divMenuHeight = 331;
this.divMenuInUse = ""; //활성화되어있는 서브메뉴 Div
this.divTopMenuExpand = false; //Div 확장 여부
this.TopFrame_onload = function (obj:Form, e:nexacro.LoadEventInfo)
{
	this.divSkip.set_height(0);

 	nexacro.getApplication().gv_topFrame = this;
	
	//mainFrame에 있는 데이터셋 복사.
	this.dsScreenUrl.copyData(nexacro.getApplication().gv_mainFrame.dsScreenUrl);

	// Top 메뉴 셋팅
	this.fnSetTopMenu();
	
	var dDate = new Date();
	var rDate = dDate.getFullYear() + (dDate.getMonth() + 1).toString().padLeft(2, "0") + dDate.getDate().toString().padLeft(2, "0");

	nexacro.getApplication().gds_SearchCond.clearData();
	nexacro.getApplication().gds_SearchCond.addRow();
	nexacro.getApplication().gds_SearchCond.setColumn(nexacro.getApplication().gds_SearchCond.rowposition, "searchField", "ALL");
	nexacro.getApplication().gds_SearchCond.setColumn(nexacro.getApplication().gds_SearchCond.rowposition, "useSynonym", "Y");
	nexacro.getApplication().gds_SearchCond.setColumn(nexacro.getApplication().gds_SearchCond.rowposition, "startCount", "0");
	nexacro.getApplication().gds_SearchCond.setColumn(nexacro.getApplication().gds_SearchCond.rowposition, "collection", "ALL");
	nexacro.getApplication().gds_SearchCond.setColumn(nexacro.getApplication().gds_SearchCond.rowposition, "sort", 'DATE/DESC');
	nexacro.getApplication().gds_SearchCond.setColumn(nexacro.getApplication().gds_SearchCond.rowposition, "range", "A");
	nexacro.getApplication().gds_SearchCond.setColumn(nexacro.getApplication().gds_SearchCond.rowposition, "startDate", '19700101');
	nexacro.getApplication().gds_SearchCond.setColumn(nexacro.getApplication().gds_SearchCond.rowposition, "endDate", rDate);
	nexacro.getApplication().gds_SearchCond.setColumn(nexacro.getApplication().gds_SearchCond.rowposition, "query", "");
	nexacro.getApplication().gds_SearchCond.setColumn(nexacro.getApplication().gds_SearchCond.rowposition, "reQuery", "");
	nexacro.getApplication().gds_SearchCond.setColumn(nexacro.getApplication().gds_SearchCond.rowposition, "realQuery", "");

	nexacro.getApplication().gds_SearchCond.setColumn(nexacro.getApplication().gds_SearchCond.rowposition, "writer", "");
	nexacro.getApplication().gds_SearchCond.setColumn(nexacro.getApplication().gds_SearchCond.rowposition, "employ", "");
	nexacro.getApplication().gds_SearchCond.setColumn(nexacro.getApplication().gds_SearchCond.rowposition, "pub_yn", "");
	nexacro.getApplication().gds_SearchCond.setColumn(nexacro.getApplication().gds_SearchCond.rowposition, "doc_id", "");
	nexacro.getApplication().gds_SearchCond.setColumn(nexacro.getApplication().gds_SearchCond.rowposition, "open_yn", "");
	nexacro.getApplication().gds_SearchCond.setColumn(nexacro.getApplication().gds_SearchCond.rowposition, "goods_gbn", "");
	nexacro.getApplication().gds_SearchCond.setColumn(nexacro.getApplication().gds_SearchCond.rowposition, "rt", "");
	nexacro.getApplication().gds_SearchCond.setColumn(nexacro.getApplication().gds_SearchCond.rowposition, "rt2", "");

};

/**
 * @description topmenu 셋팅
 */
this.fnSetTopMenu = function ()
{
	var sFilter = "lev == '0' ";
	this.dsTopMenu.filter(sFilter);
	
	// Top 메뉴 복사
	var ds = new Dataset;
	this.addChild("dsTopMenuBtn", ds);
	this.dsTopMenuBtn.copyData(this.dsTopMenu, true);
	this.dsTopMenu.filter("");

	for (var i = 0; i < this.dsTopMenuBtn.getRowCount(); i++) 
	{
		var sMenuNm = this.dsTopMenuBtn.getColumn(i, "caption");
		var sMenuId = this.dsTopMenuBtn.getColumn(i, "idx");
		this.fnCreateTopMenu(sMenuId, sMenuNm, i);
	}
};

/**
 * @description Top menu creation
 */
this.fnCreateTopMenu = function (sTopId, sTopNm, index)
{
	// Creating page button
	var objBtn = new Button();
	objBtn.init("TOP_" + sTopNm, this.fnGetLeft(sTopNm), 0, 0, 55, null, null);
	this.divTop.form.divTopMenu.form.addChild(objBtn.name, objBtn);
	objBtn.show();
	objBtn.set_text(sTopNm);
	objBtn.set_cssclass("btn_TF_Navi");
	var sCond = "lev == '1' && parent == '" + sTopNm + "'";
	if(this.dsTopMenu.findRowExpr(sCond) > -1){
		objBtn.set_accessibilitydescription("메뉴 확장");
		objBtn.setEventHandler("onsetfocus", this.btnTopMenu_onclick, this);
		//서브메뉴 Div 생성
		this.fnCreateSubMenuDiv(sTopNm);
	}else{
	    objBtn.set_accessibilitydescription("링크");
	}
	objBtn.menuid = sTopId;
	
	// 버튼 width 셋팅
	objBtn.set_fittocontents("width");
	var nWidth = objBtn.getOffsetWidth();
	objBtn.set_fittocontents("none");
	objBtn.set_width(nWidth + 55);
	objBtn.setEventHandler("onclick", this.btnTopMenu_onclick, this);
};

/**
 * @description Sub Menu Div 생성
 */
this.fnCreateSubMenuDiv = function (sTopNm)
{
	//Creat
	var objDiv = new Div();
	objDiv.init("divMenu_" + sTopNm, 0, 55, null, 331, 0);
	this.divTop.form.divTopMenu.form.addChild(objDiv.name, objDiv);
	objDiv.show();
	objDiv.cssclass = "div_TF_NaviBG";
	objDiv.visible = false;
	objDiv.accessibilityenable = false;
	objDiv.setEventHandler("onkillfocus", this.divMenu_onkillfocus, this);
	
	//Div 초기 셋팅
	var objImg = new ImageViewer();
	objImg.init("stcMenu", 86, 28, 166, 47);
	objDiv.addChild(objImg.name, objImg);
	objImg.show();
	objImg.text = sTopNm.toUpperCase();
	objImg.accessibilitydescription = "메뉴";
	objImg.cssclass = "img_MF_Txt28px";
	
	var objSta1 = new Static();
	objSta1.init("Static01", 270, 20, 6, null, null, 20);
	objDiv.addChild(objSta1.name, objSta1);
	objSta1.show();
	objSta1.border = "0px none, 1px solid #e2e2e6, 0px none, 0px none";
	objSta1.accessibilityenable = false;
	
	var objSta2 = new Static();
	objSta2.init("Static02", 513, 20, 6, null, null, 20);
	objDiv.addChild(objSta2.name, objSta2);
	objSta2.show();
	objSta2.border = "0px none, 1px solid #e2e2e6, 0px none, 0px none";
	objSta2.accessibilityenable = false;

	var objSta3 = new Static();
	objSta3.init("Static03", 749, 20, 6, null, null, 20);
	objDiv.addChild(objSta3.name, objSta3);
	objSta3.show();
	objSta3.border = "0px none, 1px solid #e2e2e6, 0px none, 0px none";
	objSta3.accessibilityenable = false;
};

/**
 * @description sub1pmenu 셋팅
 */
this.btnTopMenu_onclick = function (obj, e)
{
	//연관검색어 창 열려있다면 닫기
	nexacro.getApplication().gv_mainFrame.showAutoCompleteResult(false);
	
	//접근성 적용. 선택된 버튼 role heading2 지정
	//heading지정 시 h로 버튼으로 Focus 진입 시 서브메뉴 열리지 않고 Top 높이 이상해 지는 현상 발생. 주석처리함.
// 	var length = this.divTop.form.divTopMenu.form.components.length;
// 	for (var i = 0; i < length; i++) {
// 		if (this.divTop.form.divTopMenu.form.components[i].accessibilityrole == "heading2") {
// 			this.divTop.form.divTopMenu.form.components[i].accessibilityrole = "";
// 		}
// 	}
// 	obj.accessibilityrole = "heading2";

	//활성화 된 subMenu Div 숨기기
	if (this.divTopMenuExpand) {
		this.fn_closeMenu();
		this.fnSetTopMenuWidth(false);
	}
	
	var parentId = obj.name.replace("TOP_","");
	var sCond = "lev == '1' && parent == '" + parentId + "'";	
	if(this.dsTopMenu.findRowExpr(sCond) > -1){
// 		this.divMenu.form.stcMenu.set_text(parentId);
		// 맨 앞으로
		var elem = this.parent.parent.divTop.getElement();
		if(elem)
		{
			elem.setElementZIndex(1);
		}	
	}else{
		// 저장된 스크롤 위치 초기화
		nexacro.getApplication().gv_mainFrame.SCROLL_POS = 0;
		
		// 게시판 검색어 초기화
		nexacro.getApplication().gv_mainFrame.Board_Cond_Keyword = "";
		nexacro.getApplication().gv_mainFrame.Board_Cond_KeywordAll = "";
		nexacro.getApplication().gv_mainFrame.divMain.form.divSearch.set_url("");
		if (obj.menuid == "QnA")
		{
			nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 0;
			var sHash = "menu=QnA&page=1";
			MyHistory.setData(sHash, {});
		}
		
		nexacro.getApplication().gv_mainFrame.param = {
			'menu': obj.menuid,
			'keyword': "",
			'page': 1,
			'postId': ""
		};
		
		this.divMenuInUse = "";
		this.parent.parent.divTop.height = 120;
		nexacro.getApplication().gv_mainFrame.gfnGoMain();
		return;
	}

	var sFilter = "lev == '1' && parent == '" + parentId + "'";
	this.dsTopMenu.filter(sFilter);
	
	// Top 메뉴 복사
	if (!this.isValidObject("dsTopSub1Btn")){
		// Create Object
		var ds = new Dataset;
		this.addChild("dsTopSub1Btn", ds);
	}
	
	//메뉴에 맞는 서브메뉴Div 활성화
	this.divMenuInUse = this.divTop.form.divTopMenu.form["divMenu_" + parentId];
	for (var i = this.divMenuInUse.form.components.length - 1; i > -1; i--) {
		if(this.divMenuInUse.form.components[i].name.substr(0, 4) == "SUB1"
		   || this.divMenuInUse.form.components[i].name.substr(0, 4) == "SUB2"
		   || this.divMenuInUse.form.components[i].name.substr(0, 4) == "SUB3") {
			var objDel = this.divMenuInUse.removeChild(this.divMenuInUse.form.components[i].name);
			objDel.destroy();
			objDel = null;
		}
	}

	this.dsTopSub1Btn.copyData(this.dsTopMenu, true);
	this.dsTopMenu.filter("");
	var nLeft = "";
	var nTop = 33;
	var nHGap = 43;
	var objPrev = "";

	for (var i = 0; i < this.dsTopSub1Btn.getRowCount(); i++) 
	{
		if(objPrev =="") objPrev = obj; 
 		var sMenuNm = this.dsTopSub1Btn.getColumn(i, "caption");
		var sMenuId = this.dsTopSub1Btn.getColumn(i, "idx");
		// Creating page button
		var objBtn = new Button();
		objBtn.init("SUB1_" + sMenuNm, "Static01:15", nTop, 200, 36, null, null);
		this.divMenuInUse.form.addChild(objBtn.name, objBtn);
		objBtn.menuid = sMenuId;
		objBtn.show();
		objPrev = objBtn;
		nTop += nHGap;		
		
		var text = this.fn_makeEllipse(sMenuNm, objBtn);
		if (sMenuNm != text) {
			objBtn.set_text(text);
			objBtn.set_tooltiptext(sMenuNm);
		} else {
			objBtn.set_text(sMenuNm);
		}
		
		var sCond = "lev == '2' && parent == '" + sMenuNm + "'";
		if (this.dsTopMenu.findRowExpr(sCond) > -1) {
			objBtn.set_cssclass("btn_TF_NaviSubR");
			objBtn.set_accessibilitydescription("메뉴 확장");
			//lev2 동적 생성(taborder 순서 맞추기 위함)
			this.fnCreateSub2Menu(objBtn);
			objBtn.setEventHandler("onsetfocus", this.btnSub1Menu_onclick, this);
		} else {
		    objBtn.set_cssclass("btn_TF_NaviSub");
			objBtn.set_accessibilitydescription("링크");
			
			var nFindRow = this.dsScreenUrl.findRow("subCatgy", sMenuId);
			if (!this.gfnIsNull(this.dsScreenUrl.getColumn(nFindRow, "Link"))) objBtn.set_accessibilitydescription("새창열림");
			
			objBtn.setEventHandler("onclick", this.btnSub1Menu_onclick, this);
		}

		objBtn.setEventHandler("onclick", this.btnSub1Menu_onclick, this);
	}
	
	this.fnSetMenuDivHeight();
 	this.fnSetTopMenuWidth(true);
 	this.divMenuInUse.visible = true;
};

/**
 * @description divTopMenu 넓이 조절 및 버튼 위치 이동
 */
this.fnSetTopMenuWidth = function(bExpand)
{
	var nLeft = 0;
	if (bExpand) {		
		nLeft = this.divTop.form.divTopMenu.getOffsetLeft();
		this.divTop.form.divTopMenu.left = 0;
		this.divTop.form.divTopMenu.right = 0;
		this.divTopMenuExpand = true;
	} else {
		this.divTop.form.divTopMenu.left = 256;
		this.divTop.form.divTopMenu.width = 750;
		this.divTopMenuExpand = false;
	}

	var cnt = this.dsTopMenuBtn.getRowCount();
	for (var i = 0; i < cnt; i++) {
		var sMenuNm = this.dsTopMenuBtn.getColumn(i, "caption");
		var menuBtn = this.divTop.form.divTopMenu.form.components["TOP_" + sMenuNm];
		
		if (i == 0) {
			menuBtn.setOffsetLeft(nLeft);
			continue;
		}
		
		var nCurRow = this.dsTopMenuBtn.findRow("caption", sMenuNm);
		var prevBtn = this.fnFindObj("TOP_" + this.dsTopMenuBtn.getColumn(nCurRow - 1, "caption"));
		var prevBtnId = prevBtn.id;
		
		menuBtn.left = prevBtnId + ":0";
	}
};

/**
 * @description sub2menu 셋팅
 */
this.btnSub1Menu_onclick = function (obj, e)
{
	// sub2 div 활성화/비활성화
	var comps = this.divMenuInUse.form.components;
	var compsLen = comps.length;
	for (var i = 0; i < compsLen; i++)
	{ 
		if (comps[i] instanceof nexacro.Div ) {
			if (comps[i].name.indexOf(obj.name.replace("SUB1_","")) > -1) {
				comps[i].visible = true;
			} else {
				comps[i].visible = false;
			}
		}
	}

	if(obj.cssclass == "btn_TF_NaviSub"){	//메뉴호출
		// 저장된 스크롤 위치 초기화
		nexacro.getApplication().gv_mainFrame.SCROLL_POS = 0;
		
		// 게시판 검색어 초기화
		nexacro.getApplication().gv_mainFrame.Board_Cond_Keyword = "";
		nexacro.getApplication().gv_mainFrame.Board_Cond_KeywordAll = "";
		nexacro.getApplication().gv_mainFrame.divMain.form.divSearch.set_url("");
		if (obj.menuid == "QnA")
		{
			nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 0;
			var sHash = "menu=QnA&page=1";
			MyHistory.setData(sHash, {});
		}

		nexacro.getApplication().gv_mainFrame.param = {
			'menu': obj.menuid,
			'keyword': "",
			'page': 1,
			'postId': ""
			};
		
		//서브메뉴Div가 visible=false되면 초점이 자동으로 PRODUCT메뉴버튼으로 튐.(메뉴 Div 자동열림) 포커스를 최상단으로 이동시켜 메뉴Div열림 방지.
		this.fn_setFocus();	
			
		this.fn_closeMenu();
		nexacro.getApplication().gv_mainFrame.gfnGoMain();		
		return;
	}

	this.fnSetMenuDivHeight();
};

/**
 * @description sub2menu 동적 생성
 */
this.fnCreateSub2Menu = function(obj)
{
	var parentId = obj.name.replace("SUB1_","");
	var sFilter = "lev == '2' && parent == '" + parentId + "'";
	this.dsTopMenu.filter(sFilter);
	
	// Top 메뉴 복사
	if (!this.isValidObject("dsTopSub2Btn")){
		// Create Object
		var ds = new Dataset;
		this.addChild("dsTopSub2Btn", ds);
	}

	this.dsTopSub2Btn.copyData(this.dsTopMenu, true);
	this.dsTopMenu.filter("");
	var nParentTop = obj.top;
	var nTop = 0;
	var nHGap = 43;
	var objPrev = "";
	var nCnt = this.dsTopSub2Btn.getRowCount();
	
	//div 생성
	var objDiv = new Div();
	var divId  = "SUB2_" + parentId;
	objDiv.init(divId, "Static02:15", nParentTop, 200, nCnt * nHGap);
	this.divMenuInUse.form.addChild(objDiv.name, objDiv);
	objDiv.show();
	objDiv.accessibilityenable = false;
	objDiv.visible = false;

	//버튼 생성
	for (var i = 0; i < nCnt; i++) 
	{
		if(objPrev =="") objPrev = obj; 
 		var sMenuNm = this.dsTopSub2Btn.getColumn(i, "caption");
		var sMenuId = this.dsTopSub2Btn.getColumn(i, "idx");
		
		var objBtn = new Button();
		objBtn.init("SUB2_" + sMenuNm, 0, nTop, 200, 36);
		objDiv.addChild(objBtn.name, objBtn);
		objBtn.menuid = sMenuId;
		objBtn.show();
		objPrev = objBtn;
		nTop += nHGap;
		
		var text = this.fn_makeEllipse(sMenuNm, objBtn);
		if (sMenuNm != text) {
			objBtn.set_text(text);
			objBtn.set_tooltiptext(sMenuNm);
		} else {
			objBtn.set_text(sMenuNm);
		}

		if(sMenuId =="Document_N"){
			objBtn.set_cssclass("btn_TF_NaviSubR");
			objBtn.set_accessibilitydescription("메뉴 확장");
			//lev3 동적 생성(taborder 순서 맞추기)
			this.fnCreateSub3Menu(objBtn);
			objBtn.setEventHandler("onsetfocus", this.btnSub2Menu_onsetfocus, this);
		}else{
		    objBtn.set_cssclass("btn_TF_NaviSub");
			objBtn.set_accessibilitydescription("링크");
			var nFindRow = this.dsScreenUrl.findRow("subCatgy", sMenuId);
			if (!this.gfnIsNull(this.dsScreenUrl.getColumn(nFindRow, "Link"))) objBtn.set_accessibilitydescription("새창열림");
			objBtn.setEventHandler("onclick", this.btnSub2Menu_onclick, this);
        }
	}
};

/**
 * @description top메뉴 div 높이 조절
 */
this.fnSetMenuDivHeight = function() {
	var comps = this.divMenuInUse.form.components;
	var compsLen = comps.length;
	
	var nMaxBottom = 0;
	for(var i = 0; i < compsLen; i++){
		var objComp = comps[i];
		if (!(objComp instanceof nexacro.Static)) {
			if (objComp.visible && (objComp.getOffsetBottom() > nMaxBottom) ) {
				nMaxBottom = objComp.getOffsetBottom();
			}		
		}
	}
	
	this.divMenuHeight = nMaxBottom + 33;
	this.divMenuInUse.height = this.divMenuHeight;
	this.divTop.form.divTopMenu.height = this.divMenuHeight + 88;
	this.divTop.height = this.divMenuHeight + 120;
	this.parent.parent.divTop.height = this.divMenuHeight + 120;
};


/**
 * @description sub3menu 클릭 이벤트 (링크)
 */
this.btnSub2Menu_onclick = function (obj, e)
{
	if(obj.cssclass == "btn_TF_NaviSub"){	//메뉴호출
		// 저장된 스크롤 위치 초기화
		nexacro.getApplication().gv_mainFrame.SCROLL_POS = 0;
		
		if( !e.id.indexOf("Demo") == -1 || !e.id.indexOf("Install_FAQ") == -1 || !e.id.indexOf("SelfStudy_14") == -1 || !e.id.indexOf("_SK") == -1 )
		{
			// 게시판 검색어 초기화
			nexacro.getApplication().gv_mainFrame.Board_Cond_Keyword = "";
			nexacro.getApplication().gv_mainFrame.Board_Cond_KeywordAll = "";
			nexacro.getApplication().gv_mainFrame.divMain.form.divSearch.set_url("");
		}	
		if (obj.menuid == "QnA")
		{
			nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 0;
			var sHash = "menu=QnA&page=1";
			MyHistory.setData(sHash, {});
		}

		nexacro.getApplication().gv_mainFrame.param = {
			'menu': obj.menuid,
			'keyword': "",
			'page': 1,
			'postId': ""
			};
		//서브메뉴Div가 visible=false되면 초점이 자동으로 PRODUCT메뉴버튼으로 튐.(메뉴 Div 자동열림) 포커스를 최상단으로 이동시켜 메뉴Div열림 방지.
		this.fn_setFocus();	
		
		this.fn_closeMenu();
		nexacro.getApplication().gv_mainFrame.gfnGoMain();		
	}
};


/**
 * @description sub3menu div 활성화
 */
this.btnSub2Menu_onsetfocus = function(obj, e)
{
	var len = obj.parent.components.length
	for (var i = 0; i < len; i++) {
		var comp = obj.parent.components[i];
		if (comp instanceof nexacro.Div) {
			comp.visible = true;
		}
	}
	obj.parent.parent.width = 430;			
	this.fnSetMenuDivHeight();
}

this.fnCreateSub3Menu = function(obj)
{
	var parentId = obj.name.replace("SUB2_","");
	var sFilter = "lev == '3' && parent == '" + parentId + "'";
	this.dsTopMenu.filter(sFilter);
	
	// Top 메뉴 복사
	if (!this.isValidObject("dsTopSub3Btn")){
		// Create Object
		var ds = new Dataset;
		this.addChild("dsTopSub3Btn", ds);
	}
	
	this.dsTopSub3Btn.copyData(this.dsTopMenu, true);
	this.dsTopMenu.filter("");
	var nParentTop = obj.top;
	var nTop = 0;
	var nHGap = 43;
	var objPrev = "";
	var nCnt = this.dsTopSub3Btn.getRowCount();

	//div 생성
	var objDiv = new Div();
	var divId  = "SUB3_" + parentId;
	objDiv.init(divId, obj.getOffsetRight() + 30, nParentTop, 200, nCnt * nHGap);
	obj.parent.addChild(objDiv.name, objDiv);
	objDiv.show();
	objDiv.accessibilityenable = false;
	objDiv.visible = false;
	objDiv.setEventHandler("onkillfocus", this.divSub3Menu_onkillfocus, this);
	
	for (var i = 0; i < nCnt; i++) 
	{
		if(objPrev =="") objPrev = obj; 
 		var sMenuNm = this.dsTopSub3Btn.getColumn(i, "caption");
		var sMenuId = this.dsTopSub3Btn.getColumn(i, "idx");
		// Creating page button
		var objBtn = new Button();
		objBtn.init("SUB3_" + sMenuNm, 0, nTop, 200, 36);
		objDiv.addChild(objBtn.name, objBtn);
		objBtn.menuid = sMenuId;
		objBtn.show();
		
		objPrev = objBtn;
		nTop += nHGap;		
		var text = this.fn_makeEllipse(sMenuNm, objBtn);
		if (sMenuNm != text) {
			objBtn.set_text(text);
			objBtn.set_tooltiptext(sMenuNm);
		} else {
			objBtn.set_text(sMenuNm);
		}

		objBtn.set_cssclass("btn_TF_NaviSub");
		objBtn.set_accessibilitydescription("링크");
		var nFindRow = this.dsScreenUrl.findRow("subCatgy", sMenuId);
		if (!this.gfnIsNull(this.dsScreenUrl.getColumn(nFindRow, "Link"))) objBtn.set_accessibilitydescription("새창열림");
		
		objBtn.setEventHandler("onclick", this.btnSub3Menu_onclick, this);
	}
};

this.divSub3Menu_onkillfocus = function(obj, e)
{
	obj.visible = false;
	obj.parent.parent.width = 200;
};

