    <Script type="xscript5.1"><![CDATA[/**
*  라이트프레임
*
*  @MenuPath 
*  @FileName 		FRAME::RightFrame.xfdl 
*  @Creator 		김광호
*  @CreateDate 		2022.01.01
*  @LastModifier  
*  @LastModifyDate  
*  @Version 		1.0
*  @Outline 		라이트프레임
*  @Desction 
************** 소스 수정 이력 *************************************************
*    date          Modifier            Description
*******************************************************************************
*  2022.01.01      김광호	           최초 생성 
*******************************************************************************
*/

this.RightFrame_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	nexacro.getApplication().gv_rightFrame = this;

	// BestTip 조회
	this.fn_bestTipCallTrans();
	
	// 현재 메뉴에 따라서 연관검색어를 인기검색어로 변경
	var mPageName=nexacro.getApplication().gv_CurMenu;
	if(mPageName=="Tip"||mPageName=="교육자료"||mPageName=="교육공지"||mPageName=="공지사항"||mPageName=="나의 질문내역"||mPageName=="북마크"){
		this.staRelative.set_text("인기검색어");
		this.fn_popularCallData();
	}
};

// 연관검색어 조회
this.fn_relativeCallData = function(sKeyword)
{
	var strUrl = "url=" + nexacro.getEnvironmentVariable("gv_SearchEngine") + "/tobe_relationList&zip=false";
	var arg = "query='" + sKeyword +"'";//this.searchEdt.value +"' ";
  
	this.ds_autoComplete.clearData();
	this.ds_autoResult.clearData();
	
	this.transaction("selectRelative", nexacro.getEnvironment().services["SVC_JSP"].url + "Next_JSP/SearchEngine/Service/url.jsp?" + strUrl,"","ds_autoComplete=ds_auto",arg,"callback"); 	// 개발 
}

// BestTip 조회
this.fn_bestTipCallTrans = function() 
{
	nexacro.getApplication().gds_MiWizard.clearData();
	nexacro.getApplication().com_AddMiWizard("","output","","CS,cs_request_proc,37");	
	this.com_CallService("selectBestTip", "", "", "ds_List=output", "callback", "CS", false);	
}

this.callback = function(id, code, msg)
{
	if (id == "selectBestTip") {
 		
    }
	else if (id == "selectRelative") {
		if (code >= 0) {
			var ds = this.ds_autoComplete;  				
			var strRecvData = ds.getColumn(0, "rtn");
			if ( String(strRecvData).length > 0 )
			{
				this.divRelative.form.staNullText.set_visible(false);
				//접근성 대응
				this.divRelative.tabstop = true;
				strRecvData = String(strRecvData).trim();
				strRecvData = strRecvData.replace(/&quot;/g, '"');
				var revcJsonObj = JSON.parse(strRecvData);
				var count = revcJsonObj.result.length;
				var datas = [];

				var resultDs = this.ds_autoResult;
				resultDs.clearData();
				var nRow;
				var i;
				var j;
				for (i = 0 ; i < count; i++)
				{
					var eachResult = revcJsonObj.result[i];				
					var inCount = eachResult.totalcount;
					var jObj;
					var txt;
					for (j = 0 ; j < inCount ; j++) 
					{
						jObj = eachResult.items[j];

						nRow = resultDs.addRow();
						resultDs.setColumn(nRow, "keyword", jObj.keyword);
					}  
				}             
				resultDs.set_rowposition(0);

				//우선 초기화
				for (i = 0; i < 9; i++)
				{
					eval("this.divRelative.form.btn"+i+".set_visible(false);");
				}				
				if (resultDs.rowcount == 0)
				{
					this.divRelative.form.staNullText.set_visible(true);
					//접근성 대응
					this.divRelative.tabstop = false;					
				}
				else
				{
					this.divRelative.form.staNullText.set_visible(false);
					//접근성 대응
					this.divRelative.tabstop = true;					
					j = 0;
					for (i = 0; i < 9; i++)
					{
						if (!this.gfnIsNull(resultDs.getColumn(i, "keyword")))
						{
							
							if (nexacro.getTextSize(resultDs.getColumn(i, "keyword"), "normal 400 14px 'NotoSansKR'").nx > 68)
							{
								resultDs.setColumn(i, "keyword", resultDs.getColumn(i, "keyword"));
							}
							eval("this.divRelative.form.btn"+j+".set_text('"+resultDs.getColumn(i, "keyword")+"');");
							eval("this.divRelative.form.btn"+j+".set_tooltiptext('"+resultDs.getColumn(i, "keyword")+"');");
							eval("this.divRelative.form.btn"+j+".set_visible(true);");
							j++;
						}
						this.divRelative.form.resetScroll();
					}
				}
			}
			else 		
			{
			}
			
		} else if  (code < 0) {
			
			//키워드가 없을 경우에는 code에 -4와 msg는 "Parameter is invalid"가 전달됨.
		}
    }else if(id == "selectPopular"){
		if(code >= 0){
			
			var ds = this.ds_autoComplete;  	
			var strRecvData = ds.getColumn(0, "rtn");
			if ( String(strRecvData).length > 0 )
			{
				strRecvData = String(strRecvData).trim();
				strRecvData = strRecvData.replace(/&quot;/g, '"');
				var revcJsonObj = JSON.parse(strRecvData);
				var count = revcJsonObj.result.length;
				var datas = [];
					
				var resultDs = this.ds_autoResult;
				resultDs.clearData();
				var nRow;
				var i;
				for (i = 0 ; i < count; i++)
				{
					var eachResult = revcJsonObj.result[i];				
					var inCount = eachResult.totalcount;
					var jObj;
					var txt;
					for (var j = 0 ; j < inCount ; j++) 
					{
						jObj = eachResult.items[j];

						nRow = resultDs.addRow();
						resultDs.setColumn(nRow, "keyword", jObj.keyword);
					}  
				}
				resultDs.set_rowposition(0);
				// 인기검색어 셋팅
				var j = 0;
				for (i = 0; i < resultDs.rowcount; i++)
				{
					if (i > 7) {break;}
					if (!this.gfnIsNull(resultDs.getColumn(i, "keyword")))
					{
						eval("this.divRelative.form.btn"+j+".set_text('"+resultDs.getColumn(i, "keyword")+"');");
						eval("this.divRelative.form.btn"+j+".set_tooltiptext('"+resultDs.getColumn(i, "keyword")+"');");
						eval("this.divRelative.form.btn"+j+".set_visible(true);");
						j++;
					}
				}
				this.divRelative.form.resetScroll();
				this.divRelative.form.staNullText.set_visible(false);
				//접근성 대응
				this.divRelative.tabstop = true;				
			}
		}
	}
}

// 연관검색어 버튼 이벤트
this.divRelative_btn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sKeyword = obj.text;
	if(this.staRelative.text=="연관검색어")
	{
		if (nexacro.getApplication().gv_mainFrame.PCategory2 == "SearchEngine")	// QnA리스트일 경우 제품 탭에 전체 건수 표시를 위해 조회
		{
			nexacro.getApplication().gv_searchEngine.divSearch.form.edtSearch.set_value(sKeyword);
			nexacro.getApplication().gv_searchEngine.fn_search(1);
		}
		else if (nexacro.getApplication().gv_mainFrame.PCategory2 == "QnA")
		{
			nexacro.getApplication().gv_searchEngine.divSearch.form.edtSearch.set_value(sKeyword);
			nexacro.getApplication().gv_searchEngine.divResult.form.btn1.click();
		}
	}
	else if (this.staRelative.text=="인기검색어")
	{
		nexacro.getApplication().gv_mainFrame.param = {
			'menu': "SearchEngine",
			'keyword': sKeyword,
			'page': 1,
			'postId': ""
			};
		nexacro.getApplication().gv_mainFrame.gfnGoMain();
	}
};


// 질문하기 버튼 이벤트
this.btnWrite_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 자동로그인 유저면 그냥 보여주고 아니면 로그인화면으로 보낸다.
	var bLogin = nexacro.getApplication().gv_mainFrame.fn_AutoLogin();
	if (bLogin)
	{
		if( nexacro.getApplication().gv_mainFrame.PCategory2 == "Sketch" )
		{
			nexacro.getApplication().gv_mainFrame.QAStatus = "Write";
			nexacro.getApplication().gv_mainFrame.param = {
				'menu': "Sketch_Write",
				'keyword': "",
				'page': 1,
				'postId': ""
				};
			nexacro.getApplication().gv_mainFrame.gfnGoMain();
		} else if( nexacro.getApplication().gv_mainFrame.PCategory2 == "Tutorial" )
		{
			nexacro.getApplication().gv_mainFrame.QAStatus = "Write";
			nexacro.getApplication().gv_mainFrame.param = {
				'menu': "Tutorial_Write",
				'keyword': "",
				'page': 1,
				'postId': ""
				};
			nexacro.getApplication().gv_mainFrame.gfnGoMain();
		} else {
			nexacro.getApplication().gv_mainFrame.QAStatus = "Write";
			nexacro.getApplication().gv_mainFrame.param = {
				'menu': "QnA_Write",
				'keyword': "",
				'page': 1,
				'postId': ""
				};
			nexacro.getApplication().gv_mainFrame.gfnGoMain();		
		}
	}
	else
	{
		nexacro.getApplication().gv_mainFrame.QAStatus = "Write";
		nexacro.getApplication().gv_mainFrame.TargetUrl = "QnA_Write";
		
		nexacro.getApplication().gv_mainFrame.param = {
			'menu': "login",
			'keyword': "",
			'page': 1,
			'postId': ""
			};
		nexacro.getApplication().gv_mainFrame.gfnGoMain();
}
};

// 원격지원 4.0
this.btnRemote4_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
