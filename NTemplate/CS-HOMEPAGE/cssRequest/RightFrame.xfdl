};


// 제품 BestTip expr
this.fn_exprBestTipProd = function(sProd)
{
	switch(sProd) {
	case "Nexacro N":
		return "[N]";
		break;
	case "nexacro 17":
		return "[17]";
		break;
	case "nexacro 14":
		return "[14]";
		break;
	case "XPLATFORM":
		return "[XP]";
		break;
	case "MiPlatform":
		return "[MI]";
		break;
	default:
	}
}


/******************************************************************************
 * 함수명			: gfn_makeEllipse
 * 설명				: 문자열이 영역 사이즈보다 초과되는 경우, 사이즈에 맞는 
					  문자열을 반환한다.
 * argument			: text - Static 영역에 들어갈 문자열
					  obj  - Static Object
 * return			: String - 영역 너비에 맞는 문자열
 ******************************************************************************/ 
// gfn그대로 적용할 수 없어 재정의해서 사용
this.fn_makeEllipse = function(text, obj, font)
{
	if( !obj ){
		return text;
	}
	
	if (this.gfnIsNull(font)){
		font = 'normal 500 24px/normal "NotoSansKR"';
	}
	var nPaddingLeft = 0;
	var nPaddingRight = 0;
	var sFontInfo = font;
	if (!this.gfnIsNull(obj.padding))
	{
		nPaddingLeft = obj.padding.left;
		nPaddingRight = obj.padding.right
	}
	if (!this.gfnIsNull(obj.font))
	{
		sFontInfo = obj.font;
	}		

 	var _width = obj.getOffsetWidth() - nPaddingLeft - nPaddingRight + 100;
 	
	return this.fn_makeEllipseByWidth(text, _width, sFontInfo);
};


/******************************************************************************
 * 함수명			: gfn_makeEllipseByWidth
 * 설명				: 문자열이 사이즈보다 초과되는 경우, 파라미터로 전달한 
					  사이즈에 맞는 문자열을 반환한다.
 * argument			: text   - 영역에 들어갈 문자열
					  width  - 영역의 너비
					  font   - 문자열의 폰트 객체
 * return			: String - 영역 너비에 맞는 문자열
 ******************************************************************************/ 
this.fn_makeEllipseByWidth = function(text, width, font)
{
	if( !width || ! font)
		return text;
	
	var ellipse		= "...";
	var objWidth	= width;
	
	var textSize	= nexacro.getTextSize(text, font);
	var ellipseSize	= nexacro.getTextSize(ellipse, font);			
	if( textSize.nx <= objWidth )
	{
		return text;
	}
	else
	{
		var hString, tString;
		var subIndex = Math.floor(text.length / 2);
		
		for( var i = subIndex ; i > 0  ; i = Math.floor(i / 2) )
		{	
				
			hString = text.substring(0, subIndex);
			tString = text.substring(subIndex, subIndex + i);
			
			if( nexacro.getTextSize(hString, font).nx + ellipseSize.nx > objWidth )
				subIndex -= i / 2;	//자른 텍스트 길이가 영역 크기보다 초과하는 경우
			else
				subIndex += i / 2;	//자른 텍스트 길이가 영역 크기보다 작은 경우
			
			textSize = nexacro.getTextSize(text.substring(0, subIndex), font);
			
			if( (textSize.nx + ellipseSize.nx) > objWidth )
				subIndex -= i / 2;
		}

		return text.substring(0, subIndex).trim() + ellipse;
	}
};

// BestTip 그리드 셀클릭 화면이동
this.grdTip_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
//	if (e.cell == 2)
//	{
		var sSeq = this.ds_List.getColumn(e.row, "bl_seq");
		var sProd = this.ds_List.getColumn(e.row, "product_nm");
		var sMenu = "";
		switch(sProd) {
		case "Nexacro N":
			sMenu = "Tip_View_N";
			break;
		case "nexacro 17":
			sMenu = "Tip_View_17";
			break;
		case "nexacro 14":
			sMenu = "Tip_View_14";
			break;
		case "XPLATFORM":
			sMenu = "Tip_View_XP";
			break;
		case "MiPlatform":
			sMenu = "Tip_View_MP";
			break;
		default:
		}
		
		nexacro.getApplication().gv_mainFrame.param = {
			'menu': sMenu,
			'keyword': "",
			'page': 1,
			'postId': sSeq
			};
		nexacro.getApplication().gv_mainFrame.gfnGoMain();	
//	}
};

// 인기검색어 조회
this.fn_popularCallData = function()
{
	var strUrl = "url=" + nexacro.getEnvironmentVariable("gv_SearchEngine") + "/tobe_topList&zip=false";
	this.ds_autoComplete.clearData();      
	this.ds_autoResult.clearData();     
	
	this.transaction("selectPopular", nexacro.getEnvironment().services["SVC_JSP"].url + "Next_JSP/SearchEngine/Service/url.jsp?" + strUrl,"","ds_autoComplete=ds_auto","","callback");
}
