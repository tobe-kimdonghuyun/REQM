              <WebBrowser id="webBrowResult2" left="30" top="33" width="1240" taborder="0" onloadcompleted="webBrowResult2_onloadcompleted" onusernotify="webBrowResult2_onusernotify" visible="true" border="0px none" accessibilitylabel="답변" height="200"/>
              <Static id="staResDate" taborder="1" left="49.00" top="webBrowResult2:0" width="117" height="30" cssclass="sta_WF_viewDate" fittocontents="width" accessibilitylabel="등록일"/>
