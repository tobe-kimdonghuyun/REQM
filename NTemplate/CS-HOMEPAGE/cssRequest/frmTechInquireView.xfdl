        <WebBrowser id="webBrowResult" left="0" top="staResTitle:80" width="1300" height="0" taborder="9" onloadcompleted="webBrowResult_onloadcompleted" onusernotify="webBrowResult_onusernotify" visible="true" border="0px none" accessibilitylabel="내용"/>
