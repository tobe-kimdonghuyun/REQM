              <Button id="btnAttachFileRes" taborder="7" text="attadfgdfgfdgdfgdfgdfgdfgdfgchfile.7z" top="webBrowResult2:0" width="400" cssclass="btn_WF_attatchR" fittocontents="width" right="51" visible="true" maxwidth="650" minwidth="" onclick="divTreat_btnAttachFileRes_onclick" height="30"/>
              <Div id="divFiles" taborder="8" top="btnAttachFileRes:0" width="230" height="180" accessibilityenable="false" right="51" maxheight="102" minheight="" cssclass="div_WF_result">
                <Layouts>
                  <Layout>
                    <Grid id="grdFiles" taborder="0" left="20.00" top="10" binddataset="ds_downloadfile_res" autofittype="col" right="20" bottom="10" cssclass="grd_WF_hisMenu" oncellclick="pdivFiles_grdFiles_oncellclick" accessibilitylabel="첨부파일 목록" selecttype="cell">
