                          <Columns>
                            <Column size="153"/>
                            <Column size="35"/>
                            <Column size="35"/>
                          </Columns>
                          <Rows>
                            <Row size="40"/>
                          </Rows>
                          <Band id="body" accessibilityenable="false">
                            <Cell text="expr:comp.parent.parent.parent.gfn_makeEllipse(FILE_NAME, comp)" tooltiptext="bind:FILE_NAME" accessibilitylabel="bind:FILE_NAME" accessibilitydescription="다운로드"/>
                            <Cell col="1" text="bind:Column1" cssclass="grd_WF_down" accessibilitylabel="첨부파일" accessibilitydescription="다운로드" edittype="button" displaytype="buttoncontrol"/>
                            <Cell col="2" cssclass="grd_WF_view" accessibilitylabel="expr:dataset.parent.fn_exprFileChkRes(currow)?'파일 소스보기':''" accessibilityenable="expr:dataset.parent.fn_exprFileChkRes(currow)?'true':'false'" displaytype="buttoncontrol" edittype="button"/>
