<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="techinquireView" width="1300" height="1820" titletext="New Form" onload="techinquireView_onload" scrollbarsize="0" ontimer="techinquireView_ontimer">
