this.cboListType_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	var sFlag = nexacro.getApplication().gv_mainFrame.SearchEngineFlag;
	
	if (e.postindex == 0)
	{
		nexacro.getApplication().gv_mainFrame.QA_Cond_ListType = 0;
		sFlag == "Tip"? this.fn_createBoardList() : this.fn_createTechInquireList();
		sFlag == "Tip"? this.fn_SetInitSize_Board() : this.fn_SetInitSize_Inq();
	}
	else
	{
		nexacro.getApplication().gv_mainFrame.QA_Cond_ListType = 1;
		sFlag == "Tip"? this.fn_createBoardList() : this.fn_createTechInquireList();
		sFlag == "Tip"? this.fn_SetInitSize_Board() : this.fn_SetInitSize_Inq();
	}
};
