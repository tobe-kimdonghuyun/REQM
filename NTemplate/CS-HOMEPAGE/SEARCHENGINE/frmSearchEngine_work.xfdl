/************************************************************************
 * ↓↓↓↓↓↓ 여기부터 frmBoardList ↓↓↓↓↓↓
 ************************************************************************/
this.frmBoardList_onload = function()
{
	this.fvListType = "Board";
	this.divInquireList.visible = false;
	this.viewList.visible = true;

	// 페이징 초기화
	nexacro.getApplication().gv_mainFrame.QA_Cond_Page = 1;    
	nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = 0;
	
	// History에 기억된 keyword나 page가 있으면 셋팅
	if (!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.param.page))
	{
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = nexacro.getApplication().gv_mainFrame.param.page;
		nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = nexacro.floor(nexacro.getApplication().gv_mainFrame.QA_Cond_Page/10);
	}

	this.fn_search(nexacro.getApplication().gv_mainFrame.QA_Cond_Page);
};


this.fn_searchEngineCall_Board = function ()
{
	this.ds_NoticeList.clearData();
	var dsSE = "";
	
	switch(nexacro.getApplication().gv_mainFrame.SearchEngineFlag) {
	case "Tip":
		dsSE = nexacro.getApplication().gv_searchEngine.ds_bbs_tip;
		break;
	case "Education_Notice":
		dsSE = nexacro.getApplication().gv_searchEngine.ds_bbs_edu_notice;
		break;
	case "Education_material":
		dsSE = nexacro.getApplication().gv_searchEngine.ds_bbs_edu_resource;
		break;
	case "Notice":
		dsSE = nexacro.getApplication().gv_searchEngine.ds_bbs_notice;
		break;
	default:
	}
	
	this.ds_NoticeList.copyData(dsSE);
	
	if (this.ds_NoticeList.rowcount == 0)
	{
		this.viewPaging.set_visible(false);
		this.fn_createBoardList();
		this.fn_SetInitSize_Board();
		return;
	}
	else
	{
		this.fn_createBoardList();
		this.viewPaging.set_visible(true);
	}
	
	// 키워드강조하기
	this.keywordall = nexacro.getApplication().gv_searchEngine.fvKeyword;
	if (!this.gfnIsNull(this.keywordall))
	{
		var sKeyWord = this.keywordall.replaceAll(" ", "|");
		var objRegExp = new RegExp('('+sKeyWord+')', 'gi');
		
		var sSubject;
		var sContents;
		
		this.ds_NoticeList.set_enableevent(false);
		
		// 키워드강조하기
		if (!this.gfnIsNull(sKeyWord))
		{
			if (nexacro.getApplication().gv_searchEngine.divSearch.form.rdoField.value == "title")		// 제목만
			{
				for (var i = 0; i < this.ds_NoticeList.rowcount; i++)
				{
					sSubject = this.ds_NoticeList.getColumn(i, "SUBJECT");
					sSubject = sSubject.toString().replace(objRegExp, "<fc v='#ff0000'>"+"$&"+"</fc>");
					this.ds_NoticeList.setColumn(i, "SUBJECT", sSubject);
				}
			}
			else 	// 제목+내용
			{
				for (var i = 0; i < this.ds_NoticeList.rowcount; i++)
				{
					sSubject = this.ds_NoticeList.getColumn(i, "SUBJECT");
					sContents = this.ds_NoticeList.getColumn(i, "CONTENTS");
					
					sSubject = sSubject.toString().replace(objRegExp, "<fc v='#ff0000'>"+"$&"+"</fc>");
					sContents = sContents.toString().replace(objRegExp, "<fc v='#ff0000'>"+"$&"+"</fc>");
					
					this.ds_NoticeList.setColumn(i, "SUBJECT", sSubject);
					this.ds_NoticeList.setColumn(i, "CONTENTS", sContents);
				}
			}
		}
		this.ds_NoticeList.set_enableevent(true);
	}
	
	// 히스토리 저장
	this.fn_SetHistoryData();
	
	this.fn_SetInitSize_Board();
	
	// 저장된 스크롤 위치가 있으면 이동
	nexacro.getApplication().gv_mainFrame.vscrollbar.set_pos(nexacro.getApplication().gv_mainFrame.SCROLL_POS);
	nexacro.getApplication().gv_mainFrame.SCROLL_POS = 0;
};


this.fn_createBoardList = function()
{
	var flag = nexacro.getApplication().gv_mainFrame.SearchEngineFlag;
	var nRowCnt = this.ds_NoticeList.rowcount;
	
	var nLeft 	= 0;
	var nTop 	= 0;
	var nHeight = 226;
	var nRight 	= 0;
	var sDivId 	= "divNoticeList";
	var sUrl 	= "";
	
 	switch(flag) {
 	case "Tip":
 		sUrl = this.cboListType.index==0? "BOARD::frmBoardList_01_Tip.xfdl":"BOARD::frmBoardList_03_Title.xfdl";
		nHeight = this.cboListType.index==0? 226:130;
 		break;
 	case "Education_Notice":
 	case "Education_material":
 	case "Notice":
 		 sUrl = "BOARD::frmBoardList_02_Notice.xfdl";
		nHeight = 85;
 		break;
 	default:
 	}
	
	var nLen = this.viewList.form.divNoticeList.form.components.length;
	for (var i = nLen - 1; i >= 0; i--) {
		var objDel = this.viewList.form.divNoticeList.removeChild(this.viewList.form.divNoticeList.form.components[i].name);
		objDel.destroy();
		objDel = null;		
	}
	
	if (nRowCnt > 0) {
		this.viewList.form.divNoticeList.accessibilityenable = false;
		this.viewList.form.divNoticeList.text = "";
		
		
		for (var i = 0; i < nRowCnt; i++) {
			var newDiv = new Div();
			newDiv.init(sDivId + i, nLeft, nTop, null, nHeight, nRight);
			this.viewList.form.divNoticeList.addChild(newDiv.id, newDiv);
			newDiv.set_url(sUrl);
			newDiv.set_accessibilityenable(false);
			newDiv.show();
			
			if (i != 0) newDiv.prevDiv = this.viewList.form.divNoticeList.form.components[sDivId + (i-1)];
			if (!this.gfnIsNull(newDiv.prevDiv))  newDiv.set_top(newDiv.prevDiv.id+":0");			
			
			nTop = nTop + nHeight;
		}
  		var lastDiv = this.viewList.form.divNoticeList.form.components[sDivId + (nRowCnt-1)];
  		
  		this.viewList.form.divNoticeList.set_height();
  		this.viewList.set_height(lastDiv.getOffsetBottom());
		this.resetScroll();
	}
};


// 사이즈 초기화
this.fn_SetInitSize_Board = function()
{
	this.nGrdSize = 0;

	var flag = nexacro.getApplication().gv_mainFrame.SearchEngineFlag;
	var nDivHeight = 0;
	switch(flag) {
 	case "Tip":
		nDivHeight = this.cboListType.index==0? 226 : 130;
 		break;
 	case "Education_Notice":
 	case "Education_material":
 	case "Notice":
		nDivHeight = 85;
 		break;
 	default:
 	}
	
	this.nDivRightHeight = 1037;
	
	this.nGrdSize = this.ds_NoticeList.getRowCount() * nDivHeight;
	
	// 그리드 전체 사이즈 구하는 함수
	if(this.nGrdSize < this.nDivRightHeight)
	{
		this.viewList.set_height(this.nGrdSize);
		this.viewPaging.set_top(this.viewList.getOffsetBottom() + 40);
		this.divRight.set_height(this.nDivRightHeight);
		this.resetScroll();
		
		this.fvWorkHeight = 280 + parseInt(this.nDivRightHeight) + 40 + 40 + 12;
		nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, this.fvWorkHeight);
		if(this.ds_NoticeList.rowcount <= 0)
		{
			this.viewList.set_height(this.nDivRightHeight);
		}
	}
	else
	{
		this.viewList.set_height(this.nGrdSize);
		this.viewPaging.set_top(this.viewList.getOffsetBottom() + 40);
		this.divRight.set_height(this.nGrdSize);
		this.resetScroll();
		
		this.fvWorkHeight = 280 + this.nGrdSize + 40 + 50 + 76;
		nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, this.fvWorkHeight);
	}
};



//제목 클릭
this.fn_BoardstaTitle_onclick = function(nRow, gubun)
{       
	var nFindRow = nexacro.getApplication().gv_mainFrame.dsScreenUrl.findRow("subCatgy", nexacro.getApplication().gv_mainFrame.param.menu);
	var sLayout = nexacro.getApplication().gv_mainFrame.dsScreenUrl.getColumn(nFindRow, "Layout");
		
	if(sLayout == "BOOKMARK")
	{
		nexacro.getApplication().gv_BookmarkTipCd = nexacro.getApplication().gv_mainFrame.divMain.form.divBookmark.form.tabProduct.tabindex;
	}

 
	nexacro.getApplication().gv_mainFrame.Board_Cond_Resetflag = false;
	//var dsDataCur = eval("this."+obj.binddataset);
	var dsDataCur = this.ds_NoticeList;
	this.rowNum = dsDataCur.getColumn(nRow, "rowNum");
	var strAn = dsDataCur.getColumn(nRow, "BL_SEQ");
	var strBoardid = dsDataCur.getColumn(nRow, "boardid");
	var strGoodsgbn = dsDataCur.getColumn(nRow,"goods_gbn");

	var ProductGubun="MiPlatform";
	if(strGoodsgbn  == "001")
	{
		ProductGubun = "MiPlatform";		
	} else if(strGoodsgbn == "002")
	{
		ProductGubun = "XPLATFORM";		
	} else if(strGoodsgbn == "003")
	{   
		ProductGubun = "X-UP(difingo)";		
	} else if(strGoodsgbn == "004")   
	{
		ProductGubun = "X-PUP";		
	} else if(strGoodsgbn == "005")
	{ 
		ProductGubun = "X-PUSH";		
	} else if(strGoodsgbn == "006")
	{
		ProductGubun = "nexacro platform";		
	} else if(strGoodsgbn == "008")
	{
		ProductGubun = "nexacro platform17";		
	}  
	
	nexacro.getApplication().gv_mainFrame.strTempFilder1 = strAn;  
	nexacro.getApplication().gv_mainFrame.BoardCategoryID = strGoodsgbn;       
   
// 	nexacro.getApplication().gv_mainFrame.Board_Cond_DisplayCnt  = this.divPageExpr.unitSelRowNo;
// 	nexacro.getApplication().gv_mainFrame.Board_Cond_Page        = (this.divPageExpr.startPageNo+1); 
	nexacro.getApplication().gv_mainFrame.Board_Cond_Searchfield = this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition,"searchfield");
	nexacro.getApplication().gv_mainFrame.Board_Cond_Searchgubun = this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition,"searchgubun");
	nexacro.getApplication().gv_mainFrame.Board_Cond_BusinessSection = this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition,"BusinessSection");
	nexacro.getApplication().gv_mainFrame.Board_Cond_Resort = this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition,"search_resort");	
	nexacro.getApplication().gv_mainFrame.Board_Cond_Keyword = this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition,"keyword");	  
	nexacro.getApplication().gv_mainFrame.Board_Cond_KeywordAll = this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition,"keywordall");	  

	// sMenu 셋팅
	var sMenu = "Notice_View";
	switch(nexacro.getApplication().gv_mainFrame.PCategory2) {
	case "Notice":
		sMenu = "Notice_View";
		break;
	case "Tip_N":
		sMenu = "Tip_View_N";
		break;
	case "Tip_17":
		sMenu = "Tip_View_17";
		break;
	case "Tip_14":
		sMenu = "Tip_View_14";
		break;
	case "Tip_XP":
		sMenu = "Tip_View_XP";
		break;
	case "Tip_MP":
		sMenu = "Tip_View_MP";
		break;
	case "Education_information":
		sMenu = "Education_information_View";
		break;
	case "Education_material":
		sMenu = "Education_material_View";
		break;
	case "Education_Review":
		sMenu = "Education_Review_View";
		break;
	case "Bookmark_Tip":
		sMenu = "Bookmark_Tip_View";
		nexacro.getApplication().gv_mainFrame.Bookmark_Tab_Index = nexacro.getApplication().gv_mainFrame.divMain.form.divBookmark.form.tabProduct.tabindex;
		break;
	case "SearchEngine":
		sMenu = "SearchEngine_Board_View";
		break;
	default:
	}
	
	// 현재 스크롤 위치 저장
	nexacro.getApplication().gv_mainFrame.SCROLL_POS = nexacro.getApplication().gv_mainFrame.vscrollbar.pos;
	
	nexacro.getApplication().gv_mainFrame.param = {
		'menu': sMenu,
		'keyword': nexacro.getApplication().gv_mainFrame.QA_Cond_Keyword,
		'page': nexacro.getApplication().gv_mainFrame.QA_Cond_Page,
		'postId': strAn
		};
	nexacro.getApplication().gv_mainFrame.gfnGoMain();
};


//링크복사 버튼 클릭
this.btnLink_onclick = function(nRow)
{
	var sMenu = nexacro.getApplication().gv_mainFrame.PCategory2.substr(0, 3)+"_View" +nexacro.getApplication().gv_mainFrame.PCategory2.substr(3);
	prompt("클립 보드에 복사하세요 : Ctrl 키 + C", nexacro.getApplication().gv_DomainInfo+"?menu="+sMenu+"&postid="+this.ds_NoticeList.getColumn(nRow, "BL_SEQ"));
};

/************************************************************************
 * ↑↑↑↑↑↑ 여기까지 frmBoardList ↑↑↑↑↑↑↑↑
 ************************************************************************/


this.div_autoCompleteCover_onclick = function(obj:nexacro.Div,e:nexacro.ClickEventInfo)
{
	nexacro.getApplication().gv_mainFrame.div_autoCompleteCover_onclick();
};
this.div_autoCompleteCover_onkillfocus = function(obj:nexacro.Div,e:nexacro.KillFocusEventInfo)
{
	nexacro.getApplication().gv_mainFrame.div_autoCompleteCover_onkillfocus();
};

]]></Script>
  </Form>
</FDL>
