	{
		rtn = "sta_WF_ConTitle";
	}
	//trace(rtn);
	return rtn;
}


this.fn_InqstaTitle_onclick = function (ds, nIdx)
{		
	var dsDataCur = ds;
	
	var strIdx = dsDataCur.getColumn(nIdx, "QL_SEQ");
	
	nexacro.getApplication().gv_mainFrame.TargetPostId = strIdx;

	//이전글,다음글 번호 저장
	nexacro.getApplication().gv_mainFrame.arrIdx[0] = dsDataCur.getColumn(nIdx-1, "QL_SEQ"); //다음글
	nexacro.getApplication().gv_mainFrame.arrIdx[1] = dsDataCur.getColumn(nIdx+1, "QL_SEQ"); //이전글
	
	nexacro.getApplication().gv_mainFrame.strTempFilder1 = strIdx;

	nexacro.getApplication().gv_mainFrame.QA_Cond_Searchfield = this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition, "searchfield");
	nexacro.getApplication().gv_mainFrame.QA_Cond_Searchgubun = this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition, "searchgubun");
	nexacro.getApplication().gv_mainFrame.QA_Cond_BusinessSection = this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition, "BusinessSection");
	nexacro.getApplication().gv_mainFrame.QA_Cond_Resort = this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition, "search_resort");
	nexacro.getApplication().gv_mainFrame.QA_Cond_Keyword = this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition, "keyword");
	nexacro.getApplication().gv_mainFrame.QA_Cond_KeywordAll = this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition, "keywordall");

	var nRow = nexacro.getApplication().gv_mainFrame.dsScreenUrl.findRow("subCatgy", nexacro.getApplication().gv_mainFrame.param.menu);
	var sLayout = nexacro.getApplication().gv_mainFrame.dsScreenUrl.getColumn(nRow, "Layout");
	
	if(sLayout == "MYQNALIST" || sLayout == "BOOKMARK")
	{
		nexacro.getApplication().gv_BookmarkTipCd = nexacro.getApplication().gv_mainFrame.divMain.form.divBookmark.form.tabProduct.tabindex;
	}
	
	var sMenu = "QnA_View";
	if (nexacro.getApplication().gv_mainFrame.PCategory2 == "Bookmark")
	{
		sMenu = "Bookmark_View";
		nexacro.getApplication().gv_mainFrame.Bookmark_Tab_Index = nexacro.getApplication().gv_mainFrame.divMain.form.divBookmark.form.tabProduct.tabindex;
	}
	else if (nexacro.getApplication().gv_mainFrame.PCategory2 == "MyQnAList")
	{
		sMenu = "MyQnAList_View";
		nexacro.getApplication().gv_mainFrame.My_Tab_Index = nexacro.getApplication().gv_mainFrame.divMain.form.divBookmark.form.tabProduct.tabindex;
	}
	else if (nexacro.getApplication().gv_mainFrame.PCategory2 == "SearchEngine")
	{
		sMenu = "SearchEngine_QnA_View";
	}
	
	var strCode =  dsDataCur.getColumn(nIdx, "PRODUCT_CODE");	
	if (strCode == "044")
	{
		sMenu = "Sketch_View";
	}
	else if (strCode == "045")
	{
		sMenu = "Tutorial_View";
	}	

	// 현재 스크롤 위치 저장
	nexacro.getApplication().gv_mainFrame.SCROLL_POS = nexacro.getApplication().gv_mainFrame.vscrollbar.pos;

	nexacro.getApplication().gv_mainFrame.param = {
		'menu': sMenu,
		'keyword': nexacro.getApplication().gv_mainFrame.QA_Cond_Keyword,
		'page': nexacro.getApplication().gv_mainFrame.QA_Cond_Page,
		'postId': strIdx,
		'gbn': nexacro.getApplication().gv_mainFrame.PCategory2
		};
	nexacro.getApplication().gv_mainFrame.gfnGoMain();
};
