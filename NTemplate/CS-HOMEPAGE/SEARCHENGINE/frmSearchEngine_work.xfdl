    <Bind/>
    <Script type="xscript5.1"><![CDATA[/**
*  QnA리스트
*
*  @MenuPath 
*  @FileName 		SUPPORT::frmTechInquireList.xfdl 
*  @Creator 		김광호
*  @CreateDate 		2022.01.01
*  @LastModifier  
*  @LastModifyDate  
*  @Version 		1.0
*  @Outline 		QnA리스트
*  @Desction 
************** 소스 수정 이력 *************************************************
*    date          Modifier            Description
*******************************************************************************
*  2022.01.01      김광호	           최초 생성 
*******************************************************************************
*/

this.user_id = "";			// 투비직원여부를 위한 user id

this.keywordall = "";		// 검색어

this.tobe_yn = false;		// 투비직원 여부

this.TotalCnt = "";			// 나의질문내역&북마크 에서 토탈건수로 페이징 보정
this.fvTotalN = 0;			// 각 총건수
this.fvTotal17 = 0;
this.fvTotal14 = 0;
this.fvTotalXP = 0;
this.fvTotalMP = 0;
this.fvTotalAll = 0;

this.nDivRightHeight = 0;	// RightFrame의 높이

this.fromDate = "";			// 조회조건 시작날짜
this.toDate = "";			// 조회조건 종료날짜

this.fvBookCD = 0;			// 북마크 코드



//SearchEngine 폼변수
this.collection = "mng_nexacroN";	// 통합검색 조회 조건 제품 //"mng_nexacroN,mng_nexacro17,mng_nexacro14,mng_xplatform,mng_miplatform,bbs_tip,bbs_edu_notice,bbs_edu_resource,bbs_notice";
this.Search_query = ""; 
this.Search_oquery = ""; 
this.fvListSize = 10;
this.fvPageNum = 1;
this.fvSelectedTotal = 0;
this.fvFocus = "NPN";
this.fvKeyword = "";
this.fvTab = 1;

// 높이 저장
this.fvSearchOpen = 244;
this.fvSearchClose = 0;
this.fvWorkHeight = 0;



//TechInquire/Board 구분
this.fvListType = "Inq";


this.frmSearchEngine_work_onload = function (obj:Form, e:nexacro.LoadEventInfo)
{
	nexacro.getApplication().gv_searchEngine = this;
	this.searchEngine_onload();
};


/************************************************************************
 * ↓↓↓↓↓↓ 여기부터 frmSearchEngine ↓↓↓↓↓↓
 ************************************************************************/
this.searchEngine_onload = function()
{
	nexacro.getApplication().gv_mainFrame.QA_Cond_Page = 1;
	nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = 0;

	// 초기 검색어 셋팅
	if (!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.param.keyword))
	{
		this.edtSearch.set_value(nexacro.getApplication().gv_mainFrame.param.keyword);
	}
	if (!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.param.page))
	{
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = nexacro.getApplication().gv_mainFrame.param.page;
		nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = nexacro.floor(nexacro.getApplication().gv_mainFrame.QA_Cond_Page/10);
	}
	
	// 브라우저 히스토리를 사용하기 위해 조건 데이터 저장 불러오기
	var sData = nexacro.getApplication().gv_mainFrame.gfnGetHistoryData();
	if (!this.gfnIsNull(sData))
	{
		// 히스토리 sData에서 불러오기
		if (!this.gfnIsNull(sData.rdoField)){	this.divSearch.form.rdoField.set_value(sData.rdoField); }
		if (!this.gfnIsNull(sData.rdoOperator)){	this.divSearch.form.rdoOperator.set_value(sData.rdoOperator); }
		if (!this.gfnIsNull(sData.rdoTerm)){	this.divSearch.form.rdoTerm.set_value(sData.rdoTerm); }
		if (!this.gfnIsNull(sData.calStart)){	this.divSearch.form.calStart.set_value(sData.calStart); }
		if (!this.gfnIsNull(sData.calEnd)){	this.divSearch.form.calEnd.set_value(sData.calEnd); }
		if (!this.gfnIsNull(sData.filterst)){nexacro.getApplication().gv_mainFrame.filterst = sData.filterst}else{nexacro.getApplication().gv_mainFrame.filterst="close"};
		if (!this.gfnIsNull(sData.SearchEngineFlag)){nexacro.getApplication().gv_mainFrame.SearchEngineFlag = sData.SearchEngineFlag};
	}
	// 초기값
	if (this.gfnIsNull(nexacro.getApplication().gv_mainFrame.SearchEngineFlag))
	{
		nexacro.getApplication().gv_mainFrame.SearchEngineFlag = "Nexacro N";	//"ALL";
	}
	
	this.fvFocus = "NPN";
	this.fn_selectProduct();
	nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, 1850);
};

this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fn_search(1);
};

// 검색
this.fn_search = function(pageNum)
{
	// 현재 페이지 공통에 저장
	nexacro.getApplication().gv_mainFrame.QA_Cond_Page = pageNum;

	// 히스토리 관리를 위해 검색조건 저장
	this.fn_saveHistoryData();
	
	this.fvPageNum = pageNum;
	
	nexacro.getApplication().gv_mainFrame.showAutoCompleteResult(false);
	
	// 검색
	var strUrl = "url=" + nexacro.getEnvironmentVariable("gv_SearchEngine") + "/tobe_list&zip=false";
	if (!this.gfnIsNull(this.edtSearch.value))
	{
		this.fvKeyword = this.edtSearch.value.trim();
	}
	else
	{
		this.fvKeyword = "";
	}
	
	// 번호일때 숫자 체크
	if (this.divSearch.form.rdoField.value == "num")
	{
		var chkNo = /^\d+$/.test(this.fvKeyword);
		if (this.gfnIsNull(this.fvKeyword) || chkNo == false)	// 검색조건(번호) & 번호가 아닐때
		{
			alert("번호를 입력해주세요.");
			return;
		}
	}

	if( this.gfnIsNull(this.fvKeyword) ) this.fvKeyword = "";

	var strDsOutput = "ds_bbsResult=ds_bbsResult ";

	switch(nexacro.getApplication().gv_mainFrame.SearchEngineFlag) {
	case "Nexacro N":
		strDsOutput += "ds_mng_nexacroN=mng_nexacroN ";
		this.collection = "mng_nexacroN";
		break;
	case "nexacro platform17":
		strDsOutput += "ds_mng_nexacro17=mng_nexacro17 ";
		this.collection = "mng_nexacro17";
		break;
	case "nexacro platform14":
		strDsOutput += "ds_mng_nexacro14=mng_nexacro14 ";
		this.collection = "mng_nexacro14";
		break;
	case "XPLATFORM":
		strDsOutput += "ds_mng_xplatform=mng_xplatform ";
		this.collection = "mng_xplatform";
		break;
	case "MiPlatform":
		strDsOutput += "ds_mng_miplatform=mng_miplatform ";
		this.collection = "mng_miplatform";
		break;
	case "Tip":
		strDsOutput += "ds_bbs_tip=bbs_tip ";
		this.collection = "bbs_tip";
		break;
	case "Education_Notice":
		strDsOutput += "ds_bbs_edu_notice=bbs_edu_notice ";
		this.collection = "bbs_edu_notice";
		break;
	case "Education_material":
		strDsOutput += "ds_bbs_edu_resource=bbs_edu_resource ";
		this.collection = "bbs_edu_resource";
		break;
	case "Notice":
		strDsOutput += "ds_bbs_notice=bbs_notice ";
		this.collection = "bbs_notice";
		break;
	default:
	}
	strDsOutput += "ds_condition=ds_condition";
	
	
	var arg = 	"query='" + this.fvKeyword + "'" ; //검색어	
		arg +=	" collection=" + this.collection; //ALL, bbs_notice, mng_nexacro14, mng_nexacro14, mng_xplatform, mng_nexacroN 등등 - 게시판 단일, n개, 전체
		arg +=	" oquery=" + this.Search_oquery; //이전 검색어 - 연관 검색어 관련 필요!
		arg +=	" startDate=" + this.divSearch.form.calStart.text; // 시작 날짜 - 2021-01-01 
		arg +=	" endDate=" + this.divSearch.form.calEnd.text; // 끝 날짜 - 2022-08-01 
		arg +=	" operator=" + this.divSearch.form.rdoOperator.value; //and, or 택1 조회조건2 연산자 - and = true, or = false 				
		arg +=	" field=" + this.divSearch.form.rdoField.value; // 제목+내용, 제목, 번호 택1 조회조건 - 제목+내용 = all, 제목 = title, 번호 = num				
		arg +=	" listSize="+this.fvListSize; // 페이지 목록 개수 - 화면에 표출되는 해당 페이지에 나올 목록 개수
		arg +=	" pageNum="+pageNum; // 페이지 - 1, 2 화면에 표출되는 해당 페이지 번호
		arg +=  " sort=DATE/DESC";	// 날짜순으로 정렬되도록 추가함

	this.transaction("select",nexacro.getEnvironment().services["SVC_JSP"].url + "Next_JSP/SearchEngine/Service/url.jsp?"+ strUrl, "", strDsOutput, arg, "callbackSearchComplete");	// 개발
};

// 새로고침을 대비해 검색 데이터 저장
this.fn_saveHistoryData = function()
{
	nexacro.getApplication().gv_mainFrame.param.keyword = this.edtSearch.value;
	// 히스토리 sData에 저장
	var sData = {
	rdoField:this.divSearch.form.rdoField.value
	,rdoOperator:this.divSearch.form.rdoOperator.value
	,rdoTerm:this.divSearch.form.rdoTerm.value
	,calStart:this.divSearch.form.calStart.value
	,calEnd:this.divSearch.form.calEnd.value
	,filterst:nexacro.getApplication().gv_mainFrame.filterst
	,SearchEngineFlag:nexacro.getApplication().gv_mainFrame.SearchEngineFlag
	};
	nexacro.getApplication().gv_mainFrame.gfnSetHistoryData(sData);
};

