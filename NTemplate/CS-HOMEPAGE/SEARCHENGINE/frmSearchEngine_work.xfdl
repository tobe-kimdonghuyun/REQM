// 검색조건 초기화
this.divSearch_btnClear_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divSearch.form.rdoField.set_value("title");
	this.divSearch.form.rdoOperator.set_value(false);
	this.divSearch.form.rdoTerm.set_value(0);
	
	this.divSearch.form.calStart.set_value("");
	this.divSearch.form.calEnd.set_value("");
	
	this.edtSearch.set_value("");
	
	this.fn_search(1);
};

// 통합검색 조회 콜백
this.callbackSearchComplete = function(id, code, msg)
{
	if( id == "select" ){	
		this.Search_oquery = this.Search_query;
		var totalCnt = this.ds_bbsResult.getCaseSum("COLLECTION_CODE=='mng_nexacroN'||COLLECTION_CODE=='mng_nexacro17'||COLLECTION_CODE=='mng_nexacro14'||COLLECTION_CODE=='mng_xplatform'||COLLECTION_CODE=='mng_miplatform'||COLLECTION_CODE=='bbs_tip'||COLLECTION_CODE=='bbs_edu_notice'||COLLECTION_CODE=='bbs_edu_resource'||COLLECTION_CODE=='bbs_notice'","CNT");
		if (this.gfnIsNull(this.edtSearch.value)) {this.edtSearch.value = "";}
		
		var nNpN = this.fn_SetFormatNumber("mng_nexacroN");
		var nNp17 = this.fn_SetFormatNumber("mng_nexacro17");
		var nNp14 = this.fn_SetFormatNumber("mng_nexacro14");
		var nXp = this.fn_SetFormatNumber("mng_xplatform");
		var nMp = this.fn_SetFormatNumber("mng_miplatform");
		var nTip = this.fn_SetFormatNumber("bbs_tip");
		var nEduno = this.fn_SetFormatNumber("bbs_edu_notice");
		var nEdures = this.fn_SetFormatNumber("bbs_edu_resource");
		var nNotice = this.fn_SetFormatNumber("bbs_notice");

		// 데이터가 0건일때 이상한 데이터가 들어오던 문제 해결
		if(nNpN == 0){this.ds_mng_nexacroN.clearData()}
		if(nNp17 == 0){this.ds_mng_nexacro17.clearData()}
		if(nNp14 == 0){this.ds_mng_nexacro14.clearData()}
		if(nXp == 0){this.ds_mng_xplatform.clearData()}
		if(nMp == 0){this.ds_mng_miplatform.clearData()}
		if(nTip == 0){this.ds_bbs_tip.clearData()}
		if(nEduno == 0){this.ds_bbs_edu_notice.clearData()}
		if(nEdures == 0){this.ds_bbs_edu_resource.clearData()}
		if(nNotice == 0){this.ds_bbs_notice.clearData()}
		if(totalCnt==0||(this.fvFocus == "NP17"&&nNp17 ==0)||(this.fvFocus == "NP14"&&nNp14 ==0)||(this.fvFocus == "XP"&&nXp ==0)
		||(this.fvFocus == "MP"&&nMp ==0)||(this.fvFocus == "TIP"&&nTip ==0)||(this.fvFocus == "EDUNO"&&nEduno ==0)
		||(this.fvFocus == "EDURES"&&nEdures ==0)||(this.fvFocus == "NOTICE"&&nNotice ==0)){this.fvFocus="NPN"};
		
		// 제품 탭 조정 및 전체건수 표시
		if (nNpN == 0) {
			this.divResult.form.btnNexacroN.set_text("Nexacro N\n("+ nNpN +")");
			this.divResult.form.btnNexacroN.set_enable(false);
			if(this.fvFocus=="NPN"&&totalCnt != 0){
				this.fvFocus="NP17";
			}
		}else{
			this.divResult.form.btnNexacroN.set_text("Nexacro N\n("+ nNpN +")");
			this.divResult.form.btnNexacroN.set_enable(true);		
			if(this.fvFocus =="NPN"&&this.divResult.form.btnNexacroN.cssclass!="btn_WF_resultTab_S"){
				this.divResult.form.btnNexacroN.click();
			}
			if(this.fvFocus == "NPN") {
				this.divResult.form.btnNexacroN.set_accessibilitylabel("선택");
			}
		}
		if(nNp17 == 0){
			this.divResult.form.btnNexacro17.set_text("nexacro 17\n("+ nNp17 +")");
			this.divResult.form.btnNexacro17.set_enable(false);
			if(this.fvFocus=="NP17"){
				this.fvFocus="NP14";
			}
		}else{
			this.divResult.form.btnNexacro17.set_text("nexacro 17\n("+ nNp17 +")");
			this.divResult.form.btnNexacro17.set_enable(true);		
			if(this.fvFocus =="NP17"&&this.divResult.form.btnNexacro17.cssclass!="btn_WF_resultTab_S"){
				this.divResult.form.btnNexacro17.click();
			}
			if(this.fvFocus == "NP17") {
				this.divResult.form.btnNexacro17.set_accessibilitylabel("선택");
			}			
		}
		if(nNp14 == 0){
			this.divResult.form.btnNexacro14.set_text("nexacro 14\n("+ nNp14 +")");
			this.divResult.form.btnNexacro14.set_enable(false);
			if(this.fvFocus=="NP14"){
				this.fvFocus="XP";
			}
		}else{
			this.divResult.form.btnNexacro14.set_text("nexacro 14\n("+ nNp14 +")");
			this.divResult.form.btnNexacro14.set_enable(true);		
			if(this.fvFocus =="NP14"&&this.divResult.form.btnNexacro14.cssclass!="btn_WF_resultTab_S"){
				this.divResult.form.btnNexacro14.click();
			}
			if(this.fvFocus == "NP14") {
				this.divResult.form.btnNexacro14.set_accessibilitylabel("선택");
			}				
		}
		if(nXp == 0){
			this.divResult.form.btnXP.set_text("XPLATFORM\n("+ nXp +")");
			this.divResult.form.btnXP.set_enable(false);
			if(this.fvFocus=="XP"){
				this.fvFocus="MP";
			}
		}else{
			this.divResult.form.btnXP.set_text("XPLATFORM\n("+ nXp +")");
			this.divResult.form.btnXP.set_enable(true);		
			if(this.fvFocus =="XP"&&this.divResult.form.btnXP.cssclass!="btn_WF_resultTab_S"){
				this.divResult.form.btnXP.click();
			}
			if(this.fvFocus == "XP") {
				this.divResult.form.btnXP.set_accessibilitylabel("선택");
			}					
		}
		if(nMp == 0){
			this.divResult.form.btnMP.set_text("MiPlatform\n("+ nMp +")");
			this.divResult.form.btnMP.set_enable(false);
			if(this.fvFocus=="MP"){
				this.fvFocus="TIP";
			}
		}else{
			this.divResult.form.btnMP.set_text("MiPlatform\n("+ nMp +")");
			this.divResult.form.btnMP.set_enable(true);		
			if(this.fvFocus =="MP"&&this.divResult.form.btnMP.cssclass!="btn_WF_resultTab_S"){
				this.divResult.form.btnMP.click();
			}
			if(this.fvFocus == "XP") {
				this.divResult.form.btnMP.set_accessibilitylabel("선택");
			}				
		}
		if (nTip == 0) {
			this.divResult.form.btnTip.set_text("Tip\n("+ nTip +")");
			this.divResult.form.btnTip.set_enable(false);
			if (this.fvFocus=="TIP") {
				this.fvFocus="EDUNO";
			}
		} else {
			this.divResult.form.btnTip.set_text("Tip\n("+ nTip +")");
			this.divResult.form.btnTip.set_enable(true);
			if(this.fvFocus =="TIP"&&this.divResult.form.btnTip.cssclass!="btn_WF_resultTab_S"){
				this.divResult.form.btnTip.click();
			}
			if(this.fvFocus == "TIP") {
				this.divResult.form.btnTip.set_accessibilitylabel("선택");
			}				
		}
		if(nEduno == 0){
			this.divResult.form.btnEduNotice.set_text("교육공지\n("+ nEduno +")");
			this.divResult.form.btnEduNotice.set_enable(false);
			if(this.fvFocus=="EDUNO"){
				this.fvFocus="EDURES";
			}
		}else{
			this.divResult.form.btnEduNotice.set_text("교육공지\n("+ nEduno +")");
			this.divResult.form.btnEduNotice.set_enable(true);		
			if(this.fvFocus =="EDUNO"&&this.divResult.form.btnEduNotice.cssclass!="btn_WF_resultTab_S"){
				this.divResult.form.btnEduNotice.click();
			}
			if(this.fvFocus == "EDUNO") {
				this.divResult.form.btnEduNotice.set_accessibilitylabel("선택");
			}				
		}
		if(nEdures == 0){
			this.divResult.form.btnEduMaterial.set_text("교육자료\n("+ nEdures +")");
			this.divResult.form.btnEduMaterial.set_enable(false);
			if(this.fvFocus=="EDURES"){
				this.fvFocus="NOTICE";
			}
		}else{
			this.divResult.form.btnEduMaterial.set_text("교육자료\n("+ nEdures +")");
			this.divResult.form.btnEduMaterial.set_enable(true);
			if(this.fvFocus =="EDURES"&&this.divResult.form.btnEduMaterial.cssclass!="btn_WF_resultTab_S"){
				this.divResult.form.btnEduMaterial.click();
			}
			if(this.fvFocus == "EDURES") {
				this.divResult.form.btnEduMaterial.set_accessibilitylabel("선택");
			}				
		}
		if(nNotice == 0){
			this.divResult.form.btnNotice.set_text("공지사항\n("+ nNotice +")");
			this.divResult.form.btnNotice.set_enable(false);
		}else{
			this.divResult.form.btnNotice.set_text("공지사항\n("+ nNotice +")");
			this.divResult.form.btnNotice.set_enable(true);
			
			if(this.fvFocus =="NOTICE"&&this.divResult.form.btnNotice.cssclass!="btn_WF_resultTab_S"){
				this.divResult.form.btnNotice.click();
			}
			if(this.fvFocus == "NOTICE") {
				this.divResult.form.btnNotice.set_accessibilitylabel("선택");
			}				
		}

		if(totalCnt == 0){
			this.divResult.form.btnNexacroN.set_cssclass("btn_WF_resultTab");
			this.divResult.form.btnNexacro17.set_cssclass("btn_WF_resultTab");
			this.divResult.form.btnNexacro14.set_cssclass("btn_WF_resultTab");
			this.divResult.form.btnXP.set_cssclass("btn_WF_resultTab");
			this.divResult.form.btnMP.set_cssclass("btn_WF_resultTab");
			this.divResult.form.btnTip.set_cssclass("btn_WF_resultTab");
			this.divResult.form.btnEduNotice.set_cssclass("btn_WF_resultTab");
			this.divResult.form.btnEduMaterial.set_cssclass("btn_WF_resultTab");
			this.divResult.form.btnNotice.set_cssclass("btn_WF_resultTab");
			alert("검색된 데이터가 없습니다.");
		}
		
		switch(nexacro.getApplication().gv_mainFrame.SearchEngineFlag) {
		case "Nexacro N":
			this.fvSelectedTotal = this.ds_bbsResult.lookup("COLLECTION_CODE","mng_nexacroN","CNT");
			break;
		case "nexacro platform17":
			this.fvSelectedTotal = this.ds_bbsResult.lookup("COLLECTION_CODE","mng_nexacro17","CNT");
			break;
		case "nexacro platform14":
			this.fvSelectedTotal = this.ds_bbsResult.lookup("COLLECTION_CODE","mng_nexacro14","CNT");
			break;
		case "XPLATFORM":
			this.fvSelectedTotal = this.ds_bbsResult.lookup("COLLECTION_CODE","mng_xplatform","CNT");
			break;
		case "MiPlatform":
			this.fvSelectedTotal = this.ds_bbsResult.lookup("COLLECTION_CODE","mng_miplatform","CNT");
			break;
		case "Tip":
			this.fvSelectedTotal = this.ds_bbsResult.lookup("COLLECTION_CODE","bbs_tip","CNT");
			break;
		case "Education_Notice":
			this.fvSelectedTotal = this.ds_bbsResult.lookup("COLLECTION_CODE","bbs_edu_notice","CNT");
			break;
		case "Education_material":
			this.fvSelectedTotal = this.ds_bbsResult.lookup("COLLECTION_CODE","bbs_edu_resource","CNT");
			break;
		case "Notice":
			this.fvSelectedTotal = this.ds_bbsResult.lookup("COLLECTION_CODE","bbs_notice","CNT");
			break;
		default:
		}
		
		this.fn_pageNumInit(this.fvPageNum, this.fvSelectedTotal);
		
		if (this.fvListType == "Inq") {
			this.fn_searchEngineCall_Inq();
		} else if (this.fvListType == "Board") {
			this.fn_searchEngineCall_Board();
		}
		
		// 연관검색어 로딩
		nexacro.getApplication().gv_rightFrame.fn_relativeCallData(this.fvKeyword);
		if(!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.filterst))
		{
			this.fn_filterBFsize();
		}
	}
};

this.btnFilterResize_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fn_filterResize();	
};

//숫자 단위 표시(1000단위 콤마)
this.fn_SetFormatNumber = function(sProduct)
{
	var sPrice = 0
	if(!this.gfnIsNull(sProduct))
	{
		if(typeof(sProduct) == "string")
		{
			sPrice = this.ds_bbsResult.lookup("COLLECTION_CODE",sProduct,"CNT");
		}
		else
		{
			sPrice = sProduct;
		}
	}
	if(this.gfnIsNull(sPrice))
	{
		sPrice = 0;
		return sPrice;
	}
	return sPrice.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
}

// 검색필터 리사이즈
this.fn_filterResize = function()
{
	var changedHeight = 0;
	if (this.divSearch.height == this.fvSearchOpen)
	{
		nexacro.getApplication().gv_mainFrame.filterst ="close" ;
		this.divSearch.set_height(this.fvSearchClose);
		nexacro.getApplication().gv_mainFrame.staBGG.set_height(221);
		this.btnFilterResize.set_cssclass("btn_WF_filterOpen");
		this.btnFilterResize.set_accessibilitydescription("조건영역 닫힘");
		changedHeight = 0;
		this.fn_setCompVisible(false);
	}
	else
	{
		nexacro.getApplication().gv_mainFrame.filterst = "open" ;
		this.divSearch.set_height(this.fvSearchOpen);
		nexacro.getApplication().gv_mainFrame.staBGG.set_height(460);
		this.btnFilterResize.set_cssclass("btn_WF_filterClose");
		this.btnFilterResize.set_accessibilitydescription("조건영역 열림");
		changedHeight = this.fvSearchOpen;
		this.fn_setCompVisible(true);
	}
	
	this.divResult.set_top(this.divSearch.getOffsetBottom());
	this.resetScroll();
	
	var sFlag = nexacro.getApplication().gv_mainFrame.SearchEngineFlag;
 	if(sFlag == "Tip" ||  sFlag == "Education_Notice" || sFlag == "Education_material" || sFlag == "Notice") {
		this.viewPaging.set_top(this.viewList.getOffsetBottom() + 40);
	} else {
		this.viewPaging.set_top(this.divInquireList.getOffsetBottom() + 40);
	}
	
	this.set_height(this.fvWorkHeight + changedHeight);
	
	nexacro.getApplication().gv_mainFrame.fn_setFilterResize();
};

this.fn_filterBFsize = function()
{
	var changedHeight = 0;
	if (nexacro.getApplication().gv_mainFrame.filterst == "close")
	{
		this.divSearch.set_height(this.fvSearchClose);
		nexacro.getApplication().gv_mainFrame.staBGG.set_height(this.fvSearchOpen);
		this.btnFilterResize.set_cssclass("btn_WF_filterOpen");
		this.btnFilterResize.set_accessibilitydescription("조건영역 닫힘");
		changedHeight = this.fvSearchClose;
		this.fn_setCompVisible(false);
	}
	else
	{
		this.divSearch.set_height(this.fvSearchOpen);
		nexacro.getApplication().gv_mainFrame.staBGG.set_height(460);
		this.btnFilterResize.set_cssclass("btn_WF_filterClose");
		this.btnFilterResize.set_accessibilitydescription("조건영역 열림");
		changedHeight = this.fvSearchOpen;
		this.fn_setCompVisible(true);
	}
	
	this.divResult.set_top(this.divSearch.getOffsetBottom());
	this.resetScroll();
	
	var sFlag = nexacro.getApplication().gv_mainFrame.SearchEngineFlag;
 	if(sFlag == "Tip" ||  sFlag == "Education_Notice" || sFlag == "Education_material" || sFlag == "Notice") {
		this.viewPaging.set_top(this.viewList.getOffsetBottom() + 40);
	} else {
		this.viewPaging.set_top(this.divInquireList.getOffsetBottom() + 40);
	}
	
	this.set_height(this.fvWorkHeight + changedHeight);
	
	nexacro.getApplication().gv_mainFrame.fn_setFilterResize();
}

//상세조회 조건 visible처리
this.fn_setCompVisible = function(bFlag)
{
	this.divSearch.visible = bFlag;
}

// Search Filter토글 화면 조정
this.fn_setFilterResize = function()
{
	this.divResult.set_top(this.divSearch.getOffsetBottom());
	this.resetScroll();
};




// 검색어 입력
this.edtSearch_onkeyup = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	//열려있는 연관검색어 Div 닫기
	nexacro.getApplication().gv_mainFrame.showAutoCompleteResult(false);
	
	nexacro.getApplication().gv_mainFrame.Search_divCover = this.div_autoCompleteCover;
	nexacro.getApplication().gv_mainFrame.Search_div = this.div_autoCompleteCover.form.div_autoCompleteResult;
	nexacro.getApplication().gv_mainFrame.Search_Edit = obj;
	
	if( e.keycode == 13 ) {
		this.fn_search(1);
		nexacro.getApplication().gv_mainFrame.fn_SearchKey_onkeyup(obj, e);
	}
	else
	{
		nexacro.getApplication().gv_mainFrame.Top_Edit_flag = false;
		nexacro.getApplication().gv_mainFrame.fn_SearchKey_onkeyup(obj, e);
	}
};

// 시간설정 라디오 변경
this.divSearch_rdoTerm_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	var sDate = "";
	var eDate = "";
	var today = this.gfnGetDate();

	switch(e.postindex) {
	case 0:	// 전체
		sDate = "";
		eDate = "";
		break;
	case 1:	// 오늘
		sDate = today;
		eDate = today;
		break;
	case 2:	// 1주일
		sDate = this.gfnAddDate(today, -7);
		eDate = today;
		break;
	case 3:	// 1달
		sDate = this.gfnAddMonth(today, -1);
		eDate = today;
		break;
	case 4:
		break;
	default:
	}
	
	this.divSearch.form.calStart.set_value(sDate);
	this.divSearch.form.calEnd.set_value(eDate);
};



