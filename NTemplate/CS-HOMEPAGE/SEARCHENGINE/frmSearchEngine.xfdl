				this.divResult.form.btnEduMaterial.set_accessibilitylabel("선택 교육자료\n("+ nEdures +")");
			}				
		}
		if(nNotice == 0){
			this.divResult.form.btnNotice.set_text("공지사항\n("+ nNotice +")");
			this.divResult.form.btnNotice.set_enable(false);
		}else{
			this.divResult.form.btnNotice.set_text("공지사항\n("+ nNotice +")");
			this.divResult.form.btnNotice.set_enable(true);
			
			if(this.fvFocus =="NOTICE"&&this.divResult.form.btnNotice.cssclass!="btn_WF_resultTab_S"){
				this.divResult.form.btnNotice.click();
			}
			if(this.fvFocus == "NOTICE") {
				this.divResult.form.btnNotice.set_accessibilitylabel("선택 공지사항\n("+ nNotice +")");
			}				
		}

		if(totalCnt == 0){
			this.divResult.form.btnNexacroN.set_cssclass("btn_WF_resultTab");
			this.divResult.form.btnNexacro17.set_cssclass("btn_WF_resultTab");
			this.divResult.form.btnNexacro14.set_cssclass("btn_WF_resultTab");
			this.divResult.form.btnXP.set_cssclass("btn_WF_resultTab");
			this.divResult.form.btnMP.set_cssclass("btn_WF_resultTab");
			this.divResult.form.btnTip.set_cssclass("btn_WF_resultTab");
			this.divResult.form.btnEduNotice.set_cssclass("btn_WF_resultTab");
			this.divResult.form.btnEduMaterial.set_cssclass("btn_WF_resultTab");
			this.divResult.form.btnNotice.set_cssclass("btn_WF_resultTab");
			alert("검색된 데이터가 없습니다.");
		}
		
		switch(nexacro.getApplication().gv_mainFrame.SearchEngineFlag) {
		case "Nexacro N":
			this.fvSelectedTotal = this.ds_bbsResult.lookup("COLLECTION_CODE","mng_nexacroN","CNT");
			break;
		case "nexacro platform17":
			this.fvSelectedTotal = this.ds_bbsResult.lookup("COLLECTION_CODE","mng_nexacro17","CNT");
			break;
		case "nexacro platform14":
			this.fvSelectedTotal = this.ds_bbsResult.lookup("COLLECTION_CODE","mng_nexacro14","CNT");
			break;
		case "XPLATFORM":
			this.fvSelectedTotal = this.ds_bbsResult.lookup("COLLECTION_CODE","mng_xplatform","CNT");
			break;
		case "MiPlatform":
			this.fvSelectedTotal = this.ds_bbsResult.lookup("COLLECTION_CODE","mng_miplatform","CNT");
			break;
		case "Tip":
			this.fvSelectedTotal = this.ds_bbsResult.lookup("COLLECTION_CODE","bbs_tip","CNT");
			break;
		case "Education_Notice":
			this.fvSelectedTotal = this.ds_bbsResult.lookup("COLLECTION_CODE","bbs_edu_notice","CNT");
			break;
		case "Education_material":
			this.fvSelectedTotal = this.ds_bbsResult.lookup("COLLECTION_CODE","bbs_edu_resource","CNT");
			break;
		case "Notice":
			this.fvSelectedTotal = this.ds_bbsResult.lookup("COLLECTION_CODE","bbs_notice","CNT");
			break;
		default:
		}
		
		nexacro.getApplication().gv_mainFrame.divMain.form.divWork.form.fn_pageNumInit(this.fvPageNum, this.fvSelectedTotal);
		
		nexacro.getApplication().gv_mainFrame.divMain.form.divWork.form.fn_searchEngineCall();
		
		// 연관검색어 로딩
		nexacro.getApplication().gv_rightFrame.fn_relativeCallData(this.fvKeyword);
		if(!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.filterst))
		{
			this.fn_filterBFsize();
		}
	}
}

//숫자 단위 표시(1000단위 콤마)
this.fn_SetFormatNumber = function(sProduct)
{
	var sPrice = 0
	if(!this.gfnIsNull(sProduct))
	{
		if(typeof(sProduct) == "string")
		{
			sPrice = this.ds_bbsResult.lookup("COLLECTION_CODE",sProduct,"CNT");
		}
		else
		{
			sPrice = sProduct;
		}
	}
	if(this.gfnIsNull(sPrice))
	{
		sPrice = 0;
		return sPrice;
	}
	return sPrice.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
}

// 검색필터 리사이즈 버튼
this.divSearch_btnFilterResize_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fn_filterResize();
};

// 검색필터 리사이즈
this.fn_filterResize = function()
{
	if (this.divSearch.height == "399")
	{
		nexacro.getApplication().gv_mainFrame.filterst ="close" ;
		this.divSearch.set_height(160);
		nexacro.getApplication().gv_mainFrame.staBGG.set_height(221);
		this.divSearch.form.btnFilterResize.set_cssclass("btn_WF_filterOpen");
		this.divSearch.form.btnFilterResize.set_accessibilitydescription("조건영역 닫힘");
		
		this.fn_setCompVisible(false);
	}
	else
	{
		nexacro.getApplication().gv_mainFrame.filterst = "open" ;
		this.divSearch.set_height(399);
		nexacro.getApplication().gv_mainFrame.staBGG.set_height(460);
		this.divSearch.form.btnFilterResize.set_cssclass("btn_WF_filterClose");
		this.divSearch.form.btnFilterResize.set_accessibilitydescription("조건영역 열림");

		this.fn_setCompVisible(true);
	}
	this.divResult.set_top(this.divSearch.getOffsetBottom());
	
	this.parent.set_height(this.divResult.getOffsetBottom());

	nexacro.getApplication().gv_mainFrame.fn_setFilterResize();
};



//상세조회 조건 visible처리
this.fn_setCompVisible = function(bFlag)
{
	var comps = this.divSearch.form.components;
	
	for (var i = 0; i < comps.length; i++)
	{
		var obj = comps[i];
		// 조회 에디트,  검색 버튼 제외
		if (obj.id == "edtSearch" || obj.id == "btnSearch" || obj.id == "btnFilterResize") 	continue;
		
		obj.visible = bFlag;
	}
	this.divSearch.form.resetScroll();
}


// Search Filter토글 화면 조정
this.fn_setFilterResize = function()
{
	this.divResult.set_top(this.divSearch.getOffsetBottom());
	this.resetScroll();
};

this.fn_filterBFsize = function()
{
	if (nexacro.getApplication().gv_mainFrame.filterst == "close")
	{
		this.divSearch.set_height(160);
		nexacro.getApplication().gv_mainFrame.staBGG.set_height(221);
		this.divSearch.form.btnFilterResize.set_cssclass("btn_WF_filterOpen");
		this.divSearch.form.btnFilterResize.set_accessibilitydescription("조건영역 닫힘");
	}
	else
	{
		this.divSearch.set_height(399);
		nexacro.getApplication().gv_mainFrame.staBGG.set_height(460);
		this.divSearch.form.btnFilterResize.set_cssclass("btn_WF_filterClose");
		this.divSearch.form.btnFilterResize.set_accessibilitydescription("조건영역 열림");
	}
	
	this.divResult.set_top(this.divSearch.getOffsetBottom());
	this.parent.set_height(this.divResult.getOffsetBottom());
	nexacro.getApplication().gv_mainFrame.fn_setFilterResize();
}

// 검색어 입력
this.divSearch_edtSearch_onkeyup = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if( e.keycode == 13 ){
		this.fn_search(1);
		nexacro.getApplication().gv_mainFrame.fn_SearchKey_onkeyup(obj, e);
	}
	else
	{
		nexacro.getApplication().gv_mainFrame.Top_Edit_flag = false;
		nexacro.getApplication().gv_mainFrame.fn_SearchKey_onkeyup(obj, e);
	}
};

// 시간설정 라디오 변경
this.divSearch_rdoTerm_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	var sDate = "";
	var eDate = "";
	var today = this.gfnGetDate();

	switch(e.postindex) {
	case 0:	// 전체
		sDate = "";
		eDate = "";
		break;
	case 1:	// 오늘
		sDate = today;
		eDate = today;
		break;
	case 2:	// 1주일
		sDate = this.gfnAddDate(today, -7);
		eDate = today;
		break;
	case 3:	// 1달
		sDate = this.gfnAddMonth(today, -1);
		eDate = today;
		break;
	case 4:
		break;
	default:
	}
	
	this.divSearch.form.calStart.set_value(sDate);
	this.divSearch.form.calEnd.set_value(eDate);
};

// 제품탭 클릭
this.divResult_btnProduct_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 페이징 초기화
	nexacro.getApplication().gv_searchEngine.fvPageNum = 1;
	nexacro.getApplication().gv_mainFrame.QA_Cond_Page = 1;
	this.fvPageNum = 1;
	nexacro.getApplication().gv_mainFrame.param.page = nexacro.getApplication().gv_mainFrame.QA_Cond_Page;
	nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = 0;
	nexacro.getApplication().gv_mainFrame.divMain.form.divWork.set_url("");
	this.divResult.form.btnNexacroN.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btnNexacro17.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btnNexacro14.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btnXP.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btnMP.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btnTip.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btnEduNotice.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btnEduMaterial.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btnNotice.set_cssclass("btn_WF_resultTab");
	
	this.divResult.form.btnNexacroN.set_accessibilitylabel("");
	this.divResult.form.btnNexacro17.set_accessibilitylabel("");
	this.divResult.form.btnNexacro14.set_accessibilitylabel("");
	this.divResult.form.btnXP.set_accessibilitylabel("");
	this.divResult.form.btnMP.set_accessibilitylabel("");
	this.divResult.form.btnTip.set_accessibilitylabel("");
	this.divResult.form.btnEduNotice.set_accessibilitylabel("");
	this.divResult.form.btnEduMaterial.set_accessibilitylabel("");
	this.divResult.form.btnNotice.set_accessibilitylabel("");	
	
	
	
	obj.set_cssclass("btn_WF_resultTab_S");
	obj.set_accessibilitylabel("선택 " + obj.text);
	
	switch(obj.name) {
	case "btnNexacroN":
		this.fvFocus = "NPN";
		nexacro.getApplication().gv_mainFrame.SearchEngineFlag = "Nexacro N";	//"ALL";
		nexacro.getApplication().gv_mainFrame.divMain.form.divWork.set_url("SUPPORT::frmTechInquireList.xfdl");
		break;
	case "btnNexacro17":
		this.fvFocus = "NP17";
		nexacro.getApplication().gv_mainFrame.SearchEngineFlag = "nexacro platform17";
		nexacro.getApplication().gv_mainFrame.divMain.form.divWork.set_url("SUPPORT::frmTechInquireList.xfdl");
		break;
	case "btnNexacro14":
		this.fvFocus = "NP14";
		nexacro.getApplication().gv_mainFrame.SearchEngineFlag = "nexacro platform14";
		nexacro.getApplication().gv_mainFrame.divMain.form.divWork.set_url("SUPPORT::frmTechInquireList.xfdl");
		break;
	case "btnXP":
		this.fvFocus = "XP";
		nexacro.getApplication().gv_mainFrame.SearchEngineFlag = "XPLATFORM";
		nexacro.getApplication().gv_mainFrame.divMain.form.divWork.set_url("SUPPORT::frmTechInquireList.xfdl");
		break;
	case "btnMP":
		this.fvFocus = "MP";
		nexacro.getApplication().gv_mainFrame.SearchEngineFlag = "MiPlatform";
		nexacro.getApplication().gv_mainFrame.divMain.form.divWork.set_url("SUPPORT::frmTechInquireList.xfdl");
		break;
	case "btnTip":
		this.fvFocus = "TIP";
		nexacro.getApplication().gv_mainFrame.SearchEngineFlag = "Tip";
		nexacro.getApplication().gv_mainFrame.divMain.form.divWork.set_url("BOARD::frmBoardList.xfdl");
		break;
	case "btnEduNotice":
		this.fvFocus = "EDUNO";
		nexacro.getApplication().gv_mainFrame.SearchEngineFlag = "Education_Notice";
		nexacro.getApplication().gv_mainFrame.divMain.form.divWork.set_url("BOARD::frmBoardList.xfdl");
		break;
	case "btnEduMaterial":
		this.fvFocus = "EDURES";
		nexacro.getApplication().gv_mainFrame.SearchEngineFlag = "Education_material";
		nexacro.getApplication().gv_mainFrame.divMain.form.divWork.set_url("BOARD::frmBoardList.xfdl");
		break;
	case "btnNotice":
		this.fvFocus = "NOTICE";
		nexacro.getApplication().gv_mainFrame.SearchEngineFlag = "Notice";
		nexacro.getApplication().gv_mainFrame.divMain.form.divWork.set_url("BOARD::frmBoardList.xfdl");
		break;
	default:
	}
	
	var sData = {};
	
	var sHash = "menu=" + nexacro.getApplication().gv_mainFrame.param.menu + "&page=1";
	var sKeyword = nexacro.getApplication().gv_mainFrame.param.keyword;
	if(!this.gfnIsNull(sKeyword)) sHash += "&keyword="+sKeyword;
	var sUrl = ".?"+sHash;
	sData = this.fn_savePagingData();//nexacro.getApplication().gv_searchEngine.fn_saveHistoryData(sHash, sUrl);
	//sData = this.fn_savePagingData();
	MyHistory.setLocationHash(sHash, sData, sUrl);
};

