<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmSearchEngine" width="1300" height="494" titletext="New Form" onload="frmSearchEngine_onload">
    <Layouts>
      <Layout height="494" mobileorientation="landscape" width="1300">
        <Div id="divSearch" taborder="0" left="0" top="0" width="1300" height="160" text="" formscrolltype="none" accessibilityenable="false">
          <Layouts>
            <Layout>
              <Edit id="edtSearch" taborder="0" left="12" top="60" width="980" height="75" cssclass="edt_WF_search" onkeyup="divSearch_edtSearch_onkeyup" onkillfocus="divSearch_edtSearch_onkillfocus" accessibilitydescription="검색어 입력"/>
              <Button id="btnSearch" taborder="1" text="검색" left="1007" top="60" width="155" height="75" cssclass="btn_WF_search" onclick="divSearch_btnSearch_onclick"/>
              <Button id="btnFilterResize" taborder="2" top="88" width="104" height="18" cssclass="btn_WF_filterOpen" left="1191" onclick="divSearch_btnFilterResize_onclick" accessibilitylabel="상세검색" accessibilitydescription="조건영역 닫힘"/>
              <Static id="Static03_00" taborder="3" text="조회조건" left="30" top="178" width="80" height="37" cssclass="sta_WF_search" visible="false"/>
              <Radio id="rdoField" taborder="4" left="179" top="178" width="492" height="37" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" direction="vertical" cssclass="rdo_WF_search" index="1" text="제목" value="title" accessibilitylabel="[@Static03_00]" visible="false" initvalueid="iv_Radio0">
                <Dataset id="innerdataset">
                  <ColumnInfo>
                    <Column id="codecolumn" size="256"/>
                    <Column id="datacolumn" size="256"/>
                  </ColumnInfo>
                  <Rows>
                    <Row>
                      <Col id="codecolumn">all</Col>
                      <Col id="datacolumn">제목+내용</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">title</Col>
                      <Col id="datacolumn">제목</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">num</Col>
                      <Col id="datacolumn">번호</Col>
                    </Row>
                  </Rows>
                </Dataset>
              </Radio>
              <Radio id="rdoOperator" taborder="5" left="674" top="178" width="330" height="37" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" direction="vertical" cssclass="rdo_WF_search" index="0" text="OR" value="false" accessibilitylabel="[@Static03_00]" visible="false" initvalueid="iv_Radio0">
                <Dataset id="innerdataset">
                  <ColumnInfo>
                    <Column id="codecolumn" size="256"/>
                    <Column id="datacolumn" size="256"/>
                  </ColumnInfo>
                  <Rows>
                    <Row>
                      <Col id="codecolumn">false</Col>
                      <Col id="datacolumn">OR</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">true</Col>
                      <Col id="datacolumn">AND</Col>
                    </Row>
                  </Rows>
                </Dataset>
              </Radio>
              <Static id="Static03_00_00" taborder="6" text="조회기간" left="30" top="238" width="80" height="37" cssclass="sta_WF_search" onclick="divSearch_Static03_00_00_onclick" visible="false"/>
              <Radio id="rdoTerm" taborder="7" left="179" top="238" width="657" height="37" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" direction="vertical" cssclass="rdo_WF_search" index="0" text="제목+내용" value="0" onitemchanged="divSearch_rdoTerm_onitemchanged" accessibilitylabel="[@Static03_00_00]" visible="false" initvalueid="iv_Radio0">
                <Dataset id="innerdataset">
                  <ColumnInfo>
                    <Column id="codecolumn" size="256"/>
                    <Column id="datacolumn" size="256"/>
                  </ColumnInfo>
                  <Rows>
                    <Row>
                      <Col id="codecolumn">0</Col>
                      <Col id="datacolumn">전체</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">1</Col>
                      <Col id="datacolumn">오늘</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">2</Col>
                      <Col id="datacolumn">1주일</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">3</Col>
                      <Col id="datacolumn">1달</Col>
                    </Row>
                  </Rows>
                </Dataset>
              </Radio>
              <Static id="Static03_00_00_00" taborder="8" text="조회기간" left="836" top="238" width="80" height="37" cssclass="sta_WF_search" onclick="divSearch_Static03_00_00_onclick" visible="false"/>
              <Calendar id="calStart" taborder="9" left="955" top="236" width="155" height="40" dateformat="yyyy-MM-dd" cssclass="cal_WF_search" accessibilitylabel="시작일" visible="false" initvalueid="iv_Calendar0"/>
              <Static id="Static00" taborder="10" text="~" left="1110.00" top="236" width="20" height="40" textAlign="center" visible="false" accessibilityenable="false"/>
              <Calendar id="calEnd" taborder="11" left="1130.00" top="236" width="155" height="40" dateformat="yyyy-MM-dd" cssclass="cal_WF_search" accessibilitylabel="종료일" visible="false" initvalueid="iv_Calendar0"/>
              <Button id="btnClear" taborder="12" text="초기화" left="537" top="333" width="110" height="40" cssclass="btn_WF_searchReset" onclick="divSearch_btnClear_onclick" visible="false"/>
              <Button id="btnApply" taborder="13" text="적용" left="657" top="333" width="110" height="40" cssclass="btn_WF_searchReset" onclick="divSearch_btnSearch_onclick" visible="false"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divResult" taborder="1" left="0" top="divSearch:0" width="1300" text="" formscrolltype="none" height="95" accessibilityenable="false">
          <Layouts>
            <Layout>
              <Button id="btnNexacroN" taborder="0" text="Nexacro N" left="0" top="25" width="145" height="70" onclick="divResult_btnProduct_onclick" cssclass="btn_WF_resultTab_S"/>
              <Button id="btnNexacro17" taborder="1" text="nexacro 17" left="144" top="25" width="145" height="70" cssclass="btn_WF_resultTab" onclick="divResult_btnProduct_onclick"/>
              <Button id="btnNexacro14" taborder="2" text="nexacro 14" left="288" top="25" width="145" height="70" cssclass="btn_WF_resultTab" onclick="divResult_btnProduct_onclick"/>
              <Button id="btnXP" taborder="3" text="XPLATFORM" left="432" top="25" width="145" height="70" cssclass="btn_WF_resultTab" onclick="divResult_btnProduct_onclick"/>
              <Button id="btnMP" taborder="4" text="MiPlatform" top="25" width="145" height="70" cssclass="btn_WF_resultTab" left="576" onclick="divResult_btnProduct_onclick"/>
              <Button id="btnTip" taborder="5" text="Tip" left="720" top="25" width="145" height="70" cssclass="btn_WF_resultTab" onclick="divResult_btnProduct_onclick"/>
              <Button id="btnEduNotice" taborder="6" text="교육공지" left="864" top="25" width="145" height="70" cssclass="btn_WF_resultTab" onclick="divResult_btnProduct_onclick"/>
              <Button id="btnEduMaterial" taborder="7" text="교육자료" left="1008" top="25" width="145" height="70" cssclass="btn_WF_resultTab" onclick="divResult_btnProduct_onclick"/>
              <Button id="btnNotice" taborder="8" text="공지사항" top="25" width="147" height="70" cssclass="btn_WF_resultTab" left="1152" onclick="divResult_btnProduct_onclick"/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  통합검색(divSearch)
*
*  @MenuPath 
*  @FileName 		SEARCHENGINE::frmSearchEngine.xfdl 
*  @Creator 		김광호
*  @CreateDate 		2022.01.01
*  @LastModifier  
*  @LastModifyDate  
*  @Version 		1.0
*  @Outline 		통합검색(divSearch)
*  @Desction 
************** 소스 수정 이력 *************************************************
*    date          Modifier            Description
*******************************************************************************
*  2022.01.01      김광호	           최초 생성 
*******************************************************************************
*/

this.collection = "mng_nexacroN";	// 통합검색 조회 조건 제품 //"mng_nexacroN,mng_nexacro17,mng_nexacro14,mng_xplatform,mng_miplatform,bbs_tip,bbs_edu_notice,bbs_edu_resource,bbs_notice";
this.Search_query = ""; 
this.Search_oquery = ""; 

this.fvListSize = 10;
this.fvPageNum = 1;
this.fvSelectedTotal = 0;
this.fvFocus = "NPN";
this.fvKeyword = "";
this.fvTab = 1;

this.frmSearchEngine_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	nexacro.getApplication().gv_searchEngine = this;
	
	nexacro.getApplication().gv_mainFrame.QA_Cond_Page = 1;
	nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = 0;

	// 초기 검색어 셋팅
	if (!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.param.keyword))
	{
		this.divSearch.form.edtSearch.set_value(nexacro.getApplication().gv_mainFrame.param.keyword);
	}
	if (!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.param.page))
	{
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = nexacro.getApplication().gv_mainFrame.param.page;
		nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = nexacro.floor(nexacro.getApplication().gv_mainFrame.QA_Cond_Page/10);
	}
	
	// 브라우저 히스토리를 사용하기 위해 조건 데이터 저장 불러오기
	var sData = nexacro.getApplication().gv_mainFrame.gfnGetHistoryData();
	if (!this.gfnIsNull(sData))
	{
		// 히스토리 sData에서 불러오기
		if (!this.gfnIsNull(sData.rdoField)){	this.divSearch.form.rdoField.set_value(sData.rdoField); }
		if (!this.gfnIsNull(sData.rdoOperator)){	this.divSearch.form.rdoOperator.set_value(sData.rdoOperator); }
		if (!this.gfnIsNull(sData.rdoTerm)){	this.divSearch.form.rdoTerm.set_value(sData.rdoTerm); }
		if (!this.gfnIsNull(sData.calStart)){	this.divSearch.form.calStart.set_value(sData.calStart); }
		if (!this.gfnIsNull(sData.calEnd)){	this.divSearch.form.calEnd.set_value(sData.calEnd); }
		if (!this.gfnIsNull(sData.filterst)){nexacro.getApplication().gv_mainFrame.filterst = sData.filterst}else{nexacro.getApplication().gv_mainFrame.filterst="close"};
		if (!this.gfnIsNull(sData.SearchEngineFlag)){nexacro.getApplication().gv_mainFrame.SearchEngineFlag = sData.SearchEngineFlag};
	}
	// 초기값
	if (this.gfnIsNull(nexacro.getApplication().gv_mainFrame.SearchEngineFlag))
	{
		nexacro.getApplication().gv_mainFrame.SearchEngineFlag = "Nexacro N";	//"ALL";
	}
	
	this.fvFocus = "NPN";
	this.fn_selectProduct();
	nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, 1850);
};

// 검색버튼 이벤트
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fn_search(1);
};

// 검색
this.fn_search = function(pageNum)
{
	// 현재 페이지 공통에 저장
	nexacro.getApplication().gv_mainFrame.QA_Cond_Page = pageNum;

	// 히스토리 관리를 위해 검색조건 저장
	this.fn_saveHistoryData();
	
	this.fvPageNum = pageNum;
	
	nexacro.getApplication().gv_mainFrame.showAutoCompleteResult(false);
	
	// 검색
	var strUrl = "url=" + nexacro.getEnvironmentVariable("gv_SearchEngine") + "/tobe_list&zip=false";
	if (!this.gfnIsNull(this.divSearch.form.edtSearch.value))
	{
		this.fvKeyword = this.divSearch.form.edtSearch.value.trim();
	}
	else
	{
		this.fvKeyword = "";
	}
	
	// 번호일때 숫자 체크
	if (this.divSearch.form.rdoField.value == "num")
	{
		var chkNo = /^\d+$/.test(this.fvKeyword);
		if (this.gfnIsNull(this.fvKeyword) || chkNo == false)	// 검색조건(번호) & 번호가 아닐때
		{
			alert("번호를 입력해주세요.");
			return;
		}
	}

	if( this.gfnIsNull(this.fvKeyword) ) this.fvKeyword = "";

	var strDsOutput = "ds_bbsResult=ds_bbsResult ";

	switch(nexacro.getApplication().gv_mainFrame.SearchEngineFlag) {
	case "Nexacro N":
		strDsOutput += "ds_mng_nexacroN=mng_nexacroN ";
		this.collection = "mng_nexacroN";
		break;
	case "nexacro platform17":
		strDsOutput += "ds_mng_nexacro17=mng_nexacro17 ";
		this.collection = "mng_nexacro17";
		break;
	case "nexacro platform14":
		strDsOutput += "ds_mng_nexacro14=mng_nexacro14 ";
		this.collection = "mng_nexacro14";
		break;
	case "XPLATFORM":
		strDsOutput += "ds_mng_xplatform=mng_xplatform ";
		this.collection = "mng_xplatform";
		break;
	case "MiPlatform":
		strDsOutput += "ds_mng_miplatform=mng_miplatform ";
		this.collection = "mng_miplatform";
		break;
	case "Tip":
		strDsOutput += "ds_bbs_tip=bbs_tip ";
		this.collection = "bbs_tip";
		break;
	case "Education_Notice":
		strDsOutput += "ds_bbs_edu_notice=bbs_edu_notice ";
		this.collection = "bbs_edu_notice";
		break;
	case "Education_material":
		strDsOutput += "ds_bbs_edu_resource=bbs_edu_resource ";
		this.collection = "bbs_edu_resource";
		break;
	case "Notice":
		strDsOutput += "ds_bbs_notice=bbs_notice ";
		this.collection = "bbs_notice";
		break;
	default:
	}
	strDsOutput += "ds_condition=ds_condition";
	
	
	var arg = 	"query='" + this.fvKeyword + "'" ; //검색어	
		arg +=	" collection=" + this.collection; //ALL, bbs_notice, mng_nexacro14, mng_nexacro14, mng_xplatform, mng_nexacroN 등등 - 게시판 단일, n개, 전체
		arg +=	" oquery=" + this.Search_oquery; //이전 검색어 - 연관 검색어 관련 필요!
		arg +=	" startDate=" + this.divSearch.form.calStart.text; // 시작 날짜 - 2021-01-01 
		arg +=	" endDate=" + this.divSearch.form.calEnd.text; // 끝 날짜 - 2022-08-01 
		arg +=	" operator=" + this.divSearch.form.rdoOperator.value; //and, or 택1 조회조건2 연산자 - and = true, or = false 				
		arg +=	" field=" + this.divSearch.form.rdoField.value; // 제목+내용, 제목, 번호 택1 조회조건 - 제목+내용 = all, 제목 = title, 번호 = num				
		arg +=	" listSize="+this.fvListSize; // 페이지 목록 개수 - 화면에 표출되는 해당 페이지에 나올 목록 개수
		arg +=	" pageNum="+pageNum; // 페이지 - 1, 2 화면에 표출되는 해당 페이지 번호
		arg +=  " sort=DATE/DESC";	// 날짜순으로 정렬되도록 추가함

	this.transaction("select",nexacro.getEnvironment().services["SVC_JSP"].url + "Next_JSP/SearchEngine/Service/url.jsp?"+ strUrl, "", strDsOutput, arg, "callbackSearchComplete");	// 개발
}

// 새로고침을 대비해 검색 데이터 저장
this.fn_saveHistoryData = function()
{
	nexacro.getApplication().gv_mainFrame.param.keyword = this.divSearch.form.edtSearch.value;
	// 히스토리 sData에 저장
	var sData = {
	rdoField:this.divSearch.form.rdoField.value
	,rdoOperator:this.divSearch.form.rdoOperator.value
	,rdoTerm:this.divSearch.form.rdoTerm.value
	,calStart:this.divSearch.form.calStart.value
	,calEnd:this.divSearch.form.calEnd.value
	,filterst:nexacro.getApplication().gv_mainFrame.filterst
	,SearchEngineFlag:nexacro.getApplication().gv_mainFrame.SearchEngineFlag
	};
	nexacro.getApplication().gv_mainFrame.gfnSetHistoryData(sData);
};

// 페이징 검색 데이터 저장
this.fn_savePagingData = function()
{
	nexacro.getApplication().gv_mainFrame.param.keyword = this.divSearch.form.edtSearch.value;
	// 히스토리 sData에 저장
	var sData = {
	rdoField:this.divSearch.form.rdoField.value
	,rdoOperator:this.divSearch.form.rdoOperator.value
	,rdoTerm:this.divSearch.form.rdoTerm.value
	,calStart:this.divSearch.form.calStart.value
	,calEnd:this.divSearch.form.calEnd.value
	,filterst:nexacro.getApplication().gv_mainFrame.filterst
	,SearchEngineFlag:nexacro.getApplication().gv_mainFrame.SearchEngineFlag
	};
	return sData;
};

// 검색조건 초기화
this.divSearch_btnClear_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divSearch.form.rdoField.set_value("title");
	this.divSearch.form.rdoOperator.set_value(false);
	this.divSearch.form.rdoTerm.set_value(0);
	
	this.divSearch.form.calStart.set_value("");
	this.divSearch.form.calEnd.set_value("");
	
	this.divSearch.form.edtSearch.set_value("");
	
	this.fn_search(1);
};

// 통합검색 조회 콜백
this.callbackSearchComplete = function(id, code, msg)
{
	if( id == "select" ){	
		this.Search_oquery = this.Search_query;
		var totalCnt = this.ds_bbsResult.getCaseSum("COLLECTION_CODE=='mng_nexacroN'||COLLECTION_CODE=='mng_nexacro17'||COLLECTION_CODE=='mng_nexacro14'||COLLECTION_CODE=='mng_xplatform'||COLLECTION_CODE=='mng_miplatform'||COLLECTION_CODE=='bbs_tip'||COLLECTION_CODE=='bbs_edu_notice'||COLLECTION_CODE=='bbs_edu_resource'||COLLECTION_CODE=='bbs_notice'","CNT");
		if (this.gfnIsNull(this.divSearch.form.edtSearch.value)) {this.divSearch.form.edtSearch.value = "";}
		
		var nNpN = this.fn_SetFormatNumber("mng_nexacroN");
		var nNp17 = this.fn_SetFormatNumber("mng_nexacro17");
		var nNp14 = this.fn_SetFormatNumber("mng_nexacro14");
		var nXp = this.fn_SetFormatNumber("mng_xplatform");
		var nMp = this.fn_SetFormatNumber("mng_miplatform");
		var nTip = this.fn_SetFormatNumber("bbs_tip");
		var nEduno = this.fn_SetFormatNumber("bbs_edu_notice");
		var nEdures = this.fn_SetFormatNumber("bbs_edu_resource");
		var nNotice = this.fn_SetFormatNumber("bbs_notice");

		// 데이터가 0건일때 이상한 데이터가 들어오던 문제 해결
		if(nNpN == 0){this.ds_mng_nexacroN.clearData()}
		if(nNp17 == 0){this.ds_mng_nexacro17.clearData()}
		if(nNp14 == 0){this.ds_mng_nexacro14.clearData()}
		if(nXp == 0){this.ds_mng_xplatform.clearData()}
		if(nMp == 0){this.ds_mng_miplatform.clearData()}
		if(nTip == 0){this.ds_bbs_tip.clearData()}
		if(nEduno == 0){this.ds_bbs_edu_notice.clearData()}
		if(nEdures == 0){this.ds_bbs_edu_resource.clearData()}
		if(nNotice == 0){this.ds_bbs_notice.clearData()}
		if(totalCnt==0||(this.fvFocus == "NP17"&&nNp17 ==0)||(this.fvFocus == "NP14"&&nNp14 ==0)||(this.fvFocus == "XP"&&nXp ==0)
		||(this.fvFocus == "MP"&&nMp ==0)||(this.fvFocus == "TIP"&&nTip ==0)||(this.fvFocus == "EDUNO"&&nEduno ==0)
		||(this.fvFocus == "EDURES"&&nEdures ==0)||(this.fvFocus == "NOTICE"&&nNotice ==0)){this.fvFocus="NPN"};
		
		// 제품 탭 조정 및 전체건수 표시
		if(nNpN == 0){
			this.divResult.form.btnNexacroN.set_text("Nexacro N\n("+ nNpN +")");
			this.divResult.form.btnNexacroN.set_enable(false);
			if(this.fvFocus=="NPN"&&totalCnt != 0){
				this.fvFocus="NP17";
			}
		}else{
			this.divResult.form.btnNexacroN.set_text("Nexacro N\n("+ nNpN +")");
			this.divResult.form.btnNexacroN.set_enable(true);		
			if(this.fvFocus =="NPN"&&this.divResult.form.btnNexacroN.cssclass!="btn_WF_resultTab_S"){
				this.divResult.form.btnNexacroN.click();
			}
			if(this.fvFocus == "NPN") {
				this.divResult.form.btnNexacroN.set_accessibilitylabel("선택 Nexacro N\n("+ nNpN +")");
			}
		}
		if(nNp17 == 0){
			this.divResult.form.btnNexacro17.set_text("nexacro 17\n("+ nNp17 +")");
			this.divResult.form.btnNexacro17.set_enable(false);
			if(this.fvFocus=="NP17"){
				this.fvFocus="NP14";
			}
		}else{
			this.divResult.form.btnNexacro17.set_text("nexacro 17\n("+ nNp17 +")");
			this.divResult.form.btnNexacro17.set_enable(true);		
			if(this.fvFocus =="NP17"&&this.divResult.form.btnNexacro17.cssclass!="btn_WF_resultTab_S"){
				this.divResult.form.btnNexacro17.click();
			}
			if(this.fvFocus == "NP17") {
				this.divResult.form.btnNexacro17.set_accessibilitylabel("선택 nexacro 17\n("+ nNp17 +")");
			}			
		}
		if(nNp14 == 0){
			this.divResult.form.btnNexacro14.set_text("nexacro 14\n("+ nNp14 +")");
			this.divResult.form.btnNexacro14.set_enable(false);
			if(this.fvFocus=="NP14"){
				this.fvFocus="XP";
			}
		}else{
			this.divResult.form.btnNexacro14.set_text("nexacro 14\n("+ nNp14 +")");
			this.divResult.form.btnNexacro14.set_enable(true);		
