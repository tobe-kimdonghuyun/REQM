			}
			if(this.fvFocus == "NP14") {
				this.divResult.form.btnNexacro14.set_accessibilitylabel("선택 nexacro 14\n("+ nNp14 +")");
			}				
		}
		if(nXp == 0){
			this.divResult.form.btnXP.set_text("XPLATFORM\n("+ nXp +")");
			this.divResult.form.btnXP.set_enable(false);
			if(this.fvFocus=="XP"){
				this.fvFocus="MP";
			}
		}else{
			this.divResult.form.btnXP.set_text("XPLATFORM\n("+ nXp +")");
			this.divResult.form.btnXP.set_enable(true);		
			if(this.fvFocus =="XP"&&this.divResult.form.btnXP.cssclass!="btn_WF_resultTab_S"){
				this.divResult.form.btnXP.click();
			}
			if(this.fvFocus == "XP") {
				this.divResult.form.btnXP.set_accessibilitylabel("선택 XPLATFORM\n("+ nXp +")");
			}					
		}
		if(nMp == 0){
			this.divResult.form.btnMP.set_text("MiPlatform\n("+ nMp +")");
			this.divResult.form.btnMP.set_enable(false);
			if(this.fvFocus=="MP"){
				this.fvFocus="TIP";
			}
		}else{
			this.divResult.form.btnMP.set_text("MiPlatform\n("+ nMp +")");
			this.divResult.form.btnMP.set_enable(true);		
			if(this.fvFocus =="MP"&&this.divResult.form.btnMP.cssclass!="btn_WF_resultTab_S"){
