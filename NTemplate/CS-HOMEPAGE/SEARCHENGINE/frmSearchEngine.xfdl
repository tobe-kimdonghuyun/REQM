    <Objects>
      <Dataset id="ds_autoResult">
        <ColumnInfo>
          <Column id="hkeyword" type="STRING" size="256"/>
          <Column id="keyword" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSubMenu" firefirstcount="0" firenextcount="0" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="category" type="STRING" size="256"/>
          <Column id="subCatgy" type="STRING" size="256"/>
          <Column id="langCd" type="STRING" size="256"/>
          <Column id="selImg" type="STRING" size="256"/>
        </ColumnInfo>
