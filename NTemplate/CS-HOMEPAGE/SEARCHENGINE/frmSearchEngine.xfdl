				this.divResult.form.btnEduNotice.click();
			}
			if(this.fvFocus == "EDUNO") {
				this.divResult.form.btnEduNotice.set_accessibilitylabel("선택 교육공지\n("+ nEduno +")");
			}				
		}
		if(nEdures == 0){
			this.divResult.form.btnEduMaterial.set_text("교육자료\n("+ nEdures +")");
			this.divResult.form.btnEduMaterial.set_enable(false);
			if(this.fvFocus=="EDURES"){
				this.fvFocus="NOTICE";
			}
		}else{
			this.divResult.form.btnEduMaterial.set_text("교육자료\n("+ nEdures +")");
			this.divResult.form.btnEduMaterial.set_enable(true);
			if(this.fvFocus =="EDURES"&&this.divResult.form.btnEduMaterial.cssclass!="btn_WF_resultTab_S"){
				this.divResult.form.btnEduMaterial.click();
			}
