<FDL version="2.1">
  <Form id="frmWork" width="1300" titletext="server" height="1620" onload="frmWork_onload" scrolltype="none">
    <Layouts>
      <Layout height="1620" width="1300">
        <Static id="stcSechCmnt" taborder="0" left="0" top="32" height="60" cssclass="sta_WF_viewDetail" wordWrap="char" usedecorate="true" onclick="stcSechCmnt_onclick" text="&lt;fc v='#d62100'&gt;• 유지보수 미계약 고객(사)의 경우 패치 이후 발생하는 문제와 관련한 일체의 책임을 지지 않습니다&lt;/fc&gt;&#13;&#10;&lt;fc v='#d62100'&gt;• 유지보수 미계약 고객(사)의 경우 관련 영업대표를 통해 유지보수를 체결해 주시기 바랍니다.&lt;/fc&gt;" right="0"/>
        <Button id="stcSechCmnt00" taborder="1" left="0" top="90" width="281" height="34" cssclass="btn_WF_viewDetail" onclick="stcSechCmnt00_onclick" cursor="pointer" visible="false" accessibilitydescription="새창열림"/>
        <Combo id="cmbGubun" taborder="2" text="타이틀+상세" top="102" width="76" height="30" innerdataset="ds_gubun" codecolumn="CODE" datacolumn="DATA" index="0" value="0" cssclass="cmb_WF_view" right="90" onitemchanged="cmbGubun_onitemchanged" accessibilitylabel="구분" initvalueid="iv_Combo0"/>
        <Combo id="cmbYear" taborder="3" text="타이틀+상세" top="102" width="76" height="30" innerdataset="ds_year" codecolumn="CODE" datacolumn="DATA" index="0" value="0" cssclass="cmb_WF_view" right="0" onitemchanged="cmbYear_onitemchanged" accessibilitylabel="년도" initvalueid="iv_Combo0"/>
        <FileDownload id="FileDownload00" taborder="4" text="FileDownload00" left="1310" top="107" width="100" height="100" visible="false"/>
