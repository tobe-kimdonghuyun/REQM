<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmWork" width="800" titletext="상세팝업" scrolltype="none" height="800" onload="frmWork_onload">
    <Layouts>
      <Layout height="800" width="800">
        <Static id="Static01_00" taborder="0" left="0" height="40" cssclass="sta_POP_TitleBg" right="0" top="0" text="상세팝업"/>
        <WebBrowser id="wbContent" taborder="1" left="25" top="65" right="25" bottom="75" onloadcompleted="wbContent_onloadcompleted" accessibilitylabel="상세내용"/>
        <TextArea id="txaContent" taborder="2" left="25" top="65" right="25" bottom="75" readonly="true" wordWrap="char" visible="false" accessibilitylabel="상세내용"/>
        <Static id="Static01" taborder="3" left="0" height="42" cssclass="sta_POP_foot" accessibilityenable="false" bottom="0" right="0"/>
        <Button id="btnClose" taborder="4" text="닫기" width="55" cssclass="btn_POP_close" right="10" height="25" bottom="9" onclick="btnClose_onclick"/>
        <Button id="Button00" taborder="5" top="0" width="40" height="40" right="0" cssclass="btn_POP_CloseIcon" onclick="btnClose_onclick" accessibilitylabel="닫기"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  제품 다운로드 상세팝업
*
*  @MenuPath 
*  @FileName 		PRODUCT::frmProdDetailPop.xfdl 
*  @Creator 		김광호
*  @CreateDate 		2022.01.01
*  @LastModifier  
*  @LastModifyDate  
*  @Version 		1.0
*  @Outline 		제품 다운로드 상세팝업
*  @Desction 
************** 소스 수정 이력 *************************************************
*    date          Modifier            Description
*******************************************************************************
*  2022.01.01      김광호	           최초 생성 
*******************************************************************************
*/

this.frmWork_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.wbContent.set_url(nexacro.getApplication().gv_DomainInfo+"CKEDITOR/editor/view_admin.html");
};

this.wbContent_onloadcompleted = function(obj:nexacro.WebBrowser,e:nexacro.WebLoadCompEventInfo)
{
	this.wbContent.callMethod("setContent", this.parent.content, true);
};

this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close();
};
]]></Script>
    <Objects/>
  </Form>
</FDL>
