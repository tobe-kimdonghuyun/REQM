    <Script type="xscript5.1"><![CDATA[/**
*  제품 다운로드 매인
*
*  @MenuPath 
*  @FileName 		PRODUCT::frmProdDownload.xfdl 
*  @Creator 		김광호
*  @CreateDate 		2022.01.01
*  @LastModifier  
*  @LastModifyDate  
*  @Version 		1.0
*  @Outline 		제품 다운로드 매인
*  @Desction 
************** 소스 수정 이력 *************************************************
*    date          Modifier            Description
*******************************************************************************
*  2022.01.01      김광호	           최초 생성 
*******************************************************************************
*/


this.frmWork_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	if (nexacro.getApplication().gv_mainFrame.PCategory2 != "Download_N")
	{
		this.tabProduct.removeTabpage(3);
	} else {
		this.tabProduct.Tabpage4.set_url("PRODUCT::frmProdDownload_T04.xfdl");
	}

	if (nexacro.getApplication().gds_UserInfo.getRowCount() <= 0) 
	{
		// alert("로그인 후 사용하세요.");
		nexacro.getApplication().gv_mainFrame.TargetUrl = nexacro.getApplication().gv_mainFrame.PCategory2;
		nexacro.getApplication().gv_mainFrame.param = {
			'menu': "login",
			'keyword': "",
			'page': 1,
			'postId': ""
			};
		nexacro.getApplication().gv_mainFrame.gfnGoMain();
	}
	else 
	{
		this.tabProduct.Tabpage1.set_url("PRODUCT::frmProdDownload_T01.xfdl");
		this.tabProduct.Tabpage2.set_url("PRODUCT::frmProdDownload_T02.xfdl");
		this.tabProduct.Tabpage3.set_url("PRODUCT::frmProdDownload_T03.xfdl");		
	
		// 폼 높이 조정
		this.set_height(1672 + 200);
		this.parent.set_height(1672 + 200);
		nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, 1672 + 220);	
		
		this.fn_QueryData();
	}
};

this.Pro_gub = "001";
// 제품 탭 변경 이벤트
this.tabProduct_onchanged = function(obj:nexacro.Tab,e:nexacro.TabIndexChangeEventInfo)
{
	if (e.postindex == 0) // btn_devel
	{
		this.Pro_gub = "001";
	}
	else if (e.postindex == 1) // btn_Svr
	{
		this.Pro_gub = "002";
	}
	else if (e.postindex == 2) // btn_Etc
	{
		this.Pro_gub = "004";
	}
	else if (e.postindex == 3) // btn_Etc
	{
		this.Pro_gub = "005";
	}	
	this.fn_QueryData();
};

this.fn_callback = function (sid, errcode, errmsg)
{
	if (errcode < nexacro.getApplication().ERROR_CODE_SUCCESS) 
	{
		alert(errmsg);
	}
	if (sid == 'codedata') 
	{
		this.cmb_kind.set_index(0);
		this.fn_QueryData();
	}
	else if (sid == 'select') 
	{
		//trace(this.ds_list_detail.saveXML());
		//잘못된 로우 제거()
		var nDeleteRows= [];
		for(var x=0;x<this.ds_list.getRowCount();x++){
			var nIdx = this.ds_list.getColumn(x,"idx");
			if(this.ds_list_detail.findRow("idx",nIdx)==-1){
				nDeleteRows.push(x);
			}
			nIdx = -2;
		}
		this.ds_list.deleteMultiRows(nDeleteRows);

		this.tabProduct.Tabpage1.form.fn_cmbYearChange();
		if (this.Pro_gub == "002")
		{
			this.tabProduct.Tabpage2.form.fn_refreshDS();
		}
		else if (this.Pro_gub == "004")
		{
			this.tabProduct.Tabpage3.form.fn_refreshDS();
		}
		else if (this.Pro_gub == "005")
		{
			this.tabProduct.Tabpage4.form.fn_refreshDS();
		}
	}
};


this.fn_QueryData = function ()
{
	var args = "goods_gbn='X%'&Nation='" + nexacro.getApplication().gv_NationCd + "'";
	if (nexacro.getApplication().gv_mainFrame.PCategory2 == "Download_N") 
	{
		if (this.Pro_gub == "002") 
		{
			//args = "goods_gbn='044'&Nation='" + nexacro.getApplication().gv_NationCd + "'";
			args = "goods_gbn=' PRODUCT_CODE LIKE ''044'''&Nation='" + nexacro.getApplication().gv_NationCd + "'";
		}else{
			//args = "goods_gbn='043'&Nation='" + nexacro.getApplication().gv_NationCd + "'";
			args = "goods_gbn=' PRODUCT_CODE IN (''043'',''045'')'&Nation='" + nexacro.getApplication().gv_NationCd + "'";
		}
	}
	else if (nexacro.getApplication().gv_mainFrame.PCategory2 == "Download_14") 
	{
		args = "goods_gbn=' PRODUCT_CODE LIKE ''2%'''&Nation='" + nexacro.getApplication().gv_NationCd + "'";
	}
	else if (nexacro.getApplication().gv_mainFrame.PCategory2 == "Download_XP") 
	{
		//args = "goods_gbn='1%'&Nation='" + nexacro.getApplication().gv_NationCd + "'";
		args = "goods_gbn=' PRODUCT_CODE LIKE ''1%'''&Nation='" + nexacro.getApplication().gv_NationCd + "'";
	}
	else if (nexacro.getApplication().gv_mainFrame.PCategory2 == "Download_MP") 
	{
		//args = "goods_gbn='00%'&Nation='" + nexacro.getApplication().gv_NationCd + "'";
		args = "goods_gbn=' PRODUCT_CODE LIKE ''00%'''&Nation='" + nexacro.getApplication().gv_NationCd + "'";
	}
	else if (nexacro.getApplication().gv_mainFrame.PCategory2 == "XGEN") 
	{
		//args = "goods_gbn='3%'&Nation='" + nexacro.getApplication().gv_NationCd + "'";
		args = "goods_gbn=' PRODUCT_CODE LIKE ''3%'''&Nation='" + nexacro.getApplication().gv_NationCd + "'";
	}
	else if (nexacro.getApplication().gv_mainFrame.PCategory2 == "Nex-UP") 
	{
		//args = "goods_gbn='038'&Nation='" + nexacro.getApplication().gv_NationCd + "'";
		args = "goods_gbn=' PRODUCT_CODE LIKE ''038'''&Nation='" + nexacro.getApplication().gv_NationCd + "'";
	}
	else if (nexacro.getApplication().gv_mainFrame.PCategory2 == "Download_17") 
	{
		if (this.Pro_gub == "002" || this.Pro_gub == "003") 
		{
			//args = "goods_gbn='040'&Nation='" + nexacro.getApplication().gv_NationCd + "'";
			args = "goods_gbn=' PRODUCT_CODE LIKE ''040'''&Nation='" + nexacro.getApplication().gv_NationCd + "'";
		}
		else 
		{
			//args = "goods_gbn='039'&Nation='" + nexacro.getApplication().gv_NationCd + "'";
			args = "goods_gbn=' PRODUCT_CODE LIKE ''039'''&Nation='" + nexacro.getApplication().gv_NationCd + "'";
		}
	}
	else if (nexacro.getApplication().gv_mainFrame.PCategory2 == "nexacro platform17.1") 
	{
		if (this.Pro_gub == "002" || this.Pro_gub == "003") 
		{
			//args = "goods_gbn='040'&Nation='" + nexacro.getApplication().gv_NationCd + "'";
			args = "goods_gbn=' PRODUCT_CODE LIKE ''040'''&Nation='" + nexacro.getApplication().gv_NationCd + "'";
		}
		else if (this.Pro_gub == "004") 
		{
			//args = "goods_gbn='039'&Nation='" + nexacro.getApplication().gv_NationCd + "'";
			args = "goods_gbn=' PRODUCT_CODE LIKE ''039'''&Nation='" + nexacro.getApplication().gv_NationCd + "'";
		}
		else 
		{
			//args = "goods_gbn='041'&Nation='" + nexacro.getApplication().gv_NationCd + "'";
			args = "goods_gbn=' PRODUCT_CODE LIKE ''041'''&Nation='" + nexacro.getApplication().gv_NationCd + "'";
		}
	}

	args += "&kind='''" + this.Pro_gub + "'''";

	nexacro.getApplication().gds_MiWizard.clearData();
	nexacro.getApplication().com_AddMiWizard("", "output1", args, "XPLATFORM,TECH_MAIN,29");
	nexacro.getApplication().com_AddMiWizard("", "output2", args, "XPLATFORM,TECH_MAIN,30");

	this.com_CallService("select", "", "", "ds_list=output1 ds_list_detail=output2", "fn_callback", "CS", true);
};


this.btn_list_onclick = function (obj:Button, e:nexacro.ClickEventInfo)
{
	this.fn_QueryData();
};


this.productDown_onload = function (obj:Form, e:nexacro.LoadEventInfo)
{
	if (nexacro.getApplication().gds_UserInfo.getRowCount() <= 0) 
	{
		// alert("로그인 후 사용하세요.");
		nexacro.getApplication().gv_mainFrame.TargetUrl = "DOWNLOAD::frmGoodsDown.xfdl";
		nexacro.getApplication().gv_mainFrame.initFrmSet("Login");
	}
	else 
	{
		this.stcProdDownTitle.set_text(nexacro.getApplication().gv_mainFrame.PCategory2);
		this.LocationUrl = window.location;
	}
};

this.webBrowResult_onloadcompleted = function (obj:WebBrowser, e:nexacro.WebLoadCompEventInfo)
{

};

this.webBrowResult_onusernotify = function (obj:WebBrowser, e:nexacro.WebTitleChangeEventInfo)
{

};

this.cmb_kind_onitemchanged = function (obj:Combo, e:nexacro.ItemChangeEventInfo)
{
	this.fn_QueryData();
};



this.stcSechCmnt00_onclick = function (obj:Static, e:nexacro.ClickEventInfo)
{
	if (nexacro.getApplication().gv_mainFrame.PCategory2 == "nexacro platform14") 
	{
		// nexacro14
		window.open("http://docs.tobesoft.com/system_requirements#d293a3a4fa7d8d5b");
	}
	else if (nexacro.getApplication().gv_mainFrame.PCategory2.indexOf("nexacro platform17") >= 0) 
	{
		// nexacro17
		window.open("http://docs.tobesoft.com/system_requirements#9248a28530c3a1f8");
	}
};
]]></Script>
