<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="policyDoc" width="1300" height="1672" onload="policyDoc_onload" background="rgba(255,255,255,1)">
    <Layouts>
      <Layout width="1300" height="1672">
        <Tab id="tabPolicy" taborder="5" tabindex="0" left="0" top="0" width="1300" height="1672" cssclass="tab_WF_product" initvalueid="iv_Tab0">
          <Tabpages>
            <Tabpage id="Tabpage1" text="이메일주소 무단수집거부" url="ABOUT::frmPolicyDoc1.xfdl" accessibilityenable="false"/>
            <Tabpage id="Tabpage2" text="개인정보처리방침" url="ABOUT::frmPolicyDoc2.xfdl" accessibilityenable="false"/>
            <Tabpage id="Tabpage3" text="이용약관" url="ABOUT::frmPolicyDoc3.xfdl" accessibilityenable="false"/>
          </Tabpages>
        </Tab>
      </Layout>
    </Layouts>
    <Objects/>
    <Script type="xscript5.1"><![CDATA[
this.policyDoc_onload = function (obj:Form, e:nexacro.LoadEventInfo)
{
	this.set_height(1672+100);
	this.parent.set_height(1672+100);
	nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, 1672+200);
	
	var sKeyword = nexacro.getApplication().gv_mainFrame.param.keyword;
	if(sKeyword == "개인정보")
	{
		this.tabPolicy.set_tabindex(1);
	}
	
};

]]></Script>
  </Form>
</FDL>
