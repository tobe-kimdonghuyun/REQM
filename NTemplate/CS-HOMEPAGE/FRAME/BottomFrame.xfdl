// divFooter 중앙유지
this.BottomFrame_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fn_setBottomMidSize(e.cx);
};

// divFooter 중앙유지
this.fn_setBottomMidSize = function (nWidth)
{
	var leftSize = (nWidth - this.divBottom.width) / 2;

	if (leftSize > 0) 
	{
		this.divBottom.set_left(leftSize);
	}
	else 
	{
		this.divBottom.set_left(0);
	}

};

this.divBottom_staHelpDesk_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	// 저장된 스크롤 위치 초기화
	nexacro.getApplication().gv_mainFrame.SCROLL_POS = 0;
	
	nexacro.getApplication().gv_mainFrame.param = {
		'menu': "Help_Desk",
		'keyword': "",
		'page': 1,
		'postId': ""
		};
	nexacro.getApplication().gv_mainFrame.gfnGoMain();
};

