    <Script type="xscript5.1"><![CDATA[/**
*  매인프레임
*
*  @MenuPath 
*  @FileName 		FRAME::MainFrame.xfdl 
*  @Creator 		김광호
*  @CreateDate 		2022.01.01
*  @LastModifier  
*  @LastModifyDate  
*  @Version 		1.0
*  @Outline 		매인프레임
*  @Desction 
************** 소스 수정 이력 *************************************************
*    date          Modifier            Description
*******************************************************************************
*  2022.01.01      김광호	           최초 생성 
*******************************************************************************
*/

var objEnv = nexacro.getEnvironment();	// 웨이트커서 제어를 위해 선언

/*
 * 자동완성 관련
 */
this.Search_query = "";		// 자동완성 검색어
this.Search_oquery = ""; 	// 이전 검색어 - 연관 검색어 관련
this.Search_keywordIdx = -1;	// 자동완성 키워드 인덱스
this.Search_keyEnter = false;

this.LOGIN_FLG = false;		// 로그인 플래그(로그인 세션유지)

this.PCategory2;	// 현재 화면 ID

this.SearchEngineFlag = "";

this.QAStatus = "List";	// 글작성화면진입시 상태

this.QAKeyNo;			// 상세 진입시 글번호 저장

this.QA_Cond_startPageNo = 0;	// 페이징 시작 페이지
this.QA_Cond_Page = 1;			// 페이징 현재 페이지

this.QA_Cond_DisplayCnt = 100;	// 페이징 한번에 불러오는 행수
this.QA_Cond_Resetflag = true;
this.QA_Cond_Keyword = "";		// 검색어
this.QA_Cond_BusinessSection = "000";
this.QA_Cond_Resort = "N";
this.QA_Cond_Searchgubun = "OR"; //OR/AND
this.QA_Cond_Searchfield = "200"; //제목/내용
this.QA_Cond_AppPro = 0; 		//프로젝트 선택
this.QA_Cond_ListType = 0;		// 제목 <-> 제목-내용 토글 저장
this.QA_Cond_Prod = "All";		// 나의질문내역, 북마크 용 제품 탭 저장

this.tabCount = 0;

this.BoardCategoryID;
this.BoardStatus = "List";
this.BoardKeyNo;
this.BoardTitleBar;

this.Board_Cond_Resetflag = true;
this.Board_Cond_startPageNo = 0;
this.Board_Cond_Page = 1;
this.Board_Cond_DisplayCnt = 200;
this.Board_Cond_Keyword = "";
this.Board_Cond_KeywordAll = "";
this.Board_Cond_BusinessSection = "000";
this.Board_Cond_Resort = "N";
this.Board_Cond_Searchgubun = "OR"; //OR/AND
this.Board_Cond_Searchfield = "200"; //제목/내용

// 북마크에서 선택된 탭 인덱스
this.Bookmark_Tab_Index = 0;
this.MYPAGE_Cond_Prod = 0;
// 나의질문내역에서 선택된 탭 인덱스
this.My_Tab_Index = 0;
this.QA_Tab_Index = 0;
this.Chk_NPN_flag = true;
this.Chk_NP17_flag = true;
this.Chk_NP14_flag = true;
this.Chk_XP_flag = true;
this.Chk_MP_flag = true;
this.Chk_All_flag = true;

this.EduType = "";
this.EduReqNo = "";
this.EduNo = "";

this.TargetUrl;
this.TargetPostId;

this.strTempFilder1 = "";
this.arrIdx = [];
this.Data_Length = 0;

this.Top_Edit_flag = false;

// 리스트 화면의 화면 스크롤 유지를 위해 저장
this.SCROLL_POS = 0;

this.fileFullPath = "";

// 히스토리 관련==================================================================================
this.param = {
		'menu': "",
		'keyword': "",
		'page': 1,
		'postId': ""
	};
// ================================================================================================

/************************************************************************
 * Form Event 관련 함수
 ************************************************************************/
// 온로드
this.mainFrm_onload = function (obj:Form, e:nexacro.LoadEventInfo)
{
	nexacro.getApplication().gds_History.clearData();

	this.callGA("Main", "Main", "FRAME::MainFrame.xfdl");

	this.fn_setMainMidSize(this.width);
	this.fn_CodeData();
	 
	// 자동로그인 설정
	this.fn_AutoLogin();
	 
	// 히스토리 관련
	//모든화면에서 메인페이지에 접근을 쉽게 하기 위해 선언
	nexacro.indexPage = this;
	
	//히스토리 초기화
	MyHistory.init(this.onChangeHistory, this);
	
	this.initPage();
	
	this.resetScroll();
};

// 폼 사이즈 변경
this.mainFrm_onsize = function (obj:Form, e:nexacro.SizeEventInfo)
{
	// 탑프레임 고정
	this.staLoginBg.set_top(this.vscrollbar.pos);
	this.staLoginBg00.set_top(this.vscrollbar.pos);
	this.staTopTel.set_top(this.vscrollbar.pos);
	this.btnLogout.set_top(this.vscrollbar.pos);
	this.btnLogin.set_top(this.vscrollbar.pos);
	this.btnMypage.set_top(this.vscrollbar.pos);
	this.btnSignin.set_top(this.vscrollbar.pos);
	this.staLineLogin.set_top(10+this.vscrollbar.pos);
	this.divTop.set_top(40+this.vscrollbar.pos);
	this.staBGW00.set_top(120+this.vscrollbar.pos);
	this.staBGG00.set_top(120+this.vscrollbar.pos);

	this.showAutoCompleteResult(false);
	
	// 맨 앞으로
	this.staLoginBg.bringToFront();
	this.staLoginBg00.bringToFront();
	this.staTopTel.bringToFront();
	this.btnLogout.bringToFront();
	this.btnLogin.bringToFront();
	this.btnMypage.bringToFront();
	this.btnSignin.bringToFront();
	this.staLineLogin.bringToFront();
	this.divTop.bringToFront();
	this.staBGW00.bringToFront();
	this.staBGG00.bringToFront();
	if (this.Top_Edit_flag == true)
	{
		this.sta_autoCompleteResultTop.bringToFront();
		this.div_autoCompleteCover.bringToFront();
	}
	else
	{
		this.sta_autoCompleteResult.bringToFront();
		this.sta_autoCompleteResultTip.bringToFront();
		this.div_autoCompleteCover.bringToFront();
	}
	
	this.fn_setMainMidSize(e.cx);
	
	if (this.getVScrollPos() > 50 || this.getVScrollPos() != 0)
	{
		this.btnGoTop.bringToFront();
		this.btnGoTop.set_visible(true);
		this.btnGoTop.set_top(this.height - 130 + this.getVScrollPos());
	}
	else
	{
		this.btnGoTop.set_visible(false);
	}
	
};

// 중앙 정렬을 위한 size 구하기
this.fn_setMainMidSize = function (nWidth)
{
	// top,bottom고정
	if(nWidth < 1300)
	{
		this.divBottom.set_width(1300);
	} else {
		this.divTop.set_right(0);
		this.divBottom.set_right(0);
	}
	
	var leftSize = (nWidth - this.divMain.width) / 2;

	if (leftSize > 0) 
	{
		this.divMain.set_left(leftSize);
	}
	else 
	{
		this.divMain.set_left(0);
	}
	this.divTop.form.fn_setTopMidSize(nWidth);
	this.divBottom.form.fn_setBottomMidSize(nWidth);
};

// 폼 스크롤 시 UI정렬
this.mainFrm_onvscroll = function (obj:Form, e:nexacro.ScrollEventInfo)
{
	// 탑프레임 고정
	this.staLoginBg.set_top(e.pos);
	this.staLoginBg00.set_top(e.pos);
	this.staTopTel.set_top(e.pos);
	this.btnLogout.set_top(e.pos);
	this.btnLogin.set_top(e.pos);
	this.btnMypage.set_top(e.pos);
	this.btnSignin.set_top(e.pos);
	this.staLineLogin.set_top(10+e.pos);
	this.divTop.set_top(40+e.pos);
	this.staBGW00.set_top(120+e.pos);
	this.staBGG00.set_top(120+e.pos);
	if (this.Top_Edit_flag == true)
	{
		this.sta_autoCompleteResultTop.set_top(40+16+50-3+e.pos);
		this.div_autoCompleteCover.set_top(e.pos);
	}
	
	// 맨 앞으로
	this.staLoginBg.bringToFront();
	this.staLoginBg00.bringToFront();
	this.staTopTel.bringToFront();
	this.btnLogout.bringToFront();
	this.btnLogin.bringToFront();
	this.btnMypage.bringToFront();
	this.btnSignin.bringToFront();
	this.staLineLogin.bringToFront();
	this.divTop.bringToFront();
	this.staBGW00.bringToFront();
	this.staBGG00.bringToFront();
	if (this.Top_Edit_flag == true)
	{
		this.sta_autoCompleteResultTop.bringToFront();
		this.div_autoCompleteCover.bringToFront();
	}
	
	if (e.pos > 50 || e.pos != 0)
	{
		this.btnGoTop.bringToFront();
		this.btnGoTop.set_visible(true);
		this.btnGoTop.set_top(this.height - 130 + e.pos);
	}
	else
	{
		this.btnGoTop.set_visible(false);
	}
	
};

// 화면 히스토리 컴포넌트 정렬을 위한 타이머
this.mainFrame_ontimer = function (obj, e)
{
	this.killTimer(e.timerid);
	
	if (e.timerid == 111)
	{
		if (this.divMain.form.divHistory.form.staNext2.visible)
		{
			this.divMain.form.divHistory.form.btnHistory.set_left(this.divMain.form.divHistory.form.staNext2.getOffsetRight()+24);
		}
		else
		{
			this.divMain.form.divHistory.form.btnHistory.set_left(this.divMain.form.divHistory.form.staNext1.getOffsetRight()+24);
		}
		this.divMain.form.divHistory.form.btnHistory.set_visible(true);
	}
};

// 메뉴 이동 시 마다 제품 인덱스 초기화
this.MainFrame_onclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	this.divMain.form.divBookmark.form.tabProduct.set_tabindex(0);
};


/************************************************************************
 * Transaction & CallBack
 ************************************************************************/
// 공통코드 조회
this.fn_CodeData = function ()
{
	nexacro.getApplication().gds_MiWizard.clearData();
	var outds = "gds_ProcCate=output1 gds_ProcVers=output2 gds_Status=output3";

	// 제품분류
	nexacro.getApplication().com_AddMiWizard("", "output1", "CODE_GUBUN='PRODUCT_MODULE'", "CS,cs_common_code,1");
	// 버전
	nexacro.getApplication().com_AddMiWizard("", "output2", "CODE_GUBUN='026'", "COMM,code_common,11");
	// 처리상태
	nexacro.getApplication().com_AddMiWizard("", "output3", "CM_CODE='QL_STATUS_CODE'", "CS,cs_common_code,7");

	this.com_CallService("commCodeData", "", "", outds, "fn_CommCodeCallBack", "CS", true);
};

// 공통코드 조회 콜백
this.fn_CommCodeCallBack = function (svcid, errCode, errMsg)
{

};

// 회원정보 조회
this.fnSearchUserInfo = function()
{
	this.ds_InParam.setColumn(this.ds_InParam.rowposition, "User_id", nexacro.getPrivateProfile("cstop_nexacro_user_id"));

	var strServ = "SearchUser";
	var strUrl = "SVC_JSP::Next_JSP/Login/UserRegister_new.jsp";
	var strDsInput = "input=ds_InParam";
	var strDsOutput = "gds_UserInfo=output1";
	var strArgs = "RTYPE=XML DB='CS' REGISTTYPE=Search DBUSER='CSTOP'";

	this.com_TransSend(strServ, strUrl, strDsInput, strDsOutput, strArgs, "fn_MemberInfo_CallBack", false);
};

this.fn_MemberInfo_CallBack = function (svcid, errCode, errMsg)
{
	if (svcid == "SearchUser") 
	{
		// 로그인 체크 플래그(새로고침시 안플리게 하는 용도)
		this.LOGIN_FLG = true;
	}
};


/************************************************************************
 * 사용자 정의 함수
 ************************************************************************/
// 자동로그인 설정
this.fn_AutoLogin = function ()
{
	var bReturn = false;

	// 자동로그인 설정
	if (nexacro.getApplication().gds_UserInfo.getRowCount() == 0) 
	{
		if (!this.gfnIsNull(nexacro.getPrivateProfile("cstop_nexacro_user_id")) && nexacro.getPrivateProfile("auto_login_flag") == 1) 
		{
			var nRow = nexacro.getApplication().gds_UserInfo.addRow();
			nexacro.getApplication().gds_UserInfo.setColumn(nexacro.getApplication().gds_UserInfo.rowposition, "User_id", nexacro.getPrivateProfile("cstop_nexacro_user_id"));
			
			this.fnSearchUserInfo();
			
			this.btnLogin.set_visible(false);
			this.btnLogout.set_visible(true);
			this.btnSignin.set_visible(false);
			this.btnMypage.set_visible(true);
			bReturn = true;
		}
		else
		{
			nexacro.getApplication().gds_UserInfo.clearData();
			this.btnLogin.set_visible(true);
			this.btnLogout.set_visible(false);
			this.btnSignin.set_visible(true);
			this.btnMypage.set_visible(false);

			if (this.gfnIsNull(nexacro.getPrivateProfile("cstop_nexacro_user_id")))
			{
				nexacro.setPrivateProfile("cstop_nexacro_user_id", "undefined");
			}
			nexacro.setPrivateProfile("auto_save_flag", 0);
			bReturn = false;
		}
	}
	else if (this.gfnIsNull(nexacro.getPrivateProfile("cstop_nexacro_user_id")))
	{
		nexacro.getApplication().gds_UserInfo.clearData();
		this.btnLogin.set_visible(true);
		this.btnLogout.set_visible(false);
		this.btnSignin.set_visible(true);
		this.btnMypage.set_visible(false);

		nexacro.setPrivateProfile("cstop_nexacro_user_id", "undefined");
		nexacro.setPrivateProfile("save_id_flag", 0);
		nexacro.setPrivateProfile("auto_save_flag", 0);
		bReturn = false;
	}
	else
	{
		bReturn = true;
	}
	return bReturn;
};

this.getCookie = function (cName)
{
	cName = cName + '=';
	var cookieData = window.document.cookie;
	var start = cookieData.indexOf(cName);
	var cValue = '';
	if (start != -1) 
	{
		start += cName.length;
		var end = cookieData.indexOf(';', start);
		if (end == -1) 
		{
			end = cookieData.length;
		}
		cValue = cookieData.substring(start, end);
	}
	return unescape(cValue);
};

// call google analytics _trackEvent
this.callGA = function (category, action, opt_label)
{
	var categoryUrl = this.getFriendlyUrl(category);
	var actionUrl = this.getFriendlyUrl(action);
	var optlabelUrl = this.getFriendlyUrl(opt_label);
	var page = "/" + categoryUrl + "/" + actionUrl + "/" + optlabelUrl;
	var title = optlabelUrl;

	ga("set", "page", page);
	ga("set", "title", title);
	ga("send", "event", category, action, opt_label);
};

/**
 * function to urlify a string.
 * @param {string} str 대상 문자열.
 * @return {string} url 친화적 문자열.
 * @memberOf BB.Tracking
 */
this.getFriendlyUrl = function (str)
{
	var rtn = str.toLowerCase().replace(/[^a-z0-9가-힣-]+/g, "-").replace(/^-+|-+$/g, "-").replace(/^-+|-+$/g, '');
	return rtn;
};

// Search Filter토글 화면 조정
this.fn_setFilterResize = function()
{
	this.divMain.form.divWork.set_top(this.divMain.form.divSearch.getOffsetBottom());
	this.divMain.set_height(this.divMain.form.divWork.getOffsetBottom());
	this.divBottom.set_top(this.divMain.getOffsetBottom());
	this.resetScroll();
};


/************************************************************************
 * 메뉴이동 관련
 ************************************************************************/
// 히스토리 관련
this.initPage = function(){
	if(nexacro._Browser!="Runtime")
	{
		var urlParams = nexacro.urlParams;
		//링크타고 들어올 경우
		if(urlParams&&(this.gfnIsNull(urlParams.postId)==false||this.gfnIsNull(urlParams.menu)==false))
		{
			this.param.menu = urlParams.menu;
			this.param.keyword = urlParams.keyword;
			this.param.page = urlParams.page;
			this.param.postId = urlParams.postid;
			
			//로그인 풀리지 않게 하기위해 LOGIN_FLG 체크
			if (!this.gfnIsNull(this.gfnGetHistoryData()))
			{
				if (this.gfnGetHistoryData().LOGIN_FLG)
				{
					//alert("로그인");
					var nRow = nexacro.getApplication().gds_UserInfo.addRow();
					nexacro.getApplication().gds_UserInfo.setColumn(nexacro.getApplication().gds_UserInfo.rowposition, "User_id", nexacro.getPrivateProfile("cstop_nexacro_user_id"));
					
					this.fnSearchUserInfo();
					
					this.btnLogin.set_visible(false);
					this.btnLogout.set_visible(true);
					this.btnSignin.set_visible(false);
					this.btnMypage.set_visible(true);
				}
				else
				{

				}
			}
			
			this.gfnGoMain();
		}
		//새로고침 시
		else
		{
			var sHash = MyHistory.getLocationHash();		
			//히스토리 기록이 있을 경우
			if ( !this.gfnIsNull(sHash) )
			{
				var sData = {};
				this.onChangeHistory(sHash, sData);
			}
			//히스토리 기록이 없을 경우
			else
			{
				this.param.menu = "home";

				this.param = {
					'menu': "home",
					'keyword': "",
					'page': 1,
					'postId': ""
				};
				this.gfnGoMain();
			}
		}
	}
	//전용브라우저로 실행 시
	else{
		this.param.menu = "home";

		this.param = {
			'menu': "home",
			'keyword': "",
			'page': 1,
			'postId': ""
		};
		this.gfnGoMain();
	}
};

// 브라우저의 뒤로가기, 앞으로가기 실행시 호출됨
this.onChangeHistory = function(sHash, sData)
{
	var urlParams = {};
	
	//hash값으로 파라미터 정보 가져오기
	(function () {
		var match,
		pl     = /\+/g,
		search = /([^&=]+)=?([^&]*)/g,
		decode = function (s) { return decodeURIComponent(s.replace(pl, " ")); },
		query  = sHash;
		while (match = search.exec(query)) { urlParams[decode(match[1])] = decode(match[2]); }
		})();
	
	//페이지 이동을 위한 파라미터 오브젝트에 값 추가
	this.param.menu = urlParams.menu;
	this.param.keyword = urlParams.keyword;
	this.param.page = urlParams.page;
	this.param.postId = urlParams.postid;

	//menu값이 없으면 메인화면으로
	if ( this.gfnIsNull(this.param.menu) )
	{
		this.param = {
		'menu': "home",
		'keyword': "",
		'page': 1,
		'postId': ""
		};
	}

	this.gfnGoMain();
};

// 히스토리와 세션데이터 저장
this.gfnSetHistory = function(data)
{
	var sHash;
	var sData = {};
	sData = data;
	sData.LOGIN_FLG = this.LOGIN_FLG;
	var sUrl;
		
	var sMenu = this.param.menu;
	var sKeyWord = this.param.keyword;
	var nPage = this.param.page;
	var sPostId = this.param.postId;
	
	sHash = "menu="+sMenu
	if (!this.gfnIsNull(nPage))	{sHash+="&page="+nPage;}
	if (!this.gfnIsNull(sKeyWord))	{sHash+="&keyword="+sKeyWord;}
	if (!this.gfnIsNull(sPostId))	{sHash+="&postid="+sPostId;}
	sUrl = ".?"+sHash;
	MyHistory.setData(sHash, sData);
	MyHistory.setLocationHash(sHash, sData, sUrl);
};

// 히스토리와 세션데이터 불러오기
this.gfnGetHistory = function()
{
	var sHash = MyHistory.getLocationHash();		

	var urlParams = {};
	
	//hash값으로 파라미터 정보 가져오기
	(function () {
		var match,
		pl     = /\+/g,
		search = /([^&=]+)=?([^&]*)/g,
		decode = function (s) { return decodeURIComponent(s.replace(pl, " ")); },
		query  = sHash;
		while (match = search.exec(query)) { urlParams[decode(match[1])] = decode(match[2]); }
		})();
	
	//페이지 이동을 위한 파라미터 오브젝트에 값 추가
	this.param.menu = urlParams.menu;
	this.param.keyword = urlParams.keyword;
	this.param.page = urlParams.page;
	this.param.postId = urlParams.postid;
};

// 히스토리 Data만 저장
this.gfnSetHistoryData = function(data)
{
	var sHash;
	var sData = {};
	sData = data;

	sData.LOGIN_FLG = this.LOGIN_FLG;

	var sUrl;
		
	var sMenu = this.param.menu;
	var sKeyWord = this.param.keyword;
	var nPage = this.param.page;
	var sPostId = this.param.postId;
	
	sHash = "menu="+sMenu
	if (!this.gfnIsNull(nPage))	{sHash+="&page="+nPage;}
	if (!this.gfnIsNull(sKeyWord))	{sHash+="&keyword="+sKeyWord;}
	if (!this.gfnIsNull(sPostId))	{sHash+="&postid="+sPostId;}
	sUrl = ".?"+sHash;
	
	MyHistory.setData(sHash, sData);
};

// 히스토리 Data만 불러오기
this.gfnGetHistoryData = function()
{
	var sHash;

	var sMenu = this.param.menu;
	var sKeyWord = this.param.keyword;
	var nPage = this.param.page;
	var sPostId = this.param.postId;
	
	sHash = "menu="+sMenu
	if (!this.gfnIsNull(nPage))	{sHash+="&page="+nPage;}
	if (!this.gfnIsNull(sKeyWord))	{sHash+="&keyword="+sKeyWord;}
	if (!this.gfnIsNull(sPostId))	{sHash+="&postid="+sPostId;}
	
	return MyHistory.getData(sHash);
};

// 화면 이동
this.gfnGoMain = function()
{
	var sHash;
	var sData = {};
	var sUrl;
		
	var sMenu = this.param.menu;
	var sKeyWord = this.param.keyword;
	var nPage = this.param.page;
	var sPostId = this.param.postId;
	//trace(sMenu);
	var nFindRow = this.dsScreenUrl.findRow("subCatgy", sMenu);
	var sLink = "";
	if (!this.gfnIsNull(this.dsScreenUrl.getColumn(nFindRow, "Link")))	// 메뉴가 링크일 경우 url을 호출 
	{
		sLink = this.dsScreenUrl.getColumn(nFindRow, "Link");
		// 링크 오픈
		system.execBrowser(sLink);
		return;
	}
	
	//게시물번호가 있을 경우 상세화면으로
	if(!this.gfnIsNull(sPostId))
	{
		sHash = "menu="+sMenu+"&postid="+sPostId;
		sUrl = ".?"+sHash;
		sData.LOGIN_FLG = this.LOGIN_FLG;
		MyHistory.setLocationHash(sHash, sData, sUrl);
		
		// 업무화면 상세
		this.fn_Open();
	}
	//게시물번호가 없을 경우 
	else if(sMenu=="home")	// 매인 홈
	{
		sHash = "menu="+sMenu;
		
		sUrl = ".?"+sHash;
		sData.LOGIN_FLG = this.LOGIN_FLG;
		MyHistory.setLocationHash(sHash, sData, sUrl);

		this.fn_Open();
	}
	else if(sMenu=="login")	// 로그인
	{
		sHash = "menu="+sMenu;
		sUrl = "./"
		sData.LOGIN_FLG = this.LOGIN_FLG;
		MyHistory.setLocationHash(sHash, sData, sUrl);
		
		this.fn_Open();
	}
	else	// 업무화면 리스트 & 기타
	{
		sHash = "menu="+sMenu+"&page="+nPage;
		if(!this.gfnIsNull(sKeyWord))	sHash += "&keyword="+sKeyWord;
		sUrl = ".?"+sHash
		sData.LOGIN_FLG = this.LOGIN_FLG;
		MyHistory.setLocationHash(sHash, sData, sUrl);

		this.fn_Open();
	}
}

// 화면 오픈(화면에 맞게 UI(divMain안의 사이즈, 위치 등) 조정)
this.fn_Open = function()
{
	this.divMain.set_visible(false);
	this.divMain.form.divHistory.form.btnHistory.set_fittocontents("width");
	this.divMain.form.divWork.set_url("");
	// 스크롤 초기화(0으로)
	this.vscrollbar.set_pos(0);
	
	// 자동완성 관련 닫기
	this.showAutoCompleteResult(false);
	
	var sMenu = this.param.menu;
	var sKeyWord = this.param.keyword;
	var nPage = this.param.page;
	var sPostId = this.param.postId;
	
	// BOARD등에서 활용하기 위해 변수로 저장
	this.PCategory2 = sMenu;
	
	this.QA_Cond_Keyword = sKeyWord;
	this.QA_Cond_Page = nPage;
	this.strTempFilder1 = sPostId;
	
	// 업무화면 오픈 사전준비
	var nRow = this.dsScreenUrl.findRow("subCatgy", sMenu);
	var sUrl = "";
	var sLayout = "";
	var sCategory = "";
	var sSubCategory = "";

	// 현재 메뉴이름 저장
	nexacro.getApplication().gv_CurMenu = this.dsScreenUrl.getColumn(nRow, "DisplayNm");
	
	if(nRow >= 0)
	{
		sUrl 			= this.dsScreenUrl.getColumn(nRow, "scrUrl");
		sLayout 		= this.dsScreenUrl.getColumn(nRow, "Layout");
		sCategory 		= this.dsScreenUrl.getColumn(nRow, "category");
		sSubCategory 	= this.dsScreenUrl.getColumn(nRow, "subCatgy");
	}
	//trace("sMenu::"+sMenu);
	//trace("sPostId::"+sPostId);
	//trace("sUrl::"+sUrl);
	// 메뉴 위치(divHistory) 셋팅
	if(sMenu != "login" && sMenu != "home")
	{
		this.fn_setHistory(sMenu);
	}
	// 매인화면 뒤에 배경 안보이게
	this.staBgInitMain.set_visible(false);
	this.staBGG.set_visible(false);
	this.staBGG00.set_visible(false);
	this.staBGW.set_visible(false);
	this.staBGW00.set_visible(false);
	this.staBottomLine.set_visible(false);
	this.divMain.form.divBookmark.set_visible(false);
	// 화면 div 조정 및 일부는 화면 표시
	//this.callGA("Main", "Main", "FRAME::MainFrame.xfdl");

	switch(sLayout)
	{
		case "login":	// 로그인
			this.divMain.form.divSearch.set_url("");
			this.SearchEngineFlag = "";
			this.divMain.set_top(this.divTop.getOffsetBottom());
			// 로케이션 안보이게
			this.divMain.form.divHistory.set_visible(false);
			// divFull 보이게
			this.divMain.form.divHistory.set_visible(false);
			this.divMain.form.divSearch.set_visible(false);
			this.divMain.form.divWork.set_visible(false);
			this.divMain.form.divFull.set_visible(true);
			this.divMain.form.divFull.bringToFront();
			this.divMain.set_height(870+40);
			this.divMain.form.divFull.set_height(870+40);
			this.divMain.form.divFull.set_url("LOGIN::frmLogin.xfdl");
			this.divMain.form.divWork.set_url("");
			this.divBottom.set_top(this.divMain.getOffsetBottom());
			// 백그라운드
			this.staBGG.set_height(870+40);
			this.staBGG.set_visible(true);
			this.staBGG00.set_visible(true);
			this.divMain.set_visible(true);
			this.divMain.form.resetScroll();
			
			this.callGA(sCategory, sSubCategory, "LOGIN::frmLogin.xfdl");
			break;
		case "home":	// 매인화면
			this.divMain.form.divSearch.set_url("");
			this.SearchEngineFlag = "";
			this.divMain.set_top(this.divTop.getOffsetBottom());
			// 로케이션 안보이게
			this.divMain.form.divHistory.set_visible(false);
			// divFull 보이게
			this.divMain.form.divHistory.set_visible(false);
			this.divMain.form.divSearch.set_visible(false);
			this.divMain.form.divWork.set_visible(false);
			this.divMain.form.divFull.set_visible(true);
			this.divMain.form.divFull.bringToFront();
			this.divMain.set_height(1770);
			this.divMain.form.divFull.set_height(1770);
			this.divMain.form.divFull.set_url("MAIN::frmInitMain.xfdl");
			this.divMain.form.divWork.set_url("");
			this.divBottom.set_top(this.divMain.getOffsetBottom());
			// 백그라운드
			this.staBgInitMain.set_visible(true);
			this.staBGG.set_height(1770);
			this.staBGG.set_visible(true);
			this.staBGG00.set_visible(true);
			this.divMain.set_visible(true);
			this.divMain.form.resetScroll();
			this.callGA(sCategory, sSubCategory, "MAIN::frmInitMain.xfdl");
			break;
		case "DETAIL":	// 업무화면"DETAIL"(divRight OFF)
			if (sMenu != "SearchEngine_QnA_View" && sMenu != "SearchEngine_Board_View")
			{
				this.SearchEngineFlag = "";
			}
			this.divMain.set_top(this.divTop.getOffsetBottom());
			this.divMain.form.divFull.set_visible(false);
			this.divMain.form.divHistory.set_visible(true);
			this.divMain.form.divSearch.set_visible(false);
			this.divMain.form.divWork.set_visible(true);
			this.divMain.form.divWork.set_width(1300);
			this.divMain.form.divWork.set_top(148);
			this.staBGW.set_height(870+40);
			this.staBGW.set_visible(true);
			this.staBGW00.set_visible(true);
			
			this.divMain.form.divWork.set_url(sUrl);
			this.callGA(sCategory, sSubCategory, sUrl);
			break;
		case "QnA":	// 업무화면"QnA"(divSearch 있음)
			this.SearchEngineFlag = "";
			// 필터크기 초기화
			
			//검색조건 초기화
			this.QA_Cond_Prod = "All";

			this.divMain.set_top(this.divTop.getOffsetBottom());
			this.divMain.form.divFull.set_visible(false);
			this.divMain.form.divHistory.set_visible(false);
			this.divMain.form.divSearch.set_height(255);
			this.divMain.form.divSearch.set_visible(true);
			this.divMain.form.divSearch.set_url("SUPPORT::frmSearch.xfdl");
			this.divMain.form.divWork.set_visible(true);
			this.divMain.form.divWork.set_width(1300);
			this.divMain.form.divWork.set_top(this.divMain.form.divSearch.getOffsetBottom());
			// 백그라운드
			this.staBGG.set_height(221);
			this.staBGG.set_visible(true);
			this.staBGG00.set_visible(true);
			this.divMain.form.divWork.set_url(sUrl);
			this.callGA(sCategory, sSubCategory, sUrl);
			break;
		case "SEARCH":	// 통합검색 화면 (divSearch 있음)
			//검색조건 초기화
			this.QA_Cond_Prod = "All";
			
			this.divMain.set_top(this.divTop.getOffsetBottom());
			this.divMain.form.divFull.set_visible(false);
			this.divMain.form.divHistory.set_visible(false);
			this.divMain.form.divSearch.set_height(255);
			this.divMain.form.divSearch.set_visible(true);
			this.divMain.form.divSearch.set_url("SEARCHENGINE::frmSearchEngine.xfdl");
			this.divMain.form.divWork.set_visible(true);
			this.divMain.form.divWork.set_width(1300);
			this.divMain.form.divWork.set_top(this.divMain.form.divSearch.getOffsetBottom());
			// 백그라운드
			this.staBGG.set_height(221);
			this.staBGG.set_visible(true);
			this.staBGG00.set_visible(true);
			
			if (this.SearchEngineFlag == "Nexacro N" || 
			this.SearchEngineFlag == "nexacro platform17" || 
			this.SearchEngineFlag == "nexacro platform14" || 
			this.SearchEngineFlag == "XPLATFORM" || 
			this.SearchEngineFlag == "MiPlatform")
			{
				this.divMain.form.divWork.set_url("SUPPORT::frmTechInquireList.xfdl");
			}
			else if(this.SearchEngineFlag == "Tip" || 
			this.SearchEngineFlag == "Education_Notice" || 
			this.SearchEngineFlag == "Education_material" || 
			this.SearchEngineFlag == "Notice")
			{
				this.divMain.form.divWork.set_url("BOARD::frmBoardList.xfdl");
			}
			this.callGA(sCategory, sSubCategory,"SEARCHENGINE::frmSearchEngine.xfdl");
			break;
		case "BOOKMARK":	// 북마크(QnA와 Tip을 토글하여 보여주는 UI)
			this.divMain.form.divSearch.set_url("");
			this.SearchEngineFlag = "";
			this.divMain.set_top(this.divTop.getOffsetBottom());
			this.divMain.form.divFull.set_visible(false);
			this.divMain.form.divHistory.set_visible(true);
			if (sMenu == "Bookmark")
			{
				this.divMain.form.divBookmark.form.rdoBookmark.set_value(0);
			}
			this.divMain.form.divBookmark.form.rdoBookmark.set_visible(true);
			if (this.divMain.form.divBookmark.form.rdoBookmark.index == 0)
			{
				sUrl = "SUPPORT::frmTechInquireList.xfdl";
			}
			else
			{
				sUrl = "BOARD::frmBoardList.xfdl";
			}
			this.divMain.form.divBookmark.form.tabProduct.set_top(50);
			this.divMain.form.divBookmark.set_height(116);
			this.divMain.form.divBookmark.set_visible(true);
			this.divMain.form.divSearch.set_visible(false);
			this.divMain.form.divWork.set_visible(true);
			this.divMain.form.divWork.set_width(1300);
			this.divMain.form.divWork.set_top(this.divMain.form.divBookmark.getOffsetBottom());
			this.staBGW.set_height(870+40);
			this.staBGW.set_visible(true);
			this.staBGW00.set_visible(true);
			
			this.divMain.form.divWork.set_url(sUrl);
			this.callGA(sCategory, sSubCategory, sUrl);
			break;
		case "MYQNALIST":	// 나의 질문내역(QnA만 보임)
			this.divMain.form.divSearch.set_url("");
			this.SearchEngineFlag = "";
			this.divMain.set_top(this.divTop.getOffsetBottom());
			this.divMain.form.divFull.set_visible(false);
			this.divMain.form.divHistory.set_visible(true);
			this.divMain.form.divBookmark.form.rdoBookmark.set_visible(false);
			this.divMain.form.divBookmark.form.tabProduct.set_top(0);
			this.divMain.form.divBookmark.set_height(66);
			this.divMain.form.divBookmark.set_visible(true);
			this.divMain.form.divSearch.set_visible(false);
			this.divMain.form.divWork.set_visible(true);
			this.divMain.form.divWork.set_width(1300);
			this.divMain.form.divWork.set_top(this.divMain.form.divBookmark.getOffsetBottom());
			this.staBGW.set_height(870+40);
			this.staBGW.set_visible(true);
			this.staBGW00.set_visible(true);
			
			this.divMain.form.divWork.set_url(sUrl);
			this.callGA(sCategory, sSubCategory, sUrl);			
			break;
		default:
	}
	this.resetScroll();	// 동적으로 변경한 UI의 정렬을 위해
	this.vscrollbar.set_pos(0);	// 스크롤 초기화
};

// divHistory 셋팅(화면 depth(히스토리) 표시 영역 셋팅
this.fn_setHistory = function(sMenu)
{
	if (sMenu == "Bookmark_Tip" || sMenu == "Bookmark_Tip_View")
	{
		sMenu = "Bookmark";
	}
	else if (sMenu == "SearchEngine")
	{
		this.divMain.set_visible(true);
		return;
	}
	else if (sMenu == "MyQnAList_View" )
	{
		sMenu == "MyQnAList";
	}
	this.divMain.form.divHistory.form.btnHistory.set_visible(false);
	this.dsHistory.filter("");
	var nRow = this.dsHistory.findRow("menuId", sMenu.replace("_View", ""));
	if (nRow == -1)
	{
		return;
	}
	this.divMain.form.divHistory.form.btnHistory.set_visible(true);
	this.divMain.form.divHistory.form.staNext1.set_visible(true);
	
	// cate1
	var sMenuNm = this.dsHistory.getColumn(nRow, "menuNm");
	this.divMain.form.divHistory.form.staCate1.set_text(this.dsHistory.getColumn(nRow, "cate1"));
	this.divMain.form.divHistory.form.btnHistory.set_text(sMenuNm);
	var sKo = /[ㄱ-ㅎ|ㅏ-ㅣ|가-힣]/;
	var nSize = 0;
	var arrMenuKo = [];
	var arrMenuEn = [];
	var j = 0;
	this.divMain.form.divHistory.form.btnHistory.set_fittocontents("none");
	
	// 글자 크기에 따른 사이즈 조정을 위해 계산
	for(var i = 0; i < sMenuNm.length; i++)
	{
		if(sKo.test(sMenuNm[i]))
		{
			arrMenuKo[i] = sMenuNm[i];
		}
		else
		{
			arrMenuEn[j] = sMenuNm[i];
			j++;
		}	
	}
	
	if(arrMenuEn.length > 0)
	{
		var sEn = /[a-z]/;
		for(var i = 0; i < arrMenuEn.length; i++)
		{
			if(sEn.test(arrMenuEn[i]))
			{
				nSize += 28.2;
				if(arrMenuEn[i] == " ")
				{
					nSize -= 28.2;
				}
			}
			else
			{
				nSize += 22;
				if(arrMenuEn[i] == " ")
				{
					nSize -= 22;
				}
			}
		}
		if(sMenuNm == "Tip")
		{
			nSize = 97;
		}
	}
	if(arrMenuKo.length > 0)
	{
		for(var i = 0; i < arrMenuKo.length; i++)
		{
			if(arrMenuKo.length == 3)
				nSize += 46;
			else if (arrMenuKo.length == 4)
				nSize += 43;
			else if (arrMenuKo.length == 7)
				nSize += 35;
			else
				nSize += 41;
		}
	}
	
	this.divMain.form.divHistory.form.btnHistory.set_width(nSize);
	// cate2 & pdiv
	if (this.dsHistory.getColumn(nRow, "cate1") == "Product")		// PRODUCT메뉴의 경우 제품간 이동도 필요하므로 처리
	{
		this.divMain.form.divHistory.form.staCate2.set_visible(true);
		this.divMain.form.divHistory.form.staNext2.set_visible(true);

		this.divMain.form.divHistory.form.staCate2.set_text(this.dsHistory.getColumn(nRow, "cate2"));
		var sKey = sMenu.substr(-2, 2);
		switch(sKey) {
		case "_N":
			this.dsHistory.filter("cate2=='Nexacro N'");
			break;
		case "17":
			this.dsHistory.filter("cate2=='nexacro 17'");
			break;
		case "14":
			this.dsHistory.filter("cate2=='nexacro 14'");
			break;
		case "XP":
			this.dsHistory.filter("cate2=='XPLATFORM'");
			break;
		case "MP":
			this.dsHistory.filter("cate2=='MiPlatform'");
			break;
		default:
		}
		this.divMain.form.divHistory.form.resetScroll();
	}
	else
	{
		if (this.gfnIsNull(this.dsHistory.getColumn(nRow, "cate2")))
		{
			this.divMain.form.divHistory.form.staNext1.set_visible(false);
			this.divMain.form.divHistory.form.staCate2.set_visible(false);
		}
		else
		{
			this.divMain.form.divHistory.form.staCate2.set_text(this.dsHistory.getColumn(nRow, "cate2"));
		}
	
		this.divMain.form.divHistory.form.staCate2.set_visible(false);
		this.divMain.form.divHistory.form.staNext2.set_visible(false);
		this.dsHistory.filter("cate1=='"+this.dsHistory.getColumn(nRow, "cate1")+"'");
		this.divMain.form.divHistory.form.resetScroll();
	}
	
	// pdiv 높이 조정하기
	this.divMain.form.divHistory.form.pdivHistory.set_height(this.dsHistory.rowcount*40+20);
	
	// pdivProd셋팅 sta 안보이게하고 btn보이게
	if (this.dsScreenUrl.getColumn(this.dsScreenUrl.findRow("subCatgy", sMenu), "category") == "Product")
	{
		switch(sMenu.substr(0, 3)) {
		case "Dow":
			this.dsHistoryProd.filter("cate3=='Download'");
			break;
		case "Doc":
			this.dsHistoryProd.filter("cate3=='Document'");
			break;
		case "Tip":
			if (sMenu.substr(0, 8) == "Tip_View")
			{
				this.dsHistoryProd.filter("cate3=='Tip View'");
			}
			else
			{
				this.dsHistoryProd.filter("cate3=='Tip'");
			}
			break;
		default:
		}
	
		var sProcNm = this.dsHistoryProd.getColumn(this.dsHistoryProd.findRow("menuId", sMenu), "cate2");
		var nProcSize = 0;
		this.divMain.form.divHistory.form.btnHistoryProd.set_fittocontents("none");
		

		var nSize = 0;
		switch(sProcNm) {
		case "Nexacro N V24":
			nSize = 244;
			break;		
		case "Nexacro N":
			nSize = 224;
			break;
		case "nexacro 17":
			nSize = 234;
			break;
		case "nexacro 14":
			nSize = 234;
			break;
		case "XPLATFORM":
			nSize = 250;
			break;
		case "MiPlatform":
			nSize = 238;
			break;
		default:
		}
		this.divMain.form.divHistory.form.btnHistoryProd.set_width(nSize);
		
		this.divMain.form.divHistory.form.btnHistoryProd.set_text(sProcNm);

		this.divMain.form.divHistory.form.staCate2.set_visible(false);
		this.divMain.form.divHistory.form.btnHistoryProd.set_visible(true);

		
		// 위치
		this.divMain.form.divHistory.form.btnHistoryProd.set_left(this.divMain.form.divHistory.form.staNext1.getOffsetRight());
		this.divMain.form.divHistory.form.staNext2.set_left(this.divMain.form.divHistory.form.btnHistoryProd.getOffsetRight()+20);
		this.divMain.form.divHistory.form.btnHistory.set_left("staNext2:0px");
	}
	else
	{
		this.divMain.form.divHistory.form.btnHistoryProd.set_visible(false);
	}
	
	// 메뉴가 하나일 경우(depth1 짜리 메뉴일 경우)
	if (this.dsHistory.rowcount == 1)
	{
		this.divMain.form.divHistory.form.staCate2.set_visible(true);
		this.divMain.form.divHistory.form.staCate2.set_text(this.dsHistory.getColumn(0, "cate2"));
		this.divMain.form.divHistory.form.btnHistory.set_visible(false);
		this.divMain.form.divHistory.form.resetScroll();
	}
	else if (sMenu == "QnA" || sMenu == "QnA_Write" || sMenu == "QnA_View")	// Q&A일 경우
	{
		this.divMain.form.divHistory.form.staCate2.set_visible(false);
		this.divMain.form.divHistory.form.staNext1.set_visible(false);
		this.divMain.form.divHistory.form.staNext2.set_visible(false);
		this.divMain.form.divHistory.form.btnHistory.set_visible(false);
		this.divMain.form.divHistory.form.resetScroll();
	}
	// 통합검색의 상세화면일때 히스토리버튼메뉴 가리기
	else if (sMenu == "SearchEngine_QnA_View" || sMenu == "SearchEngine_Board_View")
	{
		this.divMain.form.divHistory.form.btnHistory.set_visible(false);
		this.divMain.form.divHistory.form.resetScroll();
	}
	else
	{
		this.setTimer(111, 50);		// 히스토리 간격조정을 위한 타이머
	}
};

// divMain, divBottom 사이즈 조정
this.fn_setMainResize = function (nFlag, nHeight)
{
	var sMenu = this.param.menu;
	// 업무화면 오픈 사전준비
	var nRow = this.dsScreenUrl.findRow("subCatgy", sMenu);
	var sLayout = "";
	if(nRow > -1)
	{
		sLayout = this.dsScreenUrl.getColumn(nRow, "Layout");
	}
	if (sLayout != "DETAIL")
	{
		if (nHeight < 1080) nHeight = 1080;
	}

	// divWork높이
	this.divMain.form.divWork.set_height(nHeight-200);
	// divMain높이
	if (sLayout == "QnA" || sLayout == "SEARCH")
	{
		this.divMain.set_height(nHeight+this.divMain.form.divSearch.getOffsetHeight());	// 495
		this.divMain.form.divWork.set_height(nHeight);
	}
	else if (sLayout == "MYQNALIST")
	{
		this.divMain.set_height(nHeight+66);
	}
	else if (sLayout == "BOOKMARK")
	{
		this.divMain.set_height(nHeight+116);
	}
	else
	{
		this.divMain.set_height(nHeight);
	}
	// divBottom높이
	this.divBottom.set_top(this.divMain.getOffsetBottom());
	
	// 배경 회색인 화면들
	if (sMenu == "QnA_Write" || sMenu == "MemberInfo" || sMenu == "MembWithdrawal")
	{
		this.staBGW.set_visible(false);
		this.staBGW00.set_visible(false);
		this.staBGG.set_height(this.divMain.height);
		this.staBGG.set_visible(true);
		this.staBGG00.set_visible(true);
	}

	// bottom 라인
	this.staBottomLine.set_top();
	this.staBottomLine.set_bottom("divBottom:0");
	this.staBottomLine.bringToFront();
	this.staBottomLine.set_visible(true);

	
	this.vscrollbar.set_pos(0);
	
	// divTop 위치 재설정
	this.staLoginBg.set_top(0);
	this.staLoginBg00.set_top(0);
	this.staTopTel.set_top(0);
	this.btnLogout.set_top(0);
	this.btnLogin.set_top(0);
	this.btnMypage.set_top(0);
	this.btnSignin.set_top(0);
	this.staLineLogin.set_top(10+0);
	this.divTop.set_top(40+0);
	this.staBGW00.set_top(120+0);
	this.staBGG00.set_top(120+0);
	
	// divMain 보이게
	this.divMain.set_visible(true);
	
	this.resetScroll();
};


/************************************************************************
 * Component Event
 ************************************************************************/
// 로그인 버튼 이벤트
this.btnLogin_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 저장된 스크롤 위치 초기화
	this.SCROLL_POS = 0;

	this.TargetUrl = this.param.menu;

	this.param = {
		'menu': "login",
		'keyword': "",
		'page': 1,
		'postId': ""
		};
	this.gfnGoMain();
};

// 로그아웃 버튼 이벤트 처리
this.btnLogout_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 저장된 스크롤 위치 초기화
	this.SCROLL_POS = 0;

	if (nexacro.getPrivateProfile("save_id_flag")==0)
	{
		nexacro.setPrivateProfile("cstop_nexacro_user_id", "");
	}
	nexacro.setPrivateProfile("get_email", "");

	nexacro.setPrivateProfile("auto_login_flag", 0);
	
	// 로그인 유지 플래그 해제
	this.LOGIN_FLG = false;

	nexacro.getApplication().gds_UserInfo.clearData();

	// history sData 초기화
	//?menu=QnA&page=1
	nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 0;
	var sHash = "menu=home";
	MyHistory.setData(sHash, {});

	// 초기화면으로 돌아가기
	this.btnLogin.set_visible(true);
	this.btnLogout.set_visible(false);
	this.btnSignin.set_visible(true);
	this.btnMypage.set_visible(false);
	
	// 로그인 히스토리 세션 빼기
	this.param = {
		'menu': "home",
		'keyword': "",
		'page': 1,
		'postId': ""
		};
	this.gfnGoMain();
};

// 회원가입 버튼 이벤트 처리
this.btnSignin_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 저장된 스크롤 위치 초기화
	this.SCROLL_POS = 0;

	this.param = {
		'menu': "Sign_Up",
		'keyword': "",
		'page': 1,
		'postId': ""
		};
	this.gfnGoMain();
};

// Mypage 마우스 올라가면 pdiv 표시
this.btnMypage_onmouseenter = function(obj:nexacro.Button,e:nexacro.MouseEventInfo)
{
	if (this.vscrollbar.max == 0)
	{
		this.pdivMypage.trackPopup(this.width-130, 40);
	}
	else
	{
		this.pdivMypage.trackPopup(this.width-150, 40);	// -nScroll);
	}
};
this.btnMypage_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (this.vscrollbar.max == 0)
	{
		this.pdivMypage.trackPopup(this.width-130, 40);
	}
	else
	{
		this.pdivMypage.trackPopup(this.width-150, 40);	// -nScroll);
	}
};

// Mypage 메뉴 선택시
this.pdivMypage_grdMypage_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	// 저장된 스크롤 위치 초기화
	this.SCROLL_POS = 0;
	
	// 게시판 검색어 초기화
	this.Board_Cond_Keyword = "";
	this.Board_Cond_KeywordAll = "";
	this.pdivMypage.closePopup();
	this.param = {
		'menu': this.dsMypageMenu.getColumn(e.row, "menuCd"),
		'keyword': "",
		'page': 1,
		'postId': ""
		};
	this.gfnGoMain();
};

// 메뉴 히스토리 버튼 온클릭
this.divMain_divHistory_btnHistory_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (obj.name == "btnHistory")
	{
		this.divMain.form.divHistory.form.pdivHistory.trackPopupByComponent( obj, 0, 68 );
	}
	else if (obj.name == "btnHistoryProd")
	{
		this.pdivHistoryProd.trackPopupByComponent( obj, 0, 68 );
	}
};

// History pdiv메뉴 클릭
this.divMain_divHistory_pdivHistory_grdHistory_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var sId = "";

	sId = this.dsHistory.getColumn(e.row, "menuId");
	this.param = {
		'menu': sId,
		'keyword': "",
		'page': 1,
		'postId': ""
		};
	this.gfnGoMain();
	// pdiv닫기
	this.divMain.form.divHistory.form.pdivHistory.closePopup();
};

// 제품 HistoryPdiv 선택 이벤트
this.pdivHistoryProd_grdHistory_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var sId = "";

	sId = this.dsHistoryProd.getColumn(e.row, "menuId");

	// 게시판 검색어 초기화
	this.Board_Cond_Keyword = "";
	this.Board_Cond_KeywordAll = "";
	// 상세보기에서 클릭했을 경우 리스트로 보냄
	if (sId.substr(0, 8) == "Tip_View")
	{
		sId = sId.replace("View_", "");
	}

	this.param = {
		'menu': sId,
		'keyword': "",
		'page': 1,
		'postId': ""
		};
	this.gfnGoMain();
	// pdiv닫기
	this.pdivHistoryProd.closePopup();
};

// 히스토리의 홈 버튼 이벤트
this.divMain_divHistory_btnHome_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.param = {
		'menu': "home",
		'keyword': "",
		'page': 1,
		'postId': ""
		};
	this.gfnGoMain();
};

// 북마크 화면용 라디오 이벤트
this.divMain_divBookmark_rdoBookmark_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	if (e.postindex == 0)
	{
		this.param = {
			'menu': "Bookmark",
			'keyword': "",
			'page': 1,
			'postId': ""
			};
		this.gfnGoMain();
	}
	else
	{
		//Bookmark_Tip
		this.param = {
			'menu': "Bookmark_Tip",
			'keyword': "",
			'page': 1,
			'postId': ""
			};
		this.gfnGoMain();
	}
};

// 나의 질문내역, 북마크 제품선택
this.divMain_divBookmark_tabProduct_onchanged = function(obj:nexacro.Tab,e:nexacro.TabIndexChangeEventInfo)
{
	// 제품 광역변수 셋팅
	switch(e.postindex) {
	case 0:
		this.QA_Cond_Prod = "All";
		this.MYPAGE_Cond_Prod = 0;
		break;
	case 1:
		this.QA_Cond_Prod = "Nexacro N";
		this.MYPAGE_Cond_Prod = 1;
		break;
	case 2:
		this.QA_Cond_Prod = "nexacro platform17";
		this.MYPAGE_Cond_Prod = 2;
		break;
	case 3:
		this.QA_Cond_Prod = "nexacro platform14";
		this.MYPAGE_Cond_Prod = 3;
		break;
	case 4:
		this.QA_Cond_Prod = "XPLATFORM";
		this.MYPAGE_Cond_Prod = 4;
		break;
	case 5:
		this.QA_Cond_Prod = "MiPlatform";
		this.MYPAGE_Cond_Prod = 5;
		break;
	case 6:
		this.QA_Cond_Prod = "NewBoard";
		this.MYPAGE_Cond_Prod = 6;
		break;
	default:
	}
	// 페이징 초기화
	this.QA_Cond_Page = 1;
	if (!this.gfnIsNull(this.divMain.form.divWork.url))
	{
		this.divMain.form.divWork.form.fn_CallTrans();
	}
};


/************************************************************************
 * 검색창 자동완성 관련
 ************************************************************************/
this.fn_SearchKey_onkeyup = function(obj, e)
{
	if(e.keycode == 40)
	{
		var cnt = this.ds_autoResult.rowcount;
		if ( cnt > 0 )
		{
				if(this.Search_keywordIdx == (cnt-1)){
					this.showAutoCompleteResult(false);
					this.Search_keywordIdx =-1;
					return;
				} else {
					this.showAutoCompleteResult(true);
				}
				this.Search_keywordIdx++;
				
				var mText = eval("this.div_autoCompleteCover.form.div_autoCompleteResult.form.Static_" + this.Search_keywordIdx).text;
				var mStart= eval("this.div_autoCompleteCover.form.div_autoCompleteResult.form.Static_" + this.Search_keywordIdx).text.indexOf("<fc v='#ff0000'>")+16;
				var mEnd = eval("this.div_autoCompleteCover.form.div_autoCompleteResult.form.Static_" + this.Search_keywordIdx).text.indexOf("</fc>")+5;
				if(mStart != 15){
					mText =mText.substring(0,parseInt(mStart)-16)+ mText.substring(mStart,parseInt(mEnd)-5)+mText.substr(mStart,mStart-mEnd-5)+mText.substr(mEnd);
				}
				
				obj.set_value(mText.replaceAll("<fc v='#ff0000'>", "").replaceAll("</fc>", ""));
				this.setDeSelectItem();//기존 select를 초기화 한다. 
				eval("this.div_autoCompleteCover.form.div_autoCompleteResult.form.Static_" + this.Search_keywordIdx); //.setCurrentPseudo("mouseover");	
				this.div_autoCompleteCover.form.div_autoCompleteResult.form.resetScroll();
		}
		return;
	} else if(e.keycode == 38)  {  
	
		var cnt = this.ds_autoResult.rowcount;
		if ( cnt > 0 )
		{
				if(this.Search_keywordIdx <= 0){
					this.showAutoCompleteResult(false);
					this.Search_keywordIdx =-1;
					return;
				} else {
					this.showAutoCompleteResult(true);
				}
				this.Search_keywordIdx--;
				
				var mText = eval("this.div_autoCompleteCover.form.div_autoCompleteResult.form.Static_" + this.Search_keywordIdx).text;
				var mStart= eval("this.div_autoCompleteCover.form.div_autoCompleteResult.form.Static_" + this.Search_keywordIdx).text.indexOf("<fc v='#ff0000'>")+16;
				var mEnd = eval("this.div_autoCompleteCover.form.div_autoCompleteResult.form.Static_" + this.Search_keywordIdx).text.indexOf("</fc>")+5;
				if(mStart != 15){
					mText =mText.substring(0,parseInt(mStart)-16)+ mText.substring(mStart,parseInt(mEnd)-5)+mText.substr(mStart,mStart-mEnd-5)+mText.substr(mEnd);
				}
				
				obj.set_value(mText.replaceAll("<fc v='#ff0000'>", "").replaceAll("</fc>", ""));

				this.setDeSelectItem();//기존 select를 초기화 한다. 
				eval("this.div_autoCompleteCover.form.div_autoCompleteResult.form.Static_" + this.Search_keywordIdx); //.setCurrentPseudo("mouseover");	
				this.div_autoCompleteCover.form.div_autoCompleteResult.form.resetScroll();
		}
		return;
	} else if(e.keycode == 13)  {	  	
		this.Search_keyEnter=true;
		this.showAutoCompleteResult(false);
	} else {  	
		
		this.Search_query = obj.text;		
		this.Search_keywordIdx =-1;
		this.Search_keyEnter=false;		
		objEnv.set_usewaitcursor(false);		
		this.fn_callData();
	}
}

this.fn_callData = function()
{
	var strUrl = "url=" + nexacro.getEnvironmentVariable("gv_SearchEngine") + "/tobe_autoList&zip=false";
	var arg = "query='" + this.Search_query +"' ";
	
	this.showAutoCompleteResult(false);
	this.ds_autoComplete.clearData();      
	this.ds_autoResult.clearData();    
	
	this.transaction("select", nexacro.getEnvironment().services["SVC_JSP"].url + "Next_JSP/SearchEngine/Service/url.jsp?" + strUrl,"","ds_autoComplete=ds_auto",arg,"callbackAutoComplete"); 	// 개발
}

this.setDeSelectItem = function(idx)
{
	for (var i=0; i<this.ds_autoResult.rowcount; i++)
	{
		eval("this.div_autoCompleteCover.form.div_autoCompleteResult.form.Static_" + i); //.setCurrentPseudo("normal");
	}
}

this.callbackAutoComplete = function(id, code, msg)
{
	objEnv.set_usewaitcursor(true);	
	this.Search_keywordIdx = -1;
	if (code >= 0) {
 		var ds = this.ds_autoComplete;  		
 		var strRecvData = ds.getColumn(0, "rtn");
 		if ( String(strRecvData).length > 0 )
 		{
			strRecvData = String(strRecvData).trim();
			strRecvData = strRecvData.replace(/&quot;/g, '"');
			var revcJsonObj = JSON.parse(strRecvData);
			var count = revcJsonObj.result.length;
			var datas = [];
				
			var resultDs = this.ds_autoResult;
			resultDs.clearData();
			var nRow;
			for (var i = 0 ; i < count; i++)
			{
				var eachResult = revcJsonObj.result[i];				
				var inCount = eachResult.totalcount;
				var jObj;
				var txt;
				for (var j = 0 ; j < inCount ; j++) 
				{
					jObj = eachResult.items[j];

					nRow = resultDs.addRow();
					txt = jObj.hkeyword;
					resultDs.setColumn(nRow, "hkeyword", txt);
					resultDs.setColumn(nRow, "keyword", jObj.keyword);
					datas.push({   
						'KEYWORD': [jObj.hkeyword, jObj.keyword]
					});
				}  
			}             
			resultDs.set_rowposition(0);
			var div = this.div_autoCompleteCover.form.div_autoCompleteResult;
			this.Data_Length = datas.length;
			if ( datas.length == 0 )
			{
				var msg = "해당 단어로 시작하는 검색어가 없습니다.";
				var height = 30;
			}
			else
			{
			}
			if(this.Search_keyEnter == false)
			{
				this.showAutoCompleteResult(true);
			} else {
				this.showAutoCompleteResult(false);
			}	   
 		}
 		else 		
 		{
			this.showAutoCompleteResult(false);
 		}
 		
	} else if  (code < 0) {
		this.showAutoCompleteResult(false);
		//키워드가 없을 경우에는 code에 -4와 msg는 "Parameter is invalid"가 전달됨.
	}
}

this.showAutoCompleteResult = function(show)
{
	var coverDiv = this.div_autoCompleteCover;
	var div = this.div_autoCompleteCover.form.div_autoCompleteResult;
	if ( show )
	{
		if(this.ds_autoResult.getRowCount() > 0)
		{
			var nLeft = 0;
			var nTop = 0;
			var nWidth = 0;
			var nHeight = 0;
		
			div.set_visible(true);
			coverDiv.set_visible(true);
			div.bringToFront();
			var rtn =  this.div_autoCompleteCover.form.removeChild("div_autoCompleteResult");  
			// Destroy Object  
			rtn.destroy(); 
			
			rtn = null;
    
			// QnA, 통합검색, 게시판(Board), Top프레임 위치에 따라 배경 크기 조절
		    if ((this.param.menu == "SearchEngine" || this.param.menu == "QnA") && this.Top_Edit_flag == false)	//if (this.param.menu.substr(0,3) == "Tip" || )
			{
				nLeft = this.divMain.getOffsetLeft()+12;
				nTop = 120+130;
				nWidth = 980;
				nHeight = 463;
				this.sta_autoCompleteResult.set_left(nLeft);
				this.sta_autoCompleteResult.set_top(nTop-3);
				if(this.Data_Length>=10){
					this.sta_autoCompleteResult.set_height(390);
				}else{
					this.sta_autoCompleteResult.set_height(this.Data_Length*38+10);
				}
				this.sta_autoCompleteResult.set_visible(true);
			}
			else if (this.param.menu.substr(0, 3) == "Tip" && this.Top_Edit_flag == false)
			{
				nLeft = this.divMain.getOffsetLeft()+230;
				nTop = 120+148+45;
				nWidth = 980;
				nHeight = 463;
				this.sta_autoCompleteResultTip.set_left(nLeft);
				this.sta_autoCompleteResultTip.set_top(nTop-3);
				if(this.Data_Length>=10){
					this.sta_autoCompleteResultTip.set_height(390);
				}else{
					this.sta_autoCompleteResultTip.set_height(this.Data_Length*38+10);
				}
				
				this.sta_autoCompleteResultTip.set_visible(true);
			}
			else if (this.Top_Edit_flag == true)
			{
				this.sta_autoCompleteResultTop.bringToFront();
				this.div_autoCompleteCover.bringToFront();
				nLeft = this.divMain.getOffsetLeft()+998;
				nTop = 40+16+50 + this.vscrollbar.pos;
				nWidth = 300;
				nHeight = 260;
				this.sta_autoCompleteResultTop.set_left(nLeft);
				this.sta_autoCompleteResultTop.set_top(nTop-3);
				if(this.Data_Length>=6){
					this.sta_autoCompleteResultTop.set_height(238);
				}else{
					this.sta_autoCompleteResultTop.set_height(this.Data_Length*38+10);
				}
				
				this.sta_autoCompleteResultTop.set_visible(true);
			}
			this.objDiv = new Div();
			this.objDiv.init("div_autoCompleteResult",  nLeft, nTop, nWidth, nHeight, null, null);	// 318 463
			this.div_autoCompleteCover.set_top(0);
			this.div_autoCompleteCover.set_left(0);
			this.div_autoCompleteCover.set_width("100%");
			this.div_autoCompleteCover.set_height("100%");
			this.div_autoCompleteCover.form.addChild("div_autoCompleteResult", this.objDiv);

			this.objDiv.show();
			var iDivHeight=10;
			for(var i = 0; i < this.ds_autoResult.getRowCount() ;i++)
			{
				iDivHeight+=38;
				this.objStatic = new Static();
				if (this.Top_Edit_flag == true)
				{
					if(i == 0)
					{
						this.objStatic.init("Static_" + i,  23, 0, 270, 38, null, null);
					} else {
						this.objStatic.init("Static_" + i,  23, (i * 38), 270, 38, null, null);
					}
				}
				else
				{
					if(i == 0)
					{
						this.objStatic.init("Static_" + i,  23, 0, 300, 38, null, null);
					} else {
						this.objStatic.init("Static_" + i,  23, (i * 38), 300, 38, null, null);
					}
				}
				this.objStatic.set_usedecorate(true);
				this.div_autoCompleteCover.form.div_autoCompleteResult.addChild("Static_" + i, this.objStatic);
				this.objStatic.show();
   
				this.objStatic.set_text(this.ds_autoResult.getColumn(i,"hkeyword"));			
				this.objStatic.keyword = this.ds_autoResult.getColumn(i,"keyword");
				var rtn = this.objStatic.addEventHandler("onclick", this.div_autoCompleteCover.form.div_autoCompleteResult_Static_onclick, this);
				if (this.Top_Edit_flag == true && i > 4)
				{
					this.div_autoCompleteCover.bringToFront();
					break;
				}
			}
			this.div_autoCompleteCover.form.div_autoCompleteResult.set_height(iDivHeight);
			this.div_autoCompleteCover.form.div_autoCompleteResult.form.resetScroll();			
		}	
	}
	else
	{
		div.set_visible(false);
		coverDiv.set_visible(false);
		if ((this.param.menu == "SearchEngine" || this.param.menu == "QnA") && this.Top_Edit_flag == false)
		{
			this.sta_autoCompleteResult.set_visible(false);
		}
		else if (this.param.menu.substr(0, 3) == "Tip" && this.Top_Edit_flag == false)
		{
			this.sta_autoCompleteResultTip.set_visible(false);
		}
		else if (this.Top_Edit_flag == true)
		{
			this.sta_autoCompleteResultTop.set_visible(false);
		}
	}
}  

this.div_autoCompleteCover.form.div_autoCompleteResult_Static_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	if (this.param.menu == "SearchEngine" || this.param.menu == "QnA" || this.Top_Edit_flag == true)
	{
		if (this.Top_Edit_flag == true)
		{
			if (this.param.menu == "SearchEngine")
			{
				nexacro.getApplication().gv_topFrame.divTop.form.edtSearchTop.set_value("");
				nexacro.getApplication().gv_searchEngine.divSearch.form.edtSearch.set_value(obj.keyword);
				nexacro.getApplication().gv_searchEngine.fn_search(1);
			}
			else
			{
				nexacro.getApplication().gv_topFrame.divTop.form.edtSearchTop.set_value("");
				this.param = {
					'menu': "SearchEngine",
					'keyword': obj.keyword,
					'page': 1,
					'postId': ""
					};
				this.gfnGoMain();
			}			
		}
		else if (this.param.menu == "SearchEngine")
		{
			nexacro.getApplication().gv_searchEngine.divSearch.form.edtSearch.set_value(obj.keyword);
			nexacro.getApplication().gv_searchEngine.fn_search(1);
		}
		else
		{
			nexacro.getApplication().gv_searchEngine.divSearch.form.edtSearch.set_value(obj.keyword);
			nexacro.getApplication().gv_searchEngine.divSearch.form.btnSearch.click();
		}
	}
	else
	{
		this.divMain.form.divWork.form.divCondition.form.edtKeyword.set_value(obj.keyword);
		this.QA_Cond_Page = 1;
		this.QA_Cond_startPageNo = 0;
		// 페이지 제어 초기화
		this.divMain.form.divWork.form.fn_Query();
	}
	this.showAutoCompleteResult(false);
}

// 스크롤 최상단 이동 버튼
this.btnGoTop_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.vscrollbar.set_pos(0);
};

this.div_autoCompleteCover_onclick = function(obj:nexacro.Div,e:nexacro.ClickEventInfo)
{
	this.showAutoCompleteResult(false);
};

// 파일 업로드
this.attachFileUploadMain_onitemchanged = function(obj:nexacro.FileUpload,e:nexacro.FileUploadItemChangeEventInfo)
{
	//파일 사이즈 체크  from 나D
	if(!this.gfnIsNull(obj.filelist[0])){
	   var handle = obj.filelist[0]._handle;
	   if(!this.gfnIsNull(handle)){
		  var fileSize = handle.size;
		  if(this.gfnIsNull(fileSize)){
			 fileSize = 0;
		  }
		  
		  //파일 사이즈가 50메가를 초과하면,
		  if(nexacro.toNumber(fileSize) > 1024 * 1024 * 50){
			 alert("첨부 가능 용량을 초과하였습니다.");
			 obj.deleteItem(0);
			 obj.appendItem();
			 return;
		  }
	   }
	}
	this.fileFullPath = e.newvalue;
	this.divMain.form.divWork.form.divResult.form.edtUploadFile.set_value(this.fileFullPath);
	var hanFlg = /[ㄱ-핳]/.test(this.fileFullPath);
	if (hanFlg) 
	{
		var ua = navigator.userAgent;
		var objRegExp = new RegExp("MSIE ([0-9]{1,}[\.0-9]{0,})", "g");
		var checkVer = objRegExp.exec(ua);
		if (!this.gfnIsNull(checkVer)) 
		{
			checkVer = checkVer.toString();
			checkVer = nexacro.replaceAll(checkVer, "MSIE", "");
			checkVer = parseFloat(checkVer);
			if (checkVer == "8" || checkVer == 8) 
			{
				alert("Internet Explorer8 에서는 한글파일명 첨부 불가 합니다. 영문으로 변경 후 첨부해 주시기 바랍니다.");
				obj.deleteItem(0);
				obj.appendItem();
			}
		}
	}
};

