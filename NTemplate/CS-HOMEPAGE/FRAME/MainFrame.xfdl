this.divMain_divHistory_btnHistory_canitemchange = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	var sId = "";

	sId = this.dsHistory.getColumn(e.postindex, "menuId");

	this.param = {
		'menu': sId,
		'keyword': "",
		'page': 1,
		'postId': ""
		};
	this.gfnGoMain();
	// pdiv닫기
	//this.divMain.form.divHistory.form.pdivHistory.closePopup();	
	var nFindRow = this.dsScreenUrl.findRow("subCatgy", sId);
	if (!this.gfnIsNull(this.dsScreenUrl.getColumn(nFindRow, "Link")))	// 메뉴가 링크일 경우 url을 호출 
	{
		return false;
	}
};

this.divMain_divHistory_btnHistoryProd_canitemchange = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	var sId = "";

	sId = this.dsHistoryProd.getColumn(e.postindex, "menuId");
	// 게시판 검색어 초기화
	this.Board_Cond_Keyword = "";
	this.Board_Cond_KeywordAll = "";
	// 상세보기에서 클릭했을 경우 리스트로 보냄
	if (sId.substr(0, 8) == "Tip_View")
	{
		sId = sId.replace("View_", "");
	}
	
	this.param = {
		'menu': sId,
		'keyword': "",
		'page': 1,
		'postId': ""
		};
	this.gfnGoMain();
	// pdiv닫기
	//this.pdivHistoryProd.closePopup();	
	var nFindRow = this.dsScreenUrl.findRow("subCatgy", sId);
	if (!this.gfnIsNull(this.dsScreenUrl.getColumn(nFindRow, "Link")))	// 메뉴가 링크일 경우 url을 호출 
	{
		return false;
	}
	
};

this.conversion = function()
{
	// 자동로그인 유저면 그냥 보여주고 아니면 로그인화면으로 보낸다.
	var bLogin = nexacro.getApplication().gv_mainFrame.fn_AutoLogin();

	if (bLogin)
	{
		this.saveConversionInfo(); //컨버전 서비스 호출 정보 저장
	}
	else
	{
		nexacro.getApplication().gv_mainFrame.TargetUrl = "Conversion_Info";		
		nexacro.getApplication().gv_mainFrame.param = {
			'menu': "login",
			'keyword': "",
			'page': 1,
			'postId': ""
			};
		nexacro.getApplication().gv_mainFrame.gfnGoMain();
	}	
	return;
}

this.saveConversionInfo = function()
{
	var gdsUserInfo = nexacro.getApplication().gds_UserInfo;
	var idx = this.ds_InParam1.addRow();
	this.ds_InParam1.setColumn(idx, "User_id", gdsUserInfo.getColumn(0, "User_id"));
	this.ds_InParam1.setColumn(idx, "User_nm", gdsUserInfo.getColumn(0, "User_nm"));
	this.ds_InParam1.setColumn(idx, "Email_id", gdsUserInfo.getColumn(0, "Email_id"));	
	this.ds_InParam1.setColumn(idx, "Tel_hp", nexacro.replaceAll( gdsUserInfo.getColumn(0, "Tel_hp"), "-", "" ));
	this.ds_InParam1.setColumn(idx, "Comp_nm", gdsUserInfo.getColumn(0, "Comp_nm"));
	this.ds_InParam1.setColumn(idx, "CLIENT_CODE", gdsUserInfo.getColumn(0, "CLIENT_CODE"));
	
	nexacro.getApplication().gds_MiWizard.clearData();
	nexacro.getApplication().com_AddMiWizard("input", "", "", "", "CS,Conversion,1");
	var outDs = "";
	var inDs = "input=ds_InParam1:U";
	this.com_CallService("conversion", "", inDs, "", "fn_Conversion_Callback", "CS", true);
} 

this.fn_Conversion_Callback = function (svcid, errCode, errMsg)
{
	if (errCode < 0) 
	{
		alert("저장에 실패 하였습니다.");
		return;
	}
	if (svcid == "conversion") 
	{
		this.ds_InParam1.clearData();

		var gdsUserInfo = nexacro.getApplication().gds_UserInfo;
		var user_id = gdsUserInfo.getColumn(0, "User_id");
		var tel_hp = gdsUserInfo.getColumn(0, "Tel_hp");
		var email = gdsUserInfo.getColumn(0, "Email_id");				
		this.callConversion(user_id,tel_hp,email);	

		this.param.menu = "home";
		this.gfnGoMain();
	}	
};
 
this.callConversion = function(user_id,tel_hp,email)
{
	// 새 창을 엽니다.
	const newWindow = window.open('', 'newWindow', 'width=600,height=400');
	//const newWindow = window.open('about:blank', '_blank'); 
	
	// 새 창을 최대화합니다.
	newWindow.moveTo(0, 0);
	newWindow.resizeTo(screen.width, screen.height);
	
	// 폼을 동적으로 생성합니다.
	const form = document.createElement('form');
	form.method = 'POST';
	//form.action = 'http://main.demo-ezngo.com:8000/tobe/login'; // 데이터를 보낼 URL
	form.action = 'https://regen.demo-ezngo.com/tobe/login'; // 데이터를 보낼 URL
	//https://regen.demo-ezngo.com
	form.target = 'newWindow'; // 새 창에 제출
	
	// 폼에 전송할 데이터를 추가합니다.
	const inputData = {
		username: user_id,
		email: email,
		phone: tel_hp		
	};
	
	for (const key in inputData) {
		if (inputData.hasOwnProperty(key)) {
			const input = document.createElement('input');
			input.type = 'hidden';
			input.name = key;
			input.value = inputData[key];
			form.appendChild(input);
		}
	}
	
	// 폼을 문서에 추가하고 제출합니다.
	document.body.appendChild(form);
	form.submit();
	
	// 폼을 제출한 후, 문서에서 폼을 제거합니다.
	document.body.removeChild(form);
}


this.div_autoCompleteCover_onkillfocus = function(obj:nexacro.Div,e:nexacro.KillFocusEventInfo)
{
	this.showAutoCompleteResult(false);
};

this.onclick_to_close_divAutocompleteCover = function(obj:nexacro.Div,e:nexacro.ClickEventInfo)
{
	this.showAutoCompleteResult(false);
};
