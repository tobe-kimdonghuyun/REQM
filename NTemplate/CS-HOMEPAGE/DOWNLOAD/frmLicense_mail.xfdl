<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmLicense_mail" width="1300" height="344" titletext="New Form" onload="frmLicense_mail_onload">
    <Layouts>
      <Layout width="1300" height="344">
        <Static id="Static00_00_01" taborder="0" text="제품" left="0" top="0" height="30" cssclass="sta_WF_writeTitle" wordWrap="char" width="140" usedecorate="true"/>
        <Combo id="cb_Product2" taborder="1" text="XPLATFORM V9.2 / V9.1 / V9.0" left="0" top="39" width="626" height="50" innerdataset="ds_Product" codecolumn="CODE" datacolumn="VALUE" index="0" value="XP92" cssclass="cmb_WF_product" itemheight="40" enable="true" initvalueid="iv_Combo0">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row>
                <Col id="codecolumn">0</Col>
                <Col id="datacolumn">XML</Col>
              </Row>
              <Row>
                <Col id="codecolumn">1</Col>
                <Col id="datacolumn">ZIP</Col>
              </Row>
            </Rows>
          </Dataset>
        </Combo>
        <Static id="Static00_00_01_00" taborder="2" text="이메일 &lt;fc v='#fb6d3a'&gt;&lt;b v='true'&gt;*&lt;/b&gt;&lt;/fc&gt;" left="666" top="0" height="30" cssclass="sta_WF_writeTitle" wordWrap="char" width="140" usedecorate="true" initvalueid="iv_StaticE"/>
        <Edit id="edt_Email" taborder="3" left="666" top="39" width="626" height="50" cssclass="edt_WF_reply" enable="false" initvalueid="iv_EditE" accessibilitylabel="이메일"/>
        <Static id="Static00_00_01_01" taborder="4" text="파일타입 &lt;fc v='#fb6d3a'&gt;&lt;b v='true'&gt;*&lt;/b&gt;&lt;/fc&gt;" left="0" top="114" height="30" cssclass="sta_WF_writeTitle" wordWrap="char" width="140" usedecorate="true" initvalueid="iv_StaticE"/>
        <Combo id="cb_type" taborder="5" text="XML" left="0" top="153" width="626" height="50" innerdataset="ds_Type" codecolumn="code" datacolumn="NM" index="0" value="N" cssclass="cmb_WF_product" itemheight="40" initvalueid="iv_ComboE" accessibilitylabel="파일타입">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row>
                <Col id="codecolumn">0</Col>
                <Col id="datacolumn">XML</Col>
              </Row>
              <Row>
                <Col id="codecolumn">1</Col>
                <Col id="datacolumn">ZIP</Col>
              </Row>
            </Rows>
          </Dataset>
        </Combo>
        <Button id="btnSave" taborder="6" text="신청하기" width="150" height="65" cssclass="btn_WF_list" top="243" left="1150" onclick="btnSave_onclick"/>
      </Layout>
    </Layouts>
    <Bind>
      <BindItem id="item11" compid="edt_Email" propid="value" datasetid="gds_UserInfo" columnid="Email_id"/>
    </Bind>
    <Objects>
      <Dataset id="ds_ConType">
        <ColumnInfo>
          <Column id="CODE" type="STRING" size="256"/>
          <Column id="VALUE" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="CODE">TECH1</Col>
            <Col id="VALUE">TECH1-(구)고객지원사이트</Col>
          </Row>
          <Row>
            <Col id="CODE">TECH2</Col>
            <Col id="VALUE">TECH2-(신)고객지원사이</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="ds_Languge">
        <ColumnInfo>
          <Column id="Nation" type="STRING" size="256"/>
          <Column id="mes_1" type="STRING" size="256"/>
          <Column id="mes_2" type="STRING" size="256"/>
          <Column id="mes_3" type="STRING" size="256"/>
          <Column id="mes_4" type="STRING" size="256"/>
          <Column id="mes_5" type="STRING" size="256"/>
          <Column id="mes_6" type="STRING" size="256"/>
          <Column id="mes_7" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="Nation">KO</Col>
            <Col id="mes_1">* E-mail 정보 수정을 원하실 경우 회원정보 수정 후 진행해 주시기 바랍니다.</Col>
            <Col id="mes_2">* XPLATFORM 의 경우 버젼과 상관 없이 동일하게 사용을 해주시기 바랍니다.
단, V9.0 의 경우 Client License 가 다르기 때문에 메일의 내용을 참고 해주시기 바랍니다.</Col>
            <Col id="mes_3">신청</Col>
            <Col id="mes_4">당일에 한해 동일 제품을 2건 이상 요청 할수 없습니다.</Col>
            <Col id="mes_5">오류가 발생되었습니다.</Col>
            <Col id="mes_6">[라이센스] 전송이 완료 되었습니다.</Col>
            <Col id="mes_7">해당 ID는 권한(정회원)이 없습니다.
비회원일 경우 TOBESOFT 홈페이지를 통해 발급이 가능합니다.
http://www.tobesoft.co.kr -&gt; 제품의 체험판라이센스에서 발급이 가능합니다.</Col>
          </Row>
          <Row>
            <Col id="Nation">US</Col>
            <Col id="mes_1">* If you want to modify E-main information, please modify it from profile information.</Col>
            <Col id="mes_2">* Version of XPLATFORM does not matter, please use same license. 
  Only in case of V9.0, client license is different, so please refer the content of E-mail.</Col>
            <Col id="mes_4">The license of same product can be requested only two times on same day. </Col>
            <Col id="mes_5">There is an error is occurred.</Col>
            <Col id="mes_6">[License] has been delivered successfully. </Col>
            <Col id="mes_3">Submit</Col>
            <Col id="mes_7">This is not an authorized ID(Does not have membership). 
If you are not a member, then you can issue license from our homepage.  
http://www.tobesoft.co.kr -&gt; Choose 제품 menu, choose the product and clcik on the  체험판라이센스.</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="ds_data"/>
      <Dataset id="ds_Product">
        <ColumnInfo>
          <Column id="CODE" type="STRING" size="256"/>
          <Column id="VALUE" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="CODE">XP92</Col>
            <Col id="VALUE">XPLATFORM V9.2 / V9.1 / V9.0</Col>
          </Row>
          <Row>
            <Col id="CODE">XP13</Col>
            <Col id="VALUE">XPLATFORM V13</Col>
          </Row>
          <Row>
            <Col id="CODE">NP14</Col>
            <Col id="VALUE">nexacro platform 14</Col>
          </Row>
          <Row>
            <Col id="CODE">NP17</Col>
            <Col id="VALUE">nexacro platform 17</Col>
          </Row>
          <Row>
            <Col id="CODE">NPN24</Col>
            <Col id="VALUE">Nexacro N V24</Col>
          </Row>
          <Row>
            <Col id="CODE">NPN</Col>
            <Col id="VALUE">Nexacro N</Col>
          </Row>
          <Row>
            <Col id="CODE">XUP</Col>
            <Col id="VALUE">X-UP</Col>
          </Row>
          <Row>
            <Col id="CODE">NUP</Col>
            <Col id="VALUE">Nex-UP</Col>
          </Row>
          <Row>
            <Col id="CODE">XPUSH</Col>
            <Col id="VALUE">X-PUSH</Col>
          </Row>
          <Row>
            <Col id="CODE">XP13</Col>
            <Col id="VALUE">XPLATFORM V13</Col>
          </Row>
          <Row>
            <Col id="CODE">XAGENT</Col>
            <Col id="VALUE">X-AGENT</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="ds_Type">
        <ColumnInfo>
          <Column id="code" type="STRING" size="256"/>
          <Column id="NM" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="code">N</Col>
            <Col id="NM">XML</Col>
          </Row>
          <Row>
            <Col id="code">Y</Col>
            <Col id="NM">ZIP</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  라이선스(개발용) 다운로드 탭화면
*
*  @MenuPath 
*  @FileName 		DOWNLOAD::frmLicense_mail.xfdl 
*  @Creator 		김광호
*  @CreateDate 		2022.01.01
*  @LastModifier  
*  @LastModifyDate  
*  @Version 		1.0
*  @Outline 		라이선스(개발용) 다운로드 탭화면
*  @Desction 
************** 소스 수정 이력 *************************************************
*    date          Modifier            Description
*******************************************************************************
*  2022.01.01      김광호	           최초 생성 
*******************************************************************************
*/

this.btnSave_onclick = function (obj:Button, e:nexacro.ClickEventInfo)
{
	if(nexacro.getApplication().gds_UserInfo.getColumn(0, "User_status") == 'W' || nexacro.getApplication().gds_UserInfo.getColumn(0, "User_status") == 'P' || nexacro.getApplication().gds_UserInfo.getColumn(0, "User_status") == 'H' ||nexacro.getApplication().gds_UserInfo.getColumn(0, "CLIENT_CODE") == '0')
	{
	  this.alert(" 해당 ID는 권한(정회원)이 없습니다. \n 비회원일 경우 TOBESOFT 홈페이지를 통해 발급이 가능합니다. \n http://www.tobesoft.co.kr -> 제품의 체험판라이센스에서 발급이 가능합니다.");
	  return;
	}
	var sXupUrl = "https://next.tobesoft.com/FrontControllerServlet.do?service=xupservice&domain=NEXTp&model=CE_LicenseEMailSend_R01&format=xml&version=xplatform";
	//var sXupUrl = "https://tops.tobesoft.com/FrontControllerServlet.do?service=xupservice&domain=ACEp_XUP&model=CE_LicenseEMailSend_R01&format=xml&version=xplatform";
	var sConType = "&p_ConType=TECH2";
	var sProduct = "&p_Product=" + this.cb_Product2.value;
	var sLanguage = "";
	if (nexacro.getApplication().gv_NationCd == "001") 
	{
		sLanguage = "&p_Language=KOR";
	}
	else if (nexacro.getApplication().gv_NationCd == "002") 
	{
		sLanguage = "&p_Language=ENG";
	}
	else 
	{
		sLanguage = "&p_Language=JAP";
	}
	var sCustID = "&p_CustomID=" + nexacro.getApplication().gds_UserInfo.getColumn(0, "User_id");
	var sEmail = "&p_Email=" + nexacro.trim(this.edt_Email.value);
	var sMerge = "&p_Merge=" + this.cb_type.value;

	var sServiceUrl = sXupUrl + sConType + sProduct + sLanguage + sCustID + sEmail + sMerge;
	//trace(">>>>"+sServiceUrl);
	var arg2 = "url=" + sServiceUrl + "&zip=false";
	this.transaction("Send_Hompage", nexacro.getEnvironment().services["SVC_JSP"].url + "Next_JSP/url.jsp?" + arg2, "", "ds_data=output", "", "fn_CallBack");	// "SVC_JSP::Next_JSP/url.jsp?"
};

this.fn_CallBack = function (sSvcID, sErrCd, errMsg)
{
	if (sSvcID == "Send_Hompage") 
	{
		if (sErrCd == -9) 
		{
			// this.alert("당일에 한해 동일 제품을 2건 이상 요청 할수 없습니다.");
			this.alert(this.ds_Languge.getColumn(0, "mes_4"));
		}
		else if (sErrCd == -1) 
		{
			// this.alert("오류가 발생되었습니다.");
			this.alert(this.ds_Languge.getColumn(0, "mes_5"));
		}
		else 
		{
			// this.alert("[라이센스] 전송이 완료 되었습니다.");
			this.alert(this.ds_Languge.getColumn(0, "mes_6"));
		}
	}
	else 
	{
		this.alert(this.ds_Languge.getColumn(0, "mes_6"));
	}
};
this.frmLicense_mail_onload = function (obj:Form, e:nexacro.LoadEventInfo)
{
	if (nexacro.getApplication().gv_NationCd == "001") 
	{
		this.ds_Languge.filter("Nation=='KO'");
	}
	else if (nexacro.getApplication().gv_NationCd == "002") 
	{
		this.ds_Languge.filter("Nation=='US'");
	}
	
	//N, N V24 처리
	this.Static00_00_01.set_text("버전");
	this.ds_Product.filter("CODE=='NPN' || CODE=='NPN24'");
};
]]></Script>
  </Form>
</FDL>
