    <Script type="xscript5.1"><![CDATA[/**
*  라이선스(개발용) 다운로드
*
*  @MenuPath 
*  @FileName 		DOWNLOAD::frmTrialDown.xfdl 
*  @Creator 		김광호
*  @CreateDate 		2022.01.01
*  @LastModifier  
*  @LastModifyDate  
*  @Version 		1.0
*  @Outline 		라이선스(개발용) 다운로드
*  @Desction 
************** 소스 수정 이력 *************************************************
*    date          Modifier            Description
*******************************************************************************
*  2022.01.01      김광호	           최초 생성 
*******************************************************************************
*/

this.fn_callback = function(sid,errcode,errmsg)
{
	if ( errcode < nexacro.getApplication().ERROR_CODE_SUCCESS) { 
		alert(errmsg);
	}    
	
	if(sid == 'codedata')
	{
		this.fn_LicenseEmail();	
		 
	} else if(sid == 'select')
	{
		this.doc = this.webBrowResult.getProperty("document");
		var strTmp;
		var strHeml = "<table  width='100%'   border='0' cellpadding='0' cellspacing='0'>";
		strHeml += "<tr><td>";
		strHeml += "<table  width='100%'   border='0' cellpadding='0' cellspacing='3'>";
    
    
		for (var i = 0; i < this.ds_list.rowcount; i++) {	   
   		
			strHeml += "<tr>";       
			strHeml += "<td  background='../../Image/TitleLine.png' colspan='2'  height='31' valign='center' border=0><strong><font size=3>&nbsp;" + this.ds_list.getColumn(i,"ymd").substr(0,4)+ "-" + this.ds_list.getColumn(i,"ymd").substr(4,2) + "-" + this.ds_list.getColumn(i,"ymd").substr(6,2)  + "</font></strong></td>";
			strHeml += "</tr>";               
			var strTmp;
			if(nexacro.getApplication().gv_NationCd == "002") {  
				strTmp = this.ds_list.getColumn(i,"note_en");   
			} else if(nexacro.getApplication().gv_NationCd == "003") {
				strTmp = this.ds_list.getColumn(i,"note_jp");     
			} else {
				strTmp = this.ds_list.getColumn(i,"note_kr");   
			}  
			strTmp = (strTmp.replace(new RegExp(String.fromCharCode(9), "g"), "&nbsp;&nbsp;&nbsp;&nbsp"));  

			if(String(strTmp) == 'undefined') strTmp = "";	  

			strHeml += "<tr>";   
			strHeml += "<td  height='20' colspan=2 align=left><table width=100% cellpadding='2' cellspacing='3' bkcolor='#f3f3f3'><td max-width:500px;word-wrap:break-word;><font size='2'>"  + strTmp  + "</font></td></tr></table></td>";
			strHeml += "</tr>"; 
			strHeml += "<tr>";   	  
   
   
			strHeml += "<tr><td colspan='2'><table  width='100%'  cellpadding='0' cellspacing='0' border='1' rules=all bordercolor='#b1b1b1'>";             

				strHeml += "<tr bordercolor='#b1b1b1'>";
				strHeml += "<td  height='25' align=center bgcolor=#ededed>Files</td>";			   	
				strHeml += "<td  height='25' align=center bgcolor=#ededed>Description</td>";				
				strHeml += "</tr>";   

			for (var j = 0; j < this.ds_list_detail.rowcount; j++) {
				this.ds_list_detail.filter("idx == '" + this.ds_list.getColumn(i,"idx") + "'");
				 
				strHeml += "<tr bordercolor='#b1b1b1'>";
				strHeml += "<td  height='23' width=300 align=left>&nbsp;<a href='" + nexacro.getApplication().services["SVC_JSP"].url+"FileDownload/fileDownload2.jsp?path="+"Setup/MiPlatform_Trial"+ "&file="+ encodeURIComponent(this.ds_list_detail.getColumn(j,"file_name")) + "&realFileNm="+encodeURIComponent(this.ds_list_detail.getColumn(j,"file_name")) + "&uid=" + nexacro.getApplication().gds_UserInfo.getColumn(nexacro.getApplication().gds_UserInfo.rowposition,"User_id") + "&category=" +  this.cmb_kind.text + "&date=" + this.ds_list.getColumn(i,"ymd").substr(0,4)+ "-" + this.ds_list.getColumn(i,"ymd").substr(4,2) + "-" + this.ds_list.getColumn(i,"ymd").substr(6,2) + "(trial)'>" + this.ds_list_detail.getColumn(j,"file_name") + "</a></td>";								
    				
				strHeml += "<td height='23' width=300 align=left>&nbsp;" +  String(this.ds_list_detail.getColumn(j,"remark")).replace('undefined','') + "</td>";			
				strHeml += "</tr>"; 
				strHeml += "<tr>";      
			}    
			this.ds_list_detail.filter(""); 
			strHeml += "</table></td></tr>";					   
			strHeml += "<tr><td colspan=2 height=3 colspan=2 bgcolor=#ffffff </td></tr>";					   
			
		}    

		strHeml += "<tr><td height=0 colspan=2 bgcolor=#D3D3D3></td></tr> ";		
		strHeml += "<tr><td height=20 colspan=2 bgcolor=#ffffff></td></tr> ";				
		strHeml += "</table>";

		this.webBrowResult.callMethod("setContent", strHeml.replaceAll("<p>", "").replaceAll("</p>", ""), true);
		nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, this.height + 220);
	
	}  
}

// editor.html 영역에서 특정 값을 얻어온다.
this.getHTMLValue = function(name)
{
	this.webBrowResult.callMethod("getHTMLValue", name);
	
	var el = this.webBrowResult.getProperty("document").callMethod("getElementById", "transfer");
	var val = el.getProperty("value");
	
	el.setProperty("value", "");
		
	return val;	
}
   
this.Pro_gbn = "N";
this.fn_QueryData = function()
{  	
	this.webBrowResult.set_visible(true);
	this.Div00.set_visible(false);	
	var args = "Nation='" + nexacro.getApplication().gv_NationCd + "'";

	args += "&goods_gbn=" + nexacro.getApplication().com_SetQuote(this.Pro_gbn);
	nexacro.getApplication().gds_MiWizard.clearData();
	nexacro.getApplication().com_AddMiWizard("","output1",args,"XPLATFORM,TECH_MAIN,39");	           
	nexacro.getApplication().com_AddMiWizard("","output2",args,"XPLATFORM,TECH_MAIN,40");	                          
	
	this.com_CallService("select", "", "", "ds_list=output1 ds_list_detail=output2" , "fn_callback", "CS", true);		
}   
   

this.btn_list_onclick = function(obj:Button,  e:nexacro.ClickEventInfo)
{
	this.fn_QueryData();
}

  
this.productDown_onload = function(obj:Form, e:nexacro.LoadEventInfo)
{
	if(nexacro.getApplication().gds_UserInfo.getRowCount() <= 0)
	{
		nexacro.getApplication().gv_mainFrame.TargetUrl = "License_Info";
		nexacro.getApplication().gv_mainFrame.param = {
			'menu': "login",
			'keyword': "",
			'page': 1,
			'postId': ""
			};
		nexacro.getApplication().gv_mainFrame.gfnGoMain();
      
	} else {
		this.Div00.set_url("DOWNLOAD::frmLicense_mail.xfdl");
		this.LocationUrl=window.location;
		this.webBrowResult.set_url(nexacro.getApplication().gv_DomainInfo+"CKEDITOR/editor/view_FAQ.html");
	}
}

this.webBrowResult_onloadcompleted = function(obj:WebBrowser, e:nexacro.WebLoadCompEventInfo)
{  

	var args = "goods_gbn='X%'&Nation='" + nexacro.getApplication().gv_NationCd + "'";
	
	if(nexacro.getApplication().gv_mainFrame.PCategory2 == "nexacro platform")
	{
		args = "goods_gbn='2%'&Nation='" + nexacro.getApplication().gv_NationCd + "'";
	} else if(nexacro.getApplication().gv_mainFrame.PCategory2 == "XPLATFORM")
	{  
		args = "goods_gbn='1%'&Nation='" + nexacro.getApplication().gv_NationCd + "'";
	} else if(nexacro.getApplication().gv_mainFrame.PCategory2 == "MiPlatform")
	{
		args = "goods_gbn='0%'&Nation='" + nexacro.getApplication().gv_NationCd + "'";
	}	

	nexacro.getApplication().gds_MiWizard.clearData();
	nexacro.getApplication().com_AddMiWizard("","output1",args,"XPLATFORM,TECH_MAIN,31");	           
	this.com_CallService("codedata", "", "", "ds_version=output1", "fn_callback", "CS", true);		
	
}

this.webBrowResult_onusernotify = function(obj:WebBrowser, e:nexacro.WebTitleChangeEventInfo)
{

}

this.cmb_kind_onitemchanged = function(obj:Combo, e:nexacro.ItemChangeEventInfo)
{
	this.fn_QueryData();
}

this.fn_LicenseEmail = function()
{
	this.webBrowResult.set_visible(false);
	this.Div00.set_visible(true);
	
	if(this.Pro_gbn == 102)
	{
		this.Div00.form.cb_Product2.set_value("XP92");
	}
	else if(this.Pro_gbn == "039")
	{
		this.Div00.form.cb_Product2.set_value("NP17");
	}
	else if(this.Pro_gbn == 2)
	{
		this.Div00.form.cb_Product2.set_value("NP14");
	}
	else if(this.Pro_gbn == 100)
	{
		this.Div00.form.cb_Product2.set_value("XUP");
	}
	else if(this.Pro_gbn == 103)
	{
		this.Div00.form.cb_Product2.set_value("XP13");
	}	
	else if(this.Pro_gbn == "038")
	{
		this.Div00.form.cb_Product2.set_value("NUP");
	}
	else if(this.Pro_gbn == "016")
	{
		this.Div00.form.cb_Product2.set_value("XPUSH");
	}
	else if(this.Pro_gbn == "N")	// NPN
	{
		this.Div00.form.cb_Product2.set_value("NPN");
	}
	this.set_height(500);
	this.parent.set_height(700);
	this.Div00.set_height(340);
	this.webBrowResult.set_height(308);
	nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, this.height + 105);
}


// 제품 변경 이벤트
this.tabProduct_onchanged = function(obj:nexacro.Tab,e:nexacro.TabIndexChangeEventInfo)
{
	//e.postindex
	// 0 N
	// 1 17
	// 2 14
	// 3 XP
	// 4 MP
	// 5 Nex-UP
	// 6 X-UP
	// 7 X-PUSH
	if(e.postindex == 0) // "N"
	{
		this.Pro_gbn = "N"; //nexacro platform
		if(nexacro.getApplication().gv_NationCd == "001")
		{
			this.fn_LicenseEmail();
		}
		else this.fn_QueryData();		
	}
	else if(e.postindex == 2) // "btn_nexa14")
	{
		this.Pro_gbn = 2; //nexacro platform
		if(nexacro.getApplication().gv_NationCd == "001")
		{
			this.fn_LicenseEmail();
		}
		else this.fn_QueryData();		
	}
	else if(e.postindex == 1)//obj.name == "btn_nexa17")
	{
		this.Pro_gbn = "039"; //nexacro platform
		
		if(nexacro.getApplication().gv_NationCd == "001")
		{
			this.fn_LicenseEmail();
		}
		else this.fn_QueryData();	
	}
	else if(e.postindex == 3)//obj.name == "btn_XP")
	{
		this.Pro_gbn = 102; //XPLATFORM
		
		if(nexacro.getApplication().gv_NationCd == "001")
		{
			this.fn_LicenseEmail();
		}
		else this.fn_QueryData();
	}
	else if(e.postindex == 4)// obj.name == "btn_MP")
	{
		this.Pro_gbn = '001'; // Miplatform
		this.fn_QueryData();
	}
	else if(e.postindex == 6)//obj.name == "btn_XS")
	{
		this.Pro_gbn = 100; //X-Series
		
		if(nexacro.getApplication().gv_NationCd == "001")
		{
			this.fn_LicenseEmail();
		}
		else this.fn_QueryData();
	}
	else if(e.postindex == 5)//obj.name == "btn_NexUP")
	{
		this.Pro_gbn = "038"; //Nex-UP

		if(nexacro.getApplication().gv_NationCd == "001")
		{
			this.fn_LicenseEmail();
		}
		else this.fn_QueryData();
	}
	else if(e.postindex == 7)//obj.name == "btn_PUSH")
	{
		this.Pro_gbn = "016"; //Nex-UP

		if(nexacro.getApplication().gv_NationCd == "001")
		{
			this.fn_LicenseEmail();
		}
		else this.fn_QueryData();
	}
	if(e.postindex == 4)//obj.name == "btn_MP")
	{
		this.stcSechCmnt.set_visible(false);
		this.stcSechCmnt_MP.set_visible(true);
	}
	else
	{
		this.stcSechCmnt.set_visible(true);
		this.stcSechCmnt_MP.set_visible(false);
	}	
};
]]></Script>
  </Form>
</FDL>
