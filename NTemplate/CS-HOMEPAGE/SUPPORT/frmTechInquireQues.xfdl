    <Script type="xscript5.1"><![CDATA[/**
*  QnA글작성화면
*
*  @MenuPath 
*  @FileName 		SUPPORT::frmTechInquireQues.xfdl 
*  @Creator 		김광호
*  @CreateDate 		2022.01.01
*  @LastModifier  
*  @LastModifyDate  
*  @Version 		1.0
*  @Outline 		QnA글작성화면
*  @Desction 
************** 소스 수정 이력 *************************************************
*    date          Modifier            Description
*******************************************************************************
*  2022.01.01      김광호	           최초 생성 
*******************************************************************************
*/

this.quesType = "";

this.fileNm = "";
this.saveFileNm = "";
this.fileGubun = "";
this.fileCnt = 0;
this.filePath = "E:\\Project\\CS\\Next\\file\\NewHome\\";	// 파일 

// 온로드
this.techInquireQues_onload = function (obj:Form, e:nexacro.LoadEventInfo)
{
	if(nexacro.getApplication().xadl.indexOf("172.10.10.71") != -1) { 
		this.filePath = "D:\\Project\\CS\\Next\\file\\NewHome\\";	
    }
	
	//접근성 적용(readonly)
	this.fnAddEventReadonlyComp(this);

	//스케치, 통합빌드는 제품 목록에서 제외
	nexacro.getApplication().gds_ProcVers.filter("code!='044'&&code!='045'");

	//새로고침 되었을 때, MyHistory에 저장했던 모드를 꺼내온다.
	var sHash = MyHistory.getLocationHash();
	var oData = MyHistory.getData(sHash);
	if(!this.gfnIsNull(oData) && !this.gfnIsNull(oData.mode)){
	  nexacro.indexPage.QAStatus = oData.mode;
	}

	//모드 세팅. Write/Reply/Modify. default:Write
	this.fvMode = this.gfnIsNull(nexacro.indexPage.QAStatus)?"Write":nexacro.indexPage.QAStatus;
	
	nexacro.getApplication().gv_mainFrame.QAStatus = this.fvMode;

	//현재 모드를 히스토리에 저장한다.
	MyHistory.setData(sHash, {mode : this.fvMode});

	// 이메일, 전화번호 셋팅
	this.divResult.form.edtEmail.set_value(nexacro.getApplication().gds_UserInfo.getColumn(0, "Email_id"));
	this.divResult.form.edtReqTelno.set_value(nexacro.getApplication().gds_UserInfo.getColumn(0, "Tel_hp"));
	// 성함 셋팅(히든)
	this.ds_InParam.setColumn(0, "req_user", nexacro.getApplication().gds_UserInfo.getColumn(0, "User_nm"));
	
	// MianFrame의 파일 업로드 컴포넌트 초기화
	if (nexacro.getApplication().gv_mainFrame.attachFileUploadMain.filelist.length > 0)
	{
		nexacro.getApplication().gv_mainFrame.attachFileUploadMain.deleteItem(0);
		nexacro.getApplication().gv_mainFrame.attachFileUploadMain.appendItem();
	}
	
	this.divResult.form.wbContent.set_url(nexacro.getApplication().gv_DomainInfo+"CKEDITOR/editor/index.html");
	
	nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, 1910);
	
	this.quesType = nexacro.getApplication().gv_mainFrame.QAStatus;
	
	if (this.quesType == "Write")
	{
		this.fn_InquireDetail("Write");
	}
	
	this.divResult.form.radFeedback.set_value(nexacro.getApplication().gds_UserInfo.getColumn(0, "REPLY_METHOD"));
	
	//this.divResult.setFocus();
	nexacro.getApplication().gv_mainFrame.vscrollbar.set_pos(0);
	

};


this.fn_InquireDetail = function (chkFlg)
{
	if (nexacro.getApplication().gv_NationCd == '001') 
	{
		this.fn_Research();
	}
	else 
	{
		this.stcContComnt00.set_visible(false);
	}

	this.quesType = chkFlg;

	if (nexacro.getApplication().gv_NationCd == "003") 
	{
		nexacro.getApplication().gds_ProcVers.filter("nation == 'E'");
	}

	this.ds_InParam.deleteAll();
	var nRow = this.ds_InParam.addRow();

	// 신규입력 시 조회조건 셋팅
	if (chkFlg == "Write") {  
	
		// 담당자
		this.ds_InParam.setColumn(0, "req_user", nexacro.getApplication().gds_UserInfo.getColumn(0, "User_nm"));
		// 이메일
		this.ds_InParam.setColumn(0, "req_email", nexacro.getApplication().gds_UserInfo.getColumn(0, "Email_id"));
		// 전화번호
		this.ds_InParam.setColumn(0, "req_telno", nexacro.getApplication().gds_UserInfo.getColumn(0, "Tel_hp"));   
		this.ds_InParam.setColumn(0, "req_userid", nexacro.getApplication().gds_UserInfo.getColumn(0, "User_id"));
		this.ds_InParam.setColumn(0, "req_user_pwd", nexacro.getApplication().gds_UserInfo.getColumn(0, "User_id"));
		this.ds_InParam.setColumn(0, "nation", nexacro.getApplication().gv_NationCd);  
		this.ds_InParam.setColumn(0, "open_yn", "1");    
	}		
};

this.fn_SelectListCallBack = function (svcid, errCode, errMsg)
{	
	this.ds_InParam.deleteAll();
    var nRow = this.ds_InParam.addRow();
	
	// Reply 일경우 데이터 셋팅
	if( svcid == "selectDetail" ){		
		if (this.quesType == "Reply")
		{
			this.ds_InParam.setColumn(0, "req_file_name", "");      
			this.ds_InParam.setColumn(0, "req_filekey", "");     
			this.ds_InParam.setColumn(0, "open_yn", "1"); 
			
			this.ds_InParam.setColumn(0, "QL_SEQ", this.ds_ReqDetail.getColumn(0, "QL_SEQ"));
