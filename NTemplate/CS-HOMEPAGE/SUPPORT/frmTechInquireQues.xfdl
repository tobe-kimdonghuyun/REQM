this.fn_Research = function ()
{
	var arg = "user_id='" + nexacro.getApplication().gds_UserInfo.getColumn(0, "User_id") + "'";
	nexacro.getApplication().gds_MiWizard.clearData();
	nexacro.getApplication().com_AddMiWizard("", "output", arg, "CS,statistics,7");
	var outDs = "ds_before=output";
	var inDs = "";
	this.com_CallService("before_List", "", "", outDs, "fn_Research_Callback", "CS", true);
};

this.fn_searchProject = function(sSvcid)
{
	var arg = "user_id='"+nexacro.getApplication().gds_UserInfo.getColumn(0,"User_id")+"'&email='"+nexacro.getApplication().gds_UserInfo.getColumn(0, "Email_id")+"'";
   	nexacro.getApplication().gds_MiWizard.clearData();   
   	nexacro.getApplication().com_AddMiWizard("","output",arg,"SYSTEM,findProject,1");	
    var outDs = "ds_Project=output";	
    var inDs = "";		
	if(this.gfnIsNull(sSvcid))
	{
		sSvcid = "findProject";
	}
    this.com_CallService(sSvcid, "", "", outDs, "fn_Research_Callback", "CS", true);	
}

this.fn_Research_Callback = function(svcid, errCode, errMsg)
{
	if(svcid == "before_List")
  	{		
  		this.fn_searchProject();
  		if(this.ds_before.getRowCount() > 0)
  		{
  			this.parent.divResearch.ds_before.copyData(this.ds_before);
  		}
  	} else if(svcid == "findProject")
  	{
		this.ds_InParam.setColumn(0, "next_client", this.ds_Project.getColumn(0, "CLIENT_NAME"));
		this.ds_InParam.setColumn(0, "next_project", this.ds_Project.getColumn(0, "PROJECT_NAME"));
		this.ds_InParam.setColumn(0, "mip_version", this.ds_Project.getColumn(0, "PRODUCT_CODE"));
  	}
	else if(svcid == "reloadProject")
	{
		var sClientNm = this.ds_Project.getColumn(0,"CLIENT_NAME");
		var sProjectNm = this.ds_Project.getColumn(0,"PROJECT_NAME");
		
		if(this.gfnIsNull(sClientNm))
		{
			sClientNm = "";
		}
		if(this.gfnIsNull(sProjectNm))
		{
			sProjectNm = "";
		}
		this.ds_InParam.setColumn(0, "next_client", sClientNm);
		this.ds_InParam.setColumn(0, "next_project", sProjectNm);
	}
	nexacro.getApplication().gds_ProcVers.set_keystring("S:-code");
}

// 저장버튼 이벤트
this.btnSave_onclick = function (obj:Button, e:nexacro.ClickEventInfo)
{

	this.ds_InParam.setColumn(0, "req_remark", this.getContent());
	//검색용 컬럼에 태그를 제외한 텍스트만 저장처리   contentNoTag
  	this.ds_InParam.setColumn(0, "req_remark_txt", this.getContentNoTag());
	
	// 입력정보 체크
	if (this.fn_CheckParam()) 
	{
		return;
	}

	this.fileCnt = nexacro.getApplication().gv_mainFrame.attachFileUploadMain.getItemCount(true);
	
	if (this.fileCnt > 0) 
	{
		var arrList = nexacro.getApplication().gv_mainFrame.attachFileUploadMain.text.split("\\");
		this.fileNm = arrList[arrList.length - 1];
	}
	
	var strArgs = "";
	if (this.quesType == "Write") 
	{
		strArgs = "DATATYPE=Write";
	}
	else if (this.quesType == "Reply") 
	{
		strArgs = "DATATYPE=Reply";
	}
	else if (this.quesType == "Modify") 
	{
		strArgs = "DATATYPE=Modify";
	}

	strArgs += " SOURCE_CD=QL";
  	strArgs += " filePath="+this.filePath + nexacro.getApplication().com_Today().substr(0,6);

	var strServ = "QuesRegist";
	var strUrl = "SVC_JSP::Next_JSP/Support/QuestionRegist_new.jsp";

	var strDsInput = "input=ds_InParam";
	var strDsOutput = "ds_Rtn=output";
	strArgs += " RTYPE=XML DB='CS' fileNm='" + this.fileNm + "' JSESSIONID='" + nexacro.getApplication().JSESSIONID + "'";
	this.com_TransSend(strServ, strUrl, strDsInput, strDsOutput, strArgs, "fn_QuestionRegist_CallBack");
};

// 글 저장 조회 콜백
this.fn_QuestionRegist_CallBack = function (svcid, errCode, errMsg)
{
	var sMenu = "MyQnAList_View";	// 나의질문내역 상세로 이동하기 위해
	var strIdx = this.ds_Rtn.getColumn(0,"QL_SEQ");		// 저장한 글의 글번호
	if (this.quesType == "Modify")
	{
		strIdx = this.ds_ReqDetail.getColumn(0, "QL_SEQ");
	}
	
	if (svcid == "QuesRegist") 
	{
		// 파일정보 등록
		if (this.fileCnt > 0) 
		{
			var serverUrl = nexacro.getEnvironment().services["SVC_JSP"].url;
			var strUrl = serverUrl+"Next_JSP/Next/home_FileUpload.jsp?PATH="
			+encodeURIComponent(this.filePath+nexacro.getApplication().com_Today().substr(0,6))
			+"&fileNm="+encodeURIComponent(this.fileNm)
			+"&saveFileNm="+encodeURIComponent(this.saveFileNm);
			var bSucc = nexacro.getApplication().gv_mainFrame.attachFileUploadMain.upload(strUrl);
			
			if (bSucc)
			{
				// 정상적으로 등록되었습니다<b>17시</b> 이후에 등록된 내용은 익일 처리됩니다.
				nexacro.getApplication().com_SetMessage("MSG_000063", false);
				
				nexacro.getApplication().gv_mainFrame.param = {
					'menu': sMenu,
					'keyword': "",
					'page': 1,
					'postId': strIdx
					};
				nexacro.getApplication().gv_mainFrame.gfnGoMain();
			}
			else
			{
				alert("글 등록에 실패하였습니다.");
			}
		}
		else 
		{
			// 정상적으로 등록되었습니다<b>17시</b> 이후에 등록된 내용은 익일 처리됩니다.
			nexacro.getApplication().com_SetMessage("MSG_000063", false);
			
			nexacro.getApplication().gv_mainFrame.param = {
				'menu': sMenu,
				'keyword': "",
				'page': 1,
				'postId': strIdx
				};
			nexacro.getApplication().gv_mainFrame.gfnGoMain();
		}
	}

	// 초기화
	this.quesType = "";
	nexacro.getApplication().gv_mainFrame.QAStatus = "List";
	nexacro.getApplication().gv_mainFrame.QAKeyNo = "";
};

// 취소버튼 이벤트
this.btnCancel_onclick = function (obj:Button, e:nexacro.ClickEventInfo)
{
	// 등록작업을 취소 하시겠습니까?
	var retVal = nexacro.getApplication().com_ConfirmMessage("MSG_000053", false);

	if (retVal) 
	{
		nexacro.getApplication().gv_mainFrame.QAStatus = "List";
		
		var sKeyword = nexacro.getApplication().gv_mainFrame.QA_Cond_Keyword;
		var nPage = nexacro.getApplication().gv_mainFrame.QA_Cond_Page;
		if (this.gfnIsNull(nPage))
		{
			nPage = 1;
		}
		history.back();
	}
};

// 유효성 validation 체크
this.fn_CheckParam = function ()
{
	// 필수 입력체크
	if (this.gfnIsNull(this.divResult.form.edtNextClient.value)) 
	{
		// 고객사를 입력해 주세요
		nexacro.getApplication().gv_mainFrame.vscrollbar.set_pos(this.divResult.form.Static00_00_01.getOffsetTop()+130);
		this.divResult.form.edtNextClient.setFocus();
		nexacro.getApplication().com_SetMessage("MSG_000055", false);
		return true;
	}

	// 최소 길이 체크
	var arrNxtClnVal = {
		"value" : 3,
		"msgCd" : "MSG_000056"
	};
	// 고객사명을 3자리 이상 입력해 주세요
	if (this.fn_checkValidate("minlength", arrNxtClnVal, this.divResult.form.edtNextClient.value) == 0) 
	{
		nexacro.getApplication().gv_mainFrame.vscrollbar.set_pos(this.divResult.form.Static00_00_01.getOffsetTop()+130);
		this.divResult.form.edtNextClient.setFocus();
		return true;
	}


	// 필수 입력체크
	if (this.gfnIsNull(this.divResult.form.edtNextProject.value)) 
	{
		// 프로젝트명을 입력해 주세요
		nexacro.getApplication().com_SetMessage("MSG_000057", false);
		nexacro.getApplication().gv_mainFrame.vscrollbar.set_pos(this.divResult.form.Static00_00_01_00.getOffsetTop()+130);
		this.divResult.form.edtNextProject.setFocus();
		return true;
	}

	// 최소 길이 체크
	var arrNxtPrjVal = {
		"value" : 3,
		"msgCd" : "MSG_000058"
	};
	// 프로젝트명을 3자리 이상 입력해 주세요
	if (this.fn_checkValidate("minlength", arrNxtPrjVal, this.divResult.form.edtNextProject.value) == 0) 
	{
		nexacro.getApplication().gv_mainFrame.vscrollbar.set_pos(this.divResult.form.Static00_00_01_00.getOffsetTop()+130);
		this.divResult.form.edtNextProject.setFocus();
		return true;
	}
	// 필수 입력체크
	if (this.gfnIsNull(this.divResult.form.edtEmail.value)) 
	{
		// 이메일주소를 입력해 주세요.
		nexacro.getApplication().com_SetMessage("MSG_000010", false);
		nexacro.getApplication().gv_mainFrame.vscrollbar.set_pos(this.divResult.form.Static00_00_01_01.getOffsetTop()+130);
		this.divResult.form.edtEmail.setFocus();
		return true;
	}

	// 이메일 형식체크
	var arrVal = {
		"value" : true,
		"msgCd" : "MSG_000115"
	};
	if(this.fn_checkValidate("email", arrVal, this.divResult.form.edtEmail.value)==0){
		nexacro.getApplication().gv_mainFrame.vscrollbar.set_pos(this.divResult.form.Static00_00_01_01.getOffsetTop()+130);
		this.divResult.form.edtEmail.setFocus();
		return true;
	}

	// 필수 입력체크
	if (this.gfnIsNull(this.divResult.form.edtReqTelno.value)) 
	{
		// 전화번호를 입력해 주세요
		nexacro.getApplication().com_SetMessage("MSG_000119", false);
		nexacro.getApplication().gv_mainFrame.vscrollbar.set_pos(this.divResult.form.Static00_00_01_00_00.getOffsetTop()+130);
		this.divResult.form.edtReqTelno.setFocus();
		return true;
	}
	//필수 입력체크
	if (this.gfnIsNull(this.divResult.form.cmb_Prod.value))
		{
		// 제품버전을 선택해 주세요.
		nexacro.getApplication().com_SetMessage("MSG_000118", false);
		nexacro.getApplication().gv_mainFrame.vscrollbar.set_pos(this.divResult.form.Static00_00_01_01_00.getOffsetTop()+130);
		this.divResult.form.cmb_Prod.setFocus();
		return true;
	}
	// 필수 입력체크
	if (this.gfnIsNull(this.divResult.form.edtReqTitle.value)) 
	{
		// 제목을 입력해 주세요
		nexacro.getApplication().com_SetMessage("MSG_000041", false);
		nexacro.getApplication().gv_mainFrame.vscrollbar.set_pos(this.divResult.form.Static00_00_01_01_01.getOffsetTop()+130);
		this.divResult.form.edtReqTitle.setFocus();
		return true;
	}

	// 최대 길이 체크
	var arrReqTitleVal = {
		"value" : 200,
		"msgCd" : "MSG_000042",
		"unit" : "ascii"
	};
	// 제목을 200자 이하로 입력하십시오\n\n영문은 200자(200byte)까지 한글은 100자(200byte)까지 가능
	if (this.fn_checkValidate("maxlength", arrReqTitleVal, this.divResult.form.edtReqTitle.value) == 0) 
	{
		nexacro.getApplication().gv_mainFrame.vscrollbar.set_pos(this.divResult.form.Static00_00_01_01_01.getOffsetTop()+130);
		this.divResult.form.edtReqTitle.setFocus();
		return true;
	}

	// 필수 입력체크
	if (this.gfnIsNull(this.ds_InParam.getColumn(0, "req_remark")))
	{
		// 내용을 입력해 주세요
		nexacro.getApplication().com_SetMessage("MSG_000043", false);
		nexacro.getApplication().gv_mainFrame.vscrollbar.set_pos(this.divResult.form.Static00_00_01_01_01_00.getOffsetTop()+130);
		this.divResult.form.wbContent.setFocus();
		return true;
	}
	
	// 답변 회신방법
	if (this.gfnIsNull(this.divResult.form.radFeedback.value))
	{
		// 답변 회신방법을 선택해 주세요
		nexacro.getApplication().com_SetMessage("MSG_000117", false);
		nexacro.getApplication().gv_mainFrame.vscrollbar.set_pos(this.divResult.form.Static00_00_01_00_00_00.getOffsetTop()+130);
		this.divResult.form.radFeedback.setFocus();
		return true;
	}
};

//////////////////////////////////////////////////////////////////////////
// 웹에디터 관련 //
//////////////////////////////////////////////////////////////////////////

// 컨텐츠 반환
this.getContent = function()
{
	return this.getHTMLValue("editor.content");
}

// 태그 제거 컨텐츠 반환
this.getContentNoTag = function()
{
	return this.getHTMLValue("contentNoTag");
}

// 컨텐츠 지정
this.setContent = function(content) 
{
	this.divResult.form.wbContent.callMethod("setContent", content || emptyHtml, true);
}

// editor.html 영역에서 특정 값을 얻어온다.
this.getHTMLValue = function(name)
{
	this.divResult.form.wbContent.callMethod("getHTMLValue", name);
	
	var el = this.divResult.form.wbContent.getProperty("document").callMethod("getElementById", "transfer");
	var val = el.getProperty("value");
	
	el.setProperty("value", "");
		
	return val;	

}

// CKEditor가 들어간 WBcomponent 로딩이 끝나면 조회
this.divResult_wbContent_onloadcompleted = function(obj:nexacro.WebBrowser,e:nexacro.WebLoadCompEventInfo)
{
	if ( obj.url != "about:blank" && obj.url == e.url )
	{
		obj.__load = true;
		// editor.html 의 initEditor 함수를 호출하고 완료되면 
		// this.initRichTextEditor 을 호출하도록 지정
	}
	
	// 재질문일경우
	if (nexacro.getApplication().gv_mainFrame.QAStatus == "Reply" || nexacro.getApplication().gv_mainFrame.QAStatus == "Modify")
	{
		
		//alert(nexacro.getApplication().gv_mainFrame.param.postId);
		var reqIdx = nexacro.getApplication().gv_mainFrame.param.postId;	//this.sIdx;//nexacro.getApplication().gv_mainFrame.strTempFilder1;
		nexacro.getApplication().gv_mainFrame.QAKeyNo=reqIdx;

		this.user_id = nexacro.getApplication().gds_UserInfo.getColumn(0, "User_id");
		this.user_nm = nexacro.getApplication().gds_UserInfo.getColumn(0, "User_nm");
		this.tel_hp  = nexacro.getApplication().gds_UserInfo.getColumn(0, "Tel_hp");
		
		nexacro.getApplication().gds_MiWizard.clearData();   	
		nexacro.getApplication().com_AddMiWizard("","output1","req_idx=" + reqIdx+ "&user_id='"+this.user_id+"'","CS,cs_request_proc,25");
		nexacro.getApplication().com_AddMiWizard("","output2","str_an=" + reqIdx + "&user_id='"+this.user_id+"'","CS,statistics,5");
		nexacro.getApplication().com_AddMiWizard("","output3","req_idx=" + reqIdx + "&kind='QL'","CS,cs_request_proc,32");
		nexacro.getApplication().com_AddMiWizard("","output4","req_idx=" + reqIdx + "&kind='AL'","CS,cs_request_proc,32");
		nexacro.getApplication().com_AddMiWizard("","output5","user_nm='" + this.user_nm +"'&tel_no='" + this.tel_hp + "'","SYSTEM,sys_findStaff,11");	
		nexacro.getApplication().com_AddMiWizard("input1","","req_idx=" + reqIdx + "&user_id='"+this.user_id+"'&kind='Q'&flag='Y'","","CS,cs_request_proc,26");
		// idx의 상태에따라 만족도 조사 SQL문을 가져와야함  includeQAViewBodyNew.asp

		var outDs = "ds_ReqDetail=output1 ds_CustSafctData=output2 ds_downloadfile_req=output3 ds_downloadfile_res=output4 ds_userInfo=output5";
		var inDs = "input1=ds_update:U";
		this.com_CallService("selectDetail", "", inDs, outDs, "fn_SelectListCallBack", "CS", true);
	}
};

this.divResult_wbContent_onusernotify = function(obj:nexacro.WebBrowser,e:nexacro.WebUserNotifyEventInfo)
{
	if ( obj.__load )
	{
		var userdata = e.userdata;		
	}
};

