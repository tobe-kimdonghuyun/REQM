// 온타이머
this.techInquireQues_ontimer = function(obj:nexacro.Form,e:nexacro.TimerEventInfo)
{
	this.killTimer(e.timerid);
	if (e.timerid == 111)
	{
		// [추가질문] 텍스트   
		var strComnt = nexacro.getApplication().gds_CompLang.getColumn(nexacro.getApplication().gds_CompLang.rowposition, "btnPlusQues");
//			strComnt = strComnt.replace(/\n/g, " ");
		   
		var strRemark = "<p>" +"****************** "+strComnt+" ******************"  + "</p>";
		this.setContent(strRemark + "<p>" +this.ds_ReqDetail.getColumn(0,"req_title") + "</p>");
	}
	else if (e.timerid == 222)
	{
		this.setContent(this.ds_ReqDetail.getColumn(0, "req_remark"));
	}
};

// 온로드 버튼 이벤트
this.divResult_btnUploadFile_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	nexacro.getApplication().gv_mainFrame.attachFileUploadMain.filefindbuttons[0].click();
};



this.fnAddEventReadonlyComp = function(obj)
{
	var comps = obj.components;
	
	for(var i = 0; i  < comps.length; i++) {
		if(comps[i] instanceof Div) {
			this.fnAddEventReadonlyComp(comps[i].form);
			continue;
		}
		
		if(comps[i].readonly == true) {
			comps[i].addEventHandler("onsetfocus", this.fnReadonlyCss_onsetfocus, this);
			comps[i].addEventHandler("onkillfocus", this.fnReadonlyCss_onkillfocus, this);
		}
	}
};

this.fnReadonlyCss_onsetfocus = function(obj:nexacro.Edit,e:nexacro.SetFocusEventInfo)
{
	this.fnSetReadonlyCss(obj, true);
};
this.fnReadonlyCss_onkillfocus = function(obj:nexacro.Edit,e:nexacro.KillFocusEventInfo)
{
	this.fnSetReadonlyCss(obj, false);
};

this.fnSetReadonlyCss = function(obj, oAdd) 
{
	var sOriCss = obj.cssclass;
	var sAddCss = "readonly";
	var aCss = sOriCss.split(",").filter(Boolean); // 빈 문자열 제거
	var cssSet = new Set(aCss);

	oAdd ? cssSet.add(sAddCss) : cssSet.delete(sAddCss);

	obj.set_cssclass(Array.from(cssSet).join(","));
};


]]></Script>
  </Form>
</FDL>
