			this.ds_InParam.setColumn(0, "PROCESSING_NAME", this.ds_ReqDetail.getColumn(0, "PROCESSING_NAME"));
			this.ds_InParam.setColumn(0, "proc_result", this.ds_ReqDetail.getColumn(0, "proc_result"));
