<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Pop" width="650" height="892" cssclass="sta_POP_foot" scrolltype="none">
    <Layouts>
      <Layout height="892" width="650">
        <Static id="Static01" taborder="0" left="0" width="650" height="42" top="850" cssclass="sta_POP_foot"/>
        <Static id="Static03" taborder="1" top="20" width="65" height="20" cssclass="sta_POP_logo" left="505"/>
        <CheckBox id="CheckBox00" taborder="2" text="오늘 하루 이 창을 띄우지 않음" left="20" top="858" width="190" height="25" onclick="CheckBox00_onclick" cssclass="check_POP_notToday" value="false" tabstop="true"/>
        <Button id="Button00" taborder="3" text="닫기" top="858" width="55" height="25" cssclass="btn_POP_close" left="585" onclick="Button00_onclick"/>
        <ImageViewer id="ImageViewer00" taborder="4" left="0" top="0" width="650" height="850" stretch="fixaspectratio" background="url('theme://images/tobePop_Job.png') repeat center"/>
        <Static id="Static00" taborder="5" left="160" top="742" width="330" height="57" onclick="Static00_onclick" cursor="pointer"/>
      </Layout>
    </Layouts>
    <Objects/>
    <Script type="xscript5.1"><![CDATA[
this.CheckBox00_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	nexacro.setPrivateProfile("mTodayPop1",this.gfnGetDate());
	this.close();
};

this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close();
};

this.Static00_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	// 해당 이벤트 공지사항으로 이동
	nexacro.getApplication().gv_mainFrame.param = {
		'menu': "Notice_View",
		'keyword': "",
		'page': 1,
		'postId': 230
		};
	nexacro.getApplication().gv_mainFrame.gfnGoMain();
	this.close();
};
]]></Script>
  </Form>
</FDL>
