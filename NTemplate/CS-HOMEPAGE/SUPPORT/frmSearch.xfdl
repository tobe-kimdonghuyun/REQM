<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmSearch" width="1300" height="494" titletext="New Form" scrolltype="none" onload="frmSearch_onload">
    <Layouts>
      <Layout height="494" mobileorientation="landscape" width="1300">
        <Div id="divSearch" taborder="0" left="0" top="0" width="1300" height="160" text="" accessibilityenable="false">
          <Layouts>
            <Layout>
              <Edit id="edtSearch" taborder="0" left="12" top="60" width="980" height="75" cssclass="edt_WF_search" onkeyup="divSearch_edtSearch_onkeyup" onkillfocus="divSearch_edtSearch_onkillfocus" accessibilitydescription="검색어 입력"/>
              <Button id="btnSearch" taborder="1" text="검색" left="1007" top="60" width="155" height="75" cssclass="btn_WF_search" onclick="divSearch_btnSearch_onclick"/>
              <Button id="btnFilterResize" taborder="2" top="88" width="104" height="18" cssclass="btn_WF_filterOpen" left="1191" onclick="divSearch_btnFilter_onclick" text="" accessibilitylabel="상세검색" accessibilitydescription="조건영역 닫힘"/>
              <Static id="Static03" taborder="3" text="제품선택" left="30" top="170" width="80" height="37" cssclass="sta_WF_search" visible="false"/>
              <CheckBox id="Chk_ALL" taborder="4" text="전체" left="179" top="172" width="150" height="37" cssclass="chk_WF_product" value="true" onclick="divSearch_Chk_ALL_onclick" visible="false"/>
              <CheckBox id="Chk_NPN" taborder="5" text="Nexacro N" left="304" top="172" width="150" height="37" cssclass="chk_WF_product" value="true" onclick="divSearch_Chk_onclick" visible="false"/>
              <CheckBox id="Chk_NP17" taborder="6" text="nexacro 17" left="469" top="172" width="150" height="37" cssclass="chk_WF_product" value="true" onclick="divSearch_Chk_onclick" visible="false"/>
              <CheckBox id="Chk_NP14" taborder="7" text="nexacro 14" left="634" top="172" width="150" height="37" cssclass="chk_WF_product" value="true" onclick="divSearch_Chk_onclick" visible="false"/>
              <CheckBox id="Chk_XP" taborder="8" text="XPLATFORM" left="799" top="172" width="150" height="37" cssclass="chk_WF_product" value="true" onclick="divSearch_Chk_onclick" visible="false"/>
              <CheckBox id="Chk_MP" taborder="9" text="MiPlatform" left="979" top="172" width="150" height="37" cssclass="chk_WF_product" value="true" onclick="divSearch_Chk_onclick" visible="false"/>
              <CheckBox id="Chk_TDO" taborder="10" text="TobeDevOps" left="1139" top="172" width="150" height="37" cssclass="chk_WF_product" value="true" onclick="divSearch_Chk_onclick" visible="false"/>
              <Static id="Static03_00" taborder="11" text="조회조건" left="30" top="225" width="80" height="37" cssclass="sta_WF_search" visible="false"/>
              <Radio id="rdoField" taborder="12" left="179" top="228" width="657" height="37" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" direction="vertical" cssclass="rdo_WF_search" index="1" text="제목" value="200" onitemchanged="divSearch_rdoField_onitemchanged" accessibilitylabel="[@Static03_00]" visible="false" initvalueid="iv_Radio0">
                <Dataset id="innerdataset">
                  <ColumnInfo>
                    <Column id="codecolumn" size="256"/>
                    <Column id="datacolumn" size="256"/>
                  </ColumnInfo>
                  <Rows>
                    <Row>
                      <Col id="codecolumn">100</Col>
                      <Col id="datacolumn">제목+내용</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">200</Col>
                      <Col id="datacolumn">제목</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">300</Col>
                      <Col id="datacolumn">내용</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">600</Col>
                      <Col id="datacolumn">번호</Col>
                    </Row>
                  </Rows>
                </Dataset>
              </Radio>
              <Radio id="rdoOperator" taborder="13" left="840" top="228" width="330" height="37" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" direction="vertical" cssclass="rdo_WF_search" index="0" text="OR" value="0" onitemchanged="divSearch_rdoOperator_onitemchanged" visible="false" accessibilitylabel="[@Static03_00]" initvalueid="iv_Radio0">
                <Dataset id="innerdataset">
                  <ColumnInfo>
                    <Column id="codecolumn" size="256"/>
                    <Column id="datacolumn" size="256"/>
                  </ColumnInfo>
                  <Rows>
                    <Row>
                      <Col id="codecolumn">OR</Col>
                      <Col id="datacolumn">OR</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">AND</Col>
                      <Col id="datacolumn">AND</Col>
                    </Row>
                  </Rows>
                </Dataset>
              </Radio>
              <Static id="Static03_00_00" taborder="14" text="조회기간" left="30" top="278" width="80" height="37" cssclass="sta_WF_search" onclick="divSearch_Static03_00_00_onclick" visible="false"/>
              <Radio id="rdoTerm" taborder="15" left="182" top="281" width="657" height="37" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" direction="vertical" cssclass="rdo_WF_search" index="0" text="전체" value="1" onitemchanged="divSearch_rdoTerm_onitemchanged" accessibilitylabel="[@Static03_00_00]" visible="false" initvalueid="iv_Radio0">
                <Dataset id="innerdataset">
                  <ColumnInfo>
                    <Column id="codecolumn" size="256"/>
                    <Column id="datacolumn" size="256"/>
                  </ColumnInfo>
                  <Rows>
                    <Row>
                      <Col id="codecolumn">1</Col>
                      <Col id="datacolumn">전체</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">2</Col>
                      <Col id="datacolumn">오늘</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">3</Col>
                      <Col id="datacolumn">1주일</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">4</Col>
                      <Col id="datacolumn">1달</Col>
                    </Row>
                  </Rows>
                </Dataset>
              </Radio>
              <Static id="Static03_00_00_00" taborder="16" text="조회기간" left="840.00" top="278" width="80" height="37" cssclass="sta_WF_search" onclick="divSearch_Static03_00_00_onclick" visible="false"/>
              <Calendar id="calStart" taborder="17" left="959.00" top="278" width="155" height="40" dateformat="yyyy-MM-dd" cssclass="cal_WF_search" accessibilitylabel="시작 날짜" visible="false" initvalueid="iv_Calendar0"/>
              <Static id="Static00" taborder="18" text="~" left="1114.00" top="278" width="20" height="40" textAlign="center" accessibilityenable="false" visible="false"/>
              <Calendar id="calEnd" taborder="19" left="1134.00" top="278" width="155" height="40" dateformat="yyyy-MM-dd" cssclass="cal_WF_search" accessibilitylabel="종료 날짜" visible="false" initvalueid="iv_Calendar0"/>
              <Button id="btnClear" taborder="20" text="초기화" left="537" top="353" width="110" height="40" cssclass="btn_WF_searchReset" onclick="divSearch_btnClear_onclick" visible="false"/>
              <Button id="btnApply" taborder="21" text="적용" left="657" top="353" width="110" height="40" cssclass="btn_WF_searchReset" onclick="divSearch_btnApply_onclick" visible="false"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divResult" taborder="1" text="Div00" left="0" top="divSearch:0" width="1300" height="95" accessibilityenable="false">
          <Layouts>
            <Layout>
              <Button id="btn1" taborder="0" text="전체" left="1" top="25" width="186" height="70" cssclass="btn_WF_resultTab_S" onclick="divResult_btnProd_onclick" visible="true"/>
              <Button id="btn2" taborder="1" text="Nexacro N" left="btn1:-1" top="25" width="186" height="70" cssclass="btn_WF_resultTab" onclick="divResult_btnProd_onclick" visible="true"/>
              <Button id="btn3" taborder="2" text="nexacro 17" left="btn2:-1" top="25" width="186" height="70" cssclass="btn_WF_resultTab" onclick="divResult_btnProd_onclick" visible="true"/>
              <Button id="btn4" taborder="3" text="nexacro 14" left="btn3:-1" top="25" width="186" height="70" cssclass="btn_WF_resultTab" onclick="divResult_btnProd_onclick" visible="true"/>
              <Button id="btn5" taborder="4" text="XPLATFORM" left="btn4:-1" top="25" width="186" height="70" cssclass="btn_WF_resultTab" onclick="divResult_btnProd_onclick" visible="true"/>
              <Button id="btn6" taborder="5" text="MiPlatform" top="25" width="186" height="70" cssclass="btn_WF_resultTab" left="btn5:-1" onclick="divResult_btnProd_onclick" visible="true"/>
              <Button id="btn7" taborder="6" text="TobeDevOps" top="25" width="186" height="70" cssclass="btn_WF_resultTab" left="btn6:-1" onclick="divResult_btnProd_onclick" visible="true"/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  QnA검색(divSearch)
*
*  @MenuPath 
*  @FileName 		SUPPORT::frmSearch.xfdl 
*  @Creator 		김광호
*  @CreateDate 		2022.01.01
*  @LastModifier  
*  @LastModifyDate  
*  @Version 		1.0
*  @Outline 		QnA검색(divSearch)
*  @Desction 
************** 소스 수정 이력 *************************************************
*    date          Modifier            Description
*******************************************************************************
*  2022.01.01      김광호	           최초 생성 
*******************************************************************************
*/
 
this.period = "전체";
this.fromDate = "";
this.toDate = "";

this.searchGubun = "OR";
this.searchfield = "200";
this.searchVersion = "";

this.frmSearch_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	nexacro.getApplication().gv_searchEngine = this;
	
	if (!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.param.keyword))
	{
		this.divSearch.form.edtSearch.set_value(nexacro.getApplication().gv_mainFrame.param.keyword);
	}
	if (!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.param.page))
	{
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = nexacro.getApplication().gv_mainFrame.param.page;
	}
	
	// 새로고침이나 브라우저 히스토리 이동 시 각종 값이 초기화되지 않도록 저장
	var sData = nexacro.getApplication().gv_mainFrame.gfnGetHistoryData();
	
	if (!this.gfnIsNull(sData))
	{
		// 히스토리 sData에서 불러오기
		if (!this.gfnIsNull(sData.Chk_ALL)){	this.divSearch.form.Chk_ALL.set_value(sData.Chk_ALL); }
		if (!this.gfnIsNull(sData.Chk_NPN)){	this.divSearch.form.Chk_NPN.set_value(sData.Chk_NPN); }
		if (!this.gfnIsNull(sData.Chk_NP17)){	this.divSearch.form.Chk_NP17.set_value(sData.Chk_NP17); }
		if (!this.gfnIsNull(sData.Chk_NP14)){	this.divSearch.form.Chk_NP14.set_value(sData.Chk_NP14); }
		if (!this.gfnIsNull(sData.Chk_XP)){	this.divSearch.form.Chk_XP.set_value(sData.Chk_XP); }
		if (!this.gfnIsNull(sData.Chk_MP)){	this.divSearch.form.Chk_MP.set_value(sData.Chk_MP); }
		if (!this.gfnIsNull(sData.Chk_TDO)){	this.divSearch.form.Chk_TDO.set_value(sData.Chk_TDO); }		
		if (!this.gfnIsNull(sData.rdoField)){	this.divSearch.form.rdoField.set_value(sData.rdoField);
			this.searchfield = sData.rdoField; }
		if (!this.gfnIsNull(sData.rdoOperator)){	this.divSearch.form.rdoOperator.set_value(sData.rdoOperator);
			this.searchGubun = sData.rdoOperator;
			nexacro.getApplication().gv_mainFrame.QA_Cond_Searchgubun = sData.rdoOperator; }
		if (!this.gfnIsNull(sData.rdoTerm)){	this.divSearch.form.rdoTerm.set_value(sData.rdoTerm); }
		if (!this.gfnIsNull(sData.Chk_ALL)){	this.period = sData.rdoTerm; }
		if (!this.gfnIsNull(sData.calStart)){	this.divSearch.form.calStart.set_value(sData.calStart);
			this.fromDate = sData.calStart; }
		if (!this.gfnIsNull(sData.calEnd)){	this.divSearch.form.calEnd.set_value(sData.calEnd);
			this.toDate = sData.calEnd; }
		if (!this.gfnIsNull(sData.filterstatus)){nexacro.getApplication().gv_mainFrame.filterstatus = sData.filterstatus}else{nexacro.getApplication().gv_mainFrame.filterstatus="close"};
		if (!this.gfnIsNull(sData.QA_Tab_Index)){nexacro.getApplication().gv_mainFrame.QA_Tab_Index = sData.QA_Tab_Index};
	}
	// 키워드 셋팅
	if (!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.param.keyword))
	{
		 this.divSearch.form.edtSearch.set_value(nexacro.getApplication().gv_mainFrame.param.keyword);
	}
	
	// 제품탭 설정
	if (!this.divSearch.form.Chk_NPN.value && !this.divSearch.form.Chk_NP17.value && !this.divSearch.form.Chk_NP14.value && !this.divSearch.form.Chk_XP.value && !this.divSearch.form.Chk_MP.value && !this.divSearch.form.Chk_TDO.value)
	{
		alert("선택한 제품이 없습니다.");
		return;
	}
	this.divResult.form.btn2.set_width(this.divSearch.form.Chk_NPN.value?186:0);
	this.divResult.form.btn3.set_width(this.divSearch.form.Chk_NP17.value?186:0);
	this.divResult.form.btn4.set_width(this.divSearch.form.Chk_NP14.value?186:0);
	this.divResult.form.btn5.set_width(this.divSearch.form.Chk_XP.value?186:0);
	this.divResult.form.btn6.set_width(this.divSearch.form.Chk_MP.value?186:0);
	this.divResult.form.btn7.set_width(this.divSearch.form.Chk_TDO.value?186:0);
	this.divResult.form.resetScroll();

	nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, 1850);
};

// 필터 버튼 이벤트 (토글)
this.divSearch_btnFilter_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fn_filterResize();
};


// 검색필터 리사이즈
this.fn_filterResize = function()
{
	if (this.divSearch.height == "399")
	{
		nexacro.getApplication().gv_mainFrame.filterstatus = "close";
		this.divSearch.set_height(160);
		nexacro.getApplication().gv_mainFrame.staBGG.set_height(221);
		this.divSearch.form.btnFilterResize.set_cssclass("btn_WF_filterOpen");
		this.divSearch.form.btnFilterResize.set_accessibilitydescription("조건영역 닫힘");
		
		this.fn_setCompVisible(false);
	}
	else
	{
		nexacro.getApplication().gv_mainFrame.filterstatus = "open";
		this.divSearch.set_height(399);
		nexacro.getApplication().gv_mainFrame.staBGG.set_height(460);
		this.divSearch.form.btnFilterResize.set_cssclass("btn_WF_filterClose");
		this.divSearch.form.btnFilterResize.set_accessibilitydescription("조건영역 열림");
		
		this.fn_setCompVisible(true);
	}
	this.divResult.set_top(this.divSearch.getOffsetBottom());
	this.parent.set_height(this.divResult.getOffsetBottom());
	nexacro.getApplication().gv_mainFrame.fn_setFilterResize();
};

this.fn_filterBFsize = function()
{
	if (nexacro.getApplication().gv_mainFrame.filterstatus == "close")
	{
		this.divSearch.set_height(160);
		nexacro.getApplication().gv_mainFrame.staBGG.set_height(221);
		this.divSearch.form.btnFilterResize.set_cssclass("btn_WF_filterOpen");
		this.divSearch.form.btnFilterResize.set_accessibilitydescription("조건영역 닫힘");
	}
	else
	{
		this.divSearch.set_height(399);
		nexacro.getApplication().gv_mainFrame.staBGG.set_height(460);
		this.divSearch.form.btnFilterResize.set_cssclass("btn_WF_filterClose");
		this.divSearch.form.btnFilterResize.set_accessibilitydescription("조건영역 열림");
	}
	
	this.divResult.set_top(this.divSearch.getOffsetBottom());
	this.parent.set_height(this.divResult.getOffsetBottom());
	nexacro.getApplication().gv_mainFrame.fn_setFilterResize();
}


//상세조회 조건 visible처리
this.fn_setCompVisible = function(bFlag)
{
	var comps = this.divSearch.form.components;
	
	for (var i = 0; i < comps.length; i++)
	{
		var obj = comps[i];
		// 조회 에디트,  검색 버튼 제외
		if (obj.id == "edtSearch" || obj.id == "btnSearch" || obj.id == "btnFilterResize") 	continue;
		
		obj.visible = bFlag;
	}
	this.divSearch.form.resetScroll();
}


// 제품탭 선택
this.divResult_btnProd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.searchVersion = obj.name;
	var sKeyword = this.divSearch.form.edtSearch.value;
	// 번호일때 숫자 체크
	if (this.searchfield == 600)
	{
		var chkNo = /^\d+$/.test(sKeyword);
		if (this.gfnIsNull(sKeyword) || chkNo == false)	// 검색조건(번호) & 번호가 아닐때
		{
			alert("번호를 입력해주세요.");
			return;
		}
	}

	this.divResult.form.btn1.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn2.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn3.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn4.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn5.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn6.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn7.set_cssclass("btn_WF_resultTab");
	
	this.divResult.form.btn1.set_accessibilitylabel("");
	this.divResult.form.btn2.set_accessibilitylabel("");
	this.divResult.form.btn3.set_accessibilitylabel("");
	this.divResult.form.btn4.set_accessibilitylabel("");
	this.divResult.form.btn5.set_accessibilitylabel("");
	this.divResult.form.btn6.set_accessibilitylabel("");	
	this.divResult.form.btn7.set_accessibilitylabel("");	
	
	obj.set_cssclass("btn_WF_resultTab_S");

	switch(obj.name) {
	case "btn1":
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "All";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 0;
		nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = 0;
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = 1;
		break;
	case "btn2":
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "Nexacro N";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 1;
		nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = 0;
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = 1;
		break;
	case "btn3":
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "nexacro platform17";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 2;
		nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = 0;
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = 1;
		break;
	case "btn4":
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "nexacro platform14";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 3;
		nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = 0;
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = 1;
		break;
	case "btn5":
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "XPLATFORM";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 4;
		nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = 0;
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = 1;
		break;
	case "btn6":
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "MiPlatform";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 5;
		nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = 0;
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = 1;
		break;
	case "btn7":
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "TobeDevOps";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 6;
		nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = 0;
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = 1;
		break;				
	default:
	}
	
	this.fn_saveHistoryData();	// 히스토리 세션 데이터 저장

	// 검색 조건 번호일때 키워드 없으면 반려
	var sKeyword = "";
	if (!this.gfnIsNull(this.divSearch.form.edtSearch.value))
	{
		sKeyword = this.divSearch.form.edtSearch.value.trim();
	}
	else
	{
		sKeyword = this.divSearch.form.edtSearch.value;
	}
	this.divSearch.form.edtSearch.value;

	nexacro.getApplication().gv_mainFrame.divMain.form.divWork.form.fn_CallTrans();	// 조회
	
	//obj.set_accessibilitylabel("선택 " +  obj.text);
};

// 제품탭 선택(사용자 클릭 아님)
this.fn_selectTab = function(nTabIndex)
{
	var sKeyword = this.divSearch.form.edtSearch.value;
	// 번호일때 숫자 체크
	if (this.searchfield == 600)
	{
		var chkNo = /^\d+$/.test(sKeyword);
		if (this.gfnIsNull(sKeyword) || chkNo == false)	// 검색조건(번호) & 번호가 아닐때
		{
			alert("번호를 입력해주세요.");
			return;
		}
	}

	this.divResult.form.btn1.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn2.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn3.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn4.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn5.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn6.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn7.set_cssclass("btn_WF_resultTab");
	
	switch(nTabIndex) {
	case 0:
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "All";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 0;
		this.divResult.form.btn1.set_cssclass("btn_WF_resultTab_S");
		break;
	case 1:
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "Nexacro N";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 1;
		this.divResult.form.btn2.set_cssclass("btn_WF_resultTab_S");
		break;
	case 2:
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "nexacro platform17";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 2;
		this.divResult.form.btn3.set_cssclass("btn_WF_resultTab_S");
		break;
	case 3:
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "nexacro platform14";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 3;
		this.divResult.form.btn4.set_cssclass("btn_WF_resultTab_S");
		break;
	case 4:
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "XPLATFORM";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 4;
		this.divResult.form.btn5.set_cssclass("btn_WF_resultTab_S");
		break;
	case 5:
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "MiPlatform";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 5;
		this.divResult.form.btn6.set_cssclass("btn_WF_resultTab_S");
		break;
	case 6:
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "TobeDevOps";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 6;
		this.divResult.form.btn7.set_cssclass("btn_WF_resultTab_S");
		break;		
	default:
	}
	
	this.fn_saveHistoryData();	// 히스토리 세션 데이터 저장
	
	nexacro.getApplication().gv_mainFrame.divMain.form.divWork.form.fn_CallTrans();	// 조회
};

// 새로고침을 대비해 검색 데이터 저장
this.fn_saveHistoryData = function()
{
	nexacro.getApplication().gv_mainFrame.param.keyword = this.divSearch.form.edtSearch.value;
	// 히스토리 sData에 저장
	var sData = {
	Chk_ALL:this.divSearch.form.Chk_ALL.value
	,Chk_NPN:this.divSearch.form.Chk_NPN.value
	,Chk_NP17:this.divSearch.form.Chk_NP17.value
	,Chk_NP14:this.divSearch.form.Chk_NP14.value
	,Chk_XP:this.divSearch.form.Chk_XP.value
	,Chk_MP:this.divSearch.form.Chk_MP.value
	,Chk_TDO:this.divSearch.form.Chk_TDO.value	
	,rdoField:this.divSearch.form.rdoField.value
	,rdoOperator:this.divSearch.form.rdoOperator.value
	,rdoTerm:this.divSearch.form.rdoTerm.value
	,calStart:this.divSearch.form.calStart.value
	,calEnd:this.divSearch.form.calEnd.value
	,filterstatus:nexacro.getApplication().gv_mainFrame.filterstatus
	,QA_Tab_Index:nexacro.getApplication().gv_mainFrame.QA_Tab_Index
	};
	nexacro.getApplication().gv_mainFrame.gfnSetHistoryData(sData);
};

// 페이징 검색 데이터 저장
this.fn_savePagingData = function()
{
	nexacro.getApplication().gv_mainFrame.param.keyword = this.divSearch.form.edtSearch.value;
	// 히스토리 sData에 저장
	var sData = {
	Chk_ALL:this.divSearch.form.Chk_ALL.value
	,Chk_NPN:this.divSearch.form.Chk_NPN.value
	,Chk_NP17:this.divSearch.form.Chk_NP17.value
	,Chk_NP14:this.divSearch.form.Chk_NP14.value
	,Chk_XP:this.divSearch.form.Chk_XP.value
	,Chk_MP:this.divSearch.form.Chk_MP.value
	,Chk_TDO:this.divSearch.form.Chk_TDO.value
	,rdoField:this.divSearch.form.rdoField.value
	,rdoOperator:this.divSearch.form.rdoOperator.value
	,rdoTerm:this.divSearch.form.rdoTerm.value
	,calStart:this.divSearch.form.calStart.value
	,calEnd:this.divSearch.form.calEnd.value
	,filterstatus:nexacro.getApplication().gv_mainFrame.filterstatus
	,QA_Tab_Index:nexacro.getApplication().gv_mainFrame.QA_Tab_Index
	};
	return sData;
};

// 조회버튼 클릭
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (!this.divSearch.form.Chk_NPN.value && !this.divSearch.form.Chk_NP17.value && !this.divSearch.form.Chk_NP14.value && !this.divSearch.form.Chk_XP.value && !this.divSearch.form.Chk_MP.value && !this.divSearch.form.Chk_TDO.value)
	{
		alert("선택한 제품이 없습니다.");
		return;
	}

	// 제품 조회 조건에 따라 안보이게 처리
	this.divResult.form.btn2.set_width(this.divSearch.form.Chk_NPN.value?186:0);
	this.divResult.form.btn3.set_width(this.divSearch.form.Chk_NP17.value?186:0);
	this.divResult.form.btn4.set_width(this.divSearch.form.Chk_NP14.value?186:0);
	this.divResult.form.btn5.set_width(this.divSearch.form.Chk_XP.value?186:0);
	this.divResult.form.btn6.set_width(this.divSearch.form.Chk_MP.value?186:0);
	this.divResult.form.btn7.set_width(this.divSearch.form.Chk_TDO.value?186:0);
	this.divResult.form.resetScroll();
	
	switch(this.searchVersion) {
	case "btn1":
		this.divResult.form.btn1.click();	// 전체건수로 조회
		break;
	case "btn2":
		this.divResult.form.btn2.click();	
		break;
	case "btn3":
		this.divResult.form.btn3.click();	
		break;
	case "btn4":
		this.divResult.form.btn4.click();	
		break;
	case "btn5":
		this.divResult.form.btn5.click();	
		break;
	case "btn6":
		this.divResult.form.btn6.click();	
		break;
	case "btn7":
		this.divResult.form.btn7.click();	
		break;				
	default:
		this.divResult.form.btn1.click();	// 전체건수로 조회
	}	
	//this.divResult.form.btn1.click();	// 전체건수로 조회
};

// 날짜 조회 조건 변경
this.divSearch_rdoTerm_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	var sDate = "";
	var eDate = "";
	var today = this.gfnGetDate();

	switch(e.postindex) {
	case 0:	// 전체
		sDate = "";
		eDate = "";
		break;
	case 1:	// 오늘
		sDate = today;
		eDate = today;
		break;
	case 2:	// 1주일
		sDate = this.gfnAddDate(today, -7);
		eDate = today;
		break;
	case 3:	// 1달
		sDate = this.gfnAddMonth(today, -1);
		eDate = today;
		break;
	case 4:
		break;
	default:
	}
	this.period = this.divSearch.form.rdoTerm.text;
	this.fromDate = sDate;
	this.toDate = eDate;
	this.divSearch.form.calStart.set_value(sDate);
	this.divSearch.form.calEnd.set_value(eDate);
};

// 조회조건 (전체, 내용 등) 변경 시
this.divSearch_rdoField_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	this.searchfield = obj.value;
};

// 조회조건 AND, OR 설정
this.divSearch_rdoOperator_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	nexacro.getApplication().gv_mainFrame.QA_Cond_Searchgubun = obj.value;
};

// 전체 체크박스 이벤트
this.divSearch_Chk_ALL_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	if (obj.value)
	{
		this.divSearch.form.Chk_NPN.set_value(obj.value);
		this.divSearch.form.Chk_NP17.set_value(obj.value);
		this.divSearch.form.Chk_NP14.set_value(obj.value);
		this.divSearch.form.Chk_XP.set_value(obj.value);
		this.divSearch.form.Chk_MP.set_value(obj.value);
		this.divSearch.form.Chk_TDO.set_value(obj.value);
		nexacro.getApplication().gv_mainFrame.Chk_NPN_flag = true;
		nexacro.getApplication().gv_mainFrame.Chk_NP17_flag = true;
		nexacro.getApplication().gv_mainFrame.Chk_NP14_flag = true;
		nexacro.getApplication().gv_mainFrame.Chk_XP_flag = true;
		nexacro.getApplication().gv_mainFrame.Chk_MP_flag = true;
		nexacro.getApplication().gv_mainFrame.Chk_TDO_flag = true;
	}
	else
	{
		this.divSearch.form.Chk_NPN.set_value(obj.value);
		this.divSearch.form.Chk_NP17.set_value(obj.value);
		this.divSearch.form.Chk_NP14.set_value(obj.value);
		this.divSearch.form.Chk_XP.set_value(obj.value);
		this.divSearch.form.Chk_MP.set_value(obj.value);
		this.divSearch.form.Chk_TDO.set_value(obj.value);
		nexacro.getApplication().gv_mainFrame.Chk_NPN_flag = false;
		nexacro.getApplication().gv_mainFrame.Chk_NP17_flag = false;
		nexacro.getApplication().gv_mainFrame.Chk_NP14_flag = false;
		nexacro.getApplication().gv_mainFrame.Chk_XP_flag = false;
		nexacro.getApplication().gv_mainFrame.Chk_MP_flag = false;
		nexacro.getApplication().gv_mainFrame.Chk_TDO_flag = false;
	}
};

// 개별 제품 체크박스 이벤트
this.divSearch_Chk_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	if (obj.value)
	{
		this.divSearch.form.Chk_ALL.set_value(true);
		switch(obj.name) {
		case "Chk_NPN":
			nexacro.getApplication().gv_mainFrame.Chk_NPN_flag = true;
			break;
		case "Chk_NP17":
			nexacro.getApplication().gv_mainFrame.Chk_NP17_flag = true;
			break;
		case "Chk_NP14":
			nexacro.getApplication().gv_mainFrame.Chk_NP14_flag = true;
			break;
		case "Chk_XP":
			nexacro.getApplication().gv_mainFrame.Chk_XP_flag = true;
			break;
		case "Chk_MP":
			nexacro.getApplication().gv_mainFrame.Chk_MP_flag = true;
			break;
		case "Chk_TDO":
			nexacro.getApplication().gv_mainFrame.Chk_TDO_flag = true;
			break;				
		default:
		}
	}
	else
	{
		switch(obj.name) {
		case "Chk_NPN":
			nexacro.getApplication().gv_mainFrame.Chk_NPN_flag = false;
			break;
		case "Chk_NP17":
			nexacro.getApplication().gv_mainFrame.Chk_NP17_flag = false;
			break;
		case "Chk_NP14":
			nexacro.getApplication().gv_mainFrame.Chk_NP14_flag = false;
			break;
		case "Chk_XP":
			nexacro.getApplication().gv_mainFrame.Chk_XP_flag = false;
			break;
		case "Chk_MP":
			nexacro.getApplication().gv_mainFrame.Chk_MP_flag = false;
			break;
		case "Chk_TDO":
			nexacro.getApplication().gv_mainFrame.Chk_TDO_flag = false;
			break;				
		default:
		}
		if (this.divSearch.form.Chk_NPN.value == false && this.divSearch.form.Chk_NP17.value == false && this.divSearch.form.Chk_NP14.value == false && this.divSearch.form.Chk_XP.value == false && this.divSearch.form.Chk_MP.value == false && this.divSearch.form.Chk_TDO.value == false)		{
			this.divSearch.form.Chk_ALL.set_value(false);
		}
		if (this.divSearch.form.Chk_NPN.value == true && this.divSearch.form.Chk_NP17.value == true && this.divSearch.form.Chk_NP14.value == true && this.divSearch.form.Chk_XP.value == true && this.divSearch.form.Chk_MP.value == true && this.divSearch.form.Chk_TDO.value == true)
		{
			nexacro.getApplication().gv_mainFrame.Chk_All_flag = true;
		}
		else
		{
			nexacro.getApplication().gv_mainFrame.Chk_All_flag = false;
		}
	}
};

// 검색창에서 키입력 시 이벤트
this.divSearch_edtSearch_onkeyup = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if (e.keycode == 13)
	{
		this.divSearch.form.btnSearch.click();
		nexacro.getApplication().gv_mainFrame.fn_SearchKey_onkeyup(obj, e);
	}
	else
	{
		nexacro.getApplication().gv_mainFrame.Top_Edit_flag = false;
		nexacro.getApplication().gv_mainFrame.fn_SearchKey_onkeyup(obj, e);
	}
};

this.divSearch_edtSearch_onkillfocus = function(obj:nexacro.Edit,e:nexacro.KillFocusEventInfo)
{
	nexacro.getApplication().gv_mainFrame.showAutoCompleteResult(false);
};

// 적용 버튼 이벤트
this.divSearch_btnApply_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (!this.divSearch.form.Chk_NPN.value && !this.divSearch.form.Chk_NP17.value && !this.divSearch.form.Chk_NP14.value && !this.divSearch.form.Chk_XP.value && !this.divSearch.form.Chk_MP.value && !this.divSearch.form.Chk_TDO.value)
	{
		alert("선택한 제품이 없습니다.");
		return;
	}

	this.divResult.form.btn2.set_width(this.divSearch.form.Chk_NPN.value?186:0);
	this.divResult.form.btn3.set_width(this.divSearch.form.Chk_NP17.value?186:0);
	this.divResult.form.btn4.set_width(this.divSearch.form.Chk_NP14.value?186:0);
	this.divResult.form.btn5.set_width(this.divSearch.form.Chk_XP.value?186:0);
	this.divResult.form.btn6.set_width(this.divSearch.form.Chk_MP.value?186:0);
	this.divResult.form.btn7.set_width(this.divSearch.form.Chk_TDO.value?186:0);
	this.divResult.form.resetScroll();
	
	//this.divResult.form.btn1.click();
	switch(this.searchVersion) {
	case "btn1":
		this.divResult.form.btn1.click();	// 전체건수로 조회
		break;
	case "btn2":
		this.divResult.form.btn2.click();	
		break;
	case "btn3":
		this.divResult.form.btn3.click();	
		break;
	case "btn4":
		this.divResult.form.btn4.click();	
		break;
	case "btn5":
		this.divResult.form.btn5.click();	
		break;
	case "btn6":
		this.divResult.form.btn6.click();	
		break;
	case "btn7":
		this.divResult.form.btn7.click();	
		break;			
	default:
		this.divResult.form.btn1.click();	// 전체건수로 조회
	}	
};

// 초기화 버튼
this.divSearch_btnClear_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divSearch.form.edtSearch.set_value("");
	
	this.divSearch.form.Chk_ALL.set_value(1);
	this.divSearch.form.Chk_NPN.set_value(1);
	this.divSearch.form.Chk_NP17.set_value(1);
	this.divSearch.form.Chk_NP14.set_value(1);
	this.divSearch.form.Chk_XP.set_value(1);
	this.divSearch.form.Chk_MP.set_value(1);
	this.divSearch.form.Chk_TDO.set_value(1);
	
	this.divSearch.form.rdoField.set_value(200);
	this.searchfield = 200;
	this.divSearch.form.rdoOperator.set_value("OR");
	
	this.divSearch.form.rdoTerm.set_value(1);
	this.divSearch.form.calStart.set_value("");
	this.divSearch.form.calEnd.set_value("");
	
	if (!this.divSearch.form.Chk_NPN.value && !this.divSearch.form.Chk_NP17.value && !this.divSearch.form.Chk_NP14.value && !this.divSearch.form.Chk_XP.value && !this.divSearch.form.Chk_MP.value && !this.divSearch.form.Chk_TDO.value)
	{
		alert("선택한 제품이 없습니다.");
		return;
	}

	this.divResult.form.btn2.set_width(this.divSearch.form.Chk_NPN.value?186:0);
	this.divResult.form.btn3.set_width(this.divSearch.form.Chk_NP17.value?186:0);
	this.divResult.form.btn4.set_width(this.divSearch.form.Chk_NP14.value?186:0);
	this.divResult.form.btn5.set_width(this.divSearch.form.Chk_XP.value?186:0);
	this.divResult.form.btn6.set_width(this.divSearch.form.Chk_MP.value?186:0);
	this.divResult.form.btn7.set_width(this.divSearch.form.Chk_TDO.value?186:0);	
	this.divResult.form.resetScroll();
	
	this.divResult.form.btn1.click();
};
