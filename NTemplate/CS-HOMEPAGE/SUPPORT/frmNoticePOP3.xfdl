	//this.close();
};

this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close();
};

this.Static00_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	system.execBrowser("https://form.naver.com/response/K8LGZkwbshSF7OfuDoeKcg");
	return;
	// 해당 이벤트 공지사항으로 이동
	nexacro.getApplication().gv_mainFrame.param = {
		'menu': "Notice_View",
		'keyword': "",
		'page': 1,
		'postId': 230
		};
	nexacro.getApplication().gv_mainFrame.gfnGoMain();
	this.close();
};

this.Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
