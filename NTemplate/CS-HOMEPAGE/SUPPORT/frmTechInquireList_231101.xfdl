    <Layouts>
      <Layout width="1300" height="1110">
        <Grid id="grdInquireList" taborder="0" left="0" top="40" width="945" height="1045" cssclass="grd_WF_list" binddataset="ds_hotlist" scrollbartype="none none" autofittype="col" oncellclick="grdInquireList_oncellclick" nodatatext="검색된 데이터가 없습니다.">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="30"/>
                <Column size="92"/>
                <Column size="30"/>
                <Column size="60"/>
                <Column size="14"/>
                <Column size="86"/>
                <Column size="14"/>
                <Column size="30"/>
                <Column size="70"/>
                <Column size="14"/>
                <Column size="340"/>
                <Column size="166"/>
              </Columns>
              <Rows>
                <Row size="60"/>
                <Row size="40"/>
                <Row size="98"/>
                <Row size="20"/>
              </Rows>
              <Band id="body">
                <Cell text="expr:comp.parent.fnProductCodeIcon(PRODUCT_CODE)" displaytype="imagecontrol" autosizerow="none"/>
                <Cell col="1" text="expr:comp.parent.fnProductCode(PRODUCT_CODE)" cssclass="grd_WF_product" autosizerow="none"/>
                <Cell col="2" cssclass="grd_WF_number" textAlign="right" text="No." autosizerow="none"/>
                <Cell col="3" cssclass="grd_WF_number" text="bind:QL_SEQ" autosizerow="none" displaytype="normal"/>
                <Cell col="4" displaytype="imagecontrol" text="URL('theme://images/grd_WF_dot.png')" autosizerow="none"/>
                <Cell col="5" text="bind:INSERT_DATE" autosizerow="none" cssclass="grd_WF_date" displaytype="date" calendardateformat="yyyy-MM-dd"/>
                <Cell col="6" text="URL('theme://images/grd_WF_dot.png')" autosizerow="none" displaytype="imagecontrol"/>
                <Cell col="7" autosizerow="none" displaytype="imagecontrol" text="URL('theme://images/btn_MF_bookmark_S.png')"/>
                <Cell col="8" cssclass="grd_WF_date" text="bind:user_cnt1" autosizerow="none" displaytype="number"/>
                <Cell col="9" autosizerow="none" displaytype="imagecontrol" text="URL('theme://images/grd_WF_dot.png')"/>
                <Cell col="10" autosizerow="none" cssclass="expr:comp.parent.fn_statusCss(STATUS_CODE,qc_no)" text="expr:dataset.parent.gfnIsNull(qc_no)==false&amp;&amp;dataset.parent.tobe_yn?'RC '+qc_no:'' "/>
                <Cell col="11" text="expr:comp.parent.fn_statusWait(STATUS_CODE,qc_no,WAIT_TIME)"/>
                <Cell row="1" colspan="12" text="expr:comp.parent.gfn_makeEllipse(SUBJECT, comp)" cssclass="expr:comp.parent.fnGrdCssclass(gridLevelImage)" wordWrap="char" autosizerow="none" tooltiptext="expr:SUBJECT.replaceAll(&quot;&lt;fc v='#fb6d3a'&gt;&quot;,&quot;&quot;).replaceAll(&quot;&lt;/fc&gt;&quot;,&quot;&quot;)" displaytype="decoratetext"/>
                <Cell row="2" colspan="12" text="bind:CONTENTS" wordWrap="char" cssclass="grd_WF_content" displaytype="decoratetext"/>
                <Cell row="3" colspan="12" cssclass="grd_WF_line"/>
              </Band>
            </Format>
