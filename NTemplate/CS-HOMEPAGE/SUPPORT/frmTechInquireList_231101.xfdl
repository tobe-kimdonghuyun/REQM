                <Cell row="1" colspan="12" text="expr:comp.parent.gfn_makeEllipse(SUBJECT, comp)" cssclass="expr:comp.parent.fnGrdCssclass(gridLevelImage)" wordWrap="char" autosizerow="none" tooltiptext="expr:SUBJECT.replaceAll(&quot;&lt;fc v='#fb6d3a'&gt;&quot;,&quot;&quot;).replaceAll(&quot;&lt;/fc&gt;&quot;,&quot;&quot;)" displaytype="decoratetext"/>
