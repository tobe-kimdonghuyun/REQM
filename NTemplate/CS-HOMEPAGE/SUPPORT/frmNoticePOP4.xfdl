<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Pop" width="600" height="440" cssclass="sta_POP_foot" scrolltype="none">
    <Layouts>
      <Layout height="440" width="600">
        <Static id="Static01_00" taborder="0" left="0" height="40" cssclass="sta_POP_TitleBg" top="0" text="" right="0"/>
        <Static id="Static00" taborder="1" left="0" top="40" width="600" height="100" cssclass="sta_POP_top" accessibilityenable="false"/>
        <Static id="Static03" taborder="2" top="60" width="65" height="20" cssclass="sta_POP_logo" left="505"/>
        <Static id="Static02" taborder="3" left="20" top="80" height="55" cssclass="sta_POP_title" width="580" text="넥사크로 N V24 호남권 지역 교육 안내"/>
        <TextArea id="TextArea00" taborder="4" left="35" top="143" cssclass="txt_POP_mainText" value="안녕하세요. &#10;투비소프트 제품확산팀입니다.&#10;저희 투비소프트는 2024년 8월 광주광역시에 위치한 조선이공대학교와 &#10;산학협약을 체결하였으며, 이를 통해 호남권 지역의 넥사크로 제품에 대한 &#10;저변확대와 인재 양성을 위한 기반을 마련하였습니다.&#10;이를 바탕으로 겨울방학 기간 중 호남권 지역의 고객사 및 협력사, &#10;조선이공대학교 학생을 대상으로 넥사크로 오프라인 교육을 진행하고자 &#10;하오니, 관심 있는 분들의 많은 참여를 부탁드립니다." readonly="true" width="565" wordWrap="char" scrollbartype="none auto" scrollbardecbuttonsize="0" scrollbarincbuttonsize="0" scrollbarsize="10" height="250" font="normal 400 16px/24px &quot;NotoSansKR&quot;" onchanged="TextArea00_onchanged" initvalueid="iv_TextArea_Readonly" letterSpacing="0.5px" tabstop="false"/>
        <Static id="Static00_00" taborder="5" left="239" top="352" width="127" height="36" onclick="Static00_onclick" cursor="pointer" accessibilityenable="false" text="자세히 보기" font="bold 24px/24px &quot;NotoSansKR&quot;" border="0px solid black,0px solid black,2px double #666666" color="#666666"/>
        <Static id="Static01" taborder="6" left="0" width="600" height="42" top="398" cssclass="sta_POP_foot" accessibilityenable="false"/>
        <CheckBox id="CheckBox00" taborder="7" text="일주일간 이 창을 띄우지 않음" left="20" top="406" width="190" height="25" onclick="CheckBox00_onclick" cssclass="check_POP_notToday" value="false" tabstop="true" initvalueid="iv_CheckBox0"/>
        <Button id="Button00" taborder="8" text="닫기" top="406" width="55" height="25" cssclass="btn_POP_close" left="525" onclick="Button00_onclick"/>
        <Button id="Button00_00" taborder="9" top="0" width="40" height="40" right="0" cssclass="btn_POP_CloseIcon" accessibilitylabel="닫기" onclick="Button00_onclick"/>
      </Layout>
    </Layouts>
    <Objects/>
    <Script type="xscript5.1"><![CDATA[
this.CheckBox00_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	//nexacro.setPrivateProfile("mTodayPop4",this.gfnGetDate());
	nexacro.setPrivateProfile("mTodayPop4",this.gfnAddDate(this.gfnGetDate(),7));	//일주일 후 날짜 저장
	//this.close();
};

this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close();
};

this.Static00_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	// 해당 이벤트 공지사항으로 이동
	nexacro.getApplication().gv_mainFrame.param = {
		'menu': "Education_information_View",
		'keyword': "",
		'page': 1,
		'postId': 52
		};
	nexacro.getApplication().gv_mainFrame.gfnGoMain();
	this.close();	
};]]></Script>
  </Form>
</FDL>
