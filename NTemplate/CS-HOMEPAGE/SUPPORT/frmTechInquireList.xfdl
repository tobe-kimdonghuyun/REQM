this.getTabIndex = function (idx)
{
	var nIdx = nexacro.toNumber(idx) + 1;
	if (nexacro.getApplication().gv_mainFrame.tabCount > 0) 
	{
		if (idx == "1") 
		{
			nIdx = 4;
		}
		else if (idx == "2" || idx == "3") 
		{
			nIdx = nexacro.toNumber(idx);
		}
		else 
		{
			nIdx = 1;
		}
	}

	return nIdx;
};


this.initCallback = function (svcid, errCode, errMsg)
{
	if (svcid == "TabCount") 
	{
		nexacro.getApplication().gv_mainFrame.tabCount = this.ds_AccPro.rowcount;
	}
	this.formOnload();
};

this.formOnload = function ()
{
	if ((nexacro.getApplication().gv_mainFrame.QAStatus == "Modify") || (nexacro.getApplication().gv_mainFrame.QAStatus == "Reply")) 
	{
		this.fn_SetInitSize();

		nexacro.getApplication().gds_MiWizard.clearData();
		nexacro.getApplication().com_AddMiWizard("", "output1", "req_idx=" + nexacro.getApplication().gv_mainFrame.QAKeyNo, "CS,cs_request_proc,25");

		var outDs = "ds_ReqDetail=output1";
		this.com_CallService("selectDetail", "", "", outDs, "fn_DetailCallBack", "CS", true);
		return;
	}
	else if (nexacro.getApplication().gv_mainFrame.QAStatus == "List") 
	{
		nexacro.getApplication().gv_mainFrame.QAStatus = "List";
		this.ds_SearchParam.clearData();
		this.ds_SearchParam.addRow();
		this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition, "display_cnt", nexacro.getApplication().gv_mainFrame.QA_Cond_DisplayCnt);
		this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition, "page", nexacro.getApplication().gv_mainFrame.QA_Cond_Page);
		this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition, "searchfield", nexacro.getApplication().gv_mainFrame.QA_Cond_Searchfield);
		this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition, "searchgubun", nexacro.getApplication().gv_mainFrame.QA_Cond_Searchgubun);
		this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition, "BusinessSection", nexacro.getApplication().gv_mainFrame.QA_Cond_BusinessSection);
		this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition, "search_resort", nexacro.getApplication().gv_mainFrame.QA_Cond_Resort);
		this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition, "keyword", nexacro.getApplication().gv_mainFrame.QA_Cond_Keyword);
		this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition, "keywordall", nexacro.getApplication().gv_mainFrame.QA_Cond_Keyword);

	}
	else 
	{
		nexacro.getApplication().gv_mainFrame.QAStatus = "Write";
		var nIdx = 0;

		// 페이지 제어 초기화
		this.divPageExpr.form.fn_PageInit(this.ds_hotlist, "", this, "fn_CallTrans()", "fn_SetInitSize()");
	}
};

this.techinquireList_onbeforeclose = function (obj:Form, e:nexacro.CloseEventInfo)
{
};

this.attachFileUpload_onsuccess = function (obj:FileUpload, e:nexacro.FileUploadEventInfo)
{
	var ds_OutPut = new Dataset;
	ds_OutPut.copyData(e.datasets[0]);
	var errorCode = e.errorcode;
	var errorMsg = e.errormsg;


	if (errorCode < 0) 
	{
		this.attachFileUpload.deleteItem(0);
		this.attachFileUpload.appendItem();
	}
	else 
	{
		// 정상적으로 등록되었습니다<b>17시</b> 이후에 등록된 내용은 익일 처리됩니다.
		nexacro.getApplication().com_SetMessage("MSG_000063", false);
		// 질문내역 화면으로 이동
		var nCount = this.tabQnaExpr.getTabpageCount();
		var nIdx = nCount - 2;
		this.fn_indexChange(nIdx);
	}
};

this.fn_setFilePosition = function ()
{
	var nTop = this.tabQnaExpr.getOffsetTop() + this.tabQnaExpr.tabpg3.getOffsetTop() + this.tabQnaExpr.tabpg3.form.divInquireData.getOffsetTop()
		 + this.tabQnaExpr.tabpg3.form.divInquireData.stcTempFile.getOffsetTop();
	var nLeft = this.tabQnaExpr.getOffsetLeft() + this.tabQnaExpr.tabpg3.form.divInquireData.txtReqRemark.getOffsetLeft();

	this.attachFileUpload.move(nLeft, nTop);
};

// expr : 그리드의 expr로 제품 선택
this.fnProductCode = function(sPdCd)
{
/*
 *	N     043
 *	17    039
 *	14    024 025 026 027 034
 *	XP    010 011 019 020 021 022 023 031 032 033
 *	MP    001 002 003 004 005 006 007 008 009 017 018 028 029 030
 *  URL('theme://images/grd_WF_iconN.png')
 *  URL('theme://images/grd_WF_icon17.png')
 *  URL('theme://images/grd_WF_icon14.png')
 *  URL('theme://images/grd_WF_iconXP.png')
 *  URL('theme://images/grd_WF_iconMI.png')
 *  NexacroN
 *  Nexacro17
 *  Nexacro14
 *  Xplatform
 *  MiPlatform
 */
	var sRtn = "";
	switch(sPdCd) {
	case "047":
		sRtn = "TobeDevOps";
		break;		
	case "045":
		sRtn = "Build";
		break;	
	case "044":
		sRtn = "Sketch";
		break;	
	case "043":
	case "046":	
		sRtn = "Nexacro N";
		break;		
	case "039":
		sRtn = "nexacro 17";
		break;
	case "024": case "025": case "026": case "027": case "034":
		sRtn = "nexacro 14";
		break;
	case "010": case "011": case "019": case "020": case "021": case "022": case "023": case "031": case "032": case "033":
		sRtn = "XPLATFORM";
		break;
	case "001": case "002": case "003": case "004": case "005": case "006": case "007": case "008": case "009": case "017": case "018": case "028": case "029": case "030":
		sRtn = "MiPlatform";
		break;
	default:
	}
	return sRtn;
};

