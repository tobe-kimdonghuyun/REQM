// expr : 재질문 여부에 따라 글제목 들여쓰기
this.fnStaCssclass = function(sStr)
{
	//trace("sStr:"+sStr);
	var rtn = "";
	switch(sStr.substr(31,1)) {
	case "0":
		rtn = "sta_WF_ConTitle";
		break;
	case "1":
		rtn = "sta_WF_ConTitle1";
		break;
	case "2":
		rtn = "sta_WF_ConTitle2";
		break;
	case "3":
		rtn = "sta_WF_ConTitle3";
		break;
	case "4":
		rtn = "sta_WF_ConTitle4";
		break;
	case "5":
		rtn = "sta_WF_ConTitle5";
		break;
	default:
	}
	if (this.gfnIsNull(rtn))
	{
		rtn = "sta_WF_ConTitle";
	}
	//trace(rtn);
	return rtn;
}

// expr : 재질문 여부에 따라 글제목 들여쓰기
this.fnGrdCssclass = function(sStr)
{
	//trace("sStr:"+sStr);
	var rtn = "";
	switch(sStr.substr(31,1)) {
	case "0":
		rtn = "grd_WF_title0";
		break;
	case "1":
		rtn = "grd_WF_title1";
		break;
	case "2":
		rtn = "grd_WF_title2";
		break;
	case "3":
		rtn = "grd_WF_title3";
		break;
	case "4":
		rtn = "grd_WF_title4";
		break;
	case "5":
		rtn = "grd_WF_title5";
		break;
	default:
	}
	if (this.gfnIsNull(rtn))
	{
		rtn = "grd_WF_title0";
	}
	//trace(rtn);
	return rtn;
}

// cboListType콤보 이벤트 그리드를 제목만 <-> 제목/내용 변경
this.cboListType_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	if (e.postindex == 0)
	{
		//this.grdInquireList.set_formatid("default");
		nexacro.getApplication().gv_mainFrame.QA_Cond_ListType = 0;
		this.fn_createList();
		this.fn_SetInitSize();
	}
	else
	{
		//this.grdInquireList.set_formatid("title");
		nexacro.getApplication().gv_mainFrame.QA_Cond_ListType = 1;
		this.fn_createList();
		this.fn_SetInitSize();
	}
};


// expr : 그리드 처리현황 표시
this.fn_statusCss = function(sStatus,qc_no)
{
	if (sStatus.substr(0,1) == "P")
	{
		return "sta_WF_Status1";
	}
	else if (sStatus.substr(0,1) == "W" || sStatus.substr(0,1) == "A")
	{
		return "sta_WF_Status2";
	}
	else if (sStatus.substr(0,1) == "C")
	{
		return "sta_WF_Status3"
	}
	else
	{
		return "";
	}
}

// expr : 그리드 처리현황 표시
this.fn_statusCss_Grid = function(sStatus,qc_no)
{
	if (sStatus.substr(0,1) == "P")
	{
		if (this.tobe_yn && !this.gfnIsNull(qc_no))
		{
			return "grd_WF_status2";
		}
		else
		{
			return "grd_WF_status1";
		}
