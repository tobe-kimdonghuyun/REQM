	else if (sStatus.substr(0,1) == "W" || sStatus.substr(0,1) == "A")
	{
		if (this.tobe_yn && !this.gfnIsNull(qc_no))
		{
			return "grd_WF_status4";
		}
		else
		{
			return "grd_WF_status3";
		}
	}
	else if (sStatus.substr(0,1) == "C")
	{
		if (this.tobe_yn && !this.gfnIsNull(qc_no))
		{
			return "grd_WF_status6";
		}
		else
		{
			return "grd_WF_status5";
		}
	}
	else
	{
		return "";
	}

}


this.fn_statusAccessibility = function(sStatus,qc_no){

	if (sStatus.substr(0,1) == "P")
	{
		return "진행상태 처리중";
	}
	else if (sStatus.substr(0,1) == "W" || sStatus.substr(0,1) == "A")
	{
		return "진행상태 접수";
	}
	else if (sStatus.substr(0,1) == "C")
	{
