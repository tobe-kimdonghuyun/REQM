 // 검색창에서 키입력 시 이벤트
this.edtSearch_onkeyup = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	//열려있는 연관검색어 Div 닫기
	nexacro.getApplication().gv_mainFrame.showAutoCompleteResult(false);
	
	nexacro.getApplication().gv_mainFrame.Search_divCover = this.div_autoCompleteCover;
	nexacro.getApplication().gv_mainFrame.Search_div = this.div_autoCompleteCover.form.div_autoCompleteResult;
	nexacro.getApplication().gv_mainFrame.Search_Edit = obj;
	
	if (e.keycode == 13)
	{
		this.btnSearch.click();
		nexacro.getApplication().gv_mainFrame.fn_SearchKey_onkeyup(obj, e);
	}
	else
	{
		nexacro.getApplication().gv_mainFrame.Top_Edit_flag = false;
		nexacro.getApplication().gv_mainFrame.fn_SearchKey_onkeyup(obj, e);
	}
};

// 조회버튼 클릭
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (!this.divSearch.form.Chk_NPN.value && !this.divSearch.form.Chk_NP17.value && !this.divSearch.form.Chk_NP14.value && !this.divSearch.form.Chk_XP.value && !this.divSearch.form.Chk_MP.value && !this.divSearch.form.Chk_TDO.value)
	{
		alert("선택한 제품이 없습니다.");
		return;
	}
	
	//열려있는 연관검색어 Div 닫기
	nexacro.getApplication().gv_mainFrame.showAutoCompleteResult(false);	

	// 제품 조회 조건에 따라 안보이게 처리
	this.divResult.form.btn2.set_width(this.divSearch.form.Chk_NPN.value?186:0);
	this.divResult.form.btn3.set_width(this.divSearch.form.Chk_NP17.value?186:0);
	this.divResult.form.btn4.set_width(this.divSearch.form.Chk_NP14.value?186:0);
	this.divResult.form.btn5.set_width(this.divSearch.form.Chk_XP.value?186:0);
	this.divResult.form.btn6.set_width(this.divSearch.form.Chk_MP.value?186:0);
	this.divResult.form.btn7.set_width(this.divSearch.form.Chk_TDO.value?186:0);
	this.fn_setTabBtnVisible();
	this.divResult.form.resetScroll();
	
	switch(this.searchVersion) {
	case "btn1":
		this.divResult.form.btn1.click();	// 전체건수로 조회
		break;
	case "btn2":
		this.divResult.form.btn2.click();	
		break;
	case "btn3":
		this.divResult.form.btn3.click();	
		break;
	case "btn4":
		this.divResult.form.btn4.click();	
		break;
	case "btn5":
		this.divResult.form.btn5.click();	
		break;
	case "btn6":
		this.divResult.form.btn6.click();	
		break;
	case "btn7":
		this.divResult.form.btn7.click();	
		break;				
	default:
		this.divResult.form.btn1.click();	// 전체건수로 조회
	}		
};

this.btnFilter_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fn_filterResize();	
};

// 검색필터 리사이즈
this.fn_filterResize = function()
{
	var changedHeight = 0;
	if (this.divSearch.height == this.fvSearchOpen)
	{
		nexacro.getApplication().gv_mainFrame.filterstatus = "close";
		this.divSearch.set_height(this.fvSearchClose);
		nexacro.getApplication().gv_mainFrame.staBGG.set_height(221);
		this.btnFilterResize.set_cssclass("btn_WF_filterOpen");
		this.btnFilterResize.set_accessibilitydescription("조건영역 닫힘");
		changedHeight = 0;
		
		this.fn_setCompVisible(false);
	}
	else
	{
		nexacro.getApplication().gv_mainFrame.filterstatus = "open";
		this.divSearch.set_height(this.fvSearchOpen);
		nexacro.getApplication().gv_mainFrame.staBGG.set_height(460);
		this.btnFilterResize.set_cssclass("btn_WF_filterClose");
		this.btnFilterResize.set_accessibilitydescription("조건영역 열림");
		changedHeight = this.fvSearchOpen;
		
		this.fn_setCompVisible(true);
	}
	
	this.divResult.set_top(this.divSearch.getOffsetBottom());
	this.resetScroll();
	this.divPageExpr.set_top(this.divInquireList.getOffsetBottom() + 40);
	this.set_height(this.fvWorkHeight + changedHeight);
	
	//TODO
	nexacro.getApplication().gv_mainFrame.fn_setFilterResize();
};

this.fn_filterBFsize = function()
{
	var changedHeight = 0;
	if (nexacro.getApplication().gv_mainFrame.filterstatus == "close")
	{
		this.divSearch.set_height(this.fvSearchClose);
		nexacro.getApplication().gv_mainFrame.staBGG.set_height(221);
		this.btnFilterResize.set_cssclass("btn_WF_filterOpen");
		this.btnFilterResize.set_accessibilitydescription("조건영역 닫힘");
		changedHeight = 0;
		
		this.fn_setCompVisible(false);
	}
	else
	{
		this.divSearch.set_height(this.fvSearchOpen);
		nexacro.getApplication().gv_mainFrame.staBGG.set_height(460);
		this.btnFilterResize.set_cssclass("btn_WF_filterClose");
		this.btnFilterResize.set_accessibilitydescription("조건영역 열림");
		changedHeight = this.fvSearchOpen;
		
		this.fn_setCompVisible(true);
	}
	
	this.divResult.set_top(this.divSearch.getOffsetBottom());
	this.resetScroll();
	this.divPageExpr.set_top(this.divInquireList.getOffsetBottom() + 40);
	this.set_height(this.fvWorkHeight + changedHeight);
	
	nexacro.getApplication().gv_mainFrame.fn_setFilterResize();
}

//상세조회 조건 visible처리
this.fn_setCompVisible = function(bFlag)
{
	this.divSearch.visible = bFlag;
	
	//화면 onload될 때 divSearch가 visible=false여도 내부 컴포넌트 읽어주는 현상이 있음.
	var comps = this.divSearch.form.components;
	for (var i = 0; i < comps.length; i++)
	{
		var obj = comps[i];
		obj.visible = bFlag;
	}
};

// 전체 체크박스 이벤트
this.divSearch_Chk_ALL_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	if (obj.value)
	{
		this.divSearch.form.Chk_NPN.set_value(obj.value);
		this.divSearch.form.Chk_NP17.set_value(obj.value);
		this.divSearch.form.Chk_NP14.set_value(obj.value);
		this.divSearch.form.Chk_XP.set_value(obj.value);
		this.divSearch.form.Chk_MP.set_value(obj.value);
		this.divSearch.form.Chk_TDO.set_value(obj.value);
		nexacro.getApplication().gv_mainFrame.Chk_NPN_flag = true;
		nexacro.getApplication().gv_mainFrame.Chk_NP17_flag = true;
		nexacro.getApplication().gv_mainFrame.Chk_NP14_flag = true;
		nexacro.getApplication().gv_mainFrame.Chk_XP_flag = true;
		nexacro.getApplication().gv_mainFrame.Chk_MP_flag = true;
		nexacro.getApplication().gv_mainFrame.Chk_TDO_flag = true;
	}
	else
	{
		this.divSearch.form.Chk_NPN.set_value(obj.value);
		this.divSearch.form.Chk_NP17.set_value(obj.value);
		this.divSearch.form.Chk_NP14.set_value(obj.value);
		this.divSearch.form.Chk_XP.set_value(obj.value);
		this.divSearch.form.Chk_MP.set_value(obj.value);
		this.divSearch.form.Chk_TDO.set_value(obj.value);
		nexacro.getApplication().gv_mainFrame.Chk_NPN_flag = false;
		nexacro.getApplication().gv_mainFrame.Chk_NP17_flag = false;
		nexacro.getApplication().gv_mainFrame.Chk_NP14_flag = false;
		nexacro.getApplication().gv_mainFrame.Chk_XP_flag = false;
		nexacro.getApplication().gv_mainFrame.Chk_MP_flag = false;
		nexacro.getApplication().gv_mainFrame.Chk_TDO_flag = false;
	}	
};

this.divSearch_Chk_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	if (obj.value)
	{
		this.divSearch.form.Chk_ALL.set_value(true);
		switch(obj.name) {
		case "Chk_NPN":
			nexacro.getApplication().gv_mainFrame.Chk_NPN_flag = true;
			break;
		case "Chk_NP17":
			nexacro.getApplication().gv_mainFrame.Chk_NP17_flag = true;
			break;
		case "Chk_NP14":
			nexacro.getApplication().gv_mainFrame.Chk_NP14_flag = true;
			break;
		case "Chk_XP":
			nexacro.getApplication().gv_mainFrame.Chk_XP_flag = true;
			break;
		case "Chk_MP":
			nexacro.getApplication().gv_mainFrame.Chk_MP_flag = true;
			break;
		case "Chk_TDO":
			nexacro.getApplication().gv_mainFrame.Chk_TDO_flag = true;
			break;				
		default:
		}
	}
	else
	{
		switch(obj.name) {
		case "Chk_NPN":
			nexacro.getApplication().gv_mainFrame.Chk_NPN_flag = false;
			break;
		case "Chk_NP17":
			nexacro.getApplication().gv_mainFrame.Chk_NP17_flag = false;
			break;
		case "Chk_NP14":
			nexacro.getApplication().gv_mainFrame.Chk_NP14_flag = false;
			break;
		case "Chk_XP":
			nexacro.getApplication().gv_mainFrame.Chk_XP_flag = false;
			break;
		case "Chk_MP":
			nexacro.getApplication().gv_mainFrame.Chk_MP_flag = false;
			break;
		case "Chk_TDO":
			nexacro.getApplication().gv_mainFrame.Chk_TDO_flag = false;
			break;				
		default:
		}
		if (this.divSearch.form.Chk_NPN.value == false && this.divSearch.form.Chk_NP17.value == false && this.divSearch.form.Chk_NP14.value == false && this.divSearch.form.Chk_XP.value == false && this.divSearch.form.Chk_MP.value == false && this.divSearch.form.Chk_TDO.value == false)		{
			this.divSearch.form.Chk_ALL.set_value(false);
		}
		if (this.divSearch.form.Chk_NPN.value == true && this.divSearch.form.Chk_NP17.value == true && this.divSearch.form.Chk_NP14.value == true && this.divSearch.form.Chk_XP.value == true && this.divSearch.form.Chk_MP.value == true && this.divSearch.form.Chk_TDO.value == true)
		{
			nexacro.getApplication().gv_mainFrame.Chk_All_flag = true;
		}
		else
		{
			nexacro.getApplication().gv_mainFrame.Chk_All_flag = false;
		}
	}	
};

// 조회조건 (전체, 내용 등) 변경 시
this.divSearch_rdoField_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	this.searchfield = obj.value;	
};

// 조회조건 AND, OR 설정
this.divSearch_rdoOperator_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	nexacro.getApplication().gv_mainFrame.QA_Cond_Searchgubun = obj.value;	
};

// 날짜 조회 조건 변경
this.divSearch_rdoTerm_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	var sDate = "";
	var eDate = "";
	var today = this.gfnGetDate();

	switch(e.postindex) {
	case 0:	// 전체
		sDate = "";
		eDate = "";
		break;
	case 1:	// 오늘
		sDate = today;
		eDate = today;
		break;
	case 2:	// 1주일
		sDate = this.gfnAddDate(today, -7);
		eDate = today;
		break;
	case 3:	// 1달
		sDate = this.gfnAddMonth(today, -1);
		eDate = today;
		break;
	case 4:
		break;
	default:
	}
	this.period = this.divSearch.form.rdoTerm.text;
	this.fromDate = sDate;
	this.toDate = eDate;
	this.divSearch.form.calStart.set_value(sDate);
	this.divSearch.form.calEnd.set_value(eDate);	
};

// 초기화 버튼
this.divSearch_btnClear_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.edtSearch.set_value("");
	
	this.divSearch.form.Chk_ALL.set_value(1);
	this.divSearch.form.Chk_NPN.set_value(1);
	this.divSearch.form.Chk_NP17.set_value(1);
	this.divSearch.form.Chk_NP14.set_value(1);
	this.divSearch.form.Chk_XP.set_value(1);
	this.divSearch.form.Chk_MP.set_value(1);
	this.divSearch.form.Chk_TDO.set_value(1);
	
	this.divSearch.form.rdoField.set_value(200);
	this.searchfield = 200;
	this.divSearch.form.rdoOperator.set_value("OR");
	
	this.divSearch.form.rdoTerm.set_value(1);
	this.divSearch.form.calStart.set_value("");
	this.divSearch.form.calEnd.set_value("");
	
	if (!this.divSearch.form.Chk_NPN.value && !this.divSearch.form.Chk_NP17.value && !this.divSearch.form.Chk_NP14.value && !this.divSearch.form.Chk_XP.value && !this.divSearch.form.Chk_MP.value && !this.divSearch.form.Chk_TDO.value)
	{
		alert("선택한 제품이 없습니다.");
		return;
	}

	this.divResult.form.btn2.set_width(this.divSearch.form.Chk_NPN.value?186:0);
	this.divResult.form.btn3.set_width(this.divSearch.form.Chk_NP17.value?186:0);
	this.divResult.form.btn4.set_width(this.divSearch.form.Chk_NP14.value?186:0);
	this.divResult.form.btn5.set_width(this.divSearch.form.Chk_XP.value?186:0);
	this.divResult.form.btn6.set_width(this.divSearch.form.Chk_MP.value?186:0);
	this.divResult.form.btn7.set_width(this.divSearch.form.Chk_TDO.value?186:0);	
	this.divResult.form.resetScroll();
	
	this.divResult.form.btn1.click();	
};

// 적용 버튼 이벤트
this.divSearch_btnApply_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (!this.divSearch.form.Chk_NPN.value && !this.divSearch.form.Chk_NP17.value && !this.divSearch.form.Chk_NP14.value && !this.divSearch.form.Chk_XP.value && !this.divSearch.form.Chk_MP.value && !this.divSearch.form.Chk_TDO.value)
	{
		alert("선택한 제품이 없습니다.");
		return;
	}

	this.divResult.form.btn2.set_width(this.divSearch.form.Chk_NPN.value?186:0);
	this.divResult.form.btn3.set_width(this.divSearch.form.Chk_NP17.value?186:0);
	this.divResult.form.btn4.set_width(this.divSearch.form.Chk_NP14.value?186:0);
	this.divResult.form.btn5.set_width(this.divSearch.form.Chk_XP.value?186:0);
	this.divResult.form.btn6.set_width(this.divSearch.form.Chk_MP.value?186:0);
	this.divResult.form.btn7.set_width(this.divSearch.form.Chk_TDO.value?186:0);
	this.fn_setTabBtnVisible();
	this.divResult.form.resetScroll();
	
	//this.divResult.form.btn1.click();
	switch(this.searchVersion) {
	case "btn1":
		this.divResult.form.btn1.click();	// 전체건수로 조회
		break;
	case "btn2":
		this.divResult.form.btn2.click();	
		break;
	case "btn3":
		this.divResult.form.btn3.click();	
		break;
	case "btn4":
		this.divResult.form.btn4.click();	
		break;
	case "btn5":
		this.divResult.form.btn5.click();	
		break;
	case "btn6":
		this.divResult.form.btn6.click();	
		break;
	case "btn7":
		this.divResult.form.btn7.click();	
		break;			
	default:
		this.divResult.form.btn1.click();	// 전체건수로 조회
	}		
};

// 제품탭 선택
this.divResult_btnProd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.searchVersion = obj.name;
	var sKeyword = this.edtSearch.value;
	// 번호일때 숫자 체크
	if (this.searchfield == 600)
	{
		var chkNo = /^\d+$/.test(sKeyword);
		if (this.gfnIsNull(sKeyword) || chkNo == false)	// 검색조건(번호) & 번호가 아닐때
		{
			alert("번호를 입력해주세요.");
			return;
		}
	}

	this.divResult.form.btn1.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn2.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn3.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn4.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn5.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn6.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn7.set_cssclass("btn_WF_resultTab");	
	
	obj.set_cssclass("btn_WF_resultTab_S");

	switch(obj.name) {
	case "btn1":
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "All";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 0;
		nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = 0;
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = 1;
		break;
	case "btn2":
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "Nexacro N";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 1;
		nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = 0;
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = 1;
		break;
	case "btn3":
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "nexacro platform17";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 2;
		nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = 0;
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = 1;
		break;
	case "btn4":
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "nexacro platform14";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 3;
		nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = 0;
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = 1;
		break;
	case "btn5":
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "XPLATFORM";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 4;
		nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = 0;
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = 1;
		break;
	case "btn6":
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "MiPlatform";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 5;
		nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = 0;
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = 1;
		break;
	case "btn7":
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "TobeDevOps";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 6;
		nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = 0;
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = 1;
		break;				
	default:
	}
	
	this.fn_saveHistoryData();	// 히스토리 세션 데이터 저장

	// 검색 조건 번호일때 키워드 없으면 반려
	var sKeyword = "";
	if (!this.gfnIsNull(this.edtSearch.value))
	{
		sKeyword = this.edtSearch.value.trim();
	}
	else
	{
		sKeyword = this.edtSearch.value;
	}
	this.edtSearch.value;

	this.fn_CallTrans();	// 조회	
};


// 제품탭 선택(사용자 클릭 아님)
this.fn_selectTab = function(nTabIndex)
{
	var sKeyword = this.edtSearch.value;
	// 번호일때 숫자 체크
	if (this.searchfield == 600)
	{
		var chkNo = /^\d+$/.test(sKeyword);
		if (this.gfnIsNull(sKeyword) || chkNo == false)	// 검색조건(번호) & 번호가 아닐때
		{
			alert("번호를 입력해주세요.");
			return;
		}
	}

	this.divResult.form.btn1.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn2.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn3.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn4.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn5.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn6.set_cssclass("btn_WF_resultTab");
	this.divResult.form.btn7.set_cssclass("btn_WF_resultTab");
	
	switch(nTabIndex) {
	case 0:
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "All";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 0;
		this.divResult.form.btn1.set_cssclass("btn_WF_resultTab_S");
		break;
	case 1:
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "Nexacro N";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 1;
		this.divResult.form.btn2.set_cssclass("btn_WF_resultTab_S");
		break;
	case 2:
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "nexacro platform17";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 2;
		this.divResult.form.btn3.set_cssclass("btn_WF_resultTab_S");
		break;
	case 3:
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "nexacro platform14";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 3;
		this.divResult.form.btn4.set_cssclass("btn_WF_resultTab_S");
		break;
	case 4:
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "XPLATFORM";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 4;
		this.divResult.form.btn5.set_cssclass("btn_WF_resultTab_S");
		break;
	case 5:
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "MiPlatform";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 5;
		this.divResult.form.btn6.set_cssclass("btn_WF_resultTab_S");
		break;
	case 6:
		nexacro.getApplication().gv_mainFrame.QA_Cond_Prod = "TobeDevOps";
		nexacro.getApplication().gv_mainFrame.QA_Tab_Index = 6;
		this.divResult.form.btn7.set_cssclass("btn_WF_resultTab_S");
		break;		
	default:
	}
	
	this.fn_saveHistoryData();	// 히스토리 세션 데이터 저장
	
	this.fn_CallTrans();	// 조회
};


// 새로고침을 대비해 검색 데이터 저장
this.fn_saveHistoryData = function()
{
	nexacro.getApplication().gv_mainFrame.param.keyword = this.edtSearch.value;
	// 히스토리 sData에 저장
	var sData = {
	Chk_ALL:this.divSearch.form.Chk_ALL.value
	,Chk_NPN:this.divSearch.form.Chk_NPN.value
	,Chk_NP17:this.divSearch.form.Chk_NP17.value
	,Chk_NP14:this.divSearch.form.Chk_NP14.value
	,Chk_XP:this.divSearch.form.Chk_XP.value
	,Chk_MP:this.divSearch.form.Chk_MP.value
	,Chk_TDO:this.divSearch.form.Chk_TDO.value	
	,rdoField:this.divSearch.form.rdoField.value
	,rdoOperator:this.divSearch.form.rdoOperator.value
	,rdoTerm:this.divSearch.form.rdoTerm.value
	,calStart:this.divSearch.form.calStart.value
	,calEnd:this.divSearch.form.calEnd.value
	,filterstatus:nexacro.getApplication().gv_mainFrame.filterstatus
	,QA_Tab_Index:nexacro.getApplication().gv_mainFrame.QA_Tab_Index
	};
	nexacro.getApplication().gv_mainFrame.gfnSetHistoryData(sData);
};


// 페이징 검색 데이터 저장
this.fn_savePagingData = function()
{
	nexacro.getApplication().gv_mainFrame.param.keyword = this.edtSearch.value;
	// 히스토리 sData에 저장
	var sData = {
	Chk_ALL:this.divSearch.form.Chk_ALL.value
	,Chk_NPN:this.divSearch.form.Chk_NPN.value
	,Chk_NP17:this.divSearch.form.Chk_NP17.value
	,Chk_NP14:this.divSearch.form.Chk_NP14.value
	,Chk_XP:this.divSearch.form.Chk_XP.value
	,Chk_MP:this.divSearch.form.Chk_MP.value
	,Chk_TDO:this.divSearch.form.Chk_TDO.value
	,rdoField:this.divSearch.form.rdoField.value
	,rdoOperator:this.divSearch.form.rdoOperator.value
	,rdoTerm:this.divSearch.form.rdoTerm.value
	,calStart:this.divSearch.form.calStart.value
	,calEnd:this.divSearch.form.calEnd.value
	,filterstatus:nexacro.getApplication().gv_mainFrame.filterstatus
	,QA_Tab_Index:nexacro.getApplication().gv_mainFrame.QA_Tab_Index
	};
	return sData;
};

 /************************************************************************
 * ↑↑↑↑↑↑ 여기까지 search 영역 ↑↑↑↑↑↑↑↑
 ************************************************************************/
 
this.div_autoCompleteCover_onclick = function(obj:nexacro.Div,e:nexacro.ClickEventInfo)
{
	nexacro.getApplication().gv_mainFrame.div_autoCompleteCover_onclick();
};

this.div_autoCompleteCover_onkillfocus = function(obj:nexacro.Div,e:nexacro.KillFocusEventInfo)
{
	nexacro.getApplication().gv_mainFrame.div_autoCompleteCover_onkillfocus();
};
