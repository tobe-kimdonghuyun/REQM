    <Bind/>
    <Script type="xscript5.1"><![CDATA[/**
*  QnA리스트
*
*  @MenuPath 
*  @FileName 		SUPPORT::frmTechInquireList.xfdl 
*  @Creator 		김광호
*  @CreateDate 		2022.01.01
*  @LastModifier  
*  @LastModifyDate  
*  @Version 		1.0
*  @Outline 		QnA리스트
*  @Desction 
************** 소스 수정 이력 *************************************************
*    date          Modifier            Description
*******************************************************************************
*  2022.01.01      김광호	           최초 생성 
*******************************************************************************
*/

this.user_id = "";			// 투비직원여부를 위한 user id

this.keywordall = "";		// 검색어

this.tobe_yn = false;		// 투비직원 여부

this.TotalCnt = "";			// 나의질문내역&북마크 에서 토탈건수로 페이징 보정
this.fvTotalN = 0;			// 각 총건수
this.fvTotal17 = 0;
this.fvTotal14 = 0;
this.fvTotalXP = 0;
this.fvTotalMP = 0;
this.fvTotalAll = 0;

this.nDivRightHeight = 0;	// RightFrame의 높이

this.fromDate = "";			// 조회조건 시작날짜
this.toDate = "";			// 조회조건 종료날짜

this.fvBookCD = 0;			// 북마크 코드


//Search영역 폼변수
this.period = "전체";
this.fromDate = "";
this.toDate = "";
this.searchGubun = "OR";
this.searchfield = "200";
this.searchVersion = "";


// 높이 저장
this.fvSearchOpen = 266;
this.fvSearchClose = 0;
this.fvWorkHeight = 0;



this.techinquireList_onload = function (obj:Form, e:nexacro.LoadEventInfo)
{	
	if (nexacro.getApplication().gv_mainFrame.PCategory2 == "MyQnAList" || nexacro.getApplication().gv_mainFrame.PCategory2 == "Bookmark" || nexacro.getApplication().gv_mainFrame.PCategory2 == "Bookmark_Tip") 
	{
		//검색영역 없애기.
		this.fn_setSearchArea(false);
	
		if (nexacro.getApplication().gv_mainFrame.MYPAGE_Cond_Prod > 0)
		{
			nexacro.getApplication().gv_mainFrame.divMain.form.divBookmark.form.tabProduct.set_tabindex(nexacro.getApplication().gv_mainFrame.MYPAGE_Cond_Prod);
		}
		// 로그인 확인
		if(nexacro.getApplication().gds_UserInfo.getRowCount() <= 0)
		{
			nexacro.getApplication().gv_mainFrame.TargetUrl = nexacro.getApplication().gv_mainFrame.PCategory2;
			nexacro.getApplication().gv_mainFrame.param = {
				'menu': "login",
				'keyword': "",
				'page': 1,
				'postId': ""
				};
			nexacro.getApplication().gv_mainFrame.gfnGoMain();
			return;
		}
	} else {
		//검색영역
		this.fn_setSearchArea(true);
		this.search_onload();	
	}

	// 비교를 위해 초기 RightFrame의 높이를 저장
	this.nDivRightHeight = this.divRight.getOffsetHeight();
	
	// 페이지 가져오기
	if (!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.param.page))
	{
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = nexacro.getApplication().gv_mainFrame.param.page;
	}
	
	this.user_id = nexacro.getApplication().gds_UserInfo.getColumn(0, "User_id");
	
	// 리스트 타입 설정
	if (nexacro.getApplication().gv_mainFrame.QA_Cond_ListType == 1)
	{
		this.cboListType.set_index(1);
		//this.grdInquireList.set_formatid("title");
		this.fn_SetInitSize();
	}
	
// 	// 통합검색에서 들어왔을 경우 return;
// 	if (!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.SearchEngineFlag))
// 	{
// 		// 페이징 교체
// 		this.divPageExpr.set_visible(false);
// 		this.viewPaging.set_visible(true);
// 		nexacro.getApplication().gv_searchEngine.fn_search(nexacro.getApplication().gv_mainFrame.QA_Cond_Page);
// 		return;
// 	}

//	this.formOnload();
	
	// 조회조건 초기화
	this.ds_SearchParam.clearData();
	this.ds_SearchParam.addRow();
	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition, "display_cnt", nexacro.getApplication().gv_mainFrame.QA_Cond_DisplayCnt);
	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition, "page", nexacro.getApplication().gv_mainFrame.QA_Cond_Page);
	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition, "searchfield", nexacro.getApplication().gv_mainFrame.QA_Cond_Searchfield);
	if(this.gfnIsNull(nexacro.getApplication().gv_mainFrame.QA_Cond_Searchgubun))nexacro.getApplication().gv_mainFrame.QA_Cond_Searchgubun = "OR";
	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition, "searchgubun", nexacro.getApplication().gv_mainFrame.QA_Cond_Searchgubun);
	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition, "BusinessSection", nexacro.getApplication().gv_mainFrame.QA_Cond_BusinessSection);
	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition, "search_resort", nexacro.getApplication().gv_mainFrame.QA_Cond_Resort);
	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition, "keyword", nexacro.getApplication().gv_mainFrame.QA_Cond_Keyword);
	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition, "keywordall", nexacro.getApplication().gv_mainFrame.QA_Cond_Keyword);
	
	this.fvBookCD = nexacro.getApplication().gv_BookmarkTipCd;
	var objTab = nexacro.getApplication().gv_mainFrame.divMain.form.divBookmark.form.tabProduct;
	
	var nRow = nexacro.getApplication().gv_mainFrame.dsScreenUrl.findRow("subCatgy", nexacro.getApplication().gv_mainFrame.param.menu);
	var sLayout = nexacro.getApplication().gv_mainFrame.dsScreenUrl.getColumn(nRow, "Layout");
	if(sLayout == "MYQNALIST" || sLayout == "BOOKMARK")
	{
		if(!this.gfnIsNull(nexacro.getApplication().gv_BookmarkTipCd))
		{
			var sBookCD = this.fvBookCD;
			objTab.set_tabindex(sBookCD);
			nexacro.getApplication().gv_BookmarkTipCd=0;
		}
		else
		{
			objTab.set_tabindex(sBookCD);
			nexacro.getApplication().gv_BookmarkTipCd=0;
		}
	}
	
	nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, 1000);
	
	// 페이지 제어 초기화
	nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = nexacro.floor((parseInt(nexacro.getApplication().gv_mainFrame.QA_Cond_Page)-1)/10);
	this.divPageExpr.form.fn_PageInit(this.ds_hotlist, "", this, "fn_CallTrans()", "fn_SetInitSize()");
	// 상세에서 뒤로 가기 시 목록 전체 이므로 전체 표시
	if (nexacro.getApplication().gv_mainFrame.PCategory2 == "QnA")
	{
		// 저장된 nexacro.getApplication().gv_mainFrame.QA_Tab_Index 에 따라 해당 제품을 조회
		nexacro.getApplication().gv_searchEngine.fn_selectTab(nexacro.getApplication().gv_mainFrame.QA_Tab_Index);
		return;
	}
	this.fn_CallTrans();

	//타이틀+상세 위로 올리기
	//this.cboListType.bringToPrev();
};


this.fn_setSearchArea = function(bFlag)
{
	this.edtSearch.visible = bFlag;
	this.btnSearch.visible = bFlag;
	this.btnFilterResize.visible = bFlag;
	//this.divSearch.visible = bFlag; //divSearch default false상태
	this.divResult.visible = bFlag;
	
	if (!bFlag) this.cboListType.set_top(0);
}

this.search_onload = function()
{
	nexacro.getApplication().gv_searchEngine = this;
	
	if (!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.param.keyword))
	{
		this.edtSearch.set_value(nexacro.getApplication().gv_mainFrame.param.keyword);
	}
	if (!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.param.page))
	{
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = nexacro.getApplication().gv_mainFrame.param.page;
	}
	
	// 새로고침이나 브라우저 히스토리 이동 시 각종 값이 초기화되지 않도록 저장
	var sData = nexacro.getApplication().gv_mainFrame.gfnGetHistoryData();
	
	if (!this.gfnIsNull(sData))
	{
		// 히스토리 sData에서 불러오기
		if (!this.gfnIsNull(sData.Chk_ALL)){	this.divSearch.form.Chk_ALL.set_value(sData.Chk_ALL); }
		if (!this.gfnIsNull(sData.Chk_NPN)){	this.divSearch.form.Chk_NPN.set_value(sData.Chk_NPN); }
		if (!this.gfnIsNull(sData.Chk_NP17)){	this.divSearch.form.Chk_NP17.set_value(sData.Chk_NP17); }
		if (!this.gfnIsNull(sData.Chk_NP14)){	this.divSearch.form.Chk_NP14.set_value(sData.Chk_NP14); }
		if (!this.gfnIsNull(sData.Chk_XP)){	this.divSearch.form.Chk_XP.set_value(sData.Chk_XP); }
		if (!this.gfnIsNull(sData.Chk_MP)){	this.divSearch.form.Chk_MP.set_value(sData.Chk_MP); }
		if (!this.gfnIsNull(sData.Chk_TDO)){	this.divSearch.form.Chk_TDO.set_value(sData.Chk_TDO); }		
		if (!this.gfnIsNull(sData.rdoField)){	this.divSearch.form.rdoField.set_value(sData.rdoField);
			this.searchfield = sData.rdoField; }
		if (!this.gfnIsNull(sData.rdoOperator)){	this.divSearch.form.rdoOperator.set_value(sData.rdoOperator);
			this.searchGubun = sData.rdoOperator;
			nexacro.getApplication().gv_mainFrame.QA_Cond_Searchgubun = sData.rdoOperator; }
		if (!this.gfnIsNull(sData.rdoTerm)){	this.divSearch.form.rdoTerm.set_value(sData.rdoTerm); }
		if (!this.gfnIsNull(sData.Chk_ALL)){	this.period = sData.rdoTerm; }
		if (!this.gfnIsNull(sData.calStart)){	this.divSearch.form.calStart.set_value(sData.calStart);
			this.fromDate = sData.calStart; }
		if (!this.gfnIsNull(sData.calEnd)){	this.divSearch.form.calEnd.set_value(sData.calEnd);
			this.toDate = sData.calEnd; }
		if (!this.gfnIsNull(sData.filterstatus)){nexacro.getApplication().gv_mainFrame.filterstatus = sData.filterstatus}else{nexacro.getApplication().gv_mainFrame.filterstatus="close"};
		if (!this.gfnIsNull(sData.QA_Tab_Index)){nexacro.getApplication().gv_mainFrame.QA_Tab_Index = sData.QA_Tab_Index};
	}
	// 키워드 셋팅
	if (!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.param.keyword))
	{
		 this.edtSearch.set_value(nexacro.getApplication().gv_mainFrame.param.keyword);
	}
	
	// 제품탭 설정
	if (!this.divSearch.form.Chk_NPN.value && !this.divSearch.form.Chk_NP17.value && !this.divSearch.form.Chk_NP14.value && !this.divSearch.form.Chk_XP.value && !this.divSearch.form.Chk_MP.value && !this.divSearch.form.Chk_TDO.value)
	{
		alert("선택한 제품이 없습니다.");
		return;
	}
	this.divResult.form.btn2.set_width(this.divSearch.form.Chk_NPN.value?186:0);
	this.divResult.form.btn3.set_width(this.divSearch.form.Chk_NP17.value?186:0);
	this.divResult.form.btn4.set_width(this.divSearch.form.Chk_NP14.value?186:0);
	this.divResult.form.btn5.set_width(this.divSearch.form.Chk_XP.value?186:0);
	this.divResult.form.btn6.set_width(this.divSearch.form.Chk_MP.value?186:0);
	this.divResult.form.btn7.set_width(this.divSearch.form.Chk_TDO.value?186:0);
	this.fn_setTabBtnVisible();
	
	this.divResult.form.resetScroll();

	nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, 1850);
};

//보이지 않는 Tab버튼 visible처리.
this.fn_setTabBtnVisible = function()
{
	// 버튼 width 0일경우 visible여부 처리 (접근성)
	var nCnt = this.divResult.form.components.length;
	for (var i = 1; i < nCnt; i++)
	{
		var nComp = this.divResult.form.components[i];
		if (nComp.width == 0) nComp.visible = false;
		else 				  nComp.visible = true;
	}	
}


this.fn_DetailCallBack = function (svcid, errCode, errMsg)
{
	var nIdx = 2;
	if (nexacro.getApplication().gv_mainFrame.tabCount > 0) 
	{
		nIdx = 3;
	}
	this.fn_indexChange(nIdx);
	// 화면 이동
	this.tabQnaExpr.set_tabindex(nIdx);
	// 수정시 설정
	this.tabQnaExpr.tabpg3.form.divInquireData.fn_InquireDetail(nexacro.getApplication().gv_mainFrame.QAStatus);
};


this.fn_InquireList = function (obj, e)
{
	this.fn_CallTrans();
};

this.fn_CallTrans = function ()
{	
	if (nexacro.getApplication().gv_mainFrame.PCategory2 == "QnA")
	{
		if (!this.gfnIsNull(nexacro.getApplication().gv_searchEngine.edtSearch.value))
		{
			this.ds_SearchParam.setColumn(0, "keyword", nexacro.getApplication().gv_searchEngine.edtSearch.value.trim());
			// 연관검색어 로딩
			nexacro.getApplication().gv_rightFrame.fn_relativeCallData(nexacro.getApplication().gv_searchEngine.edtSearch.value.trim());
		}
		else
		{
			this.ds_SearchParam.setColumn(0, "keyword", "");
		}
	}

	this.user_nm = nexacro.getApplication().gds_UserInfo.getColumn(0, "User_nm");
	this.tel_hp  = nexacro.getApplication().gds_UserInfo.getColumn(0, "Tel_hp");
	
	nexacro.getApplication().gds_MiWizard.clearData();
	nexacro.getApplication().com_AddMiWizard("","output","user_nm='" + this.user_nm +"'&tel_no='" + this.tel_hp + "'","SYSTEM,sys_findStaff,11");
	this.com_CallService("selectTobeUser", "", "", "ds_userInfo=output", "", "CS", false);		
	
	if( this.ds_userInfo.rowcount > 0 ) this.tobe_yn = true;
	
	//투비 직원인 경우 QC번호 그리드에 표현
// 	if( this.tobe_yn == false )
// 	{
// 		this.grdInquireList.setCellProperty("body", 10, "text", "");
// 	}
	
	
	// 검색조건
	// dispGubun : "MY" or 일반 검색
	// keyword : 현재 검색어
	// keywordall : 이전 검색어 두개를 같이 검색
	// PCategory2 : "nexacro", "MiPlatform", "XPLATFROM", "X-UP", "X-POP", "X-PUSH"
	// display_cnt : 화면에 나타내는 레코드 갯수
	// page : 현재 페이지
	// searchfield : 제목, 내용, 등록자, 번호
	// searchgubun : AND, OR
	// search_resort : 재질문
	// BusinessSection : 제품 분류
	// loginAcc : 로그인시의 접근인지 구분
	if (nexacro.getApplication().gv_mainFrame.PCategory2 == "MyQnAList") 
	{
	}
	if (this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition, "keyword") == undefined) 
	{
		this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition, "keyword", "");
	}
	this.keywordall = this.ds_SearchParam.getColumn(0, "keyword");

	
	this.ds_SearchParam.setColumn(0, "searchgubun", nexacro.getApplication().gv_mainFrame.QA_Cond_Searchgubun);
	this.ds_SearchParam.setColumn(0, "keywordall", this.keywordall);
	if( nexacro.getApplication().gv_mainFrame.PCategory2 == "QnA" && nexacro.getApplication().gv_mainFrame.QA_Cond_Prod == "All" )
	{
		this.PCategory = "";
		if( nexacro.getApplication().gv_searchEngine.divSearch.form.Chk_NPN.value ) this.PCategory += ",Nexacro N";
		if( nexacro.getApplication().gv_searchEngine.divSearch.form.Chk_NP17.value ) this.PCategory += ",nexacro platform17";
		if( nexacro.getApplication().gv_searchEngine.divSearch.form.Chk_NP14.value ) this.PCategory += ",nexacro platform14";
		if( nexacro.getApplication().gv_searchEngine.divSearch.form.Chk_XP.value ) this.PCategory += ",XPLATFORM";
		if( nexacro.getApplication().gv_searchEngine.divSearch.form.Chk_MP.value ) this.PCategory += ",MiPlatform";	
		if( nexacro.getApplication().gv_searchEngine.divSearch.form.Chk_TDO.value ) this.PCategory += ",TobeDevOps";	
		this.ds_SearchParam.setColumn(0, "PCategory2", this.PCategory.substr(1));
	}
	else if (nexacro.getApplication().gv_mainFrame.PCategory2 == "MyQnAList" && nexacro.getApplication().gv_mainFrame.QA_Cond_Prod != "NewBoard")
	{
		this.ds_SearchParam.setColumn(0, "PCategory2", nexacro.getApplication().gv_mainFrame.QA_Cond_Prod);
		this.ds_SearchParam.setColumn(0, "period", "전체");
		this.ds_SearchParam.setColumn(0, "fromDate", "");
		this.ds_SearchParam.setColumn(0, "toDate", "");
	}
	else
	{
		this.ds_SearchParam.setColumn(0, "PCategory2", nexacro.getApplication().gv_mainFrame.QA_Cond_Prod);
	}
	
	this.ds_SearchParam.setColumn(0, "display_cnt", this.divPageExpr.form.unitSelRowNo);
	this.ds_SearchParam.setColumn(0, "page", this.divPageExpr.form.startPageNo + 1);

	this.ds_SearchParam.setColumn(0, "loginAcc", "OFF");
	this.ds_SearchParam.setColumn(0, "User_id", nexacro.getApplication().gds_UserInfo.getColumn(nexacro.getApplication().gds_UserInfo.rowposition, "User_id"));
	// 조회조건 날짜 및 And, Or
	if (nexacro.getApplication().gv_mainFrame.PCategory2 == "QnA")
	{
		this.ds_SearchParam.setColumn(0, "period", nexacro.getApplication().gv_searchEngine.period);	
		this.ds_SearchParam.setColumn(0, "searchfield", nexacro.getApplication().gv_searchEngine.searchfield);	
		this.ds_SearchParam.setColumn(0, "fromDate", nexacro.getApplication().gv_searchEngine.divSearch.form.calStart.value);	
		this.ds_SearchParam.setColumn(0, "toDate", nexacro.getApplication().gv_searchEngine.divSearch.form.calEnd.value);
		if( this.gfnIsNull(nexacro.getApplication().gv_searchEngine.divSearch.form.calStart.value) ) this.ds_SearchParam.setColumn(0, "fromDate", "");
		if( this.gfnIsNull(nexacro.getApplication().gv_searchEngine.divSearch.form.calEnd.value) ) this.ds_SearchParam.setColumn(0, "toDate", "");
	}
	
	// 나의메뉴 > 북마크 일경우
	var nRow = nexacro.getApplication().gv_mainFrame.dsScreenUrl.findRow("subCatgy", nexacro.getApplication().gv_mainFrame.param.menu);
	var sLayout = nexacro.getApplication().gv_mainFrame.dsScreenUrl.getColumn(nRow, "Layout");
	if (sLayout == "BOOKMARK")
	{
		this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition,"bookMark", "OK");
		nexacro.getApplication().gds_SearchParam.setColumn(0,"bookMark", "OK");
		this.ds_SearchParam.setColumn(0, "period", "전체");
		this.ds_SearchParam.setColumn(0, "fromDate", "");	
		this.ds_SearchParam.setColumn(0, "toDate", "");
		this.ds_SearchParam.setColumn(0, "dispGubun", "MY");
		
		// PCategory2 : "nexacro", "MiPlatform", "XPLATFROM", "X-UP", "X-POP", "X-PUSH"
		var nTabIndex = nexacro.getApplication().gv_mainFrame.divMain.form.divBookmark.form.tabProduct.tabindex
		var sPCate = "";		
		// PCategoryGubun 셋팅
		switch(nTabIndex) {
		case 0:
			sPCate = "All";	// 전체		// ,Nexacro N,nexacro platform17,nexacro platform14,XPLATFORM,MiPlatform
			break;
		case 1:
			sPCate = "Nexacro N";	// N
			break;
		case 2:
			sPCate = "nexacro platform17";	// 17
			break;
		case 3:
			sPCate = "nexacro platform14";	// 14
			break;
		case 4:
			sPCate = "XPLATFORM";	// XP
			break;
		case 5:
			sPCate = "MiPlatform";	// MP
			break;
		case 7:
			sPCate = "TobeDevOps";	// MP
			break;				
		default:
		}
		this.ds_SearchParam.setColumn(0, "PCategory2", sPCate);
	}
	
	nexacro.getApplication().com_SetParam(this.ds_SearchParam);

	this.ds_hotlist.filter("");

	this.ds_hotlist.deleteAll();

	// 인수 설정
	var strArgs = "RTYPE=XML DB='CS' sessionChk=false nationCd='" + nexacro.getApplication().gv_NationCd + "' JSESSIONID='" + nexacro.getApplication().JSESSIONID + "'";
	var strUrl = "SVC_JSP::Next_JSP/Support/SearchQA_SSV.jsp?";
	var strDsInput = "input1=gds_SearchParam";
	var strDsOutput = "ds_hotlist=output";

	if (nexacro.getApplication().gv_mainFrame.PCategory2 == "MyQnAList" && nexacro.getApplication().gv_mainFrame.QA_Cond_Prod != "NewBoard") 
	{
		this.ds_SearchParam.setColumn(0, "dispGubun", "MY");
		nexacro.getApplication().gds_SearchParam.setColumn(0, "dispGubun", "MY");
		this.ds_SearchParam.setColumn(0, "period", "전체");
		this.ds_SearchParam.setColumn(0, "fromDate", "");	
		this.ds_SearchParam.setColumn(0, "toDate", "");
	}
	else if (nexacro.getApplication().gv_mainFrame.PCategory2 == "Bookmark")
	{
		nexacro.getApplication().gds_SearchParam.setColumn(0, "bookMark", "OK");
		this.ds_SearchParam.setColumn(0,"keyword","");
		this.keywordall = "";
	}
	
	if (nexacro.getApplication().gv_mainFrame.PCategory2 == "QnA")	// QnA리스트일 경우 제품 탭에 전체 건수 표시를 위해 조회
	{
		this.fn_getCount();
	}
	
	// PCategory2 ==> 제품
	// 북마크 조회조건

	if( nexacro.getApplication().gv_mainFrame.QA_Cond_Prod == "NewBoard"){
		var strBoardId = "%";
		strArgs = "RTYPE=XML DB='CS' sessionChk=false BoardID=" + strBoardId + " BoardID2=" + strBoardId +"Q" + " PCategoryGubun='%' nationCd=" +  nexacro.getApplication().gv_NationCd + "' JSESSIONID='"+nexacro.getApplication().JSESSIONID+"'";
		nexacro.getApplication().gds_SearchParam.setColumn(0, "dispGubun", null);
		nexacro.getApplication().gds_SearchParam.setColumn(0, "PCategory2", null);
		var strDsOutput = "ds_totalCnt=output1 ds_hotlist=output2";
		var strUrl = "SVC_JSP::Next_JSP/Board/SearchBoard_new3.jsp";
	} else {
		var strUrl = "SVC_JSP::Next_JSP/Support/SearchQA_SSV_new.jsp?";
	}	
	this.com_TransSend("selectList", strUrl, strDsInput, strDsOutput, strArgs, "fn_SelectListCallBack");
};

//  전체건수 가져오기 조회
this.condSQL = "";              
this.fn_getCount = function()
{
	var flag    = "";
	var sqlquery = "";
	var sqlquery1 = "";
	this.condSQL = "";
	var sqlkeyword = nexacro.getApplication().gv_searchEngine.edtSearch.value;
	var searchgubun = this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition, "searchgubun");
	if (this.gfnIsNull(sqlkeyword))
	{
		sqlkeyword = " ";
	}
	var strTemp = sqlkeyword.split(" ");
	// 재검색시 키워드 설정
	if (strTemp.length > 0) {
		sqlquery = " and (";
	}
	
	// 전체 검색 조건인 경우   
	if (this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition, "searchfield") == "100") {
		for (var i = 0; i < strTemp.length; i++) {
				//sqlquery += " SUBJECT like N''%" + strTemp[i] + "%'' or CONTENTS like N''%" + strTemp[i] + "%''";			
				sqlquery += " SUBJECT like N''%" + strTemp[i] + "%'' or CONTENTS_TEXT like N''%" + strTemp[i] + "%''";
			if (i == (strTemp.length - 1)) {
				sqlquery += " ) ";
			} else {
				sqlquery += " " + searchgubun + " ";
			}
		}
		this.condSQL += sqlquery;
	} else if (this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition, "searchfield") == "200") {
		for (var i = 0; i < strTemp.length; i++) {
				sqlquery += " SUBJECT like N''%" + strTemp[i] + "%''";			
			if (i == (strTemp.length - 1)) {
				sqlquery += " ) ";
			} else {
				sqlquery += " " + searchgubun + " ";
			}
		}
		this.condSQL += sqlquery;	
	} else if (this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition, "searchfield") == "300") {
		for (var i = 0; i < strTemp.length; i++) {
				//sqlquery += " CONTENTS like N''%" + strTemp[i] + "%''";			
				sqlquery += " CONTENTS_TEXT like N''%" + strTemp[i] + "%''";
			if (i == (strTemp.length - 1)) {
				sqlquery += " ) ";
			} else {
				sqlquery += " " + searchgubun + " ";
			}
		}
		this.condSQL += sqlquery;	
	}else if (this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition, "searchfield") == "600") {
		for (var i = 0; i < strTemp.length; i++) {
				sqlquery += " QL_SEQ like N''" + strTemp[i] + "''";			
			if (i == (strTemp.length - 1)) {
				sqlquery += " ) ";
			} else {
				sqlquery += " " + searchgubun + " ";
			}
		}
		this.condSQL += sqlquery;	
	}	
	
	if( !this.gfnIsNull(nexacro.getApplication().gv_searchEngine.divSearch.form.calStart.value) ){
		sqlquery1 = " AND CONVERT(VARCHAR(8), INSERT_DATE, 112) > ''" + this.gfnAddDate(nexacro.getApplication().gv_searchEngine.divSearch.form.calStart.value,-1) +"'' ";
		this.condSQL += sqlquery1;
	}

	if( !this.gfnIsNull(nexacro.getApplication().gv_searchEngine.divSearch.form.calEnd.value) ){
		sqlquery1 = " AND CONVERT(VARCHAR(8), INSERT_DATE, 112) < ''" + this.gfnAddDate(nexacro.getApplication().gv_searchEngine.divSearch.form.calEnd.value,1) +"'' ";
		this.condSQL += sqlquery1;
	}
	
	var args  = "";
	
	var args = "query='" + this.condSQL + "'";
	nexacro.getApplication().gds_MiWizard.clearData();	
	nexacro.getApplication().com_AddMiWizard("","output",args,"XPLATFORM,XP_STATUS,29");		
	this.com_CallService("selectCnt", "", "", "ds_cnt=output", "fn_SelectListCallBack", "CS", false);		
}


this.fn_SelectListCallBack = function (svcid, errCode, errMsg)
{
	//trace(this.ds_hotlist.saveXML());
	if (svcid == "selectList") 
	{
		//trace(this.ds_hotlist.saveXML());
		// 키워드강조하기
		if (!this.gfnIsNull(this.keywordall))
		{
			var sKeyWord = this.keywordall.replaceAll(" ", "|");
			var objRegExp = new RegExp('('+sKeyWord+')', 'gi');
			
			var sSubject;
			var sContents;
			
			//this.grdInquireList.set_enableredraw(false);
			this.ds_hotlist.set_enableevent(false);
			
			// 키워드강조하기
			if (!this.gfnIsNull(sKeyWord))
			{
				if (this.ds_SearchParam.getColumn(0, "searchfield") == 200)		// 제목만
				{
					for (var i = 0; i < this.ds_hotlist.rowcount; i++)
					{
						sSubject = this.ds_hotlist.getColumn(i, "SUBJECT");
						sSubject = sSubject.toString().replace(objRegExp, "<fc v='#ff0000'>"+"$&"+"</fc>");
						this.ds_hotlist.setColumn(i, "SUBJECT", sSubject);
					}
				}
				else if (this.ds_SearchParam.getColumn(0, "searchfield") == 300)	// 내용만
				{
					for (var i = 0; i < this.ds_hotlist.rowcount; i++)
					{
						sContents = this.ds_hotlist.getColumn(i, "CONTENTS");
						sContents = sContents.toString().replace(objRegExp, "<fc v='#ff0000'>"+"$&"+"</fc>");
						this.ds_hotlist.setColumn(i, "CONTENTS", sContents);
					}
				}
				else 																// 제목+내용
				{
					for (var i = 0; i < this.ds_hotlist.rowcount; i++)
					{
						sSubject = this.ds_hotlist.getColumn(i, "SUBJECT");
						sContents = this.ds_hotlist.getColumn(i, "CONTENTS");
						
						sSubject = sSubject.toString().replace(objRegExp, "<fc v='#ff0000'>"+"$&"+"</fc>");
						sContents = sContents.toString().replace(objRegExp, "<fc v='#ff0000'>"+"$&"+"</fc>");
						
						this.ds_hotlist.setColumn(i, "SUBJECT", sSubject);
						this.ds_hotlist.setColumn(i, "CONTENTS", sContents);
					}
				}
			}
			this.ds_hotlist.set_enableevent(true);
			//this.grdInquireList.set_enableredraw(true);
		}
		
		// 데이터가 있을경우
		this.ds_totalCnt.clearData();
		this.ds_totalCnt.addRow();
		this.ds_totalCnt.setColumn(0, "totalCnt", errMsg);
		this.divPageExpr.form.fn_PageInit(this.ds_hotlist, "", this, "fn_CallTrans()", "fn_SetInitSize()");

		if (this.ds_hotlist.rowcount > 0) 
		{
			if((nexacro.getApplication().gv_mainFrame.PCategory2 == "MyQnAList")||(nexacro.getApplication().gv_mainFrame.PCategory2 == "Bookmark")){
				this.TotalCnt = this.ds_hotlist.rowcount;
			}
			this.fn_setGridView(this.ds_hotlist);
			this.divPageExpr.form.serverRowCount = this.ds_hotlist.getRowCount();
			
			if (nexacro.getApplication().gv_mainFrame.PCategory2 == "QnA")	// QnA리스트일 경우 제품 탭에 전체 건수 표시를 위해 조회
			{
				// 선택된 탭 별로 다른 총건수 적용
				switch(nexacro.getApplication().gv_mainFrame.QA_Tab_Index) {
				case 0:
					this.divPageExpr.form.totalCount = this.fvTotalAll;
					break;
				case 1:
					this.divPageExpr.form.totalCount = this.fvTotalN;
					break;
				case 2:
					this.divPageExpr.form.totalCount = this.fvTotal17;
					break;
				case 3:
					this.divPageExpr.form.totalCount = this.fvTotal14;
					break;
				case 4:
					this.divPageExpr.form.totalCount = this.fvTotalXP;
					break;
				case 5:
					this.divPageExpr.form.totalCount = this.fvTotalMP;
					break;
				case 6:
					this.divPageExpr.form.totalCount = this.fvTotalTDO;
					break;							
				default:
				}
			}
			else
			{
				this.divPageExpr.form.totalCount = this.TotalCnt;
			}
			
			this.divPageExpr.form.set_visible(true);

			var iLastRow = this.divPageExpr.form.startPageNo * this.divPageExpr.form.unitSelRowNo;

			this.ds_hotlist.filter("rowNum >= " + (iLastRow + this.divPageExpr.form.startPageNo) + " && rowNum <= " + (iLastRow + this.divPageExpr.form.rowCount));

			this.divPageExpr.form.fn_SetPageNo();
			
			this.divPageExpr.form.fn_indexBtnSet(nexacro.toNumber(nexacro.getApplication().gv_mainFrame.QA_Cond_Page));
		}
		else 
		{
			var strMsg = "msg_nation1";
			if (nexacro.getApplication().gv_NationCd == "002") 
			{
				strMsg = "msg_nation2";
			}
			else if (nexacro.getApplication().gv_NationCd == "003") 
			{
				strMsg = "msg_nation3";
			}
			
			this.divPageExpr.form.fn_SetPageNo();
			this.divPageExpr.form.fn_indexBtnSet(nexacro.toNumber(nexacro.getApplication().gv_mainFrame.QA_Cond_Page));
			this.divPageExpr.form.set_visible(false);
			//this.grdInquireList.set_nodatatext(nexacro.getApplication().gds_MessageCd.lookup("msg_code_id", "MSG_000029", strMsg));
			//this.grdInquireList.set_height(100);
			this.divInquireList.text = nexacro.getApplication().gds_MessageCd.lookup("msg_code_id", "MSG_000029", strMsg);
			this.divInquireList.set_height(100);
		}
		// 저장된 스크롤 위치가 있으면 이동
		nexacro.getApplication().gv_mainFrame.vscrollbar.set_pos(nexacro.getApplication().gv_mainFrame.SCROLL_POS);
		nexacro.getApplication().gv_mainFrame.SCROLL_POS = 0;
	}
	else if (svcid == "selectCnt") 
	{
		var nNpN = this.fn_SetFormatNumber("NPN");
		var nNp17 = this.fn_SetFormatNumber("NP17");
		var nNp14 = this.fn_SetFormatNumber("NP14");
		var nXp	= this.fn_SetFormatNumber("XP");
		var nMp = this.fn_SetFormatNumber("MP");
		var nTdo = this.fn_SetFormatNumber("TDO");
		this.fvTotalN = nNpN;
		this.fvTotal17 = nNp17;
		this.fvTotal14 = nNp14;
		this.fvTotalXP = nXp;
		this.fvTotalMP = nMp;
		this.fvTotalTDO = nTdo;
		var nTotalAll = 0;

		nexacro.getApplication().gv_searchEngine.divResult.form.btn2.set_text("Nexacro N\n("+ nNpN +")");
		nexacro.getApplication().gv_searchEngine.divResult.form.btn3.set_text("nexacro 17\n("+ nNp17 +")");
		nexacro.getApplication().gv_searchEngine.divResult.form.btn4.set_text("nexacro 14\n("+ nNp14 +")");
		nexacro.getApplication().gv_searchEngine.divResult.form.btn5.set_text("XPLATFORM\n("+ nXp +")");
		nexacro.getApplication().gv_searchEngine.divResult.form.btn6.set_text("MiPlatform\n("+ nMp +")");
		nexacro.getApplication().gv_searchEngine.divResult.form.btn7.set_text("TobeDevOps\n("+ nTdo +")");
		if (nNpN == 0) { nexacro.getApplication().gv_searchEngine.divResult.form.btn2.set_enable(false); } else {nexacro.getApplication().gv_searchEngine.divResult.form.btn2.set_enable(true);}
		if (nNp17 == 0) { nexacro.getApplication().gv_searchEngine.divResult.form.btn3.set_enable(false); } else {nexacro.getApplication().gv_searchEngine.divResult.form.btn3.set_enable(true);}
		if (nNp14 == 0) { nexacro.getApplication().gv_searchEngine.divResult.form.btn4.set_enable(false); } else {nexacro.getApplication().gv_searchEngine.divResult.form.btn4.set_enable(true);}
		if (nXp == 0) { nexacro.getApplication().gv_searchEngine.divResult.form.btn5.set_enable(false); } else {nexacro.getApplication().gv_searchEngine.divResult.form.btn5.set_enable(true);}
		if (nMp == 0) { nexacro.getApplication().gv_searchEngine.divResult.form.btn6.set_enable(false); } else {nexacro.getApplication().gv_searchEngine.divResult.form.btn6.set_enable(true);}
		if (nTdo == 0) { nexacro.getApplication().gv_searchEngine.divResult.form.btn7.set_enable(false); } else {nexacro.getApplication().gv_searchEngine.divResult.form.btn7.set_enable(true);}
		nexacro.getApplication().gv_searchEngine.divResult.form.resetScroll();
		
		if (nexacro.getApplication().gv_searchEngine.divSearch.form.Chk_NPN.value)
		{	
			if(parseInt(nNpN) > 0)
			{
				nTotalAll += this.ds_cnt.lookup("PRODUCT_CODE","NPN","total_cnt");
			}
		}
		else 
		{
			nexacro.getApplication().gv_searchEngine.divResult.form.btn2.set_text("Nexacro N\n(0)");
		}
		if (nexacro.getApplication().gv_searchEngine.divSearch.form.Chk_NP17.value)
		{
			if(parseInt(nNp17) > 0)
			{
				nTotalAll += this.ds_cnt.lookup("PRODUCT_CODE","NP17","total_cnt"); 
			}
		}
		else {nexacro.getApplication().gv_searchEngine.divResult.form.btn3.set_text("nexacro 17\n(0)");}
		if (nexacro.getApplication().gv_searchEngine.divSearch.form.Chk_NP14.value)
		{
			if(parseInt(nNp14) > 0)
			{
				nTotalAll += this.ds_cnt.lookup("PRODUCT_CODE","NP14","total_cnt"); 
			}
		}
		else {nexacro.getApplication().gv_searchEngine.divResult.form.btn4.set_text("nexacro 14\n(0)");}
		if (nexacro.getApplication().gv_searchEngine.divSearch.form.Chk_XP.value)
		{
			if(parseInt(nXp) > 0)
			{
				nTotalAll += this.ds_cnt.lookup("PRODUCT_CODE","XP","total_cnt"); 
			}
		}
		else 
		{
			nexacro.getApplication().gv_searchEngine.divResult.form.btn5.set_text("XPLATFORM\n(0)");
		}
		if (nexacro.getApplication().gv_searchEngine.divSearch.form.Chk_MP.value)
		{
			if(parseInt(nMp) > 0)
			{
				nTotalAll += this.ds_cnt.lookup("PRODUCT_CODE","MP","total_cnt");
			}
		}
		else 
		{
			nexacro.getApplication().gv_searchEngine.divResult.form.btn6.set_text("MiPlatform\n(0)");
		}
		if (nexacro.getApplication().gv_searchEngine.divSearch.form.Chk_TDO.value)
		{
			if(parseInt(nTdo) > 0)
			{
				nTotalAll += this.ds_cnt.lookup("PRODUCT_CODE","TDO","total_cnt");
			}
		}
		else 
		{
			nexacro.getApplication().gv_searchEngine.divResult.form.btn7.set_text("TobeDevOps\n(0)");
		}		
		
		nTotalAll = this.fn_SetFormatNumber(nTotalAll);
		nexacro.getApplication().gv_searchEngine.divResult.form.btn1.set_text("전체\n("+ nTotalAll +")");
		if (nTotalAll == 0) 
		{
			nexacro.getApplication().gv_searchEngine.divResult.form.btn1.set_enable(false);
			nexacro.getApplication().gv_searchEngine.divResult.form.btn1.set_cssclass("btn_WF_resultTab");
			alert("검색된 데이터가 없습니다.");
		}
		else 
		{
			nexacro.getApplication().gv_searchEngine.divResult.form.btn1.set_enable(true);
		}
		

		var sKeyword = "";
		if (nexacro.getApplication().gv_mainFrame.PCategory2 == "QnA")
		{
			if (!this.gfnIsNull(nexacro.getApplication().gv_searchEngine.edtSearch.value))
			{
				sKeyword = nexacro.getApplication().gv_searchEngine.edtSearch.value;
			}
		}
		
		this.fvTotalAll = nTotalAll;
		// 전체건수 표시
		nexacro.getApplication().gv_searchEngine.divResult.form.btn1.set_text("전체\n("+ nTotalAll +")");
		
		// 건수 표시 완료 후 접근성label 적용.
		var nCnt = nexacro.getApplication().gv_searchEngine.divResult.form.components.length;
		for (var i = 1; i <= nCnt; i++)
		{
			var btn = nexacro.getApplication().gv_searchEngine.divResult.form.components["btn" + i];
			if (btn.cssclass == "btn_WF_resultTab_S") {
				btn.set_accessibilitylabel("선택");
			} else {
				btn.set_accessibilitylabel("링크");
			}
		}
	}	

	if(!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.filterstatus))
	{
		nexacro.getApplication().gv_searchEngine.fn_filterBFsize();
	}
};


//div 동적생성..
this.fn_createList = function()
{
	var nListType = nexacro.getApplication().gv_mainFrame.QA_Cond_ListType;
	var nRowCnt = this.ds_hotlist.rowcount;
	
	var nLeft 	= 0;
	var nTop 	= 0;
	var nHeight = nListType==0?226:141;
	var nWidth 	= 945;
	var sDivId 	= "divInquireList";
	var sUrl 	= nListType==0?"SUPPORT::frmTechInquireList_01_Default.xfdl":"SUPPORT::frmTechInquireList_02_Title.xfdl";
	
	var nLen = this.divInquireList.form.components.length;
	for (var i = nLen - 1; i >= 0; i--) {
		var objDel = this.divInquireList.removeChild(this.divInquireList.form.components[i].name);
		objDel.destroy();
		objDel = null;		
	}
	this.divInquireList.set_accessibilityenable(true);
	
	if (nRowCnt > 0) {
		this.divInquireList.set_accessibilityenable(false);
		this.divInquireList.set_text("");
		
		for (var i = 0; i < nRowCnt; i++) {
			var newDiv = new Div();
			newDiv.init(sDivId + i, nLeft, nTop, nWidth, nHeight);
			this.divInquireList.addChild(newDiv.id, newDiv);
			newDiv.set_url(sUrl);
			newDiv.set_accessibilityenable(false);
			newDiv.show();
			
			nTop = nTop + nHeight;
		}
		
		var lastDiv = this.divInquireList.form.components[sDivId + (nRowCnt-1)];
		
		this.divInquireList.set_height(lastDiv.getOffsetBottom());
		this.divPageExpr.set_top(this.divInquireList.getOffsetBottom() + 40);
		//this.viewPaging.set_top(this.divInquireList.getOffsetBottom() + 40);	
	}
};


