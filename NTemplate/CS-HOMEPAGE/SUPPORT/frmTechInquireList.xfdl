};

//처리상태 접근성 label 적용.
this.fn_statusAccessibility_Grid = function(sStatus,qc_no){

	if (sStatus.substr(0,1) == "P")
	{
		if (this.tobe_yn && !this.gfnIsNull(qc_no))
		{
			return "진행상태 처리중, qc번호 " + qc_no;
		}
		else
		{
			return "진행상태 처리중";
		}
	}
	else if (sStatus.substr(0,1) == "W" || sStatus.substr(0,1) == "A")
	{
		if (this.tobe_yn && !this.gfnIsNull(qc_no))
		{
			return "진행상태 접수, qc번호 " + qc_no;
		}
		else
		{
			return "진행상태 접수";
		}
	}
	else if (sStatus.substr(0,1) == "C")
	{
		if (this.tobe_yn && !this.gfnIsNull(qc_no))
		{
			return  "진행상태 답변완료, qc번호 " + qc_no;
		}
		else
		{
			return "진행상태 답변완료";
		}
	}
	else
	{
		return "";
	}
};



// expr : 그리드 처리시간 표시
this.fn_statusWait = function(sStatus,qc_no,WAIT_TIME,QL_SEQ)
{
	//trace( (new Date()).getTime());
	//기본 대기시간 표시
	if( (sStatus.substr(0,1)=='W'||sStatus.substr(0,1)=='A'||sStatus.substr(0,1)=='P') && this.gfnIsNull(qc_no) && !this.gfnIsNull(WAIT_TIME)){
		return "예상 대응시간 "+WAIT_TIME +" (시간)";
	} else if (sStatus.substr(0,1)=='C' && !this.gfnIsNull(qc_no) && !this.gfnIsNull(WAIT_TIME)){ //완료 + tops접수건
		if( WAIT_TIME > 24 ){			
			return "완료 대응시간 " + nexacro.round(WAIT_TIME/24) +" (일)";
		} else {
			return "완료 대응시간 " + WAIT_TIME +" (시간)";
		}
	//} else if (sStatus.substr(0,1)=='P' && !this.gfnIsNull(qc_no) && !this.gfnIsNull(WAIT_TIME)){ //처리중 + tops접수건
	} else if (sStatus.substr(0,1)=='P' && !this.gfnIsNull(qc_no)){ //처리중 + tops접수건
		return "예상 대응시간 보류";
	} else if(sStatus.substr(0,1)=='C' && !this.gfnIsNull(WAIT_TIME) && this.gfnIsNull(qc_no)) {
		if( WAIT_TIME > 24 ){			
			return "완료 대응시간 " + nexacro.round(WAIT_TIME/24) +" (일)";
		} else {
			return "완료 대응시간 " + WAIT_TIME +" (시간)";
		}
	} else if(sStatus.substr(0,1)=='P' && this.gfnIsNull(WAIT_TIME) ) {
		return "예상 대응시간 보류";
	}
	
}


