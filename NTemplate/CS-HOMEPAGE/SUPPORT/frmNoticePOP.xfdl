        <Static id="Static02" taborder="3" left="30" top="63" height="55" cssclass="sta_POP_title" width="540" text="[공지] 접수건 지원 안내"/>
        <TextArea id="TextArea00" taborder="4" left="30" top="155" cssclass="txt_POP_mainText" value="11월3일(목)~4일(금)은 워크샵 일정으로 인하여 설치건 중심의 기술지원만&#10;가능합니다.&#10;&#10;따라서 접수된 기술문의 접수 건은 11월7일(월요일)에 정상적으로 지원이&#10;가능하오니 업무에 참고하시기 바랍니다.&#10;&#10;감사합니다" readonly="true" width="540" wordWrap="char" scrollbartype="none auto" scrollbardecbuttonsize="0" scrollbarincbuttonsize="0" scrollbarsize="10" height="220" font="normal 400 16px/24px &quot;NotoSansKR&quot;" onchanged="TextArea00_onchanged" initvalueid="iv_TextArea_Readonly"/>
        <Static id="Static01" taborder="5" left="0" width="600" top="398" cssclass="sta_POP_foot" accessibilityenable="false" height="42"/>
        <CheckBox id="CheckBox00" taborder="6" text="오늘 하루 이 창을 띄우지 않음" left="20" top="406" width="190" height="25" onclick="CheckBox00_onclick" cssclass="check_POP_notToday" value="false" tabstop="true" initvalueid="iv_CheckBox0"/>
        <Button id="Button00" taborder="7" text="닫기" top="406" width="55" height="25" cssclass="btn_POP_close" left="525" onclick="Button00_onclick"/>
        <Button id="Button00_00" taborder="8" top="0" width="40" height="40" right="0" cssclass="btn_POP_CloseIcon" accessibilitylabel="닫기" onclick="Button00_onclick"/>
      </Layout>
    </Layouts>
    <Objects/>
    <Script type="xscript5.1"><![CDATA[
this.CheckBox00_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	nexacro.setPrivateProfile("mTodayPop0",this.gfnGetDate());
	//this.close();
};

this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
