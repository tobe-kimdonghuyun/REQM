    <Bind/>
    <Script type="xscript5.1"><![CDATA[/**
*  교육신청
*
*  @MenuPath 
*  @FileName 		EDUCATION::frmEduRegistration.xfdl 
*  @Creator 		김광호
*  @CreateDate 		2022.01.01
*  @LastModifier  
*  @LastModifyDate  
*  @Version 		1.0
*  @Outline 		교육신청
*  @Desction 
************** 소스 수정 이력 *************************************************
*    date          Modifier            Description
*******************************************************************************
*  2022.01.01      김광호	           최초 생성 
*******************************************************************************
*/

this.sFormType = "frmEduRegistration";
this.pageMoveCd = 0;		//제품 탭 값을 담을 변수
this.ErrorEsSeq = "";
 

this.frmEduRegistration_onload = function(obj:Form, e:nexacro.LoadEventInfo)
{
	// 공통측에서 요청한 내용임 : 프레임 사이즈가 다른 화면에 갔다오면 변경되어
	// 문자가 깨질수 있으므로 초기화 해달라고함
	this.set_height(1950);      		
	this.parent.set_height(1950);            
	nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, 1790);
	
	//로그인 여부 체크   
	if(nexacro.getApplication().gds_UserInfo.getRowCount() <= 0)
 	{
 		nexacro.getApplication().gv_mainFrame.TargetUrl = nexacro.getApplication().gv_mainFrame.PCategory2;
		nexacro.getApplication().gv_mainFrame.param = {
			'menu': "login",
			'keyword': "",
			'page': 1,
			'postId': ""
			};
		nexacro.getApplication().gv_mainFrame.gfnGoMain();
		return;
 	}

	//로그인 사용자 정보Get
	var sUserNm   = nexacro.getApplication().gds_UserInfo.getColumn(0, "User_nm");		//성명
	var sTelhp    = nexacro.getApplication().gds_UserInfo.getColumn(0, "Tel_hp");		//전화번호
	var sEmail    = nexacro.getApplication().gds_UserInfo.getColumn(0, "Email_id");		//이메일
	var sCompNm   = nexacro.getApplication().gds_UserInfo.getColumn(0, "Comp_nm");		//회사명
	var sDept     = nexacro.getApplication().gds_UserInfo.getColumn(0, "Comp_dept");		//부서명
	
	if(!this.gfnIsNull(sTelhp)){
		sTelhp = nexacro.replaceAll(sTelhp, "-", "");
	}
	

	//로그인 사용자 정보Set
	this.mskPhoneNo.set_value(sTelhp);
	this.edtEmail.set_value(sEmail);
	this.edtCompanyName.set_value(sCompNm);
	this.edtDeptName.set_value(sDept);
	this.edtName.set_value(sUserNm);

	this.fn_EduScheduleList();	//교육회차

	//페이지 이동 전 제품 탭 확인   
	this.pageMoveCd = nexacro.getApplication().gv_prodMoveCd;
	
	//접수현황에서 수정을 클릭해서 들어온 경우 신청하기 버튼 텍스트 수정으로 변경
	if(!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.param.postId)){	
		this.btnFlagSave.set_text("수정하기");
	}else{
		nexacro.getApplication().gv_prodMoveCd = 0;			//제품 탭 초기화
	}
	
	this.fn_LeftBottomMessage();
	this.tabProduct.set_tabindex(this.pageMoveCd);		//해당 제품 교육회차를 불러오기 위한 탭 이동 이벤트

	this.divKocham.set_visible(false);
	this.btnFlagSave.set_text("신청하기");         
		
}

//교육 회차 조회
this.fn_EduScheduleList = function() 
{

	// 인수 설정 
	var strArgs = "RTYPE=XML DB='CS'"
	            + " sessionChk=false"
	            + " nationCd='"    + nexacro.getApplication().gv_NationCd + "'"
	            + " JSESSIONID='"  + nexacro.getApplication().JSESSIONID  + "'"
	            + " sFormType='"   + this.sFormType          + "'";
//테스트서버
	var strUrl = "SVC_JSP::Next_JSP/Education/SearchEduSchedule.jsp?";
	var strDsInput = "";
	var strDsOutput = "ds_ScheduleList=output1";  

	this.com_TransSend("ScheduleList",strUrl,strDsInput,strDsOutput,strArgs,"fn_CallBack");
}

//로그인 아이디로 신청되어있는 리스트 조회
this.fn_EduRegList = function() 
{
	// 인수 설정 
	var sUserId = nexacro.getApplication().gds_UserInfo.getColumn(0, "User_id");
	var strArgs = "RTYPE=XML DB='CS'"
	            + " sessionChk=false"
	            + " nationCd='"    + nexacro.getApplication().gv_NationCd + "'"
	            + " JSESSIONID='"  + nexacro.getApplication().JSESSIONID  + "'"
	            + " sUserId='"     + sUserId                 + "'";

//테스트서버
	var strUrl = "SVC_JSP::Next_JSP/Education/SearchEduReg.jsp?";
	var strDsInput = "";
	var strDsOutput = "ds_EduRegList=output1";  

	this.com_TransSend("EduRegList",strUrl,strDsInput,strDsOutput,strArgs,"fn_CallBack");
}



//콜백함수
this.fn_CallBack = function (svcid,errCode,errMsg)
{
	
	if(errCode < 0){
		this.alert("신청하신 " + this.ErrorEsSeq + " 회차에 최대 수강인원을 초과하였습니다.");
		  
		//수강인원 초과의 경우 해당 제품 체크 해제
		this.ds_ScheduleList.setColumn(this.ds_ScheduleList.findRow("ES_SEQ",this.ErrorEsSeq),"CHK",0);
		this.ds_ScheduleList.setColumn(this.ds_ScheduleList.findRow("ES_SEQ",this.ErrorEsSeq),"CHK_ON",0);
		this.ds_Registration.clearData();
		return;
	}   
	
	if (svcid == "ScheduleList") 
	{
		if(this.ds_ScheduleList.rowcount > 0)
		{
			//신청가능한 교육 일정만 조회될수 있게 
			var sProd = "";
			switch(this.tabProduct.tabindex) {
			case 0:
				sProd = "NPN";
				break;
			case 1:
				sProd = "NP17";
				break;
			case 2:
				sProd = "NP14";
				break;
			case 3:
				sProd = "XP";
				break;
			default:
			}   
			this.ds_ScheduleList.filter("EDU_PRODUCT_CODE == '" + sProd + "'");
			this.ds_ScheduleList.set_keystring("S:-EDU_METHOD+EDU_TYPE_DET+START_DATE");		
			
			var nHead = this.Grid01.getRealRowFullSize("head");
			var nRow  = this.Grid01.getRealRowFullSize("body");			
			this.Grid01.set_height(nHead + nRow + 1);
			nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, nHead + nRow + 900);
			  
				    
			//this.set_height(nHead + nRow + 1000);   
			
			//this.parent.set_height(nHead + nRow + 1500);
			//this.parent.parent.parent.set_height(nHead + nRow + 2000);
			//this.parent.parent.parent.resetScroll();         
			//alert("5==" + this.height + "===" + this.parent.height + "--" +  this.parent.parent.height);    
			
			//alert(this.name + ":" + this.parent.name + ":" + this.parent.parent.name + ":" + this.parent.parent.parent.name);
			//alert(nHead + nRow + 1000); 
			      
			
			  
		}
		this.fn_notice(sProd);
		this.ds_ScheduleList.addColumn("EX_FLAG","string");
		this.fn_EduRegList();		//등록현황목록 
		
		
	}	
 	else if(svcid == "saveStudentInfo")
 	{	
		
		if(!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.param.postId)){	//접수현황에서 수정을 통해 들어왔는지 체크
			this.alert("수정이 완료되었습니다");
			//접수현황 메뉴 이동
			nexacro.getApplication().gv_mainFrame.param = {
				'menu': "Education_Condition",
				'keyword': "",
				'page': 1,
				'postId': ""
				};
			nexacro.getApplication().gv_mainFrame.gfnGoMain();
		}else{
			this.alert("교육이 정상적으로 신청되었습니다.");
			//접수현황 메뉴 이동	
			nexacro.getApplication().gv_mainFrame.param = {
				'menu': "Education_Condition",
				'keyword': "",
				'page': 1,
				'postId': ""
				};
			nexacro.getApplication().gv_mainFrame.gfnGoMain();
		}
		
		
 	}
	else if(svcid == "EduRegList"){
		
		//접수현황에서 수정을 통해 들어온 경우 우측 신청내용을 불러옴
		if(!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.param.postId)){	
			this.fn_EduCheck();
		}

		//접수 현황 내역을 불러와서 이미 신청한 교육은 체크 못하도록 막음
		for(var i=0;i<this.ds_EduRegList.getRowCountNF();i++){
			//var nCheckEdu = this.ds_ScheduleList.findRowNF("ES_SEQ",this.ds_EduRegList.getColumn(i,"ES_SEQ"));
			var nCheckEdu = this.ds_ScheduleList.findRowExprNF("EDU_PRODUCT_CODE == '" + this.ds_EduRegList.getColumn(i,"EDU_PRODUCT_CODE") + "' &&   ES_SEQ == '" + this.ds_EduRegList.getColumn(i,"ES_SEQ") + '"');
			   
			//접수현황에서 수정을 통해 들어온 경우 해당 회차는 수정가능하도록 변경

			if(nCheckEdu != -1&&nexacro.getApplication().gv_mainFrame.param.postId ==this.ds_EduRegList.getColumn(i,"ES_SEQ")){
				var mStatusCd = this.ds_EduRegList.getColumn(i, "STATUS_CD");
				
				//온라인 오프라인 여부 확인
				if(mStatusCd =='1'){
					this.ds_ScheduleList.setColumnNF(nCheckEdu,"CHK",1)
				}else if(mStatusCd == '7'){
					this.ds_ScheduleList.setColumnNF(nCheckEdu,"CHK_ON",1)
				}
				
				//접수여부를 체크하기 위한 컬럼 추가
				this.ds_ScheduleList.addColumn("EX_FLAG","string");
				this.ds_ScheduleList.setColumnNF(nCheckEdu,"EX_FLAG","N");
				this.ds_ScheduleList.addColumn("STATUS_CD","string");
				this.ds_ScheduleList.setColumnNF(nCheckEdu,"STATUS_CD",this.ds_EduRegList.getColumn(i,"STATUS_CD"));
				
			}else if(nCheckEdu != -1){
				var mStatusCd = this.ds_EduRegList.getColumn(i, "STATUS_CD");
				
				//온라인 오프라인 여부 확인
				if(mStatusCd =='1'){
					this.ds_ScheduleList.setColumnNF(nCheckEdu,"CHK",1)
				}else if(mStatusCd == '7'){
					this.ds_ScheduleList.setColumnNF(nCheckEdu,"CHK_ON",1)
				}

				//접수여부를 체크하기 위한 컬럼 추가   
				this.ds_ScheduleList.addColumn("EX_FLAG","string");  
				this.ds_ScheduleList.setColumnNF(nCheckEdu,"EX_FLAG","Y");
				this.ds_ScheduleList.addColumn("STATUS_CD","string");
				this.ds_ScheduleList.setColumnNF(nCheckEdu,"STATUS_CD",this.ds_EduRegList.getColumn(i,"STATUS_CD"));
			}
		}
		//교육일정에서 저장한 교육번호 확인 후 체크박스 체크
		if(!this.gfnIsNull(nexacro.getApplication().gv_ApplyEduSEQ)){
			var nCheckRow = this.ds_ScheduleList.findRow("ES_SEQ",nexacro.getApplication().gv_ApplyEduSEQ);
			if(this.ds_ScheduleList.getColumn(nCheckRow,"ICOUNT")<this.ds_ScheduleList.getColumn(nCheckRow,"ONLINE_NUM")){
				this.ds_ScheduleList.setColumn(nCheckRow , "CHK",1);
			} //else{this.ds_ScheduleList.setColumn(nCheckRow , "CHK_ON",1)};  온라인 교육 진행되면 활성화
			nexacro.getApplication().gv_ApplyEduSEQ = "";		//체크 후 변수 초기화
		}
		
		//이전 수강 신청 내용제거
		var mDate = new nexacro.Date();
		mDate = mDate.toString().substr(0,8);
		var mDateOverEdu = [];
		for(var i = 0;i<this.ds_EduRegList.getRowCount();i++){
			if(mDate>this.ds_EduRegList.getColumn(i,"END_DATE")){
				mDateOverEdu.push(i);
			}
		}
		this.ds_EduRegList.deleteMultiRows(mDateOverEdu);
		
		
	}else if(svcid == "EduRegCancel"){
		//수정을 통해 해당 교육을 체크 해제해서 신청된 교육이 없는경우
		if(this.ds_ScheduleList.findRowExprNF("CHK==1||CHK_ON==1")==-1){
			alert("교육신청이 취소되었습니다.");
			//접수현황 메뉴 이동	
			nexacro.getApplication().gv_mainFrame.param = {
				'menu': "Education_Condition",
				'keyword': "",
				'page': 1,
				'postId': ""
				};
			nexacro.getApplication().gv_mainFrame.gfnGoMain();
		}
	}
}

//상단 제품 선택시 데이터 필터(NP17, NP, XP)
this.tabProduct_onchanged = function(obj:nexacro.Tab,e:nexacro.TabIndexChangeEventInfo)
{
	var sProd = "";
	switch(e.postindex) {
	case 0:
		sProd = "NPN";
		break;
	case 1:
		sProd = "NP17";
		break;
	case 2:
		sProd = "NP14";
		break;
	case 3:
		sProd = "XP";
		break;
	default:
	}
	
	this.pageMoveCd = e.postindex;
	this.ds_ScheduleList.filter("");
	this.ds_ScheduleList.filter("EDU_PRODUCT_CODE == '" + sProd + "' && ONLINE_NUM > ICOUNT");
	
	var nHead = this.Grid01.getRealRowFullSize("head");
	var nRow  = this.Grid01.getRealRowFullSize("body");	
	this.Grid01.set_height(nHead + nRow + 1);

  
	this.fn_notice(sProd);

}  



