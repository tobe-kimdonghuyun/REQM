this.ds_ScheduleList_cancolumnchange = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{


	var icnt = this.ds_ScheduleList.getCaseCount( 'KORCHAM_FLAG == "1" && CHK == "1" && currow != "' +  e.row + '"');
	
   
	if(icnt > 0 )    
	{
		this.alert("대한상공회의소 교육과정은 포함된 경우 복수 신청은 지원되지 않습니다.");
		this.divKocham.set_visible(true);
		this.btnFlagSave.set_text("페이지 이동"); 
		return false;
	}
	
	var icnt = this.ds_ScheduleList.getCaseCount( 'KORCHAM_FLAG != "1" && CHK == "1" && currow != "' +  e.row + '"');
   
	if(icnt > 0 )    
	{          
		if(this.ds_ScheduleList.getColumn(e.row,"KORCHAM_FLAG") == "1" && e.newvalue == "1")
		{
			this.alert("대한상공회의소 교육과정은 포함된 경우 복수 신청은 지원되지 않습니다.");
			this.divKocham.set_visible(false);
			this.btnFlagSave.set_text("신청하기");     
			return false;  
		}	
	}
	 
};

this.ds_ScheduleList_oncolumnchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	if(this.ds_ScheduleList.getColumn(e.row,"KORCHAM_FLAG") == "1" && this.ds_ScheduleList.getColumn(e.row,"CHK") == "1" ) 
	{    
		this.divKocham.set_visible(true);
		this.btnFlagSave.set_text("페이지 이동"); 

	} else {    
		this.divKocham.set_visible(false);
		this.btnFlagSave.set_text("신청하기");          
	}	
};
