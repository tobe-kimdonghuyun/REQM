//신청 버튼 클릭
this.btnFlagSave_onclick = function(obj:Button, e:nexacro.ClickEventInfo)
{

	var iKoCnt  = this.ds_ScheduleList.getCaseCount("CHK == '1' && KORCHAM_FLAG == '1' "); 
	var iNoCnt  = this.ds_ScheduleList.getCaseCount("CHK == '1' && KORCHAM_FLAG != '1' "); 
 
	if((iKoCnt  > 1))
	{   
		alert("대한상공회의소 교육은 복수 선택을 허용하지 않습니다.");
		return; 
	} else if((iKoCnt  >= 1) && (iNoCnt >= 1))
	{   
		alert("대한상공회의소 교육은 복수 선택을 허용하지 않습니다.");
		return; 
	} else if((iKoCnt == 1) && (iNoCnt == 0))
	{
		var iFindRow = this.ds_ScheduleList.findRowExpr("CHK == '1' && KORCHAM_FLAG == '1'"); 
		this.ds_ScheduleList.set_rowposition(iFindRow); 		
		alert("대한상공회의소 페이지로 이동합니다.");      
		system.execDefaultBrowser("https://www.kccistc.net:8443/education/improvementEduDetail.do?rootMenuId=4919&menuId=4920&gaebalwon_cd=09000&mcourse_no=" + this.ds_ScheduleList.getColumn(iFindRow,"KORCHAM_CODE")+ "&callFlag=YEAR&bunryu=1,3,8"); 
		return;
				  
	} 
	
	//다음 페이지에서 제품 탭 변경을 위한 변수 저장
	nexacro.getApplication().gv_prodMoveCd = this.pageMoveCd;
	
	//수정 교육 번호 확인
	var mUpdateId = nexacro.getApplication().gv_mainFrame.param.postId;
	var mUpdateRow = this.ds_ScheduleList.findRow("ES_SEQ",mUpdateId);
	
	//필수입력체크
	if(this.fn_CheckData() == false) return;

	if(this.ds_ScheduleList.findRowExprNF('(CHK == "1" || CHK_ON=="1") && EX_FLAG != "Y"') < 0){
		if(!this.gfnIsNull(mUpdateId)){
			//수정을 통해 들어와서 신청한 교육 없이 해당 회차를 체크 해제한 경우 수강 취소 확인
			if(nexacro.getApplication().com_ConfirmMessage("MSG_000105", false)){
				this.fn_CallTransDelete(mUpdateId);
			}else{
				return false;
			}
		}else{
			this.alert("과정을 선택하시기 바랍니다.");
			return;
		}
	}
	
	for(var i = 0; i<this.ds_ScheduleList.getRowCount();i++){
	
		if((this.ds_ScheduleList.getColumn(i, "CHK")==1||this.ds_ScheduleList.getColumn(i, "CHK_ON")==1)&&this.gfnIsNull(this.ds_ScheduleList.getColumn(i,"EX_FLAG"))){
			var sProd       = this.ds_ScheduleList.getColumn(i, "EDU_PRODUCT_CODE");
			var sEsSeq      = this.ds_ScheduleList.getColumn(i, "ES_SEQ");
			var sEduTypeDet = this.ds_ScheduleList.getColumn(i, "EDU_TYPE_DET");
			var sEduDate    = this.ds_ScheduleList.getColumn(i, "START_DATE");
			var sOverlapDate = sEduDate.substring(0,4)+"년"+sEduDate.substring(4,6)+"월"+sEduDate.substring(6,8)+"일";
			var sEduTypeDetName = this.ds_ScheduleList.getColumn(i, "EDU_TYPE_DET_NAME");
			var nCnt = -1;
			

			//0. 같은 일정에 다른 과정 선택 불가(개발 , 디자인 동시 신청 불가)
			nCnt = this.ds_ScheduleList.findRowExpr("START_DATE =='" + sEduDate + "' && (CHK =='1'||CHK_ON=='1')&& currow != " + i);
			if(nCnt > -1){
				if(this.ds_ScheduleList.getColumn(nCnt,"EX_FLAG")=='N'){		//수정인 경우 예외처리
				}else{
					this.alert(sOverlapDate+" 일정에 다른 과정이 이미 선택되어 있습니다.");
					return false;
				}
			}

			//0-1. 같은 일정에 다른 과정 선택 불가(개발 , 디자인 동시 신청 불가)
			 nCnt = this.ds_EduRegList.findRowExpr("DONE_FLAG == 'UNDONE' && START_DATE >='" + sEduDate + "' && END_DATE <= '" + sEduDate + "'");
			 if(nCnt > -1){
				if(!this.gfnIsNull(mUpdateId)&&sEsSeq==mUpdateId){
					if((this.ds_ScheduleList.getColumn(mUpdateRow,"CHK")==1||this.ds_ScheduleList.getColumn(mUpdateRow,"CHK_ON")==1)&&this.ds_ScheduleList.getColumn(mUpdateRow,"EX_FLAG")=="N"){
					}
				}else{
					this.alert(sOverlapDate+" 일정에 다른 과정이 이미 등록되어 있습니다.");
					return false;
				}
			 }
			//1. 스케줄에서 과정을 선택하고 다른 일자에 똑같은 과정을 또 선택했을때 체크
			nCnt = this.ds_ScheduleList.findRowExpr("EDU_PRODUCT_CODE =='" + sProd + "' && EDU_TYPE_DET == '" + sEduTypeDet + "' && (CHK =='1'||CHK_ON =='1') && currow != " + i);
			if(nCnt > -1){
				if(!this.gfnIsNull(mUpdateId)&&sEsSeq==mUpdateId){
				}else if(this.ds_ScheduleList.getColumn(i,"STATUS_CD")!=this.ds_EduRegList.getColumn(mUpdateRow,"STATUS_CD")){
				}else{
					this.alert("'"+sEduTypeDetName+"'과 동일한 과정이 이미 선택되어 있습니다.");
					return false;
				}
				
			}
	
			//2. 이미 신청된 과정을 또 선택했을때 체크
			//DONE_FLAG 컬럼은 신청일 기준으로 이전 날짜는 'UNDONE'(종료된과정), 이후 날짜는 'DONE'(진행중과정)을 의미
			 nCnt = this.ds_EduRegList.findRowExpr("DONE_FLAG == 'UNDONE' && EDU_PRODUCT_CODE =='" + sProd + "' && ES_SEQ == " + sEsSeq);
			 if(nCnt > -1){
			 
				if(!this.gfnIsNull(mUpdateId)&&sEsSeq==mUpdateId){
				}else{
					this.alert("'"+sEduTypeDetName+"'는 이미 신청하신 교육과정 입니다.");
					return false;
				}
				
			 }
				 
			 //3. 이미 신청된 과정을 다른 일자로 선택했을때 체크
			 nCnt = this.ds_EduRegList.findRowExprNF("DONE_FLAG == 'UNDONE' && EDU_PRODUCT_CODE =='" + sProd + "' && EDU_TYPE_DET == '" + sEduTypeDet + "'");
			 var sRegDate = this.ds_EduRegList.getColumn(nCnt, "START_DATE");
			 this.cal_dateformat.set_value(sRegDate);
			 if(nCnt > -1){
				if(!this.gfnIsNull(mUpdateId)&&sEsSeq==mUpdateId){
				
				
				}else if((this.ds_ScheduleList.getColumn(mUpdateRow,"CHK")!=1&&this.ds_ScheduleList.getColumn(mUpdateRow,"CHK_ON")!=1)&&this.ds_ScheduleList.getColumn(mUpdateRow,"EX_FLAG")=="N"){
					
				}else{
					this.alert(this.cal_dateformat.text + " 에 동일 과정이 신청되어 있습니다. \r\n해당일에 신청하신 교육을 취소하고 다시 신청하시기 바랍니다.");
					return false;
				}
				
			 }
		}
		
	}
	//교육수정 & 신청
	if(!this.gfnIsNull(mUpdateId)){
		this.fn_CallTransDelete(mUpdateId)
	}
	this.fn_setDs();
	this.fn_CallTransSave();	
}

//서버로 전송할 Data Set
this.fn_setDs = function()
{
	var sUserId = nexacro.getApplication().gds_UserInfo.getColumn(0, "User_id");
	if(sUserId == null || nexacro.getApplication().com_IsEmpty(nexacro.trim(sUserId))){
		this.alert("user id check");
		return;
	}
	for(var i=0; i< this.ds_ScheduleList.getRowCountNF(); i++)
	{
		if((this.ds_ScheduleList.getColumnNF(i, "CHK") == "1"||this.ds_ScheduleList.getColumnNF(i, "CHK_ON") == "1")&&this.ds_ScheduleList.getColumnNF(i,"EX_FLAG")!='Y'){
			var nRow = this.ds_Registration.addRow();
			this.ds_Registration.setColumn(nRow, "EDU_PRODUCT_CODE", this.ds_ScheduleList.getColumnNF(i, "EDU_PRODUCT_CODE"));
			this.ds_Registration.setColumn(nRow, "ES_SEQ"          , this.ds_ScheduleList.getColumnNF(i, "ES_SEQ"));
			this.ds_Registration.setColumn(nRow, "COMPANY_NAME"    , this.edtCompanyName.value);
			this.ds_Registration.setColumn(nRow, "DEPT_NAME"       , this.edtDeptName.value);
			this.ds_Registration.setColumn(nRow, "EMP_NAME"       , this.edtName.value);
			this.ds_Registration.setColumn(nRow, "PHONE_NO"        , this.mskPhoneNo.value);
			this.ds_Registration.setColumn(nRow, "EMAIL"           , this.edtEmail.value);
			if(this.ds_ScheduleList.getColumnNF(i, "CHK") == "1"){
				this.ds_Registration.setColumn(nRow, "STATUS_CD"       , "1");	//신청
			}else if(this.ds_ScheduleList.getColumnNF(i, "CHK_ON") == "1"){
				this.ds_Registration.setColumn(nRow, "STATUS_CD"       , "7");	//온라인 신청
			}
			this.ds_Registration.setColumn(nRow, "REQ_REASON"      , this.rdoReqReason.value);
			if(this.rdoReqReason.value==3){   //신청동기가 '기타'가 아니면 텍스트 내용을 저장하지 않음
				this.ds_Registration.setColumn(nRow, "REQ_REASON_ETC"  , this.edtReqReasonEtc.value);
			}
			this.ds_Registration.setColumn(nRow, "QUESTION"        , this.txaQuestion.value);
		}
	}
}

//기본 정보 저장
this.fn_CallTransSave = function() 
{		
	// 인수 설정 
	var strArgs = "RTYPE=XML DB='CS'"
	            + " sessionChk=false"
	            + " nationCd='"   + nexacro.getApplication().gv_NationCd + "'"
	            + " JSESSIONID='" + nexacro.getApplication().JSESSIONID + "'"
	            + " sUserId='" + nexacro.getApplication().gds_UserInfo.getColumn(0, "User_id") + "'"
	            + " sSaveType='I'"
//테스트 서버	
	var strUrl = "SVC_JSP::Next_JSP/Education/SaveRegistration.jsp?"; 
	var strDsInput = "input=ds_Registration";
	var strDsOutput = "";

	this.transaction("saveStudentInfo",strUrl,strDsInput,strDsOutput,strArgs,"fn_CallBack");
}
   

//필수입력체크
this.fn_CheckData = function() 
{
 	if(this.edtName.value == null || nexacro.getApplication().com_IsEmpty(nexacro.trim(this.edtName.value))) {
 		this.alert("이름을 입력해주세요."); 
 		this.edtName.setFocus();
		nexacro.getApplication().gv_mainFrame.vscrollbar.set_pos(this.Static00_00_01_02.getOffsetTop()+20);
 		return false;
 	}		
	if((nexacro.getApplication().com_IsEmpty(this.mskPhoneNo.value) || this.mskPhoneNo.value == "" )){
		this.alert("연락처를 입력해주세요.");
		this.mskPhoneNo.setFocus();
		nexacro.getApplication().gv_mainFrame.vscrollbar.set_pos(this.Static00_00_01.getOffsetTop()+20);
		return false;
	}
	if (this.edtEmail.value == null || nexacro.getApplication().com_IsEmpty(nexacro.trim(this.edtEmail.value))){
		this.alert("이메일을 입력해주세요.");
		this.edtEmail.setFocus();
		nexacro.getApplication().gv_mainFrame.vscrollbar.set_pos(this.Static00_00_01_01.getOffsetTop()+20);
		return false;
	}
	else{
		var nIndexOfDot = this.edtEmail.value.indexOf("."); 
		var nLength = this.edtEmail.value.length; 
		
		if(nIndexOfDot == 0 || nIndexOfDot == -1  || nIndexOfDot+1 == nLength || this.edtEmail.value.indexOf(" ") != -1){
			this.alert("이메일 형식을 확인해주세요.");
			this.edtEmail.setFocus();
			return false;
		}			
	}
	return true;
	
}

//신청동기 변경 이벤트
this.rdoReqReason_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	var mRdoReqReason = this.rdoReqReason.value;
	if(this.rdoReqReason.value == "3"){ 			//신청동기가 '기타'일 경우에만 텍스트박스 활성화
		this.edtReqReasonEtc.set_enable(true);
	}else{
		this.edtReqReasonEtc.set_enable(false);
	}
};

//접수내용을 통해 우측 신청내용 자동완성
this.fn_EduCheck = function()
{
	//수정을 선택한 교육회차 확인
	var sPostId = nexacro.getApplication().gv_mainFrame.param.postId;
	
	if(!this.gfnIsNull(sPostId)){
		var mRegRow = this.ds_EduRegList.findRow("ES_SEQ",sPostId);
		var sRow = this.ds_ScheduleList.findRow("ES_SEQ",sPostId);
		
		this.mskPhoneNo.set_value(this.ds_EduRegList.getColumn(mRegRow,"PHONE_NO"));
		this.edtEmail.set_value(this.ds_EduRegList.getColumn(mRegRow,"EMAIL"));
		this.edtCompanyName.set_value(this.ds_EduRegList.getColumn(mRegRow,"COMPANY_NAME"));
		this.edtDeptName.set_value(this.ds_EduRegList.getColumn(mRegRow,"DEPT_NAME"));
		this.edtName.set_value(this.ds_EduRegList.getColumn(mRegRow,"EMP_NAME"));
		this.rdoReqReason.set_index(this.ds_EduRegList.getColumn(mRegRow,"REQ_REASON"));
		if(this.ds_EduRegList.getColumn(mRegRow,"REQ_REASON")==3){
			this.edtReqReasonEtc.set_value(this.ds_EduRegList.getColumn(mRegRow,"REQ_REASON_ETC"));
			this.rdoReqReason_onitemchanged();
		}
		this.txaQuestion.set_value(this.ds_EduRegList.getColumn(mRegRow,"QUESTION"));
		
		//온라인 - 오프라인 여부 확인
		var mStatusCd = this.ds_EduRegList.getColumn(mRegRow, "STATUS_CD");
		if(mStatusCd =='1'){
			this.ds_ScheduleList.setColumn(sRow,"CHK",1)
		}else if(mStatusCd == '7'){
			this.ds_ScheduleList.setColumn(sRow,"CHK_ON",1)
		}
	};
};

//교육 취소 함수
this.fn_CallTransDelete= function(seq){
		var mRow = this.ds_EduRegList.findRow("ES_SEQ",seq);
		var sUserId = nexacro.getApplication().gds_UserInfo.getColumn(0, "User_id");
		var sEslSeq = this.ds_EduRegList.getColumnNF(mRow, "ESL_SEQ");
		var strArgs = "RTYPE=XML DB='CS'"
					+ " sessionChk=false"
					+ " nationCd='"    + nexacro.getApplication().gv_NationCd + "'"
					+ " JSESSIONID='"  + nexacro.getApplication().JSESSIONID  + "'"
					+ " sUserId='"     + sUserId                 + "'"
					+ " sEslSeq='"     + sEslSeq                 + "'";
		//테스트서버
		var strUrl = "SVC_JSP::Next_JSP/Education/SaveCancel.jsp?";
		var strDsInput = "";
		var strDsOutput = "";
		this.mChkCount -= 1;
		this.com_TransSend("EduRegCancel",strUrl,strDsInput,strDsOutput,strArgs,"fn_CallBack");
		
		
}

//그리드 클릭 이벤트
this.Grid01_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{

	var mRow  = this.ds_ScheduleList.findRow("ES_SEQ",this.Grid01.getCellText(e.row,1));
	//그리드 교육신청 체크박스 클릭 이벤트
	if(e.cell ==7){ 
		if(this.Grid01.getCellText(e.row,6)!="마감"&&this.ds_ScheduleList.getColumn(mRow,"CHK")==0){
			this.ds_ScheduleList.setColumn(mRow, "CHK","1");
			this.ds_ScheduleList.setColumn(mRow, "CHK_ON","0");
		}else if(this.Grid01.getCellText(e.row,6)!="마감"&&this.ds_ScheduleList.getColumn(mRow,"CHK")==1){
			this.ds_ScheduleList.setColumn(mRow, "CHK","0");
		}
	}   
	
/* 
else if(e.cell == 7){
		if(this.ds_ScheduleList.getColumn(mRow,"CHK_ON")==1){
			this.ds_ScheduleList.setColumn(mRow, "CHK","0");
		}
	}
*/	  
	
};

//교육 일정 하단 텍스트 출력 함수
this.fn_LeftBottomMessage = function()
{
   
	var txt = "";
	txt += "<fc v='black'>[ 2025년도 정기교육과정에 대한 변경사항 안내 ]<br/>";
	txt += "•  정기교육은 <fc v='blue'>온라인</fc>과<fc v='red'>오프라인</fc>을 병행하여 운영되며, <fc v='blue'>2월 부터 넥사크로N V24버전으로 통일</fc>합니다.</fc><br/>";	
	txt += "•  <fc v='blue'>온라인</fc> 교육: 교육생 자신의 사무실(위치)에서 온라인(Zoom)을 이용하여 교육을 받을 수 있습니다.<br/>";
	txt += "•  <fc v='red'>오프라인</fc> 교육: 투비소프트 3층 교육장을 방문하여 교육을 받을 수 있습니다.<br/>";
	txt += "   교육장에는 <b>노트북</b>이 배치되어 있으며, <b>점심</b> 및 <b>주차</b>는 지원되지 않습니다.<br/>";
	txt += "   <fc v='black'>개발자 교육</fc> 중 <fc v='red'>오프라인</fc> 교육 일부는 <fc v='blue'>대한상공회의소 과정</fc>으로 진행됩니다.<br>";	
	txt += "•  교육장 주소: 서울시 강남구 봉은사로 617 인탑스빌딩 (주)투비소프트 3층 교육장<br/>";
	txt += "•  교육 문의는 02-2140-7224 / edu@tobesoft.com 으로 연락주시기 바랍니다.<br/>";  
	this.staNotice.set_text(txt);
}
