        <Static id="Static02_00_00" taborder="1" text="교육과정" left="0" top="91" width="176" height="30" cssclass="sta_WF_eduTitle"/>
        <Grid id="Grid01" taborder="2" left="0" top="141" right="450" binddataset="ds_ScheduleList" autofittype="col" nodatatext="신청 가능한 교육과정이 없습니다." oncellclick="Grid01_oncellclick" scrolltype="none" selectscrollmode="select" scrollbartype="none none" height="697" accessibilitylabel="교육과정" selecttype="cell" autoenter="select" cellclickbound="cell">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="76"/>
                <Column size="68"/>
                <Column size="123"/>
                <Column size="183"/>
                <Column size="140"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="0"/>
                <Column size="0"/>
                <Column size="48"/>
              </Columns>
              <Rows>
                <Row size="55" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head" accessibilityenable="false">
                <Cell text="교육방식"/>
                <Cell col="1" text="교육회차"/>
                <Cell col="2" colspan="2" text="교육과정"/>
                <Cell col="4" text="교육일자"/>
                <Cell col="5" text="정원"/>
                <Cell col="6" text="신청인원"/>
                <Cell col="7" text="신청"/>
                <Cell col="8" text="온라인&#13;&#10;신청인원"/>
                <Cell col="9" text="온라인&#13;&#10;참여신청"/>
                <Cell col="10" text="지역"/>
              </Band>
              <Band id="body" accessibilityenable="false">
                <Cell text="bind:EDU_METHOD_NAME" suppress="1" suppressalign="middle"/>
                <Cell col="1" text="bind:ES_SEQ"/>
                <Cell col="2" text="bind:EDU_TYPE_NAME" suppress="2" textAlign="center"/>
                <Cell col="3" text="bind:EDU_TYPE_DET_NAME" textAlign="left" suppress="3"/>
                <Cell col="4" text="bind:START_DATE" displaytype="date"/>
                <Cell col="5" text="bind:ONLINE_NUM"/>
                <Cell col="6" text="expr:KORCHAM_FLAG == &quot;1&quot; ? &quot;-&quot; : ICOUNT"/>
                <Cell col="7" text="expr:KORCHAM_FLAG == &quot;1&quot; ? CHK : ONLINE_NUM&lt;=ICOUNT&amp;&amp;EX_FLAG!='N'?&quot;마감&quot;:CHK" cssclass="expr:KORCHAM_FLAG == &quot;1&quot; ? &quot;&quot; : EX_FLAG=='Y'?STATUS_CD=='1'?'grd_WF_uncheck':'grd_WF_discheck':&quot;&quot;" checkboxfalsevalue="0" checkboxtruevalue="1" displaytype="expr:KORCHAM_FLAG == &quot;1&quot; ? &quot;checkboxcontrol&quot; :  ONLINE_NUM&lt;=ICOUNT&amp;&amp;EX_FLAG!='N'?'normal':&quot;checkboxcontrol&quot;" edittype="expr:KORCHAM_FLAG == &quot;1&quot; ? &quot;checkbox&quot; : ONLINE_NUM&lt;=ICOUNT&amp;&amp;EX_FLAG!='N'?'none':'checkbox'"/>
                <Cell col="8" text="bind:ONCOUNT"/>
                <Cell col="9" text="bind:CHK_ON" displaytype="checkboxcontrol" edittype="checkbox" cssclass="expr:EX_FLAG=='Y'?STATUS_CD=='7'?'grd_WF_uncheck':'grd_WF_discheck':&quot;&quot;"/>
                <Cell col="10" text="bind:EDU_AREA_NAME" suppress="2" suppressalign="middle"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="sta_notice" taborder="3" text="2024년 6월 부터 동영상 교육으로 대체 합니다. " left="200" top="150" height="90" usedecorate="true" visible="false" onclick="sta_notice_onclick" cssclass="sta_WF_eduMovie" background="none no-repeat" verticalAlign="top" width="580"/>
