        <Radio id="rdoReqReason" taborder="16" left="877" top="658" height="65" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" cssclass="rdo_WF_search" index="0" text="제목+내용" value="0" columncount="2" onitemchanged="rdoReqReason_onitemchanged" initvalueid="iv_Radio0" right="6">
