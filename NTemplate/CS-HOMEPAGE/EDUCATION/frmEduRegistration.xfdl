<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <TypeDefinition url="..\default_typedef.xml"/>
  <Form id="frmEduRegistration" classname="WorkFrame" left="0" top="0" width="1300" height="1810" onload="frmEduRegistration_onload" titletext="교육신청" scrollbars="none" onbindingvaluechanged="frmEduRegistration_onbindingvaluechanged">
    <Layouts>
      <Layout stepcount="">
        <Tab id="tabProduct" taborder="0" tabindex="0" left="0" top="0" width="1300" height="66" cssclass="tab_WF_product" onchanged="tabProduct_onchanged" accessibilitylabel="교육과정" initvalueid="iv_Tab0">
          <Tabpages>
            <Tabpage id="Tabpage1" text="Nexacro N" accessibilityenable="false">
