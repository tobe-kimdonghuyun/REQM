<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <TypeDefinition url="..\default_typedef.xml"/>
  <Form id="noticeList" classname="WorkFrame" left="0" top="0" width="1300" height="1672" scrollbars="none" onload="noticeList_onload" ontimer="noticeList_ontimer" scrollbarsize="0">
    <Layouts>
      <Layout>
        <Div id="divContent" taborder="0" left="0" top="610" width="1300" height="500" cssclass="div_WF_faq" formscrolltype="none" visible="false">
          <Layouts>
            <Layout>
              <WebBrowser id="wbContent" taborder="2" left="30" top="30" width="1240" height="440" visible="true" onusernotify="divContent_wbContent_onusernotify" border="0px none"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divList" taborder="1" text="Div00" left="1310" top="0" width="1300" height="90" visible="false">
          <Layouts>
            <Layout>
              <Static id="staTitle" taborder="0" text="투비소프트 교육신청방법 변경 안내" left="0" top="0" width="1300" height="90" cssclass="sta_WF_faq" visible="false"/>
              <Button id="btnOpen" taborder="1" left="1230" top="20" width="50" height="50" cssclass="btn_WF_faqClose" visible="false"/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="ds_NoticeList" firefirstcount="0" firenextcount="0" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false" onload="ds_hotlist_onload">
        <ColumnInfo>
          <Column id="rowNum" type="STRING" size="256"/>
          <Column id="BL_SEQ" type="STRING" size="256"/>
          <Column id="user_cnt" type="STRING" size="256"/>
          <Column id="boardid" type="STRING" size="256"/>
          <Column id="SUBJECT" type="STRING" size="256"/>
          <Column id="INSERT_DATE" type="STRING" size="256"/>
          <Column id="CONTENTS" type="STRING" size="256"/>
          <Column id="goods_gbn" type="STRING" size="256"/>
          <Column id="SUBJECT_COLOR" type="STRING" size="256"/>
          <Column id="BOLD_FLAG" type="STRING" size="256"/>
          <Column id="HOT_FLAG" type="STRING" size="256"/>
          <Column id="IMPORTANT_FLAG" type="STRING" size="256"/>
          <Column id="NOTICE_FLAG" type="STRING" size="256"/>
          <Column id="BookMark_cnt" type="STRING" size="256"/>
          <Column id="BookMark_FLAG" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="ds_totalCnt" firefirstcount="0" firenextcount="0" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="totalCnt" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="ds_SearchParam" firefirstcount="0" firenextcount="0" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="loginAcc" type="STRING" size="256"/>
          <Column id="dispGubun" type="STRING" size="256"/>
          <Column id="PCategory2" type="STRING" size="256"/>
          <Column id="display_cnt" type="STRING" size="256"/>
          <Column id="page" type="STRING" size="256"/>
          <Column id="searchfield" type="STRING" size="256"/>
          <Column id="searchgubun" type="STRING" size="256"/>
          <Column id="keyword" type="STRING" size="256"/>
          <Column id="search_resort" type="STRING" size="256"/>
          <Column id="keywordall" type="STRING" size="256"/>
          <Column id="BusinessSection" type="STRING" size="256"/>
          <Column id="statusType" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="dispGubun"/>
            <Col id="BusinessSection">000</Col>
            <Col id="searchgubun">OR</Col>
            <Col id="searchfield">200</Col>
            <Col id="search_resort">N</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="ds_downloadfile" firefirstcount="0" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="FM_SEQ" type="STRING" size="19"/>
          <Column id="FILE_NAME" type="STRING" size="256"/>
          <Column id="SAVE_PATH" type="STRING" size="256"/>
          <Column id="SAVE_FILE_NAME" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="ds_localDir" useclientlayout="true">
        <ColumnInfo>
          <Column id="dir" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="dir">D:\Project\CS\Next\file\</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item2" compid="tabQnaExpr.tabpage1.cmbProcCate" propid="value" datasetid="ds_SearchParam" columnid="BusinessSection"/>
      <BindItem id="item3" compid="tabQnaExpr.tabpage1.cmbSearchField" propid="value" datasetid="ds_SearchParam" columnid="searchfield"/>
      <BindItem id="item4" compid="tabQnaExpr.tabpage1.edtKeyword" propid="value" datasetid="ds_SearchParam" columnid="keyword"/>
      <BindItem id="item5" compid="tabQnaExpr.tabpage1.Combo02" propid="value" datasetid="ds_SearchParam" columnid="searchgubun"/>
      <BindItem id="item6" compid="tabQnaExpr.tabpage1.chkBoxResearch" propid="value" datasetid="ds_SearchParam" columnid="search_resort"/>
    </Bind>
    <Script type="xscript5.1"><![CDATA[/**
*  교육FAQ
*
*  @MenuPath 
*  @FileName 		EDUCATION::frmEduFAQ.xfdl 
*  @Creator 		김광호
*  @CreateDate 		2022.01.01
*  @LastModifier  
*  @LastModifyDate  
*  @Version 		1.0
*  @Outline 		교육FAQ
*  @Desction 
************** 소스 수정 이력 *************************************************
*    date          Modifier            Description
*******************************************************************************
*  2022.01.01      김광호	           최초 생성 
*******************************************************************************
*/

this.fvPrevDiv = "";
this.fvPrevContentDiv = "";

//폼 온로드 이벤트
this.noticeList_onload = function(obj:Form, e:nexacro.LoadEventInfo)
{     
	//페이지 초기화
	if(nexacro.getApplication().gv_mainFrame.Board_Cond_Resetflag == true)
	{   
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = 1;    
		nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = 0;
	}  else {
		nexacro.getApplication().gv_mainFrame.Board_Cond_Resetflag = true;
	}		
	
	
	//조회 조건 셋팅
 	this.ds_SearchParam.clearData();
 	this.ds_SearchParam.addRow();
 	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition,"display_cnt",nexacro.getApplication().gv_mainFrame.Board_Cond_DisplayCnt);
 	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition,"page",nexacro.getApplication().gv_mainFrame.Board_Cond_Page);
 	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition,"searchfield",nexacro.getApplication().gv_mainFrame.Board_Cond_Searchfield);
 	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition,"searchgubun",nexacro.getApplication().gv_mainFrame.Board_Cond_Searchgubun);
 	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition,"BusinessSection",nexacro.getApplication().gv_mainFrame.Board_Cond_BusinessSection);
 	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition,"search_resort",nexacro.getApplication().gv_mainFrame.Board_Cond_Resort);
 	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition,"keyword",nexacro.getApplication().gv_mainFrame.Board_Cond_Keyword);
 	this.ds_SearchParam.setColumn(this.ds_SearchParam.rowposition,"keywordall",nexacro.getApplication().gv_mainFrame.Board_Cond_Keyword);
 	
 	// "등록자, 번호" 항목은 제외
  	nexacro.getApplication().gds_SearchField.filter("");
  	nexacro.getApplication().gds_SearchField.filter("currow < 3 || currow > 4");
	
	//this.divContent.form.wbContent.set_url(nexacro.getApplication().gv_DomainInfo+"CKEDITOR/editor/view_FAQ.html");
 	
	// 데이터 취득
 	this.fn_CallTrans();
}

//전체 높이 조절 함수
this.fn_SetInitSize = function(nHeight)
{
	if(nHeight > 0)
	{
		nHeight = parseInt(nHeight)+111;
	}
	// 각 컴퍼넌트의 초기값 설정
	this.set_height(376 + (this.ds_NoticeList.getRowCount() * 70) + parseInt(nHeight));//    1050  		
	this.parent.set_height(376  + (this.ds_NoticeList.getRowCount() * 70) + parseInt(nHeight));//      
	nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, 426  + (this.ds_NoticeList.getRowCount() * 70) + parseInt(nHeight));
}    


//리스트 조회 함수
this.fn_CallTrans = function() {
	
	nexacro.getApplication().com_SetParam(this.ds_SearchParam);
	
	// filter된 상태로 삭제후 값이 들어가면 rowcount가 0이되는 에러가 있음
	// 상기에 대한 회피책으로 우선 filter를 되돌리고 나서 처리
	if(this.gfnIsNull(this.strAn)){
		this.ds_NoticeList.filter("");
		this.ds_NoticeList.deleteAll();
	}
 	

	// 인수 설정     
	var strBoardId="A36";
	var PCategoryGubun="%";
	if(this.gfnIsNull(this.strAn)){			//처음 조회하는 경우 리스트를 불러옴
		var strArgs = "RTYPE=XML DB='CS' sessionChk=false BoardID=" + strBoardId + " PCategoryGubun=" + PCategoryGubun +" nationCd=" +  nexacro.getApplication().gv_NationCd + "' JSESSIONID='"+nexacro.getApplication().JSESSIONID+"'";
		if(strBoardId == "A37")
		{
			var strUrl = "SVC_JSP::Next_JSP/Board/SearchBoard2.jsp?";
		}
		else
		{
			var strUrl = "SVC_JSP::Next_JSP/Board/SearchBoard_new.jsp?";
		}		
		var strDsInput = "input1=gds_SearchParam";
		var strDsOutput = "ds_totalCnt=output1 ds_NoticeList=output2";  
		this.com_TransSend("noticeList",strUrl,strDsInput,strDsOutput,strArgs,"fn_NoticeListCallBack");
	}else{		//조회 내역이 있는 경우 필요한 데이터만 조회
		nexacro.getApplication().gds_MiWizard.clearData();   
		nexacro.getApplication().com_AddMiWizard("","output2","BoardID='" + strBoardId  + "'&strAn="+this.ds_NoticeList.getColumn(this.strAn,"BL_SEQ"),"XPLATFORM,TECH_MAIN,48");
		var outDs = "ds_downloadfile=output2";
		this.com_CallService("fileDwnInfo", "", "", outDs, "fn_NoticeListCallBack", "CS", true);
	}
}
  
//리스트 조회 콜백 함수
this.fn_NoticeListCallBack = function (svcid,errCode,errMsg)
{   

	if (svcid == "noticeList") {
 		// 데이터가 있을경우
 		if (this.ds_NoticeList.rowcount > 0) {
		
			// EduFAQ 항목 동적생성
			this.fn_createList();
			this.fvPrevDiv = "";
			this.fvPrevContentDiv = "";
			this.setTimer(111, 200);
			
 		}            

	}else if (svcid == "fileDwnInfo"){
		
		this.ds_downloadfile.addColumn("URL", "STRING");
				// 다운로드url 추가  이후 다운로드 시 사용
				for (var i = 0; i < this.ds_downloadfile.rowcount; i++) {
				
					this.ds_downloadfile.setColumn(i, "URL", nexacro.getEnvironment().services["SVC_JSP"].url 
					+ "Next_JSP/FileDownload/fileDownload.jsp?path="+encodeURIComponent(this.ds_downloadfile.getColumn(i,"SAVE_PATH"))//.replace("E:","D:"))
					+ "&file="+ encodeURIComponent(this.ds_downloadfile.getColumn(i,"SAVE_FILE_NAME")) 
					+ "&realFileNm='"+encodeURIComponent(this.ds_downloadfile.getColumn(i,"FILE_NAME")));
		}
	}
	   
 	// 사이즈 초기화
 	this.fn_SetInitSize(0);

	
}

// 리스트뷰 사이즈에 맞게 화면 조정
this.fn_lvSize = function ()
{
	var nRowCnt = this.ds_NoticeList.rowcount;
	this.set_height(92*nRowCnt+400);      		
	this.parent.set_height(92*nRowCnt+400);         
	nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, 92*nRowCnt+500);
	
};



// 리스트 동적생성
this.fn_createList = function()
{
	var nRowCnt = this.ds_NoticeList.rowcount;
	
	var i;
	for (i = 0; i < nRowCnt; i++)
	{
		var objDiv = new Div("divList"+i, 0, 90*i, 1300, 90);
		this.addChild("divList"+i, objDiv);
		objDiv.set_url("EDUCATION::frmEduFAQRow.xfdl");
		objDiv.show();
		this.fvPrevDiv = objDiv;
		//arrange 걸기
		if(!this.gfnIsNull(this.fvPrevContentDiv)) objDiv.set_top(this.fvPrevContentDiv.id+":0");
		
		//내용Div 동적생성
		var objContentDiv = new Div("divContent"+i, 0, 90*i + 90 , 1300, 0);
		this.addChild("divContent"+i, objContentDiv);
		objContentDiv.show();
		objContentDiv.cssclass = "div_WF_faq";
		objContentDiv.formscrolltype = "none";
		objContentDiv.visible = false;
		objContentDiv.accessibilityenable = false;
		this.fvPrevContentDiv = objContentDiv;
		//arrange 걸기
		if(!this.gfnIsNull(this.fvPrevDiv)) objContentDiv.set_top(this.fvPrevDiv.id+":0");
				
		
		var wbContent = new WebBrowser("wbContent", 30, 30, 1240, 440);
		objContentDiv.addChild("wbContent", wbContent);
		wbContent.show();
		wbContent.set_url(nexacro.getApplication().gv_DomainInfo+"CKEDITOR/editor/view_FAQ.html");
		wbContent.border = "0px none";
		wbContent.accessibilitylabel = "내용";
	}
};

// 리스트 타이틀 셋팅
this.fn_setListTitle = function()
{
	var nRowCnt = this.ds_NoticeList.rowcount;

	var i;
	for (i = 0; i < nRowCnt; i++)
	{
		//eval("this.divList"+i+".form.staTitle.set_text('"+this.ds_NoticeList.getColumn(i, "SUBJECT")+"');");
		//eval("this.divList"+i+".form.btnTitle.set_accessibilitylabel('Q: "+this.ds_NoticeList.getColumn(i, "SUBJECT")+"');");
		var comp = this.components["divList"+i];
		comp.form.staTitle.set_text(this.ds_NoticeList.getColumn(i, "SUBJECT"));
		comp.form.btnOpen.set_accessibilitylabel("열기 " + this.ds_NoticeList.getColumn(i, "SUBJECT"));
		//comp.form.btnTitle.set_text('Q: ' + this.ds_NoticeList.getColumn(i, "SUBJECT"));
	}
}
this.rNum = 0;
// 리스트 Open버튼 제어
this.fn_btnOpen_Onclick = function(objDiv, sDiv)
{
	this.selectedRow = sDiv.substr(7);
	var nRowCnt = this.ds_NoticeList.rowcount;
	// 새로 열때
	if (objDiv.form.btnOpen.cssclass == "btn_WF_faqOpen")
	{
		for (var i = 0; i < nRowCnt; i++)
		{
			var objComp = this.components["divList"+i];
			//열려있던 Div가 있다면 닫기.
			if (objComp.form.btnOpen.cssclass == "btn_WF_faqClose") {
				this.fvDivContent.set_visible(false);		
				this.fvDivContent.height = 0;
				this.resetScroll();		
				objComp.form.btnOpen.cssclass = "btn_WF_faqOpen";
				objComp.form.btnOpen.accessibilitylabel = "열기 " + this.ds_NoticeList.getColumn(i, "SUBJECT");
			} else {
				objComp.form.btnOpen.cssclass = "btn_WF_faqOpen";
				objComp.form.btnOpen.accessibilitylabel = "열기 " + this.ds_NoticeList.getColumn(i, "SUBJECT");	
			}
		}
		
		objDiv.form.btnOpen.cssclass = "btn_WF_faqClose";
		objDiv.form.btnOpen.accessibilitylabel = "닫기 " + this.ds_NoticeList.getColumn(this.selectedRow, "SUBJECT");
		this.setTimer(222, 200);
		
		// 웹브라우저 로딩
		this.fvDivContent = this.components["divContent"+this.selectedRow];
		this.fvDivContent.set_visible(true);
	}
	else // 열려있던거 또 눌렀을때(닫기)
	{
		objDiv.form.btnOpen.cssclass = 'btn_WF_faqOpen';
		objDiv.form.btnOpen.accessibilitylabel = "열기 " + this.ds_NoticeList.getColumn(this.selectedRow, "SUBJECT");
		
		// 웹브라우저 닫기
		//this.fvDivContent.form.wbContent.reload();
		this.fvDivContent.set_visible(false);		
		this.fvDivContent.height = 0;
		this.resetScroll();
		// 전체 높이 조절
		this.fn_SetInitSize(0);
	}
	this.strAn = this.selectedRow;
	this.fn_CallTrans();
};

// Open시 리스트 높이 조정
this.fn_openListHeight = function(nHeight)
{
	var nRowCnt = this.ds_NoticeList.rowcount;
	var i;
	for (i = 0; i < nRowCnt; i++)
	{
		if (i > this.selectedRow)
		{
			eval("this.divList"+i+".set_top("+i*90+"+parseInt("+nHeight+")+110);");
		}
		else
		{
			eval("this.divList"+i+".set_top("+i*90+");");
		}
	}
};


this.noticeList_ontimer = function(obj:nexacro.Form,e:nexacro.TimerEventInfo)
{
	this.killTimer(e.timerid);
	if (e.timerid == 111)
	{
		this.fn_setListTitle();
	}
	//새로 열때 폼 구성 타이머
	else if (e.timerid == 222)
	{
		var nFileName = "";
		if(this.ds_downloadfile.getRowCount()!=0){		//파일이 있는 경우
			for(var i=0;i<this.ds_downloadfile.getRowCount();i++){
				nFileName += "<a href='"+this.ds_downloadfile.getColumn(i,"URL")+"'>";
				nFileName +=this.ds_downloadfile.getColumn(i,"FILE_NAME")+"</a><br/>";
			}
		}
		//trace(this.ds_NoticeList.saveXML());
		//trace(this.ds_NoticeList.getColumn(this.selectedRow, "CONTENTS"));
		//this.divContent.form.wbContent.callMethod("setContent", this.ds_NoticeList.getColumn(this.selectedRow, "CONTENTS")+nFileName, true);
		this.fvDivContent.form.wbContent.callMethod("setContent", this.ds_NoticeList.getColumn(this.selectedRow, "CONTENTS")+nFileName, true);
		this.ds_downloadfile.clear();
		
		//폼 높이 조절
		this.setTimer(333, 50);
	}
	//폼 높이 조절 함수
	else if (e.timerid == 333)
	{
		var nRes = this.getHTMLValue("getContentHeight");
		// 웹브라우저 높이 조절	
		this.fvDivContent.form.wbContent.set_height(parseInt(nRes) + 50);
		this.fvDivContent.set_height(parseInt(nRes) + 50 + 60);
		this.resetScroll();
		// 리스트 높이 조절
		//this.fn_openListHeight(nRes);
		// 전체 높이 조절
		this.fn_SetInitSize(nRes);
		
		//클릭한 로우로 포커스 이동
		nexacro.getApplication().gv_mainFrame.scrollBy(0, this.selectedRow*90+148);
	}
};

// editor.html 영역에서 특정 값을 얻어온다.
this.getHTMLValue = function(name)
{
	//this.divContent.form.wbContent.callMethod("getHTMLValue", name);
	this.fvDivContent.form.wbContent.callMethod("getHTMLValue", name);
	
	//var el = this.divContent.form.wbContent.getProperty("document").callMethod("getElementById", "transfer");
	var el = this.fvDivContent.form.wbContent.getProperty("document").callMethod("getElementById", "transfer");
	var val = el.getProperty("value");
	
	el.setProperty("value", "");
		
	return val;	
}
]]></Script>
  </Form>
</FDL>
