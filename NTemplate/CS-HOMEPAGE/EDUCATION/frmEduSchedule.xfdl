<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <TypeDefinition url="..\default_typedef.xml"/>
  <Form id="frmEduSchedule" classname="WorkFrame" left="0" top="0" width="1300" height="1820" scrollbars="none" onload="frmEduSchedule_onload" titletext="교육일정" onclose="frmEduSchedule_onclose">
    <Layouts>
      <Layout>
        <Tab id="tabProduct" taborder="0" tabindex="0" left="0" top="0" width="1300" height="66" cssclass="tab_WF_product" onchanged="tabProduct_onchanged" initvalueid="iv_Tab0" accessibilitylabel="교육일정">
