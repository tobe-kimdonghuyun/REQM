        <Grid id="grd_eduList" taborder="9" left="440" top="141" height="629" right="0" binddataset="ds_EduSchedule" autofittype="col" oncelldblclick="grd_eduList_oncelldblclick" nodatatext="교육일정이 없습니다." accessibilitylabel="교육일정" selecttype="cell" cellclickbound="cell">
