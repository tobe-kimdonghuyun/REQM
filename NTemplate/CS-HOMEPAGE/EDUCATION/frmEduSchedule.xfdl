                <Cell col="7" text="bind:EDU_AREA_NAME" suppress="2" suppressalign="middle"/>
              </Band>
            </Format>
            <Format id="format_date">
              <Columns>
                <Column size="100"/>
                <Column size="150"/>
                <Column size="135"/>
                <Column size="163"/>
                <Column size="100"/>
                <Column size="100"/>
                <Column size="160"/>
              </Columns>
              <Rows>
                <Row size="55" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="교육방식"/>
                <Cell col="1" text="교육일자"/>
                <Cell col="2" colspan="2" text="교육과정"/>
                <Cell col="4" text="교육기간"/>
                <Cell col="5" text="교육회차"/>
                <Cell col="6" text="신청인원/교육정원"/>
              </Band>
              <Band id="body">
                <Cell text="bind:EDU_METHOD_NAME" suppress="1" suppressalign="middle"/>
                <Cell col="1" displaytype="date" text="bind:START_DATE"/>
                <Cell col="2" text="bind:EDU_TYPE_DET_NAME"/>
                <Cell col="3" text="bind:EDU_TYPE_DET_NAME" suppress="1"/>
                <Cell col="4" text="expr:comp.parent.fn_getEduDay(START_DATE, END_DATE)"/>
                <Cell col="5" text="bind:ES_SEQ" suppress="0"/>
                <Cell col="6" text="expr:ICOUNT &gt;= ONLINE_NUM || CURR_DATE &gt;= START_DATE ? &quot;신청마감&quot; : ICOUNT +&quot; / &quot;+ ONLINE_NUM" cssclass="expr:ICOUNT &gt;= ONLINE_NUM || CURR_DATE &gt;= START_DATE ? 'grd_WF_schRed':'grd_WF_schBlue'"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="sta_notice" taborder="10" text="2024년 6월 부터 동영상 교육으로 대체 합니다.  " left="580" top="200" width="460" height="90" usedecorate="true" visible="false" onclick="sta_notice_onclick" cssclass="sta_WF_eduMovie" background="none no-repeat" verticalAlign="top"/>
