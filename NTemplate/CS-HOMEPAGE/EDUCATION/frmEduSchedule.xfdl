    <Script type="xscript5.1"><![CDATA[/**
*  교육일정
*
*  @MenuPath 
*  @FileName 		EDUCATION::frmEduSchedule.xfdl 
*  @Creator 		김광호
*  @CreateDate 		2022.01.01
*  @LastModifier  
*  @LastModifyDate  
*  @Version 		1.0
*  @Outline 		교육일정
*  @Desction 
************** 소스 수정 이력 *************************************************
*    date          Modifier            Description
*******************************************************************************
*  2022.01.01      김광호	           최초 생성 
*******************************************************************************
*/


//이 값에 따라 서비스 쿼리 실행이 달라짐
this.sFormType = "frmEduSchedule";
this.fv_prodCd = "NPN";
this.fv_prodNm = "넥사크로N";

this.fv_eduY = "";	//현재 선택된 년도
this.fv_eduM = "";	//현재 선택된 월

this.fv_eduClosed = false;	//신청 마감여부(true:마감 false:신청)

this.mBtnTop;

this.frmEduSchedule_onload = function(obj:Form, e:nexacro.LoadEventInfo)
{
	// 공통측에서 요청한 내용임 : 프레임 사이즈가 다른 화면에 갔다오면 변경되어
	// 문자가 깨질수 있으므로 초기화 해달라고함
//  	this.set_height(1350);      		
//  	this.parent.set_height(1350);         
//  	nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, 1045);
 	
	this.fn_LeftBottomMessage();    
	this.set_height(1550);      		   
	this.parent.set_height(1550);            
	nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, 1290);
	
	
	//Today
    var objDate = new Date();    
	var currY = objDate.getFullYear().toString();
	var currM = (objDate.getMonth()+1).toString().padLeft(2,"0");
	var currD = objDate.getDate().toString().padLeft(2,"0");			

	this.fv_eduY = currY;
	this.fv_eduM = currM;
	


	//다음 월
    objDate = new Date(currY + "-" + currM + "-" + "01");
	objDate.setMonth(objDate.getMonth() + 1);
	var nextY = objDate.getFullYear().toString();
	var nextM = (objDate.getMonth()+1).toString().padLeft(2,"0");

	//다다음 월(
	objDate.setMonth(objDate.getMonth() + 1);	//또 다음달
	var sTempY = objDate.getFullYear().toString();
	var sTempM = (objDate.getMonth()+1).toString().padLeft(2,"0");

	//이번달 버튼 userdata set
	this.btn_month1.userDataY = currY;
	this.btn_month1.userDataM = currM;
	
	//다음달 버튼 userdata set
	this.btn_month2.userDataY = nextY;
	this.btn_month2.userDataM = nextM;		
	

 
	//왼쪽 그리드 칼렌더 그리기		   
    this.fn_drawCalendar(this.ds_data, this.Grid_calendar, currY, currM);
	this.fn_setCalendarDay(currY+currM+currD);

	this.fn_CallTrans();    
	

	//오늘 날짜 구하기
	var mDate = this.gfnGetDate();
	if(mDate != nexacro.getPrivateProfile("mTodayPop1")){
		this.fn_NoticePop();		//팝업 함수 호출
	}
	
	//페이지 번호에 따라 탭 변경
	var nPage = nexacro.getApplication().gv_mainFrame.param.page;
	this.tabProduct.set_tabindex(nPage-1);
}

this.fn_CallTrans = function() 
{  
	// 인수 설정 
	var strArgs = "RTYPE=XML DB='CS'"
	            + " sessionChk=false"
	            + " nationCd='"    + nexacro.getApplication().gv_NationCd    + "'"
	            + " JSESSIONID='"  + nexacro.getApplication().JSESSIONID     + "'"
	            + " sFormType='"    + this.sFormType            + "'";
				
	var strUrl = "SVC_JSP::Next_JSP/Education/SearchEduSchedule.jsp?"; 
	var strDsInput = "";
	var strDsOutput = "ds_EduSchedule=output1";  

	this.com_TransSend("EduSchedule",strUrl,strDsInput,strDsOutput,strArgs,"fn_callBack");
	
	//신청하기 버튼 높이 수정
	this.mBtnTop = this.Static00_00_00.getOffsetTop()+this.Static00_00_00.getOffsetHeight()-this.btnRegistration.getOffsetHeight()-this.btnRegistration.getOffsetHeight();
	this.btnRegistration.set_top(this.mBtnTop);
}

//콜백 함수
this.fn_callBack = function(svcId, errCd, errMsg)
{



	//this.ds_EduSchedule.set_keystring("S:EDU_PRODUCT_CODE+EDU_TYPE_DET+START_DATE");		
	this.ds_EduSchedule.set_keystring("S:-EDU_METHOD+EDU_TYPE_DET+START_DATE");		
	
 	this.ds_EduSchedule.filter("EDU_PRODUCT_CODE == '" + this.fv_prodCd + "' && START_DATE.indexOf('" + (this.fv_eduY+this.fv_eduM) +"') >= 0");
   
 	
 	var nHeadSize = this.grd_eduList.getRealRowFullSize("head");
 	var nBodySize = this.grd_eduList.getRealRowFullSize("body");
 	this.grd_eduList.set_height(nHeadSize+nBodySize+2);
   
	this.resetScroll();
	
	var mBtnMinTop = this.grd_eduList.getOffsetHeight()+this.grd_eduList.getOffsetTop();
	if(this.mBtnTop < mBtnMinTop){
		this.btnRegistration.set_top(mBtnMinTop+15);
	}else{
		this.btnRegistration.set_top(this.mBtnTop);
	}
	this.fn_CalPocus();
}

//Grid에서 호출
this.fn_getEduDay = function(sStartDate, sEndDate)
{
    var vFromDate = new Date(parseInt(sEndDate.substring(0,4),  10), parseInt(sEndDate.substring(4,6)-1,  10), parseInt(sEndDate.substring(6,8), 10));
    var vToDate = new Date(parseInt(sStartDate.substring(0,4),  10), parseInt(sStartDate.substring(4,6)-1,  10), parseInt(sStartDate.substring(6,8), 10));
	var nDiffDate = parseInt((vFromDate - vToDate)/(1000*60*60*24));

    return ( nDiffDate + 1) + "Day";

}

//년월 선택시
this.fn_selectYYMM = function(obj:Button, e:nexacro.ClickEventInfo)
{
	//접근성. visible=false되면서 초점이 Tab으로 이동하는 것을 방지하기 위함.
	this.staYearMonth.setFocus();
	
	obj.set_visible(false);
	if (obj.name == "btn_month1")
	{
		this.btn_month2.set_visible(true);
	}
	else
	{
		this.btn_month1.set_visible(true);
	}
	
	this.fv_eduY = obj.userDataY;
	this.fv_eduM = obj.userDataM;
	this.fn_dataFilter(this.fv_eduY+this.fv_eduM, this.fv_prodCd);
	
	//왼쪽 그리드 칼렌더 그리기		   
    this.fn_drawCalendar(this.ds_data, this.Grid_calendar, this.fv_eduY, this.fv_eduM);
	this.fn_setCalendarDay(this.fv_eduY+this.fv_eduM+"01");
	
	//현재 달력이면 날짜 표시
	if(this.fv_eduM== this.gfnGetDate().substr(4,2)){
		this.fn_CalPocus();
	}
	
	this.fn_notice(this.fv_prodCd, this.fv_eduY+this.fv_eduM);
}

//제품, 년월 버튼 선택시 제품 & 년월에 따른 필터
this.fn_dataFilter = function(sYYMM, sProd)
{
	//이미 필터한 조건이면 하지말자...
	var nRow = this.ds_EduSchedule.findRowExpr("EDU_PRODUCT_CODE == '" + sProd + "' && START_DATE.indexOf('" + sYYMM +"') >= 0");
	if(nRow > -1)	return;
	
	this.ds_EduSchedule.filter("EDU_PRODUCT_CODE == '" + sProd + "' && START_DATE.indexOf('" + sYYMM +"') >= 0");

 	var nHeadSize = this.grd_eduList.getRealRowFullSize("head");
 	var nBodySize = this.grd_eduList.getRealRowFullSize("body");
 	this.grd_eduList.set_height(nHeadSize+nBodySize+2);
	
	
	var mBtnMinTop = this.grd_eduList.getOffsetHeight()+this.grd_eduList.getOffsetTop();
	if(this.mBtnTop < mBtnMinTop){
		this.btnRegistration.set_top(mBtnMinTop+15);
	}else{
		this.btnRegistration.set_top(this.mBtnTop);
	}
}

/* 그리드 칼렌더 ***************************************/
this.fn_drawCalendar = function(objDS, objGrid, sYear, sMonth)
{
	var nYear  = parseInt(sYear, 10);
    var nMonth = parseInt(sMonth, 10);
    var nCurrLastDate = this.gfnGetLastDate(nYear+String(nMonth).padStart(2,'0')).substr(6,2);	//이번달 마지막 일

    var nStartDay = new Date(sYear  + "-" + sMonth + "-" + "01").getDay();	//2019-06-01 요일값
    var nLastDay  = new Date(sYear  + "-" + sMonth + "-" + nCurrLastDate).getDay();	//2019-06-30 요일값
						
    objDS.clearData();
    
    var day;
    var nRow = objDS.addRow();
    for(var i=1, day=nStartDay; i<=nCurrLastDate; i++ )
    {
        objDS.setColumn(nRow, "COL_D"+day, i);
        objDS.setColumn(nRow, "COL_YMD"+day, sYear+sMonth+i.toString().padLeft(2,"0"));

        day = (day + 1) % 7;
        if (day == 0 && i != nCurrLastDate){
            nRow = objDS.addRow();
        }        
    }
 
	this.staYearMonth.set_text(sYear + "년 " + nMonth + "월");
	this.fn_setStyle();
	
 	var nHeadSize = this.Grid_calendar.getRealRowFullSize("head");
 	var nBodySize = this.Grid_calendar.getRealRowFullSize("body");
 	this.Grid_calendar.set_height(nHeadSize+nBodySize+2);
	
}


//칼렌더 일자 색상 변경 Expr
this.fn_setStyle = function()
{
	for(var i=0; i<this.Grid_calendar.getCellCount("Body"); i++)
	{
		this.Grid_calendar.setCellProperty("Body", i, "cssclass", "EXPR:comp.parent.fn_cellCssClass(COL_YMD"+i+")");
		this.Grid_calendar.setCellProperty("Body", i, "accessibilitylabel", "EXPR:comp.parent.fn_cellAccessibilitylabel(COL_YMD"+i+", COL_D"+i+")");
	}
}

// 교육 일정 있는 날 셀 cssClass 변경
this.fn_cellCssClass = function(sYMD)
{
	if (this.gfnIsNull(sYMD))
	{
		return;
	}
	var nRow = this.ds_EduSchedule.findRowExpr("START_DATE == '" + sYMD + "' && EDU_PRODUCT_CODE == '" + this.fv_prodCd + "'");

	if(nRow > -1){
		return "grd_WF_schDay";
	}
	else{
		return "";
	}
}

// 교육 일정 있는 날 셀 접근성 속성 적용
this.fn_cellAccessibilitylabel = function(sYMD, sDay)
{
	if (this.gfnIsNull(sYMD))
	{
		return;
	}
	var nRow = this.ds_EduSchedule.findRowExpr("START_DATE == '" + sYMD + "' && EDU_PRODUCT_CODE == '" + this.fv_prodCd + "'");
	
	if(nRow > -1){
		return sDay + " 교육일정 있음";
	}
	else{
		return "";
	}
}


//그리드 칼런더 선택시 교육 리스트 선택
this.Grid_calendar_oncellclick = function(obj:Grid, e:nexacro.GridClickEventInfo)
{
	this.fn_selectEduList(e.row, e.cell);	
}


//교육 목록 필터 함수
this.fn_selectEduList = function(nRow, nCell)
{
	var sDate = this.ds_data.getColumn(nRow, "COL_YMD"+nCell);
	var nRow = this.ds_EduSchedule.findRowExpr("START_DATE == '" + sDate + "' || END_DATE == '" + sDate + "'" );
	this.ds_EduSchedule.set_rowposition(nRow);
}

//데이터셋 변경 이벤트
this.ds_EduSchedule_onrowposchanged = function(obj:Dataset, e:nexacro.DSRowPosChangeEventInfo)
{
	if(e.reason == 51 && e.newrow > -1){
		var sDate = obj.getColumn(e.newrow, "START_DATE");
		this.fn_setCalendarDay(sDate);			//클릭한 교육 캘린더에 표시
	}
}

// 교육일정 선택시 해당 일자 그리드 칼렌더 선택
this.fn_setCalendarDay = function(sDate)
{
	if (this.gfnIsNull(sDate))
	{
		return;
	}
	var sY = sDate.substr(0,4);
	var sM = sDate.substr(4,2);
	var sD = sDate.substr(6,2);
	var nDay = parseInt(sD);
	var nStartDay = new Date(sY + "-" + sM + "-" + sD).getDay();	//2019-06-01 요일값
	
	var nRow = this.ds_data.findRow("COL_D"+nStartDay, nDay);
	
	this.ds_data.set_rowposition(nRow);
	this.Grid_calendar.setCellPos(nStartDay);
}

// 신청하기 - 그리드 더블클릭 이벤트
this.grd_eduList_oncelldblclick = function(obj:Grid, e:nexacro.GridClickEventInfo)
{
	
	var nCell = 6;
	if(this.grd_eduList.formatid=="format_date"){
		nCell = 5;
	}   
	//온라인 오픈되면 막을것. 번호 저장만 살릴것
	if(this.grd_eduList.getCellValue(e.row,nCell)=="신청마감"){
		alert("마감되었습니다.");    
		return false;    
	}else{
		//신청하기에서 체크할 교육번호 저장
		nexacro.getApplication().gv_ApplyEduSEQ = this.grd_eduList.getCellValue(e.row,3);
	}

	var iCount  = this.ds_EduSchedule.getColumn(e.row, "ICOUNT");
	var iOnLine = this.ds_EduSchedule.getColumn(e.row, "ONLINE_NUM");
	var sCurrDt = this.ds_EduSchedule.getColumn(e.row, "CURR_DATE");
	var sStarDt = this.ds_EduSchedule.getColumn(e.row, "START_DATE");
	var sProdCd = this.ds_EduSchedule.getColumn(e.row, "EDU_PRODUCT_CODE");

	nexacro.getApplication().gv_mainFrame.param = {
		'menu': "Education_Registration",
		'keyword': "",
		'page': 1,
		'postId': ""   
		};
	nexacro.getApplication().gv_mainFrame.gfnGoMain();
}

// 신청하기 버튼 클릭 이벤트
this.btnRegistration_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var nRow = this.ds_EduSchedule.rowposition;
	if(nRow != -1){
		//온라인 오픈되면 막을것. 번호 저장만 살릴것
		if((this.ds_EduSchedule.getColumn(nRow,"ICOUNT")<this.ds_EduSchedule.getColumn(nRow,"ONLINE_NUM"))||(this.ds_EduSchedule.getColumn(nRow,"CURR_DATE")>=this.ds_EduSchedule.getColumn(nRow,"START_DATE"))){
			//신청하기에서 체크할 교육번호 저장
			nexacro.getApplication().gv_ApplyEduSEQ = this.ds_EduSchedule.getColumn(nRow, "ES_SEQ");	
		}else{	
			alert("마감되었습니다.");
			return false;
		}
	}
	
	var iCount  = this.ds_EduSchedule.getColumn(this.ds_EduSchedule.rowposition, "ICOUNT");
	var iOnLine = this.ds_EduSchedule.getColumn(this.ds_EduSchedule.rowposition, "ONLINE_NUM");
	var sCurrDt = this.ds_EduSchedule.getColumn(this.ds_EduSchedule.rowposition, "CURR_DATE");
	var sStarDt = this.ds_EduSchedule.getColumn(this.ds_EduSchedule.rowposition, "START_DATE");
	var sProdCd = this.ds_EduSchedule.getColumn(this.ds_EduSchedule.rowposition, "EDU_PRODUCT_CODE");

	nexacro.getApplication().gv_mainFrame.param = {
		'menu': "Education_Registration",
		'keyword': "",
		'page': 1,
		'postId': ""
		};
	nexacro.getApplication().gv_mainFrame.gfnGoMain();
	
};

//넥사크로 17 교육과정 소개 동영상 클릭 이벤트
this.sta_eduInfo_onclick = function(obj:Button, e:nexacro.ClickEventInfo)
{
	system.execBrowser("https://youtu.be/xEP5OGOhR3Q");
}
 
// 제품선택 탭 체인지 이벤트
this.tabProduct_onchanged = function(obj:nexacro.Tab,e:nexacro.TabIndexChangeEventInfo)
{  
	switch(e.postindex) {
	case 0:	// N
		this.fv_prodCd = "NPN";
		this.fv_prodNm = "넥사크로N";
		//this.sta_eduInfo.set_visible(false);
		break;
	case 1:	// 17
		this.fv_prodCd = "NP17";
		this.fv_prodNm = "넥사크로17";
		//this.sta_eduInfo.set_visible(true);
		break;   
	case 2: // 14
		this.fv_prodCd = "NP14";
		this.fv_prodNm = "넥사크로14";
		//this.sta_eduInfo.set_visible(false);		
		break;
	case 3:	// XP
		this.fv_prodCd = "XP";
		this.fv_prodNm = "엑스플랫폼";
		//this.sta_eduInfo.set_visible(false);		
		break;
	default:
	}
	nexacro.getApplication().gv_prodMoveCd = e.postindex;
	var nPageMoveCd = e.postindex;
	nexacro.getApplication().gv_mainFrame.gfnSetHistoryData(nPageMoveCd);
	this.fn_dataFilter(this.fv_eduY+this.fv_eduM, this.fv_prodCd);

	this.fn_notice(this.fv_prodCd, this.fv_eduY+this.fv_eduM);
	  
	//칼렌더 그리드 스타일 적용
	this.fn_setStyle();	
	
	// 신청하기 버튼 위치 조정
	this.resetScroll();
};

// 과정별/일자별 정렬
this.radSort_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	if (e.postindex == 0)
	{
		this.ds_EduSchedule.set_keystring("S:-EDU_METHOD-EDU_PRODUCT_CODE+EDU_TYPE_DET+START_DATE");		
		this.grd_eduList.set_formatid("default");
	}
	else
	{      
		this.ds_EduSchedule.set_keystring("S:-EDU_METHOD+START_DATE+EDU_PRODUCT_CODE+EDU_TYPE_DET");
		this.grd_eduList.set_formatid("format_date");
	}
	this.fn_CalPocus();   
};

//교육 일정 하단 텍스트 출력 함수
this.fn_LeftBottomMessage = function(mMonth){
	
	var objDate = new Date();
	var mYear = objDate.getYear();
	var mMonth = objDate.getMonth()+3;
	if(mMonth>12){
		mYear = mYear +1;
		mMonth = mMonth-12;
	}
	
	var mPreYear = objDate.getYear();
	var mPreMonth = objDate.getMonth()+2;
	if(mPreMonth>12){
		mPreYear = mPreYear+1;
		mPreMonth = mPreMonth-12;
	}
/*	
	var txt = "";
	txt += "•  교육시간은 10:00 ~ 17:00 (6H) 입니다. <br/>";
	txt += "<fc v='#fb6d3a'>•  "+mYear+"년 "+mMonth+"월 일정은 "+mPreYear+"년 "+mPreMonth+"월 첫 영업일 오전 10시에 오픈됩니다.</fc><br/>";
	txt += "•  교육문의는 02-2140-7224 / edu@tobesoft.com 으로 <br/>";
	txt += "&nbsp;&nbsp;&nbsp;연락주시기 바랍니다.";
	return txt;
*/
	var txt = "";
	txt += "<fc v='#fb6d3a'>•  "+mYear+"년 "+mMonth+"월 교육 일정은 "+mPreMonth+"월 첫 영업일 오전 10시에 오픈됩니다.</fc><br/>";
	txt += "•  교육은 10시부터 17시까지 6시간 진행됩니다.<br/>";
	txt += "•  교육 문의는 02-2140-7224 / edu@tobesoft.com 으로 <br/>";
	txt += "&nbsp;&nbsp;&nbsp;연락주시기 바랍니다.";
	this.Static00_00_00.set_text(txt);
}

//팝업 오픈 함수(코로나 알림 메세지)
this.fn_NoticePop = function(msg){

	var objFrame = new ChildFrame();
	var objParentFrame = this.getOwnerFrame();

	var nLeft = nexacro.getApplication().gv_mainFrame.getOffsetWidth()/2 - 400;
	var nTop = 300;
	objFrame.init( "modalContent", 0, 0, 600, 800 );
	//objFrame.set_titlebarheight(40);
	//objFrame.titlebar.set_background("#49506d");
	objFrame.showtitlebar = false;
	objFrame.set_dragmovetype("all");
	objFrame.set_openalign("center middle");
	objFrame.set_formurl( "EDUCATION::frmEduNoticePOP.xfdl" );
	var vRtn = objFrame.showModal( objParentFrame, msg, this, this.fn_callback );
	
	if(vRtn){
		this.gvFrame = objFrame;
	}
}

// 팝업을 연채로 이동하려할때 닫기
this.frmEduSchedule_onclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
   if(!this.gfnIsNull(this.gvFrame)){
		this.gvFrame.destroy();
   }
};


//오늘 날짜 표시
this.fn_CalPocus = function(){
	var nToday = this.gfnGetDate();
	var sWeek = this.gfnGetDay(nToday);
	var iRow= this.ds_data.findRow("COL_YMD"+sWeek,nToday);
	this.ds_data.set_rowposition(iRow);
	this.Grid_calendar.setCellPos(sWeek);	
};

// 동영상 교육 대체 안내
this.fn_notice = function(pCd, pYm)
{   
//	if(pYm >= "202206" && (pCd == "XP" || pCd == "NP14" ))  //|| pCd == "NP17"   //여기 수정 
	if(pYm >= "202206" && (pCd == "XP" || pCd == "NP14" || pCd == "NP17" ))  //여기 수정 
	{        
   
		this.radSort.set_visible(false);
		this.grd_eduList.set_visible(false);
		this.sta_notice.set_visible(true);
		this.btnMovie.set_visible(true); 
//		var sTxt  = (pCd == "XP" ? "XPLATFORM" : "nexacro 14") + " 정기교육은 2022년 6월부터 동영상 교육으로 대체합니다. \r\n \r\n";
//			sTxt += "<l v='http://demo.nexacro.com/EduPlay/_web_/index.html'><fc v='#1363CE'><u v='true'>동영상 바로가기</u></fc></l>";
		var sTxt  = (pCd == "XP" ? "XPLATFORM" : pCd == "NP14" ? "nexacro 14" : "nexacro 17") + " 정기교육은 " +  (pCd == "NP14" ? "2022" : "2024")  + "년 6월부터 \r\n 동영상 교육으로 대체합니다. \r\n\r\n";
//			sTxt += "<l v='http://demo.nexacro.com/EduPlay/_web_/index.html'><fc v='#1363CE'><u v='true'>동영상 바로가기</u></fc></l>";
			
		this.sta_notice.set_text(sTxt);
		this.sta_notice.set_fittocontents("height");
		this.btnRegistration.set_visible(false);
	}
	else
	{
  
//		this.radSort.set_visible(true);
		this.grd_eduList.set_visible(true);
		this.sta_notice.set_visible(false);
		this.btnMovie.set_visible(false); 
		this.btnRegistration.set_visible(true);
	}
}


this.btnMovie_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	system.execBrowser("http://demo.nexacro.com/EduPlay/_web_/index.html");
};]]></Script>
