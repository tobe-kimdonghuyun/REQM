        <Grid id="Grid_calendar" taborder="5" left="0" top="220" width="385" height="390" cssclass="grd_WF_schedule" binddataset="ds_data" autofittype="col" scrolltype="none" selecttype="cell" oncellclick="Grid_calendar_oncellclick" accessibilitylabel="교육일정">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="55"/>
                <Column size="55"/>
                <Column size="55"/>
                <Column size="55"/>
                <Column size="55"/>
                <Column size="55"/>
                <Column size="55"/>
              </Columns>
              <Rows>
                <Row size="55" band="head"/>
                <Row size="55"/>
              </Rows>
              <Band id="head" accessibilityenable="false">
                <Cell text="Sun" color="#ff5131" accessibilitylabel="일요일"/>
                <Cell col="1" text="Mon" accessibilitylabel="월요일"/>
                <Cell col="2" text="Tue" accessibilitylabel="화요일"/>
                <Cell col="3" text="Wed" accessibilitylabel="수요일"/>
                <Cell col="4" text="Thu" accessibilitylabel="목요일"/>
                <Cell col="5" text="Fri" accessibilitylabel="금요일"/>
                <Cell col="6" text="Sat" color="#0662cd" accessibilitylabel="토요일"/>
              </Band>
              <Band id="body" accessibilityenable="false">
                <Cell text="bind:COL_D0" color="#ff5131" accessibilityenable="expr:dataset.getColumn(currow, this.col) == undefined ? 'false':'true'"/>
                <Cell col="1" text="bind:COL_D1" accessibilityenable="expr:dataset.getColumn(currow, this.col) == undefined ? 'false':'true'"/>
                <Cell col="2" text="bind:COL_D2" accessibilityenable="expr:dataset.getColumn(currow, this.col) == undefined ? 'false':'true'"/>
                <Cell col="3" text="bind:COL_D3" accessibilityenable="expr:dataset.getColumn(currow, this.col) == undefined ? 'false':'true'"/>
                <Cell col="4" text="bind:COL_D4" accessibilityenable="expr:dataset.getColumn(currow, this.col) == undefined ? 'false':'true'"/>
                <Cell col="5" text="bind:COL_D5" accessibilityenable="expr:dataset.getColumn(currow, this.col) == undefined ? 'false':'true'"/>
                <Cell col="6" text="bind:COL_D6" color="#0662cd" accessibilityenable="expr:dataset.getColumn(currow, this.col) == undefined ? 'false':'true'"/>
              </Band>
            </Format>
