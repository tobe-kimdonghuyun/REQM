    <Bind/>
    <Script type="xscript5.1"><![CDATA[/**
*  교육접수현황
*
*  @MenuPath 
*  @FileName 		EDUCATION::fimEduCondition.xfdl 
*  @Creator 		김광호
*  @CreateDate 		2022.01.01
*  @LastModifier  
*  @LastModifyDate  
*  @Version 		1.0
*  @Outline 		교육접수현황
*  @Desction 
************** 소스 수정 이력 *************************************************
*    date          Modifier            Description
*******************************************************************************
*  2022.01.01      김광호	           최초 생성 
*******************************************************************************
*/
 
this.mChkRows = [];
this.mHeadChk; 
this.mHeadVal = 0;
this.pageMoveCd = 0;

this.frmEduCondition_onload = function(obj:Form, e:nexacro.LoadEventInfo)
{	
	// 공통측에서 요청한 내용임 : 프레임 사이즈가 다른 화면에 갔다오면 변경되어
	// 문자가 깨질수 있으므로 초기화 해달라고함
	this.set_height(1000);      		
	this.parent.set_height(1000);         
	nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, 1150);

	//로그인 여부 확인
	if(nexacro.getApplication().gds_UserInfo.getRowCount() <= 0)
 	{
 		nexacro.getApplication().gv_mainFrame.TargetUrl = nexacro.getApplication().gv_mainFrame.PCategory2;
		nexacro.getApplication().gv_mainFrame.param = {
			'menu': "login",
			'keyword': "",
			'page': 1,
			'postId': ""
			};
		nexacro.getApplication().gv_mainFrame.gfnGoMain();
		return;
 	}
	
	//교육 신청 정보 
 	this.fn_EduRegList();
	var sProd = "";
	switch(e.postindex) {
	case 0:
		sProd = "NPN";
		break;
	case 1:
		sProd = "NP17";
		break;
	case 2:
		sProd = "NP14";
		break;
	case 3:
		sProd = "XP";
		break;
	default:
	}
	this.ds_EduRegList.filter("EDU_PRODUCT_CODE == '" + sProd + "'");
 	
}

//로그인 아이디로 신청되어있는 리스트 조회
this.fn_EduRegList = function() 
{
	// 인수 설정 
	var sUserId = nexacro.getApplication().gds_UserInfo.getColumn(0, "User_id");
	var strArgs = "RTYPE=XML DB='CS'"
	            + " sessionChk=false"
	            + " nationCd='"    + nexacro.getApplication().gv_NationCd + "'"
	            + " JSESSIONID='"  + nexacro.getApplication().JSESSIONID  + "'"
	            + " sUserId='"     + sUserId                 + "'";

	var strUrl = "SVC_JSP::Next_JSP/Education/SearchEduReg.jsp?";
	var strDsInput = "";
	var strDsOutput = "ds_EduRegTemp=output1";  

	this.com_TransSend("EduRegList",strUrl,strDsInput,strDsOutput,strArgs,"fn_CallBack");
}
     
this.fn_CallBack = function (svcid,errCode,errMsg)
{
	if(svcid == "EduRegList") 
	{
		//아이디에 해당하는 전체 신청정보에서 'DONE_FLAG' 컬럼 'UNDONE'이면 지나지 않은, 'DONE' 지난과정 
		if(this.ds_EduRegTemp.rowcount > 0){
			this.ds_EduRegTemp.filter("DONE_FLAG == 'UNDONE'");
			this.ds_EduRegList.copyData(this.ds_EduRegTemp, true);
			
			this.ds_EduRegTemp.filter("DONE_FLAG == 'DONE'");
			this.ds_RegHistory.copyData(this.ds_EduRegTemp, true);
			
			this.ds_EduRegList.reset();
			this.ds_EduRegList.filter("EDU_PRODUCT_CODE == 'NPN'");
			
			this.ds_RegHistory.reset();
			this.ds_RegHistory.filter("EDU_PRODUCT_CODE == 'NPN'");
		}
		//탭 이동을 위한 변수 확인
		this.pageMoveCd = nexacro.getApplication().gv_prodMoveCd;
		if(!this.gfnIsNull(nexacro.getApplication().gv_prodMoveCd)){
			var sProdCd = this.pageMoveCd;
			this.tabProduct.set_tabindex(sProdCd);
			nexacro.getApplication().gv_prodMoveCd=0;
		}else{
			nexacro.getApplication().gv_prodMoveCd = 0;
			this.tabProduct.set_tabindex(0);
		}
		
 	}	  
 	else if(svcid == "EduRegCancel"){
		if(this.mChkCount < 0){
			alert("교육신청이 취소되었습니다.");
			this.reload();
		}else{
			this.fn_ProdDelete()
		}
		
 	}else if(svcid == "fn_EduCertificate"){
     
		var sFileName = "투비소프트수료증서_"+this.ds_RegHistory.getColumn(this.ds_RegHistory.rowposition,"EMP_NAME") + "_" + this.ds_RegHistory.getColumn(this.ds_RegHistory.rowposition,"ESL_SEQ") + ".pdf";
		system.execBrowser(nexacro.getEnvironment().services["SVC_JSP"].url+"Next_JSP/Education/CertificateFileDownload.jsp?FileName=" + sFileName);		
         	
    }
}

//단건 취소처리
this.grdEduCondition_oncellclick = function(obj:Grid, e:nexacro.GridClickEventInfo)
{
	nexacro.getApplication().gv_prodMoveCd = this.pageMoveCd;
	if(e.cell == 7){
		
		var sES_SEQ = this.grdEduCondition.getCellValue(e.row,2);

		var nRow = this.ds_EduRegList.findRow("ES_SEQ",sES_SEQ);
		if(this.ds_EduRegList.getCaseCount("CHK == 1")>1){			//체크박스 여러개 체크 후 삭제시 메세지
			this.alert("정보수정은 개별수정만 가능합니다.");
			return false;
		}   
		
		nexacro.getApplication().gv_mainFrame.param = {
			'menu': "Education_Registration",
			'keyword': "",
			'page': 1,
			'postId': sES_SEQ
			};
		nexacro.getApplication().gv_mainFrame.gfnGoMain();
	
	}else if(e.cell == 0){  
		var nCellIdx  = e.cell;
		//체크 여부 확인
		var sChk = this.ds_EduRegList.getColumn(nRow,"CHK");
		if(sChk == 0){
			if (this.mHeadChk == "1")
			{
				//Head의 값을 체크해제로 설정
				obj.setCellProperty("head", nCellIdx, "text", "0");
				this.mHeadChk="0";
			}
		}else{
			if(this.ds_EduRegList.findRow("CHK",0)==-1){
				obj.setCellProperty("head", nCellIdx, "text", "1");
				this.mHeadChk="1";
			}
		}
	}
}


// 제품 선택 이벤트
this.tabProduct_onchanged = function(obj:nexacro.Tab,e:nexacro.TabIndexChangeEventInfo)
{
	var sProd = "";
	switch(e.postindex) {
	case 0:
		sProd = "NPN";
		break;
	case 1:
		sProd = "NP17";
		break;
	case 2:
		sProd = "NP14";
		break;
	case 3:
		sProd = "XP";
		break;
	default:
	}
	this.ds_EduRegList.reset();
	this.ds_EduRegList.filter("EDU_PRODUCT_CODE == '" + sProd + "'");
	this.ds_RegHistory.reset();
	this.ds_RegHistory.filter("EDU_PRODUCT_CODE == '" + sProd + "'");
	this.pageMoveCd = e.postindex;
	
	this.grdEduCondition.setCellProperty("head",0,"text","0");
	this.mHeadChk="0";
};

//신청 취소 버튼 클릭 이벤트
this.btn_ProdDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sRowCount = this.ds_EduRegList.getRowCount();
	this.mChkCount = -1;    
	
	if(this.ds_EduRegList.findRow("CHK",1) == -1){
		alert("선택된 교육이 없습니다.");
	}else{
		if(nexacro.getApplication().com_ConfirmMessage("MSG_000105", false))
		{
			for(var i =0; i< sRowCount;i++){
				var sChk= this.ds_EduRegList.getColumn(i,"CHK");
				if(sChk == "1"){
					this.mChkRows.push(i);
					this.mChkCount += 1;
				}
			}
		}else{
			return false;
		}
		this.fn_ProdDelete();
	}
};

//교육 취소 함수
this.fn_ProdDelete= function(){


		var sUserId = nexacro.getApplication().gds_UserInfo.getColumn(0, "User_id");
		var sEslSeq = this.ds_EduRegList.getColumn(this.mChkRows[this.mChkCount], "ESL_SEQ");
		var strArgs = "RTYPE=XML DB='CS'"
					+ " sessionChk=false"
					+ " nationCd='"    + nexacro.getApplication().gv_NationCd + "'"
					+ " JSESSIONID='"  + nexacro.getApplication().JSESSIONID  + "'"
					+ " sUserId='"     + sUserId                 + "'"
					+ " sEslSeq='"     + sEslSeq                 + "'";
		var strUrl = "SVC_JSP::Next_JSP/Education/SaveCancel.jsp?";
		var strDsInput = "";
		var strDsOutput = "";
		this.mChkCount -= 1;
		this.com_TransSend("EduRegCancel",strUrl,strDsInput,strDsOutput,strArgs,"fn_CallBack");

}

//그리드 헤드 클릭 이벤트
this.grdEduCondition_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	
	//그리드 전체체크/체크해제 실행 함수 호출
	if(e.cell==0)
	{	
		this.gfnSetGridCheckAll(obj, e);
	}
};

//그리드 전체체크/체크해제 실행 함수
this.gfnSetGridCheckAll = function (obj, e)
{
	var objDs;
	var nCellIdx  = e.cell;
	var sColumnId;
	
	//그리드에 연결된 데이터셋 가져오기
	objDs  = obj.getBindDataset();
	
	//데이터셋에 데이터가 없을 경우 리턴
	if(objDs.rowcount < 1) return;
	
	//전체 체크/체크해제할 컬럼명 구하기
	sColumnId = obj.getCellProperty("body", nCellIdx, "text");
	sColumnId = sColumnId.toString().replace("bind:", "");
		
	//Head의 현재 Check설정 값 가져오기
	this.mHeadVal = obj.getCellProperty("head", nCellIdx, "text");

	//현재 체크상태일 경우
	if (this.mHeadVal == "1" )
	{
		//Head의 값을 체크해제로 설정
		obj.setCellProperty("head", nCellIdx, "text", "0");
		this.mHeadChk="0";
	}
	//현재 체크해제상태일 경우
	else {
		//Head의 값을 체크로 설정
		obj.setCellProperty("head", nCellIdx, "text", "1");
		this.mHeadChk="1";
	}
	
	// Body에 전체 체크/체크해제 상태 적용
	for(var i=0 ; i< objDs.rowcount ; i++) 
	{
		objDs.setColumn(i, sColumnId, this.mHeadChk);
	}

};

//수료증 발급 클릭
this.grdEduHistory_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if(e.cell == 6){
    	if(this.ds_RegHistory.getColumn(e.row, "ATTEND_FLAG") == "1"){
	
    		this.fn_EduCertificate();
    	}      
    }
};

//수료증 발급 함수
this.fn_EduCertificate = function()   
{   
        	    	    	    
	this.ds_print.clearData();
    this.ds_print.addRow();
     				   
    this.ds_print.setColumn(this.ds_print.rowposition,"cer_no",this.ds_RegHistory.getColumn(this.ds_RegHistory.rowposition,"cer_no"));
    this.ds_print.setColumn(this.ds_print.rowposition,"req_nm",this.ds_RegHistory.getColumn(this.ds_RegHistory.rowposition,"EMP_NAME"));
    this.ds_print.setColumn(this.ds_print.rowposition,"company_nm",this.ds_RegHistory.getColumn(this.ds_RegHistory.rowposition,"COMPANY_NAME"));
    
    var sPcode = this.ds_RegHistory.getColumn(this.ds_RegHistory.rowposition, "EDU_PRODUCT_CODE");
    var sCourseNm = ""
    if(sPcode == "NP17") sCourseNm = "nexacro platform 17™ " + this.ds_RegHistory.getColumn(this.ds_RegHistory.rowposition, "EDU_DET_NAME");
    if(sPcode == "NP14") sCourseNm = "nexacro platform 14™ " + this.ds_RegHistory.getColumn(this.ds_RegHistory.rowposition, "EDU_DET_NAME");
    if(sPcode == "XP")   sCourseNm = "X-Internet 및 XPLATFORM™ v9.2(엑스플랫폼)";
    if(sPcode == "MP")   sCourseNm = "X-Internet 및 Miplatform™ v3.3(마이플랫폼)";
    		
    this.ds_print.setColumn(this.ds_print.rowposition,"course_nm",sCourseNm);
    this.ds_print.setColumn(this.ds_print.rowposition,"product_nm",this.ds_RegHistory.getColumn(this.ds_RegHistory.rowposition,"product_name"));
    	
    this.ds_print.setColumn(this.ds_print.rowposition,"period",this.ds_RegHistory.getColumn(this.ds_RegHistory.rowposition,"START_DATE") + " ~ " + this.ds_RegHistory.getColumn(this.ds_RegHistory.rowposition,"END_DATE"));
        	
    this.ds_print.setColumn(this.ds_print.rowposition,"yyyy",this.ds_RegHistory.getColumn(this.ds_RegHistory.rowposition,"yyyy"));
    this.ds_print.setColumn(this.ds_print.rowposition,"mm",this.ds_RegHistory.getColumn(this.ds_RegHistory.rowposition,"mm"));
    this.ds_print.setColumn(this.ds_print.rowposition,"dd",this.ds_RegHistory.getColumn(this.ds_RegHistory.rowposition,"dd"));
       	 
        	
    this.ds_print.setColumn(this.ds_print.rowposition,"getTime",this.ds_RegHistory.getColumn(this.ds_RegHistory.rowposition,"getTime"));
    this.ds_print.setColumn(this.ds_print.rowposition,"EMAIL",this.ds_RegHistory.getColumn(this.ds_RegHistory.rowposition,"EMAIL"));
    this.ds_print.setColumn(this.ds_print.rowposition,"ESL_SEQ",this.ds_RegHistory.getColumn(this.ds_RegHistory.rowposition,"ESL_SEQ"));
        	
    this.transaction("fn_EduCertificate"
                    ,"SVC_JSP::Next_JSP/Education/EduCertificate.jsp?"
                    ,"in_print=ds_print:U"
                    ,""
                    ,""
                    ,"fn_CallBack");
};




this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	trace(this.ds_EduRegList.saveXML());
};
]]></Script>
  </Form>
