    <Layouts>
      <Layout>
        <Tab id="tabProduct" taborder="0" tabindex="0" left="0" top="0" width="1300" height="66" cssclass="tab_WF_product" onchanged="tabProduct_onchanged" accessibilitylabel="접수현황" focusacceptable="true" initvalueid="iv_Tab0">
