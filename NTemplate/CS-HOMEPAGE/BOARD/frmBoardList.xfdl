// 검색 에디트 이벤트
this.divCondition_edtKeyword_onkeyup = function(obj:Edit, e:nexacro.KeyEventInfo)
{
	//Tip 게시판일 때만 동작하도록
	if (nexacro.getApplication().gv_CurMenu == "Tip") {
		this.div_autoCompleteCover.form.sta_autoCompleteResult.visible = true;
	} else {
		this.div_autoCompleteCover.form.sta_autoCompleteResult.visible = false;
	}
	
	//열려있는 연관검색어 Div 닫기
	nexacro.getApplication().gv_mainFrame.showAutoCompleteResult(false);
	nexacro.getApplication().gv_mainFrame.Search_divCover = this.div_autoCompleteCover;
	nexacro.getApplication().gv_mainFrame.Search_div = this.div_autoCompleteCover.form.div_autoCompleteResult;
	nexacro.getApplication().gv_mainFrame.Search_Edit = obj;		
	
	if(e.keycode == 13)  
	{    
		// 검색 데이터 저장
		this.fn_saveHistoryData();
		
		nexacro.getApplication().gv_mainFrame.Board_Cond_Resetflag = true;
		nexacro.getApplication().gv_mainFrame.QA_Cond_Page = 1;    
		nexacro.getApplication().gv_mainFrame.QA_Cond_startPageNo = 0;

		this.fn_Query();
		nexacro.getApplication().gv_mainFrame.fn_SearchKey_onkeyup(obj, e);
	}
	else
	{
		nexacro.getApplication().gv_mainFrame.Top_Edit_flag = false;
		nexacro.getApplication().gv_mainFrame.fn_SearchKey_onkeyup(obj, e);
	}	
}

// expr : 그리드의 내용을 2줄까지 제한  ->  autosizerow로 변경해서 사용안하므로 확인후 삭제
this.fnGrdContentLimit = function(sStr)
{
	sStr = nexacro.replaceAll(sStr, "&nbsp;", "");
	sStr = nexacro.replaceAll(sStr, "<br>", "\n\n");
	sStr = nexacro.replaceAll(sStr, "<BR>", "\n\n");
	//<fc v='#ff0000'>
	sStr = nexacro.replaceAll(sStr, "<fc v='#ff0000'>", "##DECORATE##");
	sStr = nexacro.replaceAll(sStr, "</fc>", "$$DECORATE$$");
	sStr = sStr.replace(/(<([^>]+)>)/ig,"");
	sStr = nexacro.replaceAll(sStr, "##DECORATE##", "<fc v='#ff0000'>");
	sStr = nexacro.replaceAll(sStr, "$$DECORATE$$", "</fc>");
	sStr = sStr.replaceAll("\n\n", "\n");
 	sStr = sStr.split("\n");
	
	var s0 = "";
	var s1 = "";
	if (sStr[0])
	{
		s0 = sStr[0];
	}
	if (sStr[1])
	{
		s1 = "\n"+sStr[1];
	}

	return s0+s1;//+s2;
};

// html태그 제거	->   CONTENTS_TEXT를 내려주면서 사용하지 않음
this.fn_deleteTag = function(sStr)
{
	sStr = nexacro.replaceAll(sStr, "&nbsp;", "");
	
	sStr = nexacro.replaceAll(sStr, "<br>", "\n\n");
	sStr = nexacro.replaceAll(sStr, "<BR>", "\n\n");
	sStr = sStr.replace(/(<([^>]+)>)/ig,"");
	if (sStr.indexOf("\n") == 0)
	{
		sStr = nexacro.replace("\n", "");
	}
	
	return sStr;
};

// 제목 글자수제한을 위한 함수 ===================================================
this.fnGridSubjectLimit = function(sStr)
{
	return this.fn_subString( sStr, 0, 80 );
};


// 문자열의 길이를 구하는 함수
this.fn_strlen = function(str)
{
	var len = 0;
	for(var i=0;i<str.length;i++) {
		len += (str.charCodeAt(i) > 128) ? 2 : 1;
	}
	return len;
};

// 문자열에서 시작위치와 길이를 주면 substring 하여 리턴한다.
this.fn_subString = function(str,start,size)
{
	var lim = 0;
	var pos = 0;
	var beg = 0;
	var minus = 0;
	var len = this.fn_strlen(str);

	// 시작위치까지 skip하는 로직
	for(var i=0;pos<start;i++) {
		pos += (str.charCodeAt(i) > 128) ? 2 : 1;
	}

	beg = i;

	// 시작위치에서 길이만큼 잘라내는 로직
	for (var i=beg; i<len; i++) {
		lim += (str.charCodeAt(i) > 128) ? 2 : 1;

		if (lim > size) {
			return str.substring(beg,i)+"..."; 
		}
	}
	return str;
};



