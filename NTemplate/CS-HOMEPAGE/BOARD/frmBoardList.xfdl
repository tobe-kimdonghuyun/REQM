//div 동적생성
this.fn_createList = function()
{
	var PCategoryGubun = nexacro.getApplication().gv_mainFrame.PCategory2;
	var nRowCnt = this.ds_NoticeList.rowcount;
	
	var nLeft 	= 0;
	var nTop 	= 0;
	var nHeight = 226;
	var nRight 	= 0;
	var sDivId 	= "divNoticeList";
	var sUrl 	= "";
	
 	switch(PCategoryGubun) {
		case "Notice":
			sUrl = "BOARD::frmBoardList_02_Notice.xfdl";
			nHeight = 91;
			break;
		case "Tip_N":
		case "Tip_17":
		case "Tip_14":
		case "Tip_XP":
		case "Tip_MP":
			sUrl = "BOARD::frmBoardList_01_Tip.xfdl";
			nHeight = 226;
			break;
		case "Education_information":
			sUrl = "BOARD::frmBoardList_02_Notice.xfdl";
			nHeight = 85;
			break;
		case "Education_material":
			sUrl = "BOARD::frmBoardList_02_Notice.xfdl";
			nHeight = 85;
			break;
		case "Education_Review":
			sUrl = "BOARD::frmBoardList_04_Notice_Edu.xfdl";
			nHeight = 180;
			break;
		case "Bookmark_Tip":
			//북마크 콤보박스 아이템 수정 시
			//var nListType = nexacro.getApplication().gv_mainFrame.QA_Cond_ListType;
			var nListType = this.cboListType.index; //북마크Tip 처음 진입 시 QA_Cond_ListType과 상관 없이 상세+타이틀로 셋팅됨.
			if (nListType == 0) {
				sUrl = "BOARD::frmBoardList_01_Tip.xfdl";
				nHeight = 226;		
			} else if (nListType == 1) {
				sUrl = "BOARD::frmBoardList_03_Title.xfdl";
				nHeight = 130;			
			}
		default:
 	}
	
	var nLen = this.viewList.form.divNoticeList.form.components.length;
	for (var i = nLen - 1; i >= 0; i--) {
		var objDel = this.viewList.form.divNoticeList.removeChild(this.viewList.form.divNoticeList.form.components[i].name);
		objDel.destroy();
		objDel = null;		
	}
	
	if (nRowCnt > 0) {
		this.viewList.form.divNoticeList.accessibilityenable = false;
		this.viewList.form.divNoticeList.text = "";
		
		
		for (var i = 0; i < nRowCnt; i++) {
			var newDiv = new Div();
			newDiv.init(sDivId + i, nLeft, nTop, null, nHeight, nRight);
			this.viewList.form.divNoticeList.addChild(newDiv.id, newDiv);
			newDiv.set_url(sUrl);
			newDiv.set_accessibilityenable(false);
			newDiv.show();
			
			if (i != 0) newDiv.prevDiv = this.viewList.form.divNoticeList.form.components[sDivId + (i-1)];
			if (!this.gfnIsNull(newDiv.prevDiv))  newDiv.set_top(newDiv.prevDiv.id+":0");			
			
			nTop = nTop + nHeight;
		}
		
		var lastDiv = this.viewList.form.divNoticeList.form.components[sDivId + (nRowCnt-1)];
		
		this.viewList.form.divNoticeList.set_height(lastDiv.getOffsetBottom());
		this.viewList.set_height(this.viewList.form.divNoticeList.getOffsetHeight());
		this.divPageExpr.set_top(this.viewList.getOffsetBottom() + 40);
		this.viewPaging.set_top(this.viewList.getOffsetBottom() + 40);	
		this.resetScroll();
	}	
};


// 주요공지사항 동적 div 생성
this.fn_createImpList = function(nCnt)
{
	var nRowCnt = nCnt;

	var nLeft 	= 0;
	var nTop 	= 0;
	var nHeight = 85;
	var nRight 	= 0;
	var sDivId 	= "divImpList";
	var sUrl 	= "BOARD::frmBoardList_05_Imp.xfdl";
	
	var nLen = this.divImpList.form.components.length;
	
	for (var i = nLen - 1; i >= 0; i--) {
		var objDel = this.divImpList.removeChild(this.divImpList.form.components[i].name);
		objDel.destroy();
		objDel = null;		
	}
	
	if (nRowCnt > 0) {
		this.divImpList.accessibilityenable = false;
		this.divImpList.text = "";
		
		
		for (var i = 0; i < nRowCnt; i++) {
			var newDiv = new Div();
			newDiv.init(sDivId + i, nLeft, nTop, null, nHeight, nRight);
			this.divImpList.addChild(newDiv.id, newDiv);
			newDiv.set_url(sUrl);
			newDiv.set_accessibilityenable(false);
			newDiv.show();
			
			nTop = nTop + nHeight;

			if (i != 0) newDiv.prevDiv = this.divImpList.form.components[sDivId + (i-1)];
			if (!this.gfnIsNull(newDiv.prevDiv))  newDiv.set_top(newDiv.prevDiv.id+":0");
		}
		
		var lastDiv = this.divImpList.form.components[sDivId + (nRowCnt-1)];
		
		this.divImpList.visible = true;
		this.divImpList.set_height(lastDiv.getOffsetBottom());
		this.viewList.set_top(this.divImpList.getOffsetBottom());
	}	
};


//제목 클릭
this.fn_BoardstaTitle_onclick = function(nRow, gubun)
{       
	var nFindRow = nexacro.getApplication().gv_mainFrame.dsScreenUrl.findRow("subCatgy", nexacro.getApplication().gv_mainFrame.param.menu);
	var sLayout = nexacro.getApplication().gv_mainFrame.dsScreenUrl.getColumn(nFindRow, "Layout");
		
	if(sLayout == "BOOKMARK")
	{
		nexacro.getApplication().gv_BookmarkTipCd = nexacro.getApplication().gv_mainFrame.divMain.form.divBookmark.form.tabProduct.tabindex;
	}

 
	nexacro.getApplication().gv_mainFrame.Board_Cond_Resetflag = false;
	//var dsDataCur = eval("this."+obj.binddataset);
	var dsDataCur = this.ds_NoticeList;
	this.rowNum = dsDataCur.getColumn(nRow, "rowNum");
	var strAn = dsDataCur.getColumn(nRow, "BL_SEQ");
	var strBoardid = dsDataCur.getColumn(nRow, "boardid");
	var strGoodsgbn = dsDataCur.getColumn(nRow,"goods_gbn");

	var ProductGubun="MiPlatform";
	if(strGoodsgbn  == "001")
	{
		ProductGubun = "MiPlatform";		
	} else if(strGoodsgbn == "002")
	{
		ProductGubun = "XPLATFORM";		
	} else if(strGoodsgbn == "003")
	{   
		ProductGubun = "X-UP(difingo)";		
	} else if(strGoodsgbn == "004")   
	{
		ProductGubun = "X-PUP";		
	} else if(strGoodsgbn == "005")
	{ 
		ProductGubun = "X-PUSH";		
	} else if(strGoodsgbn == "006")
	{
		ProductGubun = "nexacro platform";		
	} else if(strGoodsgbn == "008")
	{
		ProductGubun = "nexacro platform17";		
	}  
	
	nexacro.getApplication().gv_mainFrame.strTempFilder1 = strAn;  
	nexacro.getApplication().gv_mainFrame.BoardCategoryID = strGoodsgbn;       
   
	nexacro.getApplication().gv_mainFrame.Board_Cond_DisplayCnt  = this.divPageExpr.unitSelRowNo;
	nexacro.getApplication().gv_mainFrame.Board_Cond_Page        = (this.divPageExpr.startPageNo+1); 
	nexacro.getApplication().gv_mainFrame.Board_Cond_Searchfield = this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition,"searchfield");
	nexacro.getApplication().gv_mainFrame.Board_Cond_Searchgubun = this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition,"searchgubun");
	nexacro.getApplication().gv_mainFrame.Board_Cond_BusinessSection = this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition,"BusinessSection");
	nexacro.getApplication().gv_mainFrame.Board_Cond_Resort = this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition,"search_resort");	
	nexacro.getApplication().gv_mainFrame.Board_Cond_Keyword = this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition,"keyword");	  
	nexacro.getApplication().gv_mainFrame.Board_Cond_KeywordAll = this.ds_SearchParam.getColumn(this.ds_SearchParam.rowposition,"keywordall");	  

	// sMenu 셋팅
	var sMenu = "Notice_View";
	switch(nexacro.getApplication().gv_mainFrame.PCategory2) {
	case "Notice":
		sMenu = "Notice_View";
		break;
	case "Tip_N":
		sMenu = "Tip_View_N";
		break;
	case "Tip_17":
		sMenu = "Tip_View_17";
		break;
	case "Tip_14":
		sMenu = "Tip_View_14";
		break;
	case "Tip_XP":
		sMenu = "Tip_View_XP";
		break;
	case "Tip_MP":
		sMenu = "Tip_View_MP";
		break;
	case "Education_information":
		sMenu = "Education_information_View";
		break;
	case "Education_material":
		sMenu = "Education_material_View";
		break;
	case "Education_Review":
		sMenu = "Education_Review_View";
		break;
	case "Bookmark_Tip":
		sMenu = "Bookmark_Tip_View";
		nexacro.getApplication().gv_mainFrame.Bookmark_Tab_Index = nexacro.getApplication().gv_mainFrame.divMain.form.divBookmark.form.tabProduct.tabindex;
		break;
	case "SearchEngine":
		sMenu = "SearchEngine_Board_View";
		break;
	default:
	}
	
	// 현재 스크롤 위치 저장
	nexacro.getApplication().gv_mainFrame.SCROLL_POS = nexacro.getApplication().gv_mainFrame.vscrollbar.pos;
	
	nexacro.getApplication().gv_mainFrame.param = {
		'menu': sMenu,
		'keyword': nexacro.getApplication().gv_mainFrame.QA_Cond_Keyword,
		'page': nexacro.getApplication().gv_mainFrame.QA_Cond_Page,
		'postId': strAn
		};
	nexacro.getApplication().gv_mainFrame.gfnGoMain();
};


//링크복사 버튼 클릭
this.btnLink_onclick = function(nRow)
{
	var sMenu = nexacro.getApplication().gv_mainFrame.PCategory2.substr(0, 3)+"_View" +nexacro.getApplication().gv_mainFrame.PCategory2.substr(3);
	prompt("클립 보드에 복사하세요 : Ctrl 키 + C", nexacro.getApplication().gv_DomainInfo+"?menu="+sMenu+"&postid="+this.ds_NoticeList.getColumn(nRow, "BL_SEQ"));
};
]]></Script>
