// 통합검색용 페이징 버튼이벤트
this.viewPaging_btnPageNum_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	nexacro.getApplication().gv_searchEngine.fn_search(obj.text);
	//페이징 처리될 때마다, url를 히스토리에 기록한다.
	this.fn_SetHistoryData();
};

// 통합검색용 페이징 이전버튼
this.viewPaging_btnPagePre_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	nexacro.getApplication().gv_searchEngine.fn_search(parseInt(nexacro.getApplication().gv_searchEngine.fvPageNum)-1);
	//페이징 처리될 때마다, url를 히스토리에 기록한다.
	this.fn_SetHistoryData();
};

// 통합검색용 페이징 다음버튼
this.viewPaging_btnPageNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	nexacro.getApplication().gv_searchEngine.fn_search(parseInt(nexacro.getApplication().gv_searchEngine.fvPageNum)+1);
	//페이징 처리될 때마다, url를 히스토리에 기록한다.
	this.fn_SetHistoryData();
};

// 통합검색용 페이징 이전10개 버튼
this.viewPaging_btnPageHome_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var nstartPageNum = 1;
	if (nexacro.getApplication().gv_searchEngine.fvPageNum > 10)
	{
		nstartPageNum = nexacro.floor(nexacro.getApplication().gv_searchEngine.fvPageNum/10)*10+1;
	}
	nexacro.getApplication().gv_searchEngine.fn_search(nstartPageNum-10);
	//페이징 처리될 때마다, url를 히스토리에 기록한다.
	this.fn_SetHistoryData();
};

// 통합검색용 페이징 다음10개 버튼
this.viewPaging_btnPageEnd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var nstartPageNum = 1;
	if (nexacro.getApplication().gv_searchEngine.fvPageNum > 10)
	{
		nstartPageNum = nexacro.floor(nexacro.getApplication().gv_searchEngine.fvPageNum/10)*10+1;
	}
	nexacro.getApplication().gv_searchEngine.fn_search(nstartPageNum+10);
	//페이징 처리될 때마다, url를 히스토리에 기록한다.
	this.fn_SetHistoryData();
};

// 페이징 번호 초기화
this.fn_pageNumInit = function(pageNum, total)
{
	var sBtnNum = pageNum%10;
	if (sBtnNum == 0)
	{
		sBtnNum = 10;
	}

	var nLastCnt = 0;// = total%10;
	if (total%10 != 0)
	{
		nLastCnt = nexacro.floor(total/10)%10 + 1;
	}
	else
	{
		nLastCnt = nexacro.floor(total/10)%10;
	}
	var nstartPageNum = 1;
	if (pageNum > 10)
	{
		nstartPageNum = nexacro.floor((pageNum-1)/10)*10+1;
	}
	if (nLastCnt == 0)
	{
		nLastCnt = 10;
	}
	// 각 숫자 셋팅
	var i;
	for (i = 0; i < 10; i++)
	{
		eval("this.viewPaging.form.btnPageNum"+(i+1)+".set_text("+(nstartPageNum+i)+");");
		if (nexacro.floor(total/10) < nstartPageNum+10 && nLastCnt <= i)
		{
			eval("this.viewPaging.form.btnPageNum"+(i+1)+".set_visible(false);");
		}
		else
		{
			eval("this.viewPaging.form.btnPageNum"+(i+1)+".set_visible(true);");
		}
	}
	
	// cssclass 셋팅
	this.viewPaging.form.btnPageHome.set_enable(true);
	this.viewPaging.form.btnPagePre.set_enable(true);
	this.viewPaging.form.btnPageNum1.set_cssclass("btn_WF_pageNum");
	this.viewPaging.form.btnPageNum2.set_cssclass("btn_WF_pageNum");
	this.viewPaging.form.btnPageNum3.set_cssclass("btn_WF_pageNum");
	this.viewPaging.form.btnPageNum4.set_cssclass("btn_WF_pageNum");
	this.viewPaging.form.btnPageNum5.set_cssclass("btn_WF_pageNum");
	this.viewPaging.form.btnPageNum6.set_cssclass("btn_WF_pageNum");
	this.viewPaging.form.btnPageNum7.set_cssclass("btn_WF_pageNum");
	this.viewPaging.form.btnPageNum8.set_cssclass("btn_WF_pageNum");
	this.viewPaging.form.btnPageNum9.set_cssclass("btn_WF_pageNum");
	this.viewPaging.form.btnPageNum10.set_cssclass("btn_WF_pageNum");
	this.viewPaging.form.btnPageNext.set_enable(true);
	this.viewPaging.form.btnPageEnd.set_enable(true);
	
	if (pageNum <= 10)
	{
		this.viewPaging.form.btnPageHome.set_enable(false);
	}
	if (pageNum == 1)
	{
		this.viewPaging.form.btnPagePre.set_enable(false);
	}
	eval("this.viewPaging.form.btnPageNum"+sBtnNum+".set_cssclass('btn_WF_pageNum_S');");
	
	if (pageNum == nexacro.ceil(total/10))
	{
		this.viewPaging.form.btnPageNext.set_enable(false);
	}
	if (nexacro.floor(total/10) < nstartPageNum+10)
	{
		this.viewPaging.form.btnPageEnd.set_enable(false);
	}
};

// 페이징용 히스토리 셋팅
this.fn_SetHistoryData = function()
{
	var sData = {};
	
	var sHash = "menu=" + nexacro.getApplication().gv_mainFrame.param.menu + "&page=" + nexacro.getApplication().gv_mainFrame.QA_Cond_Page;
	var sKeyword = nexacro.getApplication().gv_mainFrame.param.keyword;
	if(!this.gfnIsNull(sKeyword)) sHash += "&keyword="+sKeyword;
	var sUrl = ".?"+sHash;
	sData = nexacro.getApplication().gv_searchEngine.fn_savePagingData();
	MyHistory.setLocationHash(sHash, sData, sUrl);
};
