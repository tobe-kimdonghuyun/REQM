// cboListType 변경 이벤트    제목 <-> 제목+내용   토글
this.cboListType_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	if (e.postindex == 0)
	{
		this.viewList.form.grdNoticeList.set_formatid("tip");
		nexacro.getApplication().gv_mainFrame.QA_Cond_ListType = 0;
		this.fn_createList();
		this.fn_SetInitSize();
	}
	else
	{
		this.viewList.form.grdNoticeList.set_formatid("title");
		nexacro.getApplication().gv_mainFrame.QA_Cond_ListType = 1;
		this.fn_createList();
		this.fn_SetInitSize();
	}
};

