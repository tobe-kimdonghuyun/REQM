	contents += '</tr>\n';
	contents += '<tr>\n';
	contents += '<th style="padding: 15px 0 15px 10px;width: 15%;color: #999;font-weight: 400;border-bottom: 1px solid #dee1ee;">제목</th>\n';
	contents += '<td style="padding: 15px 10px;width: auto;color: #333;font-weight: 500;border-bottom: 1px solid #dee1ee;">'+this.ds_NoticeDetail.getColumn(0, "SUBJECT")+'</td>\n';
	contents += '</tr>\n';
	contents += '<tr>\n';
	contents += '<th style="padding: 15px 0 15px 10px;width: 15%;color: #999;font-weight: 400;border-bottom: 1px solid #dee1ee;">내용</th>\n';
	contents += '<td style="padding: 15px 10px;width: auto;color: #666;font-weight: 400;border-bottom: 1px solid #dee1ee;">'+this.ds_NoticeDetail.getColumn(0, "content")+'</td>\n';
	contents += '</tr>\n';
	contents += '</table>\n';
	contents += '</div>\n';
	contents += '<div style="padding: 30px 0;text-align: center;color: #999;font-size: 14px;background-color: #eee;">\n';
	contents += '<p style="margin: 0; padding-bottom: 10px;">\n';
	contents += '서울시 강남구 봉은사로 617-2 5F |  고객지원센터 : 1588-7895  |  이메일 : helpdesk@tobesoft.com\n';
	contents += '</p>\n';
	contents += '<p style="margin: 0; padding-bottom: 10px;">\n';
	contents += 'Copyright © 2022. TOBESOFT. All rights reserved.\n';
	contents += '</p>\n';
	contents += '</div>\n';
	contents += '</div>\n';
	contents += '</body>\n';
	contents += '</html>\n';
	
	var objAry = contents.split("\n");	
	
	var strContent = "";	
	for(var i = 0; i < objAry.length; i++)
	{
		strContent += objAry[i] +"<\BR>";
	}	
	
	this.ds_sendmail.setColumn(0, "subject", subject);
	this.ds_sendmail.setColumn(0, "mailto", mailto);
	this.ds_sendmail.setColumn(0, "contents", contents);
	this.ds_sendmail.setColumn(0, "mailFrom", "helpdesk@tobesoft.com");
		
	if(this.gfnIsNull(mailto))
	{
		this.alert("메일주소를 입력해 주세요");
	}
	
	this.fn_saveData();
	this.divEmail.set_visible(false);
};


// 이메일 보내기 transaction
this.fn_saveData = function()
{	
	var strURL = "SVC_JSP::Next_JSP/Support/sendMail.jsp";	
	this.transaction("sendMail",strURL,"dsMail=ds_sendmail:A File=ds_downloadfile:A","dsReturn=dsMail","","fnCallBack");	
}

// 이메일 보내기 콜백
this.fnCallBack = function(svcid, errCode, errMsg)
{
	if(errCode < 0)
	{
		alert("메일 발송에 실패 하였습니다.");
		return;
	}
	if(svcid == "sendMail")
	{
		//nexacro.setPrivateProfile("get_email", this.pdivEmail.form.edtEmail.value);
		nexacro.setPrivateProfile("get_email", this.divEmail.form.edtEmail.value);
		alert("메일 전송이 완료 되었습니다.");	
	}
}

// 이메일 보내기 엔터키로 보내기
this.pdivEmail_edtEmail_onkeyup = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if (e.keycode == 13)
	{
		this.pdivEmail.form.btnSendEmail.click();
	}
};

this.divEmail_edtEmail_onkeyup = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if (e.keycode == 13)
	{
		this.divEmail.form.btnSendEmail.click();
	}	
};


// 파일 다운로드 pdiv 선택 이벤트
this.pdivFiles_grdFiles_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if (e.cell == 0 || e.cell == 1)
	{
		// 바로 다운로드
		this.FileDownload00.set_downloadurl(this.ds_downloadfile.getColumn(e.row, "URL"));
		this.FileDownload00.download();
	}
	else if (e.cell == 2)	// 파일 소스보기 팝업 호출
	{
		if (!this.fn_exprFileChk(e.row))
		{
			return;
		}
		var objFrame = new ChildFrame();
		var objParentFrame = this.getOwnerFrame();

		var nLeft = nexacro.getApplication().gv_mainFrame.getOffsetWidth()/2 - 400;
		var nTop = nexacro.getApplication().gv_mainFrame.getOffsetHeight()/2 - 470;
		objFrame.init( "modalContent", nLeft, nTop, 800, 800 );
		objFrame.set_titletext("소스보기");
		objFrame.set_titlebarheight(40);
		objFrame.set_formurl( "COMMFORM::frmFileViewer.xfdl" );

		var vRtn = objFrame.showModal( objParentFrame, {dsNM:this.ds_downloadfile,nRow:this.ds_downloadfile.rowposition}, this, this.fn_callback );
	}
};

// 소스보기 가능 확장자 정의(체크)
this.ext_Array = new Array("xml","xfdl","js","xjs","html","jsp","txt","xadl","asp","csv", "css","xcss");
this.fn_exprFileChk = function(nRow)
{
	var ext = this.get_FlieExt(this.ds_downloadfile.getColumn(nRow,"SAVE_FILE_NAME"));
	var chk = false;
	for(var i=0; i<this.ext_Array.length; i++){
		if( this.ext_Array[i] == ext ) {
			chk = true;
			break;
		}
	}
	return chk;
}

this.get_FlieExt = function(filename)
{
	var fileSplit = filename.split('.');
	var fileExt = '';
	if (fileSplit.length > 1) {
		fileExt = fileSplit[fileSplit.length - 1];
	} 
	return fileExt;
}

// 온타이머
this.noticeView_ontimer = function(obj:nexacro.Form,e:nexacro.TimerEventInfo)
{
	this.killTimer(e.timerid);
	if (e.timerid == 111)
	{
		this.nRes = this.getHTMLValue1("getContentHeight");
	}
};


this.divEmail_edtEmail_onchanged = function(obj:nexacro.Edit,e:nexacro.ChangeEventInfo)
{
	
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="staResTitle" propid="text" datasetid="ds_NoticeDetail" columnid="SUBJECT"/>
      <BindItem id="item2" compid="btnAttachFile" propid="text" datasetid="ds_downloadfile" columnid="FILE_NAME"/>
    </Bind>
  </Form>
</FDL>
