this.pdivEmail_btnSendEmail_onclick = function(obj:Button,  e:nexacro.ClickEventInfo)
{	
	var staTitle;

	staTitle = "팁 게시판";
	var subject  = "투비소프트 " + staTitle +" [" +  this.ds_NoticeDetail.getColumn(0, "BL_SEQ") + "] 게시물 입니다";
	var mailto   = this.pdivEmail.form.edtEmail.value;		
	var contents = "";

	contents += '<!DOCTYPE html>\n';
	contents += '<html style="margin: 0;padding: 0;border: 0;font-size: 100%;font: inherit;vertical-align: baseline;font-family: Noto Sans KR, sans-serif;">\n';
	contents += '<head>\n';
	contents += '<meta charset="utf-8">\n';
	contents += '<meta http-equiv="X-UA-Compatible" content="IE=edge">\n';
	contents += '<title>아이디/비밀번호찾기 안내입니다.</title>\n';
	contents += '<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/normalize/8.0.1/normalize.min.css" />\n';
	contents += '<link rel="preconnect" href="https://fonts.googleapis.com">\n';
	contents += '<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>\n';
	contents += '<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">\n';
	contents += '</head>\n';
	contents += '<body style="margin: 0;padding: 0;border: 0;font-size: 100%;font:inherit;vertical-align: baseline;line-height: 1;\n';
	contents += 'background-color: #fafafa;">\n';
	contents += '<div style="margin:0px auto;width: 700px;height: 100%;background-color: #fff;letter-spacing: -1;">\n';
	contents += '<div style="padding: 23px 40px 40px 40px;height: auto;background: url(http://support.tobesoft.co.kr/portal/Mail/images/05-5.png) no-repeat;color:#fff;">\n';
	contents += '<h1 style="margin: 0;position: relative;padding-bottom: 85px;">\n';
	contents += '<a href="#" target="_blank" style="display: inline-block;"><img src="http://support.tobesoft.co.kr/portal/Mail/images/logo-w.gif"></a>\n';
	contents += '<span style="display: inline-block;position: absolute;top: 0;right: 0;font-size: 16px;">(주)투비소프트 고객지원센터</span>';
	contents += '</h1>\n';
	contents += '<span style="font-size: 46px;line-height: 1.1;"><span style=font-weight:700;>요청하신 소스</span>에 대한<br>내용입니다</span>\n';
	contents += '</div>\n';
	contents += '<div style="padding: 40px 40px;font-size: 16px;color:#555;line-height: 1.5;">\n';
	contents += '<p style="margin: 0; padding-bottom: 30px;">요청하신 팁 게시판 ['+this.ds_NoticeDetail.getColumn(0, "BL_SEQ")+'] 게시물입니다.</p>\n';
	contents += '<table cellpadding="0" cellspacing="0" border="0" style="width: 100%;border-top: 2px solid #666;border-bottom: 2px solid #666;text-align: left;line-height: 1.5;">\n';
	contents += '<tr>\n';
	contents += '<th style="padding: 15px 0 15px 10px;width: 15%;color: #999;font-weight: 400;border-bottom: 1px solid #dee1ee;">등록일</th>\n';
	contents += '<td style="padding: 15px 10px;width: auto;color: #333;font-weight: 500;border-bottom: 1px solid #dee1ee;">'+this.ds_NoticeDetail.getColumn(0, "INSERT_DATE")+'</td>\n';
	contents += '</tr>\n';
	contents += '<tr>\n';
	contents += '<th style="padding: 15px 0 15px 10px;width: 15%;color: #999;font-weight: 400;border-bottom: 1px solid #dee1ee;">제목</th>\n';
	contents += '<td style="padding: 15px 10px;width: auto;color: #333;font-weight: 500;border-bottom: 1px solid #dee1ee;">'+this.ds_NoticeDetail.getColumn(0, "SUBJECT")+'</td>\n';
	contents += '</tr>\n';
	contents += '<tr>\n';
	contents += '<th style="padding: 15px 0 15px 10px;width: 15%;color: #999;font-weight: 400;border-bottom: 1px solid #dee1ee;">내용</th>\n';
	contents += '<td style="padding: 15px 10px;width: auto;color: #666;font-weight: 400;border-bottom: 1px solid #dee1ee;">'+this.ds_NoticeDetail.getColumn(0, "content")+'</td>\n';
	contents += '</tr>\n';
	contents += '</table>\n';
	contents += '</div>\n';
	contents += '<div style="padding: 30px 0;text-align: center;color: #999;font-size: 14px;background-color: #eee;">\n';
	contents += '<p style="margin: 0; padding-bottom: 10px;">\n';
	contents += '서울시 강남구 봉은사로 617-2 5F |  고객지원센터 : 1588-7895  |  이메일 : helpdesk@tobesoft.com\n';
	contents += '</p>\n';
	contents += '<p style="margin: 0; padding-bottom: 10px;">\n';
	contents += 'Copyright © 2022. TOBESOFT. All rights reserved.\n';
	contents += '</p>\n';
	contents += '</div>\n';
	contents += '</div>\n';
	contents += '</body>\n';
	contents += '</html>\n';
	
	var objAry = contents.split("\n");	
	
	var strContent = "";	
	for(var i = 0; i < objAry.length; i++)
	{
		strContent += objAry[i] +"<\BR>";
	}	
	
	this.ds_sendmail.setColumn(0, "subject", subject);
	this.ds_sendmail.setColumn(0, "mailto", mailto);
	this.ds_sendmail.setColumn(0, "contents", contents);
	this.ds_sendmail.setColumn(0, "mailFrom", "helpdesk@tobesoft.com");
		
	if(this.gfnIsNull(mailto))
	{
		this.alert("메일주소를 입력해 주세요");
	}
	
	this.fn_saveData();
	this.pdivEmail.closePopup();
}


