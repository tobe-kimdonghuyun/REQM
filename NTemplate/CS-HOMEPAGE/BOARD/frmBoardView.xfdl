    <Script type="xscript5.1"><![CDATA[/**
*  게시판 상세(Notice, Tip 등)
*
*  @MenuPath 
*  @FileName 		BOARD::frmBoardView.xfdl 
*  @Creator 		김광호
*  @CreateDate 		2022.01.01
*  @LastModifier  
*  @LastModifyDate  
*  @Version 		1.0
*  @Outline 		게시판 상세(Notice, Tip 등)
*  @Desction 
************** 소스 수정 이력 *************************************************
*    date          Modifier            Description
*******************************************************************************
*  2022.01.01      김광호	           최초 생성 
*******************************************************************************
*/

this.iWebSizeCnt=0;
this.LocationUrl;
this.strBoardId;

this.doc = "";
this.sIdx = "";

this.fv_PCategoryGubun = "";

// 웹브라우저 관련
this.nRes = 0;		// html에서 가져온 높이
this.wbHeight1 = 0; // 높이
this.wbHeightLongFlg = false;	// 높이가 길때 FLAG

this.noticeView_onload = function(obj:Form, e:nexacro.LoadEventInfo)
{ 	
 	if(nexacro.getApplication().gds_UserInfo.getRowCount() <= 0 && nexacro.getApplication().gv_mainFrame.PCategory2.substr(0, 8) == "Tip_View")
 	{
 		nexacro.getApplication().gv_mainFrame.TargetUrl = nexacro.getApplication().gv_mainFrame.PCategory2;
		nexacro.getApplication().gv_mainFrame.TargetPostId = nexacro.getApplication().gv_mainFrame.param.postId;
		nexacro.getApplication().gv_mainFrame.param = {
			'menu': "login",
			'keyword': "",
			'page': 1,
			'postId': ""
			};
		nexacro.getApplication().gv_mainFrame.gfnGoMain();
 	} else {
 		this.LocationUrl=window.location;  
		this.webBrowResult.set_url(nexacro.getApplication().gv_DomainInfo+"CKEDITOR/editor/view_admin.html");
 	}
}



// 이전/다음글 조회
this.set_PreNextNo = function(idx,code,kind)
{	
	this.viewNavi.set_visible(true);
	if(nexacro.getApplication().gv_mainFrame.PCategory2 == "Education_Review_View")
	{
		this.viewNavi.set_top("webBrowResult:10");
		this.viewNavi.set_height(0);
		this.viewNavi.set_visible(false);
		this.resetScroll();
		
	}
	nexacro.getApplication().gv_mainFrame.QAKeyNo=idx;	
	this.ds_PreNext.clear();
	nexacro.getApplication().gds_MiWizard.clearData();
	
	this.query = "WHERE "; 
	if( kind == "A05" ){
		this.query += "PRODUCT_CODE IN (" + code + ") AND BOARD_KIND IN (''" + kind +"'') AND";
		//this.query += "PRODUCT_CODE IN (" + nexacro.stripQuote(code) + ") AND BOARD_KIND IN (''" + kind +"'') AND";
	} else {
		this.query += "BOARD_KIND IN (''" + kind +"'') AND";
	}	
	
	var sqlkeyword = "";
	var strTemp = [""];
	if(!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.Board_Cond_Keyword)){
		strTemp = nexacro.getApplication().gv_mainFrame.Board_Cond_Keyword.split(" ");
	}
	
	var searchgubun = nexacro.getApplication().gv_mainFrame.Board_Cond_Searchgubun;
	if (nexacro.getApplication().gv_mainFrame.Board_Cond_Searchfield == "100") {
		for (var i = 0; i < strTemp.length; i++) {
				sqlkeyword += " SUBJECT like N''%" + strTemp[i] + "%'' or CONTENTS like N''%" + strTemp[i] + "%''";			
			if (i == (strTemp.length - 1)) {
				sqlkeyword += " ) ";
			} else {
				sqlkeyword += " " + searchgubun + " ";
			}
		}
		this.condSQL += sqlkeyword;
	} else if (nexacro.getApplication().gv_mainFrame.Board_Cond_Searchfield == "200") {
		for (var i = 0; i < strTemp.length; i++) {
				sqlkeyword += " SUBJECT like N''%" + strTemp[i] + "%''";			
			if (i == (strTemp.length - 1)) {
				sqlkeyword += " ) ";
			} else {
				sqlkeyword += " " + searchgubun + " ";
			}
		}
		this.condSQL += sqlkeyword;	
	} else if (nexacro.getApplication().gv_mainFrame.Board_Cond_Searchfield == "300") {
		for (var i = 0; i < strTemp.length; i++) {
				sqlkeyword += " CONTENTS like N''%" + strTemp[i] + "%''";			
			if (i == (strTemp.length - 1)) {
				sqlkeyword += " ) ";
			} else {
				sqlkeyword += " " + searchgubun + " ";
			}
		}		
	}			
	
    this.condSQL = this.query + " ( " + sqlkeyword ;
    
	var args = "query='" + this.condSQL + "'&idx="+idx;
	var objEnv = nexacro.getEnvironment();
	objEnv.set_usewaitcursor( true );

	nexacro.getApplication().com_AddMiWizard("","output1",args,"CS,cs_request_proc,35");	
	this.com_CallService("selectNo", "", "", "ds_PreNext=output1", "fn_callback", "CS", true);	


}    

// 북마크용 이전/다음글 조회
this.set_PreNextNoBookmark = function(idx,code,kind)
{
	this.viewNavi.set_visible(true);

	nexacro.getApplication().gv_mainFrame.QAKeyNo=idx;	
	this.ds_PreNext2.clear();
	nexacro.getApplication().gds_MiWizard.clearData();

	if( this.fv_PCategoryGubun == "001" ){
		this.query = "WHERE PRODUCT_CODE IN (''001'')  and";
	} else if( this.fv_PCategoryGubun == "002" ){
		this.query = "WHERE PRODUCT_CODE IN (''002'')  and";
	} else if( this.fv_PCategoryGubun == "006" ){
		this.query = "WHERE PRODUCT_CODE IN (''006'')  and";
	} else if( this.fv_PCategoryGubun == "008" ){
		this.query = "WHERE PRODUCT_CODE IN (''008'')  and";
	} else if( this.fv_PCategoryGubun == "009"){
		this.query = "WHERE PRODUCT_CODE IN (''009'')  and";
	} else if( this.fv_PCategoryGubun == "%" ){
		this.query = "WHERE";
	} 		

	var sqlkeyword = "";
	var strTemp = [""];
	if(!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.Board_Cond_Keyword)){
		strTemp = nexacro.getApplication().gv_mainFrame.Board_Cond_Keyword.split(" ");
	}
	var searchgubun = nexacro.getApplication().gv_mainFrame.QA_Cond_Searchgubun;
	if (nexacro.getApplication().gv_mainFrame.QA_Cond_Searchfield == "100") {
		for (var i = 0; i < strTemp.length; i++) {
				sqlkeyword += " SUBJECT like N''%" + strTemp[i] + "%'' or CONTENTS like N''%" + strTemp[i] + "%''";			
			if (i == (strTemp.length - 1)) {
				sqlkeyword += " ) ";
			} else {
				sqlkeyword += " " + searchgubun + " ";
			}
		}
		this.condSQL += sqlkeyword;
	} else if (nexacro.getApplication().gv_mainFrame.QA_Cond_Searchfield == "200") {
		for (var i = 0; i < strTemp.length; i++) {
				sqlkeyword += " SUBJECT like N''%" + strTemp[i] + "%''";			
			if (i == (strTemp.length - 1)) {
				sqlkeyword += " ) ";
			} else {
				sqlkeyword += " " + searchgubun + " ";
			}
		}
		this.condSQL += sqlkeyword;	
	} else if (nexacro.getApplication().gv_mainFrame.QA_Cond_Searchfield == "300") {
		for (var i = 0; i < strTemp.length; i++) {
				sqlkeyword += " CONTENTS like N''%" + strTemp[i] + "%''";			
			if (i == (strTemp.length - 1)) {
				sqlkeyword += " ) ";
			} else {
				sqlkeyword += " " + searchgubun + " ";
			}
		}		
	}			
	
	this.condSQL = this.query + " ( " + sqlkeyword ;
	var args = "query='" + this.condSQL + "'&idx="+idx+"&userid='" + nexacro.getApplication().gds_UserInfo.getColumn(0, "User_id") + "'&kind='T'";
	var objEnv = nexacro.getEnvironment();
	objEnv.set_usewaitcursor( true );
	nexacro.getApplication().com_AddMiWizard("","output1",args,"CS,cs_request_proc,39");	
	this.com_CallService("selectNo", "", "", "ds_PreNext=output1", "fn_callback", "CS", true);	
};

