// 조회 콜백
this.fn_NoticeListCallBack = function (svcid,errCode,errMsg)
{
	if (svcid == "noticeDetail") {
		this.btn_BookMark.set_text(this.ds_NoticeDetail.getColumn(0, "BookMark_cnt"));
		if( this.ds_NoticeDetail.getColumn(0, "BookMark_FLAG") == "Y" ){
			this.btn_BookMark.set_cssclass("btn_WF_book_S");
			this.btn_BookMark.set_accessibilitylabel("북마크 선택됨");
		}
	} else if (svcid == "fileDwnInfo") {
		
		nexacro.getApplication().gv_mainFrame.divMain.set_visible(true);
		
		if (this.ds_downloadfile.rowcount > 0)
		{
			// 첨부파일 있으면 보여주기
			switch(nexacro.getApplication().gv_mainFrame.PCategory2) {
			case "Notice_View":
				this.btnAttachFileRes.set_visible(false);	// 첨부파일(하단)
				this.btnAttachFile.set_visible(true);		// 첨부파일(상단)
				this.staLine.set_visible(true);
				break;
			case "Bookmark_Tip_View":
			case "Tip_View_N":
			case "Tip_View_17":
			case "Tip_View_14":
			case "Tip_View_XP":
			case "Tip_View_MP":
				this.btnAttachFileRes.set_visible(true);	// 첨부파일(하단)
				this.btnAttachFile.set_visible(false);		// 첨부파일(상단)
				this.btnGetEmail.set_visible(true);
				break;
			case "Education_information_View":
				this.btnAttachFileRes.set_visible(false);	// 첨부파일(하단)
				this.btnAttachFile.set_visible(true);		// 첨부파일(상단)
				this.staLine.set_visible(true);
				break;
			case "Education_material_View":
				this.btnAttachFileRes.set_visible(false);	// 첨부파일(하단)
				this.btnAttachFile.set_visible(true);		// 첨부파일(상단)
				this.staLine.set_visible(true);
				break;
			case "Education_Review_View":
				this.btnAttachFileRes.set_visible(false);	// 첨부파일(하단)
				this.btnAttachFile.set_visible(true);		// 첨부파일(상단)
				this.staLine.set_visible(true);
				break;				
			case "SearchEngine_Board_View":
				this.btnAttachFileRes.set_visible(true);	// 첨부파일(하단)
				this.btnAttachFile.set_visible(false);		// 첨부파일(상단)
				this.btnGetEmail.set_visible(true);
				break;
			default:
			}
			
			// 첨부파일 데이터셋 셋팅
			if (this.ds_downloadfile.rowcount > 0)
			{
				if (this.ds_downloadfile.rowcount > 1)
				{
					this.btnAttachFileRes.set_text(this.ds_downloadfile.getColumn(0, "FILE_NAME") + " (" + this.ds_downloadfile.rowcount + ")");
				}
				else
				{
					this.btnAttachFileRes.set_text(this.ds_downloadfile.getColumn(0, "FILE_NAME"));
				}
				
				
				// 컬럼추가
				this.ds_downloadfile.addColumn("URL", "STRING");
				// 다운로드url 추가  이후 다운로드 시 사용
				for (var i = 0; i < this.ds_downloadfile.rowcount; i++) {
					
					this.ds_downloadfile.setColumn(i, "URL", nexacro.getEnvironment().services["SVC_JSP"].url 
					+ "Next_JSP/FileDownload/fileDownload.jsp?path="+encodeURIComponent(this.ds_downloadfile.getColumn(i,"SAVE_PATH"))//.replace("E:","D:"))
					+ "&file="+ encodeURIComponent(this.ds_downloadfile.getColumn(i,"SAVE_FILE_NAME")) 
					+ "&realFileNm='"+encodeURIComponent(this.ds_downloadfile.getColumn(i,"FILE_NAME")));
				}
			}
			//팝업 크기 조절
			if(this.ds_downloadfile.rowcount<4){
				//this.pdivFiles.set_height((this.ds_downloadfile.rowcount*40)+20);
				this.divFiles.set_height((this.ds_downloadfile.rowcount*40)+22);
				this.divFilesRes.set_height((this.ds_downloadfile.rowcount*40)+22);
			}
		}
		else
		{
			this.btnAttachFileRes.set_visible(false);	// 첨부파일(하단)
			this.btnAttachFile.set_visible(false);		// 첨부파일(상단)
			this.staLine.set_visible(false);
		}
 
		this.btn_BookMark.set_text(this.ds_NoticeDetail.getColumn(0, "BookMark_cnt"));
		if( this.ds_NoticeDetail.getColumn(0, "BookMark_FLAG") == "Y" ){
			this.btn_BookMark.set_cssclass("btn_WF_book_S");
			this.btn_BookMark.set_accessibilitylabel("북마크 선택됨");
		}

		// 날짜
		var sDate = this.ds_NoticeDetail.getColumn(0, "INSERT_DATE");
		if (!this.gfnIsNull(sDate))
		{
			sDate = sDate.replaceAll("/","");
			this.staInsertDate.set_text(sDate.substr(0, 4)+"-"+sDate.substr(4, 2)+"-"+sDate.substr(6, 2));
		}
		
		// CONTENTS
		var content = this.ds_NoticeDetail.getColumn(this.ds_NoticeDetail.rowposition, "content");
		this.webBrowResult.callMethod("setContent", content, true);
		// 이전/다음 게시물 불러오기
		//		this.set_PreNextNo(this.ds_NoticeDetail.getColumn(0,"QL_SEQ"),this.ds_NoticeDetail.getColumn(0,"mip_version"));
		if (nexacro.getApplication().gv_mainFrame.PCategory2 == "Bookmark_Tip_View")
		{
			this.set_PreNextNoBookmark(this.ds_NoticeDetail.getColumn(0,"BL_SEQ"),this.ds_NoticeDetail.getColumn(0,"PRODUCT_CODE"),this.ds_NoticeDetail.getColumn(0,"board_kind"));
		}
		else if (nexacro.getApplication().gv_mainFrame.PCategory2 == "SearchEngine_Board_View")
		{
			this.viewNavi.set_height(0);
			this.viewNavi.set_visible(false); 
			this.resetScroll();
		}
		else
		{
			this.set_PreNextNo(this.ds_NoticeDetail.getColumn(0,"BL_SEQ"),this.fv_PCategoryGubun,this.ds_NoticeDetail.getColumn(0,"board_kind"));
		}
	}  
}
    
// 목록 가기 버튼 클릭 이벤트
this.btnList_onclick = function(obj:Button,  e:nexacro.ClickEventInfo)
{
	nexacro.getApplication().gv_mainFrame.QAStatus = "List";
	var sMenu = nexacro.getApplication().gv_mainFrame.PCategory2.replace("_View", "");
	if (sMenu == "SearchEngine_Board")
	{
		sMenu = "SearchEngine";
	}
	var sKeyword = nexacro.getApplication().gv_mainFrame.QA_Cond_Keyword;
	var nPage = nexacro.getApplication().gv_mainFrame.QA_Cond_Page;
	
	if (this.gfnIsNull(nPage))
	{
		nPage = 1;
	}
	nexacro.getApplication().gv_mainFrame.param = {
		'menu': sMenu,
		'keyword': sKeyword,
		'page': nPage,
		'postId': ""
		};
	nexacro.getApplication().gv_mainFrame.gfnGoMain();
}   

// 내용 웹브라우저 로딩 끝나면 조회
this.webBrowResult_onloadcompleted = function(obj:WebBrowser, e:nexacro.WebLoadCompEventInfo)
{
	this.fn_CallTrans(); 
}  

// 조회
this.fn_CallTrans = function()
{
	// 인수 설정 
	var strAn=nexacro.getApplication().gv_mainFrame.strTempFilder1;
	
	if (this.gfnIsNull(nexacro.getApplication().gv_mainFrame.strTempFilder1))
	{
		nexacro.getApplication().gv_mainFrame.strTempFilder1 = nexacro.getApplication().gv_mainFrame.param.postId;
	}
	this.sIdx = nexacro.getApplication().gv_mainFrame.strTempFilder1;
	// 인수 설정     
	// 인수 설정     
	this.strBoardId="A05";
	var PCategoryGubun="%";
	var PCategoryGubun2="%"; //이전글, 다음글 조회를 위해 추가 
	
	// strBoardId 셋팅(겸사겸사 안보일거 안보이게)
	//alert("nexacro.getApplication().gv_mainFrame.PCategory2:"+nexacro.getApplication().gv_mainFrame.PCategory2);
	switch(nexacro.getApplication().gv_mainFrame.PCategory2) {
	case "Sketch_View":
		this.strBoardId="SK";
		break;
	case "Notice_View":
		this.strBoardId="A06";
		this.btnGetEmail.set_visible(false);		// 이메일로 소스받기
		this.btnAttachFileRes.set_visible(false);	// 첨부파일(하단)
		this.btnAttachFile.set_visible(true);		// 첨부파일(상단)
		this.staLine.set_visible(true);
		this.btnCopyLink.set_visible(false);		// 링크복사
		this.btn_BookMark.set_visible(false);		// 북마크
		break;
	case "Tip_View_N":
	case "Tip_View_17":
	case "Tip_View_14":
	case "Tip_View_XP":
	case "Tip_View_MP":
	case "Bookmark_Tip_View":
		this.strBoardId="A05";
		this.staLine.set_visible(true);
		this.btnCopyLink.set_visible(true);		// 링크복사
		this.btnReply.set_visible(true);
		this.btn_BookMark.set_visible(true);		// 북마크
		this.btnGetEmail.set_visible(true);		// 이메일로 소스받기
		break;
	case "Education_information_View":
		this.strBoardId="A14";
		this.btnGetEmail.set_visible(false);		// 이메일로 소스받기
		this.btnAttachFileRes.set_visible(false);	// 첨부파일(하단)
		this.btnAttachFile.set_visible(true);		// 첨부파일(상단)
		this.btnCopyLink.set_visible(false);		// 링크복사
		this.btn_BookMark.set_visible(false);		// 북마크
		break;
	case "Education_Review_View":
		this.strBoardId="A16";
		this.btnGetEmail.set_visible(false);		// 이메일로 소스받기
		this.btnAttachFileRes.set_visible(false);	// 첨부파일(하단)
		this.btnAttachFile.set_visible(true);		// 첨부파일(상단)
		this.btnCopyLink.set_visible(false);		// 링크복사
		this.btn_BookMark.set_visible(false);		// 북마크
		break;		
	case "Education_material_View":
		this.strBoardId="A09";
		this.btnGetEmail.set_visible(false);		// 이메일로 소스받기
		this.btnAttachFileRes.set_visible(false);	// 첨부파일(하단)
		this.btnAttachFile.set_visible(true);		// 첨부파일(상단)
		this.staLine.set_visible(true);
		this.btnCopyLink.set_visible(false);		// 링크복사
		this.btn_BookMark.set_visible(false);		// 북마크
		break;
	case "SearchEngine_Board_View":
		switch(nexacro.getApplication().gv_mainFrame.SearchEngineFlag) {
		case "Tip":
			this.strBoardId="A05";
			this.staLine.set_visible(true);
			this.btnCopyLink.set_visible(true);		// 링크복사
			this.btnReply.set_visible(true);
			this.btn_BookMark.set_visible(true);		// 북마크
			break;
		case "Education_Notice":
			this.strBoardId="A14";
			this.btnGetEmail.set_visible(false);		// 이메일로 소스받기
			this.btnAttachFileRes.set_visible(false);	// 첨부파일(하단)
			this.btnAttachFile.set_visible(true);		// 첨부파일(상단)
			this.btnCopyLink.set_visible(false);		// 링크복사
			this.btn_BookMark.set_visible(false);		// 북마크
			break;
		case "Educationmaterial":
			this.strBoardId="A09";
			this.btnGetEmail.set_visible(false);		// 이메일로 소스받기
			this.btnAttachFileRes.set_visible(false);	// 첨부파일(하단)
			this.btnAttachFile.set_visible(true);		// 첨부파일(상단)
			this.staLine.set_visible(true);
			this.btnCopyLink.set_visible(false);		// 링크복사
			this.btn_BookMark.set_visible(false);		// 북마크
			break;
		case "Notice":
			this.strBoardId="A06";
			this.btnGetEmail.set_visible(false);		// 이메일로 소스받기
			this.btnAttachFileRes.set_visible(false);	// 첨부파일(하단)
			this.btnAttachFile.set_visible(true);		// 첨부파일(상단)
			this.staLine.set_visible(true);
			this.btnCopyLink.set_visible(false);		// 링크복사
			this.btn_BookMark.set_visible(false);		// 북마크
			break;
		default:
		}
		break;
	default:
	}
	
	// PCategoryGubun 셋팅
	switch(nexacro.getApplication().gv_mainFrame.PCategory2) {
	case "Notice_View":
		
		break;
	case "Tip_View_N":
		PCategoryGubun2 = "''010'',''009''"; 
		PCategoryGubun = nexacro.wrapQuote("'010','009'");
		break;
	case "Tip_View_17":
		PCategoryGubun2 = "''008''";
		PCategoryGubun = nexacro.wrapQuote("'008'");
		break;
	case "Tip_View_14":
		PCategoryGubun2 = "''006''";
		PCategoryGubun = nexacro.wrapQuote("'006'");
		break;
	case "Tip_View_XP":
		PCategoryGubun2 = "''002''";
		PCategoryGubun = nexacro.wrapQuote("'002'");
		break;
	case "Tip_View_MP":
		PCategoryGubun2 = "''001''";
		PCategoryGubun = nexacro.wrapQuote("'001'");
		break;
	case "Bookmark_Tip_View":
		PCategoryGubun = "'%'";
		switch(nexacro.getApplication().gv_mainFrame.Bookmark_Tab_Index) {
		case 1:
			//PCategoryGubun = "009";
			PCategoryGubun2 = "''010'',''009''"; 
			PCategoryGubun = nexacro.wrapQuote("'010','009'");			
			break;
		case 2:
			//PCategoryGubun = "008";
			PCategoryGubun2 = "''008''";
			PCategoryGubun = nexacro.wrapQuote("'008'");			
			break;
		case 3:
			//PCategoryGubun = "006";
			PCategoryGubun2 = "''006''";
			PCategoryGubun = nexacro.wrapQuote("'006'");			
			break;
		case 4:
			//PCategoryGubun = "002";
			PCategoryGubun2 = "''002''";
			PCategoryGubun = nexacro.wrapQuote("'002'");			
			break;
		case 5:
			//PCategoryGubun = "001";
			PCategoryGubun2 = "''001''";
			PCategoryGubun = nexacro.wrapQuote("'001'");			
			break;
		default:
		}
		break;
		case "SearchEngine_Board_View":
			PCategoryGubun = "'%'";
			break;
	default:
	}	

	//this.fv_PCategoryGubun = PCategoryGubun;
	this.fv_PCategoryGubun = PCategoryGubun2;

	var UserID = nexacro.getApplication().gds_UserInfo.getColumn(0, "User_id");
	var strArgs = "RTYPE=XML DB='CS' user_id="+UserID+" BoardID=" + this.strBoardId + " PCategoryGubun=" + PCategoryGubun  + " strAn='"+strAn+"' nationCd='001'";
	
	var strUrl = "SVC_JSP::Next_JSP/Board/ProcDetailBoard_new.jsp?";
	var strDsInput = "";
	var strDsOutput = "ds_NoticeDetail=output1";
	this.com_TransSend("noticeDetail",strUrl,strDsInput,strDsOutput,strArgs,"fn_NoticeListCallBack",false);

	nexacro.getApplication().gds_MiWizard.clearData();   
	nexacro.getApplication().com_AddMiWizard("","output2","BoardID='" + this.strBoardId + "'&strAn="+strAn+ "&kind='"+this.strBoardId+"'","XPLATFORM,TECH_MAIN,48");
	
	var outDs = "ds_downloadfile=output2";
	this.com_CallService("fileDwnInfo", "", "", outDs, "fn_NoticeListCallBack", "CS", true);

}

// 웹브라우저 내부함수 호출
this.webBrowResult_onusernotify = function(obj:WebBrowser, e:nexacro.WebTitleChangeEventInfo)
{	
	if(e.userdata.method == "loadContent"){
		this.getHTMLValue1("getContentHeight");
	}else if(e.userdata.method =="getContentHeight"){
		// wb높이 구하기
		this.nRes = e.userdata.height; 
		
		this.wbHeight1 = this.nRes;
		
		if (this.wbHeight1 > 1000 && this.wbHeightLongFlg == false)
		{
			this.wbHeightLongFlg = true;
			this.setTimer(111, 300);
		}
		else
		{
			// wb높이
			var wbHeight1 = this.nRes;
			
			// 총높이
			var nHeight = parseInt(wbHeight1);
			// 웹브라우저 높이 조절
			this.webBrowResult.set_height(parseInt(wbHeight1));
			// 웹브라우저 아래 컴포넌트 위치 조정
			this.webBrowResult.set_visible(true);
			this.resetScroll();

			nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, this.btnList.getOffsetBottom() +  260);
		}
	}
}

// 재질문 버튼
this.btnReply_onclick = function(obj:Button,  e:nexacro.ClickEventInfo)
{
	nexacro.getApplication().gv_mainFrame.QAStatus = "Write";
	nexacro.getApplication().gv_mainFrame.param = {
		'menu': "QnA_Write",
		'keyword': "",
		'page': 1,
		'postId': ""
		};
	nexacro.getApplication().gv_mainFrame.gfnGoMain();
}

// 수정하기 버튼
this.btnModify_onclick = function(obj:Button,  e:nexacro.ClickEventInfo)
{  
	nexacro.getApplication().gv_mainFrame.BoardCategoryID = this.ds_NoticeDetail.getColumn(this.ds_NoticeDetail.rowposition,"board_kind");	//"boardid");
	nexacro.getApplication().gv_mainFrame.BoardKeyNo = this.ds_NoticeDetail.getColumn(this.ds_NoticeDetail.rowposition,"BL_SEQ");	//	"an");
	nexacro.getApplication().gv_mainFrame.BoardStatus = "Modify";

}

// editor.html 영역에서 특정 값을 얻어온다.
this.getHTMLValue1 = function(name)
{
	this.webBrowResult.callMethod("getHTMLValue", name);
	
	var el = this.webBrowResult.getProperty("document").callMethod("getElementById", "transfer");
	var val = el.getProperty("value");
	el.setProperty("value", "");
		
	return val;	
}

// 조회 후 콜백
this.fn_callback = function (svcid,errCode,errMsg)
{
	if( svcid == "selectNo" )
	{
		this.viewNavi.set_enable(true);
		var objEnv = nexacro.getEnvironment();
		objEnv.set_usewaitcursor( false );
		var seq = this.ds_NoticeDetail.getColumn(0,"BL_SEQ");
		this.ds_PreNext.filter("BL_SEQ!="+seq);
		if( this.ds_PreNext.rowcount == 1 && nexacro.toNumber(this.ds_PreNext.getColumn(0,"BL_SEQ")) > nexacro.toNumber(seq) ){
			this.viewNavi.form.stc_pre.BL_SEQ = this.ds_PreNext.getColumn(0, "BL_SEQ");
			this.viewNavi.form.stc_pre.set_text(this.ds_PreNext.getColumn(0, "SUBJECT"));
			this.viewNavi.form.stc_pre.set_cursor("");
			this.viewNavi.form.stc_preIcon.set_cursor("pointer");
			this.viewNavi.form.stc_next.set_text("게시글이 없습니다.");
			this.viewNavi.form.stc_next.set_cssclass("btn_WF_viewDetail2");
			this.viewNavi.form.stc_next.set_enable(false);
			this.viewNavi.form.stc_nextIcon.set_enable(false);
			this.viewNavi.form.stc_nextIcon.set_cursor("default");
		} else if( this.ds_PreNext.rowcount == 1 && nexacro.toNumber(this.ds_PreNext.getColumn(0,"BL_SEQ")) < nexacro.toNumber(seq) ){
			this.viewNavi.form.stc_next.BL_SEQ = this.ds_PreNext.getColumn(0, "BL_SEQ");
			this.viewNavi.form.stc_next.set_text(this.ds_PreNext.getColumn(0, "SUBJECT"));	
			this.viewNavi.form.stc_next.set_cursor("");
			this.viewNavi.form.stc_nextIcon.set_cursor("pointer");
			this.viewNavi.form.stc_pre.set_text("게시글이 없습니다.");
			this.viewNavi.form.stc_pre.set_cssclass("btn_WF_viewDetail2");
			this.viewNavi.form.stc_pre.set_enable(false);
			this.viewNavi.form.stc_preIcon.set_enable(false);
			this.viewNavi.form.stc_preIcon.set_cursor("default");
		}else if(this.ds_PreNext.getRowCount() ==0){
			this.viewNavi.form.stc_pre.set_text("게시글이 없습니다.");
			this.viewNavi.form.stc_pre.set_cssclass("btn_WF_viewDetail2");
			this.viewNavi.form.stc_pre.set_enable(false);
			this.viewNavi.form.stc_preIcon.set_enable(false);
			this.viewNavi.form.stc_preIcon.set_cursor("default");
			this.viewNavi.form.stc_next.set_text("게시글이 없습니다.");
			this.viewNavi.form.stc_next.set_cssclass("btn_WF_viewDetail2");
			this.viewNavi.form.stc_next.set_enable(false);
			this.viewNavi.form.stc_nextIcon.set_enable(false);
			this.viewNavi.form.stc_nextIcon.set_cursor("default");
		} else {
			this.viewNavi.form.stc_next.BL_SEQ = this.ds_PreNext.getColumn(1, "BL_SEQ");
			this.viewNavi.form.stc_next.set_text(this.ds_PreNext.getColumn(1, "SUBJECT"));
			this.viewNavi.form.stc_next.set_cursor("");
			this.viewNavi.form.stc_nextIcon.set_cursor("pointer");
			this.viewNavi.form.stc_pre.BL_SEQ = this.ds_PreNext.getColumn(0, "BL_SEQ");
			this.viewNavi.form.stc_pre.set_text(this.ds_PreNext.getColumn(0, "SUBJECT"));	
			this.viewNavi.form.stc_pre.set_cursor("");
			this.viewNavi.form.stc_preIcon.set_cursor("pointer");
		}
		this.resetScroll();
	}
	this.viewNavi.form.stc_pre.set_fittocontents("width");
	this.viewNavi.form.stc_next.set_fittocontents("width");
}

//북마크 버튼 클릭
this.btn_BookMark_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{   
	var bookMarkFlag = this.ds_NoticeDetail.getColumn(0, "BookMark_FLAG");
	var userId = nexacro.getApplication().gds_UserInfo.getColumn(0, "User_id");
	var reqIdx = this.ds_NoticeDetail.getColumn(0, "BL_SEQ");

	//북마크 중복처리용
	nexacro.getApplication().gds_MiWizard.clearData();
	nexacro.getApplication().com_AddMiWizard("","output1","req_idx=" + reqIdx + "&user_id='" + userId + "'&kind='T'","CS,cs_request_proc,27");              
	this.com_CallService("selectBookMark", "", "", "ds_bookMark=output1", "", "CS", false);         

	//북마크 체크 -> 해제
	if(bookMarkFlag == "Y") {
		this.btn_BookMark.set_cssclass("btn_WF_book");
		this.btn_BookMark.set_accessibilitylabel("북마크 해제됨");

		//북마크 저장을 위한 데이터셋 
		this.ds_update.clearData();
		this.ds_update.addRow();
		this.ds_update.setColumn(0, "SQL_ID", "'CS,cs_request_proc,26'" );

		nexacro.getApplication().gds_MiWizard.clearData();      
		nexacro.getApplication().com_AddMiWizard("input1","","req_idx=" + reqIdx + "&user_id='" + userId + "'&kind='T'&flag='N'","","CS,cs_request_proc,26");

		var inDs = "input1=ds_update:U";
		this.com_CallService("deleteBookMark", "", inDs, "", "", "CS", false);                     

	//북마크 해제 -> 체크
	} else {
		this.btn_BookMark.set_cssclass("btn_WF_book_S");
		this.btn_BookMark.set_accessibilitylabel("북마크 선택됨");

		//북마크 저장을 위한 데이터셋 
		this.ds_update.clearData();
		this.ds_update.addRow();
		this.ds_update.setColumn(0, "SQL_ID", "'CS,cs_request_proc,26'");

		nexacro.getApplication().gds_MiWizard.clearData();      
		nexacro.getApplication().com_AddMiWizard("input1","","req_idx=" + reqIdx + "&user_id='" + userId + "'&kind='T'&flag='Y'","","CS,cs_request_proc,26");

		var inDs = "input1=ds_update:U";
		this.com_CallService("selectBookMark", "", inDs, "", "", "CS", false);      
	}   
	this.fn_CallTrans();
};

