// 파일 다운로드
this.btnAttachFileRes_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
// 	// pdiv 띄우기
// 	if (obj.name == "btnAttachFile")
// 	{
// 		this.pdivFiles.trackPopupByComponent(obj, 0, 38);
// 	}
// 	else
// 	{
// 		if (1300-obj.getOffsetLeft() > 230)  // 팝업 div가 밖으로 튀어나가지 않게 하기 위해 분기처리
// 		{
// 			this.pdivFiles.trackPopupByComponent(obj, 0, 38);
// 		}
// 		else
// 		{
// 			this.pdivFiles.trackPopupByComponent(obj, -(230-(1300-obj.getOffsetLeft())), 38);
// 		}
// 	}

		//btnAttachFile 첨부파일 상단, btnAttachFileRes 첨부파일 하단
	if (obj.name == "btnAttachFile")
	{
		if (!this.divFiles.visible) {
			this.divFiles.set_visible(true);
			this.divFiles.set_left(this.btnAttachFile.getOffsetLeft());
			this.divFiles.set_width(this.btnAttachFile.getOffsetWidth());				
		} else {
			this.divFiles.set_visible(false);
		}
	}
	else if (obj.name == "btnAttachFileRes")
	{	
		if (!this.divFilesRes.visible) {
			this.divFilesRes.set_visible(true);
			this.divFilesRes.set_left(this.btnAttachFileRes.getOffsetLeft());
			this.divFilesRes.set_width(this.btnAttachFileRes.getOffsetWidth());			
		} else {
			this.divFilesRes.set_visible(false);
		}
	}
};

