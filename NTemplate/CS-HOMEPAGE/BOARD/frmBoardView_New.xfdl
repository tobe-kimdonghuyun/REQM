this.pdivEmail_btnSendEmail_onclick = function(obj:Button,  e:nexacro.ClickEventInfo)
{	
	var id = this.ds_ReqDetail.getColumn(0, "req_userid");
	var subject  = "투비소프트 QnA [" +  this.ds_ReqDetail.getColumn(0, "BL_SEQ") + "] 접수건 입니다";
	//var mailto   = this.pdivEmail.form.edtEmail.value;		
	var mailto   = this.divTreat.form.divEmail.form.edtEmail.value;		
	var contents = "";
	
	contents +='<!DOCTYPE html>                                                                                                                                                                     ';
	contents +='<html style="margin: 0;padding: 0;border: 0;font-size: 100%;font: inherit;vertical-align: baseline;font-family: Noto Sans KR, sans-serif;">                                         ';
	contents +='    <head>                                                                                                                                                                          ';
	contents +='        <meta charset="utf-8">                                                                                                                                                      ';
	contents +='        <meta http-equiv="X-UA-Compatible" content="IE=edge">                                                                                                                       ';
	contents +='        <title>아이디/비밀번호찾기 안내입니다.</title>                                                                                                                                            ';
	contents +='        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/normalize/8.0.1/normalize.min.css" />                                                                   ';
	contents +='        <link rel="preconnect" href="https://fonts.googleapis.com">                                                                                                                 ';
	contents +='        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>                                                                                                        ';
	contents +='        <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">                                                          ';
	contents +='    </head>                                                                                                                                                                         ';
	contents +='    <body style="margin: 0;padding: 0;border: 0;font-size: 100%;font:inherit;vertical-align: baseline;line-height: 1;                                                               ';
	contents +='    background-color: #fafafa;">                                                                                                                                                    ';
	contents +='        <div style="margin:0px auto;width: 700px;height: 100%;background-color: #fff;letter-spacing: -1;">                                                                          ';
	contents +='            <div style="padding: 23px 40px 40px 40px;height: auto;background: url(http://support.tobesoft.co.kr/portal/Mail/images/05-4.png) no-repeat;color:#fff;">                                                          ';
	contents +='                <h1 style="margin: 0;position: relative;padding-bottom: 35px;">                                                                                                     ';
	contents +='                    <a href="#" target="_blank" style="display: inline-block;"><img src="http://support.tobesoft.co.kr/portal/Mail/images/logo-w.gif"></a>                                                                    ';
	contents +='                    <span style="display: inline-block;position: absolute;top: 0;right: 0;font-size: 16px;">(주)투비소프트 고객지원센터</span>                                                  ';
	contents +='                </h1>                                                                                                                                                               ';
	contents +='                <span style="font-size: 46px;line-height: 1.1;"><span style=font-weight:700;>QnA</span><br>문의하신 내용에 대한<br>답변입니다</span>                                              ';
	contents +='            </div>                                                                                                                                                                  ';
	contents +='            <div style="padding: 40px 40px;font-size: 16px;color:#555;line-height: 1.5;">                                                                                           ';
	contents +='                <p style="margin: 0; padding-bottom: 30px;">투비소프트 QnA [' +  this.ds_ReqDetail.getColumn(0, "BL_SEQ") + '] 접수건으로 문의하신 내용에 대한 답변입니다. </p>                                                                        ';
	contents +='                <table cellpadding="0" cellspacing="0" border="0" style="width: 100%;border-top: 2px solid #666;border-bottom: 2px solid #666;text-align: left;line-height: 1.5;">  ';
	contents +='                    <tr>                                                                                                                                                            ';
	contents +='                        <th style="padding: 15px 0 15px 10px;width: 15%;color: #999;font-weight: 400;border-bottom: 1px solid #dee1ee;">등록일</th>                                    ';
	contents +='                        <td style="padding: 15px 10px;width: auto;color: #333;font-weight: 500;border-bottom: 1px solid #dee1ee;">' + this.ds_ReqDetail.getColumn(0, "req_dt") + '</td>                                 ';
	contents +='                    </tr>                                                                                                                                                           ';
	contents +='                    <tr>                                                                                                                                                            ';
	contents +='                        <th style="padding: 15px 0 15px 10px;width: 15%;color: #999;font-weight: 400;border-bottom: 1px solid #dee1ee;">제목</th>                                     ';
	contents +='                        <td style="padding: 15px 10px;width: auto;color: #333;font-weight: 500;border-bottom: 1px solid #dee1ee;">' + this.ds_ReqDetail.getColumn(0, "req_title") + '</td>         ';
	contents +='                    </tr>                                                                                                                                                           ';
	contents +='                    <tr>                                                                                                                                                            ';
	contents +='                        <th style="padding: 15px 0 15px 10px;width: 15%;color: #999;font-weight: 400;border-bottom: 1px solid #dee1ee;">내용</th>                                     ';
	contents +='                        <td style="padding: 15px 10px;width: auto;color: #666;font-weight: 400;border-bottom: 1px solid #dee1ee;">' + this.ds_ReqDetail.getColumn(0, "req_remark") + '</td>  ';
	contents +='                    </tr>                                                                                                                                                           ';
	contents +='                    <tr>                                                                                                                                                            ';
	contents +='                        <th style="padding: 15px 0 15px 10px;width: 15%;color: #999;font-weight: 400;border-bottom: 1px solid #dee1ee;">처리결과</th>                                   ';
	contents +='                        <td style="padding: 15px 10px;width: auto;color: #333;font-weight: 500;border-bottom: 1px solid #dee1ee;">' + this.ds_ReqDetail.getColumn(0, "res_remark")+ '</td>    ';
	contents +='                    </tr>                                                                                                                                                           ';
	contents +='                </table>                                                                                                                                                            ';
