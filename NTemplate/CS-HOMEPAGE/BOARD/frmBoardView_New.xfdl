			this.viewNavi.form.stc_pre.set_text("게시글이 없습니다.");
			this.viewNavi.form.stc_pre.set_cssclass("sta_WF_viewDetail");
			this.viewNavi.form.stc_pre.set_enable(false);
			this.viewNavi.form.stc_preIcon.set_enable(false);
			this.viewNavi.form.stc_preIcon.set_cursor("default");
		} else {
			this.viewNavi.form.stc_next.BL_SEQ = this.ds_PreNext2.getColumn(1, "BL_SEQ");
			this.viewNavi.form.stc_next.set_text(this.ds_PreNext2.getColumn(1, "SUBJECT"));
			this.viewNavi.form.stc_next.set_cursor("");
			this.viewNavi.form.stc_nextIcon.set_cursor("pointer");
			this.viewNavi.form.stc_pre.BL_SEQ = this.ds_PreNext2.getColumn(0, "BL_SEQ");
			this.viewNavi.form.stc_pre.set_text(this.ds_PreNext2.getColumn(0, "SUBJECT"));	
			this.viewNavi.form.stc_pre.set_cursor("");
			this.viewNavi.form.stc_preIcon.set_cursor("pointer");
		}
	}
	this.viewNavi.form.stc_pre.set_fittocontents("width");
	this.viewNavi.form.stc_next.set_fittocontents("width");
}

this.webBrowResult_onloadcompleted = function (obj:WebBrowser, e:nexacro.WebLoadCompEventInfo)
{
	var reqIdx = this.sIdx;
	nexacro.getApplication().gv_mainFrame.QAKeyNo=reqIdx;

	switch(nexacro.getApplication().gv_mainFrame.PCategory2) {
		case "Sketch_View":
			this.strBoardId="SK";
			break;
		case "Tutorial_View":
			this.strBoardId="ST";
			break;			
		default:
	}		

	this.user_id = nexacro.getApplication().gds_UserInfo.getColumn(0, "User_id");
	this.user_nm = nexacro.getApplication().gds_UserInfo.getColumn(0, "User_nm");
	this.tel_hp  = nexacro.getApplication().gds_UserInfo.getColumn(0, "Tel_hp");

	//조회 카운트 저장을 위한 데이터셋 
	this.ds_update.clearData();
	this.ds_update.addRow();
	this.ds_update.setColumn(0, "SQL_ID" , "'CS,cs_request_proc,26'" );
	//trace("req_idx=" + reqIdx+ "&Board_Kind="+this.strBoardId);	
	nexacro.getApplication().gds_MiWizard.clearData();   	
	nexacro.getApplication().com_AddMiWizard("","output1","req_idx=" + reqIdx+ "&Board_Kind='"+this.strBoardId+"'","CS,cs_request_proc,40");
	nexacro.getApplication().com_AddMiWizard("","output2","str_an=" + reqIdx + "&user_id='"+this.user_id+"'","CS,statistics,5");
	nexacro.getApplication().com_AddMiWizard("","output3","req_idx=" + reqIdx + "&kind='"+this.strBoardId+"Q'","CS,cs_request_proc,32");
	nexacro.getApplication().com_AddMiWizard("","output4","req_idx=" + reqIdx + "&kind='"+this.strBoardId+"A'","CS,cs_request_proc,32");
	nexacro.getApplication().com_AddMiWizard("","output5","user_nm='" + this.user_nm +"'&tel_no='" + this.tel_hp + "'","SYSTEM,sys_findStaff,11");	
	// idx의 상태에따라 만족도 조사 SQL문을 가져와야함  includeQAViewBodyNew.asp

	var outDs = "ds_ReqDetail=output1 ds_CustSafctData=output2 ds_downloadfile_req=output3 ds_downloadfile_res=output4 ds_userInfo=output5";
	var inDs = "input1=ds_update:U";
	this.com_CallService("selectDetail", "", inDs, outDs, "fn_SelectListCallBack", "CS", true);
};


this.fn_SelectListCallBack = function (svcid, errCode, errMsg)
{
	if( svcid == "selectDetail2" ){
		this.btn_BookMark.set_text(this.ds_ReqDetail.getColumn(0, "BookMark_cnt"));
		if( this.ds_ReqDetail.getColumn(0, "BookMark_FLAG") == "Y" ){
			this.btn_BookMark.set_cssclass("btn_WF_book_S");
			this.btn_BookMark.set_accessibilitydescription("북마크수, 활성상태");
		}	
	}else if (svcid == "selectDetail") {
		//trace(this.ds_ReqDetail.saveXML());
		//조회수 저장을 위한 데이터셋 
		this.ds_update.clearData();
		this.ds_update.addRow();
		this.ds_update.setColumn(0, "SQL_ID" , "'CS,cs_request_proc,42'" );
		
		//com_AddMiWizard = function (inDs, outDs, args, sqlSel, sqlIns, sqlUpd, sqlDel)
		nexacro.getApplication().gds_MiWizard.clearData();   	
		nexacro.getApplication().com_AddMiWizard("input1","","BL_SEQ=" + this.sIdx + "&USER_ID='"+this.user_id+"'&BOARD_KIND='"+this.strBoardId+"'","","CS,cs_request_proc,42");

		var inDs = "input1=ds_update:U";	
		this.com_CallService("saveVisit", "", inDs, "", "", "CS", false);	
		
		this.btn_BookMark.set_text(this.ds_ReqDetail.getColumn(0, "BookMark_cnt"));
		if( this.ds_ReqDetail.getColumn(0, "BookMark_FLAG") == "Y" ){	
			this.btn_BookMark.set_cssclass("btn_WF_book_S");
			this.btn_BookMark.set_accessibilitydescription("북마크수, 활성상태");
		}
		
		// 타이틀 셋팅
		this.staResTitle.set_text(this.ds_ReqDetail.getColumn(0, "req_title"));
		this.resetScroll();
		
		if( (this.ds_userInfo.rowcount > 0) && (this.ds_ReqDetail.getColumn(0, "qc_no") > 0) )
		{
			this.staRC.set_visible(true);
			this.staRC.set_text("RC " + this.ds_ReqDetail.getColumn(0, "qc_no"));
			this.staLineRC.set_visible(true);
		} 
		else
		{
			this.staRC.set_visible(false);
			this.staLineRC.set_visible(false);
			this.btnAttachFile.set_left(283);
			this.divFilesReq.set_left(283);
			this.staLineFile.set_left(262);
		}
		
		// staResDate 답변 날짜 셋팅
		if (!this.gfnIsNull(this.ds_ReqDetail.getColumn(0,"RESULT_DATE")))
		{
			this.divTreat.form.staResDate.set_text(this.ds_ReqDetail.getColumn(0,"RESULT_DATE").substring(0,4) + "-" + this.ds_ReqDetail.getColumn(0,"RESULT_DATE").substring(4,6) + "-" + this.ds_ReqDetail.getColumn(0,"RESULT_DATE").substring(6,8));
		}
		
		if(this.ds_CustSafctData.rowcount > 0)
		{
			this.Div_reSearch.form.fn_setSafctData();
		}
		var res_status = this.ds_ReqDetail.getColumn(0, "res_status");
		// 안건의 진행 상태에 따라 표시
		if (res_status == "005" || res_status == "006" || res_status == "007" || res_status == "008" || res_status == "009") {
			// 만족도 조사 데이터
		}

		var reqFilekey = this.ds_ReqDetail.getColumn(0, "req_filekey");
		var resFilekey = this.ds_ReqDetail.getColumn(0, "res_filekey");
    
		if (typeof(reqFilekey) == 'undefined') 
		{
			reqFilekey = "";
		}
		if (typeof(resFilekey) == 'undefined') 
		{
			resFilekey = "";
		}
		// 첨부파일
		if (this.ds_downloadfile_req.rowcount > 0)
		{
			this.btnAttachFile.set_visible(true);
			this.btnAttachFile.set_text(this.ds_downloadfile_req.getColumn(0, "FILE_NAME"));
			
			// 컬럼추가
			this.ds_downloadfile_req.addColumn("URL", "STRING");
			// 다운로드url 추가  이후 다운로드 시 사용
			for (var i = 0; i < this.ds_downloadfile_req.rowcount; i++) {
				this.ds_downloadfile_req.setColumn(i, "URL", nexacro.getEnvironment().services["SVC_JSP"].url 
				+ "Next_JSP/FileDownload/fileDownload.jsp?path="+encodeURIComponent(this.ds_downloadfile_req.getColumn(i,"SAVE_PATH"))//.replace("E:","D:"))
				+ "&file="+ encodeURIComponent(this.ds_downloadfile_req.getColumn(i,"SAVE_FILE_NAME")) 
				+ "&realFileNm="+encodeURIComponent(this.ds_downloadfile_req.getColumn(i,"FILE_NAME")));
			}
			if(this.ds_downloadfile_req.rowcount<4){
				//this.pdivFilesReq.set_height((this.ds_downloadfile_req.rowcount*40)+20);
				this.divFilesReq.set_height((this.ds_downloadfile_req.rowcount*40)+30);
			}
		}
		else
		{
			this.btnAttachFile.set_visible(false);
			this.staLineFile.set_visible(false);
		}
		// 첨부파일
		if (this.ds_downloadfile_res.rowcount > 0)
		{
			this.divTreat.form.btnAttachFileRes.set_visible(true);
			if (this.ds_downloadfile_res.rowcount > 1)
			{
				this.divTreat.form.btnAttachFileRes.set_text(this.ds_downloadfile_res.getColumn(0, "FILE_NAME") + " (" + this.ds_downloadfile_res.rowcount + ")");
			}
			else
			{
				this.divTreat.form.btnAttachFileRes.set_text(this.ds_downloadfile_res.getColumn(0, "FILE_NAME"));
			}
			
			
			// 컬럼추가
			this.ds_downloadfile_res.addColumn("URL", "STRING");
			// 다운로드url 추가  이후 다운로드 시 사용
			for (var i = 0; i < this.ds_downloadfile_res.rowcount; i++) {
				this.ds_downloadfile_res.setColumn(i, "URL", nexacro.getEnvironment().services["SVC_JSP"].url 
				+ "Next_JSP/FileDownload/fileDownload.jsp?path="+encodeURIComponent(this.ds_downloadfile_res.getColumn(i,"SAVE_PATH"))
				+ "&file="+ encodeURIComponent(this.ds_downloadfile_res.getColumn(i,"SAVE_FILE_NAME")) 
				+ "&realFileNm="+encodeURIComponent(this.ds_downloadfile_res.getColumn(i,"FILE_NAME")));
			}
		}

		// 제품 아이콘 셋팅
		var sPrd = this.fnProductCodeIcon(this.ds_ReqDetail.getColumn(0, "mip_version"));
		this.staProduct.set_cssclass(sPrd);
		switch(sPrd.substr(sPrd.length-2, 2)) {
		case "SK":
			this.staProduct.set_text("Sketch •");
			break;			
		case "NN":
			this.staProduct.set_text("Nexacro N  •");
			break;
		case "17":
			this.staProduct.set_text("nexacro 17  •");
			break;
		case "14":
			this.staProduct.set_text("nexacro 14  •");
			break;
		case "XP":
			this.staProduct.set_text("XPLATFORM  •");
			break;
		case "MI":
			this.staProduct.set_text("MiPlatform  •");
			break;
		default:
		}
		this.staProduct.set_visible(true);
		// 날짜
		var sDate = this.ds_ReqDetail.getColumn(0, "req_dt");
		if (!this.gfnIsNull(sDate))
		{
			this.staReqDate.set_text(sDate.substr(0, 4)+"-"+sDate.substr(4, 2)+"-"+sDate.substr(6, 2));
			this.staReqDate.set_visible(true);
		}
		
		if (this.ds_CustSafctData.rowcount > 0)
		{
			this.Div_reSearch.form.fn_setSafctData();
		}

		if (nexacro.getApplication().gds_UserInfo.getColumn(nexacro.getApplication().gds_UserInfo.rowposition, "User_id") == this.ds_ReqDetail.getColumn(0, "req_userid")) 
		{
			this.btnModify.set_visible(true);
		}
		
		var reqFilekey = this.ds_ReqDetail.getColumn(0, "req_filekey");
		var resFilekey = this.ds_ReqDetail.getColumn(0, "res_filekey");

		if (typeof (reqFilekey) == 'undefined') 
		{
			reqFilekey = "";
		}
		if (typeof (resFilekey) == 'undefined') 
		{
			resFilekey = "";
		}

		this.doc = this.webBrowResult.getProperty("document");

		nexacro.getApplication().gv_mainFrame.divMain.set_visible(true);
		
		
		var content = this.ds_ReqDetail.getColumn(0, "req_remark");
		
		content = content.replaceAll(String.fromCharCode(10),'<br>');	// view.html 내로 이동시킴
		//trace(content);
		this.webBrowResult.callMethod("setContent", content, true);

		// 이전/다음 게시물 불러오기
		if (nexacro.getApplication().gv_mainFrame.PCategory2 == "Bookmark_View")
		{
			this.set_PreNextNoBookmark(this.ds_ReqDetail.getColumn(0,"BL_SEQ"),this.ds_ReqDetail.getColumn(0,"mip_version"));	
		}
		else if (nexacro.getApplication().gv_mainFrame.PCategory2 == "SearchEngine_QnA_View")	// 통합검색일경우 이전/다음글 안보이게
		{
			this.viewNavi.set_height(0);
			this.viewNavi.set_visible(false);
			this.resetScroll();
		}
		else
		{
			this.set_PreNextNo(this.ds_ReqDetail.getColumn(0,"BL_SEQ"),this.ds_ReqDetail.getColumn(0,"mip_version"));	
		}
		
	}
};

// editor.html 영역에서 특정 값을 얻어온다.
this.getHTMLValue1 = function(name)
{
	this.webBrowResult.callMethod("getHTMLValue", name);
	
	var el = this.webBrowResult.getProperty("document").callMethod("getElementById", "transfer");
	var val = el.getProperty("value");
	
	el.setProperty("value", "");
		
	return val;	
}

// editor.html 영역에서 특정 값을 얻어온다.
this.getHTMLValue2 = function(name)
{
	this.divTreat.form.webBrowResult2.callMethod("getHTMLValue", name);
	
	var el = this.divTreat.form.webBrowResult2.getProperty("document").callMethod("getElementById", "transfer");
	var val = el.getProperty("value");
	
	el.setProperty("value", "");
		
	return val;	
}

// req 웹브라우저 이벤트
this.webBrowResult_onusernotify = function (obj:WebBrowser, e:nexacro.WebTitleChangeEventInfo)
{
	var id = e.userdata.method;
	//var id = e.userdata;

	if (id == "loadContent")
	{
		this.nRes = this.getHTMLValue1("getContentHeight");
	}
	else if (id == "getContentHeight")
	{
		this.wbHeight1 = this.nRes;
		
		if (this.wbHeight1 > 1000 && this.wbHeightLongFlg == false)
		{
			this.wbHeightLongFlg = true;
			this.setTimer(111, 300);
		}
		else
		{
			// 웹브라우저 높이 조절
			this.webBrowResult.set_height(parseInt(this.wbHeight1) + 50);
			
			// 두번째 웹브라우저 setContent
			var content2 = this.ds_ReqDetail.getColumn(0, "res_remark");
			content2 = content2.replaceAll(String.fromCharCode(10),'<br>');	// view.html 내로 이동시킴
			this.divTreat.form.webBrowResult2.callMethod("setContent", content2, true);
		}
	}
};

// res 웹브라우저 이벤트
this.webBrowResult2_onloadcompleted = function(obj:nexacro.WebBrowser,e:nexacro.WebLoadCompEventInfo)
{
	
};

this.webBrowResult2_onusernotify = function(obj:nexacro.WebBrowser,e:nexacro.WebUserNotifyEventInfo)
{

	var id = e.userdata.method;

	if (id == "loadContent")
	{
		this.nRes2 = this.getHTMLValue2("getContentHeight");
	}	
	else if (id == "getContentHeight")
	{
		var wbHeight2 = this.nRes2;
		
		// 총높이
		var nHeight = 0;
			
		// 상태값 '처리중' 인 게시물은 답변란 가리기
			
		// wb높이 Null Check
		nHeight = 680+parseInt(this.wbHeight1)+parseInt(wbHeight2);
		// 웹브라우저 높이 조절

		this.divTreat.form.webBrowResult2.set_height(parseInt(wbHeight2) + 50);
		this.divTreat.set_height(parseInt(wbHeight2) + 200);	
		this.divTreat.set_top(this.webBrowResult.getOffsetBottom()+50);
		// 웹브라우저 아래 컴포넌트 위치 조정
		var sStatus = this.ds_ReqDetail.getColumn(0, "res_status");
		
		var nSize = 0;
		switch(sStatus)
		{
			case "C":
				//this.Div_reSearch.set_height(190);
				nSize = nHeight + 497;
				break;
			case "WI":
			case "W":
				nHeight = 680+parseInt(this.wbHeight1);
				this.Div_reSearch.set_height(0);
				this.Div_reSearch.set_visible(false);
				nSize = nHeight + 108;
				this.divTreat.set_height(0);
				this.divTreat.set_visible(false);
				break;
			default:
				this.Div_reSearch.set_height(0);
				this.Div_reSearch.set_visible(false);
				nSize = nHeight + 308;
		}
		// 통합검색은 이전/다음글이 없기 때문에 하단 높이를 조금 작게함
		var sMenu = nexacro.getApplication().gv_mainFrame.PCategory2.replace("_View", "");
		if (sMenu == "SearchEngine_QnA")
		{
			nSize = nSize - 110;
		}
		nexacro.getApplication().gv_mainFrame.fn_setMainResize(false, nSize);
		this.divTreat.form.resetScroll();
		this.resetScroll();
	}
};

// 목록으로 돌아가기
this.btnList_onclick = function (obj:Button, e:nexacro.ClickEventInfo)
{
	nexacro.getApplication().gv_mainFrame.QAStatus = "List";
	var sMenu = nexacro.getApplication().gv_mainFrame.PCategory2.replace("_View", "");
	if (sMenu == "SearchEngine_QnA")
	{
		sMenu = "SearchEngine";
	}
	//else if (sMenu == "MyQnAList")
	if( this.gbn == "MyQnAList" )
	{
		sMenu = "MyQnAList";
		if (nexacro.getApplication().gv_mainFrame.QA_Cond_Prod != "All")
		{
			switch(nexacro.getApplication().gv_mainFrame.QA_Cond_Prod) {
			case "All":
				nexacro.getApplication().gv_mainFrame.MYPAGE_Cond_Prod = 0;
				break;
			case "Nexacro N":
				nexacro.getApplication().gv_mainFrame.MYPAGE_Cond_Prod = 1;
				break;
			case "nexacro platform17":
				nexacro.getApplication().gv_mainFrame.MYPAGE_Cond_Prod = 2;
				break;
			case "nexacro platform14":
				nexacro.getApplication().gv_mainFrame.MYPAGE_Cond_Prod = 3;
				break;
			case "XPLATFORM":
				nexacro.getApplication().gv_mainFrame.MYPAGE_Cond_Prod = 4;
				break;
			case "MiPlatform":
				nexacro.getApplication().gv_mainFrame.MYPAGE_Cond_Prod = 5;
				break;
			default:
			}
			
		}
	}
	var sKeyword = nexacro.getApplication().gv_mainFrame.QA_Cond_Keyword;
	var nPage = nexacro.getApplication().gv_mainFrame.QA_Cond_Page;
	if (this.gfnIsNull(nPage))
	{
		nPage = 1;
	}
	
	nexacro.getApplication().gv_mainFrame.param = {
		'menu': sMenu,
		'keyword': sKeyword,
		'page': nPage,
		'postId': ""
		};
	nexacro.getApplication().gv_mainFrame.gfnGoMain();
};

this.btnWrite_onclick = function (obj:Button, e:nexacro.ClickEventInfo)
{
	nexacro.getApplication().gv_mainFrame.QAStatus = "Write";
	
	var sMenu = nexacro.getApplication().gv_mainFrame.PCategory2.replace("_View", "");
	nexacro.getApplication().gv_mainFrame.param = {
		'menu': sMenu+"_Write",//"Sketch_Write",
		'keyword': "",
		'page': 1,
		'postId': ""
		};
	nexacro.getApplication().gv_mainFrame.gfnGoMain();
};

this.btnReply_onclick = function (obj:Button, e:nexacro.ClickEventInfo)
{
	nexacro.getApplication().gv_mainFrame.QAStatus = "Reply";
	
	var sMenu = nexacro.getApplication().gv_mainFrame.PCategory2.replace("_View", "");
	// 화면의 데이터를 복제
	nexacro.getApplication().gv_mainFrame.param = {
		'menu': sMenu+"_Write",//"Sketch_Write",
		'keyword': "",
		'page': 1,
		'postId': this.sIdx
		};
	nexacro.getApplication().gv_mainFrame.gfnGoMain();
};

// 제품 아이콘 셋팅
this.fnProductCodeIcon = function(sPdCd)
{
/*
 *	N     043
 *	17    039
 *	14    024 025 026 027 034
 *	XP    010 011 019 020 021 022 023 030 031 032 033
 *	MP    001 002 003 004 005 006 007 008 009 017 018 028 029 030
 *  URL('theme://images/grd_WF_iconN.png')
 *  URL('theme://images/grd_WF_icon17.png')
 *  URL('theme://images/grd_WF_icon14.png')
 *  URL('theme://images/grd_WF_iconXP.png')
 *  URL('theme://images/grd_WF_iconMI.png')
 */
	var sRtn = "";
	switch(sPdCd) {
	case "044":
		sRtn = "sta_WF_iconSK";
		break;	
	case "045":
		sRtn = "sta_WF_iconNN";
		break;	
	case "043":
		sRtn = "sta_WF_iconNN";
		break;
	case "039":
		sRtn = "sta_WF_iconN17";
		break;
	case "024": case "025": case "026": case "027": case "034":
		sRtn = "sta_WF_iconN14";
		break;
	case "010": case "011": case "019": case "020": case "021": case "022": case "023": case "031": case "032": case "033":
		sRtn = "sta_WF_iconXP";
		break;
	case "001": case "002": case "003": case "004": case "005": case "006": case "007": case "008": case "009": case "017": case "018": case "028": case "029": case "030":
		sRtn = "sta_WF_iconMI";
		break;
	default:
	}
	return sRtn;
};


// 북마크 이벤트
this.btn_BookMark_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
		this.user_id = nexacro.getApplication().gds_UserInfo.getColumn(0, "User_id");
		this.reqIdx = this.ds_ReqDetail.getColumn(e.row, "BL_SEQ");

		//북마크 중복처리용
		nexacro.getApplication().gds_MiWizard.clearData();
		nexacro.getApplication().com_AddMiWizard("","output1","req_idx=" + this.reqIdx + "&user_id='"+this.user_id+"'&kind='Q'","CS,cs_request_proc,27");	           
		this.com_CallService("selectBookMark", "", "", "ds_bookMark=output1", "fn_callback", "CS", false);			

		if(this.ds_bookMark.rowcount > 0) {
			this.btn_BookMark.set_cssclass("btn_WF_book");
			this.btn_BookMark.set_accessibilitydescription("북마크수, 비활성상태");
			
			//북마크 저장을 위한 데이터셋 
			this.ds_update.clearData();
			this.ds_update.addRow();
			this.ds_update.setColumn(0, "SQL_ID" , "'CS,cs_request_proc,26'" );
			
			nexacro.getApplication().gds_MiWizard.clearData();   	
			nexacro.getApplication().com_AddMiWizard("input1","","req_idx=" + this.reqIdx + "&user_id='"+this.user_id+"'&kind='Q'&flag='N'","","CS,cs_request_proc,26");

			var inDs = "input1=ds_update:U";
			this.com_CallService("deleteBookMark", "", inDs, "", "", "CS", false);							
		} else {
			this.btn_BookMark.set_cssclass("btn_WF_book_S");	
			this.btn_BookMark.set_accessibilitydescription("북마크수, 활성상태");
			
			//북마크 저장을 위한 데이터셋 
			this.ds_update.clearData();
			this.ds_update.addRow();
			this.ds_update.setColumn(0, "SQL_ID" , "'CS,cs_request_proc,26'" );
			
			nexacro.getApplication().gds_MiWizard.clearData();   	
			nexacro.getApplication().com_AddMiWizard("input1","","req_idx=" + this.reqIdx + "&user_id='"+this.user_id+"'&kind='Q'&flag='Y'","","CS,cs_request_proc,26");

			var inDs = "input1=ds_update:U";
			this.com_CallService("selectBookMark", "", inDs, "", "", "CS", false);		
		}	
		var reqIdx=nexacro.getApplication().gv_mainFrame.strTempFilder1;
		if (this.gfnIsNull(reqIdx))
		{
			reqIdx = this.reqIdx;
		}
		nexacro.getApplication().gv_mainFrame.QAKeyNo=reqIdx;
		
		// 인수 설정     

		this.user_id = nexacro.getApplication().gds_UserInfo.getColumn(0, "User_id");
		
		//조회 카운트 저장을 위한 데이터셋 
		this.ds_update.clearData();
		this.ds_update.addRow();
		this.ds_update.setColumn(0, "SQL_ID" , "'CS,cs_request_proc,26'" );
		
		nexacro.getApplication().gds_MiWizard.clearData();   	
		nexacro.getApplication().com_AddMiWizard("","output1","req_idx=" + reqIdx+ "&user_id='"+this.user_id+"'","CS,cs_request_proc,25");
		nexacro.getApplication().com_AddMiWizard("","output2","str_an=" + reqIdx + "&user_id='"+this.user_id+"'","CS,statistics,5");
		//nexacro.getApplication().com_AddMiWizard("","output3","req_idx=" + reqIdx + "&kind='QL'","CS,cs_request_proc,32");
 		//nexacro.getApplication().com_AddMiWizard("","output4","req_idx=" + reqIdx + "&kind='AL'","CS,cs_request_proc,32");		
		nexacro.getApplication().com_AddMiWizard("","output3","req_idx=" + reqIdx + "&kind='"+this.strBoardId+"Q'","CS,cs_request_proc,32");
		nexacro.getApplication().com_AddMiWizard("","output4","req_idx=" + reqIdx + "&kind='"+this.strBoardId+"A'","CS,cs_request_proc,32");		
		
		// idx의 상태에따라 만족도 조사 SQL문을 가져와야함  includeQAViewBodyNew.asp

		var outDs = "ds_ReqDetail=output1 ds_CustSafctData=output2 ds_downloadfile_req=output3 ds_downloadfile_res=output4";
		var inDs = "input1=ds_update:U";
		this.com_CallService("selectDetail2", "", inDs, outDs, "fn_SelectListCallBack", "CS", true);
};

