// pdiv위 grid 다운로드 클릭
this.pdivFiles_grdFiles_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if (e.cell == 0 || e.cell == 1)
	{
		// 바로 다운로드
		this.FileDownload00.set_downloadurl(this.ds_downloadfile_res.getColumn(e.row, "URL"));
		this.FileDownload00.download();
		
	}
	else if (e.cell == 2)
	{
		if (!this.fn_exprFileChkRes(e.row))
		{
			return;
		}
		var objFrame = new ChildFrame();
		var objParentFrame = this.getOwnerFrame();

		var nLeft = nexacro.getApplication().gv_mainFrame.getOffsetWidth()/2 - 400;
		var nTop = nexacro.getApplication().gv_mainFrame.getOffsetHeight()/2 - 400;
		objFrame.init( "modalContent", nLeft, nTop, 800, 800 );
		objFrame.set_titletext("소스보기");
		objFrame.set_titlebarheight(40);
		objFrame.set_formurl( "COMMFORM::frmFileViewer.xfdl" );

		var vRtn = objFrame.showModal( objParentFrame, {dsNM:this.ds_downloadfile_res,nRow:this.ds_downloadfile_res.rowposition}, this, this.fn_callback );
	}
};

