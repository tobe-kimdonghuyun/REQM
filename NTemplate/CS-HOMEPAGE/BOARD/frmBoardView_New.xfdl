*******************************************************************************
*/

this.doc = "";
this.sIdx = "";

this.query = "WHERE";

this.sFilePop = "";

this.nRes = 0;
this.nRes2 = 0;
this.wbHeight1 = 0;
this.wbHeight2 = 0;
this.wbHeightLongFlg = false;

this.strBoardId;
this.gbn;
this.techinquireView_onload = function (obj:Form, e:nexacro.LoadEventInfo)
{
	this.gbn = nexacro.getApplication().gv_mainFrame.param.gbn;
	
	if (this.gfnIsNull(nexacro.getApplication().gv_mainFrame.strTempFilder1))
	{
		this.sIdx = nexacro.getApplication().gv_mainFrame.param.postId;
	}
	else
	{
		this.sIdx = nexacro.getApplication().gv_mainFrame.strTempFilder1;
	}
	
	// 자동로그인 유저면 그냥 보여주고 아니면 로그인화면으로 보낸다.
	var bLogin = nexacro.getApplication().gv_mainFrame.fn_AutoLogin();

	if (bLogin)
	{
		this.LocationUrl = window.location;

		this.webBrowResult.set_url(nexacro.getApplication().gv_DomainInfo+"CKEDITOR/editor/view.html");	//	nexacro.getApplication().gv_DomainInfo + "Next_JSP/SearchEngine/Html/Inner_" + nexacro.getApplication().gv_Language + ".html"	
		this.divTreat.form.webBrowResult2.set_url(nexacro.getApplication().gv_DomainInfo+"CKEDITOR/editor/view_admin.html");	//	nexacro.getApplication().gv_DomainInfo + "Next_JSP/SearchEngine/Html/Inner_" + nexacro.getApplication().gv_Language + ".html"	
		
		this.Div_reSearch.set_url("SUPPORT::Research.xfdl");
	}
	else
	{
		nexacro.getApplication().gv_mainFrame.TargetUrl = nexacro.getApplication().gv_mainFrame.param.menu;
		nexacro.getApplication().gv_mainFrame.TargetPostId = this.sIdx;
		
		nexacro.getApplication().gv_mainFrame.param = {
			'menu': "login",
			'keyword': "",
			'page': 1,
			'postId': ""
			};
		nexacro.getApplication().gv_mainFrame.gfnGoMain();
	}
};

// 이전/다음 게시글 제목 가져오기
this.set_PreNextNo = function(idx,code)
{
	if( this.gbn == "MyQnAList" ) {
		this.viewNavi.set_visible(false);
		this.viewNavi.set_height(0);
	} else { 
		this.viewNavi.set_visible(true);
	}	

	nexacro.getApplication().gv_mainFrame.QAKeyNo=idx;
	this.ds_PreNext2.clear();
	nexacro.getApplication().gds_MiWizard.clearData();

	if( nexacro.getApplication().gv_mainFrame.PCategory2 == "MyQnAList_View" || this.gbn == "MyQnAList"){
		if( nexacro.getApplication().gv_mainFrame.My_Tab_Index == 6 ){
			this.query = "WHERE PRODUCT_CODE IN (''044'',''045'')  and";
		} else if( nexacro.getApplication().gv_mainFrame.My_Tab_Index == 5 ){
			this.query = "WHERE PRODUCT_CODE IN (''001'',''002'',''003'',''004'',''005'',''006'',''007'',''008'',''009'', ''017'',''018'',''028'',''029'',''030'', null, '''', '' '')  and";
		} else if( nexacro.getApplication().gv_mainFrame.My_Tab_Index == 4 ){
			this.query = "WHERE PRODUCT_CODE IN (''010'',''011'',''012'', ''019'', ''020'', ''021'', ''022'', ''023'', ''031'',''032'',''033'')  and";
		} else if( nexacro.getApplication().gv_mainFrame.My_Tab_Index == 3 ){
			this.query = "WHERE PRODUCT_CODE IN (''024'',''025'',''026'', ''027'', ''034'')  and";
		} else if( nexacro.getApplication().gv_mainFrame.My_Tab_Index == 2 ){
			this.query = "WHERE PRODUCT_CODE IN (''039'')  and";
		} else if( nexacro.getApplication().gv_mainFrame.My_Tab_Index == 1 ){
			this.query = "WHERE PRODUCT_CODE IN (''043'')  and";
		} else if( nexacro.getApplication().gv_mainFrame.My_Tab_Index == 0 ){

			this.query = "WHERE";
		} 				
		this.query += " INSERT_USER_ID IN (''" + nexacro.getApplication().gds_UserInfo.getColumn(0, "User_id") + "'') and";		
	} else if(nexacro.getApplication().gv_mainFrame.PCategory2 == "Sketch_View") {		
		this.query ="WHERE PRODUCT_CODE IN (''044'')  and";
		this.query += " OPEN_FLAG in (1)  AND ";
		this.query += " INSERT_DATE BETWEEN DATEADD(MONTH, -1, @INSERT_DATE) AND DATEADD(MONTH, 1, @INSERT_DATE) and "; //조회 속도를 위해 추가(QnA전체 게시글)
	} else if(nexacro.getApplication().gv_mainFrame.PCategory2 == "Tutorial_View") {		
		this.query ="WHERE PRODUCT_CODE IN (''045'')  and";
		this.query += " OPEN_FLAG in (1)  AND ";
		this.query += " INSERT_DATE BETWEEN DATEADD(MONTH, -1, @INSERT_DATE) AND DATEADD(MONTH, 1, @INSERT_DATE) and "; //조회 속도를 위해 추가(QnA전체 게시글)
	}

	var sqlkeyword = "";
	var strTemp = [""];
	
	if(!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.QA_Cond_Keyword)){
		strTemp = nexacro.getApplication().gv_mainFrame.QA_Cond_Keyword.split(" ");
	}
	
	var searchgubun = nexacro.getApplication().gv_mainFrame.QA_Cond_Searchgubun;
	if (nexacro.getApplication().gv_mainFrame.QA_Cond_Searchfield == "100") {
		for (var i = 0; i < strTemp.length; i++) {
				sqlkeyword += " SUBJECT like N''%" + strTemp[i] + "%'' or CONTENTS like N''%" + strTemp[i] + "%''";			
			if (i == (strTemp.length - 1)) {
				sqlkeyword += " ) ";
			} else {
				sqlkeyword += " " + searchgubun + " ";
			}
		}
		this.condSQL += sqlkeyword;
	} else if (nexacro.getApplication().gv_mainFrame.QA_Cond_Searchfield == "200") {
		for (var i = 0; i < strTemp.length; i++) {
				sqlkeyword += " SUBJECT like N''%" + strTemp[i] + "%''";			
			if (i == (strTemp.length - 1)) {
				sqlkeyword += " ) ";
			} else {
				sqlkeyword += " " + searchgubun + " ";
			}
		}
		this.condSQL += sqlkeyword;	
	} else if (nexacro.getApplication().gv_mainFrame.QA_Cond_Searchfield == "300") {
		for (var i = 0; i < strTemp.length; i++) {
				sqlkeyword += " CONTENTS like N''%" + strTemp[i] + "%''";			
			if (i == (strTemp.length - 1)) {
				sqlkeyword += " ) ";
			} else {
				sqlkeyword += " " + searchgubun + " ";
			}
		}		
	}			
	
	var objEnv = nexacro.getEnvironment();
	objEnv.set_usewaitcursor( false );
    this.condSQL = this.query + " ( " + sqlkeyword ;
	var args = "query='" + this.condSQL + "'&idx="+idx;

	nexacro.getApplication().com_AddMiWizard("","output1",args,"CS,cs_request_proc,41");	
	this.com_CallService("selectNo", "", "", "ds_PreNext2=output1", "fn_callback", "CS", true);
}

this.set_PreNextNoBookmark = function(idx,code)
{
	this.viewNavi.set_visible(true);

	nexacro.getApplication().gv_mainFrame.QAKeyNo=idx;	
	this.ds_PreNext2.clear();
	nexacro.getApplication().gds_MiWizard.clearData();

	switch(nexacro.getApplication().gv_mainFrame.Bookmark_Tab_Index) {
	case 0:
		this.query = "WHERE";
		break;
	case 1:
		this.query = "WHERE PRODUCT_CODE IN (''043'')  and";
		break;
	case 2:
		this.query = "WHERE PRODUCT_CODE IN (''039'')  and";
		break;
	case 3:
		this.query = "WHERE PRODUCT_CODE IN (''024'',''025'',''026'', ''027'', ''034'')  and";
		break;
	case 4:
		this.query = "WHERE PRODUCT_CODE IN (''010'',''011'',''012'', ''019'', ''020'', ''021'', ''022'', ''023'', ''031'',''032'',''033'')  and";
		break;
	case 5:
		this.query = "WHERE PRODUCT_CODE IN (''001'',''002'',''003'',''004'',''005'',''006'',''007'',''008'',''009'', ''017'',''018'',''028'',''029'',''030'', null, '''', '' '')  and";
		break;
	default:
	}
	
	this.query += " OPEN_FLAG in (1)  AND ";
	
	var sqlkeyword = "";
	var strTemp = [""];
	if(!this.gfnIsNull(nexacro.getApplication().gv_mainFrame.QA_Cond_Keyword)){
		strTemp = nexacro.getApplication().gv_mainFrame.QA_Cond_Keyword.split(" ");
	}
	var searchgubun = nexacro.getApplication().gv_mainFrame.QA_Cond_Searchgubun;
	if (nexacro.getApplication().gv_mainFrame.QA_Cond_Searchfield == "100") {
		for (var i = 0; i < strTemp.length; i++) {
				sqlkeyword += " SUBJECT like N''%" + strTemp[i] + "%'' or CONTENTS like N''%" + strTemp[i] + "%''";			
			if (i == (strTemp.length - 1)) {
				sqlkeyword += " ) ";
			} else {
				sqlkeyword += " " + searchgubun + " ";
			}
		}
		this.condSQL += sqlkeyword;
	} else if (nexacro.getApplication().gv_mainFrame.QA_Cond_Searchfield == "200") {
		for (var i = 0; i < strTemp.length; i++) {
				sqlkeyword += " SUBJECT like N''%" + strTemp[i] + "%''";			
			if (i == (strTemp.length - 1)) {
				sqlkeyword += " ) ";
			} else {
				sqlkeyword += " " + searchgubun + " ";
			}
		}
		this.condSQL += sqlkeyword;	
	} else if (nexacro.getApplication().gv_mainFrame.QA_Cond_Searchfield == "300") {
		for (var i = 0; i < strTemp.length; i++) {
				sqlkeyword += " CONTENTS like N''%" + strTemp[i] + "%''";			
			if (i == (strTemp.length - 1)) {
				sqlkeyword += " ) ";
			} else {
				sqlkeyword += " " + searchgubun + " ";
			}
		}		
	}			

	this.condSQL = this.query + " ( " + sqlkeyword ;		
	var args = "query='" + this.condSQL + "'&idx="+idx+"&userid='" + nexacro.getApplication().gds_UserInfo.getColumn(0, "User_id") + "'&kind='Q'";

	
	var objEnv = nexacro.getEnvironment();
	objEnv.set_usewaitcursor( false );
	nexacro.getApplication().com_AddMiWizard("","output1",args,"CS,cs_request_proc,38");	
	this.com_CallService("selectNo2", "", "", "ds_PreNext2=output1", "fn_callback", "CS", true);	
};

this.fn_callback = function (svcid,errCode,errMsg)
{
	if( svcid == "selectNo" )
	{
		this.viewNavi.set_enable(true);
		var objEnv = nexacro.getEnvironment();
		objEnv.set_usewaitcursor( true );
		 var seq = this.ds_ReqDetail.getColumn(0,"BL_SEQ");
         this.ds_PreNext2.filter("BL_SEQ!="+seq);
	
		var idx = this.ds_ReqDetail.getColumn(0,"BL_SEQ");
		this.ds_PreNext2.filter("BL_SEQ!="+idx);
		if( this.ds_PreNext2.rowcount == 1 && nexacro.toNumber(this.ds_PreNext2.getColumn(0,"BL_SEQ")) > nexacro.toNumber(idx) ){
			if( nexacro.toNumber(this.ds_PreNext2.getColumn(0,"BL_SEQ_PARENTS")) == nexacro.toNumber(idx) && this.ds_PreNext2.getColumn(0, "RE_LEVEL") > 0 ){
				this.viewNavi.form.stc_next.BL_SEQ = this.ds_PreNext2.getColumn(0, "BL_SEQ");
				this.viewNavi.form.stc_next.set_text(this.ds_PreNext2.getColumn(0, "SUBJECT"));	
				this.viewNavi.form.stc_next.set_cursor("");
				this.viewNavi.form.stc_nextIcon.set_cursor("pointer");
				this.viewNavi.form.stc_pre.set_text("게시글이 없습니다.");
