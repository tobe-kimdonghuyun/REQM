this.ext_Array = new Array("xml","xfdl","js","xjs","html","jsp","txt","xadl","asp","csv", "css","xcss");
this.fn_exprFileChkReq = function(nRow)
{
	var ext = this.get_FlieExt(this.ds_downloadfile_req.getColumn(nRow,"SAVE_FILE_NAME"));
	var chk = false;
	for(var i=0; i<this.ext_Array.length; i++){
		if( this.ext_Array[i] == ext ) {
			chk = true;		
			break;
		}	
	}
	return chk;
}

this.fn_exprFileChkRes = function(nRow)
{
	var ext = this.get_FlieExt(this.ds_downloadfile_res.getColumn(nRow,"SAVE_FILE_NAME"));
	var chk = false;
	for(var i=0; i<this.ext_Array.length; i++){
		if( this.ext_Array[i] == ext ) {
			chk = true;		
			break;
		}	
	}
	return chk;
}

this.get_FlieExt = function(filename)
{
	var fileSplit = filename.split('.');
	var fileExt = '';
	if (fileSplit.length > 1) {
		fileExt = fileSplit[fileSplit.length - 1];
	} 
	return fileExt;
}


