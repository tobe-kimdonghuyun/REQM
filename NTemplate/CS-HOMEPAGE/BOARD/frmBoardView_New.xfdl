				this.viewNavi.form.stc_next.set_text("게시글이 없습니다.");
				this.viewNavi.form.stc_next.set_cssclass("sta_WF_viewDetail");
				this.viewNavi.form.stc_next.set_enable(false);
				this.viewNavi.form.stc_nextIcon.set_enable(false);
				this.viewNavi.form.stc_nextIcon.set_cursor("default");
			}
		} else if( this.ds_PreNext2.rowcount == 1 && nexacro.toNumber(this.ds_PreNext2.getColumn(0,"BL_SEQ")) < nexacro.toNumber(seq) ){
			this.viewNavi.form.stc_next.BL_SEQ = this.ds_PreNext2.getColumn(0, "BL_SEQ");
			this.viewNavi.form.stc_next.set_text(this.ds_PreNext2.getColumn(0, "SUBJECT"));	
