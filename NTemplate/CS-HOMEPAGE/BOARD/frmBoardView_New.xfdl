// 수정하기 버튼 이벤트
this.btnModify_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// Modify
	nexacro.getApplication().gv_mainFrame.QAStatus = "Modify";
	var sMenu = nexacro.getApplication().gv_mainFrame.PCategory2.replace("_View", "");
	// 화면의 데이터를 복제
	nexacro.getApplication().gv_mainFrame.param = {
		'menu': sMenu+"_Write",//"Sketch_Write",
		'keyword': "",
		'page': 1,
		'postId': this.sIdx
		};
	nexacro.getApplication().gv_mainFrame.gfnGoMain();
};

// 온타이머
this.techinquireView_ontimer = function(obj:nexacro.Form,e:nexacro.TimerEventInfo)
{
	this.killTimer(e.timerid);
	if (e.timerid == 111)
	{
		this.nRes = this.getHTMLValue1("getContentHeight");
	}
};
]]></Script>
    <Bind>
      <BindItem id="item1" compid="btnAttachFile" propid="text" datasetid="ds_downloadfile_req" columnid="FILE_NAME"/>
    </Bind>
  </Form>
</FDL>
