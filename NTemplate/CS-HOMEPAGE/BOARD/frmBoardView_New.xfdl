	contents +='        </div>                                                                                                                                                                      ';
	contents +='    </body>                                                                                                                                                                         ';
	contents +='</html>                                                                                                                                                                             ';
	
	var objAry = contents.split("\n");	
	
	var strContent = "";	
	for(var i = 0; i < objAry.length; i++)
	{
		strContent += objAry[i] +"<\BR>";
	}	
	
	this.ds_sendmail.setColumn(0, "id", id);
	this.ds_sendmail.setColumn(0, "subject", subject);
	this.ds_sendmail.setColumn(0, "mailto", mailto);
	this.ds_sendmail.setColumn(0, "contents", strContent);
	this.ds_sendmail.setColumn(0, "mailFrom", "helpdesk@tobesoft.com");
		
	if(this.gfnIsNull(mailto))
	{
		this.alert("메일주소를 입력해 주세요");		
	}
	this.ds_downloadfile.clearData();
	this.ds_downloadfile.appendData(this.ds_downloadfile_req);
	this.ds_downloadfile.appendData(this.ds_downloadfile_res);
	
	//드라이브 위치 조정(운영과 달라서 조정)
	for(var i=0; i<this.ds_downloadfile.rowcount; i++)
	{
		this.ds_downloadfile.setColumn(i,"SAVE_PATH", this.ds_downloadfile.getColumn(i,"SAVE_PATH"));
	}
	
	this.fn_saveData();
	//this.pdivEmail.closePopup();
}

this.fn_saveData = function()
{	
	var strURL = "SVC_JSP::Next_JSP/Support/sendMail.jsp";	
	this.transaction("sendMail",strURL,"dsMail=ds_sendmail:A File=ds_downloadfile:A","dsReturn=dsMail","","fnCallBack");
	
}

this.fnCallBack = function(svcid, errCode, errMsg)
{
	if(errCode < 0)
	{
		alert("메일 발송에 실패 하였습니다.");
		return;
	}
	if(svcid == "sendMail")
	{
		//nexacro.setPrivateProfile("get_email", this.pdivEmail.form.edtEmail.value);
		nexacro.setPrivateProfile("get_email", this.divTreat.form.divEmail.form.edtEmail.value);
		alert("메일 전송이 완료 되었습니다.");	
	}
}


