			this.viewNavi.form.stc_preIcon.set_cursor("default");
		} else if(this.ds_PreNext2.rowcount == 0) {
			this.viewNavi.form.stc_next.set_text("게시글이 없습니다.");
			this.viewNavi.form.stc_next.set_cssclass("sta_WF_viewDetail");
			this.viewNavi.form.stc_next.set_enable(false);
			this.viewNavi.form.stc_nextIcon.set_enable(false);
			this.viewNavi.form.stc_nextIcon.set_cursor("default");
			this.viewNavi.form.stc_pre.set_text("게시글이 없습니다.");
			this.viewNavi.form.stc_pre.set_cssclass("sta_WF_viewDetail");
			this.viewNavi.form.stc_pre.set_enable(false);
			this.viewNavi.form.stc_preIcon.set_enable(false);
			this.viewNavi.form.stc_preIcon.set_cursor("default");
		} else {
			this.viewNavi.form.stc_next.BL_SEQ = this.ds_PreNext2.getColumn(1, "BL_SEQ");
			this.viewNavi.form.stc_next.set_text(this.ds_PreNext2.getColumn(1, "SUBJECT"));
			this.viewNavi.form.stc_next.set_cursor("");
			this.viewNavi.form.stc_nextIcon.set_cursor("pointer");
			this.viewNavi.form.stc_pre.BL_SEQ = this.ds_PreNext2.getColumn(0, "BL_SEQ");
			this.viewNavi.form.stc_pre.set_text(this.ds_PreNext2.getColumn(0, "SUBJECT"));	
			this.viewNavi.form.stc_pre.set_cursor("");
			this.viewNavi.form.stc_preIcon.set_cursor("pointer");
		}
		this.resetScroll();
	}
	else if( svcid == "selectNo2" )
	{
