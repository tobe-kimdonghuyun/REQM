<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmBoardList_Tip" width="945" height="226" titletext="Format : Tip" onload="frmBoardList_Tip_onload">
    <Layouts>
      <Layout height="226" horizontalgap="0" mobileorientation="landscape" spacing="0px" tabletemplate="1* / 1*" verticalgap="0" width="945">
        <Static id="staTitle" taborder="0" left="0" top="20" height="40" right="0" cssclass="sta_WF_ConTitle" usedecorate="true" onclick="staTitle_onclick" accessibilityenable="false" accessibilitydescription="링크"/>
        <Button id="btnTitle" taborder="1" left="0" top="20" width="945" height="40" cssclass="btn_WF_Focus" onclick="staTitle_onclick"/>
        <Static id="staContent" taborder="2" left="0" top="70" height="80" right="0" cssclass="sta_WF_Content" usedecorate="true" text="" accessibilitylabel="내용"/>
        <Static id="staNo" taborder="3" left="0" top="165" height="40" width="80" cssclass="sta_WF_ConNumber" accessibilitylabel="글번호"/>
        <Static id="staDate" taborder="4" left="staNo:20" top="165" height="40" width="95" cssclass="sta_WF_ConNumber" accessibilitylabel="등록일"/>
        <Static id="staView" taborder="5" left="staDate:20" top="165" height="40" width="80" cssclass="sta_WF_ConView" accessibilitylabel="조회수"/>
        <Button id="btnLink" taborder="6" left="staView:20" top="165" width="120" height="40" cssclass="btn_WF_ConLink" text="링크복사" onclick="btnLink_onclick" accessibilitydescription="팝업"/>
        <Static id="staFileName" taborder="7" left="btnLink:20" top="165" height="40" width="95" cssclass="sta_WF_ConFile" onclick="staFileName_onclick" fittocontents="width" accessibilitylabel="첨부파일명"/>
        <Static id="Static03" taborder="8" left="0" height="1" right="0" cssclass="sta_WF_ConLine" top="225" accessibilityenable="false"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[this.BoardForm = this.parent.parent.parent.parent.parent.parent;

this.frmBoardList_Tip_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	var sParentId = this.parent.id;
	var objDs  = this.BoardForm.ds_NoticeList;
	this.fn_InitFormData(objDs, nexacro.toNumber(sParentId.replaceAll("divNoticeList","")));	
};


this.fn_InitFormData = function(ds, nIdx)
{
	this.staTitle.text = this.gfn_makeEllipse(ds.getColumn(nIdx, "SUBJECT"), this.staTitle);
	this.staTitle.tooltiptext = ds.getColumn(nIdx, "SUBJECT").replaceAll("<fc v='#fb6d3a'>","").replaceAll("<fc v='#ff0000'>","").replaceAll("</fc>","");
	this.btnTitle.accessibilitylabel = "링크 제목 " + this.staTitle.tooltiptext;
	
	this.staContent.text = ds.getColumn(nIdx, "CONTENTS");
// 	this.staContent.accessibilitylabel = "내용 " + this.staContent.text.replaceAll(/<[^>]*>/g, '')  // HTML 태그 제거
// 																		.replaceAll('&nbsp;', ' ')  // &nbsp;를 공백으로 변경
// 																		.replaceAll('&quot;', '"')  // &quot;를 따옴표로 변경
// 																		.replaceAll('&#39;', "'")	// &#39;를 작은따옴표로 변경
// 																		.replaceAll('&lt;', '<')    // &lt;를 <로 변경
// 																		.replaceAll('&gt;', '>')   	// &gt;를 >로 변경
// 																		.replaceAll("&#xa;", "");  	// &#xa;를 빈 문자열로 바꾸기
	
	this.staNo.text = "No." + ds.getColumn(nIdx, "BL_SEQ");
	
	var sDate = ds.getColumn(nIdx, "INSERT_DATE");
	if(sDate.indexOf("/") > 0) 	sDate = sDate.replaceAll("/","-");
	else				 		sDate = sDate.slice(0, 4) + "-" + sDate.slice(4, 6) + "-" + sDate.slice(6);
	this.staDate.text = sDate;	
	
	this.staView.text = ds.getColumn(nIdx, "user_cnt");
	
	var sFileName = ds.getColumn(nIdx, "FILENAME");
	if (!this.gfnIsNull(sFileName)) {
		var nFileCnt =  ds.getColumn(nIdx, "FILE_CNT")>1? '('+ ds.getColumn(nIdx, "FILE_CNT") +')' : '';
		this.staFileName.text = sFileName + nFileCnt;
	} else {
		this.staFileName.visible = false;
	}
	
	this.resetScroll();
};


this.staTitle_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	var nIdx = nexacro.toNumber(this.parent.id[this.parent.id.length - 1]);
	var PCategoryGubun = nexacro.getApplication().gv_mainFrame.PCategory2;
	this.BoardForm.fn_BoardstaTitle_onclick(nIdx, PCategoryGubun);
};

this.btnLink_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var nIdx = nexacro.toNumber(this.parent.id[this.parent.id.length - 1]);
	var PCategoryGubun = nexacro.getApplication().gv_mainFrame.PCategory2;
	this.BoardForm.btnLink_onclick(nIdx);	
};
]]></Script>
    <Objects/>
  </Form>
</FDL>
