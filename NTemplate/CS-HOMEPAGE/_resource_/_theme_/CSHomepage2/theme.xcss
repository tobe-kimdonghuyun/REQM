	background : url('theme://images/btn_close_O.png') no-repeat center center transparent;
	-nexa-border : 2px solid transparent;
}
.Button.btn_POP_CloseIcon[status=focused]
{
	background : url('theme://images/btn_close_O.png') no-repeat center center transparent;
}
