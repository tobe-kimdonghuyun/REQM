	-nexa-border : 2px solid #000000;
	background : #000000;
	border-radius : 10px;
	cursor : pointer;
}
.ImageViewer.img_MF_Line01,
.ImageViewer.img_MF_Line01[status=mouseover],.ImageViewer.img_MF_Line01[status=disabled]
{
	-nexa-border : 0px solid;
	background : transparent;
	border-radius : 10px;
	cursor : pointer;
}
.ImageViewer.img_MF_Line01[status=focused]
{
	-nexa-border : 3px solid #5a86cd;
	background : transparent;
	border-radius : 10px;
	cursor : pointer;
}
.ImageViewer.img_MF_Logo,
.ImageViewer.img_MF_Logo[status=mouseover],.ImageViewer.img_MF_Logo[status=disabled]
{
	-nexa-border : 2px solid transparent;
	background : transparent;
	border-radius : 5px;
	cursor : pointer;
}
.ImageViewer.img_MF_Logo[status=focused]
{
	-nexa-border : 2px solid #5a86cd;
	background : transparent;
	border-radius : 5px;
	cursor : pointer;
}
.ImageViewer.img_WF_WA[status=focused]
{
	-nexa-border : 2px solid #5a86cd;
	background : transparent;
	border-radius : 5px;
	cursor : pointer;
}
.Static.sta_WF_viewDetail
{
	-nexa-vertical-align : top;
	-nexa-padding : 0px 0px 15px 0px;
	color : #444444;
	font : normal 400 14px/30px "NotoSansKR","Noto Sans KR";
	letter-spacing : 0px;	
}
.Static.sta_WF_PP
{
	-nexa-vertical-align : top;
	-nexa-padding : 0px 0px 15px 0px;
	color : #D9205E;
	font : normal 400 14px/30px "NotoSansKR","Noto Sans KR";
	letter-spacing : 0px;	
}
.Static.sta_WF_listUp
{
	-nexa-padding : 0px 0px 0px 30px;
	background : URL('theme://images/sta_WF_listUp.png') no-repeat left center transparent;
	color : #222222;
	font : normal 500 18px/normal "NotoSansKR","Noto Sans KR";
	letter-spacing : -1px;	
}
.Static.sta_WF_listDown
{
	-nexa-padding : 0px 0px 0px 30px;
	background : URL('theme://images/sta_WF_listDown.png') no-repeat left center transparent;
	color : #222222;
	font : normal 500 18px/normal "NotoSansKR","Noto Sans KR";
	letter-spacing : -1px;	
}
/***** WA-readonly *****/
.Edit.readonly,
.Edit.readonly[userstatus=nulltext],.Edit.readonly[status=mouseover],
.Edit.readonly[status=focused],.Edit.readonly[status=readonly],
.Edit.readonly[status=disabled],
.Calendar.readonly,
.Calendar.readonly[status=mouseover],.Calendar.readonly[status=focused],
.Calendar.readonly[status=readonly],.Calendar.readonly[status=disabled],
.CheckBox.readonly,
.CheckBox.readonly[status=mouseover],.CheckBox.readonly[status=focused],
.CheckBox.readonly[status=readonly],.CheckBox.readonly[status=disabled],
.Combo.readonly,
.Combo.readonly[status=mouseover],.Combo.readonly[status=focused],
.Combo.readonly[status=readonly],.Combo.readonly[status=disabled],
.MaskEdit.readonly,
.MaskEdit.readonly[userstatus=nulltext],.MaskEdit.readonly[status=mouseover],
.MaskEdit.readonly[status=focused],.MaskEdit.readonly[status=readonly],
.MaskEdit.readonly[status=disabled],
.Spin.readonly,
.Spin.readonly[status=mouseover],.Spin.readonly[status=focused],
.Spin.readonly[status=readonly],.Spin.readonly[status=disabled],
.TextArea.readonly,
.TextArea.readonly[userstatus=nulltext],.TextArea.readonly[status=mouseover],
.TextArea.readonly[status=focused],.TextArea.readonly[status=readonly],
.TextArea.readonly[status=disabled]
{
	-nexa-border : 2px solid #5a86cd;
}]]></CSSData>
