/**********************TextArea***********************************************/
.TextArea,.TextAreaControl
{
	-nexa-border : 1px solid #dbe2ea;
	-nexa-padding : 9px;
	background : #ffffff;
	border-radius : 5px;
	font : normal 400 14px/24px "NotoSansKR","Noto Sans KR";
}

.TextArea[status=mouseover],.TextArea[status=focused],
.TextAreaControl[status=mouseover],.TextAreaControl[status=focused]
{
	-nexa-border : 2px solid #5a86cd;
	-nexa-padding : 8px;
	border-radius : 5px;
}

