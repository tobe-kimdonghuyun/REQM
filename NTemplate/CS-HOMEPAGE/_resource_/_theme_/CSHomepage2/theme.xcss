}


/**********************ProgressBar***********************************************/
.ProgressBar,.ProgressBarControl
{
	-nexa-border : 1px solid #9c9c9c;
	background : linear-gradient(to top, #f0f0f0, #eeeeee);
	color : #333333;
}

.ProgressBar .progressbaritem,.ProgressBarControl .progressbaritem
{
	background : #3194df;
}

.ProgressBar .progressbaritem[status=disabled],.ProgressBarControl .progressbaritem[status=disabled]
{
	background : #b5b5b5;
}

.ProgressBar .progressbartext,.ProgressBarControl .progressbartext
{
	-nexa-text-align : center;
	color : #333333;
}


/**********************Radio***********************************************/
.Radio 
{
 
}
.Radio .radioitem
{
	-nexa-icon : URL('theme://images/img_radio_NN.png');
	-nexa-text-padding : 0px 0px 3px 3px;
}

.Radio .radioitem[userstatus=selected]
{
	-nexa-icon : URL('theme://images/img_radio_OS.png');
	-nexa-text-decoration : underline;
}

.Radio .radioitem[status=mouseover]
{
	-nexa-icon : URL('theme://images/img_radio_ON.png');
	/*-nexa-edge : url("theme://images/grd_WF_NaviBg01.png") 5px 5px;*/
}

.Radio .radioitem[status=disabled]
{
	-nexa-icon : URL('theme://images/img_radio_DN.png');
}

.Radio .radioitem[status=disabled][userstatus=selected]
{
	-nexa-icon : URL('theme://images/img_radio_DS.png');
	cursor : default;
}
.RadioItemControl
{
	-nexa-border : 2px solid transparent;		
	border-radius : 5px;
}
.RadioItemControl[status=mouseover]
{
	-nexa-border : 2px solid #5A88CA;		
}

