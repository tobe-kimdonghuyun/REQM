/************************  accessibility GUIDE  ************************/
.Static.sta_WF_WATxt
{
	-nexa-padding		: 0px 40px 0px 40px;
	-nexa-word-wrap 	: char;
	-nexa-text-align 	: left;
	-nexa-border 		: 1px solid #E5E5E5, 1px solid #E5E5E5, 1px solid #E5E5E5, 0px none;
	background 		: #ffffff;
	font 			: 16px/28px "Malgun Gothic";
	color 			: #4F4F4F;
	letter-spacing 		: -1px;
}
.Static.sta_WF_WATitle
{
	-nexa-text-align 	: center;
	-nexa-border 		: 2px solid #3E61D7;
	border-radius 		: 15px 0px 0px 15px;
	background 		: #ffffff;
	font 			: bold 20px/32px "Malgun Gothic";
	color 			: #3E61D7;
}
.Static.sta_WF_Point
{
	-nexa-padding		: 0px 0px 0px 22px;
	font 			: bold 15px "Malgun Gothic";
	color 			: #0F2058;
}
.Static.sta_WF_WACon
{
	-nexa-text-align 	: center;
	-nexa-border 		: 0px none;
	border-radius 		: 15px 0px 0px 15px;
	font 			: bold 20px/32px "Malgun Gothic";
	color 			: #ffffff;
	background 		: linear-gradient(to top left, #6D5BEA, #4660DA);
}
.Static.sta_WF_WATxt2
{
	-nexa-word-wrap 	: char;
	-nexa-text-align 	: left;
	-nexa-vertical-align 	: top;
	font 			: 16px/28px "Malgun Gothic";
	color 			: #4F4F4F;
	letter-spacing 		: -1px;
}
.Static.sta_WF_DetailBg
{
	-nexa-border 		: 1px solid #E5E5E5;
	-nexa-padding		: 0px 20px;
	-nexa-word-wrap 	: char;
	background 		: #ffffff;
	font 			: 16px/28px "Malgun Gothic";
	color 			: #4F4F4F;
	letter-spacing 		: -1px;
}
.Static.sta_WF_DetailLabel
{
