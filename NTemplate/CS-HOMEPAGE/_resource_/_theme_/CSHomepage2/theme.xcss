/**********************Spin***********************************************/
.Spin
{
	-nexa-border : 1px solid #dbe2ea;
	-nexa-padding : 1px 8px 2px 8px;
	background : #ffffff;
	border-radius : 5px;
}

.Spin[status=mouseover],.Spin[status=focused]
{
	-nexa-border : 2px solid #5a86cd;
	-nexa-padding : 0px 7px 1px 7px;
	border-radius : 5px;
}

.Spin[status=readonly]
{
	-nexa-border : 1px solid #dbe2ea;
	background : #fcfcfc;
	border-radius : 5px;
}

.Spin[status=disabled]
{
	background : #fcfcfc;
	border-radius : 5px;
	color : #6B7280;
}

.Spin .spinedit
{
	-nexa-text-align : right;
}

.Spin .spinedit[status=disabled]
{
}

.Spin .spinupbutton
{
	-nexa-icon : URL('theme://images/btn_WF_Spinup.png');
	-nexa-padding : 2px 0px 0px 0px;
}

.Spin .spinupbutton[status=mouseover]
{
	-nexa-icon : URL('theme://images/btn_WF_Spinup_O.png');
}

.Spin .spinupbutton[userstatus=pushed]
{
	-nexa-icon : URL('theme://images/btn_WF_Spinup_P.png');
}

.Spin .spinupbutton[status=disabled]
{
	-nexa-icon : URL('theme://images/btn_WF_Spinup_D.png');
	cursor : default;
}

.Spin .spindownbutton
{
	-nexa-icon : URL('theme://images/btn_WF_Spindown.png');
	-nexa-padding : 0px 0px 2px 0px;
}

.Spin .spindownbutton[status=mouseover]
{
	-nexa-icon : URL('theme://images/btn_WF_Spindown_O.png');
}

.Spin .spindownbutton[userstatus=pushed]
{
	-nexa-icon : URL('theme://images/btn_WF_Spindown_P.png');
}

.Spin .spindownbutton[status=disabled]
{
	-nexa-icon : URL('theme://images/btn_WF_Spindown_D.png');
	cursor : default;
}


