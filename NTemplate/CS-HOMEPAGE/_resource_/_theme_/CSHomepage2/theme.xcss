	-nexa-border : 1px solid #dfe1ed;
	-nexa-padding : 10px;
	border-radius : 5px;
	font : normal 400 14px/normal "NotoSansKR","Noto Sans KR";
	letter-spacing : -1px;	
}
.TextArea.txt_WF_apply[status=mouseover],.TextArea.txt_WF_apply[status=focused]
{
	-nexa-border : 2px solid #5a86cd;
	-nexa-padding : 9px;
	border-radius : 5px;
	font : normal 400 14px/normal "NotoSansKR","Noto Sans KR";
	letter-spacing : -1px;	
}
.TextArea.txt_WF_apply[userstatus=nulltext]
{
	-nexa-border : 1px solid #dfe1ed;
	-nexa-padding : 10px;
	border-radius : 5px;
	color : #aaaaaa;
	font : normal 400 14px/normal "NotoSansKR","Noto Sans KR";
	letter-spacing : -1px; 
}

/*********************************** POP ***********************************/
.Button.btn_POP_close,.Button.btn_POP_close[status=disabled],
.Button.btn_POP_close[status=mouseover],.Button.btn_POP_close[userstatus=pushed],
.Button.btn_POP_close[userstatus=selected]
{
	-nexa-border : 1px solid #eeeeee;
	background : transparent;
	color: #ffffff;
	font : normal 300 12px/normal "NotoSansKR","Noto Sans KR";	
}
.Button.btn_POP_close[status=focused]
{
	-nexa-border : 2px solid #ffffff;
	background : transparent;
	color: #ffffff;
	font : normal 300 12px/normal "NotoSansKR","Noto Sans KR";	
}
.Button.btn_POP_CloseIcon,
.Button.btn_POP_CloseIcon[status=mouseover],.Button.btn_POP_CloseIcon[userstatus=pushed],
.Button.btn_POP_CloseIcon[userstatus=selected]
