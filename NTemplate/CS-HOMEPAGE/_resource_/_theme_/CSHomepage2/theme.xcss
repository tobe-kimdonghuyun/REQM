<?xml version="1.0" encoding="utf-8"?>
<XCSS version="1.1">
  <CSSData><![CDATA[/**********************Frame/Form***********************************************/
.Form
{
	-nexa-border : 0px none;
	font : normal 400 14px/normal "NotoSansKR","Noto Sans KR";
	color : #222222;
	background : #ffffff;	
}

.Form[userstatus=contents]
{
	background : transparent;
}

.Form[status=disabled]
{
	color : #6B7280;
}

.MainFrame
{
	-nexa-border : 1px solid #333333;
}
.ChildFrame,.FrameSet,.VFrameSet,.HFrameSet,.TileFrameSet
{
	-nexa-border : 0px none;
}

.MainFrame .titlebar .titleicon
{
	-nexa-icon : ;
}


/**********************Button***********************************************/
/**********************FileDownload***********************************************/
/**********************FileUpload***********************************************/
.Button
{
	
	-nexa-border : 1px solid #a2a7be;
	-nexa-padding : 0px 11px 1px 10px;
	background : #ffffff;
	color : #333333;
	cursor : pointer;
}

.ButtonControl
{
	-nexa-border : 0px none;
	background : transparent;	
}

.Button[status=mouseover]
{
	-nexa-border : 1px solid #5a86cd;
	-nexa-padding : 0px 11px 1px 10px;
	background : #ffffff;
	color : #333333;
	cursor : pointer;
}
.Button[status=focused]
{
	-nexa-border : 2px solid #5a86cd;
	-nexa-padding : 0px 11px 1px 10px;
	background : #ffffff;
	color : #333333;
	cursor : pointer;
}

.Button[userstatus=pushed],.Button[userstatus=selected]
{
	-nexa-border : 1px solid #a0a0a0;
	-nexa-padding : 0px 11px 1px 10px;
	background : #ffffff;
	color : #333333;
	cursor : pointer;
}

.Button[status=disabled]
{
	opacity : 0.5;
	cursor : default;
}

.FileDownload,.FileDownload[status=disabled]
{
	-nexa-border : 0px none;
	-nexa-padding : 0px;
	font : normal 400 14px/normal "NotoSansKR","Noto Sans KR";
	color : #e4e7ed;
	background : #49506d;
	border-radius : 5px;
}
.FileUpload
{
	/*별도스타일없음*/
}

.FileUpload .fileuploaditem
{
	/*별도스타일없음*/
}

.FileUpload .fileuploaditem .fileuploaditemedit
{
	-nexa-border : 1px solid #dfe1ed;
	-nexa-padding : 0px 15px 2px 15px;
	background : #ffffff;
	border-radius : 5px;
	font : normal 400 14px/normal "NotoSansKR","Noto Sans KR";
	letter-spacing : -1px;
}

.FileUpload .fileuploaditem .fileuploaditemedit[status=disabled]
{
	-nexa-border : 1px solid #dfe1ed;
	-nexa-padding : 0px 15px 2px 15px;
	background : #fcfcfc;
	border-radius : 5px;
	color : #6B7280;
	font : normal 400 14px/normal "NotoSansKR","Noto Sans KR";
	letter-spacing : -1px;
}

.FileUpload .fileuploaditem .fileuploaditemedit[status=mouseover],.FileUpload .fileuploaditem .fileuploaditemedit[status=focused]
{
	-nexa-border : 1px solid #a2a7be;
	-nexa-padding : 0px 15px 2px 15px;
	background : #ffffff;
	border-radius : 5px;
	font : normal 400 14px/normal "NotoSansKR","Noto Sans KR";
	letter-spacing : -1px;
}

.FileUpload .fileuploaditem .fileuploaditemedit[userstatus=nulltext]
{
	-nexa-border : 1px solid #dfe1ed;
	-nexa-padding : 0px 15px 2px 15px;
	background : #ffffff;
	border-radius : 5px;
	font : normal 400 14px/normal "NotoSansKR","Noto Sans KR";
	color : #b9bec5;
	letter-spacing : -1px;
}

.FileUpload .fileuploaditem[status=disabled]
{
	color : #6B7280;
}

.FileUpload .fileuploaditem .fileuploaditembutton
{
	-nexa-border : 0px none;
	-nexa-padding : 0px;
	background : #49506d;
	border-radius : 5px;
	font : normal 400 14px/normal "NotoSansKR","Noto Sans KR";
	color : #e4e7ed;	
}

.FileUpload .fileuploaditem .fileuploaditembutton[status=disabled]
{
	-nexa-border : 0px none;
	-nexa-padding : 0px;
	background : #999999;
	border-radius : 5px;
	font : normal 400 14px/normal "NotoSansKR","Noto Sans KR";
	color : #6B7280;	
}

.FileDownload[status=mouseover],.FileDownload[status=focused],
.FileUpload .fileuploaditem .fileuploaditembutton[status=mouseover],.FileUpload .fileuploaditem .fileuploaditembutton[status=focused],
.FileDownload[userstatus=pushed],.FileUpload .fileuploaditem .fileuploaditembutton[userstatus=pushed],
.FileUpload .fileuploaditem .fileuploaditembutton[userstatus=selected]
{
	-nexa-border : 0px none;
	-nexa-padding : 0px;
	background : #3c4155;
	border-radius : 5px;
	font : normal 400 14px/normal "NotoSansKR","Noto Sans KR";
	color : #e4e7ed;	
}

/**********************Calendar***********************************************/
.Calendar,.CalendarControl
{
	-nexa-border : 1px solid #dbe2ea;
	-nexa-padding : 1px;
	background : #ffffff;
	border-radius : 5px;
}

.Calendar[status=mouseover],.CalendarControl[status=mouseover],
.Calendar[status=focused],.CalendarControl[status=focused]
{
	-nexa-border : 2px solid #5a86cd;
	-nexa-padding : 0px;
	border-radius : 5px;
}

.Calendar[status=readonly],.CalendarControl[status=readonly]
{
	-nexa-border : 1px solid #dbe2ea;
	background : #fcfcfc;
	border-radius : 5px;
}

.Calendar[status=disabled],.CalendarControl[status=disabled]
{
	background : #fcfcfc;
	color : #6B7280;
}

.Calendar .calendaredit,.CalendarControl .calendaredit
{
	-nexa-padding : 0px 8px 2px 8px;
}

.Calendar .dropbutton,.CalendarControl .dropbutton
{
	-nexa-icon : URL('theme://images/btn_WF_Calendar.png');
	-nexa-padding : 0px 0px 1px 0px;
}

.Calendar .dropbutton[status=disabled],.CalendarControl .dropbutton[status=disabled]
{
	-nexa-icon : URL('theme://images/btn_WF_Calendar_D.png');
	cursor : default;
}

.Calendar .calendarspinupbutton,.CalendarControl .calendarspinupbutton
{
	-nexa-icon : URL('theme://images/btn_WF_Spinup.png');
}

.Calendar .calendarspinupbutton[status=mouseover],.CalendarControl .calendarspinupbutton[status=mouseover]
{
	-nexa-icon : URL('theme://images/btn_WF_Spinup_O.png');
}

.Calendar .calendarspinupbutton[userstatus=pushed],.CalendarControl .calendarspinupbutton[userstatus=pushed]
{
	-nexa-icon : URL('theme://images/btn_WF_Spinup_P.png');
}

.Calendar .calendarspinupbutton[status=disabled],.CalendarControl .calendarspinupbutton[status=disabled]
{
	-nexa-icon : URL('theme://images/btn_WF_Spinup_D.png');
	cursor : default;
}

.Calendar .calendarspindownbutton,.CalendarControl .calendarspindownbutton
{
	-nexa-icon : URL('theme://images/btn_WF_Spindown.png');
}

.Calendar .calendarspindownbutton[status=mouseover],.CalendarControl .calendarspindownbutton[status=mouseover]
{
	-nexa-icon : URL('theme://images/btn_WF_Spindown_O.png');
}

.Calendar .calendarspindownbutton[userstatus=pushed],.CalendarControl .calendarspindownbutton[userstatus=pushed]
{
	-nexa-icon : URL('theme://images/btn_WF_Spindown_P.png');
}

.Calendar .calendarspindownbutton[status=disabled],.CalendarControl .calendarspindownbutton[status=disabled]
{
	-nexa-icon : URL('theme://images/btn_WF_Spindown_D.png');
	cursor : default; 
}

 /**********************CheckBox***********************************************/
.CheckBox,.CheckBoxControl 
{ 
	-nexa-border : 2px solid transparent;
	-nexa-icon : URL('theme://images/img_check_NN.png'); 
	-nexa-text-padding : 1px 1px 2px 5px;
	cursor : pointer;
}
.CheckBox[status=focused],.CheckBoxControl[status=focused]
{
	-nexa-border : 2px solid #5a86cd;
	-nexa-icon : URL('theme://images/img_check_NN.png');
	-nexa-text-decoration : underline;
	border-radius : 5px;
}

.CheckBox[status=mouseover],.CheckBoxControl[status=mouseover]
{
	-nexa-icon : URL('theme://images/img_check_ON.png'); 
}

.CheckBox[status=readonly],.CheckBoxControl[status=readonly]
{
	-nexa-icon : URL('theme://images/img_check_DN.png');
}

.CheckBox[userstatus=selected],.CheckBoxControl[userstatus=selected]
{
	-nexa-icon : URL('theme://images/img_check_OS.png');
}

.CheckBox[status=disabled],.CheckBoxControl[status=disabled]
{
	-nexa-icon : URL('theme://images/img_check_DN.png');
	color : #6B7280;
	cursor : default;
}

.CheckBox[status=disabled][userstatus=selected],.CheckBoxControl[status=disabled][userstatus=selected]
{
	-nexa-icon : URL('theme://images/img_check_DS.png');
	color : #6B7280;
}


/**********************Combo***********************************************/
.Combo,.ComboControl
{
	-nexa-border : 1px solid #dbe2ea;
	-nexa-padding : 1px;
	background : #ffffff;
	border-radius : 5px;
}

.Combo[status=mouseover],.Combo[status=focused],.ComboControl[status=mouseover],.ComboControl[status=focused]
{
	-nexa-border : 2px solid #5a86cd;
	-nexa-padding : 0px;
	border-radius : 5px;
}

.Combo[status=readonly],.ComboControl[status=readonly]
{
	-nexa-border : 1px solid #dbe2ea;
	background : #ffffff;
	border-radius : 5px;
}

.Combo[status=disabled],.ComboControl[status=disabled]
{
	background : #fcfcfc;
	border-radius : 5px;
	color : #6B7280;
}

.Combo .comboedit,.ComboControl .comboedit
{
	-nexa-padding : 0px 5px 2px 5px;
}

.Combo .dropbutton,.ComboControl .dropbutton
{
	-nexa-padding : 0px 2px 0px 0px;
	-nexa-icon : URL('theme://images/cmb_WF_Drop.png');
	cursor : pointer;
}

.Combo .dropbutton[status=mouseover],.Combo .dropbutton[status=focused],
.ComboControl .dropbutton[status=mouseover],.ComboControl .dropbutton[status=focused]
{
	-nexa-icon : URL('theme://images/cmb_WF_Drop.png');
}

.Combo .dropbutton[userstatus=pushed],.Combo .dropbutton[userstatus=selected],
.ComboControl .dropbutton[userstatus=pushed],.ComboControl .dropbutton[userstatus=selected]
{
	-nexa-icon : URL('theme://images/cmb_WF_Drop.png');
}

.Combo .dropbutton[status=disabled],.ComboControl .dropbutton[status=disabled]
{
	opacity : 0.50;
	cursor : default;
}

.Combo .combolist,.ComboControl .combolist,
.Combo .combolist[status=mouseover],.ComboControl .combolist[status=mouseover]
{
	-nexa-border : 2px solid #5a86cd;
	-nexa-padding : 0px none;
	background : #ffffff;
	border-radius : 5px;
}
.Combo .combolist .listboxitem,.ComboControl .combolist .listboxitem,
.Combo .combolist .listboxitem[status=mouseover],.ComboControl .combolist .listboxitem[status=mouseover]
{
	-nexa-padding : 0px 5px 1px 5px; 
}


/**********************Edit***********************************************/
.Edit
{
	-nexa-border : 1px solid #dbe2ea;
	-nexa-padding : 0px 5px 2px 5px;
	background : #ffffff;
	border-radius : 5px;
}

.EditControl
{
	-nexa-border : 0px none;
	-nexa-padding : 0px 5px 2px 5px;
	background : transparent;
	border-radius : 5px;
}

.Edit[status=mouseover],.Edit[status=focused]
{
	-nexa-border : 2px solid #5a86cd;
	-nexa-padding : 0px 5px 2px 4px;
	border-radius : 5px;
}

.Edit[status=readonly]
{
	-nexa-border : 1px solid #dbe2ea;
	background : #fcfcfc;
	border-radius : 5px;
}

.Edit[status=disabled]
{
	background : #fcfcfc;
	border-radius : 5px;
	color : #6B7280;
}

.Edit[userstatus=nulltext]
{
	color : #666666;
}


/**********************Grid***********************************************/
.Grid
{
	-nexa-border : 1px solid #e7e9f2, 0px none, 1px solid #dfe1ed, 1px solid #dfe1ed;
}

.Grid .head
{
	-nexa-border : 0px none; 
}

.Grid .head .row .cell
{
	-nexa-border : 1px solid #e7e9f2;
	-nexa-padding : 0px 4px;
	-nexa-text-align : center;
	background : #e7e9f2;
	color : #222222;
	font : normal 500 14px/normal "NotoSansKR","Noto Sans KR";
}
.Grid .head .row .cell[status=focused]
{
	-nexa-edge : url("theme://images/grd_WF_NaviBg01.png") 5px 5px;
	background : #e7e9f2; 
}

.Grid .head .row .cell[status=disabled]
{
	color : #6B7280;
}

/*-----------------------------------headcellbutton:ButtonControl과 동일------------------------------------*/
/*-----------------------------------headcellcalendar:CalendarControl과 동일------------------------------------*/
/*-----------------------------------headcellcheckbox:CheckBoxControl과 동일------------------------------------*/
/*-----------------------------------headcellcombo:ComboControl과 동일------------------------------------*/
/*-----------------------------------headcelledit:EditControl과 동일------------------------------------*/
/*-----------------------------------headcellexpandbutton------------------------------------*/
/*-----------------------------------headcellimage:별도스타일없음------------------------------------*/
/*-----------------------------------headcellmaskedit:MaskEditControl과 동일------------------------------------*/
/*-----------------------------------headcellprogressbar:ProgressBarControl과 동일------------------------------------*/
/*-----------------------------------headcelltextarea:TextAreaControl과 동일------------------------------------*/
/*-----------------------------------headcelltreeitem:------------------------------------*/

.Grid .body
{
	-nexa-border : 0px none, 1px solid #dfe1ed, 0px none, 0px none;
}

.Grid .body .row .cell
{
	-nexa-background-odd : #ffffff;
	-nexa-border : 1px solid #dfe1ed;
	-nexa-padding : 3px 5px;
	-nexa-text-align : center;
	background : #ffffff;
	color : #444444;
	font : normal 300 14px/normal "NotoSansKR","Noto Sans KR";
}

.Grid .body .row .cell[status=mouseover]
{
	background : #ffffff;
}

.Grid .body .row .cell[userstatus=selected]
{
	background : #f8f9fe;
}
.Grid .body .row .cell[status=focused][userstatus=selected]
{
	-nexa-edge : url("theme://images/grd_WF_NaviBg01.png") 5px 5px;
	background : #ffffff; 
}

.Grid .body .row .cell[status=disabled]
{
	color : #6B7280;
}

/*-----------------------------------bodycellbutton:ButtonControl과 동일------------------------------------*/
/*-----------------------------------bodycellcalendar:CalendarControl과 동일------------------------------------*/
/*-----------------------------------bodycellcheckbox:CheckBoxControl과 동일------------------------------------*/
/*-----------------------------------bodycellcombo:ComboControl과 동일------------------------------------*/
/*-----------------------------------bodycelledit:EditControl과 동일------------------------------------*/
/*-----------------------------------bodycellexpandbutton------------------------------------*/
/*-----------------------------------bodycellimage:별도스타일없음------------------------------------*/
/*-----------------------------------bodycellmaskedit:MaskEditControl과 동일------------------------------------*/
/*-----------------------------------bodycellprogressbar:ProgressBarControl과 동일------------------------------------*/
/*-----------------------------------bodycelltextarea:TextAreaControl과 동일------------------------------------*/
/*-----------------------------------bodycelltreeitem:------------------------------------*/

.Grid .summary
{
	-nexa-border : 0px none, 1px solid transparent;
}

.Grid .summary .row .cell
{
	-nexa-border : 1px solid #e0e3ea;
	-nexa-text-align : center;
	background : #f5f8fb;
	color : #333333;
	font : normal 700 12px/normal "NotoSansKR","Noto Sans KR";	
}

/*-----------------------------------summarycellbutton:ButtonControl과 동일------------------------------------*/
/*-----------------------------------summarycellcalendar:CalendarControl과 동일------------------------------------*/
/*-----------------------------------summarycellcheckbox:CheckBoxControl과 동일------------------------------------*/
/*-----------------------------------summarycellcombo:ComboControl과 동일------------------------------------*/
/*-----------------------------------summarycelledit:EditControl과 동일------------------------------------*/
/*-----------------------------------summarycellexpandbutton------------------------------------*/
/*-----------------------------------summarycellimage:별도스타일없음------------------------------------*/
/*-----------------------------------summarycellmaskedit:MaskEditControl과 동일------------------------------------*/
/*-----------------------------------summarycellprogressbar:ProgressBarControl과 동일------------------------------------*/
/*-----------------------------------summarycelltextarea:TextAreaControl과 동일------------------------------------*/
/*-----------------------------------summarycelltreeitem:------------------------------------*/

/*-----------------------------------Grid hscrollbar:------------------------------------*/
.Grid .hscrollbar
{
	-nexa-border : 1px solid #f2f2f2;
}

/*-----------------------------------Grid vscrollbar:------------------------------------*/
.Grid .vscrollbar
{
	-nexa-border : 1px solid #f2f2f2;
}


/**********************GridCellControl***********************************************/
/*-----------------------------------cellbutton:ButtonControl과 동일------------------------------------*/
.GridCellControl .cellbutton
{
	-nexa-border : 1px solid #a2a7be;
	-nexa-padding : 0px 11px 1px 10px;
	background : #ffffff;
	border-radius : 4px;	
	color : #222222;
	cursor : pointer;	
}

.GridCellControl .cellbutton[status=mouseover],.GridCellControl .cellbutton[status=focused]
{
	-nexa-border : 2px solid #5a86cd;
	-nexa-padding : 0px 11px 1px 10px;
	background : #ffffff;
	border-radius : 4px;
	color : #222222;	
}

.GridCellControl .cellbutton[userstatus=pushed],.GridCellControl .cellbutton[userstatus=selected]
{
	-nexa-border : 1px solid #a0a0a0;
	-nexa-padding : 0px 11px 1px 10px;
	color : #222222;
	background : #ffffff;
	border-radius : 4px;
}

.GridCellControl .cellbutton[status=disabled]
{
}

/*-----------------------------------cellcalendar:CalendarControl과 동일------------------------------------*/
.GridCellControl .cellcalendar
{
}

/*-----------------------------------cellcheckbox:CheckBoxControl과 동일------------------------------------*/
.GridCellControl .cellcheckbox
{
	-nexa-border : 0px none;
	border-radius : 0px;
}
.GridCellControl .cellcheckbox[status=focused]
{
	-nexa-border : 0px none;
	border-radius : 0px;
}

/*-----------------------------------cellcombo:ComboControl과 동일------------------------------------*/
.GridCellControl .cellcombo
{
}

.GridCellControl .cellcombo .combolist
{
}

.GridCellControl .cellcombo .combolist .listboxitem[status=mouseover]
{
	background : #e8e9ed;
}

/*-----------------------------------celledit:EditControl과 동일------------------------------------*/
.GridCellControl .celledit
{
	-nexa-border : 1px solid #dbe2ea;
	-nexa-padding : 1px 3px;
	background : #ffffff;
}

.GridCellControl .celledit[status=mouseover],.GridCellControl .celledit[status=focused]
{
	-nexa-border : 2px solid #5a86cd;
	-nexa-padding : 0px 2px;
}

.GridCellControl .celledit[status=disabled]
{
	background : #fcfcfc;
	color : #6B7280;
}

/*-----------------------------------cellexpandbutton------------------------------------*/
.GridCellControl .cellexpandbutton
{
	-nexa-icon : URL('theme://images/btn_WF_Grdexpand.png');
}

/*-----------------------------------cellimage:별도스타일없음------------------------------------*/

/*-----------------------------------cellmaskedit:MaskEditControl과 동일------------------------------------*/
.GridCellControl .cellmaskedit
{
	-nexa-border : 1px solid #dbe2ea;
	-nexa-padding : 1px 9px 0px 9px;
	background : #ffffff;
}

.GridCellControl .cellmaskedit[status=mouseover],.GridCellControl .cellmaskedit[status=focused]
{
	-nexa-border : 1px solid #5a86cd;
}

.GridCellControl .cellmaskedit[status=disabled]
{
	background : #fcfcfc;
	color : #6B7280;
}

/*-----------------------------------cellprogressbar:ProgressBarControl과 동일------------------------------------*/
.GridCellControl .cellprogressbar
{
	color : #333333;
}

/*-----------------------------------celltextarea:TextAreaControl과 동일------------------------------------*/
.GridCellControl .celltextarea
{
	-nexa-padding : 2px;	
}

/*-----------------------------------celltreeitem:------------------------------------*/
.GridCellControl .celltreeitem .treeitemtext
{
}

.GridCellControl .celltreeitem .treeitemtext[status=disabled]
{
	color : #6B7280;
}

.GridCellControl .celltreeitem .treeitembutton[userstatus=expand]
{
	-nexa-icon : URL('theme://images/btn_WF_Treeexpand.png');
}

.GridCellControl .celltreeitem .treeitembutton[userstatus=collapse]
{
	-nexa-icon : URL('theme://images/btn_WF_Treecollapse.png');
}

.GridCellControl .celltreeitem .treeitemimage
{
	-nexa-icon : URL('theme://images/grd_WF_treeItem.png');
}

.GridCellControl .celltreeitem .treeitemimage[userstatus=expand]
{
	-nexa-icon : URL('theme://images/img_WF_Treeexpand.png');
}

.GridCellControl .celltreeitem .treeitemimage[userstatus=collapse]
{
	-nexa-icon : URL('theme://images/img_WF_Treecollapse.png');
}

.GridCellControl .celltreeline
{
	-nexa-border : 1px dotted #909090;
}

.Grid .body .row .cell[userstatus=blinked]
{
	background : #5a86cd;
	color : #ffffff;
}


/**********************GroupBox***********************************************/
.GroupBox
{
	/*별도스타일없음*/
}

.GroupBox .groupboxcontents
{
	-nexa-border : 1px solid #d6d4d5;
	background : #ffffff;
}

.GroupBox .groupboxcontents[status=disabled]
{
	background : #6B7280;
}

.GroupBox .groupboxtitle
{
	-nexa-padding : 0px 4px 0px 4px;
	background : #ffffff;
}

.GroupBox .groupboxtitle[status=disabled]
{
	background : #fcfcfc;
	color : #6B7280;
}


/**********************ImageViewer***********************************************/
.ImageViewer
{
	-nexa-border : 0px none;
	background : transparent;
}

.ImageViewer[status=disabled]
{
	background : #f2f2f2;
}

.ImageViewer .imagetext
{
	-nexa-text-align : center;
}

.ImageViewer .imagetext[status=disabled]
{
	color : #6B7280;
}


/**********************ListBox***********************************************/
.ListBox,.ListBoxControl
{
	-nexa-border : 1px solid #dbe2ea;
	-nexa-padding : 1px;
	background : #ffffff;
}

.ListBox[status=mouseover],.ListBox[status=focused],.ListBoxControl[status=mouseover],.ListBoxControl[status=focused]
{
	-nexa-border : 2px solid #5a86cd;
	-nexa-padding : 0px 1px 0px 0px;
}

.ListBox[status=disabled],.ListBoxControl[status=disabled]
{
	background : #fcfcfc;
}

.ListBox .listboxitem,.ListBoxControl .listboxitem
{
	-nexa-padding : 2px 9px 3px 9px;
}

.ListBox .listboxitem[status=mouseover],.ListBoxControl .listboxitem[status=mouseover]
{
	background : #e7e9ed;
}

.ListBox .listboxitem[userstatus=selected],.ListBoxControl .listboxitem[userstatus=selected]
{
	background : #5a86cd;
	color : #ffffff;
}

.ListBox .listboxitem[status=disabled],.ListBoxControl .listboxitem[status=disabled]
{
	opacity : 0.50;
}


/**********************ListView**********************************************/
.ListView,.ListView[status=readonly]
{
	-nexa-border : 0px none;
}

.ListView[status=mouseover],.ListView[status=focused]
{
	-nexa-border : 0px none;
}

.ListView[status=disabled]
{
	-nexa-border : 0px none;
	background : #ffffff;
	color : #6B7280;
}

.ListView .body,.ListView .body[status=mouseover],.ListView .body[userstatus=selected],.ListView .body[status=disabled]
{
	-nexa-border : 0px none;
	background : #ffffff;
}

.ListView .body .expandbar[userstatus=expand]
{
	-nexa-border : 0px none, 0px none, 1px solid #dee1ee, 0px none;
	-nexa-icon : URL('theme://images/grd_LF_close.png');
	cursor : pointer;
}

.ListView .body .expandbar[userstatus=collapse]
{
	-nexa-border : 0px none, 0px none, 1px solid #dee1ee, 0px none;
	-nexa-icon : URL('theme://images/grd_LF_open.png');
	cursor : pointer;
}

.ListView .body .cell,
.ListView .body .cell[status=mouseover],.ListView .body .cell[status=focused],
.ListView .body .cell[status=readonly]
{
	-nexa-border : 0px none, 0px none, 1px solid #dee1ee, 0px none;
	-nexa-padding : 0px;
	color : #222222;
	font : normal 500 24px/normal "NotoSansKR","Noto Sans KR";	
}

.ListView .detail,.ListView .detail[userstatus=selected],.ListView .detail[status=disabled]
{
	-nexa-border : 0px none;
	background : #f8f8fa;
	color : #6B7280;
	font : normal 300 14px/30px "NotoSansKR","Noto Sans KR";	
}

.ListViewCellControl .cellexpandbutton
{
	-nexa-icon : URL('theme://images/btn_GridExpand_N.png');
}
.ListViewCellControl .cellexpandbutton[status=mouseover],.ListViewCellControl .cellexpandbutton[status=focused],
.ListViewCellControl .cellexpandbutton[userstatus=pushed],.ListViewCellControl .cellexpandbutton[userstatus=selected]
{
	-nexa-icon : URL('theme://images/btn_GridExpand_O.png');
}


/**********************MaskEdit***********************************************/
.MaskEdit
{
	-nexa-border : 1px solid #dbe2ea;
	-nexa-padding : 0px 8px 2px 8px;
	-nexa-text-align : right;
	background : #ffffff;
	border-radius : 5px;
}

.MaskEditControl
{
	-nexa-border : 0px none;
	-nexa-padding : 0px 8px 2px 8px;
	background : transparent;
	border-radius : 5px;
}

.MaskEdit[status=mouseover],.MaskEdit[status=focused]
{
	-nexa-border : 2px solid #5a86cd;
	-nexa-padding : 0px 7px 2px 8px;
	border-radius : 5px;
}

.MaskEdit[status=readonly]
{
	-nexa-border : 1px solid #dbe2ea;
	background : #ffffff;
	border-radius : 5px;
}

.MaskEdit[status=disabled]
{
	background : #fcfcfc;
	border-radius : 5px;
	color : #6B7280;
}


/**********************Menu***********************************************/
.Menu
{
	background : transparent;
}

.Menu[status=disabled]
{
	background : transparent;
}

.Menu .prevbutton
{
	-nexa-icon : URL('theme://images/btn_TF_menuPrev.png');
	-nexa-padding : 0px 5px 0px 15px;
}

.Menu .prevbutton[status=mouseover],.Menu .prevbutton[userstatus=pushed]
{
	-nexa-icon : URL('theme://images/btn_TF_menuPrev.png');
}

.Menu .prevbutton[status=disabled]
{
	-nexa-icon : URL('theme://images/btn_TF_menuPrev.png');
	opacity : 0.5;
}

.Menu .nextbutton
{
	-nexa-icon : URL('theme://images/btn_TF_menuNext.png');
	-nexa-padding : 0px 15px 0px 5px;
}

.Menu .nextbutton[status=mouseover],.Menu .nextbutton[userstatus=pushed]
{
	-nexa-icon : URL('theme://images/btn_TF_menuNext.png');
}

.Menu .nextbutton[status=disabled]
{
	-nexa-icon : URL('theme://images/btn_TF_menuNext.png');
	opacity : 0.5;
}

.Menu .menuitem
{
	-nexa-border : 0px none;
	-nexa-padding : 10px 30px;
	color : #000000;
	cursor : pointer;
	font : bold 15px "MalgunGothic";
}

.Menu .menuitem[status=disabled]
{
	color : #6B7280;
}

.Menu .menuitem[status=mouseover],.Menu .menuitem[userstatus=selected]
{
	-nexa-border : 0px none;
	-nexa-padding : 10px 30px;
	color : #535ed3;
	cursor : pointer;
	font : bold 15px "MalgunGothic";
}

.Menu .menupopupmenu
{
	-nexa-border : 1px solid #555555;
	background : #ffffff;
	border-radius : 5px;
	box-shadow : 0px 5px 8px 0px hsla(0,0%,17%,0.26);
}

.Menu .menupopupmenu .prevbutton
{
	-nexa-icon : URL('theme://images/btn_WF_Popmenuprev_O.png');
}

.Menu .menupopupmenu .prevbutton[status=mouseover]
{
	-nexa-icon : URL('theme://images/btn_WF_Popmenuprev.png');
}

.Menu .menupopupmenu .prevbutton[status=disabled]
{
	-nexa-icon : URL('theme://images/btn_WF_Popmenuprev_D.png');
	opacity : 0.5;
}

.Menu .menupopupmenu .nextbutton
{
	-nexa-icon : URL('theme://images/btn_WF_Popmenunext_O.png');
}

.Menu .menupopupmenu .nextbutton[status=mouseover]
{
	-nexa-icon : URL('theme://images/btn_WF_Popmenunext.png');
}

.Menu .menupopupmenu .nextbutton[status=disabled]
{
	-nexa-icon : URL('theme://images/btn_WF_Popmenunext_D.png');
	opacity : 0.5;
}

.Menu .menupopupmenu .popupmenuitem
{
	-nexa-border : 0px none;
	-nexa-padding : 10px 20px;
	background : #ffffff;
	color : #555555;	
}

.Menu .menupopupmenu .popupmenuitem[status=mouseover],.Menu .menupopupmenu .popupmenuitem[status=focused],
.Menu .menupopupmenu .popupmenuitem[userstatus=selected]
{
	background : #eeeeee;
	color : #333333;
}

.Menu .menupopupmenu .popupmenuitem[status=disabled]
{
	color : #6B7280;
}

.Menu .menupopupmenu .popupmenuitem .popupmenuitemicon
{
	-nexa-icon : URL('theme://images/img_WF_Menuitem2.png');
}

.Menu .menupopupmenu .popupmenuitem .popupmenuitemcheckbox
{
	-nexa-padding : 0px 7px 0px 0px;
	-nexa-icon : URL('theme://images/chk_WF_Popupmenu_O.png');
}

.Menu .menupopupmenu .popupmenuitem .popupmenuitemcheckbox[status=mouseover]
{
	-nexa-icon : URL('theme://images/chk_WF_Popupmenu_O.png');
}

.Menu .menupopupmenu .popupmenuitem .popupmenuitemtext
{
	-nexa-padding : 0px 15px 0px 8px;
	color : #555555;
	font : bold 15px "MalgunGothic";
}

.Menu .menupopupmenu .popupmenuitem .popupmenuitemtext[status=mouseover]
{
	color : #535ed3;
}

.Menu .menupopupmenu .popupmenuitem .popupmenuitemtext[status=disabled]
{
	color : #6B7280;
}

