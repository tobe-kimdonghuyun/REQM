{
	-nexa-border : 1px solid #dbe2ea;
	background : #fcfcfc;
	border-radius : 5px;
}

.TextArea[status=disabled],.TextAreaControl[status=disabled]
{
	-nexa-border : 1px solid #dbe2ea;
	background : #fcfcfc;
	border-radius : 5px;
	color : #6B7280;
}


/**********************WebBrowser***********************************************/
