        <Div id="div_search01" taborder="24" left="0" top="1940" height="110" cssclass="div_SA" initvalueid="ivDivAccessibilityOn" right="0" formscrolltype="none">
          <Layouts>
            <Layout>
              <Static id="label00" taborder="0" text="평판 스캐너로 발급된 증명서를 수령한 기관 및개인이 증명서의 진위여부를 확인할 수 있습니다. 평판 스캐너를 준비하여 PC에 연결한 후 스캐너용 발급문서 진위확인 프로그램을 다운로드합니다. PC에서 스캔한 증명서와 원본문서를 대조하여 진위확인을 합니다. 스캐너는 해상도 300dpi 이상 지원이 가능해야 합니다." left="30" top="20" width="1062" height="70" cssclass="font16R" initvalueid="ivStcAccessibilityOn"/>
            </Layout>
