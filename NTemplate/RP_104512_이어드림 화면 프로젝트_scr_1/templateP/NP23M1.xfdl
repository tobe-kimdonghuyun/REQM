        <Div id="div_hang1" taborder="1" left="0" top="172" height="208" cssclass="div_WF_hang" initvalueid="ivDivAccessibilityOn" right="0" formscrolltype="none" text="" accessibilitylabel="진위확인서비스 설명박스입니다.">
          <Layouts>
            <Layout>
              <Static id="hang1" taborder="0" text="문서지위확인서비스는 발급된 문서를 수령한 기관 또는 개인이 문서의 진위여부를 확인하실 수 있는 기능을 제공합니다." left="30" top="21" width="994" height="30" cssclass="sta_WF_HangTxt_blue" initvalueid="ivStcAccessibilityOn"/>
              <Static id="hang2" taborder="1" text="발급문서 소지자만 원본문서를 조회할 수 있습니다." left="30" top="65" width="656" height="30" cssclass="sta_WF_HangTxt_blue" initvalueid="ivStcAccessibilityOn"/>
              <Static id="hang3" taborder="2" text="발급문서는 접수일 이후 90일까지 조회가 가능합니다." left="30" top="109" width="908" height="30" cssclass="sta_WF_HangTxt_blue" initvalueid="ivStcAccessibilityOn"/>
              <Static id="hang4" taborder="3" text="정부24에서 발급받은 문서는 정부24에서 진위여부 확인 가능합니다." left="30" top="153" width="878" height="30" cssclass="sta_WF_HangTxt_blue" initvalueid="ivStcAccessibilityOn"/>
            </Layout>
