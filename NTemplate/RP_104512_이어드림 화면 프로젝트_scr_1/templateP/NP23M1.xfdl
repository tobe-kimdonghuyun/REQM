        <Static id="sta01_00_00_00" taborder="17" text="마트폰을 수평으로 들고 증명서 우측 상단의&#13;&#10;‘음성변환 바코드' 위에 수직으로 10cm 위에서 스캔" left="601" top="1537" width="300" height="60" cssclass="font16R" textAlign="center" initvalueid="ivStcAccessibilityOn" verticalAlign="top" color="#767676" letterSpacing="-2px"/>
