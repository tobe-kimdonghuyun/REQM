        <ImageViewer id="title2" taborder="5" text="홍보영상" left="0" top="1544" width="133" height="50" cssclass="font34B" initvalueid="ivTitleAccessibilityOn"/>
        <Div id="div_video" taborder="6" left="0" top="1629" width="1200" height="718" background="url('imagerc::pas_mmssi00/sub_pr_video1B.jpg') no-repeat center center" initvalueid="iv_DivVideoPlayerOn"/>
        <Button id="btn00" taborder="7" left="540" top="1928" width="120" height="120" cssclass="btn_video_play" initvalueid="ivBtnAccessibilityButton"/>
        <ImageViewer id="img01" taborder="8" text="나이스 홍보영상소개" left="0" top="2369" height="34" cssclass="font24B" initvalueid="ivTitleAccessibilityOn" width="208"/>
        <Static id="sta00" taborder="9" text="종합교육행정정보시스템 나이스! 전국 1만여 학교, 17개 시도교육청과 교육부를 네트워크로 연결하였습니다. 나이스 대국민서비스를 통해 학생은 스스로 성적과 학사일정을 확인할 수 있고, 학교에서는 학생성적관리와 생활기록부, 교무업무를 편리하게, 교육청에서는 인사, 급여 등 일반행정업무를 스마트하게! 고품질 교육서비스로 여는 스마트한 교육세상 나이스!" left="0" top="2415" height="50" cssclass="font16R" wordWrap="char" initvalueid="ivStcAccessibilityOn" right="0"/>
        <Grid id="grd_video" taborder="10" left="0" top="2540" height="423" cssclass="grd_videoList" binddataset="ds_prVideo" right="0" autofittype="col" formatid="default" selecttype="cell" initvalueid="ivGrdAccessibilityOn">
