<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="NP10D3" width="1200" height="3400" titletext="나이스 홍보자료">
    <Layouts>
      <Layout height="3400" width="1200" screenid="ScreenDeskTopP">
        <ImageViewer id="title1_00" taborder="0" text="홍보 캐릭터" left="0" top="62" width="162" height="50" cssclass="font34B" initvalueid="ivTitleAccessibilityOn"/>
        <Div id="div00" taborder="1" left="0" top="141" width="720" height="660" cssclass="div_WF_shadowBox" initvalueid="ivDivAccessibilityOn">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" text="홍보캐릭터 &lt;fc v=&quot;#2b72de&quot;&gt;유니&lt;/fc&gt;" left="40" top="55" width="173" height="40" cssclass="font24B" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00" taborder="1" text="Story" left="40" top="116" width="173" height="40" cssclass="font18B" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta01" taborder="2" text="최첨단 기술을 가진 과학 행성 ‘알파오'에서 온&#13;우주인. 우주 여행 중 나이스 중학교에 불시착&#13;했다가 친절한 친구들, 선생님, 학부모님의 도움에&#13;감격하여 지구에 정착하기로 마음 먹는다. 자신이&#13;가진 기술로 자신을 도와준 사람들을 위해 해줄 수&#13;있는 일을 찾다가 &#13;&#10;‘나이스'를 개발하게 된다." left="40" top="160" width="597" height="100" cssclass="font16R,color7676" initvalueid="ivStcAccessibilityOn" letterSpacing="0px" verticalAlign="top"/>
              <Static id="sta00_00_00" taborder="3" text="성격" left="40" top="282" width="173" height="40" cssclass="font18B" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta01_00" taborder="4" text="부끄러움이 좀 많지만 스마트하고 솔직하다. 항상 &#13;새로운 생각을 듣는 것을 좋아하고 좋은&#13;아이디어를 시스템에 반영하는 걸 즐긴다." left="40" top="325" width="577" height="60" cssclass="font16R,color7676" initvalueid="ivStcAccessibilityOn" letterSpacing="0px" verticalAlign="top"/>
              <Static id="sta00_00_00_00" taborder="5" text="특징" left="40" top="400" width="173" height="40" cssclass="font18B" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta01_00_00" taborder="6" text="머리의 뾰족한 부분의 아이콘으로 감정을&#13; 표현하고 의견을 들을 땐 안테나 모양으로도&#13; 바뀐다." left="40" top="444" width="607" height="30" cssclass="font16R,color7676" initvalueid="ivStcAccessibilityOn" letterSpacing="0px" verticalAlign="top"/>
              <Static id="sta00_00_00_00_00" taborder="7" text="네이밍 컨셉" left="40" top="495" width="173" height="40" cssclass="font18B" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta01_00_00_00" taborder="8" text="&lt;우주&gt;의 의미와 &lt;나이스(NEIS)가 관할하는&#13;완벽한 교육행정 세상&gt;을 의미하는&#13;&#10; ‘Universe에서’&#13;착안" left="40" top="539" width="607" height="50" cssclass="font16R,color7676" initvalueid="ivStcAccessibilityOn" letterSpacing="0px" verticalAlign="top"/>
              <Static id="guide02" taborder="9" text="h40" left="32" top="87" width="76" height="42" cssclass="sta_WF_Size" visible="false"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="sta00" left="40" top="63" width="213" height="40" cssclass="font30B"/>
              <Static id="sta01" left="40" top="197" height="296" cssclass="font28R" text="최첨단 기술을 가진 과학 행성 ‘알파오'에서 온&#13;우주인. 우주 여행 중 나이스 중학교에 불시착&#13;했다가 친절한 친구들, 선생님, 학부모님의 도움에&#13;감격하여 지구에 정착하기로 마음 먹는다. 자신이&#13;가진 기술로 자신을 도와준 사람들을 위해 해줄 수&#13;있는 일을 찾다가 ‘나이스'를 개발하게 된다." right="36"/>
              <Static id="guide02" left="52" top="893" width="76" height="50"/>
              <Static id="sta00_00_00" left="40" top="524" width="173" height="40" cssclass="font28B"/>
              <Static id="sta01_00" left="40" top="570" height="140" cssclass="font28R" right="36" text="부끄러움이 좀 많지만 스마트하고 솔직하다. 항상&#13; 새로운 생각을 듣는 것을 좋아하고 좋은&#13;아이디어를 시스템에 반영하는 걸 즐긴다."/>
              <Static id="sta00_00_00_00" left="40" top="730" width="173" height="40" cssclass="font28B"/>
              <Static id="sta01_00_00" left="40" top="774" height="130" cssclass="font28R" right="40" text="머리의 뾰족한 부분의 아이콘으로 감정을&#13; 표현하고 의견을 들을 땐 안테나 모양으로도&#13; 바뀐다."/>
              <Static id="sta00_00_00_00_00" left="40" top="935" width="173" height="40" cssclass="font28B"/>
              <Static id="sta01_00_00_00" left="40" top="979" height="120" cssclass="font28R" text="&lt;우주&gt;의 의미와 &lt;나이스(NEIS)가 관할하는&#13;완벽한 교육행정 세상&gt;을 의미하는 ‘Universe에서’&#13;착안" right="43"/>
              <Static id="sta00_00" cssclass="font28B" left="40" top="149" width="173" height="40"/>
            </Layout>
          </Layouts>
        </Div>
