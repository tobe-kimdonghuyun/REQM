<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="NP10D2" width="1200" height="1553" titletext="나이스 추진배경 및 경과">
    <Layouts>
      <Layout height="1553" width="1200">
        <ImageViewer id="title1" taborder="0" text="나이스 추진배경" left="0" top="63" width="226" height="50" cssclass="font34B"/>
        <Static id="guide00" taborder="4" text="h70" left="0" top="0" width="180" height="70" cssclass="sta_WF_Size" visible="false" initvalueid="ivStcAccessibilityOff"/>
        <Static id="guide01" taborder="5" text="h40" left="90" top="101" width="50" height="40" cssclass="sta_WF_Size" visible="false" initvalueid="ivStcAccessibilityOff"/>
        <Div id="div00" taborder="1" left="0" top="141" width="1200" height="296" cssclass="div_WF_hang" initvalueid="ivDivAccessibilityOn">
          <Layouts>
            <Layout>
              <Static id="hang00" taborder="0" text="초고석 인터넷망과 정보통신기술의 발전에 따라 기존의 문서 위주의 행정을 디지털 행정으로 전환하여 선진 교육행정서비스를 제공할 필요성이 증가하였습니다." left="30" top="21" width="994" height="30" cssclass="sta_WF_HangTxt_Skyblue" initvalueid="ivStcAccessibilityOn"/>
              <Static id="hang01" taborder="1" text="시도 교육청 내/외부의 각종 정보시스템간 호환성 문제로 자료의 효율적 관리 이용에 어려움을 겪습니다." left="30" top="65" width="656" height="30" cssclass="sta_WF_HangTxt_Skyblue" initvalueid="ivStcAccessibilityOn"/>
              <Static id="hang02" taborder="2" text="전체 공공기관 보안사고 중 70%(2001년도)가 각급 학교에서 발생하는 등 기존의 학교 시스템(C/S, S/A)의 보안상 문제점을 해결할 필요가 컸습니다." left="30" top="109" width="908" height="30" cssclass="sta_WF_HangTxt_Skyblue" initvalueid="ivStcAccessibilityOn"/>
              <Static id="hang03" taborder="3" text="시도 교육청별 업무단위 별 프로그램의 중복개발 및 시스템 관리 비용 과다 소요 등에 따라 효율적인 시스템 관리 및 예산절감이 필요해졌습니다." left="30" top="153" width="878" height="30" cssclass="sta_WF_HangTxt_Skyblue" initvalueid="ivStcAccessibilityOn"/>
              <Static id="hang04" taborder="4" text="교육행정의 효율화를 통한 학교현장의 업무경감 방안 추진으로 학생중심의 수준별 교육과정 도입 등에 따른 교사의 연구시간 확보 지원이 필요해졌습니다." left="30" top="197" width="946" height="30" cssclass="sta_WF_HangTxt_Skyblue" initvalueid="ivStcAccessibilityOn"/>
              <Static id="hang05" taborder="5" text="21세기 국가 경쟁력 확보 및 국민 편익 증진을 위한 범 정부적 전자정부 구현 활동이 확대 강화되고 있습니다." left="30" top="241" width="671" height="30" cssclass="sta_WF_HangTxt_Skyblue" initvalueid="ivStcAccessibilityOn"/>
              <Static id="guide00" taborder="6" text="h30" left="625" top="0" width="59" height="30" cssclass="sta_WF_Size" visible="false" initvalueid="ivStcAccessibilityOff"/>
              <Static id="guide01" taborder="7" text="h30" left="625" top="44" width="59" height="30" cssclass="sta_WF_Size" visible="false" initvalueid="ivStcAccessibilityOff"/>
