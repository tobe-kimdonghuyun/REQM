                    <Button id="btn00" taborder="3" text="#연혁" left="77" top="125" width="72" height="24" cssclass="btn_GNB_link" initvalueid="ivBtnAccessibilityLink"/>
                    <Button id="btn01" taborder="4" text="#나이스플러스" left="159" top="125" width="124" height="24" cssclass="btn_GNB_link" initvalueid="ivBtnAccessibilityLink"/>
                    <Button id="btn02" taborder="5" text="#대국민안내" left="293" top="125" width="111" height="24" cssclass="btn_GNB_link" initvalueid="ivBtnAccessibilityLink"/>
