<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="NP50M1" width="1200" height="1732" titletext="웹접근성 정책">
    <Layouts>
      <Layout height="1732" width="1200" screenid="ScreenDeskTopP">
        <ImageViewer id="title1" taborder="0" text="웹접근성 정책" left="0" top="53" width="180" height="50" cssclass="font34B" initvalueid="ivTitleAccessibilityOn"/>
        <Div id="div00" taborder="1" left="0" top="138" height="156" cssclass="div_roundBox20_line" initvalueid="ivDivAccessibilityOn" right="0">
          <Layouts>
            <Layout>
              <Static id="hang1" taborder="0" text="나이스 대국민 서비스는 장애인, 노인 등의 정보취약계층의 사용자가 전문적인 능력없이도 웹 사이트에서 제공하는 정보에 접근할 수 있도록 최선의 노력을 기울이고 있습니다.&#13;&#10;&#13;&#10;나이스 대국민 서비스는 장애인, 노인 등 정보취약계층의 인터넷 정보 접근을 보장하기 위해 국가표준(KICS)으로 제정된 &quot;한국형 웹 콘텐츠 접근성 지침2.1&quot;와&#13;&#10;&quot;전자정부서비스 호환성 준수지침(행정자치부 고시 제1호)&quot;를 준수하여 제작되어 있습니다." left="30" top="28" height="96" cssclass="font16R" right="30"/>
              <Static id="guide00" taborder="1" text="h34" left="30" top="0" width="50" height="34" cssclass="sta_WF_Size" visible="false" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="hang1" cssclass="font28R" left="20" top="0" height="504" textAlign="center" verticalAlign="top" right="20" text="나이스 대국민 서비스는 장애인, 노인 등의&#13;&#10;정보취약계층의 사용자가 전문적인 능력없이도&#13;&#10;웹 사이트에서 제공하는 정보에 접근할 수 있도록&#13;&#10;최선의 노력을 기울이고 있습니다.&#13;&#10;&#13;&#10;나이스 대국민 서비스는 장애인, 노인 등&#13;&#10;정보취약계층의 인터넷 정보 접근을 보장하기 위해&#13;&#10;국가표준(KICS)으로 제정된&#13;&#10;&quot;한국형 웹 콘텐츠 접근성 지침2.1&quot;와&#13;&#10;&quot;전자정부서비스 호환성 준수지침&#13;&#10;(행정자치부 고시 제1호)&quot;를 준수하여&#13;&#10;제작되어 있습니다." fittocontents="height"/>
            </Layout>
          </Layouts>
        </Div>
        <ImageViewer id="suTitle1" taborder="2" text="웹접근성품질마크" left="0" top="div00:60" width="178" height="40" cssclass="font24B" initvalueid="ivTitleAccessibilityOn"/>
        <Div id="div01" taborder="3" left="0" top="suTitle1:35" height="156" cssclass="div_roundBox20_BG" right="0">
          <Layouts>
            <Layout>
              <ImageViewer id="img00" taborder="0" left="30" top="32" width="138" height="91" image="url('imagerc::common/sub_common_wa.png')" cssclass="display" initvalueid="ivImgAccessibilityOn" accessibilitylabel="WA BI"/>
              <Static id="hang1" taborder="1" text="장애인 및 고령자가 웹사이트 이용에 불편이 없도록 웹접근성 표준지침을 준수한 우수 사이트에 대해 웹접근성 수준을 인정하고,&#13;&#10;이를 상징하는 품질마크를 부여하는 인증 제도&#13;&#10;&#13;&#10;나이스 대국민서비스(학생,학부모서비스)는 표준지침을 준수하여 품질마크를 부여받았습니다." left="200" top="28" height="96" cssclass="font16R" right="30" initvalueid="ivStcAccessibilityOn"/>
              <Static id="guide00" taborder="2" text="h34" left="210" top="0" width="40" height="34" cssclass="sta_WF_Size" visible="false" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="hang1" cssclass="font28R" left="10" top="277" height="252" text="장애인 및 고령자가 웹사이트 이용에 불편이 없도록 &#13;&#10;웹접근성 표준지침을 준수한 우수 사이트에 대해 &#13;&#10;웹접근성 수준을 인정하고, 이를 상징하는 품질마크를&#13;&#10;부여하는 인증 제도 나이스 대국민서비스(학생,&#13;&#10;학부모서비스)는 표준지침을 준수하여 품질마크를 &#13;&#10;부여받았습니다." textAlign="center" verticalAlign="top" right="10"/>
              <ImageViewer id="img00" left="164" top="70" height="178" image="url('imagerc::common_M/sub_common_wa_M.png')" right="164" minwidth="272" maxwidth=""/>
              <Static id="guide00" left="275" top="0" height="70" width="50" text="h50"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="hang00" taborder="4" text="&lt;b v=&quot;true&quot;&gt;바로접근(Accessibility)링크&lt;/b&gt; : 서비스 문서 시작 부분에 반복되는 메뉴등의 링크가 많은 페이지를 이동시켜 본문을 효율적으로 이동할 수 있도록 &#13;&#10;스킵 네비게이션(바로가기)링크를 제공하고 있습니다. " left="30" top="div01:26" height="48" cssclass="sta_WF_HangTxt_black" usedecorate="true" right="30" initvalueid="ivStcAccessibilityOn"/>
        <Static id="hang01" taborder="5" text="&lt;b v=&quot;true&quot;&gt;문서 제목(title)태그&lt;/b&gt; : 모든 문서마다 문서의 제목[&lt;title&gt;]을 제공하고, 문서의 제목은 문서의 특징을 잘 나타내도록 간단명료하게 기술하고 있습니다." left="30" top="hang00:25" height="30" cssclass="sta_WF_HangTxt_black" initvalueid="ivStcAccessibilityOn" right="30" usedecorate="true"/>
        <Static id="hang03" taborder="6" text="&lt;b v=&quot;true&quot;&gt;문서의 구조화&lt;/b&gt; : 문서는 논리적인 접근 및 키보드 접근이 가능하도록 헤딩(&lt;h1&gt;~&lt;h6&gt;),문단(&lt;p&gt;),목록(&lt;ul&gt;,&lt;ol&gt;,&lt;dl&gt;) 등의 태그를 사용하였습니다. 또한 디자인요소를 css를 사용하여 분리하고 있으며 스타일시트를 제거하더라도 콘텐츠를 이해할 수 있습니다." left="30" top="hang01:25" height="50" cssclass="sta_WF_HangTxt_black" right="80" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
        <Static id="hang04" taborder="7" text="&lt;b v=&quot;true&quot;&gt;이미지 정보&lt;/b&gt; : 텍스트가 아닌 콘텐츠에는 모두 대체 텍스트가 제공되고 있으며, 대체 텍스트 제공이 어려운 도형이미지는 별도의 텍스트정보를 제공하고 있습니다." left="30" top="hang03:25" height="25" cssclass="sta_WF_HangTxt_black" usedecorate="true" right="30" initvalueid="ivStcAccessibilityOn"/>
        <ImageViewer id="suTitle2" taborder="8" text="지원 가능한 OS 및 브라우저" left="0" top="hang04:35" width="270" height="40" cssclass="font24B" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="hang05" taborder="9" text="나이스 대국민서비스에서는 마이크로소프트사 윈도우, 애플사 맥 OS 등의 운영체제와 인터넷익스플로서, 파이어폭스, 사파리 등의 다양한 브라우저에서 동일한 서비스 화면을 제공하고 있습니다. &#13;&#10;단, 일부운영체제와 브라우저에서는 기능이 제한이 있을 수 있습니다." left="0" top="suTitle2:8" height="48" cssclass="font16R" initvalueid="ivStcAccessibilityOn" right="0"/>
        <Div id="div_detail00" taborder="10" left="0" top="hang05:31" height="115" cssclass="div_webGuide_detail" right="0" initvalueid="ivDivAccessibilityOn">
          <Layouts>
            <Layout>
              <Static id="label00" taborder="0" text="운영체제(OS)" left="0" top="0" width="240" height="57" cssclass="sta_webGuide_detailLabel" initvalueid="ivStcAccessibilityOn"/>
              <Static id="label01" taborder="1" text="브라우저" left="0" top="57" width="240" height="57" cssclass="sta_webGuide_detailLabel" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00" taborder="2" text="윈도우 10, 11" left="240" top="0" height="57" cssclass="sta_webGuide_detailBG" initvalueid="ivStcAccessibilityOn" right="0"/>
              <Static id="sta01" taborder="3" text="크롬, 엣지, 파이어폭스, 오페라" left="240" top="57" height="57" cssclass="sta_webGuide_detailBG" initvalueid="ivStcAccessibilityOn" right="0"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="label00" cssclass="sta_webGuide_detailLabel_M" width="200" left="0" top="0" height="70"/>
