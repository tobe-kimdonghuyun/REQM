        <Static id="staDetail" taborder="1" left="0" top="1747" width="1200" height="5137" cssclass="sta_roundBox20_line"/>
        <ImageViewer id="img00" taborder="2" text="제1조(개인정보의 처리목적)" left="30" top="1778" width="263" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/policy_link01S.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00" taborder="3" text="① 「학생서비스, 학부모서비스」는 다음 각 호의 목적을 위하여 개인정보를 수집/처리하고 있으며, 이용 목적이 변경되는 경우에는 개인정보보호법 제17조 및 제18조에 따라 개인정보의 제공에 따라 별도의 동의를 받는 등 필요한 조치를 취하고 있습니다.&#13;&#10;1. 홈페이지 회원 가입 및 관리&#13;&#10;회원제 서비스 제공을 위한 본인 식별·인증, 회원자격 유지·관리, 제한적 본인확인제 시행에 따른 본인확인, 서비스 부정이용 방지, 만 14세 미만 아동의 개인정보 처리 시 법정대리인의 동의여부 확인, 각종 고지·통지 등을 목적으로 개인정보를 처리합니다.&#13;&#10;&#13;&#10;2. 서비스 제공 및 민원처리&#13;&#10;학생서비스, 학부모서비스와 기타 본 사이트의 운영 목적 달성을 위해 구축/운영하는 일체의 서비스의 운영 및 민원처리를 위한 목적으로 개인정보를 처리합니다.&#13;&#10;&#13;&#10;② 「학생서비스, 학부모서비스」가 개인정보보호법 제32조 에 따라 등록·공개하는 개인정보파일의 처리목적은 다음과 같습니다." left="29" top="img00:10" height="240" cssclass="font16R" width="1142" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <Grid id="grd00" taborder="4" left="30" top="sta00:36" width="1140" height="270" cssclass="grd_policy_detail" autoenter="select" autofittype="col" fillareatype="datarow" initvalueid="ivGrdAccessibilityOn">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="250"/>
                <Column size="360"/>
                <Column size="380"/>
                <Column size="210"/>
              </Columns>
              <Rows>
                <Row size="61" band="head"/>
                <Row size="208"/>
              </Rows>
              <Band id="head">
                <Cell text="개인정보파일의 명칭" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                <Cell col="1" text="운영근거 / 처리목적" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                <Cell col="2" text="개인정보파일에 기록되는 개인정보의 항목" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                <Cell col="3" text="보유기간" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd"/>
              </Band>
              <Band id="body">
                <Cell text="「학생서비스, 학부모서비스」&#13;&#10;회원정보" textAlign="center" padding="0px"/>
                <Cell col="1" textAlign="left" verticalAlign="middle" text="[운영근거]&#13;&#10;- 초·중등교육법 제30조의 4,5 &#13;&#10;- 교육기본법 제 23의 2&#13;&#10;- 유아교육정보시스템 및 교육정보시스템의 &#13;&#10;운영 등에 관한 규칙 제8조, 제9조&#13;&#10;&#13;&#10;[처리목적]&#13;&#10;「학생서비스, 학부모서비스」 운영 관리" padding="0px 0px 0px 20px"/>
                <Cell col="2" textAlign="left" verticalAlign="middle" text="[필수]&#13;&#10;- 학생서비스 : 성명, 아이디, 본인확인값(CI), &#13;&#10;  생년월일, 학교, 학년, 반, 번호, 계열 &#13;&#10;- 학부모서비스 : 성명, 아이디, 본인확인값(CI),&#13;&#10;  생년월일&#13;&#10;&#13;&#10;[선택]&#13;&#10;이메일, 연락처(일반, 핸드폰)" padding="0px 0px 0px 20px"/>
                <Cell col="3" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd" textAlign="center" text="가입 후 회원 탈퇴시 까지"/>
              </Band>
            </Format>
            <Format id="format00">
              <Columns>
                <Column size="200"/>
                <Column size="364"/>
              </Columns>
              <Rows>
                <Row size="108"/>
                <Row size="420"/>
                <Row size="384"/>
                <Row size="69"/>
              </Rows>
              <Band id="body">
                <Cell cssclass="cell_head" textAlign="center" padding="0px" text="개인정보파일의 &#13;&#10;명칭"/>
                <Cell col="1" text="「학생서비스, 학부모서비스」&#13;&#10;회원정보" padding="22px 30px" cssclass="cell_end"/>
                <Cell row="1" cssclass="cell_head" textAlign="center" padding="0px" text="운영근거 / &#13;&#10;처리목적"/>
                <Cell row="1" col="1" padding="22px 5px 22px 30px" text="[운영근거]&#13;&#10;- 초·중등교육법 제30조의 4,5 &#13;&#10;- 교육기본법 제 23의 2&#13;&#10;- 유아교육정보시스템 및 교육정보시스템의 운영 등에 관한 규칙 제8조, 제9조&#13;&#10;&#13;&#10;[처리목적]&#13;&#10;「학생서비스, 학부모서비스」 운영 관리" cssclass="cell_end" wordWrap="char"/>
                <Cell row="2" cssclass="cell_head" textAlign="center" padding="0px" text="개인정보파일에 &#13;&#10;기록되는 &#13;&#10;개인정보의 항목"/>
                <Cell row="2" col="1" text="[필수]&#13;&#10;- 학생서비스 : 성명, 아이디, 본인확인값(CI), 생년월일, 학교, 학년, 반, 번호, 계열 &#13;&#10;- 학부모서비스 : 성명, 아이디, 본인확인값(CI), 생년월일&#13;&#10;&#13;&#10;[선택]&#13;&#10;이메일, 연락처(일반, 핸드폰)" padding="22px 5px 22px 30px" cssclass="cell_end" wordWrap="char"/>
                <Cell row="3" cssclass="cell_head" textAlign="center" padding="0px" text="보유기간"/>
                <Cell row="3" col="1" text="가입 후 회원 탈퇴시 까지" padding="22px 30px" cssclass="cell_end"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="sta04" taborder="5" text="※ 기타 「학생서비스, 학부모서비스」의 개인정보파일에 기록된 내용의 공개는 개인정보보호위원회 개인정보보호포털&lt;l v='http://www.privacy.go.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;(www.privacy.go.kr)&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt; → 개인정보민원 → 개인정보열람등 요구 → 개인정보파 일 목록검색 메뉴를 활용해주시기 바랍니다." left="29" top="grd00:22" height="48" cssclass="font16R" width="1142" initvalueid="ivStcAccessibilityOn" fittocontents="height" usedecorate="true"/>
        <ImageViewer id="img01" taborder="6" text="제2조(개인정보의 처리 및 보유기간)" left="30" top="sta04:31" width="313" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/policy_link02S.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta05" taborder="7" text="① 「학생서비스, 학부모서비스」는 관계 법령에 따른 개인정보 보유·이용기간 또는 정보주체로부터 개인정보를 수집 시에 동의 받은 개인정보 보유·이용기간 내에서 개인정보를 처리·보유합니다.&#13;&#10;② 서비스별 개인정보 처리 및 보유 기간은 다음과 같습니다.&#13;&#10;1. 학생서비스 개인정보&#13;&#10;보유근거 : 교육기본법, 초중등교육법, 유아교육정보시스템의 운영 등에 관한 규칙 &#13;&#10;보유목적 : 학생서비스 이용(학생본인정보 열람 등)&#13;&#10;보유기간 : 회원가입 후 탈퇴시까지&#13;&#10;2. 학부모서비스 개인정보&#13;&#10;보유근거 : 교육기본법, 초중등교육법, 유아교육정보시스템의 운영 등에 관한 규칙 &#13;&#10;보유목적 : 학부모서비스의 이용(자녀정보열람 등)&#13;&#10;보유기간 : 회원가입 후 탈퇴시까지&#13;&#10;③ 다음의 사유에 해당하는 경우에는 해당 사유 종료시까지 개인정보를 처리·보유합니다.&#13;&#10;1) 관계 법령 위반에 따른 수사·조사 등이 진행중인 경우에는 해당 수사·조사 종료시까지&#13;&#10;2) 홈페이지 이용에 따른 채권·채무관계 잔존시에는 해당 채권·채무관계 정산시까지&#13;&#10;④ 기존회원의 경우 최종접속일로부터 1년동안 로그인한 기록이 없을 경우 휴면회원으로 전환됩니다.&#13;&#10;⑤ 휴면회원 전환 이후 1년까지 추가로 로그인한 기록이 없는 경우 해당 회원을 회원자격 상실시킬 수 있습니다.&#13;&#10;⑥ 고등학교 3학년 졸업 학생의 경우 졸업 이후 해당년도 3월 1일자로 해당 회원을 회원자격 상실시킬 수 있습니다." left="29" top="img01:14" width="1142" height="408" cssclass="font16R" initvalueid="ivStcAccessibilityOn"/>
        <ImageViewer id="img02" taborder="8" text="제3조(개인정보의 제3자 제공)" left="30" top="sta05:35" width="277" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/policy_link03S.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta06" taborder="9" text="①「학생서비스, 학부모서비스」는 정보주체의 동의, 법률의 특정한 규정 등 개인정보 보호법 제17조 및 제18조에 해당하는 경우에만 개인정보를, 제3자에게 제공합니다." left="29" top="img02:14" width="1142" height="24" cssclass="font16R" initvalueid="ivStcAccessibilityOn"/>
        <ImageViewer id="img03" taborder="10" text="제4조(개인정보처리의 위탁)" left="30" top="sta06:35" width="266" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/policy_link04S.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta07" taborder="11" text="① 「학생서비스, 학부모서비스」는 원활한 개인정보 업무처리를 위한 본인확인 업무 수행을 위해 개인정보 처리업무를 다음과 같이 위탁하고 있으며, 업무 처리를 위해 위탁한 개인정보는 별도로 저장하지 않습니다.&#13;&#10;1. 본인확인서비스&#13;&#10;위탁받는 자 (수탁자) : SCI평가정보(주)&#13;&#10;위탁하는 업무의 내용 : 회원정보관리를 위한 본인 확인 등 위탁기간 : 위탁계약 종료 시까지&#13;&#10;2. 학생학부모용 인증서 발급서비스 위탁받는 자 (수탁자) : 한국정보인증(KICA)&#13;&#10;위탁하는 업무의 내용 : 인증서 발급을 위한 본인 확인 등 위탁기간 : 위탁계약 종료 시까지&#13;&#10;3. 나이스 대국민서비스 운영 및 유지관리 위탁받는 자 (수탁자) : SGA(주)&#13;&#10;위탁하는 업무의 내용 : 나이스 대국민서비스 운영 및 유지관리 위탁기간 : 위탁계약 종료 시까지&#13;&#10;4. 나이스 정보시스템 운영 및 유지관리 위탁받는 자 (수탁자) : 링네트(주)&#13;&#10;위탁하는 업무의 내용 : 정보시스템 통합 위탁운영 및 유지관리 위탁기간 : 위탁계약 종료 시까지&#13;&#10;②「학생서비스, 학부모서비스」는 위탁계약 체결 시 개인정보보호법 제26조 업무위탁에 따른 개 인정보의 처리 제한에 따라 위탁업무 수행목적 외 개인정보 처리금지, 기술적·관리적 보호조치, 재 위탁 제한, 수탁자에 대한 관리·감독, 손해배상 등 책임에 관한 사항을 계약서 등 문서에 명시 하고, 수탁자가 개인정보를 안전하게 처리하는지를 감독하고 있습니다.&#13;&#10;③ 위탁업무의 내용이나 수탁자가 변경될 경우에는 지체 없이 본 개인정보 처리방침을 통하여 공 개하도록 하겠습니다." left="29" top="img03:10" width="1142" height="336" cssclass="font16R" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <ImageViewer id="img04" taborder="12" text="제5조(정보주체의 권리·의무 및 행사방법)" left="30" top="sta07:32" width="348" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/policy_link05S.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta08" taborder="13" text="① 정보주체는 「학생서비스, 학부모서비스」에 대해 다음 각 호에 해당하는 경우 개인정보 보호 관 련 권리를 행사할 수 있습니다.&#13;&#10;1. 개인정보 열람요구&#13;&#10;2. 오류 등이 있을 경우 정정 요구&#13;&#10;3. 삭제요구&#13;&#10;4. 처리정지 요구&#13;&#10;② 제1항에 명시한 권리는 「학생서비스, 학부모서비스」에 대해 개인정보 처리 방법에 관한 고시 별지 제8호 서식에 따라 서면, 전자우편, 모사전송(FAX) 등을 통하여 요구하실 수 있으며 「학생 서비스, 학부모서비스」는 이에 대해 지체없이 조치하겠습니다.&#13;&#10;1. 전자우편 : &lt;l v='mailto:mykim@keris.or.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;mykim@keris.or.kr&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;, &lt;l v='mailto:dain31@keris.or.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;dain31@keris.or.kr&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;로 접수 2. FAX : 053-714-0195로 접수&#13;&#10;③ 정보주체가 개인정보의 오류 등에 대한 정정 또는 삭제를 요구한 경우에는 「학생서비스, 학부 모서비스」는 정정 또는 삭제를 완료할 때까지 당해 개인정보를 이용하거나 제공하지 않습니다.&#13;&#10;④ 회원정보 조회/변경 기능&#13;&#10;- 로그인을 한 후 회원마당 &gt; 회원정보수정 &gt; 정보조회/정보수정 메뉴에서 회원정보 조회 및 수 정할 수 있습니다.&#13;&#10;⑤ 회원탈퇴 기능&#13;&#10;- 로그인을 한 후 회원마당 &gt; 회원정보수정 &gt; 회원탈퇴 메뉴에서 회원탈퇴를 할 수 있습니다." left="29" top="img04:14" width="1142" height="312" cssclass="font16R" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
        <ImageViewer id="img05" taborder="14" text="제6조(처리하는 개인정보 항목)" left="30" top="sta08:35" width="282" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/policy_link06S.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta09" taborder="15" text="① 「학생서비스, 학부모서비스」는 다음의 개인정보 항목을 처리하고 있습니다.&#13;&#10;&lt; 학생서비스 &gt;&#13;&#10;필수항목 : 이름, 아이디, 비밀번호, 학교명, 과정, 학년, 신청일자, 반, 번호, 주야, 계열, 학과, 생 년월일&#13;&#10;선택항목 : 이메일, 연락처(일반, 핸드폰), SMS수신여부&#13;&#10;&lt; 학부모서비스 &gt;&#13;&#10;필수항목 : 이름, 아이디, 비밀번호, 학부모 및 학생서비스 이용 유무사항 선택항목 : 이메일, 연락처(일반, 핸드폰), SMS수신여부&#13;&#10;「학생서비스, 학부모서비스」이용과정에서 아래 개인정보 항목이 자동으로 생성되어 수집될 수 있습니다.&#13;&#10;IP 주소, 쿠키, 방문 일시, 서비스 이용 기록, 가입인증정보 등&#13;&#10;② 「학부모서비스」 이용 시 다음과 같은 개인정보가 추가로 수집될 수 있습니다." left="29" top="img05:10" width="1142" height="216" cssclass="font16R" initvalueid="ivStcAccessibilityOn"/>
        <Grid id="grd01" taborder="16" left="30" top="sta09:41" width="1140" height="122" cssclass="grd_policy_detail" autoenter="select" autofittype="col" fillareatype="datarow" initvalueid="ivGrdAccessibilityOn" formatid="default">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="271"/>
                <Column size="271"/>
                <Column size="597"/>
              </Columns>
              <Rows>
                <Row size="61" band="head"/>
                <Row size="60"/>
              </Rows>
              <Band id="head">
                <Cell text="분류" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                <Cell col="1" text="서비스명" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                <Cell col="2" text="추가로 수집하는 개인정보 항목" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd"/>
              </Band>
              <Band id="body">
                <Cell text="학부모서비스" textAlign="center" padding="0px"/>
                <Cell col="1" text="학부모서비스 신청 자녀등록" textAlign="center"/>
                <Cell col="2" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd" textAlign="center" text="자녀이름, 생년월일, 학교명, 관계, 학년도, 학년, 과정, 계열, 학과, 반, 번호"/>
              </Band>
            </Format>
            <Format id="format00">
              <Columns>
                <Column size="200"/>
                <Column size="364"/>
              </Columns>
              <Rows>
                <Row size="69"/>
                <Row size="69"/>
                <Row size="150"/>
              </Rows>
              <Band id="body">
                <Cell text="분류" cssclass="cell_head" textAlign="center" padding="0px"/>
                <Cell col="1" text="학부모서비스" cssclass="cell_end" padding="22px 30px"/>
                <Cell row="1" text="서비스명" cssclass="cell_head" textAlign="center" padding="0px"/>
                <Cell row="1" col="1" text="학부모서비스 신청 자녀등록" cssclass="cell_end" padding="22px 30px"/>
                <Cell row="2" text="추가로 수집하는 &#13;&#10;개인정보 항목" cssclass="cell_head" textAlign="center" padding="0px"/>
                <Cell row="2" col="1" text="자녀이름, 생년월일, 학교명,&#13;&#13;&#10;관계, 학년도, 학년, 과정, 계열,&#13;&#10;&#13;학과, 반, 번호" cssclass="cell_end" padding="22px 30px"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="sta10" taborder="17" text="③ 이용자는 나이스 대국민서비스 회원가입 및 관리를 위한 개인정보 수집에 대하여 거부할 수 있습니다.&#13;&#10;1. 다만, 제1조 제2항의 필수항목은 나이스 대국민서비스 이용에 필요한 최소한의 정보이므로 이에 대한 수집 거부 시 회원가입이 제한됩니다.&#13;&#10;&#13;&#10;2. 쿠키(Cookie)는 웹사이트를 접속할 때 자동적으로 만들어지는 임시 파일로서 이용자의 정보 를 담고 있습니다. 이용자는 쿠키의 설치 및 수집에 대해 선택권으로 가지고 있으며 수집을 거부 할 수 있습니다. 다만, 쿠키의 저장을 거부할 경우 로그인을 필요로 하는 서비스 제공에 어려움이 있습니다.&#13;&#10;&#13;&#10;1) 쿠키 설정 거부 방법&#13;&#10;&#13;&#10;&lt;Internet Explorer&gt;&#13;&#10;&#13;&#10;· 웹 브라우저 상단 도구 &gt; 인터넷 옵션 &gt; 개인정보 &gt; 고급 개인정보 설정&#13;&#10;&#13;&#10;&lt;Chrome&gt;&#13;&#10;&#13;&#10;· 웹 브라우저 우측 상단 아이콘(크롬 맞춤설정 제어) &gt; 설정 &gt; 맨 하단 고급설정표시 &gt; 개인정보 섹션의 콘텐츠 설정 버튼 &gt; 쿠키 섹션에서 직접 설정" left="29" top="grd01:19" width="1142" height="360" cssclass="font16R" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <ImageViewer id="img06" taborder="18" text="제7조(개인정보의 파기)" left="30" top="sta10:32" width="239" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/policy_link07S.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta11" taborder="19" text="① 「학생서비스, 학부모서비스」는 개인정보 보유기간의 경과, 처리목적 달성 등 개인정보가 불필 요하게 되었을 때에는 지체없이 해당 개인정보를 파기합니다.&#13;&#10;② 정보주체로부터 동의 받은 개인정보 보유기간이 경과하거나 처리목적이 달성되었음에도 불구 하고 다른 법령에 따라 개인정보를 계속 보존하여야 하는 경우에는, 해당 개인정보(또는 개인정 보파일)을 별도의 데이터베이스(DB)로 옮기거나 보관장소를 달리하여 보존합니다.&#13;&#10;③ 개인정보 파기의 절차 및 방법은 다음과 같습니다.&#13;&#10;1. 파기절차&#13;&#10;「학생서비스, 학부모서비스」는 파기하여야 하는 개인정보(또는 개인정보파일)에 대해 개인정보 파기계획을 수립하여 파기합니다. 「학생서비스, 학부모서비스」는 파기 사유가 발생한 개인정보(또는 개인정보파일)를 선정하고, 「학생서비스, 학부모서비스」의 개인정보 보호책임자의 승인을 받 아 개인정보(또는 개인정보파일)를 파기합니다.&#13;&#10;&#13;&#10;2. 파기방법&#13;&#10;「학생서비스, 학부모서비스」는 전자적 파일 형태로 기록·저장된 개인정보는 기록을 재생할 수 없도록 파기하며, 종이 문서에 기록·저장된 개인정보는 분쇄기로 분쇄하거나 소각하여 파기합니다." left="29" top="img06:10" width="1142" height="264" cssclass="font16R" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <ImageViewer id="img07" taborder="20" text="제8조(개인정보의 안전성 확보조치)" left="30" top="sta11:32" width="310" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/policy_link08S.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta12" taborder="21" text="① 「학생서비스, 학부모서비스」는 개인정보의 안전성 확보를 위해 다음과 같은 조치를 취하고 있 습니다.&#13;&#10;1. 관리적 조치 : 내부관리계획 수립·시행, 정기적 직원 교육 등&#13;&#10;2. 기술적 조치 : 개인정보처리시스템 등의 접근권한 관리, 접근통제시스템 설치, 고유식별정보 등의 암호화, 보안프로그램 설치&#13;&#10;3. 물리적 조치 : 전산실, 자료보관실 등의 접근통제" left="29" top="img07:10" width="1142" height="96" cssclass="font16R" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <ImageViewer id="img08" taborder="22" text="제9조(개인정보 보호책임자)" left="30" top="sta12:32" width="266" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/policy_link09S.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta13" taborder="23" text="① 「학생서비스, 학부모서비스」는 개인정보 처리에 관한 업무를 총괄해서 책임지고, 개인정보 처 리와 관련한 정보주체의 불만처리 및 피해구제 등을 위하여 아래와 같이 개인정보 보호책임자를 지정하고 있습니다.&#13;&#10;1. 교육부&#13;&#10;개인정보책임자 : 교육안전정보국장 &#13;&#10;개인정보담당자 : 교육정보화과 나이스 담당자&#13;&#10;2. 한국교육학술정보원&#13;&#10;개인정보 보호책임자 : 정보보호본부장 김태우(053-714-0299)&#13;&#10;개인정보 분야별책임자 : 교육행정본부장 이두영(053-714-0248)&#13;&#10;학생/학부모서비스 분야별담당자 : 나이스대국민부장 곽재윤(053-714-0318), 선임연구원 김민영(053-714-0329)&#13;&#10;3. 시도 교육청&#13;&#10;개인정보 보호책임자 및 취급자는 시도 교육청 홈페이지를 참고하시기 바랍니다.&#13;&#10;② 정보주체께서는 「학생서비스, 학부모서비스」의 서비스(또는 사업)를 이용하시면서 발생한 모 든 개인정보 보호 관련 문의, 불만처리, 피해구제 등에 관한 사항을 개인정보 보호책임자 및 담당 부서로 문의하실 수 있습니다. 「학생서비스, 학부모서비스」는 정보주체의 문의에 대해 지체 없이 답변 및 처리해드릴 것입니다." left="29" top="img08:10" width="1142" height="312" cssclass="font16R" initvalueid="ivStcAccessibilityOn" fittocontents="height" usedecorate="false"/>
        <ImageViewer id="img09" taborder="24" text="제10조(개인정보의 열람청구를 접수·처리하는 부서)" left="30" top="sta13:32" width="412" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/policy_link10S.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta14" taborder="25" text="① 정보주체는 「개인정보 보호법」 제35조에 따른 개인정보의 열람 청구는 '개인정보 보호 담당부 서'에서 할 수 있습니다. 「학생서비스, 학부모서비스」는 정보주체의 개인정보열람청구가 신속하게 처리되도록 노력하겠습니다.&#13;&#10;1. 개인정보 보호 담당&#13;&#10;부서 부서명 : 나이스대국민부 &#13;&#10;담당자 : 김민영, 황다인&#13;&#10;연락처 : 053-714-0329, 0586 / &lt;l v='mailto:mykim@keris.or.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;mykim@keris.or.kr&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;, &lt;l v='mailto:dain31@keris.or.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;dain31@keris.or.kr&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;" left="29" top="img09:10" width="1142" height="144" cssclass="font16R" initvalueid="ivStcAccessibilityOn" fittocontents="height" usedecorate="true"/>
        <ImageViewer id="img10" taborder="26" text="제11조(권익침해 구제방법)" left="30" top="sta14:32" width="261" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/policy_link11S.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta15" taborder="27" text="정보주체는 개인정보침해로 인한 구제를 받기 위하여 개인정보분쟁조정위원회, 한국인터넷진흥원 개인정보침해신고센터 등에 분쟁해결이나 상담 등을 신청할 수 있습니다. 이 밖에 기타 개인 정보침해의 신고, 상담에 대하여는 아래의 기관에 문의하시기 바랍니다.&#13;&#10;1. 개인정보분쟁조정위원회 : (국번없이) 1833-6972 &lt;l v='http://www.kopico.go.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;(www.kopico.go.kr)&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;&#13;&#10;2. 개인정보침해신고센터 : (국번없이) 118 &lt;l v='http://privacy.kisa.or.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;(privacy.kisa.or.kr)&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;&#13;&#10;3. 대검찰청 : (국번없이) 1301 &lt;l v='http://www.spo.go.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;(www.spo.go.kr)&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;&#13;&#10;4. 경찰청 : (국번없이) 182 &lt;l v='http://cyberbureau.police.go.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;(cyberbureau.police.go.kr)&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;&#13;&#10;「개인정보보호법」제35조(개인정보의 열람), 제36조(개인정보의 정정·삭제), 제37조(개인정보의 처리정지 등)의 규정에 의한 요구에 대하여 공공기관의 장이 행한 처분 또는 부작위로 인하여 권리 또는 이익의 침해를 받은 자는 행정심판법이 정하는 바에 따라 행정심판을 청구할 수 있습니 다.&#13;&#10;※행정심판에 대해 자세한 사항은 중앙행정심판위원회&lt;l v='http://www.simpan.go.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;(www.simpan.go.kr)&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt; 홈페이지를 참고 하시기 바랍니다." left="29" top="img10:10" width="1142" height="216" cssclass="font16R" initvalueid="ivStcAccessibilityOn" fittocontents="height" usedecorate="true"/>
        <ImageViewer id="img11" taborder="28" text="제12조(개인정보파일 등록 현황)" left="30" top="sta15:32" width="291" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/policy_link12S.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta16" taborder="29" text="① 「학생서비스, 학부모서비스」는 개인정보를 운영근거/처리목적, 항목, 보유기간 등 개인정보처리방침에서 명시한 범위 내에서 처리하고 있으며, 「개인정보보호법」제32조에 따라 개인정보파일을 운영하고 있습니다.&#13;&#10;② 개인정보파일의 처리목적‧보유기간 및 항목은 개인정보파일의 특성에 따라 달리 규정하고 있으며, 개인정보파일별 상세한 내용은 개인정보보호 종합지원포털을 통해 확인하시기 바랍니다.&#13;&#10;※개인정보보호위원회 개인정보보호 종합지원포털&lt;l v='http://www.privacy.go.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;(www.privacy.go.kr)&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt; → 개인정보민원 → 개인정보 열람등 요구 → 개인정보파일 목록검색 메뉴를 활용" left="29" top="img11:10" width="1142" height="126" cssclass="font16R" initvalueid="ivStcAccessibilityOn" fittocontents="height" usedecorate="true"/>
        <ImageViewer id="img12" taborder="30" text="제13조(개인정보 처리방침 변경)" left="30" top="sta16:32" width="291" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/policy_link13S.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta17" taborder="31" text="① 이 개인정보 처리방침은 2022. 8. 29. 부터 적용됩니다." left="29" top="img12:10" width="1142" height="24" cssclass="font16R" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <Static id="guide01" taborder="32" text="h20" left="59" top="277" width="90" height="20" cssclass="sta_WF_Size" visible="false" initvalueid="ivStcAccessibilityOff"/>
        <Static id="guide01_00" taborder="33" text="h20" left="88" top="179" width="90" height="20" cssclass="sta_WF_Size" visible="false" initvalueid="ivStcAccessibilityOff"/>
        <Static id="guide01_00_00" taborder="34" text="h89" left="53" top="74" width="90" height="89" cssclass="sta_WF_Size" visible="false" initvalueid="ivStcAccessibilityOff"/>
