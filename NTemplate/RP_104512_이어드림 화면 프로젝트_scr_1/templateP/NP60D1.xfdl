          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" text="「학생서비스, 학부모서비스」는 개인정보보호법 등 관련 법령에서 정한 개인정보보호규정을 준수 하고 있으며, 개인정보보호법 제30조에 따라 정보주체의 개인정보를 보호하고 이와 관련한 고충 을 신속하고 원활하게 처리할 수 있도록 하기 위하여 다음과 같이 개인정보 처리지침을 수립·공 개합니다." left="30" top="30" height="48" cssclass="font16R" right="30" width="1140" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta01" taborder="1" text="[주요 개인정보 처리 표시(라벨링)]" left="30" top="158" width="227" height="24" cssclass="font16B" initvalueid="ivStcAccessibilityOn"/>
