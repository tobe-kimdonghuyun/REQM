<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="NP51M1" width="1200" height="2020" titletext="저작권 보호정책">
    <Layouts>
      <Layout height="2020" width="1200">
        <ImageViewer id="title1" taborder="0" text="저작권 보호정책" left="0" top="53" width="220" height="50" cssclass="font34B" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00" taborder="1" text="본 서비스는 저작권자의 동의 없이 게시(or중단)된 저작물로 인하여 저작권을 침해 받은 경우 이를 신고하기 위한 서비스 입니다. '게시중단' 또는 '재게시' 요청신고는 아래 관련양식과 소명자료를 함께 저작권 신고하기에 제출하여 주시기 바랍니다." left="0" top="138" height="48" cssclass="font16R" width="1200" initvalueid="ivStcAccessibilityOn"/>
        <Static id="subTitle00" taborder="2" text="저작권 신고 접수 수령인(담당자)" left="0" top="208" width="296" height="50" cssclass="font24B" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta01" taborder="3" text="성명 및 소속부서 : 해당 시도 교육청 개인정보보호 담당자를 참고하세요." left="10" top="260" width="461" height="26" cssclass="sta_WF_HangTxt_black" initvalueid="ivStcAccessibilityOn"/>
        <Static id="subTitle01" taborder="4" text="저작권신고 및 게시중단 요청 서비스의 대상이 되는 게시물" left="0" top="338" width="516" height="50" cssclass="font24B" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta02" taborder="5" text="나이스 대국민서비스에 게시된 저작물로 저작권자의 저작물을 무단으로 이용하였거나 또는 저작자의 명예를 훼손한다고 생각되는 게시물" left="10" top="390" width="853" height="26" cssclass="sta_WF_HangTxt_black" initvalueid="ivStcAccessibilityOn"/>
        <Static id="subTitle02" taborder="6" text="게시중단요청 신청" left="0" top="468" width="170" height="50" cssclass="font24B" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta03" taborder="7" text="게시중단요청 : 게시된 저작물에 의해 권리를 침해 당하였다고 판단되면 해당 절차에 따라서 게시중단을 요청합니다." left="10" top="520" width="853" height="26" cssclass="sta_WF_HangTxt_black" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta04" taborder="8" text="게시된 자작물의 게시중단(복제·전송 중단)을 요청할 경우에는 아래 문서를 다운로드 하여 작성한 후 저작권 신고하기에 신청 또는 '저작권 담당자'에게 방문 신청합니다." left="10" top="545" width="1024" height="26" cssclass="sta_WF_HangTxt_black" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta05" taborder="9" text="적당한 권리 없이 게시중단을 요청하면 법에 의해 손해배상의 책임이 있습니다." left="10" top="570" width="513" height="26" cssclass="sta_WF_HangTxt_black" initvalueid="ivStcAccessibilityOn"/>
        <ImageViewer id="img00" taborder="10" left="0" top="627" width="1200" height="591" cssclass="display_border" image="url('imagerc::common/img_webGuide_policy1.png')" accessibilitylabel="저작물 게시중단 요청 업무처리절차" initvalueid="ivImgAccessibilityOn"/>
        <Button id="btnFormDownload1" taborder="11" text="양식 다운로드" top="657" width="180" height="50" cssclass="btn_WF_formDownload" right="40" initvalueid="ivBtnAccessibilityButton"/>
        <Static id="subTitle03" taborder="12" text="재게시 요청 신청" left="0" top="1270" width="158" height="50" cssclass="font24B" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta06" taborder="13" text="게시된 중단된 저작물에 게시한 이용자가 해당 저작물이 정당한 권리에 의한 게시라고 판단되면 해당절차에 따라서 재 게시를 요청합니다." left="10" top="1322" width="853" height="26" cssclass="sta_WF_HangTxt_black" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta07" taborder="14" text="게시중단을 통보 받은 저작물에 대하여 재 게시를 요청할 경우에는 아래 문서를 다운로드하여 작성한 후 저작권 신고하기에 신청 또는 '저작권 담당자'에게 방문신청합니다." left="10" top="1347" width="1044" height="26" cssclass="sta_WF_HangTxt_black" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta08" taborder="15" text="정당한 권리 없이 게시중단을 요청하면 법에 의해 손해배상의 책임이 있습니다." left="10" top="1372" width="513" height="26" cssclass="sta_WF_HangTxt_black" initvalueid="ivStcAccessibilityOn"/>
        <ImageViewer id="img02" taborder="16" left="0" top="1429" width="1200" height="591" cssclass="display_border" image="url('imagerc::common/img_webGuide_policy2.png')" accessibilitylabel="저작물 제개시 요청 업무처리절차" initvalueid="ivImgAccessibilityOn"/>
        <Button id="btnFormDownload2" taborder="17" text="양식 다운로드" top="1459" width="180" height="50" cssclass="btn_WF_formDownload" right="30" initvalueid="ivBtnAccessibilityButton"/>
