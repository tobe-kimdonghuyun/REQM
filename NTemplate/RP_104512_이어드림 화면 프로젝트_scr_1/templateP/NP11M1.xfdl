            <Layout>
              <ImageViewer id="subTitle1" taborder="0" text="비영리법인민원" left="0" top="0" width="280" height="62" cssclass="font40B" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00" taborder="1" text="전국 3천 여 개의 비영리법인 운영자가 임원취임 승인&#13;외 4종(정관변경허가, 이사회&#13;&#10;소집승인, 상근직원정&#13;수승인, 수익사업승인)의 허가 및 승인사항 처리를&#13;온라인으로 &#13;&#10;실시하여 기존의 방문 접수에 따른&#13;민원인 불편사항을 해소하고 편익과 행정 &#13;&#10;만족도를&#13;높일 수 있는 서비스입니다." left="0" top="62" width="564" height="98" cssclass="sta_WF_HangTxt_blue" initvalueid="ivStcAccessibilityOn"/>
              <Button id="btn_serviceLink" taborder="2" text="서비스바로가기" left="0" top="270" width="240" height="60" cssclass="btn_WF_serviceLink_blue" initvalueid="ivBtnAccessibilityLink"/>
            </Layout>
