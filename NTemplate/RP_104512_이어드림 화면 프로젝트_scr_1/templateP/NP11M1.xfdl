  <Form id="NP11M1" width="1200" height="4402" titletext="서비스 소개">
    <Layouts>
      <Layout height="4402" width="1200">
        <ImageViewer id="title" taborder="0" text="서비스 소개" left="0" top="60" width="237" height="80" cssclass="font50B" initvalueid="ivTitleAccessibilityOn"/>
        <ImageViewer id="img01" taborder="1" left="0" top="182" width="550" height="380" cssclass="Roundbox20" image="url('imagerc::pas_mmssi00/sub_serviceReport1.jpg')" initvalueid="ivImgAccessibilityOn"/>
        <Div id="div_group1" taborder="2" text="div00" left="600" top="182" height="380" width="600">
          <Layouts>
            <Layout>
              <ImageViewer id="subTitle1" taborder="0" text="나이스플러스" left="0" top="0" width="240" height="62" cssclass="font40B" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00" taborder="1" text="나이스플러스에서 교사는 다양한 교육지원서비스를 통해 수업을 설계하고, 학생은 &#13;&#10;주도적으로 수업에&#13;참여할 수 있는 환경을 제공합니다." left="0" top="62" width="564" height="60" cssclass="sta_WF_HangTxt_blue" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta01" taborder="2" text="나이스플러스에서는 온·오프라인 환경을 통합하여&#13;편리한 과제 제출, 각종 신청 등 &#13;&#10;효율적인 관리와&#13;원활한 피드백을 지원합니다." left="0" top="129" width="564" height="50" cssclass="sta_WF_HangTxt_blue" initvalueid="ivStcAccessibilityOn"/>
              <Button id="btn_serviceLink" taborder="3" text="서비스바로가기" left="0" top="270" width="240" height="60" cssclass="btn_WF_serviceLink_blue" initvalueid="ivBtnAccessibilityLink"/>
            </Layout>
            <Layout name="Layout0">
              <ImageViewer id="subTitle1" cssclass="font42B" left="0" top="0" width="260" height="62"/>
              <Static id="sta00" cssclass="sta_WF_HangTxt_blue_M" left="0" top="subTitle1:17" height="127" text="나이스플러스에서 교사는 다양한 교육지원서비스를 통해 수업을 설계하고, 학생은 주도적으로 수업에 참여할 수 있는 환경을 제공합니다." right="0"/>
              <Button id="btn_serviceLink" cssclass="btn_WF_serviceLink_blue_M" height="120" left="0" top="sta01:43" right="0" text="서비스바로가기"/>
              <Static id="sta01" cssclass="sta_WF_HangTxt_blue_M" left="0" top="sta00:11" height="127" text="나이스플러스에서는 온·오프라인 환경을 통합하여 편리한 과제 제출, 각종 신청 등 효율적인 관리와&#13;원활한 피드백을 지원합니다." right="0"/>
            </Layout>
          </Layouts>
        </Div>
        <ImageViewer id="img02" taborder="3" left="0" top="662" width="550" height="380" cssclass="Roundbox20" image="url('imagerc::pas_mmssi00/sub_serviceReport2.jpg')" initvalueid="ivImgAccessibilityOn"/>
        <Div id="div_group2" taborder="4" text="div00" left="600" top="662" height="380" width="600">
          <Layouts>
            <Layout>
              <ImageViewer id="subTitle1" taborder="0" text="학부모 서비스" left="0" top="0" width="240" height="62" cssclass="font40B" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00" taborder="1" text="학부모서비스는 학부모(보호자)에게 자녀의 성장&#13;발달상황을 한눈에 확인할 수 &#13;&#10;있는 다양한 유치원 및&#13;학교생활 정보를 제공합니다." left="0" top="62" width="564" height="50" cssclass="sta_WF_HangTxt_blue" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta01" taborder="2" text="학부모서비스에서 학부모(보호자)는 자녀의 성적, 건강, 급식, 유아학비 및 각종 &#13;&#10;신청 정보를 온라인으로&#13;편리하게 조회할 수 있습니다." left="0" top="129" width="564" height="50" cssclass="sta_WF_HangTxt_blue" initvalueid="ivStcAccessibilityOn"/>
              <Button id="btn_serviceLink" taborder="3" text="서비스바로가기" left="0" top="270" width="240" height="60" cssclass="btn_WF_serviceLink_blue" initvalueid="ivBtnAccessibilityLink"/>
            </Layout>
            <Layout name="Layout0">
              <ImageViewer id="subTitle1" cssclass="font42B"/>
              <Static id="sta00" cssclass="sta_WF_HangTxt_blue_M" right="0" left="0" top="subTitle1:17" height="127" text="학부모서비스는 학부모(보호자)에게 자녀의 성장&#13;발달 상황을 한눈에 확인할 수 있는 다양한 유치원 및 학교생활 정보를 제공합니다."/>
              <Static id="sta01" cssclass="sta_WF_HangTxt_blue_M" left="0" top="sta00:11" height="127" text="학부모서비스에서 학부모(보호자)는 자녀의 성적,&#13;건강, 급식, 유아학비 및 각종 신청 정보를 온라인으로&#13;편리하게 조회할 수 있습니다." right="0"/>
              <Button id="btn_serviceLink" cssclass="btn_WF_serviceLink_blue_M" left="0" height="120" top="sta01:43" right="0"/>
            </Layout>
          </Layouts>
        </Div>
        <ImageViewer id="img03" taborder="5" left="0" top="1142" width="550" height="380" cssclass="Roundbox20" image="url('imagerc::pas_mmssi00/sub_serviceReport3.jpg')" initvalueid="ivImgAccessibilityOn"/>
        <Div id="div_group3" taborder="6" text="div00" left="600" top="1142" height="380" width="600">
          <Layouts>
            <Layout>
              <ImageViewer id="subTitle1" taborder="0" text="검정고시" left="0" top="0" width="200" height="62" cssclass="font40B" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00" taborder="1" text="검정고시 지원서 접수, 합격자 발표, 대입전형자료&#13;신청 등 온라인으로 처리하여 &#13;&#10;방문접수에 따른&#13;불편사항 해소, 사회적 비용 절감을 통한&#13;교육행정서비스 품질 &#13;&#10;향상을 목표로 하고 있습니다." left="0" top="62" width="503" height="74" cssclass="sta_WF_HangTxt_blue" initvalueid="ivStcAccessibilityOn"/>
              <Button id="btn_serviceLink" taborder="2" text="서비스바로가기" left="0" top="270" width="240" height="60" cssclass="btn_WF_serviceLink_blue" initvalueid="ivBtnAccessibilityLink"/>
            </Layout>
            <Layout name="Layout0">
              <ImageViewer id="subTitle1" cssclass="font42B"/>
              <Static id="sta00" cssclass="sta_WF_HangTxt_blue_M" left="0" top="subTitle1:17" height="169" text="검정고시 지원서 접수, 합격자 발표, 대입전형자료&#13;신청 등 온라인으로 처리하여 방문접수에 따른&#13;불편사항 해소, 사회적 비용 절감을 통한&#13;교육행정서비스 품질 향상을 목표로 하고 있습니다." right="0"/>
