        <ImageViewer id="img04" taborder="7" left="0" top="1622" width="550" height="380" cssclass="Roundbox20" image="url('imagerc::pas_mmssi00/sub_serviceReport4.jpg')" initvalueid="ivImgAccessibilityOn"/>
        <Div id="div_group4" taborder="8" text="div00" left="600" top="1622" height="380" width="600">
          <Layouts>
            <Layout>
              <ImageViewer id="subTitle1" taborder="0" text="교직원 채용" left="0" top="0" width="190" height="62" cssclass="font40B" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00" taborder="1" text="교육공무원, 지방공무원, 교육공무직원 채용 및&#13;계약제교원 인력풀 지원서 접수, &#13;&#10;합격자 발표를&#13;온라인으로 처리하여 방문접수에 따른 불편사항 해소,&#13;사회적 비용&#13;&#10;절감을 통한 교육행정서비스 품질향상을&#13;목표로 하고 있습니다." left="0" top="62" width="516" height="74" cssclass="sta_WF_HangTxt_blue" initvalueid="ivStcAccessibilityOn"/>
              <Button id="btn_serviceLink" taborder="2" text="서비스바로가기" left="0" top="270" width="240" height="60" cssclass="btn_WF_serviceLink_blue" initvalueid="ivBtnAccessibilityLink"/>
            </Layout>
            <Layout name="Layout0">
              <ImageViewer id="subTitle1" cssclass="font42B"/>
              <Static id="sta00" cssclass="sta_WF_HangTxt_blue_M" left="0" top="subTitle1:17" height="169" text="교육공무원, 지방공무원, 교육공무직원 채용 및 계약제 교원 인력풀 지원서 접수, 합격자 발표를&#13;온라인으로 처리하여 방문접수에 따른 불편사항 해소,&#13;사회적 비용절감을 통한 교육행정서비스 품질향상을&#13;목표로 하고 있습니다." right="0"/>
              <Button id="btn_serviceLink" cssclass="btn_WF_serviceLink_blue_M" left="0" height="120" right="0" top="sta00:43"/>
            </Layout>
          </Layouts>
        </Div>
        <ImageViewer id="img05" taborder="9" left="0" top="2102" width="550" height="380" cssclass="Roundbox20" image="url('imagerc::pas_mmssi00/sub_serviceReport5.jpg')" initvalueid="ivImgAccessibilityOn"/>
        <Div id="div_group5" taborder="10" text="div00" left="600" top="2102" height="380" width="600">
          <Layouts>
            <Layout>
              <ImageViewer id="subTitle1" taborder="0" text="학원민원" left="0" top="0" width="150" height="62" cssclass="font40B" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00" taborder="1" text="나이스 학원민원 서비스를 통해 학원, 교습소,&#13;개인과외교습자 관련 민원처리(20종) &#13;&#10;및 각종 학원/교습소 정보를 확인하실 수 있습니다." left="0" top="62" width="564" height="50" cssclass="sta_WF_HangTxt_blue" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta01" taborder="2" text="시도 교육청별 개별 정책에 따른 주요 공지사항은 구분하여 관리하고, 맞춤형 설문&#13;&#10;조사 실시 등 온라인 소통 기능을 제공합니다." left="0" top="129" width="564" height="50" cssclass="sta_WF_HangTxt_blue" initvalueid="ivStcAccessibilityOn"/>
              <Button id="btn_serviceLink" taborder="3" text="서비스바로가기" left="0" top="270" width="240" height="60" cssclass="btn_WF_serviceLink_blue" initvalueid="ivBtnAccessibilityLink"/>
            </Layout>
            <Layout name="Layout0">
