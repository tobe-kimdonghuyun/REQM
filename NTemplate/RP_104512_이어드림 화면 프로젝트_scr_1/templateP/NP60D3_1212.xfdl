                <Cell col="2" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd" text=" 전화번호: 044-203-6514&#13;&#10;       이메일: heeyajin@korea.kr" textAlign="center"/>
              </Band>
