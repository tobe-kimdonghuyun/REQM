                <Cell col="2" text="연락처" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd"/>
