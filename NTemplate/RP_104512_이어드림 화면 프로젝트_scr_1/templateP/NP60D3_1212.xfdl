                <Cell col="1" background="#ffffff" text="대국민 서비스별 로그인 이력" font="normal 400 26px/1.3999999761581421 &quot;Noto Sans KR,NotoSansKR-Regular,Malgun Gothic&quot;" padding="22px 30px" textAlign="left"/>
                <Cell row="1" text="운영근거 / &#13;&#10;처리목적" font="normal 400 26px/normal &quot;Noto Sans KR,NotoSansKR-Regular,Malgun Gothic&quot;" padding="0px"/>
                <Cell row="1" col="1" background="#ffffff" text="시스템 관리/ 서비스 제공" font="normal 400 26px/1.3999999761581421 &quot;Noto Sans KR,NotoSansKR-Regular,Malgun Gothic&quot;" padding="22px 30px" textAlign="left"/>
                <Cell row="2" text="개인정보파일에 &#13;&#10;기록되는 &#13;&#10;개인정보의 항목" font="normal 400 26px/normal &quot;Noto Sans KR,NotoSansKR-Regular,Malgun Gothic&quot;" padding="0px"/>
                <Cell row="2" col="1" background="#ffffff" text="회원ID, 접속 디바이스 분류&#13;(PC, Mobile), 대국민 시스템&#13;분류코드, 대국민 시스템&#13;서브코드, 시도교육청 코드,&#13;로그인 일시, 로그인 유형코드&#13;(인증서 등), 로그인 IP주소  &#13;" wordWrap="char" padding="22px 30px" font="normal 400 26px/1.3999999761581421 &quot;Noto Sans KR,NotoSansKR-Regular,Malgun Gothic&quot;" textAlign="left"/>
