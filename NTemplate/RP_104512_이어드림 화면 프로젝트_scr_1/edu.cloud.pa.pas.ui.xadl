			}
			if (mf.height <= objPopf[icnt].height)
			{
				////trace("1-3");
				//팝업 높이가 부모 높이보다 큰 경우 원하는 동작
				new_top = 0;
				new_height = mf.height;
				//new_height = objPopf[icnt].height;
			}
			else
			{
				new_top = (mf.height-objPopf[icnt].height)/2;
				if (objPopf[icnt].height < objPopf[icnt].org_height)
				{
					new_height = objPopf[icnt].org_height;
				}
				else
				{
					new_height= objPopf[icnt].height;
				}
			}

			objPopf[icnt].move(new_left,new_top,new_width,new_height);
		}
	}
};
