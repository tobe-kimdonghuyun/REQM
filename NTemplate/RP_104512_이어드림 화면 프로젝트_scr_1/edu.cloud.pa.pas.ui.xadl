		else
		{
			if (mf.width <= objPopf[icnt].width)
			{
				////trace("1-1");
				//팝업 너비가 부모 너비보다 큰 경우 원하는 동작
				new_left = 0;
				new_width = mf.width;
				//new_width = objPopf[icnt].width;
			}
			else
			{
