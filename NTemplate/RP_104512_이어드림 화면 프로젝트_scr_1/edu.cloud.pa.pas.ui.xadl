<?xml version="1.0" encoding="utf-8"?>
<ADL version="2.0">
  <Application id="NEIS" licenseurl="" screenid="ScreenDeskTopP,mobileP,tabletP,ScreenDeskTop,mobile,tablet" onload="Application_onload" onerror="Application_onerror" onloadforms="Application_onloadforms">
    <Layout>
      <MainFrame id="mainframe" showtitlebar="false" showstatusbar="false" left="0" top="0" width="1920" height="720" showcascadetitletext="false" titletext="나이스 대국민서비스">
        <VFrameSet id="VFrameSet" separatesize="*" showtitlebar="false" showtitleicon="false">
          <Frames>
            <ChildFrame id="frameMain" formurl="frame::frameMainP.xfdl" dragmovetype="none" showtitlebar="false" showtitleicon="false"/>
          </Frames>
        </VFrameSet>
      </MainFrame>
    </Layout>
    <Style url="xcssrc::font.xcss"/>
    <Style url="xcssrc::grid.xcss"/>
    <Style url="xcssrc::work.xcss"/>
    <Style url="xcssrc::popup.xcss"/>
    <Style url="xcssrc::top.xcss"/>
    <Style url="xcssrc::bottom.xcss"/>
    <Style url="xcssrc::navigator.xcss"/>
    <Style url="xcssrc::webGuide.xcss"/>
    <Style url="xcssrc::main.xcss"/>
    <Style url="xcssrc::navigator_M.xcss"/>
    <Style url="xcssrc::grid_M.xcss"/>
    <Style url="xcssrc::work_M.xcss"/>
    <Style url="xcssrc::top_M.xcss"/>
    <Style url="xcssrc::bottom_M.xcss"/>
    <Style url="xcssrc::main_M.xcss"/>
    <Style url="xcssrc::popup_M.xcss"/>
    <Style url="xcssrc::webGuide.xcss"/>
    <Style url="xcssrc::policy.xcss"/>
    <Style url="xcssrc::policy_M.xcss"/>
    <Style url="xcssrc::search.xcss"/>
    <Style url="xcssrc::search_M.xcss"/>
