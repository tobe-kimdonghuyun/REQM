<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Guide_07" width="1200" height="720" titletext="설명(항목)">
    <Layouts>
      <Layout height="720" width="1200" screenid="ScreenDeskTopP">
        <Div id="div00" taborder="0" left="0" top="65" width="1200" height="296" cssclass="div_WF_hang">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" text="초고석 인터넷망과 정보통신기술의 발전에 따라 기존의 문서 위주의 행정을 디지털 행정으로 전환하여 선진 교육행정서비스를 제공할 필요성이 증가하였습니다." left="30" top="21" width="994" height="30" cssclass="sta_WF_HangTxt_blue"/>
              <Static id="Static01_00_01_00_00_00_02" taborder="1" text="h30" left="625" top="0" width="59" height="30" cssclass="sta_WF_Size" visible="false"/>
              <Static id="Static01_00_01_00_00_00_02_00" taborder="2" text="h30" left="625" top="44" width="59" height="30" cssclass="sta_WF_Size" visible="false"/>
              <Static id="sta00_00" taborder="3" text="시·도교육청 내/외부의 각종 정보시스템간 호환성 문제로 자료의 효율적 관리 이용에 어려움을 겪습니다." left="30" top="65" width="656" height="30" cssclass="sta_WF_HangTxt_blue"/>
              <Static id="Static01_00_01_00_00_00_02_00_00" taborder="4" text="h30" left="625" top="88" width="59" height="30" cssclass="sta_WF_Size" visible="false"/>
              <Static id="sta00_00_00" taborder="5" text="전체 공공기관 보안사고 중 70%(2001년도)가 각급 학교에서 발생하는 등 기존의 학교 시스템(C/S, S/A)의 보안상 문제점을 해결할 필요가 컸습니다." left="30" top="109" width="908" height="30" cssclass="sta_WF_HangTxt_blue"/>
              <Static id="sta00_01" taborder="6" text="시·도교육청별 업무단위 별 프로그램의 중복개발 및 시스템 관리 비용 과다 소요 등에 따라 효율적인 시스템 관리 및 예산절감이 필요해졌습니다." left="30" top="153" width="878" height="30" cssclass="sta_WF_HangTxt_blue"/>
              <Static id="sta00_00_01" taborder="7" text="교육행정의 효율화를 통한 학교현장의 업무경감 방안 추진으로 학생중심의 수준별 교육과정 도입 등에 따른 교사의 연구시간 확보 지원이 필요해졌습니다." left="30" top="197" width="946" height="30" cssclass="sta_WF_HangTxt_blue"/>
              <Static id="sta00_00_00_00" taborder="8" text="21세기 국가 경쟁력 확보 및 국민 편익 증진을 위한 범 정부적 전자정부 구현 활동이 확대 강화되고 있습니다." left="30" top="241" width="671" height="30" cssclass="sta_WF_HangTxt_blue"/>
              <Static id="Static01_00_01_00_00_00_02_01" taborder="9" text="h30" left="625" top="132" width="59" height="30" cssclass="sta_WF_Size" visible="false"/>
              <Static id="Static01_00_01_00_00_00_02_00_01" taborder="10" text="h30" left="625" top="176" width="59" height="30" cssclass="sta_WF_Size" visible="false"/>
              <Static id="Static01_00_01_00_00_00_02_00_00_00" taborder="11" text="h30" left="625" top="220" width="59" height="30" cssclass="sta_WF_Size" visible="false"/>
              <Static id="Static01_00_01_00_00_00_02_00_00_00_00" taborder="12" text="h30" left="635" top="264" width="59" height="30" cssclass="sta_WF_Size" visible="false"/>
              <Static id="Static01_00_01_00_00_00_02_02" taborder="13" text="w14" left="34" top="31" width="14" height="30" cssclass="sta_WF_Size" visible="false"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta00" taborder="1" text="초고석 인터넷망과 정보통신기술의 발전에 따라 기존의 문서 위주의 행정을 디지털 행정으로 전환하여 선진 교육행정서비스를 제공할 필요성이 증가하였습니다." left="30" top="381" width="994" height="30" cssclass="sta_WF_HangTxt_black"/>
        <Static id="Static01_00_01_00_00_00_02_02" taborder="2" text="w14" left="34" top="381" width="14" height="30" cssclass="sta_WF_Size" visible="false"/>
        <Static id="sta00_00" taborder="3" text="초고석 인터넷망과 정보통신기술의 발전에 따라 기존의 문서 위주의 행정을 디지털 행정으로 전환하여 선진 교육행정서비스를 제공할 필요성이 증가하였습니다." left="30" top="421" width="994" height="30" cssclass="sta_WF_HangTxt_Skyblue"/>
        <Static id="Static01_00_01_00_00_00_02_02_00" taborder="4" text="h8" left="64" top="421" width="104" height="8" cssclass="sta_WF_Size" visible="false"/>
        <Static id="Static01_00_01_00_00_00_02_02_00_00" taborder="5" text="h8" left="64" top="443" width="104" height="8" cssclass="sta_WF_Size" visible="false"/>
        <Static id="sta00_01" taborder="6" text="초고석 인터넷망과 정보통신기술의 발전에 따라 기존의 문서 위주의 행정을 디지털 행정으로 전환하여 선진 교육행정서비스를 제공할 필요성이 증가하였습니다." left="30" top="491" width="824" height="50" cssclass="sta_WF_HangTxt_black"/>
