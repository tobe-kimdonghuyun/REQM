                <Cell col="1" text="bind:title" textAlign="left" cssclass="expr:key==&quot;1&quot;?&quot;cell_link,cell_bgGray&quot;:&quot;cell_link&quot;" displaytype="buttoncontrol" edittype="button"/>
                <Cell col="2" text="bind:date" calendardateformat="yyyy.MM.dd" cssclass="expr:key=='1' ? &quot;cell_bgGray&quot;:&quot;&quot;" font="normal 400 14px/normal &quot;Noto Sans KR&quot;,&quot;NotoSansKR-Regular&quot;"/>
                <Cell col="3" displaytype="imagecontrol" cssclass="expr:key=='1' ? &quot;cell_bgGray&quot;:&quot;&quot;" padding="0px" text="theme://images/grd_view.png"/>
                <Cell col="4" text="bind:view" textAlign="left" padding="0px 8px" cssclass="expr:key=='1' ? &quot;cell_bgGray&quot;:&quot;&quot;" displaytype="number" font="normal 400 14px/normal &quot;Noto Sans KR&quot;,&quot;NotoSansKR-Regular&quot;"/>
              </Band>
            </Format>
