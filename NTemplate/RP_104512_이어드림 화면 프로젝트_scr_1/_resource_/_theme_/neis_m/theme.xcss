	-nexa-text-align 	: center;
	background 		: transparent;
	color 			: #222222;
	font 			: normal 500 26px/1.3 "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic";
}
.Button.btn_WF_Announce04,.Button.btn_WF_Announce04[status=mouseover],
.Button.btn_WF_Announce04[userstatus=selected],.Button.btn_WF_Announce04[userstatus=pushed]
{
