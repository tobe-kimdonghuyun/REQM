	background 		: #2a3b64;
	border-radius 		: 0px 4px 4px 0px;
	color 			: #ffffff;
	font 			: normal 700 24px "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";
	cursor 			: pointer;
}
.FileUpload .fileuploaditem .fileuploaditembutton[status=mouseover]
{
	background 		: #4162b2;
