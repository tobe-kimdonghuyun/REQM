.MaskEdit[status=disabled]
{
	-nexa-border 		: 1px solid #d4d6d8;
	color 			: #aaaaaa;
}
/***** ProgressBar *****/
.ProgressBar,
.ProgressBar[status=mouseover],.ProgressBar[status=focused]
{
	-nexa-border 		: 1px solid #dddddd;
	background 		: #ffffff;
	border-radius 		: 4px;
}
.ProgressBar[status=disabled]
{
	-nexa-border 		: 1px solid #eeeeee;
	background 		: #ffffff;
}
.ProgressBar .progressbaritem,
.ProgressBar .progressbaritem[status=mouseover]
{
	background 		: #1E5DF2;
}
.ProgressBar .progressbaritem[status=disabled]
{
	background 		: #d7d8dc;
}
.ProgressBar .progressbartext,
.ProgressBar .progressbartext[status=mouseover],.ProgressBar .progressbartext[status=disabled]
{
	-nexa-padding 		: 0px 10px 0px 10px;
	color 			: #ffffff;
}
.ProgressBar .progressstartcap,
.ProgressBar .progressstartcap[status=mouseover]
{
	background 		: #005bac;
}
.ProgressBar .progressstartcap[status=disabled]
{
	background 		: #f4f5f9;
}
.ProgressBar .progressendcap,
.ProgressBar .progressendcap[status=mouseover]
{
	background 		: #005bac;
}
.ProgressBar .progressendcap[status=disabled]
{
	background 		: #f4f5f9;
}
/***** Radio *****/
.Radio,
.Radio[status=mouseover],
.Radio[status=readonly],.Radio[status=disabled]
{
	color 			: #172f57;
	-nexa-border		: 2px solid transparent;	
}
.Radio[status=focused]
{
	-nexa-border 		: 2px solid #172f57;
}
.Radio .radioitem,.Radio .radioitem[status=readonly]
{
	-nexa-icon 		: URL("theme://images/rdo_WF_Item.png");
	-nexa-text-padding 	: 0px 20px 0px 16px;
}
.Radio .radioitem[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/rdo_WF_ItemS.png");
}
.Radio .radioitem[status=disabled]
{
	-nexa-icon 		: URL("theme://images/rdo_WF_ItemD.png");
}
.Radio .radioitem[status=disabled][userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/rdo_WF_ItemSD.png");
}
/***** Spin *****/
.Spin,.Spin[status=focused]
{
	-nexa-border 		: 1px solid #333333;
	background 		: #ffffff;
	border-radius 		: 6px;
}
.Spin[status=disabled]
{
	background 		: #f5f5f5;
}
.Spin[status=readonly]
{
	background 		: #f5f5f5;
}
.Spin .spinedit
{
	-nexa-padding 		: 10px 20px 10px 20px;
	-nexa-text-align 	: right;
}
.Spin .spinedit[status=focused]
{
	-nexa-padding 		: 9px 19px 10px 9px;
}
.Spin .spinedit[status=disabled]
{
	color 			: #aaaaaa;
}
.Spin .spindownbutton,
.Spin .spindownbutton[status=focused],.Spin .spindownbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/spn_WF_DnBtn.png");
}
.Spin .spindownbutton[userstatus=pushed]
{
}
.Spin .spindownbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/spn_WF_DnBtnD.png");
}
.Spin .spinupbutton,
.Spin .spinupbutton[status=focused],.Spin .spinupbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/spn_WF_UpBtn.png");
	-nexa-padding 		: 1px 0px 0px 0px;
}
.Spin .spinupbutton[userstatus=pushed]
{
}
.Spin .spinupbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/spn_WF_UpBtnD.png");
}
/***** Static *****/
.Static
{
	-nexa-word-wrap 	: char;
}
.Static[status=disabled]
{
	color 			: #999999;
}
/***** StepControl *****/
.StepControl,
.StepControl[status=mouseover],.StepControl[status=disabled]
{
	-nexa-padding 		: 0px 20px 18px 0px;
	background 		: transparent; 
}
.StepControl .stepitem
{
	-nexa-padding 		: 10px 3px 0px 3px;
	-nexa-icon 		: URL("theme://images/img_StepN.png");
	background 		: transparent;	
}
.StepControl .stepitem[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/img_StepS.png");
}
/***** Tab *****/
.Tab,
.Tab[status=mouseover],.Tab[status=focused],
.Tab[status=disabled]
{
	cursor 			: pointer;
}
.Tab .prevbutton,
.Tab .prevbutton[status=focused],.Tab .prevbutton[userstatus=selected]
{

	-nexa-padding		: 0px 4px 5px 0px;
	cursor			: pointer;
}
.Tab .prevbutton[status=disabled]
{
	opacity 		: 0.3;
}
.Tab .prevbutton[status=mouseover]
{

}
.Tab .prevbutton[userstatus=pushed]
{	
}
.Tab.nextbutton,
.Tab .nextbutton[status=focused],.Tab .nextbutton[userstatus=selected]
{
	-nexa-padding		: 0px 5px 5px 3px;
	cursor 			: pointer;
}
.Tab .nextbutton[status=disabled]
{
	opacity 		: 0.3;
}
.Tab .tabbuttonitem,
.Tab .tabbuttonitem[status=mouseover],.Tab .tabbuttonitem[status=disabled]
{
	-nexa-border 		: 1px solid #a4a6ac;
	-nexa-padding 		: 25px 50px 25px 50px;
	background 		: #ffffff;
	color 			: #6b6b6b;
	font 			: normal 700 28px "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";
	border-radius 		: 0px;
}
.Tab .tabbuttonitem[userstatus=selected],.Tab .tabbuttonitem[status=focused]
{
	-nexa-border 		: 2px solid #1E5DF2;
	-nexa-padding 		: 24px 49px 24px 49px;
	background 		: #ffffff;
	color 			: #3879dd;
	font 			: normal 700 28px "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";
	border-radius 		: 0px;

}
.Tab .tabbuttonitem .tabbuttonitemtext,.Tab .tabbuttonitem .tabbuttonitemtext[status=disabled]
{
	-nexa-padding 		: 7px 15px 9px 15px;
	-nexa-text-align 	: center;
}
.Tab .tabbuttonitem .tabbuttonitemtext[status=mouseover]
{
	-nexa-text-decoration 	: underline;	
}
.Tab .tabbuttonitem .extrabutton,
.Tab .tabbuttonitem .extrabutton[status=mouseover],.Tab .tabbuttonitem .extrabutton[status=focused],
.Tab .tabbuttonitem .extrabutton[userstatus=pushed],.Tab .tabbuttonitem .extrabutton[userstatus=selected],
.Tab .tabbuttonitem .extrabutton[status=disabled]
{
	-nexa-padding 		: 0px 10px 0px 0px;
}
.Tab .tabpage,
.Tab .tabpage[status=mouseover],.Tab.tabpage[status=focused],
.Tab .tabpage[status=disabled]
{
	-nexa-border 		: 1px solid #a4a6ac,0px none,0px none,;
}
/***** TextArea *****/
.TextArea
{
	-nexa-border 		: 1px solid #6d7074;
	-nexa-padding 		: 10px 20px 10px 20px;
	-nexa-word-wrap 	: char;
	background 		: #ffffff;
	border-radius 		: 4px;
	color 			: #172f57;
}
.TextArea[status=mouseover]
{
	-nexa-border 		: 2px solid #6d7074;
	-nexa-padding 		: 9px 19px 9px 19px;
}
.TextArea[status=focused]
{
	-nexa-border 		: 2px solid #2a3b64;
	-nexa-padding 		: 9px 19px 9px 19px;
}
.TextArea[status=readonly]
{
	-nexa-border		: 1px solid #d4d6d8;
	background 		: #f5f5f5;
}
.TextArea[userstatus=nulltext]
{
        color 			: #aaaaaa;
}
.TextArea[status=disabled]
{
	-nexa-border 		: 1px solid #d4d6d8;
        color 			: #aaaaaa;
}

