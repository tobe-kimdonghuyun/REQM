/* Main Pop Step (icon) Button */
.Button.btn_main_pop_step,
.Button.btn_main_pop_step[status=mouseover],
.Button.btn_main_pop_step[userstatus=pushed]
{
	-nexa-border 		: 1px solid transparent;
	-nexa-padding 		: 0px;
	-nexa-icon		: url('imagerc::main/main_Pop_stepN.png');	
	background 		: transparent;
	border-radius 		: 15px;	
}
.Button.btn_main_pop_step[status=focused]
{
	-nexa-border 		: 1px dashed #000000;
	-nexa-padding 		: 0px;
}											
.Button.btn_main_pop_step[status=disabled]
{
	-nexa-border 		: 1px solid transparent;
	background 		: transparent;
}
/* Main Pop Step Selected (icon) Button */
.Button.btn_main_pop_step_S,
.Button.btn_main_pop_step_S[status=mouseover],
.Button.btn_main_pop_step_S[userstatus=pushed]
{
	-nexa-border 		: 1px solid transparent;
	-nexa-padding 		: 0px;
	-nexa-icon		: url('imagerc::main/main_Pop_stepS.png');	
	background 		: transparent;
	border-radius 		: 15px;	
}
.Button.btn_main_pop_step_S[status=focused]
{
	-nexa-border 		: 1px dashed #000000;
	-nexa-padding 		: 0px;
}
.Button.btn_main_pop_step_S[status=disabled]
{
	-nexa-border 		: 1px solid transparent;
	background 		: transparent;
}
/* Mobile Type CheckBox bg Black */
.CheckBox.chk_WF_M_W
{
	-nexa-icon 		: url('theme://images/chk_M_box_w.png');
	-nexa-border 		: 2px solid transparent;
	-nexa-text-padding 	: 0px 0px 0px 16px;
	-nexa-padding 		: 0px 20px;	
	color 			: #ffffff;
	font 			: normal 400 24px "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";	
}
.CheckBox.chk_WF_M_W[status=focused]
{
	-nexa-icon 		: url('theme://images/chk_M_box_w.png');
	-nexa-border	 	: 2px dashed #222222;
	border-radius 		: 7px;
}
.CheckBox.chk_WF_M_W[status=readonly]
{
	-nexa-icon 		: url('theme://images/chk_M_boxD_w.png');
	color 			: #ffffff;	
}
.CheckBox.chk_WF_M_W[status=mouseover]
{
	-nexa-icon 		: url('theme://images/chk_M_boxO_w.png');
}
.CheckBox.chk_WF_M_W[status=mouseover][userstatus=selected]
{
	-nexa-icon 		: url('theme://images/chk_M_boxSO_w.png');
}
.CheckBox.chk_WF_M_W[userstatus=selected]
{
	-nexa-icon 		: url('theme://images/chk_M_boxS_w.png');
}
.CheckBox.chk_WF_M_W[status=disabled]
{
	-nexa-icon 		: url('theme://images/chk_M_boxD_w.png');
	color 			: #d9d9d9;	
}
.CheckBox.chk_WF_M_W[status=disabled][userstatus=selected]
{
	-nexa-icon 		: url('theme://images/chk_M_boxDS_w.png');
	color 			: #d9d9d9;	
}
/* Shadow Box PopupDiv(center) */
.Div.div_Pop_shadowBox_C,
.Div.div_Pop_shadowBox_C[status=mouseover],
.Div.div_Pop_shadowBox_C[status=focused]
{
	border-radius 		: 20px;
	background 		: #ffffff;
	box-shadow 		: 0px 10px 16px 0px rgba(0,0,0,0.07);
}
.Div.div_Main_SurvBox
{
	border-radius 		: 16px;
	background 		: #ffffff;
	box-shadow 		: 12px 12px 20px 3px rgba(0,0,0,0.07);	
}
.Div.div_Main_SurvBox[status=disabled]
{
	-nexa-border 		: 2px solid #dadada;
	border-radius 		: 16px;
	background 		: #ffffff;
	box-shadow 		: none;	
}
/* ImageViewer display */
.ImageViewer.display,
.ImageViewer.display[status=mouseover],
.ImageViewer.display[status=focused],
.ImageViewer.display[status=disabled]
{
	-nexa-border 		: 0px none;
	border-radius 		: 0px;
	background 		: transparent;
}
