/*파일 내려받기*/
.Button.btn_WF_FileDown_M
{
	-nexa-border 		: 0px none;
	-nexa-icon 		: URL("theme://images/btn_WF_FileDown2.png");
	-nexa-padding 		: 0px 10px 0px 10px;
	-nexa-text-padding 	: 0px 0px 0px 8px; 
	background 		: #2a3b64;
	border-radius 		: 4px;
	color 			: #ffffff;
	font 			: normal 400 24px "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_WF_FileDown_M[status=focused]
{
	-nexa-border 		: 2px solid #1E5DF2;
	-nexa-padding 		: 0px 10px 0px 10px;
}
.Button.btn_WF_FileDown_M[status=mouseover],.Button.btn_WF_FileDown_M[userstatus=pushed]
{
	background 		: #4162b2; 
}
.Button.btn_WF_FileDown_M[status=disabled]
{
	background 		: #c8cdd7; 
}
/*파일 첨부하기*/
.Button.btn_WF_FileAdd01_M,
.Button.btn_WF_FileAdd01_M[userstatus=selected]
{
	-nexa-border 		: 1px solid #0466c9;
	-nexa-icon 		: URL("theme://images/btn_WF_FileAddN_M.png");
	-nexa-padding 		: 0px;
	-nexa-text-align 	: center;
	background 		: transparent;
}
.Button.btn_WF_FileAdd01_M[status=focused]
{
	-nexa-border 		: 2px solid #2a3b64;
	-nexa-padding 		: 0px;
}
.Button.btn_WF_FileAdd01_M[status=mouseover],.Button.btn_WF_FileAdd01_M[userstatus=pushed]
{
	-nexa-border 		: 1px solid #0466c9;
	-nexa-icon 		: URL("theme://images/btn_WF_FileAddO_M.png");
	background 		: #eef6fd;
}
.Button.btn_WF_FileAdd01_M[status=disabled]
{
	-nexa-border 		: 1px solid #acacac;
	-nexa-icon 		: URL("theme://images/btn_WF_FileAddD_M.png");
	background 		: #ffffff; 
}
