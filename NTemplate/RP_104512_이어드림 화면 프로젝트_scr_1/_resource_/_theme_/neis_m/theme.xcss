.Div.div_WF_Main11[status=disabled],.Div.div_WF_Main11[status=focused],
.Div.div_WF_Main11[status=mouseover]
{
	background 		: url('theme://images/img_WF_Main11_M.gif') no-repeat right bottom /auto 360px #9cdaea;
	border-radius 		: 0px;		
}
.Div.div_WF_Send03,
.Div.div_WF_Send03[status=disabled], .Div.div_WF_Send03[status=focused],
.Div.div_WF_Send03[status=mouseover]
{
	-nexa-border 		: 1px solid #e9e0f3;
	box-shadow 		: 10px 10px 15px 0px rgba(0,0,0,0.05);
	background		: #ffffff;
	border-radius 		: 20px;	
	cursor 			: pointer;
}
