.FileUpload .fileuploaditem .fileuploaditemedit[status=focused],.FileUpload .fileuploaditem .fileuploaditemedit[status=mouseover],
.FileUpload .fileuploaditem .fileuploaditemedit[status=readonly],.FileUpload .fileuploaditem .fileuploaditemedit[userstatus=nulltext]
{
