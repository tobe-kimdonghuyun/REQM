{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 10px 7px 0px 7px;
	-nexa-text-align	: center;	
	background 		: transparent;
	color 			: #222222;
	font 			: normal 400 28px/1.5 "Noto Sans KR","NotoSansKR-Regular";
	-nexa-icon		: url('theme://images/icon_serviceLink_complaint.png');
	-nexa-text-padding	: 23px 0px 0px 0px;
	-nexa-icon-position	: top;
	border-radius 		: 16px;	
}
.Button.btn_Pop_menu_serviceLink5[status=focused]
{
	-nexa-border 		: 2px dashed #000000;
	-nexa-padding 		: 10px 7px 0px 7px;
}
.Button.btn_Pop_menu_serviceLink5[status=mouseover],
.Button.btn_Pop_menu_serviceLink5[userstatus=pushed]
{
	-nexa-border 		: 2px solid transparent;
	-nexa-text-decoration 	: underline;
	-nexa-padding 		: 10px 7px 0px 7px;
	background 		: transparent;
	color 			: #222222;
}
.Button.btn_Pop_menu_serviceLink5[status=disabled]
{
	-nexa-border 		: 2px solid transparent;
	background 		: transparent;
	color			: #565656;
	opacity 		: 0.4;		
}
