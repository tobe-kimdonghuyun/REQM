/********************** Font Style START **/
/************************************************************************/
/* font 18 Regular */
.Static.font18R,
.Static.font18R[status=disabled], .Static.font18R[status=mouseover]
{
	letter-spacing 		: -1px;
	font			: normal 400 18px/normal "Noto Sans KR","NotoSansKR-Regular";
}
/* font 24 Regular */
.Static.font24R,
.Static.font24R[status=disabled], .Static.font24R[status=mouseover]
{
	letter-spacing 		: -1px;		
	font			: normal 400 24px/1.3 "Noto Sans KR","NotoSansKR-Regular";
	color 			: #222222;
}
/* Font 48 bold */
.Static.font48B,
.Static.font48B[status=disabled], .Static.font48B[status=mouseover]
{
	letter-spacing 		: -3px;	
	font			: normal 700 48px/normal "Noto Sans KR","NotoSansKR-Regular";
	color 			: #222222;
}
/* Font 28 bold */
.Static.font28B,
.Static.font28B[status=disabled], .Static.font28B[status=mouseover]
{
	font 			: normal 700 28px "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";
	color 			: #222222;
}
