}
.FileUpload .fileuploaditem .fileuploaditembutton[userstatus=pushed]
{
	background 		: #4162b2;
}
.FileUpload .fileuploaditem .fileuploaditembutton[status=disabled]
{
	background 		: #c8cdd7;
}
/***** Grid *****/
