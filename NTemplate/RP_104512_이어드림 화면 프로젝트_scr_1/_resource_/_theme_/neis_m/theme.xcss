<?xml version="1.0" encoding="utf-8"?>
<XCSS version="1.1">
  <CSSData><![CDATA[/***********************************************************************/
/***** PROJECT NAME : 	  					********/
/***** CREATION DATES : 					********/
/***** DRAFTER : TOBESOFT Design Team 				********/
/***** DISTRIBUTION DATE : 					********/
/***** 1st AMENDER : 						********/
/***** 1st MODIFICATION DATE : 					********/
/***********************************************************************/


/************************************************************************/
/********************** FRAME START **/
/************************************************************************/
.MainFrame
{
	-nexa-border 		: 0px solid #0078d6;
}
/***** Form *****/
.Form,
.Form[status=mouseover],.Form[status=focused],
.Form[status=disabled]
{
	background 		: #FFFFFF;
	color 			: #333333;
	font 			: normal 400 24px "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Form[userstatus=contents]
{
	background 		: transparent;
}

/***** TitleBarControl *****/
.TitleBarControl
{
	-nexa-border 		: 0px none, 0px none, 1px solid #333333, 0px none;
	-nexa-padding 		: 0px 0px 0px 20px;
	background		: #4d4b4b;
	color 			: #ffffff;
	font 			: normal 400 24px "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.TitleBarControl[status=disabled],.TitleBarControl[status=deactivate]
{
	background 		: #949494;
}
.TitleBarControl .minbutton,
.TitleBarControl .minbutton[status=focused],.TitleBarControl .minbutton[userstatus=selected],
.TitleBarControl .minbutton[status=deactivate]
{
	-nexa-icon 		: URL("theme://images/tbar_TF_Min.png");
}
.TitleBarControl .minbutton[userstatus=pushed]
{
	-nexa-icon 		: URL("theme://images/tbar_TF_MinP.png");	
}
.TitleBarControl .minbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/tbar_TF_MinD.png");
}
.TitleBarControl .maxbutton,
.TitleBarControl .maxbutton[status=focused],.TitleBarControl .maxbutton[userstatus=selected],
.TitleBarControl .maxbutton[status=deactivate]
{
	-nexa-icon 		: URL("theme://images/tbar_TF_Max.png");
}
.TitleBarControl .maxbutton[userstatus=pushed]
{
	-nexa-icon 		: URL("theme://images/tbar_TF_MaxP.png");
}
.TitleBarControl .maxbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/tbar_TF_MaxD.png");
}
.TitleBarControl .normalbutton,
.TitleBarControl .normalbutton[status=focused],.TitleBarControl .normalbutton[userstatus=selected],
.TitleBarControl .normalbutton[status=deactivate]
{
	-nexa-icon 		: URL("theme://images/tbar_TF_Normal.png");
}
.TitleBarControl .normalbutton[userstatus=pushed]
{
	-nexa-icon 		: URL("theme://images/tbar_TF_NormalP.png");
}
.TitleBarControl .normalbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/tbar_TF_NormalD.png");
}
.TitleBarControl .closebutton,
.TitleBarControl .closebutton[status=focused],.TitleBarControl .closebutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/tbar_TF_Close.png");
}
.TitleBarControl .closebutton[userstatus=pushed]
{
	-nexa-icon 		: URL("theme://images/tbar_TF_CloseP.png");
}
.TitleBarControl .closebutton[status=disabled],.TitleBarControl .closebutton[status=deactivate]
{
	-nexa-icon 		: URL("theme://images/tbar_TF_CloseD.png");
}
/***** ScrollBarControl *****/
/* HScrollBarControl */
.HScrollBarControl,
.HScrollBarControl[status=mouseover],.HScrollBarControl[status=disabled]
{
	-nexa-border 		: 6px solid transparent, 0px none, 7px solid transparent, 0px none;
	background 		: transparent;
}
.HScrollBarControl .trackbar,
.HScrollBarControl .trackbar[status=focused],.HScrollBarControl .trackbar[userstatus=selected]
{
	background 		: #b2b2b2;
	border-radius		: 6px;
}
.HScrollBarControl .trackbar[userstatus=pushed]
{
	background 		: #aaaaaa;
}
.HScrollBarControl .trackbar[status=disabled]
{
	background 		: #eeeeee;
}
/* VScrollBarControl */
.VScrollBarControl,.VScrollBarControl[status=disabled]
{
	-nexa-border 		: 0px none, 6px solid transparent, 0px none, 9px solid transparent;
	background 		: transparent;
}
.VScrollBarControl .trackbar,
.VScrollBarControl .trackbar[status=focused],.VScrollBarControl .trackbar[userstatus=selected]
{
	background 		: #b2b2b2;
	border-radius		: 6px;
}
.VScrollBarControl .trackbar[userstatus=pushed]
{
	background 		: #aaaaaa;
}
.VScrollBarControl .trackbar[status=disabled]
{
	background 		: #eeeeee;
}
/* ScrollIndicatorControl */
.VScrollIndicatorControl
{
	-nexa-border 		: 0px none, 6px solid transparent, 0px none, 9px solid transparent;
	background 		: transparent;
}
.VScrollIndicatorControl .trackbar
{
	border-radius 		: 8px;
	background 		: #b2b2b2;
}
.VScrollIndicatorControl .trackbar[userstatus=pushed]
{
	background 		: #aaaaaa;
}
.HScrollIndicatorControl
{
	-nexa-border 		: 6px solid transparent, 0px none, 9px solid transparent, 0px none;
	background 		: transparent;
}
.HScrollIndicatorControl .trackbar
{
	border-radius 		: 8px;
	background 		: #b2b2b2;
}

.HScrollIndicatorControl .trackbar[userstatus=pushed]
{
	background 		: #aaaaaa;
}
/************************************************************************/
/********************** FRAME END **/
/************************************************************************/

/************************************************************************/
/********************** BASE COMPONENT START **/
/************************************************************************/
/***** Button *****/
.Button
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px 10px 1px 10px;
	background 		: #1E5DF2;
	border-radius 		: 6px;
	color 			: #ffffff;
	cursor 			: pointer;
	font 			: normal 400 24px "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button[status=focused]
{
	-nexa-border 		: 2px solid #222222;
	-nexa-padding 		: 0px 9px 1px 9px;
}
.Button[status=mouseover]
{
	-nexa-text-decoration 	: underline;
	-nexa-padding 		: 0px 9px 1px 9px;
	background 		: #6e99ff;
	color 			: #ffffff;
}
.Button[userstatus=pushed]
{
	background 		: #6e99ff;
	color 			: #ffffff;
}
.Button[status=disabled]
{
	background 		: #c8cdd7;
	color 			: #ffffff;
}
.Button.btn_WF_Big
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px 30px 1px 30px;
	background 		: #1E5DF2;
	border-radius 		: 6px;
	color 			: #ffffff;
	cursor 			: pointer;
	font 			: normal 400 28px "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_WF_Big[status=focused]
{
	-nexa-border 		: 2px solid #2a3b64;
	-nexa-padding 		: 0px 29px 1px 29px;
}
.Button.btn_WF_Big[status=mouseover]
{
	-nexa-text-decoration 	: underline;
	-nexa-padding 		: 0px 29px 1px 29px;
	background 		: #6e99ff;
	color 			: #ffffff;
}
.Button.btn_WF_Big[userstatus=pushed]
{
	background 		: #6e99ff;
	color 			: #ffffff;
}
.Button.btn_WF_Big[status=disabled]
{
	background 		: #c8cdd7;
	color 			: #ffffff;
}
/***** Calendar *****/
.Calendar
{
	-nexa-border 		: 1px solid #6d7074;
	-nexa-padding 		: 1px;
	background 		: #ffffff;
	border-radius 		: 4px;
	color 			: #172f57;
}
.Calendar[status=mouseover]
{
	-nexa-border 		: 2px solid #6d7074;
	-nexa-padding 		: 0px;
	background 		: #ffffff;
}
.Calendar[status=focused]
{
	-nexa-border 		: 2px solid #2a3b64;
	-nexa-padding 		: 0px;
}
.Calendar[status=readonly]
{
	-nexa-border		: 1px solid #d4d6d8;
	background 		: #f5f5f5;
}
.Calendar[status=disabled]
{
	-nexa-border 		: 1px solid #d4d6d8;
	color 			: #aaaaaa;
}
.Calendar .calendaredit
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 10px 10px 10px 20px;
	color 			: #172f57;
}
.Calendar .calendaredit[status=mouseover],.Calendar .calendaredit[status=focused]
{
	-nexa-padding 		: 10px 10px 10px 20px;
}
.Calendar .calendaredit[status=readonly]
{

}
.Calendar .calendaredit[userstatus=nulltext]
{

}
.Calendar .calendaredit[status=disabled]
{
	color 			: #aaaaaa;
}
.Calendar .dropbutton,
.Calendar .dropbutton[status=mouseover],.Calendar .dropbutton[status=focused],
.Calendar .dropbutton[userstatus=pushed],.Calendar .dropbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/cal_WF_DropBtn.png");
	-nexa-padding 		: 0px 6px 0px 0px;
	cursor 			: pointer;
}
.Calendar .dropbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/cal_WF_DropBtnD.png");
}
.Calendar .calendarspindownbutton,
.Calendar .calendarspindownbutton[status=focused],.Calendar .calendarspindownbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/spin_WF_DownBtn.png");
	cursor 			: pointer;
}
.Calendar .calendarspindownbutton[status=mouseover]
{
	background 		: #ffffff;
}
.Calendar .calendarspindownbutton[userstatus=pushed]
{
	background 		: #ffffff;
}
.Calendar .calendarspindownbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/spin_WF_DownBtnD.png");
}
.Calendar .calendarspinupbutton,
.Calendar .calendarspinupbutton[status=focused],.Calendar .calendarspinupbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/spin_WF_UpBtn.png");
	cursor 			: pointer;	
}
.Calendar .calendarspinupbutton[status=mouseover]
{
	background 		: #ffffff;
}
.Calendar .calendarspinupbutton[userstatus=pushed]
{
	background 		: #ffffff;
}
.Calendar .calendarspinupbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/spin_WF_UpBtnD.png");
}
/***** CheckBox *****/
.CheckBox,
.CheckBox[status=readonly]
{
	-nexa-icon 		: URL("theme://images/chk_WF_Box.png");
	-nexa-border 		: 2px solid transparent;
	-nexa-text-padding 	: 0px 5px 0px 16px;
	color 			: #172f57;	
}
.CheckBox[status=focused]
{
	-nexa-border	 	: 2px solid #172f57;
	-nexa-text-decoration 	: none;
}
.CheckBox[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/chk_WF_BoxS.png");
}
.CheckBox[status=disabled]
{
	-nexa-icon 		: URL("theme://images/chk_WF_BoxD.png");
	color			: #999999;
}
.CheckBox[status=disabled][userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/chk_WF_BoxSD.png");
}
/***** Combo *****/
.Combo
{
	-nexa-border 		: 1px solid #6d7074;
	-nexa-padding 		: 0px 0px 1px 20px;	
	background 		: #ffffff;
	border-radius 		: 4px;
	color 			: #172f57;
}
.Combo[status=mouseover]
{
	-nexa-border 		: 2px solid #6d7074;
	-nexa-padding 		: 0px 0px 1px 19px;	
}
.Combo[status=focused]
{
	-nexa-border 		: 2px solid #2a3b64;
	-nexa-padding 		: 0px 0px 1px 19px;	
}
.Combo[status=readonly]
{
	-nexa-border		: 1px solid #d4d6d8;
	background 		: #f5f5f5;
}
.Combo[status=disabled]
{
	-nexa-border 		: 1px solid #d4d6d8;
	color 			: #aaaaaa;
}
.Combo .comboedit
{
	-nexa-border 		: 0px none;
}
.Combo .comboedit[status=mouseover],.Combo .comboedit[status=focused]
{
	-nexa-border 		: 0px none;
}
.Combo .comboedit[status=disabled],.Combo .comboedit[userstatus=nulltext]
{
	color 			: #aaaaaa;
}
.Combo .comboedit[status=readonly]
{
	background 		: #f5f5f5;
}
.Combo .dropbutton,
.Combo .dropbutton[status=focused],.Combo .dropbutton[userstatus=selected]
{
	-nexa-icon 		: url('theme://images/btn_WF_DropDown.png');
	cursor 			: pointer;
}
.Combo .dropbutton[status=mouseover]
{
	background 		: #ffffff;
}
.Combo .dropbutton[userstatus=pushed]
{
	background 		: #ffffff;
}
.Combo .dropbutton[status=disabled]
{	
	-nexa-icon 		: URL("theme://images/btn_WF_DropDownD.png");
}
.Combo .combolist,
.Combo .combolist[status=mouseover],.Combo .combolist[status=focused],
.Combo .combolist[status=readonly],.Combo .combolist[status=disabled]
{
	-nexa-border 		: 1px solid #646982;
	background 		: #ffffff;
}
.Combo .combolist .listboxitem,
.Combo .combolist .listboxitem[status=focused],.Combo .combolist .listboxitem[status=readonly],
.Combo .combolist .listboxitem[status=disabled]
{
	-nexa-padding 		: 10px 20px 10px 20px;
	color 			: #172f57;
	font 			: normal 400 24px "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Combo .combolist .listboxitem[status=mouseover]
{
	background 		: #f4f5f8; 
}
.Combo .combolist .listboxitem[userstatus=selected]
{
	background 		: #eef6ff;
}
/* DatePickerControl */
.DatePickerControl
{
	-nexa-border 		: 1px solid #646982;
	background 		: #ffffff;
}
.DatePickerControl .head,
.DatePickerControl .head[status=mouseover],.DatePickerControl .head[status=focused],
.DatePickerControl .head[status=readonly],.DatePickerControl .head[status=disabled]
{
	background 		: #ffffff;
	color 			: #333333;
	font 			: normal 700 24px "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";
}
.DatePickerControl .head .prevbutton
{
	-nexa-padding 		: 0px 0px 0px 10px;
	-nexa-icon 		: URL('theme://images/btn_WF_Calprev.png');
}
.DatePickerControl .head .prevbutton[status=mouseover]
{
	-nexa-icon 		: URL('theme://images/btn_WF_Calprev_O.png');
}
.DatePickerControl .head .prevbutton[userstatus=pushed]
{
	-nexa-icon 		: URL('theme://images/btn_WF_Calprev_O.png');
}
.DatePickerControl .head .prevbutton[status=disabled]
{
	-nexa-icon 		: URL('theme://images/btn_WF_Calprev.png');
}
.DatePickerControl .head .nextbutton
{
	-nexa-padding 		: 0px 10px 0px 0px;
	-nexa-icon 		: URL('theme://images/btn_WF_Calnext.png');
}
.DatePickerControl .head .nextbutton[status=mouseover]
{
	-nexa-icon 		: URL('theme://images/btn_WF_Calnext_O.png');
}
.DatePickerControl .head .nextbutton[userstatus=pushed]
{
	-nexa-icon 		: URL('theme://images/btn_WF_Calnext_O.png');
}
.DatePickerControl .head .nextbutton[status=disabled]
{
	-nexa-icon 		: URL('theme://images/btn_WF_Calnext.png');
}
.DatePickerControl .head .yearstatic,.DatePickerControl .head .monthstatic
{
	-nexa-padding 		: 0px 10px 0px 0px;	
	font 			: bold 14px "Tahoma";
	color 			: #ffffff;
}
.DatePickerControl .head .yearstatic[status=disabled]
{
	color 			: #c7d4e2;
}
.DatePickerControl .head .monthstatic[status=disabled]
{
	color			: #c7d4e2;
}
.DatePickerControl .head .yearspin .spinedit,.DatePickerControl .head .monthspin .spinedit
{
	font 			: bold 14px "Tahoma";
	color 			: #ffffff;
	background 		: #0042a0;
}
.DatePickerControl .head .yearspin .spinupbutton,.DatePickerControl .head .monthspin .spinupbutton
{
	-nexa-padding 		: 0px 10px 0px 5px;
	-nexa-icon 		: URL('theme://images/btn_WF_Calspinup.png');
}
.DatePickerControl .head .yearspin .spinupbutton[status=mouseover],
.DatePickerControl .head .monthspin .spinupbutton[status=mouseover]
{
	-nexa-icon 		: URL('theme://images/btn_WF_Calspinup_O.png');
}
.DatePickerControl .head .yearspin .spinupbutton[userstatus=pushed],
.DatePickerControl .head .monthspin .spinupbutton[userstatus=pushed]
{
	-nexa-icon 		: URL('theme://images/btn_WF_Calspinup_O.png');
}
.DatePickerControl .head .yearspin .spinupbutton[status=disabled],
.DatePickerControl .head .monthspin .spinupbutton[status=disabled]
{
	-nexa-icon 		: URL('theme://images/btn_WF_Calspinup_D.png');
}
.DatePickerControl .head .yearspin .spindownbutton,
.DatePickerControl .head .monthspin .spindownbutton
{
	-nexa-padding 		: 0px 10px 0px 5px;
	-nexa-icon 		: URL('theme://images/btn_WF_Calspindown.png');
}
.DatePickerControl .head .yearspin .spindownbutton[status=mouseover],
.DatePickerControl .head .monthspin .spindownbutton[status=mouseover]
{
	-nexa-icon 		: URL('theme://images/btn_WF_Calspindown_O.png');
}

.DatePickerControl .head .yearspin .spindownbutton[userstatus=pushed],
.DatePickerControl .head .monthspin .spindownbutton[userstatus=pushed]
{
	-nexa-icon 		: URL('theme://images/btn_WF_Calspindown_O.png');
}
.DatePickerControl .head .yearspin .spindownbutton[status=disabled],
.DatePickerControl .head .monthspin .spindownbutton[status=disabled]
{
	-nexa-icon 		: URL('theme://images/btn_WF_Calspindown_D.png');
}
.DatePickerControl .body
{
	-nexa-border 		: 1px solid #125dae, 1px solid #697888, 1px solid #697888, 1px solid #697888;
}
.DatePickerControl .body[status=disabled]
{
	-nexa-border 		: 1px solid #98a6b5;
}
.DatePickerControl .body .weekband
{
	background 		: #125dae;
}
.DatePickerControl .body .weekband[status=disabled]
{
	background 		: #94a9bf;
}
.DatePickerControl .body .weekitem
{
	color 			: #ffffff;
}
.DatePickerControl .body .weekitem[userstatus=saturday]
{
	color 			: #48afff;
}
.DatePickerControl .body .weekitem[userstatus=sunday]
{
	color 			: #ff7986;
}
.DatePickerControl .body .weekitem[status=disabled]
{
	color 			: #c7d4e2;
	background 		: #94a9bf;
}
.DatePickerControl .body .dayitem
{
	color 			: #333333;
}
.DatePickerControl .body .dayitem[status=mouseover]
{
	color 			: #ffffff;
	background 		: #8da3c7;
}
.DatePickerControl .body .dayitem[status=focused]
{
	color 			: #ffffff;
	background		: #125dae;
}
.DatePickerControl .body .dayitem[userstatus=selected]
{
	color 			: #ffffff;
	background 		: #125dae;
}
.DatePickerControl .body .dayitem[userstatus=today]
{
	color 			: #ffffff;
	background 		: #e7595c;
}
.DatePickerControl .body .dayitem[userstatus=saturday]
{
	color 			: #269bee;
}
.DatePickerControl .body .dayitem[status=mouseover][userstatus=saturday]
{
	color 			: #ffffff;
}
.DatePickerControl .body .dayitem[userstatus=sunday]
{
	color 			: #ff4c5e;
}
.DatePickerControl .body .dayitem[status=mouseover][userstatus=sunday]
{
	color 			: #ffffff;
}
.DatePickerControl .body .dayitem[userstatus=trailingday]
{
	color 			: #989898;
}
.DatePickerControl .body .dayitem[status=mouseover][userstatus=trailingday]
{
	color 			: #ffffff;
}
.DatePickerControl .body .dayitem[status=disabled]
{
	color 			: #cdcdcd;
}
.DatePickerControl .body .dayitem[status=disabled][userstatus=selected]
{
	background 		: #f0f0f0;
}
/***** Div *****/
.Div,
.Div[status=focused],.Div[status=disabled]
{
	background 		: transparent;
}
/***** Edit *****/
.Edit
{
	-nexa-border 		: 1px solid #6d7074;
	-nexa-padding 		: 10px 20px 10px 20px;
	background 		: #ffffff;
	border-radius 		: 4px;
	color 			: #172f57;
}
.Edit[status=mouseover]
{
	-nexa-border 		: 2px solid #6d7074;
	-nexa-padding 		: 10px 19px 10px 19px;
}
.Edit[status=focused]
{
	-nexa-border 		: 2px solid #2a3b64;
	-nexa-padding 		: 9px 19px 9px 19px;
}
.Edit[status=readonly]
{
	-nexa-border		: 1px solid #d4d6d8;
	background 		: #f5f5f5;
}
.Edit[userstatus=nulltext]
{
	color          		: #757575;
}
.Edit[status=disabled]
{
	-nexa-border 		: 1px solid #d4d6d8;
	color 			: #aaaaaa;
}
/***** FileDownload *****/
.FileDownload
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 1px 20px 1px 20px;
	-nexa-icon 		: URL("theme://images/btn_WF_FileDownload.png");
	-nexa-text-padding 	: 0px 0px 1px 15px;
	background 		: #2a3b64;
	border-radius 		: 4px;
	color 			: #ffffff;
	font 			: normal 700 24px "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";
	cursor 			: pointer;
}
.FileDownload[status=focused]
{
	-nexa-border 		: 2px solid #1E5DF2;
	-nexa-padding 		: 0px 19px 0px 19px;
}
.FileDownload[status=mouseover]
{
	background 		: #4162b2;
	-nexa-text-decoration	: underline;
}
.FileDownload[userstatus=pushed]
{
	background 		: #4162b2;
}
.FileDownload[status=disabled]
{
	background		: #c8cdd7;
}
/***** FileUpload *****/
.FileUpload,.FileUpload[status=mouseover],.FileUpload[userstatus=selected],
.FileUpload[status=disabled]
{
	-nexa-border 		: 2px solid transparent;
}
.FileUpload[status=focused]
{
	-nexa-border 		: 2px solid #2a3b64;
}
.FileUpload .fileuploaditem,
.FileUpload .fileuploaditem[status=focused],.FileUpload .fileuploaditem[status=disabled]
{
	-nexa-border 		: 0px none;
}
