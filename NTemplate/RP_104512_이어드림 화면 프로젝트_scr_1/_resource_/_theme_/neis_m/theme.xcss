.Div.div_Login_Notice01_M[status=disabled], .Div.div_Login_Notice01_M[status=focused],
.Div.div_Login_Notice01_M[status=mouseover]
{
	-nexa-border 		: 1px solid #dddddd;
	background 		: #ffffff;
	border-radius 		: 14px;
}
.Div.div_Login_Notice02_M,
.Div.div_Login_Notice02_M[status=disabled], .Div.div_Login_Notice02_M[status=focused],
.Div.div_Login_Notice02_M[status=mouseover]
{
	background 		: #f6f6f6;
	border-radius 		: 14px;
}
/* event Popup */
.Button.btn_Pop_yes01_M,.Button.btn_Pop_yes01_M[status=disabled]
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 10px 1px 10px;
	border-radius 		: 16px;
	background 		: #2b72de;
	color 			: #ffffff;
	font 			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_Pop_yes01_M[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 10px 1px 10px;
}
.Button.btn_Pop_yes01_M[status=mouseover],
.Button.btn_Pop_yes01_M[userstatus=pushed]
{
	background 		: #1A56B2;
	color 			: #ffffff;
}
.Static.sta_Notice_bg,.Static.sta_Notice_bg[status=mouseover]
{
	background 		: #f5f5f5;
	border-radius 		: 20px;
}
.Static.sta_Notice_bg01_M,.Static.sta_Notice_bg01_M[status=mouseover]
{
	-nexa-text-align 	: center;
