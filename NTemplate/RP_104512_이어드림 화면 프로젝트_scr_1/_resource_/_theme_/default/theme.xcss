{
	-nexa-icon : URL("theme://images/rdo_WF_RadioO.png");
}
.Radio .radioitem[userstatus=selected]
{
	-nexa-icon : URL("theme://images/rdo_WF_RadioS.png");
	-nexa-text-decoration : underline;
}
