{
	-nexa-icon : URL("theme://images/rdo_WF_RadioS.png");
	-nexa-text-decoration : underline;
}
.Radio .radioitem[status=disabled]
{
	-nexa-icon : URL("theme://images/rdo_WF_RadioD.png");
	color : #999999;
}
.Radio .radioitem[status=disabled][userstatus=selected]
{
	-nexa-icon : URL("theme://images/rdo_WF_RadioDS.png");
	color : #999999;
}


