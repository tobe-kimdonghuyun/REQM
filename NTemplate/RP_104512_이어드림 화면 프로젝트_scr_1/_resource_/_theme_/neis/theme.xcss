/* CheckBox White */
.CheckBox.chk_white
{
	-nexa-icon 		: URL("theme://images/chk_WF_box_W.png");
	-nexa-border 		: 1px solid transparent;
	-nexa-text-padding 	: 0px 10px 0px 8px;
	-nexa-text-align 	: center;
	color 			: #ffffff;	
}
.CheckBox.chk_white[status=focused]
{
	-nexa-icon 		: URL("theme://images/chk_WF_box_W.png");
	-nexa-border	 	: 1px dashed #ffffff;
	border-radius 		: 7px;
}
.CheckBox.chk_white[status=readonly]
{
	-nexa-icon 		: URL("theme://images/chk_WF_boxD_W.png");
	color 			: #d9d9d9;	
}
.CheckBox.chk_white[status=mouseover]
{
	-nexa-icon 		: URL("theme://images/chk_WF_boxO_W.png");
}
.CheckBox.chk_white[status=mouseover][userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/chk_WF_boxSO_W.png");
}
.CheckBox.chk_white[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/chk_WF_boxS_W.png");
}
.CheckBox.chk_white[status=disabled]
{
	-nexa-icon 		: URL("theme://images/chk_WF_boxD_W.png");
	color 			: #d9d9d9;		
}
.CheckBox.chk_white[status=disabled][userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/chk_WF_boxDS_W.png");
	color 			: #d9d9d9;	
}
