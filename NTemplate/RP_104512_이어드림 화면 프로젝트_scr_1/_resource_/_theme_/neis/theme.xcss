	-nexa-text-align	: left;
}
.Button.btn_LNB_menu[status=focused]
{
	-nexa-border 		: 1px dashed #000000;
	-nexa-padding 		: 0px 19px 1px 19px;
	background 		: transparent;	
}
.Button.btn_LNB_menu[status=mouseover],.Button.btn_LNB_menu[userstatus=pushed]
{
	-nexa-border 		: 1px solid transparent;
	-nexa-padding 		: 0px 19px 1px 19px;
	background 		: transparent;
	color 			: #2b72de;
}
.Button.btn_LNB_menu[status=disabled]
{
	-nexa-border 		: 1px solid transparent;
	background 		: transparent;
}
