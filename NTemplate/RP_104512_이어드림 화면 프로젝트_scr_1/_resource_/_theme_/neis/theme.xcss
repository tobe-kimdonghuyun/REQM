.Button.btn_BF_SurveyGo01
{
	-nexa-border 		: 2px solid transparent;
	-nexa-text-align 	: left;
	-nexa-padding 		: 0px 10px;
	background 		: url('theme://images/btn_arrow_w02.png') no-repeat right center #f2f4f8;		
