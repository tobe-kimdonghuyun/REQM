/************************************************************************/
/********************** BASE COMPONENT START **/
/************************************************************************/
/***** Button *****/
.Button,
.Button[userstatus=selected]
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px 12px 1px 12px;
	background 		: #1E5DF2;
	border-radius 		: 4px;
	color 			: #ffffff;
	cursor 			: pointer;
	font 			: normal 400 13px "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic"; 	
}
.Button[status=focused]
{
	-nexa-border 		: 2px solid #222222;
	-nexa-padding 		: 0px 10px 1px 10px;
}
.Button[status=mouseover],.Button[userstatus=pushed]
{
	-nexa-text-decoration 	: underline;
	background 		: #6e99ff;
	color 			: #ffffff;
}
.Button[status=disabled]
{
	background 		: #c8cdd7;
	color 			: #ffffff;
	cursor 			: default;
}
/***** Calendar *****/
.Calendar
{
	-nexa-border 		: 1px solid #6d7074;
	-nexa-padding 		: 1px;
	background 		: #ffffff;
	border-radius 		: 4px;
	color 			: #172f57;
}
.Calendar[status=mouseover]
{
	-nexa-border 		: 2px solid #6d7074;
	-nexa-padding 		: 0px;
	background 		: #ffffff;
}
.Calendar[status=focused]
{
	-nexa-border 		: 2px solid #2a3b64;
	-nexa-padding 		: 0px;
}
.Calendar[status=readonly]
{
	-nexa-border		: 1px solid #d4d6d8;
	background 		: #f5f5f5;
}
.Calendar[status=disabled]
{
	-nexa-border 		: 1px solid #d4d6d8;
	color 			: #aaaaaa;
}
.Calendar .calendaredit
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px 10px 1px 10px;
	color 			: #172f57;
}
.Calendar .calendaredit[status=mouseover],.Calendar .calendaredit[status=focused]
{
	-nexa-padding 		: 0px 10px 1px 10px;
}
.Calendar .calendaredit[status=readonly]
{

}
.Calendar .calendaredit[userstatus=nulltext]
{

}
.Calendar .calendaredit[status=disabled]
{
	color 			: #aaaaaa;
}
.Calendar .dropbutton,
.Calendar .dropbutton[status=mouseover],.Calendar .dropbutton[status=focused],
.Calendar .dropbutton[userstatus=pushed],.Calendar .dropbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/cal_WF_DropBtn.png");
	-nexa-padding 		: 0px 6px 0px 0px;
	cursor 			: pointer;
}
.Calendar .dropbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/cal_WF_DropBtnD.png");
}
.Calendar .calendarspindownbutton,
.Calendar .calendarspindownbutton[status=focused],.Calendar .calendarspindownbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/spin_WF_DownBtn.png");
	cursor 			: pointer;
}
.Calendar .calendarspindownbutton[status=mouseover]
{
	background 		: #ffffff;
}
.Calendar .calendarspindownbutton[userstatus=pushed]
{
	background 		: #ffffff;
}
.Calendar .calendarspindownbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/spin_WF_DownBtnD.png");
}
.Calendar .calendarspinupbutton,
.Calendar .calendarspinupbutton[status=focused],.Calendar .calendarspinupbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/spin_WF_UpBtn.png");
