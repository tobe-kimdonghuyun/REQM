{
	background 		: #ffffff;
	color 			: #2b72de;
}
.Combo.cbo_LNB_N .combolist .listboxitem[status=disabled],.Combo.cbo_LNB_O .combolist .listboxitem[status=disabled],
.Combo.cbo_LNB_F .combolist .listboxitem[status=disabled]
