{
	background : #f5f5f5;
	border-radius : 12px;
}
/* LNB Section Divider Line */
.Static.sta_LNB_sectionLine,
.Static.sta_LNB_sectionLine[status=disabled], .Static.sta_LNB_sectionLine[status=mouseover]
{
	background 		: url('theme://images/bg_LNB_line.png') no-repeat left center transparent;
}
/* LNB Home(icon+text) Button */
.Button.btn_LNB_home
{
	-nexa-border 		: 1px solid transparent;
	-nexa-padding 		: 0px 7px 1px 7px;
	background 		: transparent;
	color 			: #222222;
	font 			: normal 500 18px/normal "Noto Sans KR Medium","NotoSansKR-Medium","Arial","MS PGothic";
	-nexa-icon		: url('theme://images/icon_LNB_home.png');
	-nexa-text-padding	: 0px 0px 0px 14px;
	-nexa-icon-position	: left;
	-nexa-text-align	: left;
}
.Button.btn_LNB_home[status=focused]
{
	-nexa-border 		: 1px dashed #000000;
	-nexa-padding 		: 0px 7px 1px 7px;
	background 		: transparent;	
}
.Button.btn_LNB_home[status=mouseover],.Button.btn_LNB_home[userstatus=pushed]
{
	-nexa-border 		: 1px solid transparent;
	-nexa-icon		: url('theme://images/icon_LNB_home_O.png');	
	background 		: transparent;
	color 			: #2b72de;
}
.Button.btn_LNB_home[status=disabled]
{
	-nexa-border 		: 1px solid transparent;
	background 		:  transparent;
}
