	color 			: #595959;
}
.Edit.edi_Login_Pass
{
	-nexa-border 		: 1px solid #d9d9d9;
	-nexa-padding 		: 0px 20px 1px 50px;
	background 		: URL('theme://images/ic_Login_pwd.png') no-repeat left center #ffffff; 
	border-radius 		: 6px;
	color 			: #595959;
	font 			: normal 500 14px/normal "Noto Sans KR Medium","NotoSansKR-Medium","Arial","MS PGothic";
}
.Edit.edi_Login_Pass[status=mouseover],
.Edit.edi_Login_Pass[status=readonly],.Edit.edi_Login_Pass[status=disabled]
{
	-nexa-border 		: 1px solid #222222;
	-nexa-padding 		: 0px 20px 1px 50px;	
}
.Edit.edi_Login_Pass[status=focused]
{
	-nexa-border 		: 1px solid #222222;
	-nexa-padding 		: 0px 20px 1px 50px;		
}
.Edit.edi_Login_Pass[userstatus=nulltext]
{
	color 			: #595959;
}
/* Noraml Edit */
.Edit.edi_Login_Normal
{
	-nexa-border 		: 1px solid #d9d9d9;
	-nexa-padding 		: 0px 20px 1px 20px;
	background 		: #ffffff;
	border-radius 		: 6px;
	color 			: #595959;
	font 			: normal 500 14px/normal "Noto Sans KR Medium","NotoSansKR-Medium","Arial","MS PGothic";
}
.Edit.edi_Login_Normal[status=mouseover],.Edit.edi_Login_Normal[status=focused]
{
	-nexa-border 		: 1px solid #222222;
	-nexa-padding 		: 0px 20px 1px 20px;
}
.Edit.edi_Login_Normal[status=readonly]
{
	-nexa-border		: 1px solid #d9d9d9;
	background 		: #f5f5f5;
}
.Edit.edi_Login_Normal[userstatus=nulltext]
{
	color          		: #595959;
}
.Edit.edi_Login_Normal[status=disabled]
{
	-nexa-border 		: 1px solid #d9d9d9;
	color 			: #d9d9d9;
}
