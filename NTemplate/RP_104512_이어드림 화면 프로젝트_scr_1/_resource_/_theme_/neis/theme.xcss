}
/* display */
.ImageViewer.display,
.ImageViewer.display[status=mouseover],.ImageViewer.display[status=disabled]
{
	-nexa-border 		: 0px none;
	-nexa-padding : 2px;
	border-radius 		: 0px;
	background	 	: transparent;
}
.ImageViewer.display[status=focused]
{
	-nexa-border 		: 2px solid #2a3b64;
	-nexa-padding : 0px;	
	border-radius 		: 4px;
}
.ImageViewer.display01,
.ImageViewer.display01[status=mouseover],.ImageViewer.display01[status=disabled]
{
	-nexa-border 		: 2px solid transparent;
	border-radius 		: 0px;
	background	 	: transparent;
}
.ImageViewer.display01[status=focused]
{
	-nexa-border 		: 2px solid #2a3b64;
	border-radius 		: 4px;
}
