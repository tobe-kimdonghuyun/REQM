{
	-nexa-icon 		: URL("theme://images/chk_WF_MainAgrS.png");
}
.CheckBox.chk__WF_MainAgr[status=mouseover]
{
	-nexa-icon 		: URL("theme://images/chk_WF_MainAgrO.png");
	-nexa-text-decoration 	: underline;
}
