.Button.btn_WF_Crud
{
	-nexa-text-align	: center;
	-nexa-padding 		: 0px 12px 1px 12px;
	background 		: #2a3b64;
	border-radius 		: 4px;
	color 			: #ffffff;
	font 			: normal 400 13px "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_WF_Crud[status=focused]
{
	-nexa-border 		: 2px solid #1E5DF2;
}
