.Combo.cbo_LNB_O .combolist,
.Combo.cbo_LNB_F .combolist
{
	-nexa-border 		: 13px solid transparent,0px none, 0px none;
	background 		: #f5f5f5;
	border-radius 		: 0px;
}
.Combo.cbo_LNB_N .combolist .listboxitem,.Combo.cbo_LNB_N .combolist .listboxitem[status=readonly],
.Combo.cbo_LNB_O .combolist .listboxitem,.Combo.cbo_LNB_O .combolist .listboxitem[status=readonly],
.Combo.cbo_LNB_F .combolist .listboxitem,.Combo.cbo_LNB_F .combolist .listboxitem[status=readonly]
{
	-nexa-border 		: 0px none,0px none,1px solid #d9d9d9;
	-nexa-padding 		: 16px 1px 18px 20px;
	background 		: #eaeaea;	
	color 			: #222222;
	font 			: normal 500 18px/normal "Noto Sans KR Medium","NotoSansKR-Medium","Arial","MS PGothic";
	-nexa-vertical-align 	: middle;
}
.Combo.cbo_LNB_N .combolist .listboxitem[status=mouseover],.Combo.cbo_LNB_N .combolist .listboxitem[status=focused],
.Combo.cbo_LNB_O .combolist .listboxitem[status=mouseover],.Combo.cbo_LNB_O .combolist .listboxitem[status=focused],
.Combo.cbo_LNB_F .combolist .listboxitem[status=mouseover],.Combo.cbo_LNB_F .combolist .listboxitem[status=focused]
{
	background 		: #f5f5f5;
}
