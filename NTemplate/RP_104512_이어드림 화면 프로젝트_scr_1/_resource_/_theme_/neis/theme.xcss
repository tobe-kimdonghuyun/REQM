	background 		: url('theme://images/ico_WF_FAQ.png') no-repeat left center;
	color			: #333333;
	cursor			: pointer;
	font			: normal 700 14px/1.5 "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";
}
