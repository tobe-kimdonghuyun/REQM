.Grid.grd_MF_Notice .body .row .cell .cellbutton.cell_MF_TxtLinkNew[userstatus=selected],.Grid.grd_MF_Notice .body .row .cell.cell_MF_TxtLinkNew .cellbutton[userstatus=pushed]
