/***************************************************************************/
/*******************    MENU FRAME START        ********************/
/***************************************************************************/
/* Button */
.Button.btn_MNU_Item
{
    -nexa-border        : 0px none;
    -nexa-text-align    : left;
    -nexa-padding       : 0px 16px 0px 16px;
    -nexa-word-wrap     : char;
    background      : transparent;
    color           : #333333;
    font            : 400 18px "pre","Pretendard-Regular";
    letter-spacing      : -1px;
}
.Button.btn_MNU_Item[status=mouseover],.Button.btn_MNU_Item[userstatus=pushed],
.Button.btn_MNU_Item[userstatus=selected]
{
    -nexa-border        : 0px none;
    -nexa-text-decoration   : underline;
    background      : transparent;
}
.Button.btn_MNU_Item[status=focused]
{
    background      : transparent;
}
.Button.btn_MNU_Guide
{
    -nexa-border        : 0px none;
    -nexa-icon      : url("theme://images/btn_TF_Guide.svg");
    -nexa-text-padding  : 0px 0px 0px 10px;
    background      : #EEF2F7;
    border-radius       : 8px;
    color           : #323232;
    font            : 500 16px "pre","Pretendard-Medium";
}
.Button.btn_MNU_Guide[status=mouseover],.Button.btn_MNU_Guide[userstatus=pushed],
.Button.btn_MNU_Guide[userstatus=selected]
{
    background      : #D6E0EB;
}
/* Grid */
.Grid.grd_MNU_Menu
{
    -nexa-border        : 0px none;
}
.Grid.grd_MNU_Menu .body .row .cell
{
    -nexa-border        : 0px none;
    -nexa-padding       : 0px;
    color           : #000000;
    font            : 400 17px "pre","Pretendard-Regular";
}
.Grid.grd_MNU_Menu .body .row .cell[status=mouseover],.Grid.grd_MNU_Menu .body .row .cell[userstatus=selected],
.Grid.grd_MNU_Menu .body .row .cell[status=focused],.Grid.grd_MNU_Menu .body .row .cell[status=focused][userstatus=selected]
{
    background      : transparent;
}
.Grid.grd_MNU_Menu .body .row .cell .celltreeitem[status=focused]
{
    -nexa-border        : 2px dashed #000000;
    border-radius       : 4px;
}
.Grid.grd_MNU_Menu .body .row .cell .celltreeitem .treeitemtext[status=mouseover]
{
    -nexa-text-decoration   : underline;
}
.Grid.grd_MNU_Menu .body .row .cell.cell_MNU_1Depth .celltreeitem
{
    -nexa-border        : 0px none, 0px none, 1px solid #8A949E, 0px none;
    font            : 700 19px "pre","Pretendard-Bold";
}
.Grid.grd_MNU_Menu .body .row .cell.cell_MNU_1DepthO .celltreeitem
{
    -nexa-border        : 0px none, 0px none, 1px solid #8A949E, 0px none;
    background      : url("theme://images/cell_MNU_Open.svg") no-repeat right center;
    font            : 700 19px "pre","Pretendard-Bold";
}
.Grid.grd_MNU_Menu .body .row .cell.cell_MNU_1DepthC .celltreeitem
{
    -nexa-border        : 0px none, 0px none, 1px solid #8A949E, 0px none;
    background      : url("theme://images/cell_MNU_Close.svg") no-repeat right center;
    font            : 700 19px "pre","Pretendard-Bold";
}
/* Static */
.Static.sta_MNU_Title
{
    -nexa-text-align    : center;
    -nexa-vertical-align    : top;
    color           : #000000;
    font            : 500 23px "pre","Pretendard-Medium";
