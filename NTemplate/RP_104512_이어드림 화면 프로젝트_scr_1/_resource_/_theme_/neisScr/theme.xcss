    background      : #FFFFFF;
    border-radius       : 40px;
    color           : #000000;
    cursor          : pointer;
    font            : 500 17px "pre","Pretendard-Medium";
}
/* TextArea */
.TextArea.txt_WF_Output
{
    -nexa-border        : 0px none;
    -nexa-padding       : 0px;
    background      : #ffffff;
    border-radius       : 4px;
}
.TextArea.txt_WF_Output[status=mouseover]
{
    -nexa-border        : 0px none;
    background      : #ffffff;
}
.TextArea.txt_WF_Output[status=focused]
{
    -nexa-border        : 0px none;
}
.TextArea.txt_WF_Output[status=readonly]
{
    background      : #ffffff;
}
.TextArea.txt_WF_Output[userstatus=nulltext]
{
        color               : #888888;
}
.TextArea.txt_WF_Output[status=disabled]
{
    background      : #ffffff;
    color           : #888888;
}
