/*******************************************************************/
/*******************    FRAME START ****************************/
/*******************************************************************/
.TitleBarControl,
.TitleBarControl[status=deactivate],.TitleBarControl[status=disabled]
{
    background      : #413c3c;
}
.TitleBarControl .titleicon,
.TitleBarControl .titleicon[status=mouseover],.TitleBarControl .titleicon[status=deactivate],
.TitleBarControl .titleicon[status=disabled]
{
    -nexa-padding       : 0px 0px 0px 16px;
    color           : #ffffff;
    font            : bold 14px "Malgun Gothic";
}
.TitleBarControl .minbutton,
.TitleBarControl .minbutton[status=focused],.TitleBarControl .minbutton[userstatus=selected],
.TitleBarControl .minbutton[status=deactivate]
{
    -nexa-icon      : URL("theme://images/tib_WF_Min.png");
}
.TitleBarControl .minbutton[status=mouseover],.TitleBarControl .minbutton[userstatus=pushed]
{
    -nexa-icon      : URL("theme://images/tib_WF_MinO.png");
}
.TitleBarControl .minbutton[status=disabled]
{
    -nexa-icon      : URL("theme://images/tib_WF_MinD.png");
}
.TitleBarControl .maxbutton,
.TitleBarControl .maxbutton[status=focused],.TitleBarControl .maxbutton[userstatus=selected],
.TitleBarControl .maxbutton[status=deactivate]
{
    -nexa-icon      : URL("theme://images/tib_WF_Max.png");
}
.TitleBarControl .maxbutton[status=mouseover],.TitleBarControl .maxbutton[userstatus=pushed]
{
    -nexa-icon      : URL("theme://images/tib_WF_Max.png");
}
.TitleBarControl .maxbutton[status=disabled]
{
    -nexa-icon      : URL("theme://images/tib_WF_MaxD.png");
}
.TitleBarControl .normalbutton,
.TitleBarControl .normalbutton[status=focused],.TitleBarControl .normalbutton[userstatus=selected],
.TitleBarControl .normalbutton[status=deactivate]
{
    -nexa-icon      : URL("theme://images/tib_WF_Normal.png");
}
.TitleBarControl .normalbutton[status=mouseover],.TitleBarControl .normalbutton[userstatus=pushed]
{
    -nexa-icon      : URL("theme://images/tib_WF_NormalO.png");
}
.TitleBarControl .normalbutton[status=disabled]
{
    -nexa-icon      : URL("theme://images/tib_WF_NormalD.png");
}
.TitleBarControl .closebutton,
.TitleBarControl .closebutton[status=focused],.TitleBarControl .closebutton[userstatus=selected],
.TitleBarControl .closebutton[status=deactivate]
{
    -nexa-icon      : URL("theme://images/tib_WF_Close.png");
}
.TitleBarControl .closebutton[status=mouseover],.TitleBarControl .closebutton[userstatus=pushed]
{
    -nexa-icon      : URL("theme://images/tib_WF_CloseO.png");
}
.TitleBarControl .closebutton[status=disabled]
{
    -nexa-icon      : URL("theme://images/tib_WF_CloseD.png");
}
.HScrollBarControl,
.HScrollBarControl[status=mouseover]
{
    -nexa-border        : 1px solid #e1e2e7, 0px none, 0px none, 0px none;
    -nexa-padding       : 1px 1px 1px 1px;
    background      : #ffffff;
}
.HScrollBarControl[status=disabled]
{
    -nexa-border        : 0px none;
    background      : transparent;
    /*
    -nexa-border        : 1px solid #efefef, 0px none, 0px none, 0px none;
    background      : #f9f9f9;
    */
}
.HScrollBarControl .decbutton
{
    -nexa-icon      : URL("theme://images/btn_WF_Hdec.png");
}
.HScrollBarControl .decbutton[status=mouseover],.HScrollBarControl .decbutton[status=focused],
.HScrollBarControl .decbutton[userstatus=pushed],.HScrollBarControl .decbutton[userstatus=selected]
{
    -nexa-icon      : URL("theme://images/btn_WF_HdecO.png");
}
.HScrollBarControl .decbutton[status=disabled]
{
    /*-nexa-icon        : URL("theme://images/btn_WF_HdecD.png");*/
    -nexa-icon      : URL("theme://images/btn_WF_HdecDt.png");
}
.HScrollBarControl .incbutton
{
    -nexa-icon      : URL("theme://images/btn_WF_Hinc.png");
}
.HScrollBarControl .incbutton[status=disabled]
{
    /*-nexa-icon        : URL("theme://images/btn_WF_HincD.png");*/
    -nexa-icon      : URL("theme://images/btn_WF_HincDt.png");
}
.HScrollBarControl .incbutton[status=mouseover],.HScrollBarControl .incbutton[status=focused],
.HScrollBarControl .incbutton[userstatus=pushed],.HScrollBarControl .incbutton[userstatus=selected]
{
    -nexa-icon      : URL("theme://images/btn_WF_HincO.png");
}
.HScrollBarControl .trackbar,
.HScrollBarControl .trackbar[status=focused]
{
    background      : #dcdee2;
}
.HScrollBarControl .trackbar[status=mouseover]
{
    background      : #e9ebef;
}
.HScrollBarControl .trackbar[userstatus=pushed],.HScrollBarControl .trackbar[userstatus=selected]
{
    background      : #c0c1c5;
}
.HScrollBarControl .trackbar[status=disabled]
{
    background      : #e4e4e4;
}
.VScrollBarControl,
.VScrollBarControl[status=mouseover]
{
    -nexa-border        : 0px none, 0px none, 0px none, 1px solid #e1e2e7;
    -nexa-padding       : 1px 1px 1px 1px;
    background      : #ffffff;
}
.VScrollBarControl[status=disabled]
{
    -nexa-border        : 0px none;
    background      : transparent;
    /*
    -nexa-border        : 1px solid #efefef, 0px none, 0px none, 0px none;
    background      : #f9f9f9;
    */
}
.VScrollBarControl .decbutton
{
    -nexa-icon      : URL("theme://images/btn_WF_Vdec.png");
}
.VScrollBarControl .decbutton[status=mouseover],.VScrollBarControl .decbutton[status=focused],
.VScrollBarControl .decbutton[userstatus=pushed],.VScrollBarControl .decbutton[userstatus=selected]
{
    -nexa-icon      : URL("theme://images/btn_WF_VdecO.png");
}
.VScrollBarControl .decbutton[status=disabled]
{
    /*-nexa-icon        : URL("theme://images/btn_WF_VdecD.png");*/
    -nexa-icon      : URL("theme://images/btn_WF_VdecDt.png");
}
.VScrollBarControl .incbutton
{
    -nexa-icon      : URL("theme://images/btn_WF_Vinc.png");
}
.VScrollBarControl .incbutton[status=mouseover],.VScrollBarControl .incbutton[status=focused],
.VScrollBarControl .incbutton[userstatus=pushed],.VScrollBarControl .incbutton[userstatus=selected]
{
    -nexa-icon      : URL("theme://images/btn_WF_VincO.png");
}
.VScrollBarControl .incbutton[status=disabled]
{
    /*-nexa-icon        : URL("theme://images/btn_WF_VincD.png");*/
    -nexa-icon      : URL("theme://images/btn_WF_VincDt.png");
}
.VScrollBarControl .trackbar,
.VScrollBarControl .trackbar[status=focused]
{
    background      : #dcdee2;
}
.VScrollBarControl .trackbar[status=mouseover]
{
    background      : #e9ebef;
}
.VScrollBarControl .trackbar[userstatus=pushed],.VScrollBarControl .trackbar[userstatus=selected]
{
    background      : #c0c1c5;
}
.VScrollBarControl .trackbar[status=disabled]
{
    background      : #e4e4e4;
}
/* ScrollIndicatorControl */
.VScrollIndicatorControl,.HScrollIndicatorControl
{
    background      : transparent;
}

.VScrollIndicatorControl .trackbar,.HScrollIndicatorControl .trackbar,
.VScrollIndicatorControl .trackbar[userstatus=pushed],.HScrollIndicatorControl .trackbar[userstatus=pushed],
.VScrollIndicatorControl .trackbar[status=mouseover],.HScrollIndicatorControl .trackbar[status=mouseover]
{
    background      : rgba(0,0,0,0.30);
    border-radius       : 30px;
}
.Form
{
    -nexa-border        : 0px none;
    background      : #ffffff;
    color           : #222222;
    font            : 400 18px "pre","Pretendard-Regular";
}
.Form[userstatus=contents]
{
    background      : transparent;
}
.Form.frm_WF_Work .hscrollbar[status=disabled]
{
    -nexa-border        : 0px none;
    background      : transparent;
}
.Form.frm_WF_Work .hscrollbar .trackbar[status=disabled]
{
    background      : transparent;
}
.Form.frm_WF_Work .vscrollbar[status=disabled]
{
    -nexa-border        : 0px none;
    background      : transparent;
}
.Form.frm_WF_Work .vscrollbar .trackbar[status=disabled]
{
    background      : transparent;
}

.ChildFrame.frm_POP_Bg
{
    border-radius       : 12px;
}
.Form.frm_POP_Bg
{
    border-radius       : 12px;
}
/*******************************************************************/
/*******************    FRAME END   ****************************/
/*******************************************************************/

/***************************************************************************/
/*******************    BASE COMPONENT START    ****************************/
/***************************************************************************/
/***** Button *****/
.Button
{
    -nexa-border        : 1px solid #21409A;
    -nexa-padding       : 0px 20px 0px 20px;
    background      : #F2F5FF;
    border-radius       : 4px;
    cursor          : pointer;
    color           : #21409A;
    font            : 500 18px "pre","Pretendard-Medium";
}
.Button[status=focused]
{
    -nexa-border        : 2px dashed #121212;
}
.Button[status=mouseover],.Button[userstatus=pushed],
.Button[userstatus=selected]
{
    background      : #DBE3FE;
}
.Button[status=disabled]
{
    -nexa-border        : 1px solid #CCCCCC;
    background      : #F4F4F4;
    color           : #9A9A9A;
}

/***** Calendar *****/
.Calendar,
.CalendarControl
{
    -nexa-border        : 1px solid #A3A3A3;
    -nexa-padding       : 0px 5px 0px 0px;
    background      : #ffffff;
    border-radius       : 4px;
}
.Calendar[status=focused]
{
    -nexa-border        : 2px dashed #121212;
}
.Calendar[status=mouseover],.CalendarControl[status=mouseover],
.CalendarControl[status=focused]
{
    -nexa-border        : 1px solid #0097EF;
}
.Calendar[status=readonly],
.CalendarControl[status=readonly]
{
    background      : #EEEEEE;
}
.Calendar[status=disabled],
.CalendarControl[status=disabled]
{
    background      : #EEEEEE;
    color           : #888888;
}
.Calendar .calendaredit,
.Calendar .calendaredit[status=mouseover],.Calendar .calendaredit[status=focused],
.Calendar .calendaredit[status=readonly],.Calendar .calendaredit[status=disabled],
.CalendarControl .calendaredit,
.CalendarControl .calendaredit[status=mouseover],.CalendarControl .calendaredit[status=focused],
.CalendarControl .calendaredit[status=readonly],.CalendarControl .calendaredit[status=disabled]
{
    -nexa-border        : 0px none;
    -nexa-padding       : 0px 0px 0px 10px;
    background      : transparent;
}
.Calendar .calendaredit[userstatus=nulltext],
.CalendarControl .calendaredit[userstatus=nulltext]
{
    color               : #888888;
}
.Calendar .dropbutton,
.Calendar .dropbutton[status=focused],
.CalendarControl .dropbutton,
.CalendarControl .dropbutton[status=focused]
{
    -nexa-icon      : URL("theme://images/cal_WF_DropBtn.svg");
    cursor          : pointer;
}
.Calendar .dropbutton[status=disabled],
.CalendarControl .dropbutton[status=disabled]
{
    -nexa-icon      : URL("theme://images/cal_WF_DropBtnD.svg");
}
.Calendar .calendarspindownbutton,
.Calendar .calendarspindownbutton[status=focused]
{
    -nexa-icon      : ;
    cursor          : pointer;
}
.Calendar .calendarspindownbutton[status=disabled]
{
    -nexa-icon      : ;
}
.Calendar .calendarspinupbutton,
.Calendar .calendarspinupbutton[status=focused]
{
    -nexa-icon      : ;
    cursor          : pointer;
}
.Calendar .calendarspinupbutton[status=disabled]
{
    -nexa-icon      : ;
}
/***** DatePickerControl *****/
.DatePickerControl
{
    -nexa-border        : 1px solid #C6C6C6 ;
    background      : #ffffff;
    border-radius       : 12px;
}
.DatePickerControl .head
{
    background      : #ffffff;
    color           : #333333;
    font            : 600 20px "pre","Pretendard-SemiBold";
    letter-spacing      : -1px;
}
.DatePickerControl .head .prevbutton,
.DatePickerControl .head .prevbutton[status=mouseover],.DatePickerControl .head .prevbutton[userstatus=pushed],
.DatePickerControl .head .prevbutton[userstatus=selected]
{
    -nexa-icon      : URL("theme://images/cal_WF_PreBtn.svg");
    cursor          : pointer;
}
.DatePickerControl .head .prevbutton[status=focused]
{
    -nexa-border        : 2px dashed #000000;
}
.DatePickerControl .head .prevbutton[status=disabled]
{
    opacity         : 0.5;
}
.DatePickerControl .head .nextbutton,
.DatePickerControl .head .nextbutton[status=mouseover],.DatePickerControl .head .nextbutton[userstatus=pushed],
.DatePickerControl .head .nextbutton[userstatus=selected]
{
    -nexa-icon      : URL("theme://images/cal_WF_NxtBtn.svg");
    cursor          : pointer;
}
.DatePickerControl .head .nextbutton[status=focused]
{
    -nexa-border        : 2px dashed #000000;
}
.DatePickerControl .head .nextbutton[status=disabled]
{
    opacity         : 0.5;
}
.DatePickerControl .body
{
    background      : #ffffff;
}
.DatePickerControl .body .weekband
{
    -nexa-border        : 1px solid #E3E3E3, 0px none, 1px solid #E3E3E3, 0px none;
    background      : #F6F6F6;
    font            : 600 18px "pre","Pretendard-SemiBold";
}
.DatePickerControl .body .weekitem
{
    color           : #000000;
}
.DatePickerControl .body .weekitem[userstatus=saturday]
{
    color           : #000000;
}
.DatePickerControl .body .weekitem[userstatus=sunday]
{
    color           : #E53B4C;
}
.DatePickerControl .body .dayitem
{
    border-radius       : 30px;
    cursor          : pointer;
    color           : #333333;
    font            : 400 18px "pre","Pretendard-Regular";
}
.DatePickerControl .body .dayitem[status=mouseover]
{
    -nexa-border        : 2px dashed #000000;
}
.DatePickerControl .body .dayitem[userstatus=selected]
{
    background      : #E53B4C;
    color           : #ffffff;
}
.DatePickerControl .body .dayitem[userstatus=today]
{
    background      : #21409A;
    color           : #ffffff;
}
.DatePickerControl .body .dayitem[userstatus=sunday]
{
    color           : #E53B4C;
}
.DatePickerControl .body .dayitem[userstatus=trailingday]
{
    color           : #D8D8D8;
}

/***** CheckBox *****/
.CheckBox,
.CheckBoxControl
{
    -nexa-icon      : URL("theme://images/chk_WF_box.svg");
    -nexa-text-padding  : 0px 18px 0px 6px;
    cursor          : pointer;
}
.CheckBox[status=mouseover],.CheckBox[status=focused],
.CheckBoxControl[status=mouseover],.CheckBoxControl[status=focused]
{
    -nexa-icon      : URL("theme://images/chk_WF_boxO.svg");
    -nexa-border        : 2px dashed #222222;
}
.CheckBox[status=mouseover][userstatus=selected],
.CheckBoxControl[status=mouseover][userstatus=selected]
{
    -nexa-icon      : URL("theme://images/chk_WF_boxS.svg");
}
.CheckBox[userstatus=selected],
.CheckBoxControl[userstatus=selected]
{  
    -nexa-icon      : URL("theme://images/chk_WF_boxS.svg");
}
.CheckBox[status=disabled],
.CheckBoxControl[status=disabled]
{
    -nexa-icon      : URL("theme://images/chk_WF_boxD.svg");
}
.CheckBox[status=disabled][userstatus=selected],
.CheckBoxControl[status=disabled][userstatus=selected]
{
    -nexa-icon      : URL("theme://images/chk_WF_boxDS.svg");
}

/***** Combo *****/
.Combo,
.ComboControl
{
    -nexa-border        : 1px solid #A3A3A3;
    background      : #ffffff;
    border-radius       : 4px;
}
.Combo[status=mouseover],
.ComboControl[status=mouseover]
{
    -nexa-border        : 1px solid #0097EF;
    background      : #F8FCFF;
}
.Combo[status=focused],
.ComboControl[status=focused]
{
    -nexa-border        : 2px dashed #000000;
    background      : #ffffff;
}
.Combo[status=readonly],
.ComboControl[status=readonly]
{
    background      : #EEEEEE;
}
.Combo[status=disabled],
.ComboControl[status=disabled]
{
    background      : #EEEEEE;
}
.Combo .comboedit,
.Combo .comboedit[status=focused],.Combo .comboedit[status=mouseover],
.Combo .comboedit[status=readonly],
.ComboControl .comboedit,
.ComboControl .comboedit[status=focused],.ComboControl .comboedit[status=mouseover],
.ComboControl .comboedit[status=readonly]
{
    -nexa-border        : 0px none;
    -nexa-padding       : 0px 0px 0px 10px;
    background      : transparent;
}
.Combo .comboedit[status=disabled],.Combo .comboedit[userstatus=nulltext],
.ComboControl .comboedit[status=disabled],.ComboControl .comboedit[userstatus=nulltext]
{
    -nexa-border        : 0px none;
    color               : #888888;
}
.Combo .dropbutton,
.Combo .dropbutton[status=mouseover],.Combo .dropbutton[userstatus=pushed],
.Combo .dropbutton[userstatus=selected],
.ComboControl .dropbutton,
.ComboControl .dropbutton[status=mouseover],.ComboControl .dropbutton[userstatus=pushed],
.ComboControl .dropbutton[userstatus=selected]
{
    -nexa-icon      : URL("theme://images/cbo_WF_Drop.svg");
    cursor          : pointer;
}
.Combo .dropbutton[status=disabled],
.ComboControl .dropbutton[status=disabled]
{   
    -nexa-icon      : URL("theme://images/cbo_WF_DropD.svg");
}
.Combo .combolist,
.ComboControl .combolist
{
    -nexa-border        : 1px solid #A3A3A3;
    background      : #ffffff;
    border-radius       : 4px;
}
.Combo .combolist .listboxitem,
.ComboControl .combolist .listboxitem
{
    -nexa-padding       : 8px 0px 8px 10px;
    color           : #222222;
    cursor          : pointer;
}
.Combo .combolist .listboxitem[status=mouseover],
.ComboControl .combolist .listboxitem[status=mouseover]
{
    background      : #e4f0fe;
}
.Combo .combolist .listboxitem[userstatus=selected],
.ComboControl .combolist .listboxitem[userstatus=selected]
{
    background      : #8ec2ff;
}

/***** Div *****/
.Div,
.Div.div_WF_Trans
{
    background      : transparent;
}

/***** Edit *****/
.Edit,
.EditControl
{
    -nexa-border        : 1px solid #A3A3A3;
    -nexa-padding       : 0px 0px 0px 10px;
    background      : #ffffff;
    border-radius       : 4px;
}
.Edit[status=focused],
.EditControl[status=focused]
{
    -nexa-border        : 2px dashed #000000;
    background      : #ffffff;
}
.Edit[status=mouseover],
.EditControl[status=mouseover]
{
    -nexa-border        : 1px solid #0097EF;
    background      : #F8FCFF;
}
.Edit[status=readonly],
.EditControl[status=readonly]
{
    background      : #EEEEEE;
}
.Edit[userstatus=nulltext],
.EditControl[userstatus=nulltext]
{
    color               : #888888;
}
.Edit[status=disabled],
.EditControl[status=disabled]
{
    background      : #EEEEEE;
    color           : #888888;
}

/***** FileDownload *****/
.FileDownload
{
}

/***** FileUpload *****/
.FileUpload
{
}

/***** Grid *****/
.Grid
{
    -nexa-border        : 1px solid #000000, 0px none, 1px solid #CCCCCC, 0px none;
    background      : #ffffff;
}
.Grid .head
{
    -nexa-border        : 0px none, 0px none, 1px solid #CCCCCC, 0px none;
    background      : #F4F5F7;
}
.Grid .head .row .cell
{
    -nexa-border        : 1px solid #CCCCCC, 0px none;
    -nexa-text-align    : center;
    color           : #000000;
    font            : 500 18px "pre","Pretendard-Medium";
}
.Grid .body .row .cell
{
    -nexa-border        : 1px solid #CCCCCC, 0px none;
    -nexa-padding       : 7px;
    background      : #FFFFFF;
    cursor          : pointer;
}
.Grid .body .row .cell[status=mouseover],.Grid .body .row .cell[userstatus=selected],
.Grid .body .row .cell[userstatus=selected][status=focused]
{
    background      : #F4F5F7;
}
.Grid .body .row .cell .cellselection
{
    -nexa-border        : 2px dashed #000000;
}
.Grid.grd_WF_Original
{
    -nexa-border        : 1px solid #000000, 0px none, 1px solid #CCCCCC, 0px none;
    background      : #ffffff;
}
.Grid.grd_WF_Original .head
{
    -nexa-border        : 0px none, 0px none, 1px solid #CCCCCC, 0px none;
    background      : #F4F5F7;
}
.Grid.grd_WF_Original .head .row .cell
{
    -nexa-border        : 1px solid #CCCCCC, 0px none;
    -nexa-text-align    : center;
    color           : #000000;
    font            : 500 18px "pre","Pretendard-Medium";
}
.Grid.grd_WF_Original .body .row .cell
{
    -nexa-border        : 1px solid #CCCCCC, 0px none;
    -nexa-padding       : 7px;
    background      : #FFFFFF;
    cursor          : pointer;
}
.Grid.grd_WF_Original .body .row .cell[status=mouseover],.Grid.grd_WF_Original .body .row .cell[userstatus=selected],
.Grid.grd_WF_Original .body .row .cell[userstatus=selected][status=focused]
{
    background      : #F4F5F7;
}
.Grid.grd_WF_Original .body .row .cell .cellselection
{
    -nexa-border        : 2px dashed #000000;
}
.Grid.grd_WF_OriginalP .body .row .cell
{
    -nexa-border        : 1px solid #CCCCCC, 0px none;
    -nexa-padding       : 7px;
    background      : #FFFFFF;
    cursor          : auto;
}
/*cellcontrol Start*/
.GridCellControl .cellbutton
{
    -nexa-border        : 1px solid #21409A;
    -nexa-padding       : 0px;
    background      : #F2F5FF;
    border-radius       : 4px;
    cursor          : pointer;
    color           : #21409A;
    font            : 500 18px "pre","Pretendard-Medium";
}
.GridCellControl .cellbutton[status=mouseover],.GridCellControl .cellbutton[userstatus=pushed],
.GridCellControl .cellbutton[userstatus=selected]
{
    -nexa-border        : 1px solid #2E4CA0;
    background      : #DBE3FE;
}
.GridCellControl .cellbutton[status=focused]
{
    -nexa-border        : 2px dashed #000000;
}
.GridCellControl .cellbutton[status=disabled]
{
    -nexa-border        : 1px solid #CCCCCC;
    background      : #F4F4F4;
    color           : #9A9A9A;
}
.GridCellControl .cellradioitem
{
    -nexa-icon      : URL("theme://images/rdo_WF_Item.svg");
    -nexa-text-padding  : 0px 18px 0px 6px;
    cursor          : pointer;
}
.GridCellControl .cellradioitem[status=mouseover]
{
    -nexa-icon      : URL("theme://images/rdo_WF_ItemO.svg");
}
.GridCellControl .cellradioitem[status=mouseover][userstatus=selected]
{
