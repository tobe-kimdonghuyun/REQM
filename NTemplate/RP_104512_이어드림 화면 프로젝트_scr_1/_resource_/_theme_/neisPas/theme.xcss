.MainFrame,.ChildFrame,.FrameSet,.VFrameSet,.HFrameSet,.TileFrameSet 
{
}
.TitleBarControl,.TitleBarControl[status=deactivate]
{
	-nexa-border		: 0px none;
	background 		: #dee1e6;
}
.TitleBarControl[status=disabled]
{
	-nexa-border		: 0px none;
	background 		: #e7eaed;
}
.TitleBarControl .titleicon,
.TitleBarControl .titleicon[status=mouseover],.TitleBarControl .titleicon[status=deactivate],
.TitleBarControl .titleicon[status=disabled]
{
	-nexa-padding 		: 0px 0px 0px 16px;
	color 			: #222222;
	font 			: 700 14px "Dotum";
}
.TitleBarControl .minbutton,
.TitleBarControl .minbutton[userstatus=selected],
.TitleBarControl .minbutton[status=deactivate]
{
	-nexa-icon 		: URL("theme://images/img_titlebar_min_N.png");
	background		: transparent;	
}
.TitleBarControl .minbutton[status=mouseover],.TitleBarControl .minbutton[status=focused]
{
	background 		: #c7cacf;
}
.TitleBarControl .minbutton[userstatus=pushed]
{
	background 		: #b2b4b8;
}
.TitleBarControl .minbutton[status=disabled]
{
	opacity 		: 0.4;
}
.TitleBarControl .maxbutton,
.TitleBarControl .maxbutton[userstatus=selected],
.TitleBarControl .maxbutton[status=deactivate]
{
	-nexa-icon		: URL("theme://images/img_titlebar_max_N.png");
}
.TitleBarControl .maxbutton[status=mouseover],.TitleBarControl .maxbutton[status=focused]
{
	background 		: #c7cacf;
}
.TitleBarControl .maxbutton[userstatus=pushed]
{
	background 		: #b2b4b8;
}
.TitleBarControl .maxbutton[status=disabled]
{
	opacity 		: 0.4;
}
.TitleBarControl .normalbutton,
.TitleBarControl .normalbutton[status=focused],.TitleBarControl .normalbutton[userstatus=selected],
.TitleBarControl .normalbutton[status=deactivate]
{
	-nexa-icon 		: URL("theme://images/img_titlebar_normal_N.png");
}
.TitleBarControl .normalbutton[status=mouseover]
{
	background 		: #c7cacf;
}
.TitleBarControl .normalbutton[userstatus=pushed]
{
	background 		: #b2b4b8;
}
.TitleBarControl .normalbutton[status=disabled]
{
	opacity 		: 0.4;
}
.TitleBarControl .closebutton,
.TitleBarControl .closebutton[userstatus=selected],
.TitleBarControl .closebutton[status=deactivate]
{
	-nexa-icon 		: URL("theme://images/img_titlebar_close_N.png");
}
.TitleBarControl .closebutton[status=mouseover],.TitleBarControl .closebutton[status=focused]
{
	-nexa-icon 		: URL("theme://images/img_titlebar_close_O.png");
	background 		: #e81123;
}
.TitleBarControl .closebutton[userstatus=pushed]
{
	-nexa-icon 		: URL("theme://images/img_titlebar_close_O.png");
	background : #e36571;
}
.TitleBarControl .closebutton[status=disabled]
{
	opacity 		: 0.4;
}

.HScrollBarControl,
.HScrollBarControl[status=mouseover] 
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px;
	background 		: #f1f1f1;
}
.HScrollBarControl[status=disabled]
{
	-nexa-border 		: 0px none;
}
.HScrollBarControl .incbutton,
.HScrollBarControl .incbutton[userstatus=selected]
{
