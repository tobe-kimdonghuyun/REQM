	-nexa-padding		: 0px 0px 0px 14px;
	background		: #f8f8f8;
	color			: #172f57;
	font			: normal 400 14px/normal "Noto Sans KR","NotoSansKR-Medium","Malgun Gothic","Arial","MS PGothic";
}
.Static.sta_WF_Input01Top,
.Static.sta_WF_Input01Top[status=disabled], .Static.sta_WF_Input01Top[status=mouseover]
{
	-nexa-border		: 1px solid #333333, 0px none, 1px solid #d6d9e1, 0px none;
	-nexa-text-align 	: left;
	-nexa-padding		: 0px 0px 0px 14px;
	background		: #f8f8f8;
	color			: #172f57;
	font			: normal 400 14px/normal "Noto Sans KR","NotoSansKR-Medium","Malgun Gothic","Arial","MS PGothic";
}
.Static.sta_WF_EssentialTop,
.Static.sta_WF_EssentialTop[status=disabled], .Static.sta_WF_EssentialTop[status=mouseover]
{
	-nexa-border		: 1px solid #333333, 0px none, 1px solid #d6d9e1, 0px none;
	-nexa-padding		: 0px 0px 0px 14px;
	background		: #f8f8f8;
	color			: #d32850;
	font			: normal 400 14px/normal "Noto Sans KR","NotoSansKR-Medium","Malgun Gothic","Arial","MS PGothic";
}
.Static.sta_WF_Essential,
.Static.sta_WF_Essential[status=disabled], .Static.sta_WF_Essential[status=mouseover]
{
	-nexa-border		: 1px solid #d6d9e1, 0px none, 1px solid #d6d9e1, 0px none;
	-nexa-padding		: 0px 0px 0px 14px;
	background		: #f8f8f8;
	color			: #d32850;
	font			: normal 400 14px/normal "Noto Sans KR","NotoSansKR-Medium","Malgun Gothic","Arial","MS PGothic";
}

/***** 230619 *****/
.Div.div_WF_Search,
.Div.div_WF_Search[status=mouseover],.Div.div_WF_Search[status=focused],
.Div.div_WF_Search[status=disabled]
{
	-nexa-border 		: 0px none;
	background 		: #f5f5f5;
	border-radius 		: 6px;
}
.Grid .body .row .cell.cell_WF_fileup .cellbutton,
.Grid .body .row .cell.cell_WF_fileup .cellbutton[status=mouseover],
.Grid .body .row .cell.cell_WF_fileup .cellbutton[userstatus=selected],
.Grid .body .row .cell.cell_WF_fileup .cellbutton[userstatus=pushed]
{
	-nexa-border 		: 0px none;
	background 		: URL("theme://images/grd_WF_fileup.png") no-repeat center center transparent;
	cursor 			: pointer;
}
/***** Calendar essential *****/
.Calendar.essential
{
	-nexa-border 		: 1px solid #d9d9d9;
	background 		: URL("theme://images/grd_WF_EdiEs.png") no-repeat left top #ffffff;
	border-radius 		: 6px;
	color 			: #595959;
}
.Calendar.essential[status=mouseover],.Calendar.essential[status=focused]
{
	-nexa-border 		: 1px solid #222222;
	background 		: URL("theme://images/grd_WF_EdiEs.png") no-repeat left top #ffffff;	
}
.Calendar.essential[status=readonly]
{
	-nexa-border		: 1px solid #d9d9d9;
	background 		: URL("theme://images/grd_WF_EdiEs.png") no-repeat left top #f5f5f5;
}
.Calendar.essential[status=disabled]
{
	-nexa-border 		: 1px solid #d9d9d9;
	color 			: #d9d9d9;
	background 		: URL("theme://images/grd_WF_EdiEs.png") no-repeat left top #ffffff;		
}

/***** Radio essential *****/
.Radio.essential .radioitem,.Radio.essential .radioitem[status=readonly]
{
	-nexa-icon 		: URL("theme://images/rdo_WF_ItemE.png");
	font 			: 14px "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
	color 			: #172f57;
}
.Radio.essential .radioitem[status=mouseover]
{
	-nexa-icon 		: URL("theme://images/rdo_WF_ItemES.png");
}
.Radio.essential .radioitem[status=mouseover][userstatus=selected],.Radio.essential .radioitem[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/rdo_WF_ItemSES.png");
}

/***** CheckBox essential *****/
.CheckBox.essential,
.CheckBox.essential[status=readonly],.CheckBox.essential[status=focused]
{
	-nexa-icon 		: URL("theme://images/chk_WF_boxE.png");
	font 			: 14px "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
	color 			: #172f57;
}
.CheckBox.essential[status=mouseover]
{
	-nexa-icon 		: URL("theme://images/chk_WF_boxEO.png");
}
.CheckBox.essential[status=mouseover][userstatus=selected],
.CheckBox.essential[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/chk_WF_boxSES.png");
}
/***** Edit essential *****/
.Edit.essential
{
	-nexa-border 		: 1px solid #d9d9d9;
	-nexa-padding 		: 0px 20px 1px 20px;
	background 		: URL("theme://images/grd_WF_EdiEs.png") no-repeat left top #ffffff;
	border-radius 		: 6px;
	color 			: #595959;
	font 			: normal 500 16px/normal "Noto Sans KR","NotoSansKR-Medium","Malgun Gothic","Arial","MS PGothic";
}
.Edit.essential[status=mouseover]
{
	-nexa-border 		: 1px solid #222222;
}
.Edit.essential[status=focused]
{
	-nexa-border 		: 1px solid #222222;
}
.Edit.essential[status=readonly]
{
	-nexa-border		: 1px solid #d9d9d9;
	background 		: URL("theme://images/grd_WF_EdiEs.png") no-repeat left top #f5f5f5;
}
.Edit.essential[userstatus=nulltext]
{
	color          		: #595959;
}
.Edit.essential[status=disabled]
{
	-nexa-border 		: 1px solid #d9d9d9;
	color 			: #d9d9d9;
}

/* font Color #d32850(Red) */
.Static.colorEssential,.Static.colorEssential[status=mouseover]
{
	color 			: #d32850;
}
/* 링크텍스트 Blue 14px  */
.Static.sta_WF_Blue14Link
{
	-nexa-padding		: 1px;
	color			: #1E5DF2;
	cursor 			: pointer;
	font			: 14px "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Static.sta_WF_Blue14Link[status=mouseover]
{
	-nexa-padding		: 1px;
	-nexa-text-decoration 	: underline;
	color			: #1E5DF2;
	cursor 			: pointer;
	font			: 14px "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}]]></CSSData>
