}
/***************************************************************************/
/*******************	BASE COMPONENT START	****************************/
/***************************************************************************/
.Button
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 12px 1px 12px;
	-nexa-text-align	: center;	
	background 		: #2B72DE;
	border-radius 		: 6px;
	color 			: #ffffff;
	cursor 			: pointer;
	font 			: normal 500 14px/normal "Noto Sans KR","NotoSansKR-Medium","Malgun Gothic","Arial","MS PGothic";
}
.Button[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 12px 1px 12px;
}
.Button[status=mouseover]
{
	background 		: #1A56B2;
}
.Button[userstatus=pushed]
{
	background 		: #1A56B2;
}
.Button[status=disabled]
{
	background 		: #d9d9d9;
	cursor 			: default;
}
.Calendar
{
	-nexa-border 		: 1px solid #d9d9d9;
	background 		: #ffffff;
	border-radius 		: 6px;
	color 			: #595959;
}
.Calendar[status=mouseover]
{
	-nexa-border 		: 1px solid #222222;
	background 		: #ffffff;
}
.Calendar[status=focused]
{
	-nexa-border 		: 1px solid #222222;
}
.Calendar[status=readonly]
{
	-nexa-border		: 1px solid #d9d9d9;
	background 		: #f5f5f5;
}
.Calendar[status=disabled]
{
	-nexa-border 		: 1px solid #d9d9d9;
	color 			: #d9d9d9;
}
.Calendar .calendaredit
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px 20px 1px 20px;
	color 			: #595959;
}
.Calendar .calendaredit[status=mouseover],.Calendar .calendaredit[status=focused]
{

}
.Calendar .calendaredit[status=readonly]
{

}
.Calendar .calendaredit[userstatus=nulltext]
{
	color 			: #d9d9d9;
}
.Calendar .calendaredit[status=disabled]
{
	color 			: #d9d9d9;
}

.Calendar .dropbutton,.Calendar .dropbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/cal_WF_drop_N.png");
	cursor 			: pointer;
}
.Calendar .dropbutton[status=mouseover],
.Calendar .dropbutton[status=focused],
.Calendar .dropbutton[userstatus=pushed]
{
	-nexa-icon 		: URL("theme://images/cal_WF_drop_N.png");
	cursor 			: pointer;
}
.Calendar .dropbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/cal_WF_drop_D.png");
}
.Calendar .calendarspindownbutton,
.Calendar .calendarspindownbutton[status=focused],
.Calendar .calendarspindownbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/spin_down_N.png");
	cursor 			: pointer;
	-nexa-padding 		: 0px 0px 5px;	
}
.Calendar .calendarspindownbutton[status=mouseover]
{
	-nexa-icon 		: URL("theme://images/spin_down_O.png");
	background 		: #ffffff;
}
.Calendar .calendarspindownbutton[userstatus=pushed]
{
	-nexa-icon 		: URL("theme://images/spin_down_O.png");
	background 		: #ffffff;
}
.Calendar .calendarspindownbutton[status=disabled]
{
	opacity 		: 0.4;
}
.Calendar .calendarspinupbutton,
.Calendar .calendarspinupbutton[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/spin_up_N.png");
	cursor 			: pointer;	
	-nexa-padding 		: 5px 0px 0px;		
}
.Calendar .calendarspinupbutton[status=mouseover],
.Calendar .calendarspinupbutton[status=focused]
{
	-nexa-icon 		: URL("theme://images/spin_up_O.png");
	background 		: #ffffff;
}
.Calendar .calendarspinupbutton[userstatus=pushed]
{
	-nexa-icon 		: URL("theme://images/spin_up_O.png");
	background 		: #ffffff;
}
.Calendar .calendarspinupbutton[status=disabled]
{
	opacity 		: 0.4;
}
.CheckBox
{
	-nexa-icon 		: URL("theme://images/chk_WF_box.png");
	-nexa-border 		: 1px solid transparent;
	-nexa-text-padding 	: 0px 0px 0px 8px;
	-nexa-padding 		: 0px 10px;	
	color 			: #222222;	
}
.CheckBox[status=focused]
{
	-nexa-icon 		: URL("theme://images/chk_WF_box.png");
	-nexa-border	 	: 1px dashed #222222;
	border-radius 		: 7px;
}
.CheckBox[status=readonly]
{
	-nexa-icon 		: URL("theme://images/chk_WF_boxD.png");
	color 			: #222222;	
}
.CheckBox[status=mouseover]
{
	-nexa-icon 		: URL("theme://images/chk_WF_boxO.png");
}
.CheckBox[status=mouseover][userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/chk_WF_boxSO.png");
}
.CheckBox[userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/chk_WF_boxS.png");
}
.CheckBox[status=disabled]
{
	-nexa-icon 		: URL("theme://images/chk_WF_boxD.png");
	color 			: #d9d9d9;	
}
.CheckBox[status=disabled][userstatus=selected]
{
	-nexa-icon 		: URL("theme://images/chk_WF_boxDS.png");
	color 			: #d9d9d9;	
}
.Combo
{
	-nexa-border 		: 1px solid #d9d9d9;	
	background 		: #ffffff;
	border-radius 		: 6px;
}
.Combo[status=mouseover]
{
	-nexa-border 		: 1px solid #222222;
}
.Combo[status=focused]
{
	-nexa-border 		: 1px solid #222222;
}
.Combo[status=readonly]
{
	-nexa-border		: 1px solid #222222;
	background 		: #ffffff;
}
.Combo[status=disabled]
{
	-nexa-border 		: 1px solid #d9d9d9;
}
.Combo .comboedit
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px 10px 1px 20px;
	color 			: #222222;
	background 		: transparent;	
	font 			: normal 400 16px "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";	
}
.Combo .comboedit[status=mouseover],.Combo .comboedit[status=focused]
{
	-nexa-border 		: 0px none;
}
.Combo .comboedit[status=disabled],.Combo .comboedit[userstatus=nulltext]
{
	color 			: #d9d9d9;
}
.Combo .comboedit[status=readonly]
{
	color 			: #222222;
}
.Combo .dropbutton,
.Combo .dropbutton[status=focused],.Combo .dropbutton[userstatus=selected]
{
	-nexa-icon		: URL("theme://images/cbo_drop_N.png");
	-nexa-padding		: 0px 4px 0px 0px;	
	cursor 			: pointer;
}
.Combo .dropbutton[status=mouseover]
{
}
.Combo .dropbutton[userstatus=pushed]
{
	background 		: transparent;
}
.Combo .dropbutton[status=disabled]
{	
	-nexa-icon 		: URL("theme://images/cbo_drop_D.png");
}
.Combo .combolist
{
	-nexa-border 		: 1px solid #222222;
	background 		: #ffffff;
	border-radius 		: 6px;
}
.Combo .combolist .listboxitem,
.Combo .combolist .listboxitem[status=readonly]
{
	-nexa-padding 		: 8px 0px 8px 20px;
	-nexa-vertical-align 	: middle;	
	color 			: #222222;
	font 			: normal 400 16px "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Combo .combolist .listboxitem[status=mouseover],
.Combo .combolist .listboxitem[status=focused]
{
	background 		: #f5f5f5; 
}
.Combo .combolist .listboxitem[userstatus=selected]
{
	background 		: #f5f5f5;
}
.Combo .combolist .listboxitem[status=disabled]
{
	color 			: #d9d9d9;
}
.Combo .combolist .vscrollbar,
.Combo .combolist .vscrollbar[status=disabled],
.Combo .combolist .vscrollbar[status=mouseover] 
{
	-nexa-border 		: 3px solid transparent;
	background 		: transparent;	
}
.Combo .combolist .vscrollbar .decbutton,
.Combo .combolist .vscrollbar .decbutton[userstatus=selected],
.Combo .combolist .vscrollbar .decbutton[status=mouseover],
.Combo .combolist .vscrollbar .decbutton[status=focused],
.Combo .combolist .vscrollbar .decbutton[userstatus=pushed],
.Combo .combolist .vscrollbar .decbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/none.png");
	background 		: transparent;	
}
.Combo .combolist .vscrollbar .incbutton,
.Combo .combolist .vscrollbar .incbutton[userstatus=selected],
.Combo .combolist .vscrollbar .incbutton[status=mouseover],
.Combo .combolist .vscrollbar .incbutton[status=focused],
.Combo .combolist .vscrollbar .incbutton[userstatus=pushed],
.Combo .combolist .vscrollbar .incbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/none.png");
	background 		: transparent;	
}
.Combo .combolist .vscrollbar .trackbar
{
	border-radius 		: 5px;
}
.DatePickerControl
