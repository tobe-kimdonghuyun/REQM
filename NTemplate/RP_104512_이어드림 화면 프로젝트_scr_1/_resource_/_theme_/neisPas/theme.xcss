.Form,
.Form[status=disabled],.Form[status=focused],
.Form[status=mouseover]

{
	background 		: #ffffff;
	color 			: #222222;
	font 			: normal 500 14px/normal "Noto Sans KR","NotoSansKR-Medium","Malgun Gothic","Arial","MS PGothic";
}
.Form[userstatus=contents]
{
	background 		: transparent;
}
.Form.frm_Pop_bgTrsprt,
.Form.frm_Pop_bgTrsprt[status=disabled],.Form.frm_Pop_bgTrsprt[status=focused],
.Form.frm_Pop_bgTrsprt[status=mouseover]
{
