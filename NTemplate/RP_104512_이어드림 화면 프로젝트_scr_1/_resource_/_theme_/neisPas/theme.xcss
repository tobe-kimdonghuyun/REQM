}
.HScrollBarControl .decbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/HS_Dec_D.png");
	background 		: transparent;	
}
.HScrollBarControl .trackbar,.HScrollBarControl .trackbar[userstatus=selected]
{
	-nexa-border 		: 0px none,2px solid transparent;
	background 		: #c1c1c1;
}
.HScrollBarControl .trackbar[status=mouseover],.HScrollBarControl .trackbar[status=focused]
{
	-nexa-border 		: 0px none;
	background 		: #a8a8a8;
}
