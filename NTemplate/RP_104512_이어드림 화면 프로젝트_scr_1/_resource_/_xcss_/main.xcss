	font 			: normal 700 48px/normal "Noto Sans KR","NotoSansKR-Medium","Malgun Gothic","Arial","MS PGothic";
	letter-spacing 		: -3px;	
}
.ImageViewer.font20R_W,
.ImageViewer.font20R_W[status=disabled],.ImageViewer.font20R_W[status=mouseover]
{
	-nexa-border 		: 2px solid transparent;
	background		: transparent; 
}
.ImageViewer.font20R_W[status=focused]
{
	-nexa-border 		: 2px dashed #222222; 
}
.ImageViewer.font20R_W .imagetext
{
	-nexa-text-align 	: left;
	color 			: #222222;
	font 			: normal 400 20px/normal "Noto Sans KR","NotoSansKR-Medium","Malgun Gothic","Arial","MS PGothic";
}
/*나이스대국민 대학지원용 학교생활기록부 신청 서비스 */
.Static.sta_WF_UdaMainTitle,
.Static.sta_WF_UdaMainTitle[status=disabled], .Static.sta_WF_UdaMainTitle[status=mouseover]
{
	-nexa-border 		: 0px none;	
	-nexa-text-align	: center;
	background 		: #3772ff;	
	box-shadow 		: 2px 2px 4px 0px RGBA(0,0,0,0.5);
	border-radius 		: 5px;
	color 			: #ffffff;
	font 			: normal 700 26px "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";
}
.Static.sta_WF_UdaMainTxt01,
.Static.sta_WF_UdaMainTxt01[status=disabled], .Static.sta_WF_UdaMainTxt01[status=mouseover]
{
	color 			: #222222;
	font			: normal 700 32px/1.3 "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Static.sta_WF_UdaMainTxt02,
.Static.sta_WF_UdaMainTxt02[status=disabled], .Static.sta_WF_UdaMainTxt02[status=mouseover]
{
	background		: transparent;
	color 			: #333333;
	font			: normal 400 18px/1.3 "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";		
}
.Static.sta_WF_UdaContact,
.Static.sta_WF_UdaContact[status=disabled], .Static.sta_WF_UdaContact[status=mouseover]
{
	-nexa-text-align 	: center;
	-nexa-padding 		: 0px 10px 1px 10px;
	-nexa-vertical-align 	: middle;
	background 		: #eff3fb;
	border-radius		: 20px;
	color			: #172f57;
	font 			: normal 700 14px "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";
}]]></CSSData>
