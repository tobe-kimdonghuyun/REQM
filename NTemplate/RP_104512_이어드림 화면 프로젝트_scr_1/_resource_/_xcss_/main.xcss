<?xml version="1.0" encoding="utf-8"?>
<XCSS version="1.1">
  <Predefines/>
  <CSSData><![CDATA[/*******************	      MAIN         *******************/

.Static.sta_main_sub0_tooltip,.Static.sta_main_sub0_tooltip[status=mouseover]
{
	-nexa-padding 		: 0px 15px 1px 15px;
	-nexa-text-align	: center;
	-nexa-edge 		: url('imagerc::main/main_sub0_tooltip.png') 20px 0px;		
	background 		: url('imagerc::main/main_sub0_tootipTail.png') no-repeat center bottom transparent;
	color 			: #ffffff;
	font 			: normal 400 13px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
	letter-spacing		: -1px;
}
/* My Service Setting Button */
.Button.btn_main_sub0_mySetting
{
	-nexa-border 		: 1px solid transparent;
	-nexa-padding 		: 1px 5px 2px 5px;
	-nexa-text-align	: center;
	-nexa-icon		: url('imagerc::main/main_mySetting.png');
	-nexa-text-padding	: 0px 0px 0px 5px;
	-nexa-icon-position	: left;
	-nexa-vertical-align 	: middle;		
	background 		: transparent;
	color 			: #ffffff;
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_main_sub0_mySetting[status=focused]
{
	-nexa-border 		: 1px dashed #ffffff;
	-nexa-padding 		: 1px 5px 2px 5px;
}
.Button.btn_main_sub0_mySetting[status=mouseover],
.Button.btn_main_sub0_mySetting[userstatus=pushed]
{
	-nexa-border 		: 1px solid transparent;
	-nexa-text-decoration 	: underline;
	background 		: transparent;	
}
.Button.btn_main_sub0_mySetting[status=disabled]
{
	-nexa-border 		: 1px solid transparent;	
	background 		: transparent;
	color			: #ffffff;
	opacity 		: 0.4;		
}
.Div.div_main_shadowBox_C,
.Div.div_main_shadowBox_C[status=focused],.Div.div_main_shadowBox_C[status=mouseover]
{
	-nexa-border 		: 0px none;
	border-radius 		: 0px;
	background 		: #ffffff;
	box-shadow 		: 0px 5px 20px 0px rgba(0,0,0,0.06);
}
.Static.sta_main_titlebar,.Static.sta_main_titlebar[status=mouseover]
{
	-nexa-text-align 	: left;	
	background 		: url('imagerc::main/main_bg_titleline.png') no-repeat right center transparent;
	font			: normal 500 18px/normal "Noto Sans KR","NotoSansKR-Medium","Malgun Gothic","Arial","MS PGothic";
	color 			: #ffffff;	
}
/* Main sub0 line */
.Static.sta_main_sub0_line,.Static.sta_main_sub0_line[status=mouseover]
{
	-nexa-border 		: 0px none,0px none,0px none,1px solid #eaeaea;
}
/* 나이스플러스 Button */
.Button.btn_main_sub0_service1,
.Button.btn_main_sub0_service1[status=mouseover],
.Button.btn_main_sub0_service1[userstatus=pushed]
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px 5px 1px 5px;
	-nexa-text-align	: center;
	border-radius 		: 0px;	
	background 		: transparent;
	color 			: #222222;
	font 			: normal 400 24px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_main_sub0_service1[status=focused]
{
	-nexa-border 		: 2px dashed #000000;
	-nexa-padding 		: 0px 5px 1px 5px;
}
.Button.btn_main_sub0_service1[status=disabled]
{
	-nexa-border 		: 0px none;
	background 		: transparent;
	color			: #d6d6d6;
	opacity			: 0.4;		
}
