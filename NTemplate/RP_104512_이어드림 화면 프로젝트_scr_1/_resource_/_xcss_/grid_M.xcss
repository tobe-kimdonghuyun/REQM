/* Cell 중요이미지*/
.Grid .body .row .cell.cell_ImpNoti_M,
.Grid .body .row .cell.cell_ImpNoti_M[status=mouseover]
{
	-nexa-padding 		: 0px 0px 0px 130px;
	background 		: url('imagerc::pas_mmscn00_M/grd_newNotice_M02.png') no-repeat left center #f5f5f5;
}
.Grid .body .row .cell.cell_ImpNoti_M[userstatus=selected],
.Grid .body .row .cell.cell_ImpNoti_M[status=focused]
{
	-nexa-padding 		: 0px 0px 0px 130px;
	background 		: url('imagerc::pas_mmscn00_M/grd_newNotice_M02.png') no-repeat left center #f5f5f5;
	-nexa-text-decoration 	: underline;
	font			: normal 700 28px/normal "Noto Sans KR","NotoSansKR-Bold";
	color 			: #000000;	
}
