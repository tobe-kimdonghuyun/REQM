<?xml version="1.0" encoding="utf-8"?>
<XCSS version="1.1">
  <Predefines/>
  <CSSData><![CDATA[/*******************	      GRID CSS Mobile        *******************/

/* Font 32px */
.Grid .body .row .cell.cell_txt32M,
.Grid .body .row .cell.cell_txt32M[status=mouseover],
.Grid .body .row .cell.cell_txt32M[status=focused],
.Grid .body .row .cell.cell_txt32B[userstatus=blinked],
.Grid .body .row .cell.cell_txt32B[status=readonly],
.Grid .body .row .cell.cell_txt32M[userstatus=selected],
.Grid .body .row .cell.cell_txt32M[status=disabled]
{
	-nexa-text-align 	: center;
	font			: normal 500 32px/normal "Noto Sans KR","NotoSansKR-Medium";
	color 			: #222222;	
}
/* Font 30x */
.Grid .body .row .cell.cell_txt30B,
.Grid .body .row .cell.cell_txt30B[status=mouseover],
