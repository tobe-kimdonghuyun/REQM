/* Download button */
.Grid .body .row .cell.cell_btnDownload_M .cellbutton,
.Grid .body .row .cell.cell_btnDownload_M .cellbutton[status=disabled],
.Grid .body .row .cell.cell_btnDownload_M .cellbutton[userstatus=pushed],
.Grid .body .row .cell.cell_btnDownload_M .cellbutton[userstatus=selected]
{
	-nexa-border 		: 0px none;
	-nexa-icon 		: url('imagerc::pas_mmscn00_M/grd_download_M.png');
	-nexa-padding 		: 0px;
	background 		: transparent;	
	cursor 			: default;
}
.Grid .body .row .cell.cell_btnDownload_M .cellbutton[status=focused],
.Grid .body .row .cell.cell_btnDownload_M .cellbutton[status=mouseover]
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px;	
	background 		: #f5f5f5;
}
/* View button */
.Grid .body .row .cell.cell_btnView_M .cellbutton,
.Grid .body .row .cell.cell_btnView_M .cellbutton[status=disabled],
.Grid .body .row .cell.cell_btnView_M .cellbutton[status=focused],
.Grid .body .row .cell.cell_btnView_M .cellbutton[status=mouseover],
.Grid .body .row .cell.cell_btnView_M .cellbutton[userstatus=pushed],
.Grid .body .row .cell.cell_btnView_M .cellbutton[userstatus=selected]
{
	-nexa-border 		: 0px none;
	-nexa-icon 		: url('imagerc::pas_mmscn00_M/grd_view_M.png');
	-nexa-padding 		: 4px;
	background 		: transparent;	
	cursor 			: default;
}
/* Notice */
.Grid.grd_notice_M,
.Grid.grd_notice_M[status=mouseover],.Grid.grd_notice_M[status=focused],
.Grid.grd_notice_M[status=readonly],.Grid.grd_notice_M[status=disabled]
{
	-nexa-border 		: 4px solid #222222,0px none,0px none;
	font			: normal 400 24px/normal "Noto Sans KR","NotoSansKR-Regular";	

}
.Grid.grd_notice_M .body .row .cell,
.Grid.grd_notice_M .body .row .cell[status=mouseover],
.Grid.grd_notice_M .body .row .cell[userstatus=blinked],
.Grid.grd_notice_M .body .row .cell[status=readonly],
.Grid.grd_notice_M .body .row .cell[status=disabled]
{
	-nexa-border 		: 2px solid #eaeaea,0px none;
	font			: normal 400 28px/normal "Noto Sans KR","NotoSansKR-Regular";	
}
.Grid.grd_notice_M .body .row .cell[status=focused],.Grid.grd_notice_M .body .row .cell[userstatus=selected]
{
	-nexa-border 		: 2px solid #eaeaea,0px none;
	-nexa-text-decoration 	: underline;
	font			: normal 700 28px/normal "Noto Sans KR","NotoSansKR-Bold";	
	color 			: #000000;
}
/* Notice New button */
.Grid .body .row .cell.cell_btnNotice_new_M .cellbutton,
.Grid .body .row .cell.cell_btnNotice_new_M .cellbutton[status=disabled],
.Grid .body .row .cell.cell_btnNotice_new_M .cellbutton[userstatus=pushed],
.Grid .body .row .cell.cell_btnNotice_new_M .cellbutton[userstatus=selected]
{
	-nexa-border 		: 0px none;
	-nexa-icon 		: url('imagerc::pas_mmscn00_M/grd_newNotice_M.png');
	-nexa-padding 		: 0px 0px 0px 20px;
	-nexa-icon-position 	: left;
	-nexa-text-padding 	: 0px 0px 0px 20px;
	-nexa-vertical-align 	: middle;
	-nexa-text-align 	: left;	
	background 		: transparent;	
	color 			: #222222;
	font			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Medium";
