<?xml version="1.0" encoding="utf-8"?>
<XCSS version="1.1">
  <Predefines/>
  <CSSData><![CDATA[/*** Search Area ***/
.Div.div_SA_M,
.Div.div_SA_M[status=focused],.Div.div_SA_M[status=mouseover]
{
	background 		: #fafafa;
}
/* Hang Div */
.Div.div_WF_hang_M,
.Div.div_WF_hang_M[status=focused],.Div.div_WF_hang_M[status=mouseover]
{
	-nexa-border 		: 1px solid #eaeaea;
	border-radius 		: 16px;
	background 		: #ffffff;
}
/* Hang Div(Line None) */
.Div.div_WF_hang_noLine,
.Div.div_WF_hang_noLine[status=focused],.Div.div_WF_hang_noLine[status=mouseover]
{
	-nexa-border 		: 0px none;
	border-radius 		: 0px;
	background 		: transparent;
}
/* Label */
.Static.sta_SA_label_M,.Static.sta_SA_label_M[status=mouseover]
{
	color			: #222222;
	font 			: normal 700 28px/normal "Noto Sans KR","NotoSansKR-Bold";
}
/* ~,- , 단위 */
.Static.sta_SA_unit_M,.Static.sta_SA_unit_M[status=mouseover]
{
	-nexa-padding 		: 0px 26px 1px 26px;	
	color			: #222222;
	font 			: normal 700 28px/normal "Noto Sans KR","NotoSansKR-Bold";
}
/* Search Button */
.Button.btn_SA_search_M
{
	-nexa-border 		: 0px solid #222222;
	-nexa-padding 		: 0px 50px 1px 50px;
	background 		: #2B72DE;
	color 			: #ffffff;
	font 			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Medium";	
}
.Button.btn_SA_search_M[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 48px 1px 48px; 
}
.Button.btn_SA_search_M[status=mouseover],
.Button.btn_SA_search_M[userstatus=pushed]
{
	-nexa-text-decoration 	: none;
	background 		: #1A56B2;
	color 			: #ffffff;
}
.Button.btn_SA_search_M[status=disabled]
{
	background 		: #d9d9d9;
	color 			: #ffffff;	
}
/* Reset Button */
.Button.btn_SA_reset_M
{
	-nexa-border 		: 2px solid #d9d9d9;
	-nexa-padding 		: 0px 20px 1px 20px;
	background 		: #ffffff;
	color 			: #222222;
	font 			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Medium";	
}
.Button.btn_SA_reset_M[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 20px 1px 20px;
}
.Button.btn_SA_reset_M[status=mouseover],
.Button.btn_SA_reset_M[userstatus=pushed]
{
	-nexa-border 		: 2px solid #222222;
	-nexa-text-decoration 	: none;
	background 		: #ffffff;
	color 			: #222222;
}
.Button.btn_SA_reset_M[status=disabled]
{
	background 		: #ffffff;
	color 			: #d9d9d9;	
}
/* uni download Button */
.Button.btn_WF_UniDown_M
{
	-nexa-border 		: 2px solid #2b72de;
	-nexa-padding 		: 0px 10px 1px 10px;
	-nexa-text-align	: center;
	background 		: #ffffff;
	border-radius 		: 8px;
	color 			: #2b72de;
	font 			: normal 400 28px/normal "Noto Sans KR","NotoSansKR-Regular";	
}
.Button.btn_WF_UniDown_M[status=mouseover],
.Button.btn_WF_UniDown_M[userstatus=pushed]
{
	-nexa-border 		: 2px solid #2b72de;
	-nexa-padding 		: 0px 10px 1px 10px;
	-nexa-text-decoration 	: underline;
	background 		: #ffffff;
	border-radius 		: 8px;	
}
.Button.btn_WF_UniDown_M[status=focused]
{
	-nexa-border 		: 2px solid #222222; 
	-nexa-padding 		: 0px 10px 1px 10px; 
}

.Button.btn_WF_UniDown_M[status=disabled]
{
	-nexa-border 		: 1px solid #d9d9d9;
	background 		: #f5f5f5;
	color 			: #d9d9d9;
}
/* Sub Top Image RoundBox display */
.ImageViewer.Roundbox16,
.ImageViewer.Roundbox16[status=mouseover],
.ImageViewer.Roundbox16[status=focused],
.ImageViewer.Roundbox16[status=disabled]
{
	-nexa-border 		: 0px none;
	border-radius 		: 16px;
	background 		: #ffffff;
}
.ImageViewer.Roundbox16_shadow,
.ImageViewer.Roundbox16_shadow[status=mouseover],
.ImageViewer.Roundbox16_shadow[status=focused],
.ImageViewer.Roundbox16_shadow[status=disabled]
{
	-nexa-border 		: 0px none;
	border-radius 		: 16px;
	box-shadow 		: 0px 10px 30px 0px rgba(0,0,0,0.1);
	background 		: #ffffff;
}
/* Sub Top Image  LINE RoundBox display */
.ImageViewer.Roundbox16_line_M,
.ImageViewer.Roundbox16_line_M[status=mouseover],
.ImageViewer.Roundbox16_line_M[status=focused],
.ImageViewer.Roundbox16_line_M[status=disabled]
{
	-nexa-border 		: 2px solid #eaeaea;
	background 		: #ffffff;
	border-radius 		: 16px;
}
/* Form WF Quick Link Button (어두운배경에서 사용)*/
.Button.btn_WF_quickLink_M
{
	-nexa-border 		: 3px solid #ffffff;
	-nexa-padding 		: 0px 40px 1px 40px;
	background 		: #ffffff;
	border-radius 		: 35px;
	color 			: #222222;
	font 			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Medium";
}
.Button.btn_WF_quickLink_M[status=focused]
{
	-nexa-border 		: 3px solid #2b72de;
	-nexa-padding 		: 0px 40px 1px 40px;
}
.Button.btn_WF_quickLink_M[status=mouseover],
.Button.btn_WF_quickLink_M[userstatus=pushed]
{
	-nexa-border 		: 3px solid #2d73de;
	background 		: #2d73de;
	color 			: #ffffff;
}
.Button.btn_WF_quickLink_M[status=disabled]
{
	-nexa-border 		: 3px solid #ffffff;
	background 		: #ffffff;
	color			: #d9d9d9;
}
/* Form Tab(text) Button */
.Button.btn_WF_tab_M
{
	-nexa-border 		: 3px solid #f5f5f5;
	-nexa-padding 		: 0px 10px 1px 10px;
	background 		: #f5f5f5;
	border-radius 		: 35px;
	color 			: #444444;
	font 			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Medium";
}
.Button.btn_WF_tab_M[status=focused]
{
	-nexa-border 		: 3px dashed #000000;
	-nexa-padding 		: 0px 10px 1px 10px;
}
.Button.btn_WF_tab_M[status=mouseover]
{
	-nexa-border 		: 3px solid #2b72de;
	background 		: #2b72de;
	color 			: #ffffff;
}
.Button.btn_WF_tab_M[userstatus=pushed]
{
	-nexa-border 		: 3px solid #2b72de;
	background 		: #2b72de;
	color 			: #ffffff;
}
.Button.btn_WF_tab_M[status=disabled]
{
	-nexa-border 		: 3px solid #d9d9d9;
	background 		: #f5f5f5;
	color			: #d9d9d9;
}
.Button.btn_WF_tab_M_S,
.Button.btn_WF_tab_M_S[status=mouseover],
.Button.btn_WF_tab_M_S[userstatus=pushed]
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 10px 1px 10px;
	background 		: #2b72de;
	border-radius 		: 35px;
	color 			: #ffffff;
	font 			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Medium";
}
.Button.btn_WF_tab_M_S[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 10px 1px 10px;
}
.Button.btn_WF_tab_M_S[status=disabled]
{
	background 		: #d9d9d9; 
}
/* Program Download Button */
.Button.btn_WF_programDownload_M
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 10px 1px 10px;
	-nexa-icon		: url('imagerc::common_M/icon_download_M.png');
	-nexa-text-padding	: 0px 0px 0px 22px;
	-nexa-icon-position	: left;
	-nexa-text-align 	: center;	
	border-radius 		: 8px;		
	background 		: #2B72DE;
	color 			: #ffffff;
	font 			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Medium";	
	letter-spacing 		: -1px;
}
.Button.btn_WF_programDownload_M[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 10px 1px 10px;
}
.Button.btn_WF_programDownload_M[status=mouseover],
.Button.btn_WF_programDownload_M[userstatus=pushed]
{
	background 		: #1A56B2; 
}
.Button.btn_WF_programDownload_M[status=disabled]
{
	background 		: #d9d9d9; 
}
/* Form Popup Button */
.Button.btn_WF_popup_M
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 66px 1px 65px;
	border-radius 		: 16px;
	background 		: #2B72DE;
	color 			: #ffffff;
	font 			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Medium";
}
.Button.btn_WF_popup_M[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 66px 1px 65px;
}
.Button.btn_WF_popup_M[status=mouseover],
.Button.btn_WF_popup_M[userstatus=pushed]
{
	background 		: #1A56B2; 
}
.Button.btn_WF_popup_M[status=disabled]
{
	background 		: #d9d9d9; 
}
/* PDF Download(text) Button */
.Button.btn_WF_download_gray_M
{
	-nexa-border 		: 1px solid transparent,1px solid transparent,1px solid #767676;
	-nexa-padding 		: 0px;
	background 		: transparent;
	border-radius 		: 0px;
	color 			: #767676;
	font 			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Medium";
	letter-spacing		: -1px;	
}
.Button.btn_WF_download_gray_M[status=focused]
{
	-nexa-border 		: 1px dashed #000000;
	-nexa-padding 		: 0px;
}
.Button.btn_WF_download_gray_M[status=mouseover]
{
	-nexa-border 		: 1px solid transparent,1px solid transparent,1px solid #222222;
	background 		: transparent;
	color 			: #222222;
}
.Button.btn_WF_download_gray_M[userstatus=pushed]
{
	-nexa-border 		: 1px solid transparent,1px solid transparent,1px solid #222222;
	background 		: transparent;
	color 			: #222222;
}
.Button.btn_WF_download_gray_M[status=disabled]
{
	-nexa-border 		: 1px solid transparent,1px solid transparent,1px solid #d9d9d9;
	background 		: transparent;
	color			: #d9d9d9;
}
/* Form Board List Blue Button */
.Button.btn_WF_boardList_M
{
	-nexa-border 		: 2px solid #d9d9d9;
	-nexa-padding 		: 0px 20px 1px 20px;
	border-radius 		: 16px;		
	background 		: #ffffff;
	color 			: #222222;
	font 			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Medium";	
}
.Button.btn_WF_boardList_M[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 20px 1px 20px; 
}
.Button.btn_WF_boardList_M[status=mouseover],
.Button.btn_WF_boardList_M[userstatus=pushed]
{
	-nexa-border 		: 2px solid #2b72de;
	background 		: #2b72de;
	color 			: #ffffff;
}
.Button.btn_WF_boardList_M[status=disabled]
{
	-nexa-border 		: 2px solid #d9d9d9;
	background 		: #ffffff;
	color 			: #d9d9d9;
}
/* Form Download(icon+text) Button */
.Button.btn_WF_formDownload_M
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 23px 1px 23px;
	-nexa-icon		: url('imagerc::common_M/icon_download_M.png');
	-nexa-text-padding	: 0px 0px 0px 10px;
	-nexa-icon-position	: left;
	-nexa-text-align 	: center;	
	border-radius 		: 8px;		
	background 		: #2B72DE;
	color 			: #ffffff;
	font 			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Medium";	
	letter-spacing 		: -1px;
}
.Button.btn_WF_formDownload_M[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 23px 1px 23px;
}
.Button.btn_WF_formDownload_M[status=mouseover],
.Button.btn_WF_formDownload_M[userstatus=pushed]
{
	-nexa-text-decoration 	: none;
	background 		: #1A56B2; 
}
.Button.btn_WF_formDownload_M[status=disabled]
{
	background 		: #d9d9d9; 
}
.Button.btn_WF_googleDownload_M
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 35px 1px 35px;
	-nexa-icon		: url('imagerc::common_M/icon_google_M.png');
	-nexa-text-padding	: 0px 0px 0px 16px;
	-nexa-icon-position	: left;
	-nexa-text-align 	: center;	
	background 		: #2B72DE;
	color 			: #ffffff;
	font 			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Medium";	
}
.Button.btn_WF_googleDownload_M[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 35px 1px 35px;
}
.Button.btn_WF_googleDownload_M[status=mouseover],
.Button.btn_WF_googleDownload_M[userstatus=pushed]
{
	background 		: #1A56B2; 
}
.Button.btn_WF_googleDownload_M[status=disabled]
{
	background 		: #d9d9d9;
}
.Button.btn_WF_appDownload_M
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 35px 1px 35px;
	-nexa-icon		: url('imagerc::common_M/icon_appStore_M.png');
	-nexa-text-padding	: 0px 0px 0px 16px;
	-nexa-icon-position	: left;
	-nexa-text-align 	: center;	
	background 		: #2B72DE;
	color 			: #ffffff;
	font 			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Medium";	
}
.Button.btn_WF_appDownload_M[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 35px 1px 35px;
}
.Button.btn_WF_appDownload_M[status=mouseover],
.Button.btn_WF_appDownload_M[userstatus=pushed]
{
	background 		: #1A56B2;
}
.Button.btn_WF_appDownload_M[status=disabled]
{
	background 		: #d9d9d9;
}
/* Form ServiceLink Blue Button */
.Button.btn_WF_serviceLink_blue_M
{
	-nexa-border 		: 2px solid #2b72de;
	-nexa-padding 		: 0px 20px 1px 20px;
	border-radius 		: 16px;		
	background 		: #ffffff;
	color 			: #2b72de;
	font 			: normal 700 28px/normal "Noto Sans KR","NotoSansKR-Bold";
}
.Button.btn_WF_serviceLink_blue_M[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 20px 1px 20px;
}
.Button.btn_WF_serviceLink_blue_M[status=mouseover],
.Button.btn_WF_serviceLink_blue_M[userstatus=pushed]
{
	-nexa-border 		: 2px solid #2b72de;
	-nexa-text-decoration 	: none;
	background 		: #2b72de;
	color 			: #ffffff;
}
.Button.btn_WF_serviceLink_blue_M[status=disabled]
{
	-nexa-border 		: 2px solid #d9d9d9;
	background 		: #ffffff;
	color 			: #d9d9d9;
}
/* Form LinkText(text) font 28 Button */
.Button.btn_WF_linkText_M
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 5px;
	background 		: transparent;
	border-radius 		: 5px;	
	color 			: #222222;
	font 			: normal 400 28px/normal "Noto Sans KR","NotoSansKR-Regular";
}
.Button.btn_WF_linkText_M[status=focused]
{
	-nexa-border 		: 2px dashed #000000;
	-nexa-padding 		: 10px;
}
.Button.btn_WF_linkText_M[status=mouseover],
.Button.btn_WF_linkText_M[userstatus=pushed]
{
	-nexa-border 		: 2px solid transparent;
	-nexa-text-decoration 	: underline;
	background 		: transparent;
	color 			: #2b72de;
}
.Button.btn_WF_linkText_M[status=disabled]
{
	-nexa-border 		: 2px solid transparent;
	background 		: transparent;
	color 			: #d9d9d9;
}
/* Form 404 Error Back Button */
.Button.btn_WF_errorBack_M
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 90px 1px 90px;
	background 		: #2B72DE;
	color 			: #ffffff;
	font 			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Medium";
}
.Button.btn_WF_errorBack_M[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 90px 1px 90px;
}
.Button.btn_WF_errorBack_M[status=mouseover],
.Button.btn_WF_errorBack_M[userstatus=pushed]
{
	background 		: #1A56B2;
}
.Button.btn_WF_errorBack_M[status=disabled]
{
	background 		: #d9d9d9;
}
/* Video Play(icon) Button */
.Button.btn_video_play_M,
.Button.btn_video_play_M[status=mouseover],
.Button.btn_video_play_M[userstatus=pushed]
{
	-nexa-border 		: 1px solid transparent;
	-nexa-padding 		: 5px;
	-nexa-icon		: url('theme://images/icon_video_play.png');	
	background 		: #ffffff;
	border-radius 		: 60px;	
}
.Button.btn_video_play_M[status=focused]
{
	-nexa-border 		: 1px dashed #000000;
	-nexa-padding 		: 5px;
}
.Button.btn_video_play_M[status=disabled]
{
	-nexa-border 		: 1px solid transparent;
	-nexa-icon		: url('theme://images/icon_video_play.png');	
	background 		: #ffffff;
}
/* Form Paging more Button */
.Button.btn_paging_more_M
{
	-nexa-border 		: 2px solid #2b72de;
	-nexa-padding 		: 0px 20px 1px 20px;
	border-radius 		: 16px;		
	background 		: #2b72de;
	color 			: #ffffff;
	font 			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Medium";	
}
.Button.btn_paging_more_M[status=focused]
{
	-nexa-border 		: 2px dashed #000000;
	-nexa-padding 		: 0px 20px 1px 20px;
	background 		: #2560ba;
	color 			: #ffffff;	
}
.Button.btn_paging_more_M[status=mouseover],
.Button.btn_paging_more_M[userstatus=pushed]
{
	-nexa-border 		: 2px solid #2560ba;
	-nexa-text-decoration 	: none;
	background 		: #2560ba;
	color 			: #ffffff;
}
.Button.btn_paging_more_M[status=disabled]
{
	-nexa-border 		: 2px solid #d9d9d9;
	background 		: #d9d9d9;
	color : #ffffff;
}
/* HangTxt */
.Static.sta_WF_HangTxt_blue_M,.Static.sta_WF_HangTxt_blue_M[status=mouseover]
{
	-nexa-vertical-align 	: top;
	color			: #222222;
	font 			: normal 400 28px/1.5 "Noto Sans KR","NotoSansKR-Regular";
	background 		: url('imagerc::common_M/bul_hangBlue_top_M.png') no-repeat left top transparent;
	-nexa-padding 		: 1px 0px 0px 19px;
	letter-spacing 		: -2px;
}
.Static.sta_WF_HangTxt_Skyblue_M,.Static.sta_WF_HangTxt_Skyblue_M[status=mouseover]
{
	-nexa-vertical-align 	: top;
	color			: #222222;
	font 			: normal 400 28px/1.5 "Noto Sans KR","NotoSansKR-Regular";
	background 		: url('imagerc::common_M/bul_hangSkyblue_top_M.png') no-repeat left top transparent;
	-nexa-padding 		: 2px 0px 0px 17px;
	letter-spacing 		: -1px;
}
.Static.sta_WF_HangTxt_black_M,.Static.sta_WF_HangTxt_black_M[status=mouseover]
{
	-nexa-vertical-align 	: top;
	color			: #222222;
	font 			: normal 400 28px/1.5 "Noto Sans KR","NotoSansKR-Regular";
	background 		: url('imagerc::common_M/bul_hangBlack_top_M.png') no-repeat left top;
	-nexa-padding 		: 2px 0px 0px 17px;
	letter-spacing 		: -1px;
}
.Static.sta_WF_HangTxt_black_M02,.Static.sta_WF_HangTxt_black_M02[status=mouseover]
{
	-nexa-vertical-align 	: top;
	color			: #222222;
	font 			: normal 400 28px/1.5 "Noto Sans KR","NotoSansKR-Regular";
	background 		: transparent;
	-nexa-padding 		: 2px 0px 0px 0px;
	letter-spacing 		: -1px;
}
/* Shadow Box Div(center) */
.Div.div_WF_shadowBox_C_M,
.Div.div_WF_shadowBox_C_M[status=focused],.Div.div_WF_shadowBox_C_M[status=mouseover]
{
	border-radius 		: 16px;
	background 		: #ffffff;
	box-shadow 		: 0px 10px 16px 0px rgba(0,0,0,0.1);
}
.Div.div_WF_shadowBox_M,
.Div.div_WF_shadowBox_M[status=focused],.Div.div_WF_shadowBox_M[status=mouseover]
{
	-nexa-border 		: 1px solid #ebebeb;
	border-radius 		: 16px;
	background 		: #ffffff;
	box-shadow 		: 0px 5px 20px 0px rgba(0,0,0,0.06);
}
/* Mobile Type CheckBox */
.CheckBox.chk_WF_M
{
	-nexa-icon 		: url('imagerc::common_M/chk_M_box.png');
	-nexa-border 		: 2px solid transparent;
	-nexa-text-padding 	: 0px 0px 0px 16px;
	-nexa-padding		: 0px 20px;		
	color 			: #222222;
	font 			: normal 400 24px/normal "Noto Sans KR","NotoSansKR-Regular";	
