.Static.sta_webGuide_unit_M,.Static.sta_webGuide_unit_M[status=mouseover]
{
	-nexa-text-align	: center;
	-nexa-padding 		: 0px 4px;
	color 			: #777777;
	font			: normal 400 26px/normal "Noto Sans KR","NotoSansKR-Regular";
}
/* RoundBox LIne Blue */
.Static.sta_webGuide_btnType_M,.Static.sta_webGuide_btnType_M[status=mouseover]
{
	-nexa-border		: 1px solid #2b72de;
	-nexa-padding 		: 0px 5px 1px 5px;
	-nexa-text-align 	: center;		
	background 		: #fafafa;
	color 			: #2b72de;
	font			: normal 400 24px/normal "Noto Sans KR","NotoSansKR-Regular";
	border-radius 		: 4px;
}]]></CSSData>
</XCSS>
