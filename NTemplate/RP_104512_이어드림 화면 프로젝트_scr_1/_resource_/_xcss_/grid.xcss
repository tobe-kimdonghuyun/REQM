/* Cell Background */
/* 중요이미지*/
.Grid .body .row .cell.cell_ImpNoti,
.Grid .body .row .cell.cell_ImpNoti[status=mouseover]
{
	-nexa-padding 		: 0px 0px 0px 120px;
	background 		: url('theme://images/grd_newNotice02.png') no-repeat left center #fafafa;
	font			: normal 400 18px/normal "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";	
}
.Grid .body .row .cell.cell_ImpNoti[userstatus=selected],
.Grid .body .row .cell.cell_ImpNoti[status=focused]
{
	-nexa-padding 		: 0px 0px 0px 120px;
	background 		: url('theme://images/grd_newNotice02.png') no-repeat left center #fafafa;
	-nexa-text-decoration 	: underline;
	font			: normal 700 18px/normal "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";
	color 			: #000000;	
}
.Grid .body .row .cell.cell_ImpTit,
.Grid .body .row .cell.cell_ImpTit[status=mouseover]
{
	-nexa-padding 		: 0px 0px 0px 30px;
	font			: normal 400 18px/normal "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";		
}
.Grid .body .row .cell.cell_ImpTit[status=focused],.Grid .body .row .cell.cell_ImpTit[userstatus=selected]
{
	-nexa-padding 		: 0px 0px 0px 30px;
	font			: normal 700 18px/normal "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";		
}
.Grid .body .row .cell.cell_ImpNoti02,
.Grid .body .row .cell.cell_ImpNoti02[status=mouseover]
{
	-nexa-padding 		: 0px 0px 0px 0px;
	background 		: #fafafa;
}
.Grid .body .row .cell.cell_ImpNoti02[userstatus=selected],
.Grid .body .row .cell.cell_ImpNoti02[status=focused]
{
	-nexa-text-decoration 	: underline;
	font			: normal 600 16px/normal "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";
	color 			: #000000;	
}

/* Cell 첨부파일 배경별 */
.Grid .body .row .cell.cell_FileAddGray,
.Grid .body .row .cell.cell_FileAddGray[status=mouseover],
.Grid .body .row .cell.cell_FileAddGray[userstatus=blinked],
.Grid .body .row .cell.cell_FileAddGray[status=disabled]
{
	background 		: url('theme://images/grd_download3.png') no-repeat center center #fafafa; 
}
.Grid .body .row .cell.cell_FileAddGray[status=focused],.Grid .body .row .cell.cell_FileAddGray[userstatus=selected]
{
	background 		: url('theme://images/grd_download3_O.png') no-repeat center center #fafafa; 
}
.Grid .body .row .cell.cell_FileAdd,
.Grid .body .row .cell.cell_FileAdd[status=mouseover],
.Grid .body .row .cell.cell_FileAdd[userstatus=blinked],
.Grid .body .row .cell.cell_FileAdd[status=disabled]
{
	background 		: url('theme://images/grd_download3.png') no-repeat center center #ffffff; 
}
.Grid .body .row .cell.cell_FileAdd[status=focused],.Grid .body .row .cell.cell_FileAdd[userstatus=selected]
{
	background 		: url('theme://images/grd_download3_O.png') no-repeat center center #ffffff; 
}

/* Cell Gray (#fafafa) */
.Grid .body .row .cell.cell_bgGray,
.Grid .body .row .cell.cell_bgGray[status=mouseover],
.Grid .body .row .cell.cell_bgGray[userstatus=blinked],
.Grid .body .row .cell.cell_bgGray[status=disabled]
{
	-nexa-background-odd 	: #fafafa;
	background 		: #fafafa;	
}
.Grid .body .row .cell.cell_bgGray[status=focused],.Grid .body .row .cell.cell_bgGray[userstatus=selected]
{
	-nexa-text-decoration 	: underline;
	font			: normal 700 16px/normal "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";
	color 			: #000000;  
	/*-nexa-background-odd 	: #eeeeee;
	background 		: #eeeeee;	*/
}
