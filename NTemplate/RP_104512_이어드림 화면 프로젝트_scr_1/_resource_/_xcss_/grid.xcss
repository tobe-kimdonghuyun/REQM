.Grid .body .row .cell.cell_txt28M[status=disabled]
{
	-nexa-text-align 	: center;
	font			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Medium","Malgun Gothic","Arial","MS PGothic";
	color 			: #222222;	
}
