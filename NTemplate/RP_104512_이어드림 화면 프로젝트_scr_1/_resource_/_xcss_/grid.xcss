<?xml version="1.0" encoding="utf-8"?>
<XCSS version="1.1">
  <Predefines/>
  <CSSData><![CDATA[/*******************	      GRID CSS        *******************/
		
/* Font 30x */
.Grid .body .row .cell.cell_txt30B,
.Grid .body .row .cell.cell_txt30B[status=mouseover],
.Grid .body .row .cell.cell_txt30B[status=focused],
.Grid .body .row .cell.cell_txt30B[userstatus=blinked],
.Grid .body .row .cell.cell_txt30B[userstatus=selected],
.Grid .body .row .cell.cell_txt30B[status=disabled]
{
	-nexa-text-align 	: center;
	font			: normal 700 30px/normal "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";
	color 			: #222222;
	letter-spacing 		: -1px;		
}
/* Font 28px */
.Grid .body .row .cell.cell_txt28M,
.Grid .body .row .cell.cell_txt28M[status=mouseover],
.Grid .body .row .cell.cell_txt28M[status=focused],
