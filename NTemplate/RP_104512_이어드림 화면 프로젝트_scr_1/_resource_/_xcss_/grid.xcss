{
	-nexa-text-decoration 	: underline;
	-nexa-border 		: 0px none;
	background 		: #f5f5f5;	
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";	
}
/* video button */
.Grid .body .row .cell.cell_btnVideoPlay .cellbutton,
.Grid .body .row .cell.cell_btnVideoPlay .cellbutton[status=disabled],
.Grid .body .row .cell.cell_btnVideoPlay .cellbutton[userstatus=pushed],
.Grid .body .row .cell.cell_btnVideoPlay .cellbutton[userstatus=selected]
{
	-nexa-border 		: 0px none;
	-nexa-icon 		: url('theme://images/grd_play.png');
	-nexa-padding 		: 0px;
	background 		: transparent;
	border-radius 		: 0px;	
	cursor 			: pointer;
}
.Grid .body .row .cell.cell_btnVideoPlay .cellbutton[status=focused],
.Grid .body .row .cell.cell_btnVideoPlay .cellbutton[status=mouseover]
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px;
	background 		: #f5f5f5;
}
/* 건수 회색배경, 흰색배경*/
.Grid .body .row .cell.cell_CountBGGray,
.Grid .body .row .cell.cell_CountBGGray[status=mouseover],
.Grid .body .row .cell.cell_CountBGGray[userstatus=selected],
.Grid .body .row .cell.cell_CountBGGray[status=focused]
{
	background 		: url('theme://images/grd_view.png') no-repeat center center #fafafa;
}
.Grid .body .row .cell.cell_CountBG,
.Grid .body .row .cell.cell_CountBG[status=mouseover],
.Grid .body .row .cell.cell_CountBG[userstatus=selected],
.Grid .body .row .cell.cell_CountBG[status=focused]
{
	background 		: url('theme://images/grd_view.png') no-repeat center center #ffffff;
}
/* 중요이미지 회색배경02*/
.Grid .body .row .cell.cell_StatusImportance,
.Grid .body .row .cell.cell_StatusImportance[status=mouseover],
.Grid .body .row .cell.cell_StatusImportance[userstatus=selected],
.Grid .body .row .cell.cell_StatusImportance[status=focused]
{
	background 		: url('theme://images/grd_newNotice.png') no-repeat center center #fafafa;
}
/* 진행중 이미지회색배경02*/
.Grid .body .row .cell.cell_status_progress,
.Grid .body .row .cell.cell_status_progress[status=mouseover],
.Grid .body .row .cell.cell_status_progress[userstatus=selected],
.Grid .body .row .cell.cell_status_progress[status=focused]
{
	background 		: url('theme://images/grd_status_process.png') no-repeat center center #fafafa;
}
/* 마감이미지*/
.Grid .body .row .cell.cell_status_end,
.Grid .body .row .cell.cell_status_end[status=mouseover],
.Grid .body .row .cell.cell_status_end[userstatus=selected],
.Grid .body .row .cell.cell_status_end[status=focused]
{
	background 		: url('theme://images/grd_status_end.png') no-repeat center center #ffffff;
}
/* 예정이미지*/
.Grid .body .row .cell.cell_status_todo,
.Grid .body .row .cell.cell_status_todo[status=mouseover],
.Grid .body .row .cell.cell_status_todo[userstatus=selected],
.Grid .body .row .cell.cell_status_todo[status=focused]
{
	background 		: url('theme://images/grd_status_todo.png') no-repeat center center #ffffff;
}
/*
***** 그리드 수정되면 삭제예정*****(0209)
status todo(예정사항) 
.Grid .body .row .cell.cell_status_todo .cellimage
{
	background 		: url('theme://images/grd_status_todo.png') no-repeat center center transparent;	
}
 status progressing(진행중) 
.Grid .body .row .cell.cell_status_progress .cellimage
{
	background 		: url('theme://images/grd_status_process.png') no-repeat center center transparent;
}
/* status deadline(마감) 
.Grid .body .row .cell.cell_status_end .cellimage
{
	background 		: url('theme://images/grd_status_end.png') no-repeat center center transparent;
}
*/
/* Service Ok (서비스 이용가능함) */
.Grid .body .row .cell.cell_serviceOk .cellimage
{
	background 		: url('theme://images/grd_serviceOk.png') no-repeat center center transparent;
}
/* LinkText button */
.Grid .body .row .cell.cell_link .cellbutton,
.Grid .body .row .cell.cell_link .cellbutton[status=disabled],
.Grid .body .row .cell.cell_link .cellbutton[userstatus=pushed],
.Grid .body .row .cell.cell_link .cellbutton[userstatus=selected]
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px;
	-nexa-text-align 	: left;	
	background 		: transparent;	
	color 			: #222222;
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
	letter-spacing		: -1px;
	border-radius 		: 0px;
	cursor 			: pointer;
}
.Grid .body .row .cell.cell_link .cellbutton[status=mouseover]
{
	-nexa-text-decoration 	: underline;
	-nexa-border 		: 0px none;
	background 		: transparent;	
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";	
}
.Grid .body .row .cell.cell_link .cellbutton[status=focused]
{
	-nexa-text-decoration 	: underline;
	-nexa-border 		: 0px none;
	background 		: #f5f5f5;	
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";	
}
/* Grid 이용문의/ 시·도교육청별 전화번호 목록 */
.Grid.grd_telList,
.Grid.grd_telList[status=mouseover],.Grid.grd_telList[status=focused],
.Grid.grd_telList[status=readonly],.Grid.grd_telList[status=disabled]
{
	-nexa-border 		: 0px none;
	background 		: #ffffff;
}
.Grid.grd_telList .head,
.Grid.grd_telList .head[status=mouseover],.Grid.grd_telList .head[status=focused],
.Grid.grd_telList .head[status=readonly],.Grid.grd_telList .head[status=disabled]
{
	-nexa-border 		: 0px none;
	background 		: #ffffff;
}

.Grid.grd_telList .body,
.Grid.grd_telList .body[status=disabled]
{
	background 		: #ffffff;
}
.Grid.grd_telList .body .row .cell,
.Grid.grd_telList .body .row .cell[status=mouseover],
.Grid.grd_telList .body .row .cell[userstatus=selected],
.Grid.grd_telList .body .row .cell[status=disabled]
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px;
	-nexa-text-align 	: left;
	font			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
	color 			: #222222;	
}
.Grid.grd_telList .body .row .cell[status=focused]
{
}
.Grid.grd_telList .vscrollbar,
.Grid.grd_telList .vscrollbar[status=disabled],
.Grid.grd_telList .vscrollbar[status=mouseover] 
{
	-nexa-border 		: 5px solid transparent;
	background 		: transparent;	
}
.Grid.grd_telList .vscrollbar .decbutton,
.Grid.grd_telList .vscrollbar .decbutton[userstatus=selected],
.Grid.grd_telList .vscrollbar .decbutton[status=mouseover],
.Grid.grd_telList .vscrollbar .decbutton[status=focused],
.Grid.grd_telList .vscrollbar .decbutton[userstatus=pushed],
.Grid.grd_telList .vscrollbar .decbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/none.png");
	background 		: transparent;	
}
.Grid.grd_telList .vscrollbar .incbutton,
.Grid.grd_telList .vscrollbar .incbutton[userstatus=selected],
.Grid.grd_telList .vscrollbar .incbutton[status=mouseover],
.Grid.grd_telList .vscrollbar .incbutton[status=focused],
.Grid.grd_telList .vscrollbar .incbutton[userstatus=pushed],
.Grid.grd_telList .vscrollbar .incbutton[status=disabled]
{
	-nexa-icon 		: URL("theme://images/none.png");
	background 		: transparent;	
}
.Grid.grd_telList .vscrollbar .trackbar
{
	-nexa-border 		: 0px none;
	border-radius 		: 4px;
}]]></CSSData>
