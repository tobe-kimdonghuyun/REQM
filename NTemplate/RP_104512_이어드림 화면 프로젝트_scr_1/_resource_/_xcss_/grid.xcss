	-nexa-color-odd 	: #595959;
	color 			: #595959;
}
/*** Icon Buttons ***/
/* Download button */
.Grid .body .row .cell.cell_btnDownload .cellbutton,
.Grid .body .row .cell.cell_btnDownload .cellbutton[status=disabled],
.Grid .body .row .cell.cell_btnDownload .cellbutton[status=mouseover],
.Grid .body .row .cell.cell_btnDownload .cellbutton[userstatus=pushed]
{
	-nexa-border 		: 0px none;
	-nexa-icon 		: url('theme://images/grd_download.png');
	-nexa-padding 		: 0px;
	background 		: transparent;		
	cursor 			: default;
}
.Grid .body .row .cell.cell_btnDownload .cellbutton[status=focused],.Grid .body .row .cell.cell_btnDownload .cellbutton[userstatus=selected]
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px;	
	background 		: #f5f5f5;
}
/* View button */
.Grid .body .row .cell.cell_btnView .cellbutton,
.Grid .body .row .cell.cell_btnView .cellbutton[status=disabled],
.Grid .body .row .cell.cell_btnView .cellbutton[status=mouseover],
.Grid .body .row .cell.cell_btnView .cellbutton[userstatus=pushed]
{
	-nexa-border 		: 0px none;
	-nexa-icon 		: url('theme://images/grd_view.png');
	-nexa-padding 		: 4px;
	cursor 			: default;
}
.Grid .body .row .cell.cell_btnView .cellbutton[status=focused],.Grid .body .row .cell.cell_btnView .cellbutton[userstatus=selected]
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 4px;
	background 		: #f5f5f5;
}
/* Notice */
.Grid.grd_notice,
.Grid.grd_notice[status=mouseover],.Grid.grd_notice[status=focused],
.Grid.grd_notice[status=readonly],.Grid.grd_notice[status=disabled]
{
	-nexa-border 		: 2px solid #222222,0px none,0px none;
	font			: normal 400 18px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Grid.grd_notice .head .row .cell,
.Grid.grd_notice .head .row .cell[status=mouseover],
.Grid.grd_notice .head .row .cell[status=readonly],
.Grid.grd_notice .head .row .cell[userstatus=blinked],
.Grid.grd_notice .head .row .cell[status=disabled]
{
	-nexa-border 		: 1px solid #eaeaea,0px none,1px solid #eaeaea;
}
.Grid.grd_notice .head .row .cell[status=focused]
{
	-nexa-text-decoration 	: underline;
	color 			: #000000; 		
}
.Grid.grd_notice .body .row .cell,
.Grid.grd_notice .body .row .cell[status=mouseover],
.Grid.grd_notice .body .row .cell[status=readonly],
.Grid.grd_notice .body .row .cell[userstatus=blinked],
.Grid.grd_notice .body .row .cell[status=disabled]
{
	-nexa-border 		: 1px solid #eaeaea,0px none,1px solid #eaeaea;
}
.Grid.grd_notice .body .row .cell[userstatus=selected],.Grid.grd_notice .body .row .cell[status=focused]
{
	-nexa-border 		: 1px solid #eaeaea,0px none,1px solid #eaeaea;
	-nexa-text-decoration 	: underline;
	font			: normal 700 18px/normal "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";
	color 			: #000000; 	
	/*background 		: #f5f5f5;	*/
}
/* Notice New button */
.Grid .body .row .cell.cell_btnNotice_new .cellbutton,
.Grid .body .row .cell.cell_btnNotice_new .cellbutton[status=disabled],
.Grid .body .row .cell.cell_btnNotice_new .cellbutton[userstatus=pushed],
.Grid .body .row .cell.cell_btnNotice_new .cellbutton[userstatus=selected]
{
	-nexa-border 		: 0px none;
	-nexa-icon 		: url('theme://images/grd_newNotice.png');
	-nexa-padding 		: 0px 0px 0px 30px;
	-nexa-icon-position 	: left;
	-nexa-text-padding 	: 0px 0px 0px 20px;
	-nexa-vertical-align 	: middle;
	-nexa-text-align 	: left;	
	background 		: transparent;	
	color 			: #222222;
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
	letter-spacing 		: -1px;
	border-radius 		: 0px;
	cursor 			: pointer;
}
.Grid .body .row .cell.cell_btnNotice_new .cellbutton[status=mouseover]
{
	-nexa-text-decoration 	: underline;
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px 0px 0px 30px;	
	background 		: transparent;	
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";	
}
