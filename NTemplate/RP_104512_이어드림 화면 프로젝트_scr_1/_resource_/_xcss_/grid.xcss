{
	-nexa-padding 		: 0px 0px 1px;	
	-nexa-background-odd 	: url('theme://images/grd_roundBox_blue.png') no-repeat center center #f5f5f5;
	background 		: url('theme://images/grd_roundBox_blue.png') no-repeat center center #f5f5f5;
}
