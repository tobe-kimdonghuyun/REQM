{
	-nexa-padding 		: 0px 0px 1px;
	color 			: #ffffff;
	background 		: url('theme://images/grd_roundBox_blue.png') no-repeat center center transparent;
	font 			: normal 400 14px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";			
}
