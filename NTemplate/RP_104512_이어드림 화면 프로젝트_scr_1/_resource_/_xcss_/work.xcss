}
/* 대국민 마크 */
.Static.sta_WF_mark01,.Static.sta_WF_mark01[status=mouseover]
{
	-nexa-padding		: 0px 2px 0px 27px;
	background 		: url('theme://images/sta_WF_mark01.png') no-repeat left center transparent;
	font			: normal 500 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
	color 			: #222222;	
}
/* FAQ Question Hang */
.Static.sta_FAQ_hang
{
	-nexa-padding		: 1px 10px 2px 4px;
	-nexa-vertical-align 	: top;	
	color 			: #222222;
	cursor 			: pointer;
	font			: normal 400 17px/1.5 "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Static.sta_FAQ_hang[status=mouseover]
{
	-nexa-text-decoration 	: underline;
}
.Static.sta_FAQ_hang_S
{
	-nexa-padding		: 1px 10px 2px 4px;
	-nexa-vertical-align 	: top;	
	color 			: #2b72de;
	cursor 			: pointer;	
	font			: normal 700 17px/1.5 "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";
}
.Static.sta_FAQ_hang_S[status=mouseover]
{
	-nexa-text-decoration 	: underline;
}
/* FAQ Answer */
.Static.sta_FAQ_answer,.Static.sta_FAQ_answer[status=mouseover]
{
	-nexa-padding		: 1px 10px 2px 4px;
	-nexa-vertical-align 	: top;	
	color 			: #222222;
	font			: normal 400 17px/1.5 "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
/* map bg */
.Static.sta_Map_bg,.Static.sta_Map_bg[status=mouseover]
{
	background 		: url('imagerc::common/bg_map.jpg') no-repeat center top transparent;
}
/* Notice View counter */
.Static.sta_WF_notice_counter,
.Static.sta_WF_notice_counter[status=mouseover],
.Static.sta_WF_notice_counter[status=disabled]
{
	-nexa-border 		: 1px solid transparent;
	-nexa-text-align 	: left;
	-nexa-padding 		: 0px 4px 1px 4px;		
	background 		: transparent;
	font			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
	color 			: #222222;
}
/*** 웹접근성 정책 Div Round Grid ***/
/* Round Line Box Radius 20px Div */
.Div.div_roundBox20_line,
.Div.div_roundBox20_line[status=focused],.Div.div_roundBox20_line[status=mouseover]
{
	-nexa-border 		: 1px solid #d9d9d9;
	background 		: #ffffff;
	border-radius 		: 20px;
}
/* Round BG Box Radius 20px Div */
.Div.div_roundBox20_BG,
.Div.div_roundBox20_BG[status=focused],.Div.div_roundBox20_BG[status=mouseover]
{
	background 		: #fafafa;
	border-radius 		: 20px;
}
/* Web Guide Detail Div(top border 1px #eaeaea) */
.Div.div_webGuide_detail,
.Div.div_webGuide_detail[status=focused],.Div.div_webGuide_detail[status=mouseover]
{
	-nexa-border 		: 1px solid #eaeaea, 0px none, 0px none;
	background 		: #ffffff;
}
.Static.sta_webGuide_detailLabel,.Static.sta_webGuide_detailLabel[status=mouseover]
{
	-nexa-border 		: 0px none, 0px none, 1px solid #eaeaea;
	-nexa-text-align	: center;
	background 		: #fafafa;
	color 			: #222222;
	letter-spacing 		: -1px;		
	font			: normal 700 16px/normal "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";
}
.Static.sta_webGuide_detailBG,.Static.sta_webGuide_detailBG[status=mouseover]
{
	-nexa-border 		: 0px none,0px none,1px solid #eaeaea;
	-nexa-text-align	: left;
	-nexa-padding 		: 0px 30px 1px 28px;
	background 		: #ffffff;
	color 			: #222222;
	letter-spacing 		: -1px;		
	font			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Static.sta_webGuide_unit,.Static.sta_webGuide_unit[status=mouseover]
{
	-nexa-text-align	: center;
	-nexa-padding 		: 0px 9px;
	color 			: #777777;
	font			: normal 400 18px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
/* RoundBox LIne Blue */
.Static.sta_webGuide_btnType,.Static.sta_webGuide_btnType[status=mouseover]
{
	-nexa-border		: 1px solid #2b72de;
	-nexa-padding 		: 0px 5px 1px 5px;
	-nexa-text-align 	: center;		
	background 		: #fafafa;
	color 			: #2b72de;
	font			: normal 400 13px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
	border-radius 		: 4px;
}
/* 홍보캐릭터 bg */
.Static.sta_WF_CharacterBG,.Static.sta_WF_CharacterBG[status=mouseover]
{
	-nexa-border 		: 1px solid #ebebeb;
	border-radius 		: 20px;
	background 		: #ffffff;
	box-shadow 		: 0px 5px 20px 0px rgba(0,0,0,0.06);
}
/* main Top 100px height padding */
.Form.main .vscrollbar,
.Form.main .vscrollbar[status=mouseover],
.Form.main .vscrollbar[status=disabled]
{
	-nexa-border 		: 100px solid transparent, 0px none, 0px none;
} ]]></CSSData>
</XCSS>
