.Button.btn_WF_boardList_blue[status=disabled]
{
	-nexa-border 		: 1px solid #d9d9d9;
	background 		: #ffffff;
	color			: #d9d9d9;
}
/* Form Online Complaints Area Button */
.Button.btn_WF_area
{
	-nexa-border 		: 1px solid #d9d9d9;
	-nexa-padding 		: 0px 30px 1px 30px;
	background 		: #fafafa;
	border-radius 		: 0px;
	color 			: #222222;
	font 			: normal 400 18px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_WF_area[status=focused]
{
	-nexa-border 		: 1px solid #222222;
	-nexa-padding 		: 0px 30px 1px 30px;
}
.Button.btn_WF_area[status=mouseover],
.Button.btn_WF_area[userstatus=pushed]
{
	-nexa-border 		: 1px solid #2d73de;
	background 		: #2d73de;
	color 			: #ffffff;
}
.Button.btn_WF_area[status=disabled]
{
	-nexa-border 		: 1px solid #d9d9d9;
	background 		: #fafafa;
	color			: #d9d9d9;
}
/* Form Online Complaints Area Selected Button */
.Button.btn_WF_area_S,
.Button.btn_WF_area_S[status=mouseover],
.Button.btn_WF_area_S[userstatus=pushed]
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 30px 1px 30px;
	background 		: #2d73de;
	border-radius 		: 0px;
	color 			: #ffffff;
	font 			: normal 400 18px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_WF_area_S[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 30px 1px 30px;
}
.Button.btn_WF_area_S[status=disabled]
{
	background 		: #d9d9d9; 
}
/* Form Main Shortcuts Button */
.Button.btn_WF_shortcuts
{
	-nexa-border 		: 1px solid #d9d9d9;
	-nexa-padding 		: 0px 50px 1px 49px;
	background 		: #ffffff;
	border-radius 		: 25px;
	color 			: #222222;
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_WF_shortcuts[status=focused]
{
	-nexa-border 		: 1px solid #222222;
	-nexa-padding 		: 0px 50px 1px 49px;
}
.Button.btn_WF_shortcuts[status=mouseover],
.Button.btn_WF_shortcuts[userstatus=pushed]
{
	-nexa-border 		: 1px solid #2d73de;
	background 		: #2d73de;
	color 			: #ffffff;
}
.Button.btn_WF_shortcuts[status=disabled]
{
	-nexa-border 		: 1px solid #d9d9d9;
	background 		: #ffffff;
	color			: #d9d9d9;
}
/* Form WF Quick Link Button (어두운배경에서 사용)*/
.Button.btn_WF_quickLink
{
	-nexa-border 		: 1px solid #ffffff;
	-nexa-padding 		: 0px 40px 1px 40px;
	background 		: #ffffff;
	border-radius 		: 26px;
	color 			: #222222;
	font 			: normal 500 14px/normal "Noto Sans KR","NotoSansKR-Medium","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_WF_quickLink[status=focused]
{
	-nexa-border 		: 1px solid #2b72de;
	-nexa-padding 		: 0px 40px 1px 40px;
}
.Button.btn_WF_quickLink[status=mouseover],
.Button.btn_WF_quickLink[userstatus=pushed]
{
	-nexa-border 		: 1px solid #2d73de;
	background 		: #2d73de;
	color 			: #ffffff;
}
.Button.btn_WF_quickLink[status=disabled]
{
	-nexa-border 		: 1px solid #ffffff;
	background 		: #ffffff;
	color			: #d9d9d9;
}
/* Form Tab(text) Button */
.Button.btn_WF_tab
{
	-nexa-border 		: 1px solid transparent;
	-nexa-padding 		: 0px 22px 1px 22px;
	background 		: #f5f5f5;
	border-radius 		: 20px;
	color 			: #222222;
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_WF_tab[status=focused]
{
	-nexa-border 		: 1px solid #000000;
	-nexa-padding 		: 0px 22px 1px 22px;
}
.Button.btn_WF_tab[status=mouseover],.Button.btn_WF_tab[userstatus=pushed]
{
	-nexa-border 		: 1px solid #2d73de;
	background 		: #f5f5f5;
}
.Button.btn_WF_tab[status=disabled]
{
	background 		: #ffffff;
	color			: #d9d9d9;
}
.Button.btn_WF_tab_S,
.Button.btn_WF_tab_S[status=mouseover],
.Button.btn_WF_tab_S[userstatus=pushed]
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 20px 1px 20px;
	background 		: #2d73de;
	border-radius 		: 20px;
	color 			: #ffffff;
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
