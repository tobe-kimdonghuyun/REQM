}
/* HangTxt */
.Static.sta_WF_HangTxt_blue,.Static.sta_WF_HangTxt_blue[status=mouseover]
{
	color			: #222222;
	font 			: normal 400 18px/1.5 "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
	background 		: url('theme://images/bul_hangBlue_top.png') no-repeat left top transparent;
	-nexa-padding 		: 2px 0px 0px 17px;
	letter-spacing 		: -1px;
	-nexa-vertical-align 	: top;
}
.Static.sta_WF_HangTxt_Skyblue,.Static.sta_WF_HangTxt_Skyblue[status=mouseover]
{
	color			: #222222;
	font 			: normal 400 16px/1.5 "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
	background 		: url('theme://images/bul_hangSkyblue_top.png') no-repeat left top transparent;
	-nexa-padding 		: 2px 0px 0px 17px;
	letter-spacing 		: -1px;
	-nexa-vertical-align 	: top;
}
.Static.sta_WF_HangTxt_black,.Static.sta_WF_HangTxt_black[status=mouseover]
{
	-nexa-padding 		: 2px 0px 0px 17px;
	-nexa-vertical-align 	: top;	
	color			: #222222;
	font 			: normal 400 16px/1.5 "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
	background 		: url('theme://images/bul_hangBlack_top.png') no-repeat left top;
	letter-spacing 		: -1px;
}
.Static.sta_WF_HangTxt_black01,.Static.sta_WF_HangTxt_black01[status=mouseover]
{
	-nexa-padding 		: 2px 0px 0px 0px;
	-nexa-vertical-align 	: top;	
	color			: #222222;
	font 			: normal 400 16px/1.5 "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
	background 		: transparent;
	letter-spacing 		: -1px;
}
/* Form Popup Button */
.Button.btn_WF_popup
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 66px 1px 65px;
	background 		: #2B72DE;
