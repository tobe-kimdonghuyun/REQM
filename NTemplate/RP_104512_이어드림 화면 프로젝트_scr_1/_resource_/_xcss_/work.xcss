{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 20px 1px 20px;
}
.Button.btn_WF_tab_S[status=disabled]
{
	background 		: #d9d9d9; 
}
/* Hang Div */
.Div.div_WF_hang,
.Div.div_WF_hang[status=focused],.Div.div_WF_hang[status=mouseover]
{
	border-radius 		: 20px;
	background 		: #ffffff;
	-nexa-border 		: 1px solid #eaeaea;
}
/* Shadow Box Div(right bottom)) */
.Div.div_WF_shadowBox,
.Div.div_WF_shadowBox[status=focused],.Div.div_WF_shadowBox[status=mouseover]
{
	border-radius 		: 20px;
	background 		: #ffffff;
	-nexa-border 		: 1px solid #eaeaea;
	box-shadow 		: 10px 10px 12px 0px rgba(0,0,0,0.03);
}
.Div.div_WF_SummaryBox,
.Div.div_WF_SummaryBox[status=focused],.Div.div_WF_SummaryBox[status=mouseover]
{
	border-radius 		: 20px;
	background 		: #ffffff;
