<?xml version="1.0" encoding="utf-8"?>
<XCSS version="1.1">
  <Predefines/>
  <CSSData><![CDATA[/*** Search Area ***/
.Div.div_SA,
.Div.div_SA[status=focused],.Div.div_SA[status=mouseover]
{
	border-radius 		: 12px;
	background 		: #f5f5f5;
}
/* Label */
.Static.sta_SA_label,.Static.sta_SA_label[status=mouseover]
{
	color			: #222222;
	font 			: normal 700 17px/normal "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";
}
/* ~,- , 단위 */
.Static.sta_SA_unit,.Static.sta_SA_unit[status=mouseover]
{
	-nexa-padding 		: 0px 13px 1px 13px;	
	color			: #222222;
	font 			: normal 700 14px/normal "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";
}
/* Search Button */
.Button.btn_SA_search
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px 10px 1px 10px;
	background 		: #2B72DE;
	color 			: #ffffff;
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_SA_search[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 9px 1px 9px;
}
.Button.btn_SA_search[status=mouseover],
.Button.btn_SA_search[userstatus=pushed]
{
	-nexa-text-decoration 	: none;
	background 		: #1A56B2;
	color 			: #ffffff;
}
.Button.btn_SA_search[status=disabled]
{
	background 		: #d9d9d9;
}
.Button.btn_SA_CRUD
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px 10px 1px 10px;
	background 		: #2a3b64;
	color 			: #ffffff;
	font 			: normal 400 14px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_SA_CRUD[status=focused]
{
	-nexa-border 		: 2px dotted #ffffff;
	-nexa-padding 		: 0px 9px 1px 9px;
}
.Button.btn_SA_CRUD[status=mouseover],
.Button.btn_SA_CRUD[userstatus=pushed]
{
	-nexa-text-decoration 	: none;
	background 		: #2a3b64;
	color 			: #ffffff;
}
.Button.btn_SA_CRUD[status=disabled]
{
	background 		: #d9d9d9;
}
/* Reset Button */
.Button.btn_SA_reset
{
	-nexa-border 		: 1px solid #d9d9d9;
	-nexa-padding 		: 0px 10px 1px 10px;
	background 		: #ffffff;
	color 			: #222222;
	font 			: normal 500 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_SA_reset[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 10px 1px 10px;
}
.Button.btn_SA_reset[status=mouseover],
.Button.btn_SA_reset[userstatus=pushed]
{
	-nexa-border 		: 1px solid #222222;
	-nexa-text-decoration 	: none;
	background 		: #ffffff;
	color 			: #222222;
}
.Button.btn_SA_reset[status=disabled]
{
	background 		: transparent;
	color 			: #d9d9d9;	
}
/* Sub Top Image RoundBox display */
.ImageViewer.Roundbox20,
.ImageViewer.Roundbox20[status=mouseover],
.ImageViewer.Roundbox20[status=focused],
.ImageViewer.Roundbox20[status=disabled]
{
	-nexa-border 		: 0px none;
	border-radius 		: 20px;
	background 		: #ffffff;
}
/* Sub Top Image RoundBox Shadowdisplay */
.ImageViewer.Roundbox20_shadow,
.ImageViewer.Roundbox20_shadow[status=mouseover],
.ImageViewer.Roundbox20_shadow[status=focused],
.ImageViewer.Roundbox20_shadow[status=disabled]
{
	-nexa-border 		: 0px none;
	border-radius 		: 20px;
	box-shadow 		: 0px 10px 16px 0px rgba(0,0,0,0.07);
	background 		: #ffffff;
}
/* Form Download Button */
.Button.btn_WF_formDownload
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px 35px 1px 35px;
	-nexa-icon		: url('theme://images/icon_download_w.png');
	-nexa-text-padding	: 0px 0px 0px 7px;
	-nexa-icon-position	: left;	
	background 		: #2B72DE;
	color 			: #ffffff;
	font 			: normal 400 14px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_WF_formDownload[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 33px 1px 33px;
}
.Button.btn_WF_formDownload[status=mouseover],
.Button.btn_WF_formDownload[userstatus=pushed]
{
	-nexa-text-decoration 	: none;
	background 		: #1A56B2; 
}
.Button.btn_WF_formDownload[status=disabled]
{
	background 		: #d9d9d9;
}
/* Form ServiceLink Button */
.Button.btn_WF_serviceLink
{
	-nexa-border 		: 1px solid #d9d9d9;
	-nexa-padding 		: 0px 27px 1px 28px;
	-nexa-icon		: url('theme://images/icon_linkArrow_B.png');
	-nexa-text-padding	: 0px 70px 0px 0px;
	-nexa-icon-position	: right;	
	background 		: #ffffff;
	color 			: #222222;
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_WF_serviceLink[status=focused]
{
	-nexa-border 		: 1px solid #222222;
	-nexa-padding 		: 0px 27px 1px 28px;
}
.Button.btn_WF_serviceLink[status=mouseover],
.Button.btn_WF_serviceLink[userstatus=pushed]
{
	-nexa-border 		: 1px solid #000000;
	-nexa-icon		: url('theme://images/icon_linkArrow_W.png');	
	-nexa-text-decoration 	: none;
	background 		: #000000;
	color 			: #ffffff;
}
.Button.btn_WF_serviceLink[status=disabled]
{
	-nexa-border 		: 1px solid #d9d9d9;
	-nexa-icon		: url('theme://images/icon_linkArrow_G.png');	
	background 		: #ffffff;
	color 			: #d9d9d9;
}
/* Form ServiceLink Blue Button */
.Button.btn_WF_serviceLink_blue
{
	-nexa-border 		: 1px solid #2b72de;
	-nexa-text-align 	: center;
	-nexa-padding 		: 0px 27px 1px 28px;
	background 		: #ffffff;
	color 			: #2b72de;
	font 			: bold 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_WF_serviceLink_blue[status=focused]
{
	-nexa-border 		: 1px solid #000000;
	-nexa-padding 		: 0px 27px 1px 28px;
}
.Button.btn_WF_serviceLink_blue[status=mouseover],
.Button.btn_WF_serviceLink_blue[userstatus=pushed]
{
	-nexa-border 		: 1px solid #2b72de;
	-nexa-text-decoration 	: none;
	background 		: #2b72de;
	color 			: #ffffff;
}
.Button.btn_WF_serviceLink_blue[status=disabled]
{
	-nexa-border 		: 1px solid #d9d9d9;
	background 		: #ffffff;
	color 			: #d9d9d9;
}
/* Form ServiceLink Blue Button */
.Button.btn_WF_serviceLink_blue01
{
	-nexa-border 		: 1px solid #2b72de;
	-nexa-text-align 	: center;
	-nexa-padding 		: 0px 10px 1px 10px;
	background 		: #ffffff;
	color 			: #2b72de;
	font 			: normal 500 14px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_WF_serviceLink_blue01[status=focused]
{
	-nexa-border 		: 1px solid #000000;
	-nexa-padding 		: 0px 10px 1px 10px;
}
.Button.btn_WF_serviceLink_blue01[status=mouseover],
.Button.btn_WF_serviceLink_blue01[userstatus=pushed]
{
	-nexa-border 		: 1px solid #2b72de;
	-nexa-text-decoration 	: none;
	background 		: #2b72de;
	color 			: #ffffff;
}
.Button.btn_WF_serviceLink_blue01[status=disabled]
{
	-nexa-border 		: 1px solid #d9d9d9;
	background 		: #ffffff;
	color 			: #d9d9d9;
}
/* Form Notice Popup Button */
.Button.btn_WF_noticePop
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 70px 1px 70px;
	background 		: #2B72DE;
	color 			: #ffffff;
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_WF_noticePop[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 70px 1px 70px;
}
.Button.btn_WF_noticePop[status=mouseover],
.Button.btn_WF_noticePop[userstatus=pushed]
{
	background 		: #1A56B2; 
}
.Button.btn_WF_noticePop[status=disabled]
{
	background 		: #d9d9d9;
}
/* Form 404 Error Back Button */
.Button.btn_WF_errorBack
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 90px 1px 90px;
	background 		: #2B72DE;
	color 			: #ffffff;
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_WF_errorBack[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 90px 1px 90px;
}
.Button.btn_WF_errorBack[status=mouseover],
.Button.btn_WF_errorBack[userstatus=pushed]
{
	background 		: #1A56B2; 
}
.Button.btn_WF_errorBack[status=disabled]
{
	background 		: #d9d9d9;
}
.Button.btn_WF_googleDownload
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 47px 1px 47px;
	-nexa-icon		: url('theme://images/icon_google.png');
	-nexa-text-padding	: 0px 0px 0px 7px;
	-nexa-icon-position	: left;	
	background 		: #2B72DE;
	color 			: #ffffff;
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_WF_googleDownload[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 47px 1px 47px;
}
.Button.btn_WF_googleDownload[status=mouseover],
.Button.btn_WF_googleDownload[userstatus=pushed]
{
	background 		: #1A56B2;
}
.Button.btn_WF_googleDownload[status=disabled]
{
	background 		: #d9d9d9;
}
.Button.btn_WF_appDownload
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 38px 1px 38px;
	-nexa-icon		: url('theme://images/icon_appStore_N.png');
	-nexa-text-padding	: 0px 0px 0px 7px;
	-nexa-icon-position	: left;	
	background 		: #2B72DE;
	color 			: #ffffff;
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_WF_appDownload[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 38px 1px 38px;
}
.Button.btn_WF_appDownload[status=mouseover],
.Button.btn_WF_appDownload[userstatus=pushed]
{
	background 		: #1A56B2;
}
.Button.btn_WF_appDownload[status=disabled]
{
	background 		: #d9d9d9;
}
/* Form Bulletin details area Button */
.Button.btn_WF_boardList
{
	-nexa-border 		: 1px solid #d9d9d9;
	-nexa-padding 		: 0px 104px 1px 104px;
	background 		: #ffffff;
	color 			: #222222;
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_WF_boardList[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 103px 1px 103px;
}
.Button.btn_WF_boardList[status=mouseover],
.Button.btn_WF_boardList[userstatus=pushed]
{
	-nexa-border 		: 1px solid #2B72DE;
	background 		: #2B72DE;
	color 			: #ffffff;
}
.Button.btn_WF_boardList[status=disabled]
{
	-nexa-border 		: 1px solid #d9d9d9;
	background 		: #ffffff;
	color			: #d9d9d9;
}
/* Form Bulletin details area Blue Button */
.Button.btn_WF_boardList_blue
{
	-nexa-border 		: 1px solid #2b72de;
	-nexa-padding 		: 0px 50px 1px 50px;
	background 		: #ffffff;
	color 			: #2b72de;
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_WF_boardList_blue[status=focused]
{
	-nexa-border 		: 1px solid #222222;
	-nexa-padding 		: 0px 50px 1px 50px;
}
.Button.btn_WF_boardList_blue[status=mouseover],
.Button.btn_WF_boardList_blue[userstatus=pushed]
