/* Menu 1Depth Button */
.Button.btn_Pop_menu_lev1
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 74px 3px 46px;
	-nexa-text-align	: left;	
	-nexa-vertical-align 	: middle;
	border-radius 		: 0px;		
	background 		: transparent;
	color 			: #444444;
	font 			: normal 400 30px/normal "Noto Sans KR","NotoSansKR-Regular";
}
.Button.btn_Pop_menu_lev1[status=focused]
{
