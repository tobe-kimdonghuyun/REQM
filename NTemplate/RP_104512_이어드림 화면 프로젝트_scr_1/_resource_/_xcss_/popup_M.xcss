<?xml version="1.0" encoding="utf-8"?>
<XCSS version="1.1">
  <Predefines/>
  <CSSData><![CDATA[/*******************	      POPUP Mobile       *******************/

/* Background #000000 40% */
.Form.frm_Pop_bg40,
.Form.frm_Pop_bg40[status=disabled],
.Form.frm_Pop_bg40[status=focused],
.Form.frm_Pop_bg40[status=mouseover]
{
	background 		: rgba(0,0,0,0.4);
}
/*  Menu */
.Div.div_Pop_menuGroup,
.Div.div_Pop_menuGroup[status=focused],.Div.div_Pop_menuGroup[status=mouseover]
{
	background 		: #ffffff;
}
.Div.div_Pop_menuSub,
.Div.div_Pop_menuSub[status=focused],.Div.div_Pop_menuSub[status=mouseover]
{
	background 		: #f7f7f7;
}
.Button.btn_Pop_menu_lev0
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 74px 3px 46px;
	-nexa-text-align	: left;	
	-nexa-vertical-align 	: middle;	
	background 		: url('imagerc::common_M/icon_sitemap_menu0_N.png') no-repeat right center #ffffff;
	border-radius 		: 0px;		
	color 			: #000000;
	font 			: normal 500 30px/normal "Noto Sans KR","NotoSansKR-Medium";
}
.Button.btn_Pop_menu_lev0[status=focused]
{
	-nexa-border 		: 2px dashed #000000;
	-nexa-padding 		: 0px 74px 3px 46px;
	background 		: url('imagerc::common_M/icon_sitemap_menu0_N.png') no-repeat right center #ffffff;	
}
.Button.btn_Pop_menu_lev0[status=mouseover],
.Button.btn_Pop_menu_lev0[userstatus=pushed]
{
	-nexa-border 		: 2px solid transparent;
	background 		: url('imagerc::common_M/icon_sitemap_menu0_S.png') no-repeat right center #ffffff;	
	color 			: #2b72de;	
}
.Button.btn_Pop_menu_lev0[status=disabled]
{
	-nexa-border 		: 0px none;
	background 		: url('imagerc::common_M/icon_sitemap_menu0_N.png') no-repeat right center #ffffff;	
	color 			: #d9d9d9;		
}
.Button.btn_Pop_menu_lev0_subNone
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 74px 3px 46px;
	-nexa-text-align	: left;	
	-nexa-vertical-align 	: middle;	
	background 		: #ffffff;
	border-radius 		: 0px;		
	color 			: #000000;
	font 			: normal 500 30px/normal "Noto Sans KR","NotoSansKR-Medium";
}
.Button.btn_Pop_menu_lev0_subNone[status=focused]
{
	-nexa-border 		: 2px dashed #000000;
	-nexa-padding 		: 0px 74px 3px 46px;
	background 		: #ffffff;	
}
.Button.btn_Pop_menu_lev0_subNone[status=mouseover],
.Button.btn_Pop_menu_lev0_subNone[userstatus=pushed]
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 74px 3px 46px;
	background 		: #ffffff;	
	color 			: #2b72de;	
}
.Button.btn_Pop_menu_lev0_subNone[status=disabled]
{
	-nexa-border 		: 0px none;
	background 		: #ffffff;	
	color 			: #d9d9d9;		
}
