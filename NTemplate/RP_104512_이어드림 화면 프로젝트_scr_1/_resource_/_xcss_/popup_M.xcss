	-nexa-padding 		: 0px 74px 3px 46px;
	background 		: transparent;	
}
.Button.btn_Pop_menu_lev1[status=mouseover],
.Button.btn_Pop_menu_lev1[userstatus=pushed]
{
	-nexa-border 		: 2px solid transparent;
	background 		: transparent;	
