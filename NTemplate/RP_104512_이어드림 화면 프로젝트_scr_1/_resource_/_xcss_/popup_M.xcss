.MaskEdit.display_font26,
.MaskEdit.display_font26[status=mouseover],
.MaskEdit.display_font26[userstatus=nulltext],
.MaskEdit.display_font26[status=focused],
.MaskEdit.display_font26[status=readonly],
.MaskEdit.display_font26[status=disabled]
{
	-nexa-border 		: 1px solid transparent;
	-nexa-padding 		: 0px 8px 1px;
	-nexa-text-align	: left;	
	background		: transparent;
	font 			: normal 400 26px/normal "Noto Sans KR","NotoSansKR-Regular";	
	color 			: #222222;	
}
/* Shadow Box PopupDiv(center) */
.Div.div_Pop_shadowBox_C_M,
.Div.div_Pop_shadowBox_C_M[status=focused],.Div.div_Pop_shadowBox_C_M[status=mouseover]
{
	border-radius : 14px;
	background : #ffffff;
	box-shadow : 0px 30px 30px 0px rgba(0,0,0,0.1);
}
