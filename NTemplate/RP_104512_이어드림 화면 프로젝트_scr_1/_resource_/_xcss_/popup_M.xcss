.Button.btn_Pop_menu_lev0_S[status=mouseover],
.Button.btn_Pop_menu_lev0_S[userstatus=pushed]
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 74px 3px 46px;
	-nexa-text-align	: left;	
	-nexa-vertical-align 	: middle;
