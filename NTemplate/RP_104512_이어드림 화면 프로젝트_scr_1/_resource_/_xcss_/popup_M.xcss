}
.Edit.edt_GNB_search_M[status=mouseover]
{
	-nexa-border 		: 2px solid #ffffff;
}
.Edit.edt_GNB_search_M[status=focused]
{
	-nexa-border 		: 2px solid #ffffff;
}
.Edit.edt_GNB_search_M[status=readonly]
{
	-nexa-border 		: 2px solid #ffffff;
	background 		: #ffffff;
	color 			: #000000;
}
.Edit.edt_GNB_search_M[userstatus=nulltext]
{
	color          		: #b6b4b4;
}
.Edit.edt_GNB_search_M[status=disabled]
{
	-nexa-border 		: 2px solid #ffffff;
	background 		: #ffffff;
	color 			: #d9d9d9;
}
.Static.sta_GNB_bg_M,.Static.sta_GNB_bg_M[status=mouseover]
{
	background 		: #ffffff;
	box-shadow 		: 0px 30px 30px 0px rgba(0,0,0,0.15);
}
.Static.sta_Notice_bg_M,.Static.sta_Notice_bg_M[status=mouseover]
{
	background 		: #f5f5f5;
	border-radius 		: 20px;
}
.Static.sta_Notice_bg01_M,.Static.sta_Notice_bg01_M[status=mouseover]
{
	-nexa-text-align 	: center;
	-nexa-padding 		: 0px 0px 2px 0px ;
	background 		: #2b72de;
	border-radius 		: 50px;
	color 			: #ffffff;
	font 			: normal 400 22px "Noto Sans KR","NotoSansKR-Medium","Malgun Gothic","Arial","MS PGothic";	
}
/* GNB Search line */
.Static.sta_GNB_line_M,.Static.sta_GNB_line_M[status=mouseover]
{
	-nexa-border 		: 2px solid #222222, 0px none, 0px none;
}
/* GNB Search LinkText Mobile Button */
.Button.btn_GNB_txtLink_M,
.Button.btn_GNB_txtLink_M[userstatus=pushed]
{
	-nexa-border 		: 2px solid #eaeaea;
	-nexa-padding 		: 0px 30px 1px 30px;
	-nexa-text-align	: center;
	border-radius 		: 25px;	
	background 		: #ffffff;
	color 			: #444444;
	font 			: normal 500 24px/normal "Noto Sans KR","NotoSansKR-Medium";
}
.Button.btn_GNB_txtLink_M[status=mouseover],
.Button.btn_GNB_txtLink_M[status=focused]
{
	-nexa-border 		: 2px solid #2b72de;
	-nexa-padding 		: 0px 30px 1px 30px;	
	background 		: #2b72de;
	color 			: #ffffff;	
}
.Button.btn_GNB_txtLink_M[status=disabled]
{
	-nexa-border 		: 2px solid #d9d9d9;
	background 		: #ffffff;
	color			: #d9d9d9;	
}
/* Combo_M Blue Button */
.Button.btn_POP_UserCombo_M,
.Button.btn_POP_UserCombo_M[status=mouseover],
.Button.btn_POP_UserCombo_M[userstatus=pushed],.Button.btn_POP_UserCombo_M[status=disabled]
{
	-nexa-border 		: 2px solid #2b72de;
	-nexa-padding 		: 0px 20px 1px 20px;
	border-radius 		: 16px;		
	background 		: #ffffff;
	color 			: #2b72de;
	font 			: normal 400 28px/normal "Noto Sans KR","NotoSansKR-Bold";
}
.Button.btn_POP_UserCombo_M[status=focused]
{
	-nexa-border 		: 2px solid #2b72de;
	-nexa-padding 		: 0px 20px 1px 20px;
	-nexa-text-decoration 	: underline;
	font 			: normal 700 28px/normal "Noto Sans KR","NotoSansKR-Bold";
}
]]></CSSData>
</XCSS>
