{
	-nexa-border 		: 0px none;
	background 		: transparent;
	color 			: #d9d9d9;		
}
/* Popup Menu serviceLink 나이스플러스Button */
.Button.btn_Pop_menu_serviceLink1
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 10px 7px 0px 7px;
	-nexa-text-align	: center;
	-nexa-icon		: url('imagerc::common_M/icon_serviceLink_neisPlus.png');
	-nexa-text-padding	: 23px 0px 0px 0px;
	-nexa-icon-position	: top;
	border-radius 		: 16px;		
	background 		: transparent;
	color 			: #222222;
	font 			: normal 400 28px/1.5 "Noto Sans KR","NotoSansKR-Regular";
}
.Button.btn_Pop_menu_serviceLink1[status=focused]
{
	-nexa-border 		: 2px dashed #000000;
	-nexa-padding 		: 10px 7px 0px 7px;
}
.Button.btn_Pop_menu_serviceLink1[status=mouseover],
.Button.btn_Pop_menu_serviceLink1[userstatus=pushed]
{
	-nexa-border 		: 2px solid transparent;
	-nexa-text-decoration 	: underline;	
	background 		: transparent;
}
.Button.btn_Pop_menu_serviceLink1[status=disabled]
{
	-nexa-border 		: 2px solid transparent;
	background 		: transparent;
	color			: #565656;
	opacity 		: 0.4;		
}
