<?xml version="1.0" encoding="utf-8"?>
<XCSS version="1.1">
  <Predefines/>
  <CSSData><![CDATA[/*******************	      POPUP       *******************/

/* Background #000000 40% */
.Form.frm_Pop_bg40,
.Form.frm_Pop_bg40[status=disabled]
{
	background 		: rgba(0,0,0,0.4);
}
/* 나의 서비스 설정하기 */
.PopupDiv.pdiv_mySetting
{
	background 		: rgba(255,255,255,0.60);
	border-radius 		: 20px;
	box-shadow 		: 0px 0px 20px 0px rgba(0,0,0,0.20);
}
.Div.div_mySetting,
.Div.div_mySetting[status=focused],.Div.div_mySetting[status=mouseover]
{
	background 		: #ffffff;
	border-radius 		: 20px;
	box-shadow 		: 0px 0px 20px 0px rgba(0,0,0,0.20);
}
/* My Service Setting 나이스플러스 Button */
.Button.btn_mySetting_nice,
.Button.btn_mySetting_nice[status=mouseover],
.Button.btn_mySetting_nice[userstatus=pushed],
.Button.btn_mySetting_nice[status=disabled]
{
	-nexa-border 		: 1px solid transparent;
	-nexa-padding 		: 10px 10px 5px;
	-nexa-icon		: url('theme://images/img_mySetting_neis.png');
	-nexa-text-padding	: 15px 0px 0px 0px;
	-nexa-icon-position	: top;	
	background 		: transparent;
	color 			: #222222;
	font 			: normal 700 18px/normal "Noto Sans KR","NotoSansKR-Bold","Malgun Gothic","Arial","MS PGothic";
	letter-spacing 		: -1px;		
}
.Button.btn_mySetting_nice[status=focused]
{
	-nexa-border 		: 1px dashed #000000;
	-nexa-padding 		: 10px 10px 5px;
}
/* My Service Setting 학부모서비스 Button */
.Button.btn_mySetting_parents,
.Button.btn_mySetting_parents[status=mouseover],
