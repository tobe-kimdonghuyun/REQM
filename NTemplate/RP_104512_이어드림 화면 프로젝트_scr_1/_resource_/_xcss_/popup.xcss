.MaskEdit.display_font18,
.MaskEdit.display_font18[status=mouseover],
.MaskEdit.display_font18[userstatus=nulltext],
.MaskEdit.display_font18[status=focused],
.MaskEdit.display_font18[status=readonly],
.MaskEdit.display_font18[status=disabled]
{
	-nexa-border 		: 1px solid transparent;
	-nexa-padding 		: 0px;
	-nexa-text-align	: left;	
	background		: transparent;
