{
	-nexa-border 		: 1px solid transparent;
	-nexa-padding 		: 5px;
	-nexa-icon		: url('theme://images/img_mySetting_close.png');	
	background 		: transparent;
}
.Button.btn_mySetting_close[status=focused]
{
	-nexa-border 		: 1px dashed #000000;
	-nexa-padding 		: 13px;
}
/* Shadow Box PopupDiv(center) */
.PopupDiv.pdiv_Pop_shadowBox_C,
.PopupDiv.pdiv_Pop_shadowBox_C[status=focused],.PopupDiv.pdiv_Pop_shadowBox_C[status=mouseover]
{
	border-radius 		: 20px;
	background 		: #ffffff;
	box-shadow 		: 0px 10px 16px 0px rgba(0,0,0,0.07);
}
/* Shadow Box PopupDiv(center) */
.Div.div_Pop_shadowBox_C,
.Div.div_Pop_shadowBox_C[status=focused],.Div.div_Pop_shadowBox_C[status=mouseover]
{
	border-radius 		: 20px;
	background 		: #ffffff;
	box-shadow 		: 0px 10px 16px 0px rgba(0,0,0,0.07);
}
/* Popup Save Button */
.Button.btn_Pop_save
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px 30px 1px 30px;
	background 		: #2b72de;
	border-radius 		: 10px;
	color 			: #ffffff;
	font 			: normal 500 18px/normal "Noto Sans KR","NotoSansKR-Medium","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_Pop_save[status=focused]
{
	-nexa-border 		: 2px solid #222222;
	-nexa-padding 		: 0px 30px 1px 30px;
}
.Button.btn_Pop_save[status=mouseover],
.Button.btn_Pop_save[userstatus=pushed]
{
	background 		: #1A56B2; 
}
.Button.btn_Pop_save[status=disabled]
{
	background 		: #d9d9d9;
	cursor 			: default;
}
/* Popup Save blue Button */
.Button.btn_Pop_save_blue
{
	-nexa-border 		: 1px solid #2d73de;
	-nexa-icon		: url('theme://images/ic_mySetting_Reset.png');
	-nexa-text-padding	: 0px 0px 0px 7px;
	-nexa-icon-position	: left;		
	-nexa-padding 		: 0px 30px 2px 108px;
	-nexa-text-align	: left;	
	background 		: #ffffff;
	border-radius 		: 10px;
	color 			: #2d73de;
	font 			: normal 500 18px/normal "Noto Sans KR","NotoSansKR-Medium","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_Pop_save_blue[status=focused]
{
	-nexa-border 		: 2px solid #222222; 
	-nexa-icon		: url('theme://images/ic_mySetting_Reset.png');
	-nexa-text-padding	: 0px 0px 0px 7px;
	-nexa-icon-position	: left;		
	-nexa-padding 		: 0px 30px 2px 107px;
}
.Button.btn_Pop_save_blue[status=mouseover],
.Button.btn_Pop_save_blue[userstatus=pushed]
{
	-nexa-border 		: 1px solid #2d73de;
	-nexa-icon		: url('theme://images/ic_mySetting_ResetO.png');	
	background 		: #2d73de;
	color 			: #ffffff;
}
.Button.btn_Pop_save_blue[status=disabled]
{
	-nexa-icon		: url('theme://images/ic_mySetting_ResetD.png');
	-nexa-border 		: 1px solid #d9d9d9;
	background 		: #ffffff;
	color 			: #d9d9d9;
}
/* Popup Yes Button */
.Button.btn_Pop_yes
{
	-nexa-border 		: 1px solid #2b72de;
	-nexa-padding 		: 0px 10px 1px 10px;
	background 		: #2b72de;
	color 			: #ffffff;
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_Pop_yes[status=focused]
{
	-nexa-border 		: 1px dashed #ffffff;
	-nexa-padding 		: 0px 10px 1px 10px;
}
.Button.btn_Pop_yes[status=mouseover],
.Button.btn_Pop_yes[userstatus=pushed]
{
	-nexa-border 		: 1px solid #000000;
	background 		: #000000;
	color 			: #ffffff;
}
.Button.btn_Pop_yes[status=disabled]
{
	-nexa-border 		: 1px solid #d9d9d9;
	background 		: #d9d9d9;
	color			: #ffffff;
}
.Button.btn_Pop_yes01
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 10px 1px 10px;
	background 		: #2b72de;
	color 			: #ffffff;
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_Pop_yes01[status=focused]
{
	-nexa-border 		: 2px solid #000000;
	-nexa-padding 		: 0px 10px 1px 10px;
}
.Button.btn_Pop_yes01[status=mouseover],
.Button.btn_Pop_yes01[userstatus=pushed]
{
	background 		: #1A56B2;
	color 			: #ffffff;
}
.Button.btn_Pop_yes01[status=disabled]
{
	background 		: #d9d9d9;
	color			: #ffffff;
}
/* Popup No Button */
.Button.btn_Pop_no
{
	-nexa-border 		: 1px solid #d9d9d9;
	-nexa-padding 		: 0px 20px 1px 20px;
	background 		: #ffffff;
	color 			: #222222;
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";
}
