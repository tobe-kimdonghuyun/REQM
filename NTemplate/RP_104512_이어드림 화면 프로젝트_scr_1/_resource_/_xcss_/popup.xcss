/* sitemap */
.Static.sta_sitemap_bg,.Static.sta_sitemap_bg[status=mouseover]
{
	background 		: #041733;
}
.Static.sta_sitemap_line,.Static.sta_sitemap_line[status=mouseover]
{
	-nexa-border 		: 1px solid #53636e,0px none,0px none;
}
.Button.btn_sitemap_menu_lev0
{
	-nexa-border 		: 1px solid transparent;
	-nexa-padding 		: 0px 2px 3px 2px;
	-nexa-text-align	: left;	
	-nexa-vertical-align 	: middle;	
	background 		: transparent;
	color 			: #ffffff;
	font 			: normal 500 18px/normal "Noto Sans KR","NotoSansKR-Medium","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_sitemap_menu_lev0[status=focused]
{
	-nexa-border 		: 1px dashed #ffffff;
	-nexa-padding 		: 0px 2px 3px 2px;
}
.Button.btn_sitemap_menu_lev0[status=mouseover],
.Button.btn_sitemap_menu_lev0[userstatus=pushed]
{
	-nexa-border 		: 1px solid transparent;
	-nexa-text-decoration 	: underline;	
	background 		: transparent;
}
.Button.btn_sitemap_menu_lev0[status=disabled]
{
	-nexa-border 		: 1px solid transparent;
	background 		: transparent;
	color			: #ffffff;
	opacity 		: 0.4;		
}
.Button.btn_sitemap_menu_lev1
{
	-nexa-border 		: 1px solid transparent;
	-nexa-padding 		: 0px 7px 1px 7px;
	-nexa-text-align	: left;	
	-nexa-icon		: url('theme://images/img_sitemap_menuLev1.png');
	-nexa-text-padding	: 0px 0px 5px 7px;
	-nexa-icon-position	: left;
	-nexa-vertical-align	: middle;	
	background 		: transparent;
	color 			: #ffffff;
	font 			: normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic";	
}
.Button.btn_sitemap_menu_lev1[status=focused]
{
	-nexa-border 		: 1px dashed #ffffff;
	-nexa-padding 		: 0px 7px 1px 7px;
}
.Button.btn_sitemap_menu_lev1[status=mouseover],
.Button.btn_sitemap_menu_lev1[userstatus=pushed]
{
	-nexa-border 		: 1px solid transparent;
	-nexa-text-decoration 	: underline;	
	background 		: transparent;
}
.Button.btn_sitemap_menu_lev1[status=disabled]
{
	-nexa-border 		: 1px solid transparent;
	background 		: transparent;
	color			: #ffffff;
	opacity 		: 0.4;		
}
/* GNB Edit */
.Edit.edt_GNB_search
{
	-nexa-border 		: 2px solid #ffffff;
	-nexa-padding 		: 0px 18px 1px 18px;
	background 		: #ffffff;
	color 			: #000000;
	font 			: normal 500 20px/normal "Noto Sans KR","NotoSansKR-Medium","Malgun Gothic","Arial","MS PGothic";
}
.Edit.edt_GNB_search[status=mouseover]
{
	-nexa-border 		: 2px solid #ffffff;
}
.Edit.edt_GNB_search[status=focused]
{
	-nexa-border 		: 2px solid #ffffff;
}
.Edit.edt_GNB_search[status=readonly]
{
	-nexa-border 		: 2px solid #ffffff;
	background 		: #ffffff;
	color 			: #000000;
}
.Edit.edt_GNB_search[userstatus=nulltext]
{
	color          		: #b6b4b4;
}
.Edit.edt_GNB_search[status=disabled]
{
	-nexa-border 		: 2px solid #ffffff;
	background 		: #ffffff;
	color 			: #d9d9d9;
}
.Static.sta_GNB_bg,.Static.sta_GNB_bg[status=mouseover]
{
	background 		: #ffffff;
}
.Static.sta_Notice_bg,.Static.sta_Notice_bg[status=mouseover]
{
	background 		: #f5f5f5;
	border-radius 		: 20px;
}
.Static.sta_Notice_bg01,.Static.sta_Notice_bg01[status=mouseover]
{
	-nexa-text-align 	: center;
	-nexa-padding 		: 0px 0px 2px 0px ;
	background 		: #2b72de;
	border-radius 		: 50px;
	color 			: #ffffff;
	font 			: normal 400 16px "Noto Sans KR","NotoSansKR-Medium","Malgun Gothic","Arial","MS PGothic";	
}
/* GNB search line */
.Static.sta_GNB_line,.Static.sta_GNB_line[status=mouseover]
{
	-nexa-border 		: 2px solid #000000, 0px none, 0px none;
}
/* GNB link Button */
.Button.btn_GNB_link
{
	-nexa-border 		: 1px solid #d9d9d9;
	-nexa-padding 		: 0px 13px 1px 13px;
	background 		: #ffffff;
	border-radius 		: 12px;
	color 			: #222222;
	font 			: normal 500 14px/normal "Noto Sans KR","NotoSansKR-Medium","Malgun Gothic","Arial","MS PGothic";
}
.Button.btn_GNB_link[status=focused]
{
	-nexa-border 		: 1px dashed #222222;
	-nexa-padding 		: 0px 13px 1px 13px;
}
.Button.btn_GNB_link[status=mouseover]
{
	-nexa-border 		: 1px solid #d9d9d9;
	background 		: #f5f5f5;
}
.Button.btn_GNB_link[userstatus=pushed]
{
	-nexa-border 		: 1px solid #d9d9d9;
	background 		: #f5f5f5;
}
.Button.btn_GNB_link[status=disabled]
{
	-nexa-border 		: 1px solid #d6d6d6;
	background 		: #ffffff;
	color 			: #d6d6d6;	
}]]></CSSData>
</XCSS>
