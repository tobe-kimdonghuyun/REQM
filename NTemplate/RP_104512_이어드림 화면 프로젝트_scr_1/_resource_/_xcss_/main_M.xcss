<?xml version="1.0" encoding="utf-8"?>
<XCSS version="1.1">
  <Predefines/>
  <CSSData><![CDATA[/*******************	      MAIN Mobile        *******************/

.Div.div_main_M,
.Div.div_main_M[status=focused],.Div.div_main_M[status=mouseover]
{
	-nexa-border 		: 0px none;
	border-radius 		: 0px;
	background 		: #eeeeee;
}
/* Shortcuts Button */
.Button.btn_main_shortcuts
{
	-nexa-border 		: 2px solid #ffffff;
	-nexa-padding 		: 0px 35px 1px 35px;
	background 		: #ffffff;
	border-radius 		: 35px;
	color 			: #222222;
	font 			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Medium";
}
.Button.btn_main_shortcuts[status=focused]
{
	-nexa-border 		: 2px dashed #222222;
	-nexa-padding 		: 0px 35px 1px 35px;
}
.Button.btn_main_shortcuts[status=mouseover],
.Button.btn_main_shortcuts[userstatus=pushed]
{
	-nexa-border 		: 2px solid #2d73de;
	background 		: #2d73de;
	color 			: #ffffff;
}
.Button.btn_main_shortcuts[status=disabled]
{
	-nexa-border 		: 2px solid #ffffff;
	background 		: #ffffff;
	color			: #d9d9d9;
}
/* Main sub0 text */
.Static.sta_main_titlebar_M,.Static.sta_main_titlebar_M[status=mouseover]
{
	-nexa-text-align 	: left;	
	background 		: url('imagerc::main/main_bg_titleline.png') no-repeat right center transparent;
	font			: normal 400 26px/normal "Noto Sans KR","NotoSansKR-Regular";
	color 			: #ffffff;	
}
.Static.sta_main_sub_teg02_M,.Static.sta_main_sub_teg02_M[status=mouseover]
{
	-nexa-border 		: 2px solid #2d73de;	
	-nexa-padding 		: 0px 10px 1px 10px;
	-nexa-text-align	: center;	
	border-radius 		: 30px;	
	background 		: #ffffff;
	color 			: #2d73de;
	font 			: normal 400 24px/normal "Noto Sans KR","NotoSansKR-Medium";
	letter-spacing		: 0px;	
}
/* Main More Button */
.Button.btn_main_more_M,
.Button.btn_main_more_M[status=mouseover],
.Button.btn_main_more_M[userstatus=pushed]
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 5px 1px 10px;
	-nexa-text-align	: right;
	border-radius 		: 0px;	
	background 		: transparent;
	color 			: #222222;
	font 			: normal 400 24px/normal "Noto Sans KR","NotoSansKR-Regular";
}
.Button.btn_main_more_M[status=focused]
{
	-nexa-border 		: 2px dashed #000000;
	-nexa-padding 		: 0px 5px 1px 10px;
}
.Button.btn_main_more_M[status=disabled]
{
	background 		: transparent;
	opacity 		: 0.4;		
}
/* Main Notice More Button */
.Button.btn_main_sub0_more,
.Button.btn_main_sub0_more[status=mouseover],
.Button.btn_main_sub0_more[userstatus=pushed]
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px 2px 1px 2px;
	-nexa-text-align	: center;
	-nexa-icon		: url('imagerc::main_M/main_notice_more.png');	
	border-radius 		: 0px;	
	background 		: transparent;
}
.Button.btn_main_sub0_more[status=focused]
{
	-nexa-border 		: 2px dashed #000000;
	-nexa-padding 		: 0px 2px 1px 2px;
}
.Button.btn_main_sub0_more[status=disabled]
{
	-nexa-border 		: 0px none;
	background 		: transparent;
	opacity 		: 0.4;		
}
/* 교육제증명 Button */
.Button.btn_main_sub0_serviceLink1M
{
	-nexa-border 		: 2px solid #eaeaea;
	-nexa-padding 		: 10px 30px 11px 30px;
	-nexa-text-align	: left;	
	-nexa-icon		: url('imagerc::main_M/main_serviceLink01_M.png');
	-nexa-text-padding	: 0px 0px 0px 40px;
	-nexa-icon-position	: left;		
	border-radius 		: 18px;		
	background 		: url('imagerc::main_M/main_serviceLink.png') no-repeat right center #ffffff;
	color 			: #222222;
	font 			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Medium";
}
.Button.btn_main_sub0_serviceLink1M[status=focused]
{
	-nexa-border 		: 2px dashed #000000;
	-nexa-padding 		: 10px 30px 11px 30px;
}
.Button.btn_main_sub0_serviceLink1M[status=mouseover],
.Button.btn_main_sub0_serviceLink1M[userstatus=pushed]
{
	-nexa-border 		: 2px solid #eaeaea;
	-nexa-text-decoration 	: underline;	
	background 		: url('imagerc::main_M/main_serviceLink.png') no-repeat right center #ffffff;
}
.Button.btn_main_sub0_serviceLink1M[status=disabled]
{
	-nexa-border 		: 2px solid #eaeaea;
	background 		: url('imagerc::main_M/main_serviceLink.png') no-repeat right center #ffffff;
	color			: #565656;
}
/* 교육비 원클릭 신청시스템 Button */
.Button.btn_main_sub0_serviceLink2M
{
	-nexa-border 		: 2px solid #eaeaea;
	-nexa-padding 		: 10px 30px 11px 30px;
	-nexa-text-align	: left;
	-nexa-icon		: url('imagerc::main_M/main_serviceLink02_M.png');
	-nexa-text-padding	: 0px 0px 0px 40px;
	-nexa-icon-position	: left;		
	border-radius 		: 18px;		
	background 		: url('imagerc::main_M/main_serviceLink.png') no-repeat right center #ffffff;
	color 			: #222222;
	font 			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Medium";
}
.Button.btn_main_sub0_serviceLink2M[status=focused]
{
	-nexa-border 		: 2px dashed #000000;
	-nexa-padding 		: 10px 30px 11px 30px;
}
.Button.btn_main_sub0_serviceLink2M[status=mouseover],
.Button.btn_main_sub0_serviceLink2M[userstatus=pushed]
{
	-nexa-border 		: 2px solid #eaeaea;
	-nexa-text-decoration 	: underline;	
	background 		: url('imagerc::main_M/main_serviceLink.png') no-repeat right center #ffffff;
}
.Button.btn_main_sub0_serviceLink2M[status=disabled]
{
	-nexa-border 		: 2px solid #eaeaea;
	background 		: url('imagerc::main_M/main_serviceLink.png') no-repeat right center #ffffff;
	color			: #565656;
}
/* 일반설문 Button */
.Button.btn_main_sub0_serviceLink3M
{
	-nexa-border 		: 2px solid #eaeaea;
	-nexa-padding 		: 10px 30px 11px 30px;
	-nexa-text-align	: left;	
	-nexa-icon		: url('imagerc::main_M/main_serviceLink03_M.png');
