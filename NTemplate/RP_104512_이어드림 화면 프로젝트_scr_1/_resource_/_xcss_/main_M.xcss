.Button.btn_main_sub0_serviceLink4M
{
	-nexa-border 		: 2px solid #eaeaea;
	-nexa-padding 		: 10px 30px 11px 30px;
	-nexa-text-align	: left;	
	-nexa-icon		: url('imagerc::main_M/main_serviceLink04_M.png');
