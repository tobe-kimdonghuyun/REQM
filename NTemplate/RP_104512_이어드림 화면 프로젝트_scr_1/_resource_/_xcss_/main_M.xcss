/* Main Sub2 shortcuts Button */
.Button.btn_main_sub2_shortcuts_M
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 12px 1px 12px;
	-nexa-icon		: url('imagerc::main_M/main_sub2_shortcuts_M.png');
