/* Notice Grid */
.Grid.grd_main_notice_M,
.Grid.grd_main_notice_M[status=mouseover],.Grid.grd_main_notice_M[status=focused],
.Grid.grd_main_notice_M[status=readonly],.Grid.grd_main_notice_M[status=disabled]
{
	-nexa-border 		: 0px none;
	background 		: #ffffff;
}
.Grid.grd_main_notice_M .body,
.Grid.grd_main_notice_M .body[status=disabled]
{
	background 		: #ffffff;
}
.Grid.grd_main_notice_M .body .row .cell,
.Grid.grd_main_notice_M .body .row .cell[status=mouseover],
.Grid.grd_main_notice_M .body .row .cell[userstatus=selected],
.Grid.grd_main_notice_M .body .row .cell[status=disabled]
{
	-nexa-border 		: 0px none;
	-nexa-padding 		: 0px;
	-nexa-text-align 	: center;	
	color 			: #222222;	
	font			: normal 400 24px/normal "Noto Sans KR","NotoSansKR-Regular";
}
.Grid.grd_main_notice_M .body .row .cell[status=focused]
{
}
/* Cell Title Text */
.Grid.grd_main_notice_M .body .row .cell.cell_link_M,
.Grid.grd_main_notice_M .body .row .cell.cell_link_M[userstatus=selected],
.Grid.grd_main_notice_M .body .row .cell.cell_link_M[status=disabled]
{
	-nexa-text-decoration 	: none;
	-nexa-text-align 	: left;	
	-nexa-padding 		: 0px 20px;
	color 			: #222222;	
	font			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Medium";
	letter-spacing 		: -2px;	
}
.Grid.grd_main_notice_M .body .row .cell.cell_link_M[status=mouseover],
.Grid.grd_main_notice_M .body .row .cell.cell_link_M[status=focused]
{
	-nexa-text-decoration 	: underline;
	-nexa-text-align 	: left;	
	-nexa-padding 		: 0px 20px;
	color 			: #222222;	
	font			: normal 500 28px/normal "Noto Sans KR","NotoSansKR-Medium";
	letter-spacing 		: -2px;		
}
/* Main sub0 TAB 공지사항&자주묻는 질문 Button */
.Button.btn_main_sub0_tabM_N,
.Button.btn_main_sub0_tabM_N[status=mouseover],
.Button.btn_main_sub0_tabM_N[userstatus=pushed]
{
	-nexa-border 		: 2px solid #ffffff;
	-nexa-padding 		: 0px 7px 1px 7px;
	-nexa-text-align	: center;
	border-radius 		: 18px;	
	background 		: #ffffff;
	color 			: #767676;
	font 			: normal 500 42px/normal "Noto Sans KR","NotoSansKR-Medium";
	letter-spacing		: -2px;		
}
.Button.btn_main_sub0_tabM_N[status=focused]
{
	-nexa-border 		: 2px dashed #000000;
	-nexa-padding 		: 0px 7px 1px 7px;
}
.Button.btn_main_sub0_tabM_N[status=disabled]
{
	-nexa-border 		: 0px none;
	background 		: #ffffff;
	color			: #d6d6d6;
}
.Button.btn_main_sub0_tabM_S,
.Button.btn_main_sub0_tabM_S[status=mouseover],
.Button.btn_main_sub0_tabM_S[userstatus=pushed]
{
	-nexa-border 		: 2px solid transparent;
	-nexa-padding 		: 0px 7px 1px 7px;
	-nexa-text-align	: center;
	border-radius 		: 18px;	
	background 		: transparent;
	color 			: #2b72de;
	font 			: normal 700 42px/normal "Noto Sans KR","NotoSansKR-Bold";
	letter-spacing		: -3px;		
}
.Button.btn_main_sub0_tabM_S[status=focused]
{
	-nexa-border 		: 2px dashed #000000;
	-nexa-padding 		: 0px 7px 1px 7px;
}
.Button.btn_main_sub0_tabM_S[status=disabled]
{
	-nexa-border 		: 2px solid transparent;
	background 		: transparent;
	color			: #565656;	
}
/* Main sub1 Mobile Edit */
.Edit.edt_main_sub1_edt_M,
.Edit.edt_main_sub1_edt_M[status=mouseover],
.Edit.edt_main_sub1_edt_M[status=focused],
.Edit.edt_main_sub1_edt_M[status=readonly]
{
	-nexa-border 		: 4px solid #f5f5f5,0px none,4px solid #222222;
	-nexa-padding 		: 0px 20px 0px 10px;	
	background 		: url('imagerc::main_M/main_sub1_icon_bar_M.png') no-repeat left center transparent;
	font			: normal 700 80px/normal "Noto Sans KR","NotoSansKR-Bold";
	color 			: #222222;
	border-radius : 0px;	
}
.Edit.edt_main_sub1_edt_M[userstatus=nulltext]
{
	color 			: #d9d9d9;
}
.Edit.edt_main_sub1_edt_M[status=disabled]
{
	-nexa-border 		: 4px solid #f5f5f5,0px none,4px solid #222222;
	background 		: url('imagerc::main_M/main_sub1_icon_bar_M.png') no-repeat left center transparent;
	color 			: #d9d9d9;
}
/* Link Button */
.Button.btn_main_sub1_txtLink_M,
.Button.btn_main_sub1_txtLink_M[userstatus=pushed]
{
	-nexa-border 		: 2px solid #eaeaea;
