this.fvObjMapSelectGroup = [
		{
			//mapPathData : "M214.575 202.494L210.304 195.102L218.845 195.102L214.575 202.494Z" 
			mapPathData : "M202.575 202.494L198.304 195.102L206.845 195.102L202.575 202.494Z"  // 하단 역삼각형
		}	
		];

// callback을 처리하기 위한 정보
this.fvCallbackForm;
this.fvCallbackFunc;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.comp_korMap_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	if(this.parent.mapScale)
	{
		this.fvScale = parseFloat(this.parent.mapScale);
	}
	//trace("===this.fvScale="+this.fvScale);

	if(this.parent.clickMode)
	{
		
		this.fvClickMode = this.parent.clickMode;
	}
	
	// 교육청정보를 글로벌에서 가져온다
	this.dsCddcOrgCode.copyData(nexacro.getApplication().gdsCddcList);

	this.fnDrawMap();
};
 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnSetInit = function(objForm,objFunc)
{
	this.fvCallbackForm = objForm;
	this.fvCallbackFunc = objFunc;
	
}
 
 this.fnDrawMap = function()
{
	this.fnCreateMapObject();
	this.fnCreateSelectGroupObject();
	
	
	trace("this.fvScale="+this.fvScale);
	if(this.fvScale!=1.0)
	{
		var objGraphGroup = this.graMap.getObjectByID("graGroupMap");
		objGraphGroup.scale(this.fvScale,this.fvScale);
	}
	
	this.graMap.redraw();	
}
this.fnCreateMapObject = function()
{
	var sCode     = "";
	var sName     = "";
	var sMapName  = "";
	var sPathData = "";
	var nCenterX  = 0;
	var nCenterY  = 0; //0
	var nTextX = 0;
	var nTextY = 0;

	var nLenth=this.dsCddcInfo.rowcount;
	
	var objGGroupMap = new nexacro.GraphicsGroup();
	
	// 시도영역 그리기
	for(i=0;i<nLenth;i++)
	{
		sCode     = this.dsCddcInfo.getColumn(i,"code"     );
		sName     = this.dsCddcInfo.getColumn(i,"name"     );
		sMapName  = this.dsCddcInfo.getColumn(i,"mapName"  );
		sPathData = this.dsCddcInfo.getColumn(i,"pathData" );
		nCenterX  = this.dsCddcInfo.getColumn(i,"centerX"  );
		nCenterY  = this.dsCddcInfo.getColumn(i,"centerY"  );
		
		var objGPath1 = new nexacro.GraphicsPath();
		objGPath1.setPathData   (sPathData); 
		objGPath1.set_fillstyle (this.fvFillColor      );
		objGPath1.set_strokepen (this.fvStrokePen      );
		// user property setting
		objGPath1.mapId      = i       ;
		objGPath1.mapCode    = sCode   ;
		objGPath1.mapName    = sMapName;
		objGPath1.mapSelName = sName  + "교육청";
		objGPath1.centerX    = nCenterX;
		objGPath1.centerY    = nCenterY;
		
		objGGroupMap.addChild( "grapath"+i, objGPath1 );
		if(sMapName=="광주")
		{
			this.fvGJ = objGPath1;
		}
		else if(sMapName=="경북")
		{
			this.fvKB = objGPath1;
		}	
	}
	
	// 더미영역 그리기 - 울릉도/독도
	var nDumyLenth=this.dsCddcInfoDummy.rowcount;
	for(i=0;i<nDumyLenth;i++)
	{
		sMapName  = this.dsCddcInfoDummy.getColumn(i,"mapName"  );
		sPathData = this.dsCddcInfoDummy.getColumn(i,"pathData" );
		
		var objGPath1 = new nexacro.GraphicsPath();
		objGPath1.setPathData   (sPathData); 
		objGPath1.set_fillstyle (this.fvFillColor      );
		objGPath1.set_strokepen (this.fvStrokePen      );
		objGPath1.mapName= sMapName;
		objGPath1.mapId= i;
		objGGroupMap.addChild( "grapathDummy"+i, objGPath1 );
		
		if(sMapName=="울릉도")
		{
			this.fvUlleungdo = objGPath1;
		}		
		else if(sMapName=="독도")
		{
			this.fvDokdo = objGPath1;
		}				
	}
	
	// Text넣기
	for(i=0;i<nLenth;i++)
	{
		sMapName  = this.dsCddcInfo.getColumn(i,"mapName" );
		nTextX    = this.dsCddcInfo.getColumn(i,"textX"   );
		nTextY    = this.dsCddcInfo.getColumn(i,"textY"   );
		
		var objGText1 = new nexacro.GraphicsText();
		objGText1.set_text  (sMapName         ); 
		objGText1.set_x     (nTextX           ); // 지도상의 텍스트 x좌표 조정
		objGText1.set_y     (nTextY           ); // 지도상의 텍스트 y좌표 조정
		objGText1.set_color (this.fvTextColor );
		objGText1.set_font  (this.fvTextFont  );
		objGGroupMap.addChild( "gratext"+i, objGText1 );
	}	
	
	/*
	// Text를 그리기
	for(var i=0;i<objMapInfoText.length;i++)
	{
		var objGPaths1 = new nexacro.GraphicsPaths();
		objGPaths1.setPathData   (objMapInfoText[i]); 
		objGPaths1.set_fillstyle (this.fvTextColor);
		this.graMap.addChild( "grapaths_"+i, objGPaths1 );	
	}
	*/
	this.graMap.addChild( "graGroupMap", objGGroupMap );

}
this.fnCreateSelectGroupObject = function()
{
	var objGraphMainGroup = this.graMap.getObjectByID("graGroupMap");
	
	// SelectGroup넣기
		var objGGroup = new nexacro.GraphicsGroup();
		//objGGroup.set_x(282);
		//objGGroup.set_y(273);
		//objGGroup.set_width(217);
		//objGGroup.set_height(91);
		objGGroup.set_visible(false);

		var objGGroupPath1 = new nexacro.GraphicsPath();
		objGGroupPath1.setPathData   (this.fvObjMapSelectGroup[0].mapPathData); 
		objGGroupPath1.set_strokepen (this.fvSelStrokePen        );
		objGGroupPath1.set_fillstyle (this.fvSelTextFillColor    );
		objGGroup.addChild( "GraphicsGroupPath1", objGGroupPath1 );
		
		var objGGroupRect1 = new nexacro.GraphicsRect(); // 말풍선 라운드박스
		objGGroupRect1.set_x(148); // 말풍선/라운드박스 x좌표 조정
		objGGroupRect1.set_y(164); // 말풍선/라운드박스 y좌표 조정
		objGGroupRect1.set_width(150); //말풍선/라운드박스width 조정
		objGGroupRect1.set_height (32);//말풍선/라운드박스height 조정
		objGGroupRect1.set_fillstyle (this.fvSelTextFillColor     );
		objGGroupRect1.set_radiusx (20); //말풍선/라운드박스border-radius x값
		objGGroupRect1.set_radiusy (20); //말풍선/라운드박스border-radius y값
		objGGroup.addChild( "GraphicsGroupRect1", objGGroupRect1 );

		var objGGroupText1 = new nexacro.GraphicsText(); // 말풍선 안쪽 텍스트
		objGGroupText1.set_text  ("ww"); 
		objGGroupText1.set_x     (222);   // objGGroupRect1.x + (objGGroupRect1.width/2)
		objGGroupText1.set_y     (174);   // objGGroupRect1.y + (objGGroupRect1.height/2)
		objGGroupText1.set_color (this.fvSelTextColor  );
		objGGroupText1.set_font (this.fvSelTextFont  );
		objGGroupText1.set_textAlign( "center" );
		objGGroupText1.set_textwidth(150); // 텍스트 width 값
		objGGroup.addChild( "graGroupText1", objGGroupText1 );

		// 선택시 표시되는 작은 원
		var objGGroupRect2 = new nexacro.GraphicsRect();
		objGGroupRect2.set_x(200); 
		objGGroupRect2.set_y(204);
		objGGroupRect2.set_width(6);
		objGGroupRect2.set_height(6); 
		objGGroupRect2.set_radiusx(3);
		objGGroupRect2.set_radiusy(3);
		objGGroupRect2.set_fillstyle (this.fvSelPointFillColor      );
		objGGroup.addChild( "GraphicsGroupRect2", objGGroupRect2 );

		//this.graMap.addChild( "graSelGroup", objGGroup );
		objGraphMainGroup.addChild( "graSelGroup", objGGroup );

	
		this.graMap.redraw();
	
}
this.fnAllClearFill = function(obj,objSelGraphicPath)
{
	var aGraphicPaths = obj.getAllObjects();

	for(var i=0,nLength=aGraphicPaths.length;i<nLength;i++)
	{
		objGraphicPath = aGraphicPaths[i];
		//trace(objGraphicPath.id);
		if((objGraphicPath.id.indexOf("gratext")>-1) 
		  || (objGraphicPath.id.indexOf("GraphicsGroup")>-1) 
		  || (objGraphicPath.id.indexOf("graSelGroup")>-1) 
		  )
		{
			continue;
		}
		
		//if(objSelGraphicPath.id!=objGraphicPath.id)
		//{
			objGraphicPath.set_fillstyle(this.fvFillColor);
		//}
	}
};

this.fnShowGroup = function(objGraphicPath,bVisible)
{

	// StartX/Y를 구한다.(원래 그룹의 시작위치로 보정)
	var nStartX = objGraphicPath.centerX - 204;
	var nStartY = objGraphicPath.centerY - 204;
	//trace("nStartX=["+nStartX+"]  nStartY=["+nStartY+"]");
	
	// 작업할 오브젝트를 구한다.
	var objSelGroup = this.graMap.getObjectByID("graSelGroup");  // 선택정보 표시그룹오브젝트
	var objSelGroupText = this.graMap.getObjectByID("graGroupText1");  // 선택정보 표시그룹오브젝트안의 시도교육청명칭표시 텍스트오브젝트

	// 시도교욱청 명칭을 변경한다.
	objSelGroupText.set_text(objGraphicPath.mapSelName);
	
	// 그룹의 위치를 옮긴다.
	objSelGroup.set_x(nStartX);
	objSelGroup.set_y(nStartY);
	
	
	objSelGroup.set_visible(bVisible);
	
}

this.fnGetSelectCode = function()
{
	var sMapCode = "";
	if(this.fvSelArea)
	{
		sMapCode = this.fvSelArea.mapCode;
		
		// 실제코드로 변경
		sMapCode = this.dsCddcOrgCode.lookup("cddcCdMap",sMapCode,"cddcOrgCd");
		
	}
	return sMapCode;
};

this.fnGetSelectName = function()
{
	var sSelMapName = "";
	if(this.fvSelArea)
	{
		sSelMapName = this.fvSelArea.mapSelName;
	}
	return sSelMapName;
};

this.fnSetCddcCode = function(sCddcCode)
{
	var objSelGraphicPath = this.fnGetMapPathObject(sCddcCode);
	
	this.fnAllClearFill(this.graMap,objSelGraphicPath);
	
	//objSelGraphicPath.set_fillstyle(this.fvSelFillColor);
	this.fnSetSelFillColor(objSelGraphicPath);	
	
	this.fnShowGroup(objSelGraphicPath,true);
	
	this.graMap.redraw();
};

this.fnGetMapPathObject = function(sCddcCode)
{
	var aGraphicPaths = this.graMap.getAllObjects();
	for(var i=0,nLength=aGraphicPaths.length;i<nLength;i++)
	{
		var objGraphicPath = aGraphicPaths[i];
		//trace(objGraphicPath.id);
		if((objGraphicPath.id.indexOf("gratext")>-1) 
		  || (objGraphicPath.id.indexOf("GraphicsGroup")>-1) 
		  || (objGraphicPath.id.indexOf("graSelGroup")>-1) 
		  )
		{
			continue;
		}
		trace("  == "+objGraphicPath.mapCode+" == "+sCddcCode);
		if(objGraphicPath.mapCode==sCddcCode)
		{
			return objGraphicPath;
		}
	}
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.graMap_onclick = function(obj:nexacro.Graphics,e:nexacro.ClickEventInfo)
{
	var nX  = e.clientx;
	var nY  = e.clienty;

	var nX1 = e.canvasx;
	var nY1 = e.canvasy;

	trace("nX=[" + nX + "]  nY=[" + nY + "]  nX1=[" + nX1 + "]  nY1=[" + nY1 + "]");
	
	var aGraphicPaths = obj.getAllObjects();
	var objGraphicPath;
	
	var objGraphicPaths = obj.hitTestAll(nX,nY);
	for(var k=0;k<objGraphicPaths.length;k++)
	{
		if(objGraphicPaths[k].id.indexOf("grapath")>-1)
		{
			objGraphicPath = objGraphicPaths[k];
			if(objGraphicPath.mapName!="전남")
			{
				if((objGraphicPath.mapName=="울릉도")||(objGraphicPath.mapName=="독도"))
				{
					objGraphicPath = this.fvKB;
				}
				break;
			}
		}
	}
	
	if(objGraphicPath)
	{
		if(objGraphicPath.id.indexOf("grapath")>-1)
		{
			this.fnAllClearFill(obj,objGraphicPath);
			
			//objGraphicPath.set_fillstyle(this.fvSelFillColor);
			this.fnSetSelFillColor(objGraphicPath);
			//trace("===hit:"+objGraphicPath.mapName +" , id="+objGraphicPath.id);	
			
			var bVisible = true;
			
			if((this.fvSelArea)&&(this.fvSelArea.id==objGraphicPath.id))
			{
				if(this.fvClickMode=="toggle")
				{
					bVisible= false;
					//objGraphicPath.set_fillstyle(this.fvFillColor);
					fnClearSelFillColor(objGraphicPath);
				}
			}
			
			this.fnShowGroup(objGraphicPath,bVisible);
			
			if(bVisible)
			{
				this.fvSelArea = objGraphicPath;
			}
			else
			{
				this.fvSelArea = null;
			}
			
			obj.redraw();  // 지도를 다시 그린다.
			
			
			// 이벤트를 발생한다.
			var sSelCode = "";
			var sSelName = "";
			if(this.fvCallbackFunc)
			{
				if(this.fvSelArea)
				{
					sSelCode = this.fvSelArea.mapCode;
					sSelName = this.fvSelArea.mapSelName;
				}

				this.fvCallbackFunc.call(this.fvCallbackForm,sSelCode,sSelName);
			}
		}
	}
};

this.fnSetSelFillColor = function(objGraphPath)
{
	objGraphPath.set_fillstyle(this.fvSelFillColor);
	
	// 경상북도인 경우 울릉도/독도도 포함
	if(objGraphPath==this.fvKB)
	{
		this.fvDokdo.set_fillstyle(this.fvSelFillColor);
		this.fvUlleungdo.set_fillstyle(this.fvSelFillColor);
	}
	
}

this.fnClearSelFillColor = function(objGraphPath)
{
	objGraphPath.set_fillstyle(this.fvFillColor);
	
	// 경상북도인 경우 울릉도/독도도 포함
	if(objGraphPath==this.fvKB)
	{
		this.fvDokdo.set_fillstyle(this.fvFillColor);
		this.fvUlleungdo.set_fillstyle(this.fvFillColor);
	}
	
}

]]></Script>
