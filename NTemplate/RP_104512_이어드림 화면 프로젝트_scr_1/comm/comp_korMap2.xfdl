/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
// 지도 영역 선택시 표시되는 그룹의 정보 
this.fvSelTextColor     = "white";               // 지도영역선택시 표시되는 시도교육청 명칭 글자색
this.fvSelStrokePen     = "2px solid #2b72de";   // 지도영역선택시 표시되는 시도교육청 명칭 Border색
this.fvSelTextFillColor = "#2b72de";             // 지도영역선택시 표시되는 시도교육청 명칭 배경색
this.fvSelFillColor     = "#b7c3c9";             // 지도영역을 선택시 표시되는 배경색
this.fvSelPointFillColor = "#8a9ea9";            // 지도영역선택시 표시되는 위치포인트 배경색
this.fvSelTextFont = 'normal 700 12px/normal "Noto Sans KR","NotoSansKR-Regular"';

// 지도를 그릴때 표시되는 정보
this.fvTextColor = "#595959";             // 지도에 표시되는 시도교육청 명칭 글자색
this.fvFillColor = "#d3d9db";             // 일반적인 지도영역 배경색
this.fvStrokePen = "2px solid #e9ecec";   // 지도를 그릴때 사용하는 border정보
this.fvTextFont = 'normal 400 12px/normal "Noto Sans KR","NotoSansKR-Regular"';

this.fvGJ;   // 광주영역 오브젝트(전라남도와 영역이 겹치므로 클릭시 판단하기 위한 용도)
this.fvKB;   // 경상북도 오브젝트(울릉도/독도 처리용)
this.fvUlleungdo;   // 울릉도 오브젝트
this.fvDokdo;      // 독도 오브젝트
this.fvSelArea; // 현재선택된 영역 오브젝트

this.fvClickMode = "toggle";  // 같은 지역을 클릭시 처리방식. "toggle":교육청정보를 보여주지 않음, "skip" : 교육청정보를 그대로 보여줌 

// scale정보
this.fvScale = 1.0;  // 지도의 스케일

