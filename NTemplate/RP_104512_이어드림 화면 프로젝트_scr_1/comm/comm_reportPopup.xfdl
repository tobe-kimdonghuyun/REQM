<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="comm_reportPopup" width="1000" height="600" titletext="리포트 팝업" onload="comm_reportPopup_onload">
    <Layouts>
      <Layout height="600" width="1000" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divReport" taborder="1" text="div00" left="4" top="4" bottom="60" right="4" initvalueid="ivDivAccessibilityOff"/>
        <Button id="btnClose" taborder="2" text="닫기" height="30" width="50" left="47.50%" fittocontents="width" cssclass="btn_WF_Crud" bottom="15" onclick="btnClose_onclick" initvalueid="ivBtnAccessibilityButton"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    TEMPLATE
*  @FileName 	comm_reportPopup.xfdl
*  @Creator 	홍길동
*  @CreateDate 	2022.7.22
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.7.22     	홍길동 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 this.comm_reportPopup_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 팝업 폼 초기화
	this.smfInitPopup(obj); 
	
	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	this.divReport.optionReport = this.pv_params.reportOption;
	this.divReport._objForm = this.pv_params.sender;
	
	// report를 그린다.
	this.divReport.set_url("comm::comp_ozreport.xfdl");
	
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};
]]></Script>
  </Form>
</FDL>
