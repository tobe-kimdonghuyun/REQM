<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="GridPage" left="0" top="0" width="1320" height="32" scrolltype="none" onload="fnOnload" titletext="Grid Paging" visible="false" onsize="fnOnsize">
    <Layouts>
      <Layout screenid="desktopScr,mobileScr,tabletScr" width="1320" height="32">
        <Static id="staTotalCount" taborder="0" left="0" top="42" width="91" height="26" cssclass="sta_WF_Total" fittocontents="width" text="Total       " visible="false" initvalueid="ivStcAccessibilityOn"/>
        <Combo id="cboPageSize" taborder="1" left="91" width="113" height="30" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" value="100" index="3" text="100개씩보기" top="40" visible="false" initvalueid="ivCmbNormal">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row>
                <Col id="codecolumn">10</Col>
                <Col id="datacolumn">10개씩보기</Col>
              </Row>
              <Row>
                <Col id="codecolumn">15</Col>
                <Col id="datacolumn">15개씩보기</Col>
              </Row>
              <Row>
                <Col id="codecolumn">20</Col>
                <Col id="datacolumn">20개씩보기</Col>
              </Row>
              <Row>
                <Col id="codecolumn">100</Col>
                <Col id="datacolumn">100개씩보기</Col>
              </Row>
            </Rows>
          </Dataset>
        </Combo>
        <Div id="divPage" taborder="2" text="div01" left="0" top="0" width="310" height="32">
          <Layouts>
            <Layout>
              <Button id="imgPrevPage" taborder="0" left="0" width="32" height="32" cssclass="btn_WF_PagePP" top="0" onclick="fnPagemove_onclick" visible="true" initvalueid="iv_Button" accessibilitylabel="처음페이지"/>
              <Button id="imgPrev" taborder="1" left="imgPrevPage:4" width="32" height="32" cssclass="btn_WF_PageP" top="0" onclick="fnPagemove_onclick" visible="true" initvalueid="iv_Button" accessibilitylabel="이전페이지"/>
              <Div id="divPageNum" taborder="2" left="imgPrev:12" top="0" width="32" height="32" visible="true" initvalueid="ivDivAccessibilityOn">
                <Layouts>
                  <Layout>
                    <Button id="img01" cssclass="btn_WF_Page" taborder="0" left="0" top="0" width="32" height="32" visible="false" onclick="imgPageno_onclick" initvalueid="iv_Button"/>
                    <Button id="img02" cssclass="btn_WF_Page" taborder="0" left="0" top="0" width="32" height="32" visible="false" onclick="imgPageno_onclick" initvalueid="iv_Button"/>
                    <Button id="img03" cssclass="btn_WF_Page" taborder="0" left="0" top="0" width="32" height="32" visible="false" onclick="imgPageno_onclick" initvalueid="iv_Button"/>
                    <Button id="img04" cssclass="btn_WF_Page" taborder="0" left="0" top="0" width="32" height="32" visible="false" onclick="imgPageno_onclick" initvalueid="iv_Button"/>
                    <Button id="img05" cssclass="btn_WF_Page" taborder="0" left="0" top="0" width="32" height="32" visible="false" onclick="imgPageno_onclick" initvalueid="iv_Button"/>
                    <Button id="img06" cssclass="btn_WF_Page" taborder="0" left="0" top="0" width="32" height="32" visible="false" onclick="imgPageno_onclick" initvalueid="iv_Button"/>
                    <Button id="img07" cssclass="btn_WF_Page" taborder="0" left="0" top="0" width="32" height="32" visible="false" onclick="imgPageno_onclick" initvalueid="iv_Button"/>
                    <Button id="img08" cssclass="btn_WF_Page" taborder="0" left="0" top="0" width="32" height="32" visible="false" onclick="imgPageno_onclick" initvalueid="iv_Button"/>
                    <Button id="img09" cssclass="btn_WF_Page" taborder="0" left="0" top="0" width="32" height="32" visible="false" onclick="imgPageno_onclick" initvalueid="iv_Button"/>
                    <Button id="img10" cssclass="btn_WF_Page" taborder="0" left="0" top="0" width="32" height="32" visible="false" onclick="imgPageno_onclick" initvalueid="iv_Button"/>
                    <Button id="img11" cssclass="btn_WF_Page" taborder="0" left="0" top="0" width="32" height="32" visible="false" onclick="imgPageno_onclick" initvalueid="iv_Button"/>
                    <Button id="img12" cssclass="btn_WF_Page" taborder="0" left="0" top="0" width="32" height="32" visible="false" onclick="imgPageno_onclick" initvalueid="iv_Button"/>
                    <Button id="img13" cssclass="btn_WF_Page" taborder="0" left="0" top="0" width="32" height="32" visible="false" onclick="imgPageno_onclick" initvalueid="iv_Button"/>
                    <Button id="img14" cssclass="btn_WF_Page" taborder="0" left="0" top="0" width="32" height="32" visible="false" onclick="imgPageno_onclick" initvalueid="iv_Button"/>
                    <Button id="img15" cssclass="btn_WF_Page" taborder="0" left="0" top="0" width="32" height="32" visible="false" onclick="imgPageno_onclick" initvalueid="iv_Button"/>
                    <Button id="img16" cssclass="btn_WF_Page" taborder="0" left="0" top="0" width="32" height="32" visible="false" onclick="imgPageno_onclick" initvalueid="iv_Button"/>
                    <Button id="img17" cssclass="btn_WF_Page" taborder="0" left="0" top="0" width="32" height="32" visible="false" onclick="imgPageno_onclick" initvalueid="iv_Button"/>
                    <Button id="img18" cssclass="btn_WF_Page" taborder="0" left="0" top="0" width="32" height="32" visible="false" onclick="imgPageno_onclick" initvalueid="iv_Button"/>
                    <Button id="img19" cssclass="btn_WF_Page" taborder="0" left="0" top="0" width="32" height="32" visible="false" onclick="imgPageno_onclick" initvalueid="iv_Button"/>
                    <Button id="img20" cssclass="btn_WF_Page" taborder="0" left="0" top="0" width="32" height="32" visible="false" onclick="imgPageno_onclick" initvalueid="iv_Button"/>
                  </Layout>
                </Layouts>
              </Div>
              <Button id="imgNext" taborder="3" cssclass="btn_WF_PageN" left="divPageNum:12" top="0" height="32" width="32" visible="true" onclick="fnPagemove_onclick" initvalueid="iv_Button" accessibilitylabel="다음페이지"/>
              <Button id="imgNextPage" taborder="4" cssclass="btn_WF_PageNN" left="imgNext:4" top="0" height="32" width="32" visible="true" onclick="fnPagemove_onclick" initvalueid="iv_Button" accessibilitylabel="끝페이지"/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  학부모소통시스템
*  @MenuPath    공통
*  @FileName 	comp_paginator.xfdl
*  @Creator 	tobesoft
*  @CreateDate 	2025.03.17
*  @Desction    그리드 페이지기능 구현
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2025.03.17     	tobesoft 	        최초 생성 
*******************************************************************************
*/
this.fv_grid = null;
this.fv_searchFunction = function(){};
this.fv_mainForm = null;
this.foArrImg = null;
this.fv_width;

// 
this.fv_pageCnt = 0;		//페이지번호 갯수
this.fv_showRowCnt = 0;
this.fv_rowCnt = 0;			//데이타 total row수
this.fv_lastPage = 0;
this.fv_selIdx;


this.fv_dsPageInfo = null;
this.fv_divPageSummary = null;
this.mBClick = false;

this.fv_pageBtnCnt = 10; //페이징 버튼 개수 (2022-11-21)

this.fvSelBtnCss = "btn_WF_PageS";
this.fvNonBtnCss = "btn_WF_Page";


this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.fnInitValues();
};

this.fnOnsize = function(obj,e)
{
	var nFormWidth = this.getOffsetWidth();
	var nPageWidth = this.divPage.getOffsetWidth();
	var nLeft = 0;
	if ( nFormWidth > nPageWidth ) {
		nLeft = (nFormWidth / 2) - (nPageWidth / 2);
	}

    this.divPage.setOffsetLeft(nLeft);
    //trace("fnOnsize====nLeft ====="+ nLeft + ":::::nFormWidth ====="+ nFormWidth + ":::::nPageWidth ====="+ nPageWidth);	
	this.resetScroll();	
};

this.fnInited = function(){
	return this.isNotNil(this.fv_dsPageInfo);
};


this.fnGetInitPageSize = function(){
	return this.cboPageSize.value;
};

this.fnSetInitPageSize = function(nValue){
	this.cboPageSize.set_value(nValue);
};


this.fnInitValues = function(){
	this.staTotalCount.set_text("");
};

/**
 *
*/
this.fnInit = function(grid, dsPageInfo, divPageSummary, buttonOrSearchFunction, mainForm) 
{	
	this.fnInitValues();
	
	this.foArrImg = new Array(20);
	this.fv_grid = grid;
	this.fv_dsPageInfo = dsPageInfo;
	this.fv_divPageSummary = divPageSummary;
	
	this.fv_rowCnt = this.fv_dsPageInfo.getColumn(0, "totalCount");
//trace("페이지 fv_rowCnt >>>>" + this.fv_rowCnt);	
	//조회된 데이터가 있을 경우만 visible true(2022-11-21)
	if(this.fv_rowCnt > 0)
  	{
		this.set_visible(true);	
	} else {
		this.set_visible(false);	
	}
	
	this.fv_showRowCnt = this.fv_dsPageInfo.getColumn(0, "initDisplayPageSize");
	this.fv_pageCnt = this.fv_dsPageInfo.getColumn(0, "pageSize");
	if(this.fv_pageCnt == "" || this.fv_pageCnt == null || this.fv_pageCnt == undefined) this.fv_pageCnt = 10;
	
	//this.staTotalCount.set_text("Total  " + this.fv_rowCnt);
		
	if(buttonOrSearchFunction)
	{
		this.fv_buttonOrSearchFunction = buttonOrSearchFunction;
	}
	
	if(mainForm)
	{
		this.fv_mainForm = mainForm;
	}

	this.fv_width = this.getOffsetWidth();
	this.fv_lastPage = Math.ceil(this.fv_rowCnt / this.fv_pageCnt); 

	//위치 센터로 조정	
	//	var nLeft = img_Prev.Right;
	//	var nWidth = (fvWidth - img_Prev.Width - img_Next.Width) / fvPageCnt;
	var nLeft = 0;//0;
	var nWidth = 32;
	var nNumGap = 2;
	var nHeight = this.divPage.form.divPageNum.getOffsetHeight();
	
	// 상세에서 목록 이동 시 10페이지 이후 일때 오류 수정
	var nAddPageIndex = this.fv_dsPageInfo.getColumn(0, "pageIndex");
	if(nAddPageIndex > 10){
		if(Number(String(nAddPageIndex).slice(-1)) == 0){
			nAddPageIndex = Number((String(nAddPageIndex).slice(0,-1)+"0"))-10;
		}else{
			nAddPageIndex = Number((String(nAddPageIndex).slice(0,-1)+"0"));
		}
	}else{
		nAddPageIndex = 0
	}
	
	for(var i = 0; i < this.fv_pageBtnCnt; i++)
	{
		var sId = "img" + String(i + 1).padLeft(2, "0");

		var objPage = this.divPage.form.divPageNum.form.components[sId];
		if(objPage == null) {
			objPage = new Button(sId, nLeft, 0, nWidth, nHeight);
			objPage.set_textAlign("center middle");
			objPage.setEventHandler('onclick',this.imgPageno_onclick, this);
			this.divPage.form.divPageNum.form.addChild(sId, objPage); 
		} else {
			objPage.setOffsetLeft(nLeft);
			objPage.setOffsetWidth(nWidth);
		}
		
		this.foArrImg[i] = this.divPage.form.divPageNum.form.components[sId];

		if(nAddPageIndex + i + 1 > this.fv_lastPage) {
			objPage.set_visible(false);
			objPage.set_text("");
		} else {
			objPage.set_visible(true);
			objPage.set_text((nAddPageIndex + i + 1));
			nLeft += nWidth + nNumGap;
		}
	}

	this.fnRedrawPage();	
		
	this.divPage.form.imgPrev.set_visible(false);
    this.divPage.form.imgPrevPage.set_visible(false);
	if(this.fv_lastPage > this.fv_pageBtnCnt)
	{
		this.divPage.form.imgNext.set_visible(true);
		this.divPage.form.imgNextPage.set_visible(true);
	}
	else
	{
		this.divPage.form.imgNext.set_visible(false);
		this.divPage.form.imgNextPage.set_visible(false);
	}
	
	if(dsPageInfo.getConstColumn("initIsUsePageInfo")=="Y")
	{
		var nPageIndex = this.fv_dsPageInfo.getColumn(0, "pageIndex");
		this.fnSelPage(nPageIndex, true);
	}
	else
	{
		this.fnSelPage(1, true);
	}
};

this.fnPagemove_onclick = function(obj:nexacro.ImageViewer,e:nexacro.ClickEventInfo)
{	
	this.set_visible(false);
	
	switch(obj.name) {
	case "imgPrev" :
		this.fnMovePrev();
		break;
	case "imgNext" :
		this.fnMoveNext();
		break;        
	case "imgPrevPage" :
		this.fnMovePrevPage(1);
		break;
	case "imgNextPage" :
		this.fnMoveNextPage(1);
		break;
	}	

	this.set_visible(true);
};

this.fnRedrawPage = function()
{
	//divPageNum width
	var  nDivWidth = -1;
	for(var i = 0; i < this.fv_pageBtnCnt; i++)
	{
//trace( "버튼 : " + this.foArrImg[i].text + "::::nLeft == " + this.foArrImg[i].getOffsetLeft());	
		if(this.foArrImg[i].visible == false) {		
			nDivWidth = this.foArrImg[i].getOffsetLeft() - 2;
			break;
		} else {
			nDivWidth = this.foArrImg[i].getOffsetRight();
		}
	}
	this.divPage.form.divPageNum.setOffsetWidth(nDivWidth);
	//trace( " this.fv_pageCnt : " + this.fv_pageCnt + ":::: this.fv_pageBtnCnt : " + this.fv_pageBtnCnt + ":::: nDivWidth : " + nDivWidth);
	this.divPage.setOffsetWidth(nDivWidth + 160);
	this.divPage.form.resetScroll();
	
	// 위치를 Form의 중앙에 위치시킴
	this.fnOnsize();
};

this.imgPageno_onclick = function(obj:nexacro.ImageViewer,e:nexacro.ClickEventInfo)
{
	var nSelIdx = parseInt(String(obj.name).substr(3, 5));// - 1;
	
	// trace(obj.name + " :: " + nSelIdx);
	
	this.fnSelPage(nSelIdx, false);
};

this.fnSelPage = function(nSelIdx, initFlg)
{
	//선택 외 다른 css 초기화
	for( var i=0;i < this.divPage.form.divPageNum.form.components.length;i++ )
	{
		this.divPage.form.divPageNum.form.components[i].set_cssclass("btn_WF_Page");
	}
	
	if(nSelIdx == null) nSelIdx = 1;
	
	// fnInit으로 호출될 경우 10페이지 이후 일때 오류 수정
	if(nSelIdx > 10){
		if(Number(String(nSelIdx).slice(-1)) == 0){
			nSelIdx = 10;
		}else{
			nSelIdx = Number(String(nSelIdx).slice(-1));
		}
	}
	this.fv_selIdx = nSelIdx;
	
	//선택 css 초기화
	this.foArrImg[this.fv_selIdx-1].set_cssclass(this.fvSelBtnCss);
	
	if(parseInt(this.foArrImg[nSelIdx-1].text) == this.fv_lastPage) {
		this.divPage.form.imgNext.set_visible(false);
	} else {
		this.divPage.form.imgNext.set_visible(true);
	}
	
	if(parseInt(this.foArrImg[0].text) + this.fv_pageBtnCnt > this.fv_lastPage) {
		this.divPage.form.imgNextPage.set_visible(false);
	} else {
		this.divPage.form.imgNextPage.set_visible(true);
	}	

	if(parseInt(this.foArrImg[nSelIdx-1].text) == 1) {
		this.divPage.form.imgPrev.set_visible(false);
	} else {
		this.divPage.form.imgPrev.set_visible(true);
	}	

	if(parseInt(this.foArrImg[0].text) == 1) {
		this.divPage.form.imgPrevPage.set_visible(false);
	} else {
		this.divPage.form.imgPrevPage.set_visible(true);
	}
	
	if (initFlg != true){
		var pageIndex = parseInt(this.foArrImg[this.fv_selIdx-1].text);
		this.fv_dsPageInfo.setColumn(0, "pageIndex", pageIndex);

		if(isFunction(this.fv_buttonOrSearchFunction)){
			var searchFunction = this.fv_buttonOrSearchFunction;
			var senderObj = null;
			searchFunction.call(this.fv_mainForm, senderObj, {
				pageIndex: pageIndex,
			});
		}else{
			var button = this.fv_buttonOrSearchFunction;
			var onclickHandler = button.getEventHandler('onclick', 0);
			if(onclickHandler == null || onclickHandler == undefined) return;
			
			onclickHandler.call(this.fv_mainForm, button, {
				pageIndex: pageIndex,
			});
		}
	}

//	if(GetCurrentComponent() == null) this.SetFocus();
};

this.fnMovePrev = function()
{
	if(this.fv_selIdx == 1) {
		this.fnMovePrevPage(this.fv_pageBtnCnt);
	} else {
		this.fnSelPage(this.fv_selIdx-1, false);
	}
};

this.fnMoveNext = function()
{
	if(this.fv_selIdx + 1 <= this.fv_pageBtnCnt ) {
		this.fnSelPage(this.fv_selIdx + 1, false);
	} else {
		this.fnMoveNextPage(1);
	}
};

this.fnMovePrevPage = function(nSelPage)
{
    var nPage = parseInt(this.foArrImg[0].text) - this.fv_pageBtnCnt;
	if(nPage < 1) nPage = 1;

	for(var i = 0; i < this.fv_pageBtnCnt; i++)
	{
		if(i + nPage > this.fv_lastPage) 
		{
			this.foArrImg[i].set_visible(false);
		}
		else
		{		
			this.foArrImg[i].set_text(i + nPage);
			this.foArrImg[i].set_visible(true);
		}
	}
	this.fnRedrawPage();
	this.fnSelPage(nSelPage, false);
};

this.fnMoveNextPage = function(nSelPage)
{
	var nPage = parseInt(this.foArrImg[0].text) + this.fv_pageBtnCnt;
	if(nPage > this.fvLastPage) return;

	for(var i = 0; i < this.fv_pageBtnCnt; i++)
	{
		if(i + nPage > this.fv_lastPage) 
		{
			this.foArrImg[i].set_visible(false);
			this.foArrImg[i].set_text("");
		}
		else
		{		
			this.foArrImg[i].set_text((i + nPage));
			this.foArrImg[i].set_visible(true);
		}
	}
	
	this.fnRedrawPage();
	this.fnSelPage(nSelPage, false);
};]]></Script>
  </Form>
</FDL>
