<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="comp_ImgCrop" width="820" height="650" titletext="이미지크롭팝업" onload="comp_ImgCrop_onload">
    <Layouts>
      <Layout height="650" width="820" screenid="ScreenDeskTop">
        <Div id="divOption" taborder="0" text="div00" left="0" top="0" right="0" background="#f2f2f2" height="90" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staOption00_00" taborder="0" text="파일선택" left="34" top="14" width="60" height="20" textAlign="center" initvalueid="ivStcAccessibilityOn"/>
              <Button id="btn00" taborder="1" left="48" top="39" width="33" height="33" onclick="btn00_onclick" cssclass="btn_CP_FileSelect" tooltiptext="이미지파일선택" initvalueid="ivBtnAccessibilityButton" accessibilitydescription="이미지파일을 선택해주세요" accessibilitylabel="파일선택"/>
              <Static id="staOption00" taborder="2" text="Drag Mode" left="118" top="14" width="71" height="20" textAlign="center" initvalueid="ivStcAccessibilityOn"/>
              <Button id="btnDragModeMove" taborder="3" left="117" top="39" width="33" height="33" onclick="divOption_btnDragModeMove_onclick" tooltiptext="드래그할 경우 배경이미지가움직입니다." cssclass="btn_CP_Move" initvalueid="ivBtnAccessibilityButton" accessibilitydescription="드래그할 경우 배경이미지가움직입니다." accessibilitylabel="이미지이동"/>
              <Button id="btnDragModeCrop" taborder="4" left="156" top="39" width="33" height="33" onclick="divOption_btnDragModeCrop_onclick" tooltiptext="드래그할 경우 이미지선택영역박스가움직입니다." cssclass="btn_CP_Crop" initvalueid="ivBtnAccessibilityButton" accessibilitydescription="드래그할 경우 이미지선택영역박스가움직입니다." accessibilitylabel="이미지크롭박스이동"/>
              <Static id="staOption02" taborder="5" text="이미지 회전" left="227" top="14" width="68" height="20" textAlign="center" initvalueid="ivStcAccessibilityOn"/>
              <Button id="btnRotateLeft" taborder="7" left="264" top="39" width="33" height="33" onclick="divOption_btnRotateLeft_onclick" tooltiptext="시계방향 - 90도" cssclass="btn_CP_LeftTurn" initvalueid="ivBtnAccessibilityButton" accessibilitydescription="반시계방향으로 이미지를회전합니다."/>
              <Button id="btnRotateRight" taborder="6" left="225" top="39" width="33" height="33" onclick="divOption_btnRotateRight_onclick" tooltiptext="반시계방향 - 90도" cssclass="btn_CP_RightTurn" initvalueid="ivBtnAccessibilityButton" accessibilitydescription="반시계방향으로 이미지를회전합니다."/>
              <Static id="staOption03" taborder="8" text="이미지 확대/축소" left="451" top="14" width="99" height="20" textAlign="center" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtScaleRate" taborder="9" left="333" top="39" width="83" height="33" enable="true" readonly="true" initvalueid="ivEdtReadOnly" accessibilitylabel="이미지의 현재 확대비율를 표시합니다."/>
              <Button id="btnScalePlus" taborder="10" text="+10%" left="422" top="39" width="48" height="33" onclick="divOption_btnScalePlus_onclick" tooltiptext="이미지확대 10%" cssclass="btn_CP_Text" initvalueid="ivBtnAccessibilityButton" accessibilitydescription="이미지를 10% 확대합니다."/>
              <Button id="btnScale100" taborder="11" text="100%" left="476" top="39" width="48" height="33" onclick="divOption_btnScale100_onclick" tooltiptext="이미지100%로 원복" cssclass="btn_CP_Text" initvalueid="ivBtnAccessibilityButton" accessibilitydescription="이미지를 100%로 원복시킵니다"/>
              <Button id="btnScaleMinus" taborder="12" text="-10%" left="530" top="39" width="48" height="33" onclick="divOption_btnScaleMinus_onclick" tooltiptext="이미지축소 10%" cssclass="btn_CP_Text" initvalueid="ivBtnAccessibilityButton" accessibilitydescription="이미지를 10% 축소합니다."/>
              <Static id="staOption04" taborder="13" text="이미지 반전" left="612" top="14" width="76" height="20" textAlign="center" initvalueid="ivStcAccessibilityOn"/>
              <Button id="btnReverseVertical" taborder="14" left="614" top="39" width="33" height="33" onclick="divOption_btnReverseVertical_onclick" tooltiptext="상하 이미지반전" cssclass="btn_CP_TopBottom" initvalueid="ivBtnAccessibilityButton" accessibilitydescription="이미지를 상하 반전시킵니다." accessibilitylabel="상하 이미지반전"/>
              <Button id="btnReverseHorizon" taborder="15" left="653" top="39" width="33" height="33" onclick="divOption_btnReverseHorizon_onclick" tooltiptext="좌우이미지반전" cssclass="btn_CP_RightLeft" initvalueid="ivBtnAccessibilityButton" accessibilitydescription="이미지를 좌우 반전시킵니다." accessibilitylabel="좌우이미지반전"/>
              <Static id="staOption05" taborder="16" text="이미지 자르기" left="708" top="14" width="80" height="20" textAlign="center" initvalueid="ivStcAccessibilityOn"/>
              <Button id="btnCrop" taborder="17" left="732" top="39" width="33" height="33" onclick="divOption_btnCrop_onclick" tooltiptext="이미지자르기" cssclass="btn_CP_ImgCut" initvalueid="ivBtnAccessibilityButton" accessibilitydescription="이미지를 선택된 영역만큼 자릅니다." accessibilitylabel="이미지자르기"/>
              <Static id="staOption01" taborder="18" text="자르기영역" left="1218" top="20" width="120" height="30" visible="false"/>
              <Radio id="rdoCropRectType" taborder="19" left="1037" top="28" width="160" height="30" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" columncount="2" onitemchanged="divOption_rdoCropRectType_onitemchanged" value="free" text="Free" index="0" visible="false">
                <Dataset id="innerdataset">
                  <ColumnInfo>
                    <Column id="codecolumn" size="256"/>
                    <Column id="datacolumn" size="256"/>
                  </ColumnInfo>
                  <Rows>
                    <Row>
                      <Col id="codecolumn">free</Col>
                      <Col id="datacolumn">Free</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">static</Col>
                      <Col id="datacolumn">고정</Col>
                    </Row>
                  </Rows>
                </Dataset>
              </Radio>
              <Static id="sta00_00" taborder="20" text="W" left="1221" top="52" width="15" height="27" visible="false"/>
              <Edit id="edtCropRectWidth" taborder="21" left="1236" top="52" width="57" height="27" enable="true" readonly="true" visible="false"/>
              <Static id="sta00" taborder="22" text="H" left="1303" top="52" width="15" height="27" visible="false"/>
              <Edit id="edtCropRectHeight" taborder="23" left="1317" top="52" width="57" height="27" enable="true" readonly="true" visible="false"/>
              <Button id="btnCropRectSetting" taborder="24" text="실행" left="1378" top="50" width="30" height="30" onclick="divOption_btnCropRectSetting_onclick" tooltiptext="실행" visible="false"/>
              <Static id="sta01" taborder="25" left="206" top="45" width="10" height="20" cssclass="sta_TF_Section16B" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta01_00" taborder="26" left="316" top="45" width="10" height="20" cssclass="sta_TF_Section16B" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta01_00_00" taborder="27" left="596" top="45" width="10" height="20" cssclass="sta_TF_Section16B" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta01_00_00_00" taborder="28" left="707" top="45" width="10" height="20" cssclass="sta_TF_Section16B" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta01_01" taborder="29" left="99" top="45" width="10" height="20" cssclass="sta_TF_Section16B" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staOption05" taborder="2" text="자른 이미지" left="667" top="102" width="110" height="30" initvalueid="ivStcAccessibilityOn"/>
        <ImageViewer id="imgCropped" taborder="3" left="665" top="134" stretch="fit" height="158" width="140" initvalueid="ivImgAccessibilityOn" accessibilitydescription="자른 이미지를 표시합니다."/>
        <Static id="staImageCropByte" taborder="4" text="사이즈 :  0 (KB)" left="671" top="311" width="130" height="118" initvalueid="ivStcAccessibilityOn" visible="true" verticalAlign="top"/>
        <Button id="btnSave" taborder="6" text="저장" left="290" width="80" height="32" bottom="20" initvalueid="ivBtnAccessibilityButton" onclick="btnSave_onclick"/>
        <Div id="div00" taborder="1" text="div00" left="20" top="110" width="630" height="430" border="1px solid #dddddd" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <WebBrowser id="webImageCrop" taborder="0" left="0" top="0" onusernotify="webImageCrop_onusernotify" onloadcompleted="webImageCrop_onloadcompleted" initvalueid="ivWebAccessibilityOn" right="0" bottom="0" visible="false"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta00" taborder="5" text="*&lt;b value=&quot;true&quot;&gt;&lt;fc value=&quot;red&quot;&gt; [이미지자르기]&lt;/fc&gt;를 한 후 &lt;fc value=&quot;red&quot;&gt;[저장]&lt;/fc&gt;버튼을 누르시기 바랍니다.&lt;/b&gt;" left="20" top="546" width="631" height="37" usedecorate="true"/>
        <Button id="btnClose" taborder="7" text="닫기" left="380" width="80" height="32" bottom="20" onclick="btnClose_onclick" initvalueid="ivBtnAccessibilityButton"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민 - 이미지크롭 공통팝업
*  @MenuPath    공통
*  @FileName 	comp_ImgCrop.xfdl
*  @Creator 	정인혁
*  @CreateDate 	2022.10.4
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.10.4     	정인혁 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvFileName = "crop.png";

this.fvCropImageInfo = {
					      imageType             : ""
						, imageFileName         : ""
						, imageDataBase64       : ""
						, imageDataBase64Reduce : ""
                       };
// 자른 이미지의 사이즈를	표시하기 위한 처리				   
this.fv_LimitUnitByte     = 1024;  // 1024 : KB, 실제 사이즈 = this.fv_LimitUnitByte * this.fv_LimitByte
this.fv_LimitByte         = 100;
this.fv_ImageDispUnitText = "KB";
this.fv_uselimitsize = false;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
//   
this.comp_ImgCrop_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitPopup(this);
	
	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	
	//http://localhost:8080/html/imagecrop/cropperjs_nexacro.html
	//var sUrlPath = window.location.protocol + "//" + window.location.host;
	var sUrlPath = this.smfGetBaseUrl(); //window.location.protocol + "//" + window.location.host;
	var sUrl =  sUrlPath + "/html/imagecrop/cropperjs_nexacro.html";
	
	// Url세팅
	this.div00.form.webImageCrop.set_url(sUrl);		
	
	// 파일사이즈 제한을 세팅한다.
	if(this.pv_params.limitFileSize)
	{
		this.fv_uselimitsize = true;
		this.staImageCropByte.set_visible(true);
		
		this.fv_ImageDispUnitText = this.pv_params.limitFileUnit || "KB";
		this.fv_LimitByte = parseInt(this.pv_params.limitFileSize);
		if(this.fv_ImageDispUnitText=="KB")
		{  // KB
			this.fv_LimitUnitByte = 1024;
		}
		else if(this.fv_ImageDispUnitText=="MB")
		{  // MB
			this.fv_LimitUnitByte = 1024*1000;
		}
		else
		{  // GB
			this.fv_LimitUnitByte = 1024*1000*1000;
		}
		
		this.fnDisplayImageCropByteInfo(0);
	}
	else
	{
		this.fv_uselimitsize = false;
		//this.staImageCropByte.set_visible(false);	
	}
	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function()
{

}
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnSetData = function()
{
	
}

// 자른 이미지의 바이트수를 표시한다.
this.fnDisplayImageCropByteInfo = function(nImageByte,nImageReduceByte)
{
	var nLimitByte = this.fv_LimitByte;
	var sUnitText  = this.fv_ImageDispUnitText || "KB";
	var sText = "이미지사이즈 :  " + parseInt(nImageByte / this.fv_LimitUnitByte);
	
	if(this.fv_uselimitsize)
	{
		sText += "\n"+" / " + nLimitByte;
	}
	
	// 단위를 표시
	sText += " (" + sUnitText + ")";
	
	// 압축했을 경우 - 압축이미지를 사용
	if(nImageReduceByte)
	{
		sText += "\n"+ "압축시 : "+parseInt(nImageReduceByte / this.fv_LimitUnitByte)+" ("+sUnitText+")"
	}
	
	this.staImageCropByte.set_text(sText);
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.divOption_btnDragModeMove_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.div00.form.webImageCrop.callMethod("setDragMode","move");
};

this.divOption_btnDragModeCrop_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.div00.form.webImageCrop.callMethod("setDragMode","crop");	
};

this.divOption_rdoCropRectType_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	if(e.postvalue=="free")
	{
		this.divOption.form.edtCropRectWidth.set_readonly(true);
		this.divOption.form.edtCropRectHeight.set_readonly(true);
		this.divOption.form.btnCropRectSetting.set_enable(false);
	}
	else
	{
		this.divOption.form.edtCropRectWidth.set_readonly(false);
		this.divOption.form.edtCropRectHeight.set_readonly(false);
		this.divOption.form.btnCropRectSetting.set_enable(true);
	}
};

this.divOption_btnCropRectSetting_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var nWidth  = parseInt(this.divOption.form.edtCropRectWidth.value) || 0;
	var nHeight = parseInt(this.divOption.form.edtCropRectHeight.value) || 0;
	
	var objJson = {width:nWidth , height:nHeight};
	this.div00.form.webImageCrop.callMethod("setCropBoxData",objJson);	
};

this.divOption_btnRotateLeft_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.div00.form.webImageCrop.callMethod("rotateLeft");
};

this.divOption_btnRotateRight_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.div00.form.webImageCrop.callMethod("rotateRight");
};

this.divOption_btnScalePlus_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.div00.form.webImageCrop.callMethod("zoomPlus");
};

this.divOption_btnScale100_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.div00.form.webImageCrop.callMethod("zoom100");
};

this.divOption_btnScaleMinus_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.div00.form.webImageCrop.callMethod("zoomMinus");
};

this.divOption_btnReverseVertical_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.div00.form.webImageCrop.callMethod("reverseImage","vertical");
};

this.divOption_btnReverseHorizon_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.div00.form.webImageCrop.callMethod("reverseImage","horizontal");
};

this.divOption_btnCrop_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fvCropImageInfo = this.div00.form.webImageCrop.callMethod("crop");
	
	if(!this.smfIsNull(this.fvCropImageInfo.imageDataBase64Reduce))
	{
		this.imgCropped.set_image(this.fvCropImageInfo.imageDataBase64Reduce);

		// 자른 이미지의 사이즈를 표시한다.
		var nCropImageSize = this.fvCropImageInfo.imageDataBase64.length;
		var nReduceCropImageSize = this.fvCropImageInfo.imageDataBase64Reduce.length;
		this.fnDisplayImageCropByteInfo(nCropImageSize,nReduceCropImageSize);
	}
	
	
};

this.divOption_btnCropSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objCroppedCanvas = this.div00.form.webImageCrop.callMethod("crop");
	var sUrlData = objCroppedCanvas.toDataURL();
	
	var vsFileName = this.fvFileName;
	if(vsFileName.lastIndexOf(".png") == -1) {
		vsFileName += ".png";
	}
	
	var a = document.createElement("a");
	a.href = sUrlData;
	a.setAttribute("download", vsFileName);
	document.body.appendChild(a);
	a.click();
	document.body.removeChild(a);
};

this.webImageCrop_onusernotify = function(obj:nexacro.WebBrowser,e:nexacro.WebUserNotifyEventInfo)
{
	if(e.userdata=="detail")
	{
		var sVal = this.div00.form.webImageCrop.callMethod("getNexacroData");
		//trace("webImageCrop_onusernotify - detail : [" + sVal + "]");
		
		var objDetail = JSON.parse(sVal);
		this.divOption.form.edtCropRectWidth.set_value(parseInt(objDetail.width));
		this.divOption.form.edtCropRectHeight.set_value(parseInt(objDetail.height));
	}
	else if(e.userdata=="zoom")
	{
		var sVal = this.div00.form.webImageCrop.callMethod("getNexacroData");
		//trace("webImageCrop_onusernotify - zoom : [" + sVal + "]");
		
		var objDetail = JSON.parse(sVal);
		this.divOption.form.edtScaleRate.set_value(parseInt(objDetail.ratio*100));
	}
};

this.btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.div00.form.webImageCrop.visible==false)
	{
		this.div00.form.webImageCrop.set_visible(true);
	}
	this.div00.form.webImageCrop.callMethod("fnSelectFile");
};

this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};

this.webImageCrop_onloadcompleted = function(obj:nexacro.WebBrowser,e:nexacro.WebLoadCompEventInfo)
{
	// 파일선택
	//this.btn00.click();
};

this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.smfIsNull(this.fvCropImageInfo.imageDataBase64))
	{
		this.smfAlert("이미지를 자르기하지 않고 팝업을 닫으려고 합니다.", function(){
		}); // 저장하시겠습니까?		
	}
	else
	{
		// 응답을 
		this.smfSendResponseToOpener({
			"imageInfo": this.fvCropImageInfo
		});
		
		this.close(true);
	}
};
]]></Script>
  </Form>
</FDL>
