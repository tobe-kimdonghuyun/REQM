    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민 
*  @MenuPath    TEMPLATE
*  @FileName 	comm_cddcList.xfdl
*  @Creator 	정인혁
*  @CreateDate 	2022.5.25
*  @Desction    검정고시p72+(공지목록)+(타이틀,그리드)
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.5.25     	정인혁 	        최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.objApp = nexacro.getApplication();
this.fvSubSysGb = "";
this.pv_params;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
  
this.comm_selectCddc_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	if(this.opener)
	{
		this.smfInitPopup(this);
		this.pv_params = this.smfGetPopupParams();
	}
	else
	{
		this.smfInitForm(this);
		this.pv_params = this.smfGetFormParams();
	}
	
	var sSubSystemGb = this.smfGetSubSystemGb();
	this.fvSubSysGb = sSubSystemGb;
	
	if(sSubSystemGb=="ORE"||sSubSystemGb=="HRD")  // 채용
	{
		//this.divOre.set_visible(true);
		//this.fnSetTitleText("채용");
		this.fnSetTitleText("");	
	}
	else if(sSubSystemGb=="SQA")   // 검정고시
	{
		//@KBR 모바일 사용하지 않지만 만약의 상황에 대비하기 위해 if문 작성
		if( !this.smfIsMobile()){
			this.divSqa.move(this.divOre.left,this.divOre.top);
			this.divSqa.set_visible(true);
		}
		this.fnSetTitleText("검정고시");
	}
	else if(sSubSystemGb=="UDS")   // 대입전형
	{
		//@KBR 모바일 사용하지 않지만 만약의 상황에 대비하기 위해 if문 작성
		if( !this.smfIsMobile() ){
			this.divUds.move(this.divOre.left,this.divOre.top);
			this.divUds.set_visible(true);	
		}
		this.fnSetTitleText("대입전형");
	}
	else if(  (sSubSystemGb=="AFS")   // 업무지원(외부강사)
		  || (sSubSystemGb=="ECC")   // 업무지원(돌봄인력서비스)
		  || (sSubSystemGb=="IBM")   // 업무지원(교과용도서)
		  || (sSubSystemGb=="SEM")   // 업무지원(학교환경관리)
		  || (sSubSystemGb=="PHE")   // 업무지원(체육)
		  || (sSubSystemGb=="SML")   // 업무지원(급식)
		  || (sSubSystemGb=="SPR")   // 업무지원(교육복지)
		  )
	{
		this.staSelectTitle.set_left("7%");
		this.staSelectedCddcName.set_left("5%");
		this.btnClose.set_left("5%");
		this.fnSetTitleText("");
	}
	else
	{
		this.fnSetTitleText("");
	}
// 	else if(sSubSystemGb=="HES"||sSubSystemGb=="BDM")   // 학원관련민원/비영리법인민원
// 	{
// 		this.divHes.move(this.divOre.left,this.divOre.top);
// 		this.divHes.set_visible(true);
// 	}


	this.divKorMap.set_url("comm::comp_korMap.xfdl");
	// Map에 callback함수를 선택한다.
	this.divKorMap.form.fnSetInit(this,this.fnMapSelecetCallback);

	if(this.opener)
	{
		nexacro.getApplication().mainframe.VFrameSet.frameMain.form._fvPopup = this.getOwnerFrame();
		this.divKorMap.form.graMap.redraw();
	}	
	
	this.comm_selectCddc_onsize();
	this.resetScroll();

	if(  (sSubSystemGb=="SQA")   // 업무지원(외부강사)
	  || (sSubSystemGb=="BDM")   // 업무지원(돌봄인력서비스)
	  )
	{
		var sMsg = "검정고시 포털은 모바일을 지원하지 않습니다. PC에서 사용하여 주시기 바랍니다.";
	
		if(sSubSystemGb=="BDM")
		{
			sMsg = "비영리법인민원 포털은 모바일을 지원하지 않습니다. PC에서 사용하여 주시기 바랍니다.";
		}
	
		if(this.smfIsMobile()){
			this.smfAlert(sMsg, [], function ()
			{
				var sUrl = this.fnGetPortalUrl();
				
				// 화면을 이동시킨다.
				window.location.href = sUrl;				
				
				// 화며을 닫는다.
				//window.open('','_self').close();
			});
			return;
			
		}	
	}		
	
	//@KBR 콤보 인덱스 변경
	this.cboCddcList.set_index(-1);
};

this.comm_selectCddc_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	//divKorMap 가운데 정렬
	if( this.smfIsMobile() )
	{
		var nWidth = this.width;
		var nLeft = (this.width - this.divKorMap.getOffsetWidth()) /2;
		this.divKorMap.set_left(nLeft);
		this.resetScroll();
	}else {
		var nPos = nexacro.toNumber(this.cboCddcList.left) + nexacro.toNumber(this.cboCddcList.width)+4;		
		if (this.width < nPos) {
			this.staBg.set_width(nPos);
		}else {
			this.staBg.set_right(0);
		}
		
		var nWidth  = this.width;
		var nDispWidth =  this.divKorMap.getOffsetRight() -  this.staSelectedCddcName.getOffsetLeft();
		var nLeft = parseInt(nWidth-nDispWidth)/2;
		
		if(nLeft<0) nLeft=0;
		
		trace("=====nLeft:");
		
		this.staPopupTitleAss.setOffsetLeft(nLeft);		
		
		this.resetScroll();
	}
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
};

this.fnMapSelecetCallback = function (sSelCode,sSelName)
{
	
	//for(var i=0;i< arguments.length;i++)
	//{
	//	trace("i="+i+" , arguments=["+arguments[i]+"]" + this.id);
	//}
	
	var sText = "";
	if(this.smfIsNull(sSelName))
	{
		sText = "지도에서 교육청을\n선택해주세요";
		this.btnClose.set_enable(false);
		this.btnClose.set_accessibilitylabel("");
	}
	else
	{
		sText = "현재 선택하신 교육청은\n<fc v='#2b72de'><u v='true'>"+sSelName+"</u></fc> \n입니다.";
		this.btnClose.set_enable(true);
		this.btnClose.set_accessibilitylabel(sSelName);
	}

	this.staSelectedCddcName.set_text(sText);
	this.resetScroll();
	
	// combo의 값을 변경한다.
	this.cboCddcList.set_value(sSelCode);
	
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnOnsizeProc = function(e:nexacro.SizeEventInfo)
{
	var nFrameWidth  = e.cx;
	var nFrameHeight = e.cy;
	var nPopupTitleHeight = 0;//45;
	trace("====>fnOnsizeProc : nFrameWidth="+nFrameWidth+",nFrameHeight="+nFrameHeight+",nPopupTitleHeight="+nPopupTitleHeight);
	
	// ChildFrame의 넓이 높이를 조정
	this.parent.set_width (nFrameWidth                   );  
	this.parent.set_height(nFrameHeight-nPopupTitleHeight);
	this.parent.setOffsetLeft(0);
	this.parent.setOffsetTop (0);
}
 
// 지정된 버튼이 선택한 모드로 변경한다.
this.fnChangeSelectMode = function(objDiv, objBtn)
{
	// 버튼의 값이 없는 경우
	if(this.smfIsNull(objBtn._value))
	{
		return;
	}
	
	var objComps = objDiv.form.components;
	
	for(var i=0;i<objComps.length;i++)
	{
		objComp = objComps[i];
		if((objComp instanceof nexacro.Button)&&(!this.smfIsNull(objComp._value)))
		{
			if(objBtn.id==objComp.id)
			{
				objComp.set_cssclass(objComp._selCssclass);
			}
			else
			{
				objComp.set_cssclass(objComp._deSelCssclass);
			}
		}
	}
	
}

// 지정된 버튼이 선택한 모드로 변경한다.
this.fnGetSelectedButton = function(objDiv)
{
	var objSelectedBtn=null;
	
	if(objDiv.visible)
	{
		var objComps = objDiv.form.components;
		for(var i=0;i<objComps.length;i++)
		{
			objComp = objComps[i];
			if((objComp instanceof nexacro.Button)&&(!this.smfIsNull(objComp._value)))
			{
				if((objComp.cssclass=="btn_WF_MapTapS01")||(objComp.cssclass=="btn_WF_MapTapS02")||(objComp.cssclass=="btn_WF_MapTapS03"))
				{
					objSelectedBtn  = objComp;
					break;
				}
			}
		}
	}
	return objSelectedBtn;
}

// 상단 Title을 세팅한다.
this.fnSetTitleText = function(sServiceName)
{
	var sTitleText="";
	if(this.smfIsNull(sServiceName))
	{
		sTitleText = "<fc v='#2b72de'><b v='true'>원하시는 교육청</b></fc> 을 "+(this.smfIsMobile() ? "\n" : "")+"선택해주세요.";
	}
	else
	{
		sTitleText = "<fc v='#2b72de'><b v='true'>"+sServiceName+"분야</b></fc> 서비스와 교육청을 선택해주세요.";
	}
	
	this.staSelectTitle.set_text(sTitleText);
	this.resetScroll();
}

this.fnGetSubSysDetailName = function(sSubsysDetailGb)
{
	var objDetailName = {  "001" : "유·초등교원","002" : "중등교원","003" : "지방공무원","004" : "교육공무직","005" : "계약제교원인력풀"}
	var sDetailName = this.smfNvl(objDetailName[sSubsysDetailGb],"");
	
	return sDetailName;
}

this.fnGetPortalUrl = function()
{
	var sPortalUrl = "";
	var sRunMode = nexacro.getEnvironmentVariable("ev_runMode");  // "1" : 로컬,
	switch(sRunMode)
	{
		case "1" :  // 로컬
		   sPortalUrl = "http://localhost:8080/nxuiPortal/index.html";break;
		case "2" :  // 개발
		   sPortalUrl = "http://dev.neis.go.kr";break;
		case "3" :  // 운영
		   //sPortalUrl = "neis.go.kr";break;
		   sPortalUrl = "https://www.neis.go.kr";break;  
		case "4" :  // 검증
		   sPortalUrl = "http://tst.neis.go.kr";break;
	}
	
	return sPortalUrl;
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// [온라인채용 종류]버튼을 선택시 이벤트 처리
this.ButtonSelMode1_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnChangeSelectMode(obj.parent.parent,obj);	
};

// [검정고시 종류]버튼을 선택시 이벤트 처리
this.ButtonSelMode2_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnChangeSelectMode(obj.parent.parent,obj);
};

// [대입전형]버튼을 선택시 이벤트 처리
this.ButtonSelMode3_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnChangeSelectMode(obj.parent.parent,obj);
};

// [시도교육청]버튼을 선택시 이벤트 처리
this.ButtonSelModeCddcList_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnChangeSelectMode(obj.parent.parent,obj);	
};

// [닫기]버튼을 선택시 이벤트 처리
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objSelVal={selVal1:"",selVal1:"",selVal1:""};
	
	// 상단 선택값을 구한다.
	var objSel1;
	var sSelVal2 = "";
	if(this.divOre.visible)
	{
		objSel1 = this.fnGetSelectedButton(this.divOre     );	
		sSelVal2 = objSel1._subTitle;
	}
	else if(this.divSqa.visible)
	{
		objSel1 = this.fnGetSelectedButton(this.divSqa     );
		sSelVal2 = objSel1._subTitle;
	}
	else if(this.divUds.visible)
	{
		objSel1 = this.fnGetSelectedButton(this.divUds     );
	}	
	
	if(objSel1)
	{
		objSelVal.selVal1 = objSel1._value;
	}
	
	var sSelectedCddcCode = this.divKorMap.form.fnGetSelectCode();
	var sSelectedCddcName = this.divKorMap.form.fnGetSelectName();
	objSelVal.selVal3 = sSelectedCddcCode;
	
	// 교육청이 선택됐는지 체크한다.
	if(this.smfIsNull(sSelectedCddcCode))
	{
		this.smfAlert("시도교육청을선택하여주시기 바랍니다.");
		return;
	}
	
	var sSubSystemGb = this.smfGetSubSystemGb();
	if(  (sSubSystemGb=="AFS")       // 업무지원(방과후학교)
	  || (sSubSystemGb=="ECC")       // 업무지원(초등돌봄)
	  )
	{
		this.smfSetCddcCode(sSelectedCddcCode);
	
		var params = {};
		params.usertype = sSubSystemGb=="AFS" ? "AFS" : "ECC";
		var sUrl = "frame::afs/frameSelectTarget.xfdl";
		if (this.smfIsMobile()){ // 방과후학교는 모바일시 개인사업자만 간편인증 로그인
			sUrl = "frame::frameLoginNpki01.xfdl";
		}
		var bShowHead = false;
		this.smfSetWorkPage(sUrl,params,bShowHead);
	}
	else if( (sSubSystemGb=="IBM")   // 업무지원(교과용도서)
		  || (sSubSystemGb=="SEM")   // 업무지원(학교환경관리)
		  || (sSubSystemGb=="SPR")   // 업무지원(교육복지)
		  )
	{
		this.smfSetCddcCode(sSelectedCddcCode);
		
		var params = {usertype:2};   // 0:교직원, 1:개인, 2:사업자
		var sUrl = "frame::frameLoginNpki02.xfdl";
		var bShowHead = false;
		this.smfSetWorkPage(sUrl,params,bShowHead);
	}
	else if( (sSubSystemGb=="PHE")   // 업무지원(체육)
		  || (sSubSystemGb=="SML")   // 업무지원(급식)
		  )
	{
		this.smfSetCddcCode(sSelectedCddcCode);
		
		var params = {};
		var sUrl = "frame::frameLoginOnePass.xfdl";
		var bShowHead = false;
		this.smfSetWorkPage(sUrl,params,bShowHead);
	}
	else
	{
		// (2023.02.15) 온라인채용요구
		if((sSubSystemGb=="ORE")||(sSubSystemGb=="HRD"))
		{
			objSelVal.selVal1 = this.smfGetSubSystemDetailGb();
			sSelVal2 = this.fnGetSubSysDetailName(objSelVal.selVal1);
		}
	
		this.smfSendResponseToOpener({
			  "selVal1" : objSelVal.selVal1     // 서브디테일코드(101,102,103 등)
			, "selVal2" : sSelVal2              // 서브디테일명
			, "selVal3" : objSelVal.selVal3     // 교육청코드
			, "selVal4" : sSelectedCddcName     // 교육청명
		});	
		nexacro.getApplication().mainframe.VFrameSet.frameMain.form._fvPopup = null;
		
		this.close(true);
	}
};

this.btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objMap =this.divKorMap.form.graMap;
	
	var objGraphGroup = objMap.getObjectByID("graGroupMap");
	objGraphGroup.scale(0.5,0.5);
	objMap.redraw();
};

this.cboCddcList_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	var sCddcCd = e.postvalue;
	var sSelName = e.posttext;
	if(!this.smfIsNull(sCddcCd))
	{
		this.divKorMap.form.fnSetCddcCode(sCddcCd);
	}
	
	
	var sText = "";
	if(this.smfIsNull(sSelName))
	{
		sText = "지도에서 교육청을\n선택해주세요";
		this.btnClose.set_enable(false);
		this.btnClose.set_accessibilitylabel("");
	}
	else
	{
		sText = "현재 선택하신 교육청은\n<fc v='#2b72de'><u v='true'>"+sSelName+"</u></fc> \n입니다.";
		this.btnClose.set_enable(true);
		this.btnClose.set_accessibilitylabel(sSelName);
	}

	this.staSelectedCddcName.set_text(sText);	
	this.resetScroll();	
	
};

]]></Script>
    <Objects>
      <Dataset id="dsService">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
  </Form>
</FDL>
