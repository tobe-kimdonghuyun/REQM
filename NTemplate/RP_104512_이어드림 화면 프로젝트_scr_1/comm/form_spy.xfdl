          </Row>
          <Row>
            <Col id="errorCode">55037 테이블이 다중 노드로 구성된 노드 그룹에 있기 때문에 파티션 키를 삭제할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">55038 노드 그룹은 재조정(rebalance)되는 중이므로 사용할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">55039 테이블 스페이스가 적절한 상태에 있지 않기 때문에 액세스 또는 상태 변화가 허용되지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">55041 재조정이 수행되는 동안에는 컨테이너를 테이블 스페이스에 추가할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">55043 구조화된 유형에 근거하는 유형이 지정된 테이블 또는 유형이 지정된 뷰가 있는 경우 이러한 유형의 속성은 변경할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">55045 필요한 구성요소가 서버에서 사용 가능하지 않으므로 루틴에 대한 SQL 아카이브(SAR) 파일을 작성할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">55046 지정된 SQL 아카이브가 목표 환경과 일치하지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">55047 외부 함수 또는 메소드가 페더레이티드 오브젝트에 액세스하려고 했습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">55048 암호화된 데이터는 암호화할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">55049 이벤트 모니터 테이블이 제대로 정의되지 않았습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">55051 ALTER BUFFERPOOL문이 현재 진행 중입니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">55054 메소드를 중첩 메소드로 정의할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">55056 데이터베이스를 페더레이션에 사용할 수 없으므로 별칭 통계를 갱신할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">55060 데이터베이스에 대해 자동 스토리지가 정의되지 않았습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">55061 자동 스토리지 테이블 스페이스의 경로 재지정 리스토어가 허용되지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">55062 자동 스토리지에 데이터베이스를 사용할 수 없기 때문에 스토리지 경로가 제공될 수 없습니다.</Col>
          </Row>
          <Row/>
          <Row>
            <Col id="errorCode">클래스 코드 56 기타 SQL 또는 제품 오류</Col>
          </Row>
          <Row>
            <Col id="errorCode">표 37. 클래스 코드 56: 기타 SQL 또는 제품 오류</Col>
          </Row>
          <Row>
            <Col id="errorCode">의미</Col>
          </Row>
          <Row>
            <Col id="errorCode">56031 이 시스템에서는 혼합 및 DBCS 데이터가 지원되지 않기 때문에 절 또는 스칼라 함수는 유효하지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">56033 Long 문자열 컬럼의 삽입 또는 갱신 값은 호스트 변수 또는 널(NULL)이어야 합니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">56038 이 환경에서는 요청된 기능이 지원되지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">56072 후속 SQL문을 실행하는 데 영향을 미치지 못하는 하위 레벨 서버에서 지원하지 않는 함수로 인해 실행하지 못했습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">56084 LOB 데이터는 DRDA에서 지원되지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">56091 복합 SQL문의 실행 결과로 여러 가지 오류가 발생했습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">56092 인증 이름이 사용자 ID 또는 그룹 ID이기 때문에 인증 유형을 판별할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">56095 바인드 옵션이 유효하지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">56097 LONG VARCHAR와 LONG VARGRAPHIC 필드는 DEVICE에서 빌드된 TABLESPACE에서 허용되지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">56098 내재 리바인드 또는 준비 중에 오류가 발생했습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">56099 REAL 데이터 유형은 목표 데이터베이스에서 지원하지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">560A0 LOB 값에 대한 조치가 실패했습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">560AA 이 시스템에서는 UCS-2가 지원되지 않기 때문에 절 또는 스칼라 함수는 유효하지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">560AC 지정된 유형 또는 데이터 소스 버전에 대해서는 랩퍼 정의를 사용할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">560AF 게이트웨이 집중기를 사용할 때 PREPARE문이 지원되지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">560B0 테이블 스페이스 또는 테이블 스페이스 컨테이너 크기 재지정에 대해 새 크기 값이 유효하지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">560B1 스토어드 프로시저에 유효하지 않은 커서 스펙이 있습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">560B7 복수 행 INSERT의 경우, 시퀀스 표현식의 사용법은 각 행에 대해 동일해야 합니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">560BB 동적으로 준비되는 CALL문의 INOUT 매개변수에서는 USING절과 INTO절에 같은 호스트 변수를 사용해야 합니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">560BC 파일에 액세스하는 중에 오류가 발생했습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">560BD 페더레이티드 서버가 데이터 소스에서 예기치 않은 오류 코드를 수신했습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">560BF 암호화 기능이 사용 불가능합니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">560C0 유니코드 코드화 체계로 작성된 테이블은 SQL 함수 또는 SQL 메소드에 사용할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">560C1 유니코드 코드화 체계로 작성된 테이블은 유형이 지정된 테이블이 되거나, 그래픽 유형 또는 사용자 정의 유형을 포함할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">560C2 삭제된 테이블에 대한 실행기록 파일 항목을 쓰는 데 실패했습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">560C3 이후 트리거는 INSERT문에 삽입 중인 행을 수정할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">560C6 참조 제한조건이 fullselect 내의 SQL 데이터 변경 명령문에서 수정한 행을 수정할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">560C8 일부 별칭 통계를 갱신할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">560C9 지정된 명령문을 설명할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">560CA SQL문이 현재 데이터베이스 파티션에서만 실행될 수 있는 루틴을 참조합니다.</Col>
          </Row>
          <Row/>
          <Row>
            <Col id="errorCode">클래스 코드 57 자원이 사용 가능하지 않거나 조작원이 개입함</Col>
          </Row>
          <Row>
            <Col id="errorCode">표 38. 클래스 코드 57: 자원이 사용 가능하지 않거나 조작원이 개입함</Col>
          </Row>
          <Row>
            <Col id="errorCode">의미</Col>
          </Row>
          <Row>
            <Col id="errorCode">57001 테이블에 1차 인덱스가 없기 때문에 이 테이블을 사용할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57003 지정된 버퍼 풀이 활성화되지 않았습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57007 DROP 또는 ALTER가 보류 중이므로 오브젝트를 사용할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57009 가상 스토리지 또는 데이터베이스 자원이 임시로 사용 불가능하게 되었습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57011 가상 스토리지 또는 데이터베이스 자원을 사용할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57012 데이터베이스가 아닌 다른 자원을 사용할 수 없습니다. 이는 후속 명령문의 정상적인 실행에 영향을 주지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57013 데이터베이스가 아닌 다른 자원을 사용할 수 없습니다. 이는 후속 명령문의 정상적인 실행에 영향을 주지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57014 처리가 요청된 대로 취소되었습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57016 테이블이 활성화되지 않으므로 액세스할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57017 문자 변환이 정의되지 않았습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57019 자원 문제점으로 인해 명령문이 실패했습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57020 데이터베이스가 들어 있는 드라이브가 잠겨 있습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57021 디스켓 드라이브 문이 열려 있습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57022 명령문의 권한 부여 ID가 적절한 DB 스페이스를 소유하지 않으므로 테이블을 작성할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57030 응용프로그램 서버(AS)로의 연결이 정의된 설치 한계를 초과했습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57032 최대수의 동시 데이터베이스가 시작되었습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57033 자동 롤백 없이 교착 상태 또는 시간종료가 발생했습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57036 트랜잭션 로그가 현재 데이터베이스에 속하지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57046 데이터베이스 또는 인스턴스가 Quiesce 상태이기 때문에 새로운 트랜잭션을 시작할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57047 디렉토리에 액세스할 수 없기 때문에 내부 데이터베이스 파일을 작성할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57048 테이블 스페이스에 대한 컨테이너에 액세스하는 동안 오류가 발생했습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57049 운영 체제 프로세스 한계에 도달했습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57050 파일 서버가 현재 사용 가능하지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57051 계산된 CPU 비용이 자원 한계를 초과합니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57052 노드에 모든 임시 테이블 스페이스에 대한 컨테이너가 없으므로 이 노드를 사용할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57053 조작이 충돌되므로 테이블에서 조작을 수행할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57055 페이지 크기가 충분한 임시 테이블 스페이스를 사용할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57056 데이터베이스가 NO PACKAGE LOCK 모드에 있으므로 패키지를 사용할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57057 SQL문 DRDA 체인의 이전 상태로 인해 SQL문을 실행할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">57059 테이블 스페이스에 지정된 조치에 사용할 수 있는 스페이스가 충분하지 않습니다.</Col>
          </Row>
          <Row/>
          <Row>
            <Col id="errorCode">클래스 코드 58 시스템 오류</Col>
          </Row>
          <Row>
            <Col id="errorCode">표 39. 클래스 코드 58: 시스템 오류</Col>
          </Row>
          <Row>
            <Col id="errorCode">58004 시스템 오류(후속 SQL문을 정상적으로 실행할 수는 있음)가 발생했습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">58005 시스템 오류(후속 SQL문을 정상적으로 실행하지 못하게 함)가 발생했습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">58008 후속 DDM 명령 또는 SQL문의 정상적인 실행에는 영향을 주지 않는 분산 프로토콜 오류로 인해 실행에 실패했습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">58009 대화가 할당해제되게 만드는 분산 프로토콜 오류로 인해 실행에 실패했습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">58010 후속 DDM 명령 또는 SQL 문의 정상적인 실행에 영향을 주는 분산 프로토콜 오류로 인해 실행에 실패했습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">58011 바인드 프로세스가 진행되는 동안 DDM 명령이 유효하지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">58012 지정된 패키지명과 일치하는 토큰을 사용한 바인드 프로세스가 실행 중이 아닙니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">58014 DDM 명령이 지원되지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">58015 DDM 오브젝트가 지원되지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">58016 DDM 매개변수가 지원되지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">58017 DDM 매개변수 값이 지원되지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">58018 DDM 응답 메시지가 지원되지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">58023 시스템 오류로 인해 현재 프로그램이 취소되었습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">58030 입출력 오류가 발생했습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">58031 시스템 오류로 인해 연결에 실패했습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">58032 분리 모드 사용자 정의 함수(UDF)에 대한 프로세스를 사용할 수 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">58034 DMS 테이블 스페이스에서 오브젝트에 대한 페이지를 찾는 중에 오류가 발견되었습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">58035 DMS 테이블 스페이스에서 오브젝트에 대한 빈 페이지를 찾는 중에 오류가 발견되었습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">58036 지정된 내부 테이블 스페이스 ID가 없습니다.</Col>
          </Row>
          <Row>
            <Col id="errorCode">ZZZZZ 플레이스 홀더 sqlstate는 개발용으로만 사용하십시오. 코드 이동 전 변경해야 합니다.</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsOrgClassClrmCode" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="firstCode" type="STRING" size="30" value=""/>
          <ConstColumn id="filterExpr" type="STRING" size="30" value=""/>
          <ConstColumn id="cmbType" type="STRING" size="30" value="orgClassClrmCode"/>
          <Column id="classClrmCode" type="STRING" size="30"/>
          <Column id="classClrmCodeNm" type="STRING" size="120"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsOrgSbjtClrmCode" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="firstCode" type="STRING" size="30" value=""/>
          <ConstColumn id="filterExpr" type="STRING" size="30" value=""/>
          <ConstColumn id="cmbType" type="STRING" size="30" value="orgSbjtClrmCode"/>
          <Column id="sbjtClrmCode" type="STRING" size="30"/>
          <Column id="sbjtClrmCodeNm" type="STRING" size="120"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsBeans" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="xplatform" type="STRING" size="256"/>
          <Column id="package" type="STRING" size="256"/>
          <Column id="sei" type="STRING" size="256"/>
          <Column id="svc" type="STRING" size="256"/>
          <Column id="svo" type="STRING" size="256"/>
          <Column id="dqm" type="STRING" size="256"/>
          <Column id="dvo" type="STRING" size="256"/>
          <Column id="actionMapping" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsRulesetMapper" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false" oncolumnchanged="dsRulesetMapper_oncolumnchanged">
        <ColumnInfo>
          <Column id="_chk" type="STRING" size="256"/>
          <Column id="category" type="STRING" size="256"/>
          <Column id="backendMethodName" type="STRING" size="256"/>
          <Column id="backendRuleName" type="STRING" size="256"/>
          <Column id="frontendRuleName" type="STRING" size="256"/>
          <Column id="description" type="STRING" size="256"/>
          <Column id="params" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSelectedRuleset" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="_chk" type="STRING" size="256"/>
          <Column id="category" type="STRING" size="256"/>
          <Column id="backendMethodName" type="STRING" size="256"/>
          <Column id="backendRuleName" type="STRING" size="256"/>
          <Column id="frontendRuleName" type="STRING" size="256"/>
          <Column id="description" type="STRING" size="256"/>
          <Column id="params" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[
include "lib::cm_script.xjs"

/**
* transaction Callback
* @param : 없음
* @return : N/A
* @example : fnTransCallbackmsg()
*/
this.fnTransCallback = function(svcid, errcd, errmsg) {
	this.alert_opacity('폐기된 기능입니다');
	return;
	if (svcid == "login") {
		if(errcd == 0){
		this.alert_opacity("재로그인에 성공하였습니다");
		}else{
		this.alert_opacity("재로그인에 실패하였습니다.\n서버에 문제가 있나보네요.");
		}
	}
};

this.fncRenderBkColor = function(nRow){
	var sRowTypeColor = "";
	switch(this.dsData.getRowType(nRow)){
		case Dataset.ROWTYPE_EMPTY : sRowTypeColor = ""; break;
		case Dataset.ROWTYPE_NORMAL: sRowTypeColor = ""; break;
		case Dataset.ROWTYPE_INSERT: sRowTypeColor = "#feede0ff"; break;
		case Dataset.ROWTYPE_UPDATE: sRowTypeColor = "#e6f2ffff"; break;
		case Dataset.ROWTYPE_DELETE: sRowTypeColor = ""; break;
		case Dataset.ROWTYPE_GROUP : sRowTypeColor = ""; break;
	}

	return sRowTypeColor;
};
this.fncWriteLog = function(sMessage){
	this.tab.tabLog.form.taLog.set_value(sMessage + this.tab.tabLog.form.taLog.value);
};

this.fncIteratorVariant = function(ownerName, collection){
// 	try{
// 		nexacro.getApplication().
// 		var sText = "[" + ownerName + "]\n";
// 		for(var i=0,size=collection.length; i<size; i++){
// 			var obj = collection[i];
// 			//trace('obj = ' + obj.name + ' type=' + obj);
// 			if("Variant" != this.utlf_GetObjType(obj)) continue;
// 			sText += obj.name + "=[" + this.smfFindComponentInThisContext(obj.name) + ']\n';
// 		}
// 		sText += "\n";
// 
// 		this.tab.tabpage2.form.taGlobalVariables.set_value(sText);
// 	}catch(e){
// 	}
};


this.fncFullId = function(obj){
    var sId = "";
    do{
        sId = obj.name + "." +sId;
        obj = obj.parent;
    }while(obj != undefined && (obj+"") != "[object Form]" );

    if(sId.charAt(0) == "."){
        return sId.substring(1, sId.length-1);
    }else{
        return sId.substring(0, sId.length-1);
    }
};

this.fncFindDatasets = function(owner){

    if(!(owner instanceof Tab)){
		var datasets = this.smfGetDatasetsFrom(owner);
        for(var i=0,size=datasets.length; i<size; i++){
            var obj = owner.objects[i];
            if(! (obj instanceof nexacro.Dataset)) continue;
            var nRow = this.dsDatasets.addRow();

            if(owner == this.opener){
                this.dsDatasets.setColumn(nRow, "owner", "opener");
                this.dsDatasets.setColumn(nRow, "text", obj.name);
                this.dsDatasets.setColumn(nRow, "id", obj.name);
            }else{
                this.dsDatasets.setColumn(nRow, "owner", this.fncFullId(owner));
                this.dsDatasets.setColumn(nRow, "text", this.fncFullId(owner) + '.'+ obj.name);
                this.dsDatasets.setColumn(nRow, "id", this.fncFullId(owner) + '.'+ obj.name);
            }
        }
    }
return;
    for(var i in owner){
        var oComp = owner[i];
		if(oComp instanceof Div){
            this.fncFindDatasets(oComp);
		}else if(oComp instanceof Tab){
            this.fncFindDatasets(oComp);
		}else if(oComp instanceof Tabpage){
            this.fncFindDatasets(oComp);
		}
    }
};

this.fncIteratorDatasets = function(ownerName, owner, collection){
	for(var i=0,size=collection.length; i<size; i++){
		var obj = collection[i];
		if(! (obj instanceof Dataset)) continue;
		var nRow = this.dsDatasets.addRow();

		var sId = "";
		var sText = "";
		if(owner instanceof Div){
			sId = owner.name + "." + obj.name;
			sText = owner.name + "." + obj.name;
		}else{
			sId = obj.name;
			sText = obj.name;
		}


		this.dsDatasets.setColumn(nRow, "owner", ownerName);
		this.dsDatasets.setColumn(nRow, "text", sText);
		this.dsDatasets.setColumn(nRow, "id", sId);
	}
};

this.FormSpy_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.tab.removeTabpage(14); // tab15
	this.tab.removeTabpage(7); // 구너한
	this.tab.removeTabpage(7); // 구너한
	this.tab.removeTabpage(7); // tabpage8.
	this.tab.removeTabpage(6); // 코드데이터셋생성
	
	this.tab.tabpage2.form.taGlobalVariables.set_value("");
	this.tab.tabLog.form.taLog.set_value("");

	this.opener.frmFormSpy = this;

	this.fncIteratorVariant('application', nexacro.getApplication().all);

 	this.fncIteratorDatasets('application', nexacro.getApplication(), nexacro.getApplication().all);
    this.fncFindDatasets(this.opener);

    try{
        var sFormUrl = this.smfStr(this.opener.getOwnerFrame().formurl);
        var nLast = sFormUrl.lastIndexOf("\\");
        sFormUrl = sFormUrl.substr(nLast+1);
        this.edt_formUrl.set_value(sFormUrl);
    }catch(e){
		trace("Form URL을 읽는데 실패했습니다.");
    }

    if(this.smfIsProductMode()){
		this.btnCreateBeansNames.set_visible(false);
		//btn_showTabOrder01.visible = false;
		this.btn_showTabOrder00.set_visible(false);
    }

    this.initConfig();
    
    
    this.chk_showOnFormLoad.set_value(nexacro.getApplication().showOnFormLoad);
};

this.tab_tpDataset_lbDatasets_onitemclick = function(obj:nexacro.ListBox,e:nexacro.ItemClickEventInfo)
{
	/* [X-LOG] index은 지원되지 않는 속성입니다.*/ e.postindex = e.index;
	this.tab_tpDataset_lbDatasets_onitemchanged(obj, e);
};

this.fncDescriptDataset = function(ds){
	this.tab.tpDataset.form.edt_filter.set_value(ds.filterstr);
	this.dsData.assign(ds);
	this.dsData.set_filterstr(ds.filterstr);

	var sText = "";
	for(var i=0,size=this.dsData.getConstCount(); i<size; i++){
		var id = this.dsData.getConstColID(i);
		var value = this.dsData.getConstColumn(id);
		sText += id + "=[" + value + "]\n";
	}

	this.tab.tpDataset.form.taConstColumns.set_value(sText);
	this.tab.tpDataset.form.grid.set_binddataset("dsData");
 	//tab.tpDataset.grid.setCellProperty("body", 0, "text", "bind:rowType");
// 	for(var i=0,size=dsData.getColCount(); i<size; i++){
// 		var nCell = tab.tpDataset.grid.insertContentsCol(i);
// 		//tab.tpDataset.grid.insertContentsCol('body', i);
// 		trace(nCell);
// 		tab.tpDataset.grid.setCellProperty("body", nCell, "displaytype", "normal");
// 		tab.tpDataset.grid.setCellProperty("body", nCell, "edittype", "normal");
// 		tab.tpDataset.grid.setCellProperty("body", nCell, "background", "EXPR(fncRenderBkColor(rowType))");
// 		tab.tpDataset.grid.setCellProperty("body", nCell, "background2", "EXPR(fncRenderBkColor(rowType))");
// 	}

	this.tab.tpDataset.form.Static02.set_text(this.format("rowCount={0}, deletedRowCount={1}", [this.dsData.rowcount, this.dsData.getDeletedRowCount()]));
	this.tab.tpDataset.form.grid.createFormat();
	this.tab.tpDataset.form.grid.set_cellsizingtype("col");

	this.tab.tpDataset.form.grid.set_cellsizingtype("col");
	this.tab.tpDataset.form.grid.set_cellsizingtype("col");

	this.tab.tpDataset.form.grid.set_cellsizingtype('both');
	
	this.dsData.updatecontrol = false;
	try{
		this.dsData.addColumn("rowType", 'string');

		for(var i=0,size=this.dsData.rowcount; i<size; i++){
			var sRowTypeText = "";
			switch(this.dsData.getRowType(i)){
				case Dataset.ROWTYPE_EMPTY : sRowTypeText = "empty"; break;
				case Dataset.ROWTYPE_NORMAL: sRowTypeText = "normal"; break;
				case Dataset.ROWTYPE_INSERT: sRowTypeText = "insert"; break;
				case Dataset.ROWTYPE_UPDATE: sRowTypeText = "update"; break;
				case Dataset.ROWTYPE_DELETE: sRowTypeText = "delete"; break;
				case Dataset.ROWTYPE_GROUP : sRowTypeText = "group"; break;
			}
			this.dsData.setColumn(i, "rowType", sRowTypeText);
		}


		if(this.dsData.getRowCount() > 0){
			this.tab.tpDataset.form.grid.insertContentsCol('body', 0);
			this.tab.tpDataset.form.grid.setCellProperty("body", 0, "text", "expr:currow+1");

			this.tab.tpDataset.form.grid.setRealColSize(0, 100);


			this.tab.tpDataset.form.grid.set_cellsizingtype('both');
			for(var i=0,size=this.dsData.getColCount(); i<size; i++){
				this.tab.tpDataset.form.grid.setCellProperty("body", i, "displaytype", "normal");
				this.tab.tpDataset.form.grid.setCellProperty("body", i, "edittype", "normal");
				this.tab.tpDataset.form.grid.setCellProperty("body", i, "background", "EXPR(fncRenderBkColor(currow))");
				this.tab.tpDataset.form.grid.setCellProperty("body", i, "background2", "EXPR(fncRenderBkColor(currow))");
				//
			}
		}

		this.smfUpdateGrid(this.tab.tpDataset.form.grid);
	} catch(e)
	{
		trace("처리중 에러가 발생했습니다.");
	}finally{
		this.dsData.updatecontrol = true;
	}
};


this.getDataset = function(sOwner, sDatasetName){
	switch(sOwner){
		case "application":
			return nexacro.getApplication().all[sDatasetName];
		case "opener":
			return this.opener[sDatasetName];
		default:
			return this.smfFindComponentInThisContext('opener.' + sDatasetName);
	}
};

this.tab_tpDataset_lbDatasets_onitemchanged = function(obj:nexacro.ListBox,e:nexacro.ItemChangeEventInfo)
{
	this.tab.tpDataset.form.taConstColumns.set_value("");
	this.tab.tpDataset.form.taXml.set_value("");
	this.tab.tpDataset.form.taProperties.set_value("");

	var id = this.dsDatasets.getColumn(e.postindex, "id");
	var owner = this.dsDatasets.getColumn(e.postindex, "owner");
	var ds = this.getDataset(owner, id);
	this.fncDescriptDataset(ds);
};

this.FormSpy_onclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	this.opener.frmFormSpy = null;
};

this.datasetToXml = function(ds){
	var sDatasetXml = ds.saveXML();
	return sDatasetXml.substring(0, sDatasetXml.indexOf("</ColumnInfo>") + "</ColumnInfo>".length) + "</Dataset>";
};

this.tab_tpDataset_btnToClipboard_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divClipboard.setOffsetTop(72);
	this.divClipboard.setOffsetLeft(88);

	this.divClipboard.set_visible(!this.divClipboard.visible);
	if(this.divClipboard.visible){
		this.dsData.set_rowposition(0);
		this.divClipboard.setFocus();
	}
};

this.divClipboard_btnDoit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sXml = "";
	for(var i=0,size=this.dsDatasets.getRowCount(); i<size; i++){
		if(this.dsDatasets.getColumn(i, "chk") != "1") continue;
		var id = this.dsDatasets.getColumn(i, "id");
		var owner = this.dsDatasets.getColumn(i, "owner");
		var ds = this.getDataset(owner, id);

		if(this.divClipboard.form.chkWithRows.value){
			sXml += ds.saveXML() + "\n\n";
		}else{
			sXml += this.datasetToXml(ds) + "\n\n";
		}
	}

	sXml = '<?xml version="1.0" encoding="euc-kr"?>\n'
		 + '<UxFormClipBoard>\r\n'
		 + sXml
		 + '</UxFormClipBoard>\n';

	this.smfCopyToClipboard(sXml);

this.alert_opacity('복사되었습니다.\nInvisible Objects를 선택하고 ctrl+v 키를 누르십시오');
};

this.divClipboard_btnDoit00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	obj.parent.set_visible(false);
};

this.dsData_cancolumnchange = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
};

this.divClipboard_onkillfocus = function(obj:nexacro.Div,e:nexacro.KillFocusEventInfo)
{
	obj.set_visible(false);
};

this.tab_tabpage8_btnCopyToClipboard_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfCopyToClipboard(this.tab.tabpage8.form.taDatasetXml.value);
this.alert_opacity('복사되었습니다.\nInvisible Objects를 선택하고 ctrl+v 키를 누르십시오');
};


this.dbNameToObjectName = function(sName){
	//첫자리 대문자로하고 나머진 모두 소문자
	sName = sName.charAt(0).toUpperCase() + sName.toLowerCase().substring(1, 999);
	var idx = sName.indexOf("_");
	var nCount = 0;
	while(idx >= 0){
		sName = sName.substring(0, idx) + sName.charAt(idx+1).toUpperCase() + sName.substring(idx+2, 999);
		nCount++;
		if(nCount > 10) break;
		idx = sName.indexOf("_");
	}

	return sName;
};
this.tab_tabpage8_btnCreateCommonCodes_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.tab.tabpage8.form.taDatasetXml.set_value("");
	this.tab.tabpage8.form.taScript.set_value("");

	var sCodeValues = this.smfStr(this.tab.tabpage8.form.taCodes.value).trim();
	if(this.isNil(sCodeValues)){
	this.alert_opacity("공통코드명을 입력하세요");
		this.tab.tabpage8.form.taCodes.setFocus();
		return ;
	}

	var aryCode = sCodeValues.split("\n");
	//검증//
	for(var i=0,size=aryCode.length; i<size; i++){
		var sCode = nexacro.trim(aryCode[i]);
		if(sCode.indexOf(" ") > -1 || sCode.indexOf("\t") > -1){
		this.alert_opacity(this.format("'{0}'에러\n코드명에는 space나 탭을 쓸수없습니다.", [sCode]));
			return;
		}
	}
	//검증끝//
	
	


	var sXml = "";
	var sFormat = '<Dataset id="{0}" useclientlayout="true">\n'
                + '    <ColumnInfo>\n'
                + '        <ConstColumn id="firstCode" type="STRING" size="30" value="ALL"/>\n'
                + '        <ConstColumn id="filterExpr" type="STRING" size="255" value=""/>\n'
                + '        <ConstColumn id="clsfCode" type="STRING" size="255" value="{1}"/>\n'
                + '        <ConstColumn id="userDfnSet" type="STRING" size="255" value=""/>\n'
                + '        <Column id="cdcValue" type="STRING" size="30"/>\n'
                + '        <Column id="cdcValueNm" type="STRING" size="120"/>\n'
                + '        <Column id="cdcValueAbrvNm" type="STRING" size="150"/>\n'
                + '        <Column id="codeValueSeq" type="BIGDECIMAL" size="10"/>\n'
                + '        <Column id="upperClsfCodeValue" type="STRING" size="30"/>\n'
                + '        <Column id="upperCdcValue" type="STRING" size="30"/>\n'
                + '        <Column id="userDfnCodeValue01" type="STRING" size="100"/>\n'
                + '        <Column id="userDfnCodeValue02" type="STRING" size="100"/>\n'
                + '        <Column id="userDfnCodeValue03" type="STRING" size="100"/>\n'
                + '        <Column id="userDfnCodeValue04" type="STRING" size="100"/>\n'
                + '        <Column id="userDfnCodeValue05" type="STRING" size="100"/>\n'
                + '    </ColumnInfo>\n'
                + '</Dataset>\n\n';

	for(var i=0,size=aryCode.length; i<size; i++){
		var sCode = this.smfStr(aryCode[i]).trim();
		if(sCode == "") continue;
		var sDatasetXml = this.format(sFormat, ['ds' + this.dbNameToObjectName(sCode), sCode]);
		sXml += sDatasetXml + "\n\n";
	}

	sXml = '<?xml version="1.0" encoding="utf-8"?>\n'
		 + '<InvisibleClipBoard version="1.0">\r\n'
		 + sXml
		 + '</InvisibleClipBoard>\n';
	this.tab.tabpage8.form.taDatasetXml.set_value(sXml);

	//
	//
	var sScript = "";
	for(var i=0,size=aryCode.length; i<size; i++){
		var sCode = nexacro.trim(aryCode[i]);
		var sDatasetId = 'this.ds' + this.dbNameToObjectName(sCode);

		sScript += ", " + sDatasetId;
	}

	sScript = nexacro.trim(sScript).substring(2, 999);
	this.tab.tabpage8.form.taScript.set_value(this.format("//공통코드를 가져온다.\nthis.smfCodeList(\"code\", [{0}]);", [sScript]));

	this.alert_opacity('생성되었습니다.\n클립보드로 복사버튼을 이용하세요');
};

this.tab_tabpage8_btnCopyToClipboard00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfCopyToClipboard(this.tab.tabpage8.form.taScript.value);
	this.alert_opacity('복사되었습니다.');
};

this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};

this.tab_tabpage9_btnCreateCommonCodes_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
    this.tab.tabpage9.form.taDatasetXml.set_value("");
    if(this.isNil(this.tab.tabpage9.form.taCodes.value)) {
       this.alert_opacity(this.tab.tabpage9.form.Static00.text);
        return;
    }
    var fields = ':' + this.tab.tabpage9.form.taCodes.value.replace('\r\n',',:');
    var columns = fields.match(/:[\w]+(?=,)/g);
    var propertyStr = nexacro.replaceAll(columns.join(","),':', '');
    this.tab.tabpage9.form.taDatasetXml.set_value(propertyStr);
   this.alert_opacity("생성되었습니다");
};

this.tab_tabpage9_btnCopyToClipboard_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfCopyToClipboard(this.tab.tabpage9.form.taDatasetXml.value);
this.alert_opacity('복사되었습니다.');
};

this.tab_tabpage6_Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
    var sSearchForText = this.smfStr(this.tab.tabpage6.form.edt_searchDb2SqlCode.value);

    if(sSearchForText == ""){
		this.dsDb2SqlCode.filter("");
		return;
	}

    this.dsDb2SqlCode.filter(this.format(" smfStr(errorCode).indexOf('{0}') != -1 ", [sSearchForText]));
    return;
    var sText = this.tab.tabpage6.taDb2SqlCode.value;
//    var nIndex = sText.indexOf(sSearchForText);
    var nIndex = this.tab.tabpage6.taDb2SqlCode.find(sSearchForText);
    if(nIndex == -1){
       this.alert_opacity("찾으려는 code가 없습니다");
    }else{
        this.tab.tabpage6.taDb2SqlCode.setFocus();
        this.tab.tabpage6.taDb2SqlCode.setCaretPos(nIndex);
        this.tab.tabpage6.taDb2SqlCode.setSelect(nIndex, nIndex + sSearchForText.length);

    }
};

this.tab_tabpage10_btnCreateAuthCodes_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
			//validation 처리
			//TODO: 같은 그룹에 있는것만 선택할 수 있도록
			//생성 버튼을 눌렀을 때 같은 라인 아닌거는 다 날리기
			//그룹핑하여 밸리데이션 처리 하기

			var aryCode1A = ["orgAyAndSem", "orgEdcAy","orgItrtAy","orgEdcSem","orgItrtSem","orgEdcItrtAy","orgEdcItrtSem","orgDghtCrseScCode","orgOrdGradeDddepCode","orgOrdScCode","orgGrade", "orgSemBeginEndYmd", "orgDddepCode","orgClassCode", "orgClassClrmCode", "orgSbjtClrmCode", "orgGradeClassCode", "orgSchulCrseScCode"];
			var aryCode1B = ["orgAyAndSem", "ay","ay","sem","sem","ay","sem","dghtCrseScCode","ordGradeDddepCode","ordScCode","grade", "semBeginEndYmd", "dddepCode","classCode", "classClrmCode", "sbjtClrmCode", "gradeClassCode", "schulCrseScCode"];

			var aryCode2A = ["enlghActAy","enlghActDeptCode","enlghActDeptClassCode"];
			var aryCode2B = ["ay","orgEnlghActDeptCode","orgEnlghActDeptClassCode"];

			var aryCode3A = ["creatDscrActAy","creatDghtCrseScCode","creatOrdScCode","creatOrdGradeDddepCode","creatDddepCode","creatGrade","creatClassCode","creatDscrActScCode","creatRelmAwaActCode"];
			var aryCode3B = ["ay","dghtCrseScCode","ordScCode","ordGradeDddepCode","dddepCode","grade","classCode","creatDscrActScCode","creatRelmAwaActCode"];

			/* [X-LOG] eval은 로직에 맞게 수정하시기 바랍니다.*/var aryCodeA = eval("aryCode" + (obj.name).charAt((obj.name).length-1) + 'A');
			/* [X-LOG] eval은 로직에 맞게 수정하시기 바랍니다.*/var aryCodeB = eval("aryCode" + (obj.name).charAt((obj.name).length-1) + 'B');

			this.tab.tabpage10.form.taDatasetXml.set_value("");
			this.tab.tabpage10.form.taOnloadScript.set_value("");
			this.tab.tabpage10.form.taOnchangeScript.set_value("");

			var sXml = "";
			var sScriptWithDataset = "";
			var sScriptWithCmb = "";

			var sFormat = '<Dataset id="{0}" useclientlayout="true">\n'
                + '    <ColumnInfo>\n'
                + '        <ConstColumn id="firstCode" type="STRING" size="30" value=""/>\n'
                + '        <ConstColumn id="filterExpr" type="STRING" size="255" value=""/>\n'
                + '        <ConstColumn id="cmbType" type="STRING" size="255" value="{1}"/>\n'
                + '        <Column id="{2}" type="STRING" size="30"/>\n'
                + '        <Column id="{3}" type="STRING" size="120"/>\n'
                + '    </ColumnInfo>\n'
                + '</Dataset>\n';

			var choiceChkCnt = 0;
			for(var i=0; i < aryCodeA.length; i++){
				//aryCode[i]의 첫번째 문자를 대문자로변환:다른문자열과 조합하기 위하여
				var aryCodeForConcat = aryCodeA[i].charAt(0).toUpperCase() + aryCodeA[i].substring(1,aryCodeA[i].length);
				this.trace("tab.tabpage10.CheckBox"+aryCodeForConcat+".value");
				if(/* [X-LOG] eval은 로직에 맞게 수정하시기 바랍니다.*/ eval("tab.tabpage10.CheckBox"+aryCodeForConcat+".value") == true){
					var sDatasetXml = this.format(sFormat, ['ds' + aryCodeForConcat, aryCodeA[i], aryCodeB[i], aryCodeB[i]+"Nm"]);
					sXml += sDatasetXml + "\n\n";

					var sDatasetId = 'ds' + aryCodeForConcat;
					sScriptWithDataset += choiceChkCnt == 0 ? sDatasetId : ", " + sDatasetId;

					sScriptWithCmb += choiceChkCnt == 0 ? "cmb"+aryCodeForConcat+".value" : ", " + "cmb"+aryCodeForConcat+".value";

					//validation체크 용
					choiceChkCnt++;
				}

			}

			//validation 메시지 처리
			if(choiceChkCnt == 0){
			this.alert_opacity("체크박스를 선택하세요");
				return;
			}


			sXml = '<?xml version="1.0" encoding="euc-kr"?>\n'
				 + '<UxFormClipBoard>\r\n'
				 + sXml
				 + '</UxFormClipBoard>\n';

			this.tab.tabpage10.form.taDatasetXml.set_value(sXml);

			this.trace(sScriptWithDataset);
			//호출 함수명 버튼에 따라 다르게
			sFormat = "//onLoad함수에 추가하세요\n//권한이 부여된 콤보결과를 가져온다.\n smfAuthList(obj,\"authOnload\",[{0}]);";
			this.tab.tabpage10.form.taOnloadScript.set_value(this.format(sFormat,[sScriptWithDataset]));

			sFormat = "//onChange함수에 추가하세요\n//권한이 부여된 하위콤보결과를 가져온다.\n//TODO : 해당 콤보ID값.value 형태로 변경하세요. \n smfAuthChain(\"authOnchange\",obj,[{0}],[{1}]);";
			this.tab.tabpage10.form.taOnchangeScript.set_value(this.format(sFormat,[sScriptWithDataset, sScriptWithCmb]));



	if(this.tab.tabpage10.form.CheckBoxOrgSchulCrseScCode.value == true){
	this.alert_opacity("학교급구분에서 초/중/고/전공과 처럼 초/중/고 이외의 데이터가 나오게 하려면\n"
		     +"dsOrgSchulCrseScCode데이터셋의 cmbType을 orgSchulCrseScCode2 로 변경하십시오");
	}
this.alert_opacity('스크립트가 생성되었습니다.\n아래 3가지 스크립트를 이용하여 권한콤보를 완성하세요.');
};

