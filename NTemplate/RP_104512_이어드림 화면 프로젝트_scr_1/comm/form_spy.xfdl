this.fnGetMenuId = function(){
	var menuId = this.opener.getOwnerFrame().form.pv_menuId;
	try{
		if(this.isNotNil(menuId)) return menuId;

		var menuId = this.opener.opener.getOwnerFrame().form.pv_menuId;
		if(this.isNotNil(menuId)) return menuId;
		var menuId = this.opener.opener.opener.getOwnerFrame().form.pv_menuId;
		if(this.isNotNil(menuId)) return menuId;
		var menuId = this.opener.opener.opener.opener.getOwnerFrame().form.pv_menuId;
		if(this.isNotNil(menuId)) return menuId;
	}catch(e){
		this.trace(e.message);
		var nRow = nexacro.getApplication().gds_openwininfo.count-1;
		var menuId = nexacro.getApplication().gds_openwininfo.getColumn(nRow, "menuId");
		return menuId;
	}
};

this.fnGetGridDetCount = function(grd){
	var nCellCount = grd.getCellCount("body");;
	var sColId = grd.getCellProperty("body",0,"text");
	if ("bind:_chk" == sColId) nCellCount--;

	return nCellCount;
};


this.fnExecuteFp = function(component){
	if(component instanceof Button){
		var eventName = "onclick";
		var clickEvent = component.onclick;
	}else if(component instanceof Grid){
		var eventName = "oncellclick";
		var clickEvent = component.oncellclick;
	}



	var ownerComponent = this.smfOwnerComponent(component);
	if(this.isNil(ownerComponent.url)){
		var formUrl = this.opener.getOwnerFrame().formurl;
	}else{
		var formUrl = ownerComponent.url;
	}

	var componentName = component.name;
	if(clickEvent == undefined || clickEvent.length == 0){
		this.alert(component.name +  " 컴포넌트는 " + eventName + " 이벤트가 없네요");
		return;
	}
	var eventFuncName = this.smfFuncName(clickEvent.getEventHandler('clickEvent' ,0));
	var componentCaption = this.nvl(this.nvl(component.value, component.text), this.opener.smfFullId(component));
	var actionText = this.format("!!@@##FP Launcher##@@!!\taction\t{0}\t{1}\t{2}\t{3}", [formUrl, componentName, eventFuncName, componentCaption]);
	this.smfCopyToClipboard(actionText);
};

this.fnCopyToClipboard = function(source, message){
	source = this.smfStr(source);
	this.smfCopyToClipboard(this.smfStr(source));
	if(this.isNotNil(message)){
		this.alert(this.format(message + " {0} 항목을 클립보드에 복사하였습니다", [source]));
	}
};

this.fnFp = function(obj){
	// ctrl 키 누른상태
	if((obj.targetComponent instanceof Button || obj.targetComponent instanceof Grid)){
		this.fnExecuteFp(obj.targetComponent);
		//return;
	}

// 	if(obj.targetComponent instanceof Grid){
// 		var detCount = fnGetGridDetCount(obj.targetComponent);
// 		fnCopyToClipboard(detCount, "그리드 컬럼수");
// 		//return;
// 	}
// 
	var menuId = this.fnGetMenuId();
	var nFindRow = nexacro.getApplication().gds_menuinfo.findRow("menuId", menuId);
	var menuNm = nexacro.getApplication().gds_menuinfo.getColumn(nFindRow, "menuNm");
	var upperMenuId = nexacro.getApplication().gds_menuinfo.getColumn(nFindRow, "upperMenuId");
	var pgeId = this.smfStr(nexacro.getApplication().gds_menuinfo.getColumn(nFindRow, "pgeid")).toUpperCase();

	var level1 = nexacro.getApplication().gds_menuinfo.lookup("menuId", upperMenuId, "menuNm");
	var level1MenuId = upperMenuId;
	var subSystemCode = nexacro.getApplication().gds_menuinfo.lookup("menuId", upperMenuId, "upperMenuId");
	var subSystemName = nexacro.getApplication().gds_menuinfo.lookup("menuId", subSystemCode, "menuNm");


	var transaction = {};
	transaction.subSystem = subSystemName;
	transaction.level1 = level1;
	transaction.level2 = menuNm;
	transaction.programId = pgeId;

	if(obj.targetComponent instanceof Grid){
		transaction.det = "" + this.fnGetGridDetCount(obj.targetComponent);
		transaction.unitName = "그리드클릭";
	}else{
		transaction.det = "" + this.fnGetDet(obj.targetComponent.parent);
		transaction.unitName = obj.targetComponent.text;
	}


	//alert(smfDescComponent(transaction));



	this.divPopFp.form.txaResult.set_value("");
	this.divPopFp.set_visible(true);
	this.smfTrackPopupDiv(this.Button00, this.divPopFp, this.divPopFp.form.btnDoit00);


	this.divPopFp.form.txaResult.set_value("sub시스템(세부업무명)	LEVEL1(업무기능)	LEVEL2(화면, 배치, 인터페이스 명)	프로그램 ID	프로그램종류	단위프로세스명	기능구분	EI/EO/EQ	FTR	DET")
	var values = this.format("{0}\t{1}\t{2}\t{3}\t화면\t{4}\t\t\t\t{5}", [transaction.subSystem, transaction.level1, transaction.level2, transaction.programId, transaction.unitName, transaction.det]);
	this.divPopFp.form.txaResult.set_value("\n" + values);
};

this.fnGetDet = function(parent){
	var detCount = 2; //버튼 + 메시지
	var travel = function(comp){
		if(comp instanceof Grid) return;
		if(comp instanceof Button) return;
		if(comp instanceof Static) return;
		if(comp instanceof Div) return;
		if(comp.set_visible(false)) return;

		if(! ("value" in comp)) return;
		/* [X-LOG] 변수(detCount)가 있는지 확인이 필요합니다.*/ detCount++;
	};
	this.smfTravelComponents(parent, travel, false);
	return detCount;
};



this.btn_showTabOrder_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
    if(obj.text == "TabOrder 보기"){
        obj.set_text("TabOrder 끄기");


        var aryComposite = [this.opener];
        this.opener.smfTravelComponents(null, function (oComp, fnc, nLvl){
			if(oComp.parent instanceof Div || oComp.parent instanceof Tabpage) return;
            if(oComp instanceof Div){
				aryComposite.push(oComp);
			}else if(oComp instanceof Tabpage){
			this.alert_opacity(oComp);
				aryComposite.push(oComp);
			}
        }, false); 

        var aryTrueStyle = ["background:#c0c0c0b4;font:arial,9,bold;",
                            "background:#ceb986b3;font:arial,9,bold;",
                            "background:#8ec69fb4;font:arial,9,bold;",
                            "background:#7eaad6b4;font:arial,9,bold;",
                            "background:#aa7dd7b4;font:arial,9,bold;",
                            "background:#d77dbcb4;font:arial,9,bold;",
                            "background:#78dcdabc;font:arial,9,bold;",
                            "background:#7e81d6b6;font:arial,9,bold;",
                            "background:#e2eb7cb6;font:arial,9,bold;"
        ];        //font:arial,9,bold italic;
        var aryFalseStyle = ["background:#c0c0c0b4;font:arial,9,bold underline;",
                            "background:#ceb986b3;font:arial,9,bold underline;",
                            "background:#8ec69fb4;font:arial,9,bold underline;",
                            "background:#7eaad6b4;font:arial,9,bold underline;",
                            "background:#aa7dd7b4;font:arial,9,bold underline;",
                            "background:#d77dbcb4;font:arial,9,bold underline;",
                            "background:#78dcdabc;font:arial,9,bold underline;",
                            "background:#7e81d6b6;font:arial,9,bold underline;",
                            "background:#e2eb7cb6;font:arial,9,bold underline;"
        ];        //color:#ffffffff;font:arial,9,bold italic;


        for(var i=0,size=aryComposite.length; i<size; i++){
            var arySorted;
            if(i == 0){
                arySorted = this.opener.smfSortByTabOrder(aryComposite[i],null, true);
            }else{
                arySorted = this.opener.smfSortByTabOrder(aryComposite[i]);
            }
            var nSeq = 1;
            for(var n=0,sizen=arySorted.length; n<sizen; n++){
                var copyObj = arySorted[n];
                if(copyObj.visible == false ) continue;
                if(copyObj.tabstop != true ) continue;
				
				var stat = null;
                if(null == copyObj.parent.all["__taborder_" + copyObj.name]){
					if(copyObj.parent.all["__taborder_" + copyObj.name] instanceof Grid){
						var stat = new Static("__taborder_" + copyObj.name,// + Math.round(Math.random() * 1000000) + "_" +  Math.round(Math.random() * 1000000),
							copyObj.getOffsetLeft(), //l eft
							copyObj.getOffsetTop(), // top
							40, // width
							21 //height
						);
					}else{
						var stat = new Static("__taborder_" + copyObj.name,// + Math.round(Math.random() * 1000000) + "_" +  Math.round(Math.random() * 1000000),
							copyObj.getOffsetLeft(), //l eft
							copyObj.getOffsetTop(), // top
							40, // width
							21 //height
						);
					}
                    copyObj.parent.addChild(stat.name, stat);
                    stat.set_visible(copyObj.visible);
                }else{
                    var stat = copyObj.parent.all["__taborder_" + copyObj.name];
                }

				stat.set_text(nSeq++);
                if(i == 0){
					stat.set_text("*" + stat.text);
					if(stat.enable == true){
						stat.set_background("padding-box deeppink"); stat.set_opacity("0.2");
						//stat.set_style("background:#d95e5ec8 stretch 10,10;color:aliceblue;font:Arial,9,bold;");
					}else{
						//stat.set_style("background:#d95e5ec8 stretch 10,10;color:aliceblue;font:Arial,9,bold underline;");
						stat.set_background("padding-box deeppink"); stat.set_opacity("0.2");
						stat.set_text("#" + stat.text);
					}
				}else{
					if(stat.enable == true){
						stat.set_background("padding-box deeppink"); stat.set_opacity("0.2");
					}else{
						stat.set_background("padding-box deeppink"); stat.set_opacity("0.2");
						stat.set_text("#" + stat.text);
					}
				}

				if(copyObj instanceof Grid){
					stat.set_tooltiptext(" Dataset : " + this.smfStr(copyObj.binddataset));
					stat.set_background("padding-box gold"); stat.set_opacity("0.4");
					stat.set_text("GRID " + stat.text);
				}else if(copyObj instanceof Div){
					stat.set_tooltiptext(" url : " + this.smfStr(copyObj.url));
					stat.set_background("padding-box gold"); stat.set_opacity("0.4");
					stat.set_text("DIV " + stat.text);
				}else{
				}
				
				var bindItem = this.opener.smfBindItemByComponent.call(this.opener, copyObj);
				if(! bindItem){
					bindItem = {
						datasetid: "",
						columnid: "",
					};
				}
				
				var innerdatasetText = "";
				if(copyObj.innerdataset){
					innerdatasetText = "\ninnerdataset=" + this.smfStr(copyObj.innerdataset)
					                     + "\ncodecolumn=" + this.smfStr(copyObj.codecolumn)
										 + "\ndatacolumn=" + this.smfStr(copyObj.datacolumn)										 
				}
				
				var onclicktext = "";
				if(copyObj.onclick && copyObj.onclick.length > 0){
					onclicktext = "\nonclick=" + this.smfStr(this.smfFuncName.call(this.opener, copyObj.getEventHandler("onclick", 0)));
				}
				
				
				
				stat.set_tooltiptext(
					"name="+ copyObj.name
				  + "\nqualifiedname=" + this.smfGetQualifiedName.call(this.opener, copyObj)
				  + "\ntaborder=" + this.smfStr(copyObj.taborder)
				  + "\nenable=" + this.smfStr(copyObj.enable)
				  + "\nvalidate=" + this.smfStr(copyObj.validate)
				  // + "\nbackend-validate=" + this.smfStr(copyObj.rulesetExpressioinByBackend)
				  + "\nbindinfo=" + this.smfStr(bindItem.datasetid) + "." + this.smfStr(bindItem.columnid)
				  + innerdatasetText
				  + onclicktext
				);

				stat.targetComponent = copyObj;
				stat.addEventHandler('onclick', function(xbj, xe){
					trace("\n" + xbj.tooltiptext);
					this.smfCopyToClipboard(xbj.tooltiptext);
				}, this);
				// stat.addEventHandler('onclick', this.fncDescComponent, this);
				stat.show();
            }
        }
    }else{
        obj.set_text("TabOrder 보기");

        var aryComponent = [];
        this.opener.smfTravelComponents(null, function (oComp, fnc, nLvl){
            if(oComp.name.indexOf("__taborder_") == 0){
                aryComponent.push(oComp);
            }
        }, false);

        for(var i=0,size=aryComponent.length; i<size; i++){
            aryComponent[i].parent.removeChild(aryComponent[i].name);
            aryComponent[i].destroy();
        }
    }
};

