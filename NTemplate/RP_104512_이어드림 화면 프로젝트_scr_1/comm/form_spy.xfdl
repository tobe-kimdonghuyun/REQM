            <Tabpage id="tabpage8" text="코드데이터셋생성">
              <Layouts>
                <Layout>
                  <TextArea id="taCodes" taborder="0" text="smfService('selectCode'); // select 서비스호출&#10;&#10;alert(smfServiceSatate('selectCode'));    //selectCode 서비스의 상태 ('ready', 'succ', 'fail')&#10;&#10;alert(smfIsServiceSucc('selectCode'));    //selectCode 서비스가 성공여부(true/false)&#10;&#10;alert(smfIsNotServiceSucc('selectCode')); //selectCode 서비스가 성공하지 않은지 여부(true/false)&#10;&#10;alert(smfIsServiceFail('selectCode'));    //selectCode 서비스가 실패했는지 여부(true/false)&#10;&#10;&#10;-------------------------------------------------------------------------------------------------------&#10;-------- dsService 데이터셋 ctrl + c 해서 Invisible Objects 팔레트를 선택하고 ctrl+v하세요 ------------&#10;&#10;&lt;?xml version=&quot;1.0&quot; encoding=&quot;euc-kr&quot;?&gt;&#10;&lt;UxFormClipBoard&gt;&#10;      &lt;Dataset id=&quot;dsService&quot; firefirstcount=&quot;0&quot; firenextcount=&quot;0&quot; useclientlayout=&quot;false&quot; updatecontrol=&quot;true&quot; enableevent=&quot;true&quot; loadkeymode=&quot;keep&quot; loadfiltermode=&quot;keep&quot; reversesubsum=&quot;false&quot;&gt;&#10;        &lt;ColumnInfo&gt;&#10;          &lt;Column id=&quot;id&quot; type=&quot;STRING&quot; size=&quot;256&quot; sumtext=&quot;service id&quot;/&gt;&#10;          &lt;Column id=&quot;inDatasets&quot; type=&quot;STRING&quot; size=&quot;256&quot; sumtext=&quot;파라메터가 될 Dataset list(공백으로 구분)&quot;/&gt;&#10;          &lt;Column id=&quot;outDatasets&quot; type=&quot;STRING&quot; size=&quot;256&quot; sumtext=&quot;받아올 Dataset list(공백으로 구분)&quot;/&gt;&#10;          &lt;Column id=&quot;package&quot; type=&quot;STRING&quot; size=&quot;256&quot; sumtext=&quot;vo와 service에서 사용할 패치지명&quot;/&gt;&#10;          &lt;Column id=&quot;vo&quot; type=&quot;STRING&quot; size=&quot;256&quot; sumtext=&quot;vo class full name&quot;/&gt;&#10;          &lt;Column id=&quot;service&quot; type=&quot;STRING&quot; size=&quot;256&quot; sumtext=&quot;service class full name&quot;/&gt;&#10;          &lt;Column id=&quot;method&quot; type=&quot;STRING&quot; size=&quot;256&quot; sumtext=&quot;method name&quot;/&gt;&#10;          &lt;Column id=&quot;svctp&quot; type=&quot;STRING&quot; size=&quot;256&quot; sumtext=&quot;Transaction Type 정의(Status 정보 표현:CRUD)&quot;/&gt;&#10;          &lt;Column id=&quot;bindingControls&quot; type=&quot;STRING&quot; size=&quot;256&quot; sumtext=&quot;서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다.&quot;/&gt;&#10;          &lt;Column id=&quot;bizMessage&quot; type=&quot;STRING&quot; size=&quot;256&quot; sumtext=&quot;사용자 정의 Message 처리&quot;/&gt;&#10;          &lt;Column id=&quot;url&quot; type=&quot;STRING&quot; size=&quot;256&quot; sumtext=&quot;service url&quot;/&gt;&#10;          &lt;Column id=&quot;callback&quot; type=&quot;STRING&quot; size=&quot;256&quot; sumtext=&quot;콜백함수 (Default:fnTransCallback)&quot;/&gt;&#10;          &lt;Column id=&quot;state&quot; type=&quot;STRING&quot; size=&quot;256&quot; sumtext=&quot;(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)&quot;/&gt;&#10;          &lt;Column id=&quot;reason&quot; type=&quot;STRING&quot; size=&quot;256&quot; sumtext=&quot;(공통시스템에서사용)서비스호출후 결과코드&quot;/&gt;&#10;          &lt;Column id=&quot;message&quot; type=&quot;STRING&quot; size=&quot;256&quot; sumtext=&quot;(공통시스템에서사용)서비스호출후 결과메시지&quot;/&gt;&#10;          &lt;Column id=&quot;asynctp&quot; type=&quot;STRING&quot; size=&quot;256&quot; sumtext=&quot;동기/비동기 설정(Default:true)&quot;/&gt;&#10;          &lt;Column id=&quot;bintp&quot; type=&quot;STRING&quot; size=&quot;256&quot; sumtext=&quot;Binary 처리 여부(Default:false)&quot;/&gt;&#10;          &lt;Column id=&quot;comtp&quot; type=&quot;STRING&quot; size=&quot;256&quot; sumtext=&quot;Data 압축 여부(Default:false)&quot;/&gt;&#10;        &lt;/ColumnInfo&gt;&#10;        &lt;Rows&gt;&#10;          &lt;Row&gt;&#10;            &lt;Col id=&quot;id&quot;&gt;selectCode&lt;/Col&gt;&#10;            &lt;Col id=&quot;inDatasets&quot;&gt;dsCrudSampleSVO=dsCrudSampleSVO&lt;/Col&gt;&#10;            &lt;Col id=&quot;outDatasets&quot;&gt;dsCrudSampleSVO=dsCrudSampleSVO dsCrudSampleSVO_crudSampleDVOList&lt;/Col&gt;&#10;            &lt;Col id=&quot;package&quot;&gt;edusys.sample.crud.svc&lt;/Col&gt;&#10;            &lt;Col id=&quot;vo&quot;&gt;CrudSampleSVO&lt;/Col&gt;&#10;            &lt;Col id=&quot;service&quot;&gt;CrudSampleSVC&lt;/Col&gt;&#10;            &lt;Col id=&quot;method&quot;&gt;listPageRowCount000&lt;/Col&gt;&#10;            &lt;Col id=&quot;svctp&quot;&gt;R&lt;/Col&gt;&#10;            &lt;Col id=&quot;bindingControls&quot;&gt;Combo00=ALL&lt;/Col&gt;&#10;            &lt;Col id=&quot;bizMessage&quot;/&gt;&#10;            &lt;Col id=&quot;url&quot;&gt;svc_neis::commonCall.xp&lt;/Col&gt;&#10;            &lt;Col id=&quot;callback&quot;&gt;fnTransCallback&lt;/Col&gt;&#10;            &lt;Col id=&quot;state&quot;/&gt;&#10;            &lt;Col id=&quot;reason&quot;/&gt;&#10;            &lt;Col id=&quot;message&quot;/&gt;&#10;            &lt;Col id=&quot;asynctp&quot;/&gt;&#10;            &lt;Col id=&quot;bintp&quot;/&gt;&#10;            &lt;Col id=&quot;comtp&quot;/&gt;&#10;          &lt;/Row&gt;&#10;        &lt;/Rows&gt;&#10;      &lt;/Dataset&gt;&#10;&lt;/UxFormClipBoard&gt;" left="7" top="33" width="907" height="142" value="SCHUL_CRSE_SC_CODE&#10;SCHUL_FA_SC_CODE&#10;SCHUL_GRGD_SC_CODE&#10;SCHUL_KND_SC_CODE"/>
