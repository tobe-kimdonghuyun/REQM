this.fnUpperFist = function(str){
	str = this.smfStr(str);
	if(this.isNil(str)) return "";

	return str.substring(0, 1).toUpperCase() + str.substr(1).toLowerCase();
};

this.btnCreateBeansNames_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divPopBeans.form.txaResult.set_value("");
	this.divPopBeans.set_visible(!this.divPopBeans.visible);
	if(this.divPopBeans.visible){
		this.divPopBeans.setFocus();
	}else{
		return;
	}
	var formFileName = "";
	if(this.smfStr(this.edt_formUrl.value).indexOf("::") > -1){
		formFileName = this.smfStr(this.edt_formUrl.value).split('::')[1];
	}else{
		formFileName = this.smfStr(this.edt_formUrl.value);
	}
	var formName = formFileName.substring(0, formFileName.indexOf("."));
	var aryFileName = formName.split('_');
	var splitedName = [];
	splitedName.push(aryFileName[0]);
	splitedName.push(aryFileName[1].substring(0, 3));
	splitedName.push(aryFileName[1].substring(3, 5));
	splitedName.push(aryFileName[1].substring(5, 7));
	splitedName.push(aryFileName[2]);

	var sFormat =
				  "FORM ID         : {0}\n"
				+ "FORM TITLE      : {1}\n"
				+ "\n"
				+ "PACKAGE         : {2}\n"
				+ "\n"
				+ "SEI             : {3}\n"
				+ "SVC             : {4}\n"
				+ "SVO             : {5}\n"
				+ "\n"
				+ "DEM             : {6}\n"
				+ "DVO             : {7}\n"

				+ "DQM             : {8}\n"
				+ "DVO             : {9}\n"
				+ "\n"
				+ "ACTION_MAPPING  : {10}\n";

	var sPackage = this.format("edusys.(cm/ga/sa/sw).{0}.{1}.{2}.", splitedName);
//	var sPrefix = fnUpperFist(splitedName[0]) + fnUpperFist(splitedName[1]) + fnUpperFist(splitedName[2]) + fnUpperFist(splitedName[3]) + fnUpperFist(splitedName[4]);
	var sPrefix = this.fnUpperFist(splitedName[0]) + this.fnUpperFist(splitedName[1]) + this.fnUpperFist(splitedName[2]) + this.fnUpperFist(splitedName[3]) + this.fnUpperFist(splitedName[4]);
	var sSei = sPackage + 'svc.' + sPrefix + "SEI";
	var sSvc = sPackage + 'svc.' + sPrefix + "SVC";
	var sSvo = sPackage + 'svc.' + sPrefix + "SVO";

	var sDem = sPackage + 'dbio.' + sPrefix + "DEM";
	var sDeo = sPackage + 'dbio.' + sPrefix + "DVO";

	var sDqm = sPackage + 'dbio.' + sPrefix + "DQM";
	var sDvo = sPackage + 'dbio.' + sPrefix + "DVO";

	var sActionMapping = this.format("/{0}_{1}_{2}{3}_000.xp", splitedName);

	this.divPopBeans.form.txaResult.set_value(this.format(sFormat, [this.edt_formUrl.value,this.opener.titletext, sPackage, sSei, sSvc, sSvo, sDem, sDeo, sDqm, sDvo, sActionMapping]));

	this.smfTrackPopupDiv(obj, this.divPopBeans, this.divPopBeans.form.btnDoit00);


/*
XPLATFORM      :
PACKAGE        :
SEI            :
SVC            :
SVO            :
DQM            :
DVO            :
ACTION_MAPPING :


	*/
};

this.divPopBeans_btnDoit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfCopyToClipboard(this.divPopBeans.form.txaResult.value);
this.alert_opacity('복사되었습니다');
};

this.tab_tabpage14_Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sSource = this.smfStr(this.tab.tabpage14.form.staBefore.value);
    var aryToken = sSource.match(/\w+/g);
    var aryResult = [];
    for(var i=0,size=aryToken.length; i<size; i++){
		var token = this.smfStr(aryToken[i]);
		var underscore = this.dbNameToObjectName(token);
		underscore = underscore.charAt(0).toLowerCase() + underscore.substr(1);
		aryResult.push( underscore.charAt(0).toLowerCase() + underscore.substr(1) );
    }

    this.tab.tabpage14.form.staAfter.set_value(aryResult.join("\n"));
};


