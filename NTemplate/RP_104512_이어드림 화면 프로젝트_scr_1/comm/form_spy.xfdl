this.tab_tpValid_tab00_Tabpage1_rdo00_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	this.tab.tpValid.form.tab00.Tabpage1.form.txt_javasource.set_value("");
	this.fnGenerateJavaValidationSource();
};
