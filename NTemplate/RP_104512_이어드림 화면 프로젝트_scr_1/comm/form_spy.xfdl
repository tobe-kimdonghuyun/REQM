this.fnListupValidationRuleset = function(){
	this.dsRulesetMapper.clearEventHandler("oncolumnchanged");

	var rawRulesetMapperList = this.smfGetRuleMapperList();

//		, ["필수",          "required",                       "required",                            "required",                 "required"                                                     ] 

	this.dsRulesetMapper.clearData();
	for(var i in rawRulesetMapperList){
		var ruleMapper = rawRulesetMapperList[i];
		
		var nRow = this.dsRulesetMapper.addRow();
		this.dsRulesetMapper.setColumn(nRow, "category", this.smfStr(ruleMapper[0]).trim());
		this.dsRulesetMapper.setColumn(nRow, "backendRuleName", this.smfStr(ruleMapper[1]).trim());
		this.dsRulesetMapper.setColumn(nRow, "backendMethodName", this.smfStr(ruleMapper[2]).trim());
		this.dsRulesetMapper.setColumn(nRow, "frontendRuleName", this.smfStr(ruleMapper[3]).trim());
		this.dsRulesetMapper.setColumn(nRow, "params", this.smfStr(ruleMapper[4]).trim());
		this.dsRulesetMapper.setColumn(nRow, "description", this.smfStr(ruleMapper[5]).trim());
	}
	
	this.dsRulesetMapper.set_rowposition(0);
	this.dsRulesetMapper.addEventHandler("oncolumnchanged", this.dsRulesetMapper_oncolumnchanged, this);
	
	this.dsSelectedRuleset.clearData();

	this.tab.tpValid.form.tab00.Tabpage1.form.txt_javasource.set_value("");
};	


this.dsRulesetMapper_oncolumnchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	var checked = obj.getColumn(e.row, "_chk");
	var backendMethodName = obj.getColumn(e.row, "backendMethodName");
	var params = obj.getColumn(e.row, "params");

	if(checked == 1){
		var nNewRow = this.dsSelectedRuleset.addRow();
		this.dsSelectedRuleset.setColumn(nNewRow, "backendMethodName", backendMethodName);		
		this.dsSelectedRuleset.setColumn(nNewRow, "params", params);		
	}else{
		var findedRow = this.dsSelectedRuleset.findRow("backendMethodName", backendMethodName);
		this.dsSelectedRuleset.deleteRow(findedRow);
	}
	
	this.fnGenerateJavaValidationSource();
};


this.fnGenerateJavaValidationSource = function(){
	var required = "";
	var label = "";
	var comment = "";
	
	var rules = [];
	for(var i=0,size=this.dsSelectedRuleset.rowcount; i<size; i++){
		var backendMethodName = this.smfStr(this.dsSelectedRuleset.getColumn(i, "backendMethodName")).trim();
		var params = this.dsSelectedRuleset.getColumn(i, "params");
		if(backendMethodName == "required"){
			required = "required()";
		}else if(backendMethodName == "label"){
			label = backendMethodName + params;
		}else if(backendMethodName == "comment"){
			comment = backendMethodName + params;
		}else{
			rules.push(backendMethodName + params);
		}
	}
	
	// required는 맨앞 추가
	if(this.isNotNil(required)) rules.unshift(required);
	
	// label은 맨뒤 추가
	if(this.isNotNil(label)) rules.push(label);
	
	// comment는 맨뒤 추가
	if(this.isNotNil(comment)) rules.push(comment);
	
	// 나이스
	if( this.tab.tpValid.form.tab00.Tabpage1.form.rdo00.index == 0){
		var declare = "// ### 나이스 ###\n\n\n"
	                + "// 유효성 검사 객체 생성\n"
	                + "CmCmcNeisServiceValidator validator = new CmCmcNeisServiceValidator(validationName);";
	}else{
		var declare = "// ### 클라우드 ###\n\n\n"
	                + "// 유효성 검사 객체 생성\n"
	                + "CmCmcCloudServiceValidator validator = new CmCmcCloudServiceValidator(validationName);";
	}
				
	var source = 'validator.add("프로퍼티명")' + "." + rules.join(".");

	this.tab.tpValid.form.tab00.Tabpage1.form.txt_javasource.set_value(declare + "\n\n" + source + ";");
};

this.tab_tpValid_tab00_Tabpage1_Static00_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	
};

this.tab_tpValid_tab00_Tabpage1_btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
