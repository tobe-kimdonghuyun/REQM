    <Script type="xscript5.1"><![CDATA[/**
*  학부모소통시스템
*  @MenuPath    공통
*  @FileName 	comm_divSchedule.xfdl
*  @Creator 	tobesoft
*  @CreateDate 	2025.03.17
*  @Desction    일정표(Div)
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2025.03.17     	tobesoft 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvYear  = -1;
this.fvMonth = -1;
this.fvDay   = -1;
this.fvFirstDay = -1;

this.fvToday = "";

this.fvCssclass = {today  : "sta_WF_CalDayT"
				  ,normal : "sta_WF_CalDay"
				  ,select : "sta_WF_CalDayS"
				  ,closeday : "sta_WF_CalDayEnd"
				  ,closetext : "sta_WF_CalEnd"
				  ,sunday : "sta_WF_CalDaySunday"
				  ,saturday : ""
				  };
				  
this.fvCssclassM = {today  : "sta_WF_CalDayTM"
				  ,normal : "sta_WF_CalDayM"
				  ,select : "sta_WF_CalDaySM"
				  ,closeday : "sta_WF_CalDayEndM"
				  ,closetext : "sta_WF_CalEndM"
				  ,sunday : "sta_WF_CalDaySundayM"
				  ,saturday : ""
				  };
		  
//초기화변수
this.fvInitArgs = {  ownerForm    : null
					,monthDs      : this.dsMonth
					,callbackDay : null
					,callbackMonth : null
					,initYm       : ""
					,initDsCol    : ""
					,initDsYnCol  : ""
				  };

/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	var objDate	 = new Date();
	this.fvYear  = objDate.getYear();
	this.fvMonth = objDate.getMonth()+1;	
	this.fvToday = this.fnGetDateFromYMD(this.fvYear, this.fvMonth, objDate.getDate());
	
 	this.fnSetMonth(this.fvYear, this.fvMonth);	//일정표시하기
};

this.form_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	//trace("form size === " + this.getOffsetWidth());
};

 /************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 달력 초기화 함수
/*
	oArgs = {ownerForm    : 호출Form 
	        ,monthDs      : 마감일자 Dataset
			,callbackDay  : Day클릭시 Callback Function
			,callbackMonth  : 월버튼 클릭시 Callback Function
			,initYm       : 초기화 년월(YYYYMM)
			,initDsCol    : 마감일자 Dataset 사용컬럼(default - closeDate)
		    };
*/
this.fnInitMonthCalendar = function( oArgs )
{
	if ( this.fnIsNull(oArgs["initYm"]) ) oArgs["initYm"] = this.fvToday.substr(0,6);
	
	if ( this.fnIsNull(oArgs["initDsCol"]) ) oArgs["initDsCol"] = "closeDate";
	
	this.fvInitArgs = oArgs;

	this.fnSetMonth(parseInt(oArgs["initYm"].substr(0,4)), parseInt(oArgs["initYm"].substr(4,2)));	//일정표시하기
};

this.fnSetMonth = function(nYear, nMonth)
{
	if (nYear < 1900 || nYear > 2100 || nMonth < 1 || nMonth > 12)
	{
		return;
	}

	this.fvYear  = nYear;
	this.fvMonth = nMonth;
	this.fnSetMonthDiv(nYear, nMonth);	//일자생성
	
	this.staMonth.set_text(nYear + "년 " + nMonth + "월");
	
	this.fnDispSchedule();
	
	//월버튼 callback호출
	var sYYYYMM = this.fnGetDateFromYMD(this.fvYear, this.fvMonth);
	if ( this.fnIsFunc(this.fvInitArgs["callbackMonth"]) ) {
		this.fvInitArgs["callbackMonth"].call(this.fvInitArgs["ownerForm"], sYYYYMM);
	}
}

//일정 표시하기
this.fnDispSchedule = function()  
{
	var strDate = "";
	var objDiv = null;
	var objDate = new Date();
	
	var divIndex, nDay, sDate;
	//var sTotal = "";
	
	var sLayoutID = this.getCurrentLayoutID();
	var arrCalendarDiv = this.divCalendar.form.components;
	for ( var i=7; i < arrCalendarDiv.length; i++ ) //0~6 : 요일 타이틀 Component 제외
	{
		//trace(i + "::::arrCalendarDiv[i]==="+arrCalendarDiv[i].name);
		if ( arrCalendarDiv[i].visible == false ) continue;
		
		nDay  = parseInt(arrCalendarDiv[i].form.btnDate.text);
		sDate = this.fnGetDateFromYMD(this.fvYear, this.fvMonth, nDay);
		
		//일정표시하기
		if ( !this.fnIsNull(this.fvInitArgs["monthDs"]) ) {
			if ( this.fvInitArgs["monthDs"].findRow(this.fvInitArgs["initDsCol"], sDate) > -1 ) {
			
				arrCalendarDiv[i].form.btnDate.set_enable(true);
				arrCalendarDiv[i].form.staText.set_enable(true);
				
				arrCalendarDiv[i].form.btnDate.set_color('');
			
				//arrCalendarDiv[i].form.btnDate.set_cssclass(this.fvCssclass["closeday"]);	//일자
				
				if(this.fvInitArgs["monthDs"].getColumn(this.fvInitArgs["monthDs"].findRow(this.fvInitArgs["initDsCol"], sDate), this.fvInitArgs["initDsYnCol"]) == "N"){
					// 상담일정 데이터가 존재하고, 상담가능여부가 N인 경우에는 "예약마감" 처리한다.		
					if ( sLayoutID == "mobile" ) {
						//arrCalendarDiv[i].form.staText.set_cssclass(this.fvCssclassM["closetext"]);	//Text
						arrCalendarDiv[i].form.btnDate.set_color('#D8D8D8');
					} else {
						//arrCalendarDiv[i].form.staText.set_cssclass(this.fvCssclass["closetext"]);	//Text
						arrCalendarDiv[i].form.btnDate.set_color('#D8D8D8');
					}
				}
			}
		}	
	}
};

//년월일로 날짜가져오기
this.fnGetDateFromYMD = function(nYear, nMonth, nDate)
{
	if ( this.fnIsNull(nDate) ) {
		return  ( this.fvYear  
			  + ( this.fvMonth >= 10 ? "" : "0") + this.fvMonth );
	} 
	
	return  ( this.fvYear  
		  + ( this.fvMonth >= 10 ? "" : "0") + this.fvMonth 
		  + (nDate >= 10 ? "" : "0") + nDate);
};

//선택날짜 지정하기
this.fnSetDate = function(nDate)   
{
	var bSucc = this.fnSelectDate(nDate);

	if ( bSucc ) {
		var sFullDate = this.fnGetDateFromYMD(this.fvYear, this.fvMonth, nDate);
		if ( this.fnIsFunc(this.fvInitArgs["callbackDay"]) ) {
			this.fvInitArgs["callbackDay"].call(this.fvInitArgs["ownerForm"], sFullDate);
		}
	}
};

////////////////////////////////////////////////////////////////
this.fnSetMonthDiv = function(nYear,nMonth)
{
	this.fvYear  = nYear;
	this.fvMonth = nMonth;
	
	var objDate = new Date();
	objDate.setFullYear(nYear, nMonth-1, 1);
	this.fvFirstDay = objDate.getDay();			//첫번째요일(0:일요일~6:토요일)
	objDate.setFullYear(nYear, nMonth, 0);		//월말일자 설정
	
	var lastDate = objDate.getDate();	//말일
	
	var sLayoutID = this.getCurrentLayoutID();
	
	this.fvDay = -99;
	
	var i;
	//1일 이전
	for (i = 0; i < this.fvFirstDay; i++) 
	{
		var objDiv = this.divCalendar.form.components["divDate0"+i];
 		this.fnCleanDiv(objDiv);
		objDiv.set_visible(false);
	}

	i = 1;	
	while (i <= lastDate)
	{
		var objDiv = this.divCalendar.form.components["divDate"+Math.floor((i+this.fvFirstDay-1)/7)+""+((i+this.fvFirstDay-1)%7)];
		this.fnCleanDiv(objDiv);
		
		objDiv.form.btnDate.set_text(""+i);					//일자
		objDiv.form.btnDate.set_accessibilityenable(true);	//접근성
		
		//objDiv.form.btnDate.set_enable(false);
		//objDiv.form.staText.set_enable(false);
		
		objDiv.form.btnDate.set_color('#D8D8D8');

		
		//일요일
		if ( objDiv.name.substr(8,1) == "0" ) {
			if ( sLayoutID == "mobile" ) {
				objDiv.form.btnDate.set_cssclass(this.fvCssclassM["sunday"]);
				//objDiv.form.btnDate.set_enable(false);
				//objDiv.form.staText.set_enable(false);
			} else {
				objDiv.form.btnDate.set_cssclass(this.fvCssclass["sunday"]);
				//objDiv.form.btnDate.set_enable(false);
				//objDiv.form.staText.set_enable(false);
			}
		}
		
		//토요일
		if ( objDiv.name.substr(8,1) == "6" ) {
			if ( sLayoutID == "mobile" ) {
				objDiv.form.btnDate.set_cssclass(this.fvCssclassM["sunday"]);
				//objDiv.form.btnDate.set_enable(false);
				//objDiv.form.staText.set_enable(false);
			} else {
				objDiv.form.btnDate.set_cssclass(this.fvCssclass["sunday"]);
				//objDiv.form.btnDate.set_enable(false);
				//objDiv.form.staText.set_enable(false);
			}
		}
		
		//오늘표시
		sDate = this.fnGetDateFromYMD(this.fvYear, this.fvMonth, i);
		if ( sDate == this.fvToday ) 
		{
			if ( sLayoutID == "mobile" ) {
				objDiv.form.btnDate.set_cssclass(this.fvCssclassM["today"]);
			} else {
				objDiv.form.btnDate.set_cssclass(this.fvCssclass["today"]);
			}			
		}
		
		objDiv.set_visible(true);
		i++;
	}
	
	//말일 이후
	var fulldate = 42 - this.fvFirstDay;
	while (i <= fulldate)  
	{
		var objDiv = this.divCalendar.form.components["divDate"+Math.floor((i+this.fvFirstDay-1)/7)+""+((i+this.fvFirstDay-1)%7)];
 		this.fnCleanDiv(objDiv);
		objDiv.set_visible(false);
		
		i++;
	}
};

this.fnCleanDiv = function(objDiv)
{
	var sLayoutID = this.getCurrentLayoutID();
	if ( sLayoutID == "mobile" ) {
		objDiv.form.btnDate.set_cssclass(this.fvCssclassM["normal"]);
	} else {
		objDiv.form.btnDate.set_cssclass(this.fvCssclass["normal"]);
	}
	objDiv.form.btnDate.set_text("");
	//objDiv.form.btnDate.set_enable(true);
	//objDiv.form.btnDate.set_opacity("0");
	
	objDiv.form.staText.set_cssclass("");
	//objDiv.form.staText.set_enable(true);
	//objDiv.form.staText.set_text("");	
	
	//접근성 대응
	objDiv.form.btnDate.set_accessibilityenable(false);
	objDiv.form.staText.set_accessibilityenable(false);
};

this.fnSelectDate = function(nDate)
{
	var objNewDiv = this.fnGetDayDiv(nDate);
	var sLayoutID = this.getCurrentLayoutID();
	if (this.fvDay != nDate && objNewDiv != null)
	{
		var objOldDiv = this.fnGetDayDiv(this.fvDay);
		if (objOldDiv != null)
		{
			objOldDiv.form.btnDate.set_cssclass(objOldDiv.form.btnDate.param_old_cssclass);
		}
		
		objNewDiv.form.btnDate.param_old_cssclass = objNewDiv.form.btnDate.cssclass;		//cssclass기록
		if ( this.getCurrentLayoutID() == "mobile" ) {
			objNewDiv.form.btnDate.set_cssclass(this.fvCssclassM["select"]);
		} else {
		    objNewDiv.form.btnDate.set_cssclass(this.fvCssclass["select"]);
		}

		this.fvDay = nDate;
		return true;
	}
	return false;
};

this.fnGetDayDiv = function(nDate)
{
	if (nDate < 1)
	{
		return null;
	}
	var date = new Date();
	date.setFullYear(this.fvYear, this.fvMonth, 0);
	var lastDate = date.getDate();
	if (nDate >  lastDate)
	{
		return null;
	}

	var objDiv = this.divCalendar.form.components["divDate"+Math.floor((nDate*1+this.fvFirstDay-1)/7)+""+((nDate*1+this.fvFirstDay-1)%7)];
	return objDiv;
};

/**
 * Null 검사
 */
this.fnIsNull = function(sValue)
{
	if( new String(sValue).valueOf() == "undefined")
		return true;
	if( sValue == null )
		return true;
	if( ("x"+sValue == "xNaN") && ( new String(sValue.length).valueOf() == "undefined" ) )
		return true;
	if( sValue.length == 0 )
		return true;
	return false;
};

/**
 * 함수인지 체크
 */
this.fnIsFunc = function(maybeFunction){
	if(maybeFunction == undefined || maybeFunction == null) return false;

	// 존재하지 않는 함수 체크
	return (typeof maybeFunction) == "function";
};
 /************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.btnMonth_onclick = function(obj:Button,  e:nexacro.ClickEventInfo)
{
	if (obj.name == "btnPrevMonth")
	{
		if (this.fvMonth == 1)
		{
			this.fnSetMonth(this.fvYear-1, 12);
		}
		else
		{
			this.fnSetMonth(this.fvYear, this.fvMonth-1);
		}
		//this.fnSetDate(1);
	}
	else if (obj.name == "btnNextMonth")
	{
		if (this.fvMonth == 12)
		{
			this.fnSetMonth(this.fvYear+1, 1);
		}
		else
		{
			this.fnSetMonth(this.fvYear, this.fvMonth+1);
		}
		//this.fnSetDate(1);
	}
};

this.date_onclick = function(obj,  e)
{
	trace("css==="+obj.cssclass);
	var objDiv = null;
	if (obj instanceof Div)
	{
		objDiv = obj;
	}
	else if (obj instanceof Static || obj instanceof Button)
	{
		objDiv = obj.parent.parent;
	}
	
	 
	var divIndex = objDiv.name.substr(7)*1;
	var nDay = Math.floor(divIndex/10)*7 + divIndex%10 - this.fvFirstDay + 1;
	
	// 2025.05.19 조치 사항 : 오늘보다 과거일 경우 Click 이벤트를 동작하지 않음
	var clickDay = ( this.fvYear + ( this.fvMonth >= 10 ? "" : "0") + this.fvMonth  + ( nDay >= 10 ? "" : "0") + nDay);
	if(this.smfToday()  > clickDay){	
		return false;
	}
	
	this.fnSetDate(nDay);
};

this.fn_getYmd = function(obj, e){
	return  ( this.fvYear  
	      + ( this.fvMonth >= 10 ? "" : "0") + this.fvMonth 
		  + ( this.fvDay >= 10 ? "" : "0") + this.fvDay);
	return this.fvYear + "" + this.fvMonth;
}]]></Script>
    <Objects>
      <Dataset id="dsMonth">
        <ColumnInfo>
          <Column id="closeDate" size="256" type="STRING"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
  </Form>
</FDL>
