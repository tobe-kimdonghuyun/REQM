            <Div id="divDate23" visible="false"/>
            <Div id="divDate24" visible="false"/>
            <Div id="divDate25" visible="false"/>
            <Div id="divDate26" visible="false"/>
            <Div id="divDate27" visible="false"/>
            <Div id="divDate28" visible="false"/>
            <Div id="divDate29" visible="false"/>
            <Div id="divDate30" visible="false"/>
            <Div id="divDate31" visible="false"/>
            <Div id="divDate32" visible="false"/>
            <Div id="divDate33" visible="false"/>
            <Div id="divDate34" visible="false"/>
            <Div id="divDate35" visible="false"/>
            <Div id="divDate36" visible="false"/>
            <Div id="divDate37" visible="false"/>
            <Div id="divDate38" visible="false"/>
            <Div id="divDate39" visible="false"/>
            <Div id="divDate40" visible="false"/>
            <Div id="divDate41" visible="false"/>
          </InitValue>
        </Div>
      </Layout>
      <Layout height="486" name="mobile" type="default" width="450" screenid="desktopScr,mobileScr">
        <Static id="staInfo1" top="47" height="32" taborder="3" text="예약마감" right="staInfo2:18" width="85"/>
        <Static id="staInfo2" top="47" height="32" taborder="4" width="118" left="40%"/>
        <Static id="staInfo3" top="47" height="32" taborder="5" width="60" left="staInfo2:4"/>
        <Button id="btnPrevMonth" top="0" left="0%" width="32" height="32" taborder="0"/>
        <Static id="staMonth" top="0" left="0%" height="32" taborder="1" cssclass="sta_WF_TxtCenter,sta_WF_Txt22Sb" right="0"/>
        <Button id="btnNextMonth" top="0" width="0" height="32" taborder="2" right="21.11%"/>
        <Div id="divCalendar" right="0" left="0" top="94" taborder="6" bottom="0"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsMonth">
        <ColumnInfo>
          <Column id="closeDate" size="256" type="STRING"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  학부모소통시스템
*  @MenuPath    공통
*  @FileName 	comm_divSchedule4.xfdl
*  @Creator 	tobesoft
*  @CreateDate 	2025.03.17
*  @Desction    일정표(Div)
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2025.03.17     	tobesoft 	        최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::scr_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvYear  = -1;
this.fvMonth = -1;
this.fvDay   = -1;
this.fvFirstDay = -1;

this.fvToday = "";

//-------------------lhj 추가
this.cnctrDscsnBgngYmd = "";
this.cnctrDscsnEndYmd = "";

this.fvCssclass = {today  : "sta_WF_CalDayT"		/* 오늘 */
				  ,normal : "sta_WF_CalDay"			/* 오늘이 속한 달 */
				  ,select : "sta_WF_CalDayS"		/* 선택한 일자 */
				  ,closeday : "sta_WF_CalDayEnd"	/* 오늘이 속하지 않은 달 */
				  ,closetext : "sta_WF_CalEnd"		/* 예약마감 */
				  ,sunday : "sta_WF_CalDaySunday"	/* 일요일 */
				  ,saturday : ""
				  };
		  
//초기화변수
this.fvInitArgs = {  ownerForm    : null
					,monthDs      : this.dsMonth
					,callbackFunc : null
					,initYm : ""
					,initDsCol       : ""
					,initDsYnCol    : ""
				  };
				  

//Display 되는 마지막 Div Object
this.fvLastDiv = null;

/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	var objDate	 = new Date();
	this.fvYear  = objDate.getYear();
	this.fvMonth = objDate.getMonth()+1;	
	this.fvToday = this.fnGetDateFromYMD(this.fvYear, this.fvMonth, objDate.getDate());
	
	this.fnInitMonthCalendar();
};

this.form_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	//trace("form size === " + this.getOffsetWidth());
};

this.form_onlayoutchanged = function(obj:nexacro.Form,e:nexacro.LayoutChangeEventInfo)
{
	this.setTimer(1, 100);
};

this.form_ontimer = function(obj:nexacro.Form,e:nexacro.TimerEventInfo)
{
	if ( e.timerid == 1 ) {
		this.killTimer(e.timerid);

		// Layout변경시 cssclass변경하기
		var arrComp = this.divCalendar.form.components;
		var arrCompDiv = null, sCssclass = "";
		for ( var i=0; i<arrComp.length; i++ ) {
			//arrComp[i].set_cssclass(this.fnGetLayoutCssclass(arrComp[i].cssclass));		//Div는 고정
			
			if ( arrComp[i] instanceof nexacro.Div ) {
				arrCompDiv = arrComp[i].form.components;
				for ( var j=0; j<arrCompDiv.length; j++ ) {
					arrCompDiv[j].set_cssclass(this.fnGetLayoutCssclass(arrCompDiv[j].cssclass));
				}
			}
			
		}
		
		// divCalendar 높이 변경하기
		this.fnSetParentDivHeight();
	}
};

 /************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

// 달력 초기화 함수
/*
	oArgs = {ownerForm    : 호출Form 
	        ,monthDs      : 마감일자 Dataset
			,callbackFunc : Day클릭시 Callback Function
			,initYm       : 초기화 년월(YYYYMM)
			,initDsCol    : 마감일자 Dataset 사용컬럼(default - closeDate)
		    };
*/
this.fnInitMonthCalendar = function( oArgs )
{

	
	var dscsnBgngYmd = "20250801";
	var dscsnEndYmd = "20250830";
	
	if ( this.fnIsNull(dscsnBgngYmd) || this.fnIsNull(dscsnEndYmd)) {
		dscsnBgngYmd = this.fnGetDateFromYMD(this.fvYear, this.fvMonth, 1);
		
		var tmp = new Date();
		tmp.setFullYear(this.fvYear, this.fvMonth, 0);
		dscsnEndYmd = "" + tmp.getYear() + ((tmp.getMonth() + 1).toString().length< 2 ? "0"+(tmp.getMonth() + 1) : tmp.getMonth()) + (tmp.getDate().length < 2 ? "0"+tmp.getDate() : tmp.getDate());
		this.fnSetMonth(dscsnBgngYmd, dscsnEndYmd);	//일정표시하기
	}else{
		this.fnSetMonth(dscsnBgngYmd, dscsnEndYmd);	//일정표시하기
		this.fnSetDate(this.fvToday.substr(6,2), this.fvToday);
	}
	
};

this.fnSetMonth = function(dscsnBgngYmd, dscsnEndYmd)
{
	var nYear = dscsnBgngYmd.substr(0, 4);
	var nMonth = parseInt(dscsnBgngYmd.substr(4, 2));

	if (nYear < 1900 || nYear > 2100 || nMonth < 1 || nMonth > 12)
	{
		return;
	}

	this.fvYear  = nYear;
	this.fvMonth = nMonth;
	this.fnSetMonthDiv(dscsnBgngYmd, dscsnEndYmd);	//일자생성
	
	this.fnDispSchedule();
}

//일정 표시하기
this.fnDispSchedule = function()  
{
	var strDate = "";
	var objDiv = null;
	var objDate = new Date();
	
	var divIndex, nDay, sDate;
	//var sTotal = "";
	
	var sLayoutID = this.getCurrentLayoutID();
	var arrCalendarDiv = this.divCalendar.form.components;
	
	if(this.dsMonth.getRowCount() == 0){
		return;
	}
	
	var paramMon = this.fvInitArgs["monthDs"];
	var initDsCol = this.fvInitArgs["initDsCol"];
	var initDsYnCol = this.fvInitArgs["initDsYnCol"];
	
	for(var i=7; i<arrCalendarDiv.length; i++){
		if ( arrCalendarDiv[i].visible == false ) continue;
		
		if ( !this.fnIsNull(this.fvInitArgs["monthDs"]) ) {
			for(var j=0; j<this.dsMonth.getRowCount(); j++){
				var sDate = this.dsMonth.getColumn(j, "closeDate");
				
				//일정표시하기
				if(arrCalendarDiv[i].form.btnDate.text == parseInt(sDate.substr(6, 2))) {
					
					if ( !this.fnIsNull(this.fvInitArgs["monthDs"]) ) {
						if ( this.fvInitArgs["monthDs"].findRow(this.fvInitArgs["initDsCol"], sDate) > -1 ) {
							if(this.fvInitArgs["monthDs"].getColumn(this.fvInitArgs["monthDs"].findRow(this.fvInitArgs["initDsCol"], sDate), this.fvInitArgs["initDsYnCol"]) == "N"){
								arrCalendarDiv[i].form.btnDate.set_cssclass(this.fnGetLayoutCssclass("closeday"));	//일자
								arrCalendarDiv[i].form.staText.set_cssclass(this.fnGetLayoutCssclass("closetext"));	//Text
							}
						}else{
							arrCalendarDiv[i].set_enable(false);
							arrCalendarDiv[i].set_cursor("auto");
							arrCalendarDiv[i].form.btnDate.set_cursor("auto");
							arrCalendarDiv[i].form.staText.set_cursor("auto");
						}
					}
				}
				
			} //for j end
		}
	} //for i end
};

//년월일로 날짜가져오기
this.fnGetDateFromYMD = function(nYear, nMonth, nDate)
{
	return  ( nYear 
	      + ( nMonth >= 10 ? "" : "0") + nMonth
		  + (nDate >= 10 ? "" : "0") + nDate);
};

//선택날짜 지정하기
this.fnSetDate = function(nDate, sFullDate)   
{
	var bSucc = this.fnSelectDate(nDate);
	
	if ( bSucc ) {
		if ( this.fnIsFunc(this.fvInitArgs["callbackFunc"]) ) {
			var totalCalDivHgt = this.getOwnerFrame().form.divAll.form.divWork.getOffsetHeight();
			
			//trace("totalHgt : " + totalCalDivHgt);
			
			this.fvInitArgs["callbackFunc"].call(this.fvInitArgs["ownerForm"], sFullDate, totalCalDivHgt);
		}
	}
};

// 날짜포맷팅
this.fnYmdFormatting = function(paramYmdStr)
{
	var yStr = paramYmdStr.substr(0, 4);
	var mStr = paramYmdStr.substr(4, 2);
	var dStr = paramYmdStr.substr(6, 2);
	return yStr + "." + mStr + "." + dStr;
};

////////////////////////////////////////////////////////////////
this.fnSetMonthDiv = function(dscsnBgngYmd, dscsnEndYmd)
{
	var sLayoutID = this.getCurrentLayoutID();
	var divId = "";
	
	//일자 초기화
	for (i = 0; i < 42; i++) 
	{
		if(i < 10){
			divId = "divDate0" + i;
		}else{
			divId = "divDate" + i;
		}
		var objDiv = this.divCalendar.form.components[divId];
 		this.fnCleanDiv(objDiv);
		objDiv.set_visible(false);
	}
	
	var dscsnBgngYmdFr = this.fnYmdFormatting(dscsnBgngYmd);
	var dscsnEndYmdFr = this.fnYmdFormatting(dscsnEndYmd);
	
	var dscsnBgngYmdDate = new Date(dscsnBgngYmdFr);
	var dscsnEndYmdDate = new Date(dscsnEndYmdFr);
	
	var firstDayDow = dscsnBgngYmdDate.getDay();	//첫번째요일(0:일요일~6:토요일)
	var firstWeekDay = new Date(dscsnBgngYmdDate.getFullYear(), dscsnBgngYmdDate.getMonth(), dscsnBgngYmdDate.getDate() - firstDayDow);
	var firstWeekMon = firstWeekDay.getMonth();
	var firstDateMon = dscsnEndYmdDate.getMonth();
	var nextDay = new Date(firstWeekDay);
	var lastDayDow = dscsnEndYmdDate.getDay();
	
	var totalDayCnt = Math.floor((dscsnEndYmdDate - dscsnBgngYmdDate) / (1000 * 60 * 60 *24));
	totalDayCnt = totalDayCnt + firstDayDow + (6 - lastDayDow);
	
	this.dsMonth.clearData();
	
	for(var i=0; i<=totalDayCnt; i++){
		if(i < 10){
			divId = "divDate0" + i;
		}else{
			divId = "divDate" + i;
		}
		
		var objDiv = this.divCalendar.form.components[divId];
 		objDiv.set_visible(true);
		
		if(i != 0){
			nextDay.setDate(nextDay.getDate() + 1);
		}
		
		var sDate = this.fnGetDateFromYMD(nextDay.getYear(), nextDay.getMonth()+1, nextDay.getDate());
		this.dsMonth.addRow();
		this.dsMonth.setColumn(i, "closeDate", sDate);
		
		objDiv.form.btnDate.set_text(""+ nextDay.getDate());					//일자
		objDiv.userFullDate = sDate;
		objDiv.form.btnDate.set_accessibilityenable(true);	//접근성
		
		//일요일
		if ( nextDay.getDay() == "0" ) {
			objDiv.form.btnDate.set_cssclass(this.fnGetLayoutCssclass("sunday"));
		}
		
		//오늘표시
		if ( sDate == this.fvToday ) 
		{
			objDiv.form.btnDate.set_cssclass(this.fnGetLayoutCssclass("today"));
			
			objDiv.todayYn = 'Y';
		}else{
			objDiv.todayYn = 'N';
		}
		
		objDiv.set_enable(true);
	}
	
	//달력 가변 높이 세팅 - Start
	this.fvLastDiv = this.divCalendar.form.components[divId];
	this.fnSetParentDivHeight();
	//달력 가변 높이 세팅 - End

	//스크린 크기 세팅
	//trace("부모 height : " + this.getOwnerFrame().form.divAll.form.divWork.getOffsetHeight() );
	
	var divCalTop = this.divCalendar.getOffsetTop();
	var divCalHgt = this.divCalendar.getOffsetHeight();
	
	//trace("======================" + (divCalTop + divCalHgt) );
	
	//this.getOwnerFrame().form.divAll.form.divWork.setOffsetHeight(divCalTop + divCalHgt);
	
	//trace("divCalendar12 top : " + this.divCalendar.getOffsetTop() );
	//trace("divCalendar12 height : " + this.divCalendar.getOffsetHeight() );
	//trace("부모12 height : " + this.getOwnerFrame().form.divAll.form.divWork.getOffsetHeight() );
	
	//달력 헤더 세팅
	var staMonTxt = dscsnBgngYmdDate.getYear() + "년 " + (dscsnBgngYmdDate.getMonth() + 1) + "월";
	if(dscsnBgngYmdDate.getMonth() != dscsnEndYmdDate.getMonth()){
		staMonTxt = dscsnBgngYmdDate.getYear() + "년 " + (dscsnBgngYmdDate.getMonth() + 1) + "월 ~ " + (dscsnEndYmdDate.getMonth() + 1) + "월";
	}
	this.staMonth.set_text(staMonTxt);
	
}

//마지막 날짜  콤포넌트 기준으로 부모Div높이 조정
this.fnSetParentDivHeight = function()
{
//trace("fnSetParentDivHeight 실행 >>>>>>>>>>");
	var sLayoutID = this.getCurrentLayoutID();
	var nHeigth = ( sLayoutID == "mobile" ? 450 : 500);
	if ( this.fvLastDiv ) {
		var nGap = ( sLayoutID == "mobile" ? 116 : 76 );
		
		nHeigth = this.fvLastDiv.getOffsetBottom() + nGap;
	}
	this.parent.setOffsetHeight(nHeigth);
	this.parent.parent.resetScroll();
}

this.fnCleanDiv = function(objDiv)
{
	objDiv.form.btnDate.set_cssclass(this.fnGetLayoutCssclass("normal"));
	objDiv.form.btnDate.set_text("");
	//objDiv.form.btnDate.set_opacity("0");
	
	objDiv.form.staText.set_cssclass("");
	//objDiv.form.staText.set_text("");	
	
	//접근성 대응
	objDiv.form.btnDate.set_accessibilityenable(false);
	objDiv.form.staText.set_accessibilityenable(false);
};

this.fnSelectDate = function(nDate)
{
	var objNewDiv = this.fnGetDayDiv(nDate);
	var sLayoutID = this.getCurrentLayoutID();
	
	if (this.fvDay != nDate && objNewDiv != null)
	{
		var objOldDiv = this.fnGetDayDiv(this.fvDay);
		
		if (objOldDiv != null)
		{
			if ( !this.fnIsNull(objOldDiv.form.btnDate.param_old_cssclass) ) {
				objOldDiv.form.btnDate.set_cssclass(this.fnGetLayoutCssclass(objOldDiv.form.btnDate.param_old_cssclass));
			}			
			
			//오늘 표시 유지
			if(objOldDiv.todayYn == 'Y'){
				objOldDiv.form.btnDate.param_old_cssclass = objOldDiv.form.btnDate.cssclass;		//cssclass기록
				objOldDiv.form.btnDate.set_cssclass(this.fnGetLayoutCssclass("today"));
			}
		}
		
		objNewDiv.form.btnDate.param_old_cssclass = objNewDiv.form.btnDate.cssclass;		//cssclass기록
		objNewDiv.form.btnDate.set_cssclass(this.fnGetLayoutCssclass("select"));
		
		this.fvDay = nDate;
		
		return true;
	}
	return false;
};

this.fnGetDayDiv = function(nDate)
{
	if (nDate < 1)
	{
		return null;
	}
	
	var objDiv = this.divCalendar.form.components;
	var divIndex = 7;
	
	if(objDiv != undefined){
		for(var i=7; i<objDiv.length; i++){
			
			if ( objDiv[i].visible == false ) continue;
			
			if(objDiv[i].form.btnDate.text == nDate){
				divIndex = i;
			}
		}
	}
	
	var objDiv = this.divCalendar.form.components[divIndex];
	
	return objDiv;
};

/**
 * Null 검사
 */
this.fnIsNull = function(sValue)
{
	if( new String(sValue).valueOf() == "undefined")
		return true;
	if( sValue == null )
		return true;
	if( ("x"+sValue == "xNaN") && ( new String(sValue.length).valueOf() == "undefined" ) )
		return true;
	if( sValue.length == 0 )
		return true;
	return false;
};

/**
 * 함수인지 체크
 */
this.fnIsFunc = function(maybeFunction){
	if(maybeFunction == undefined || maybeFunction == null) return false;

	// 존재하지 않는 함수 체크
	return (typeof maybeFunction) == "function";
};

// 현재 LayoutID를 기준으로 cssclass값을 반환
// sKey : object key값 또는, value값
this.fnGetLayoutCssclass = function(sKey)
{
	if ( this.fnIsNull(sKey) ) return sKey;

	//key값으로 검색
	var sRtn = this.fvCssclass[sKey];
	
	//value값으로 검색
	if ( this.fnIsNull(sRtn) ) {
		sRtn = sKey.indexOf("M") > -1 ? sKey.replace("M", "") : sKey;
	}
	
	var sCurrLayout = this.getCurrentLayoutID();
	if ( sCurrLayout == "mobile" ) {
		sRtn = sRtn + "M";
	}
	
	return sRtn;
}
 /************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/*
this.btnMonth_onclick = function(obj:Button,  e:nexacro.ClickEventInfo)
{
	if (obj.name == "btnPrevMonth")
	{
		if (this.fvMonth == 1)
		{
			this.fnSetMonth(this.fvYear-1, 12);
		}
		else
		{
			this.fnSetMonth(this.fvYear, this.fvMonth-1);
		}
		//this.fnSetDate(1);
	}
	else if (obj.name == "btnNextMonth")
	{
		if (this.fvMonth == 12)
		{
			this.fnSetMonth(this.fvYear+1, 1);
		}
		else
		{
			this.fnSetMonth(this.fvYear, this.fvMonth+1);
		}
		//this.fnSetDate(1);
	}
};
*/

this.date_onclick = function(obj,  e)
{
	//trace("css==="+obj.cssclass);
	var objDiv = null;
	if (obj instanceof Div)
	{
		objDiv = obj;
	}
	else if (obj instanceof Static || obj instanceof Button)
	{
		objDiv = obj.parent.parent;
	}
	
	var nDate = objDiv.form.btnDate.text;
	
	var sDate = objDiv.userFullDate;
	this.fnSetDate(nDate, sDate);
};]]></Script>
    <InitValue/>
  </Form>
</FDL>
