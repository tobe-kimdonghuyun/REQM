        <ImageViewer id="img_02" taborder="21" left="40" top="949" width="75" height="26" image="URL(&quot;theme://images/CLCC_MN_0040_02.png&quot;)" cssclass="img_WF_Acc" accessibilitylabel="위쪽 방향키 또는 아래쪽 방향키"/>
        <Static id="staK14" taborder="22" left="321" top="933" height="58" cssclass="sta_WF_DetailBg" accessibilityenable="true" text="-   텍스트 영역을 포함한 화면 내의 이전 항목 또는 다음 항목으로 이동합니다.&#13;&#10;-   그리드표의 셀을 상/하 이동합니다." wordWrap="none" right="22"/>
        <Static id="imvTst2" taborder="18" text="&lt;b v='true'&gt;[ 예시 : 메뉴 링크 ] &lt;/b&gt;" left="611" top="828" height="20" usedecorate="true" right="219"/>
        <ImageViewer id="imvMenu" taborder="19" left="611" top="853" width="334" height="63" image="URL(&quot;theme://images/CLCC_MN_0040_E2.png&quot;)" cssclass="img_WF_Acc" accessibilitylabel="예시 : 메뉴 링크를 나타내는 이미지"/>
        <Static id="staK4" taborder="23" left="22" top="990" width="300" height="120" cssclass="sta_WF_DetailLabel" accessibilityenable="false"/>
