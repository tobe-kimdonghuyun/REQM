<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="accessibilityGuide" width="1160" height="600" titletext="웹접근성 안내" onload="form_onload">
    <Layouts>
      <Layout height="600" width="1160">
        <Static id="Static12" taborder="59" left="22" top="755" height="3" cssclass="bg_WF_SearchBg01" accessibilityenable="false" right="22"/>
        <Static id="sta1" taborder="1" text="웹접근성 운영 및 준수 지침" left="10" top="70" height="63" cssclass="sta_WF_TitleAcc02" right="10"/>
        <Static id="sta11" taborder="2" text="웹 사이트 이용에 있어 모든 사람이 동등하게 접근하고 이용에 불편함이 없도록하는 것을 목표로 하여, &lt;fc v='#444444'&gt;&lt;b v='true'&gt;“한국형 웹 컨텐츠 지침 2.1(KICS.0T-10.0003/R2)&quot;&lt;/b&gt;&lt;/fc&gt;을 &#13;준수하여 구축·운영 하고 있습니다." left="22" top="133" height="50" usedecorate="true" cssclass="sta_WF_Des01" right="28" accessibilitylabel="웹 사이트 이용에 있어 모든 사람이 동등하게 접근하고 이용에 불편함이 없도록하는 것을 목표로 하여, “한국형 웹 컨텐츠 지침 2.1(KICS.0T-10.0003/R2)&quot;을 준수하여 구축·운영 하고 있습니다." wordWrap="char"/>
        <Static id="staLine" taborder="57" left="20" top="194" height="1" cssclass="sta_WF_GuideLine" accessibilityenable="false" right="20"/>
        <Static id="sta2" taborder="3" text="웹접근성 운영 및 준수 지침" left="10" top="208" height="63" cssclass="sta_WF_TitleAcc02" right="10"/>
        <Static id="sta21" taborder="4" text="해당 시스템을 이용하실 때 스크린리더를 사용하는 분들을 위한 안내입니다.&#13;센스리더에서 아래와 같이 환경설정을 하시면 보다 편리하게 이용할 수 있습니다." left="22" top="271" height="40" usedecorate="true" cssclass="sta_WF_Des01" right="20"/>
        <Static id="staSence" taborder="5" text="&lt;b v='ture'&gt;센스리더 설정 방법 &lt;/b&gt;" left="22" top="333" height="30" cssclass="sta_WF_GridTitle01" usedecorate="true" right="28" accessibilitylabel="센스리더 설정 방법 "/>
        <Static id="staCursor" taborder="6" left="22" top="363" width="460" height="141" cssclass="sta_WF_DtlLabel" text="가상커서 설정해제"/>
        <Static id="staCursor1" taborder="7" left="481" top="363" width="496" height="141" cssclass="sta_WF_DetailBg" text="1. 브라우져 화면에서 키보드의 [ Ctrl + Shift + F12 ]키를 동시에 눌러&#13;&#10;    [가상 커서 해제]로 설정합니다.&#13;&#10;2. '숨긴 내용 읽기'를 선택, '변경 내용 자동 구성'을 선택으로 설정 후&#13;&#10;    [확인] 버튼을 선택하여 저장합니다.&#13;&#10;    (Ctrl + Alt + Shift + S)키를 누르면 설정을 저장할 수 있습니다." accessibilityenable="true" wordWrap="none"/>
        <Static id="staRead" taborder="8" left="22" top="503" height="113" cssclass="sta_WF_DtlLabel" text="구두점 읽기 설정" width="460"/>
        <Static id="staRead1" taborder="9" left="481" top="503" height="113" cssclass="sta_WF_DetailBg" text="1. 키보드의 [ Ctrl + \ ] 키를 눌러 센스리더 프로그램을 엽니다.&#13;&#10;2. 음성설정 [ Alt + S ] ▶ 세부설정 [ D ] 메뉴를 선택합니다.&#13;&#10;3. 구두점 읽기 목록 중 '문장+수학기호읽기'항목을 선택 후 [ 확인 ] 버튼을 &#13;&#10;     선택하여 저장합니다." accessibilityenable="true" wordWrap="none" width="496"/>
        <Static id="staLine2" taborder="58" left="20" top="641" height="1" cssclass="sta_WF_GuideLine" right="20" accessibilityenable="false"/>
        <Static id="staKeyboard" taborder="10" text="키보드 이용 안내 및 참고사항" left="10" top="652" height="63" cssclass="sta_WF_TitleAcc02" right="10"/>
        <Static id="staKeyboard1" taborder="11" text="본 시스템의 키보드 이용 안내 및 이용 시 참고사항입니다." left="22" top="715" height="40" usedecorate="true" cssclass="sta_WF_Des01" right="28"/>
        <Static id="staK1" taborder="12" left="22" top="757" width="300" height="58" cssclass="sta_WF_DetailLabel" accessibilityenable="false"/>
        <Static id="imvCs1" taborder="14" left="321" top="757" height="58" cssclass="sta_WF_DetailBg" accessibilityenable="true" text="-   웹 접근성 모드로 전환됩니다.&#13;&#10;-   시각장애인 및 키보드 사용자께서는 Ctrl + SpaceBar를 입력하신 후 본 사이트를 이용하시기 바랍니다." wordWrap="none" right="22"/>
        <ImageViewer id="imvCs" taborder="13" left="40" top="773" width="158" height="26" image="URL(&quot;theme://images/CLCC_MN_0040_00.png&quot;)" cssclass="img_WF_Acc" accessibilitylabel="컨트롤 스페이스바"/>
        <Static id="staK2" taborder="15" left="22" top="814" width="300" height="120" cssclass="sta_WF_DetailLabel" accessibilityenable="false"/>
        <Static id="imvTst1" taborder="17" left="321" top="814" height="120" cssclass="sta_WF_DetailBg" accessibilityenable="true" text="-   텍스트 영역을 제외한 다음 항목 또는&#13;&#10;    이전 항목으로 이동합니다.&#13;&#10;    (링크, 버튼 등)" wordWrap="none" right="22"/>
        <ImageViewer id="imvTst" taborder="16" left="40" top="861" width="221" height="26" image="URL(&quot;theme://images/CLCC_MN_0040_01.png&quot;)" cssclass="img_WF_Acc" accessibilitylabel="탭 또는 쉬프트 탭키"/>
