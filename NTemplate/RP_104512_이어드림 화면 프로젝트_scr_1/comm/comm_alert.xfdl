<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="comm_alert" width="500" height="260" onload="comm_alert_onload" titletext="알림" background="white" onclose="comm_alert_onclose" onsize="comm_alert_onsize">
    <Layouts>
      <Layout height="260" width="500" screenid="ScreenDeskTop">
        <Div id="divMain" taborder="0" text="div_00" left="0" top="0" bottom="60" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staMessage" taborder="0" left="20" top="20" text="" wordWrap="char" textAlign="center" bottom="0" right="0" initvalueid="ivStcAccessibilityOn"/>
            </Layout>
            <Layout name="default0">
              <Static id="staMessage" taborder="0" left="20" top="20" text="" wordWrap="char" textAlign="center" right="20" bottom="0"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="div00" taborder="1" text="div_00" left="0" background="whitesmoke" bottom="0" height="50" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Button id="btnOk" taborder="0" text="확인" left="42%" width="80" defaultbutton="true" escapebutton="true" bottom="10" height="30" onclick="btnOk_onclick" initvalueid="ivBtnAccessibilityButton"/>
            </Layout>
            <Layout name="default0">
              <Button id="btnOk" taborder="0" text="확인" left="40%" top="20" width="108" height="50" defaultbutton="true" escapebutton="true"/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
      <Layout height="300" width="540" name="default0" screenid="mobile,tablet">
        <Div id="div00" taborder="1" text="div_00" left="0" top="210" background="whitesmoke" right="0" bottom="0"/>
        <Div id="divMain" taborder="0" text="div_00" left="0" top="0" right="0" bottom="100"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[include "lib::cm_script.xjs"


// 로드
this.comm_alert_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitPopup(obj);
	//this.smfInitForm(obj);
	trace("this.height="+this.getOffsetHeight() + " , this.parent.height="+this.parent.getOffsetHeight())
	this.pv_params = this.smfGetPopupParams();
	this.smfUpdatePopupTitle("알림");
	
	this.divMain.form.staMessage.set_text(this.smfStr(this.pv_params.message));
};

this.btnOk_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};

this.comm_alert_onclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	this.smfSendResponseToOpener({});
};

this.comm_alert_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	trace("comm_alert_onsize : e.cy="+e.cy);
};
]]></Script>
  </Form>
</FDL>
