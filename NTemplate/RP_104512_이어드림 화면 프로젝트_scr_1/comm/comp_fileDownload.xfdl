<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="comp_fileDownload" width="400" height="72" titletext="첨부파일" onload="comp_fileDownload_onload" oninit="comp_fileDownload_oninit">
    <Layouts>
      <Layout height="72" width="400" screenid="ScreenDeskTop,ScreenDeskTopP">
        <Static id="staBg" taborder="5" text="" left="0" top="0" right="0" bottom="0" visible="true"/>
        <Button id="btnFileDown" taborder="0" left="15" top="7" width="30" height="29" cssclass="btn_WF_AddFileDown" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="(첨부파일)나이스대국민서비스_리플렛.pdf" visible="false" onclick="btnFileDown_onclick"/>
        <Static id="staFilename" taborder="1" text="나이스대국민서비스_리플렛.pdf(1234kb)" left="15" top="0" height="40" fittocontents="width" initvalueid="ivStcAccessibilityOn" visible="false" wordWrap="none" width="340" cssclass="sta_WF_FileDownTxt"/>
        <Button id="btnFileDown1" taborder="2" left="15" top="btnFileDown:0" width="30" height="29" cssclass="btn_WF_AddFileDown" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="(첨부파일)나이스대국민서비스_리플렛.pdf" visible="false"/>
        <Static id="staFilename1" taborder="3" text="나이스대국민서비스_리플렛.pdf(1234kb)" left="15" top="staFilename:-11" fittocontents="width" initvalueid="ivStcAccessibilityOn" visible="false" height="40" width="330" cssclass="sta_WF_FileDownTxt"/>
        <RaonkUpload id="RaonkDownload" taborder="4" left="410" text="File Download" RAONKUPLOAD_UploadComplete="RaonkUpload_RAONKUPLOAD_UploadComplete" RAONKUPLOAD_BeforeCreation="RaonkUpload_RAONKUPLOAD_BeforeCreation" HeaderBar="0" RAONKUPLOAD_OnError="RaonkUpload_RAONKUPLOAD_OnError" width="140" height="30" visible="false" top="21" RAONKUPLOAD_DownloadCompleteFile="RaonkDownload_RAONKUPLOAD_DownloadCompleteFile" RAONKUPLOAD_Alert="RaonkDownload_RAONKUPLOAD_Alert" UseAlertEvent="1" RAONKUPLOAD_CreationComplete="RaonkDownload_RAONKUPLOAD_CreationComplete"/>
      </Layout>
      <Layout name="Layout0" screenid="mobileP,tabletP,mobile,tablet" width="640" height="118" mobileorientation="portrait" type="default">
        <Static id="staFilename" left="15" top="8" height="42" right="0" text="나이스대국민서비스_리플렛.pdf(1234kb)" cssclass="sta_WF_FileDown_M"/>
        <Static id="staFilename1" cssclass="sta_WF_FileDownTxt_M" left="15" top="staFilename:10" height="42" right="0"/>
        <RaonkUpload id="RaonkDownload" left="700" top="21" width="140" height="30"/>
        <Button id="btnFileDown1" left="15" top="btnFileDown:21" width="34" height="31" cssclass="btn_WF_AddFileDown_M"/>
        <Button id="btnFileDown" left="15" top="15" width="34" height="31" cssclass="btn_WF_AddFileDown_M"/>
        <Static id="staBg" left="10" top="4" right="0" bottom="0"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
* 파일 다운로드
* @MenuPath    	comm
* @FileName 	comp_fileDownload1.xfdl
* @Creator 		홍길동
* @CreateDate 	2022.6.21
* @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.6.21     	홍길동 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
// 생성될 Component의 Frefix
// 주의 :  Design시 샘플로 만든 Component와 Prefix가 겹치지 않게 한다.(ResetUpload시 기존의 것을 전부 없애버리 수도 있어서...)
this.fv_prefixDownBtn = "btnDownBtn";           
this.fv_prefixDownFilename = "staDownfilename";

this.fv_arrayBackendFilename = [];
this.fv_arrayFileInfo=[];
this.fv_mofile = "";
if(this.smfIsMobile()){
	this.fv_mofile = "_M";
}

// 생성되기 전에 addfile한 것을 담아두었다가 create후에 추가하는 작업을 수행
this.fv_addUpdatedFile = [];
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// form onload이벤트 처리
this.comp_fileDownload_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	//this.smfInitDiv();
	this.staBg.set_visible(false);
}; 

// Form의 init이벤트 - Form안의 component가 생성되기 이전 최초이벤트(onload보다 먼저 생성)
this.comp_fileDownload_oninit = function(obj:nexacro.Form,e:nexacro.EventInfo)
{
	var sBaseUrl = "";
	
	// runtime인 경우에는 해당 정보를 세팅해주어야 함
	if (system.navigatorname.indexOf("nexacro")  > -1) 	{
		// raonkupload_rootUrl이 세팅이 안된경우에만 사용
		if(this.smfIsNull(raonkupload_rootUrl))
		{
			// 현재의 실행모드(서버종류)를 판별한다.
			var sRunMode = nexacro.getEnvironmentVariable("ev_runMode");
			
			//xadl의 url을 구한다
			var sXadlUrl = nexacro.getApplication().xadl;
			var nFindIdx = sXadlUrl.indexOf("nxui");
			
			//trace("====>>>> sXadlUrl="+sXadlUrl);
			if(nFindIdx>-1)
			{
				var nFindIdx2 = sXadlUrl.indexOf("/",nFindIdx);
				sBaseUrl = sXadlUrl.substr(0,nFindIdx2);
				
			}
			
			//trace("====>>>> sBaseUrl="+sBaseUrl);
			raonkupload_rootUrl = sBaseUrl + "/nexacrolib/component/raonkupload";
			//trace("====>>>> raonkupload_rootUrl="+raonkupload_rootUrl);
		}
	}	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnInit = function()
{

}

this.fnAddUploadedFile = function(handlerCode, atchFileSn, fileSize, backendFilename, frontendFilename, fileId, sDownloadPath,sFileEncryptYn, sPrivInfoFiltYn, sFileSaveStg, sFileInfSaveYn)
{ 
	var sDownloadTextPrefix = "다운로드 : ";
	this.parent._fileRefrnId = 	atchFileSn;
	
	var nAddIndex = this.fv_arrayBackendFilename.length;
	
	/*  // 2023.04.13 대국민 TF의 요구에 따라 버튼 생략("다운로드:"로 대체)
	var sBtnName      = this.fv_prefixDownBtn      + "" + backendFilename;
	var objDownBtn      = this[sBtnName];
	// 버튼의 사이즈 결정
	var nBtnStartTop = this.btnFileDown.getOffsetTop();
	var sTopBtnGap = this.btnFileDown1.top.split(":")[1];
	var nBtnGap = parseInt(sTopBtnGap);
	
	var nLeftBtn = this.btnFileDown.getOffsetLeft();
	var nTopBtn = 0;	
	var nBtnWidth = this.btnFileDown.getOffsetWidth();	
	var nBtnHeight = this.btnFileDown.getOffsetHeight();	

	// 버튼의 생성
	if(!objDownBtn)
	{
		nTopBtn = nBtnStartTop + (nAddIndex * (nBtnHeight+nBtnGap));
		if(this.smfIsMobile())	
			objDownBtn = new Button(sBtnName,nLeftBtn,nTopBtn+4,nBtnWidth,nBtnHeight);
		else 
			objDownBtn = new Button(sBtnName,nLeftBtn,nTopBtn,nBtnWidth,nBtnHeight);
			
		//this.addChild(sBtnName,objDownBtn);
		objDownBtn.set_cssclass("btn_WF_AddFileDown"+this.fv_mofile);
		objDownBtn.set_initvalueid("ivBtnAccessibilityButton");
		objDownBtn.set_accessibilitylabel("첨부파일 다운로드");
		objDownBtn.show();
		
		objDownBtn.addEventHandler("onclick",this.btnFileDown_onclick,this);
	}
	
	objDownBtn.fileIndex = nAddIndex;
	*/
	// 파일이름의 사이즈 결정
	
	var nFilnameStartTop = this.staFilename.getOffsetTop();
	var sTopFilenameGap = this.staFilename1.top.split(":")[1];
	var nFilnameGap = parseInt(sTopFilenameGap);;
	
	var nLeftFileName = this.staFilename.getOffsetLeft();	
	var nTopFileName = 0;	
	var nWidthFileName = this.staFilename.getOffsetWidth();	
	var nHeightFileName = this.staFilename.getOffsetHeight();	

	var sFilenameName = this.fv_prefixDownFilename + "" + backendFilename;
	var objDownFileName = this[sFilenameName];
	// 파일이름의 생성
	if(!objDownFileName)
	{
		nTopFileName = nFilnameStartTop + (nAddIndex * (nHeightFileName+nFilnameGap));
		objDownFileName = new Static(sFilenameName,nLeftFileName,nTopFileName,350,nHeightFileName);
		this.addChild(sFilenameName,objDownFileName);
		
		if(this.smfIsMobile())	
			objDownFileName.set_cssclass("sta_WF_FileDownTxt_M");
			//objDownFileName.set_cssclass("sta_WF_FileDown_M");
		else
			objDownFileName.set_cssclass("sta_WF_FileDownTxt");
			
		//objDownFileName.set_right(10);
		// 2023.05.02  TF의 요청에 의해 표시방법 변경 ("다운로드 : aaa.txt")
		/*
		objDownFileName.set_usedecorate(true);
		var sDownloadText = '<fc v="#222222"><u v="false">'+sDownloadTextPrefix + '</u></fc><fc v="#2b72de"><u v="true">' +frontendFilename + '</u></fc>' + '  ';
		objDownFileName.set_text(sDownloadText);  // 1~2로 다른 값이 세티되는 것을 보정하기 위해 스페이스 추가
		*/
		//this.fnSetFileName(objDownFileName,frontendFilename);
		
		objDownFileName.set_initvalueid("ivStcAccessibilityOn");
		objDownFileName.set_cursor("pointer");
				

		objDownFileName.show();
		
		this.fnSetFileName(objDownFileName,frontendFilename);
		
		objDownFileName.fileIndex = nAddIndex;
		objDownFileName.addEventHandler("onclick",this.btnFileDown_onclick,this);
	}
	objDownFileName.fileIndex = nAddIndex;

	// 파일이름과 파일다운로드 오브젝트의 순서를 동기화
	this.fv_arrayBackendFilename.push(backendFilename);
	
	// OS인 경우는 sDownloadPath 를 없앰(SV는?)
	if((sFileSaveStg=="SV")||(sFileSaveStg=="OS")) 
	{
		sDownloadPath = "";
	}
	
	// 
	var objFileInfo = { 
	                    fileIndex        : nAddIndex
	                  , atchFileSn       : atchFileSn
					  , fileId           : fileId
					  , backendFilename  : backendFilename
					  , frontendFilename : frontendFilename
					  , downloadPath     : sDownloadPath
					  , fileEncryptYn    : sFileEncryptYn
					  , privInfoFiltYn   : sPrivInfoFiltYn
					  , fileSaveStg      : sFileSaveStg
					  , fileInfSaveYn    : sFileInfSaveYn
					  };
	this.fv_arrayFileInfo.push(objFileInfo)

	//CustomValue를 세팅한다.
	var sCustomValue = handlerCode 
				 + "," + atchFileSn 
				 + "," + fileId 
				 + "," + ((this.smfIsNull(sDownloadPath))?"":sDownloadPath)  // "DB"인 경우 서버에 저장된 Path
				 + "," + sFileEncryptYn
				 + "," + sPrivInfoFiltYn
				 + "," + sFileSaveStg
				 + "," + sFileInfSaveYn;
	
	if(this.RaonkDownload.IsLoadedUploadEx())
	{
		// 3번째 파라메터에 backendFilename을 전달한다
		this.RaonkDownload.AddUploadedFile(backendFilename, frontendFilename, backendFilename, fileSize, sCustomValue);
	}
	else
	{
		// Create안된 경우 빠르게 생성되면서 중복파일 에러 나는 경우를 대비
		var objAdd = {backendFilename:backendFilename , frontendFilename:frontendFilename, backendFilename:backendFilename, fileSize:fileSize, customValue:sCustomValue}
	
		this.fv_addUpdatedFile.push(objAdd);
	}
	//this.RaonkDownload.AddUploadedFile(backendFilename, frontendFilename, backendFilename, fileSize, sCustomValue);
};

this.RaonkUpload_RAONKUPLOAD_DownloadCompleteFile = function(obj:nexacro.RaonkUpload,  paramObj:nexacro.RaonkUploadEventInfo)
{
	trace("=====RaonkUpload_RAONKUPLOAD_CreationComplete : " + paramObj+" :obj :"+obj);
	// 저장위치를 지정(대문자 : 시스템코드(2)+"."+서브시스템코드(3)+"."+대분류코드(3) - 예, PA.SAM.PLE)
	
};

this.fnReArrangeHeight = function ()
{
	var nGap = 30;
	var nMaxBottom = 0;
	
	if(this.fv_arrayBackendFilename.length > 0)
	{
		var backendFilename = this.fv_arrayBackendFilename[this.fv_arrayBackendFilename.length-1];
		var sFilenameName = this.fv_prefixDownFilename + "" + backendFilename;
		
		var objDownFileName = this[sFilenameName];
		
		if(objDownFileName)
		{
			nMaxBottom = objDownFileName.getOffsetBottom();
		}
	}
	
	this.parent.setOffsetHeight(nMaxBottom+nGap);
}

// 파일Index를 이용하여 파일을 다운로드한다.
this.fnDownload = function(nFileIndex)
{
	var sFileIndex = nFileIndex+"";
	
	this.RaonkDownload.SetSelectFile(sFileIndex,'0');
	this.RaonkDownload.DownloadFile();
}

// 파일Index를 이용하여 파일을 다운로드한다.
this.fnDownloadAll = function()
{
	this.RaonkDownload.DownloadAllFile();
}

this.fnResetUpload = function()
{
	if(!this.smfIsNull(this.RaonkDownload._UploadID))
	{
		this.RaonkDownload.ResetUpload();
	}
	
	this.parent._fileRefrnId = "";
	
	this.fv_addUpdatedFile = [];
	this.fv_arrayBackendFilename = [];
	
	//  화면에 보이는 component를 안보이게
	var arrComps = this.components;
	for(var i=(arrComps.length-1);i>=0;i--)
	{
		var objComp = arrComps[i];
		var sCompId = objComp.id;
		
		if((sCompId.indexOf(this.fv_prefixDownBtn)>-1) || (sCompId.indexOf(this.fv_prefixDownFilename)>-1))
		{
			this.removeChild(objComp);
			objComp.destroy();
		}
		
	}
	
	//var sBtnName      = this.fv_prefixDownBtn      + "" + backendFilename;
	//var sFilenameName = this.fv_prefixDownFilename + "" + backendFilename;	
	
}

// 파일아이디와 파일seq를 이용하여 파일을 다운로드한다.
this.fnFileDownWithFileId = function(sFileId,sFileSeq)
{
	//this.fv_arrayFileInfo.push({fileIndex:fileIndex,atchFileSn:atchFileSn,fileId:fileId,backendFilename:backendFilename,frontendFilename:frontendFilename})
	var nFileIndex=-1;
	for(var i=0;i<this.fv_arrayFileInfo.length;i++)
	{
		if((this.fv_arrayFileInfo[i].atchFileSn==sFileId)&&(this.fv_arrayFileInfo[i].fileId==sFileSeq))
		{
			nFileIndex = this.fv_arrayFileInfo[i].fileIndex;
			break;
		}
	}
	
	if(nFileIndex!=-1)
	{
		this.fnDownload(nFileIndex);
	}
}


this.fnSetFileName = function (objDownFileName,frontendFilename)
{
	var bDispLongText = true;  // 긴 문장에 ...을 넣을 지 여부(현재는 요청이 없어 false로 해둠)
	var sDownloadTextPrefix = "다운로드 : ";
	var sFont = this.smfIsMobile()?'normal 400 26px/normal "Noto Sans KR","NotoSansKR-Regular"':'normal 400 13px/normal "Noto Sans KR","NotoSansKR-Regular"';  // 대국민 포털용
	var sDispFileName = frontendFilename;
	
	if(bDispLongText)
	{
		if(this.smfGetSubSystemGb()=="PAS")
		{
			sFont = this.smfIsMobile()?'normal 400 28px/normal "Noto Sans KR","NotoSansKR-Regular"':'normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular"';  // 대국민 포털용
		}
		
		if(this.smfIsMobile())
		{
			objDownFileName.set_right(10);
			
			sDispFileName = this.smfDispLongText(objDownFileName,sDownloadTextPrefix+sDispFileName,sFont);
			sDispFileName = sDispFileName.substr(sDownloadTextPrefix.length,sDispFileName.length-sDownloadTextPrefix.length);
		}
	}
	objDownFileName.set_usedecorate(true);
	var sDownloadText = '<fc v="#222222"><u v="false">'+sDownloadTextPrefix + '</u></fc><fc v="#2b72de"><u v="true">' +sDispFileName + '</u></fc>' + '  ';
	objDownFileName.set_text(sDownloadText);  // 1~2로 다른 값이 세티되는 것을 보정하기 위해 스페이스 추가
	
	// 
	if(!this.smfIsMobile()||(!bDispLongText))
	{
		objDownFileName.set_fittocontents("width");
	}
	
	
	
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.btnFileDown_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnDownload(obj.fileIndex);
};

this.RaonkUpload_RAONKUPLOAD_BeforeCreation = function(obj:nexacro.RaonkUpload)
{
	// 설정값 변경
	// 국정원보안 적용 (set_InitXml->set_InitServerXml)
	//obj.set_InitXml("raonkupload.config.txt");
	obj.set_InitServerXml("/cm_cmc_file_upload.do?f=raonkupload.config.txt");
	
	// 유저별로 각각 설정한 값을 Raon에 설정
	// div userproperty 에 addProp에 함수명 설정
	// 함수에서는 Json으로 정보전달
	if(this.parent.addProp)
	{
		var sFuncName = this.parent.addProp;
		var objCur = this.parent.parent;
		var objFunc;
		
		// 함수를 찾아서 없으면 부모까지 전달(mainframe까지만 검색)
		while(objCur.id != "mainframe")
		{
			// 함수가 존재한지 여부(Form인 경우만)
			if(objCur instanceof nexacro.Form)
			{
				objFunc = objCur[sFuncName];
				// 존재한다면 처리를 중단
				if(objFunc)
				{
					break;
				}
			}
			
			// 존재하지 않으면, 부모를 계속 찾아감
			objCur = objCur.parent;
		}
		
		// 함수가 존재하면 해당 함수를 call하여 세팅할 정보를 취득
		if(objFunc)
		{
			// 해당함수 call(리턴은 설정정보 JSON)
			var objPropList = objFunc.call(objCur);
			
			// json오브젝트의 값을 raon에 세팅한다.
			for(sKey in objPropList)
			{
				// 값이 ""인 경우에도 세팅하기 위해
				if((obj[sKey]!=null)&&(obj[sKey]!="undefined"))
				{
					obj[sKey] = objPropList[sKey];
				}
			}
		}
	}
	
};

this.RaonkDownload_RAONKUPLOAD_DownloadCompleteFile = function(obj:nexacro.RaonkUpload, paramObj:nexacro.RaonkUploadEventInfo)
{
	if(this.parent.UPLOAD_DownloadComplete)
	{
		this.parent.UPLOAD_DownloadComplete.call(this.parent.UPLOAD_Form,obj,paramObj);
	}
};

this.RaonkDownload_RAONKUPLOAD_Alert = function(obj:nexacro.RaonkUpload, paramObj:nexacro.RaonkUploadEventInfo)
{
	var sMsg = paramObj.userdata.msg;
	//this.smfAlert("CM000",[sMsg]);
	this.smfAlert(sMsg);
};


this.RaonkDownload_RAONKUPLOAD_CreationComplete = function(obj:nexacro.RaonkUpload,  paramObj:nexacro.RaonkUploadEventInfo)
{
	//trace("=====RaonkUpload_RAONKUPLOAD_CreationComplete : " + JSON.stringify(paramObj.userdata) +" :obj :"+obj.id + " - " + this.fv_addUpdatedFile.length);	
	for(var i=0;i<this.fv_addUpdatedFile.length;i++)
	{
		var objAdd = this.fv_addUpdatedFile[i];
		this.RaonkDownload.AddUploadedFile(objAdd.backendFilename, objAdd.frontendFilename, objAdd.backendFilename, objAdd.fileSize, objAdd.customValue);
	}
	this.fv_addUpdatedFile =[];
	
	// 이벤트가 있으면 이벤트 호출
	if(this.parent.UPLOAD_CreateComplete)
	{
		this.parent.UPLOAD_CreateComplete.call(this.parent.UPLOAD_Form,obj,paramObj);
	}	
};

this.RaonkUpload_RAONKUPLOAD_OnError = function(obj:nexacro.RaonkUpload, paramObj:nexacro.RaonkUploadEventInfo)
{
	//trace("RaonkUpload_RAONKUPLOAD_OnError=====");
	// 에러코드가 "900"인 경우는 서버에서 만든 User에러이므로 Alert을 표시한다.
	if((paramObj.userdata.strCode=="900")&&(this.parent.errorAlertSkip!="Y"))  // 서버에서 만든 에러
	{
		this.smfAlert(paramObj.userdata.strMessage,function(){
			if(this.parent.UPLOAD_OnError)
			{
				this.parent.UPLOAD_OnError.call(this.parent.UPLOAD_Form,obj,paramObj,this.parent)
			}
		});
	
	} else
	{
		if(this.parent.UPLOAD_OnError)
		{
			this.parent.UPLOAD_OnError.call(this.parent.UPLOAD_Form,obj,paramObj,this.parent)
		}
	}	
};
]]></Script>
  </Form>
</FDL>
