<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="comm_browser_notice" width="620" height="510" titletext="태블릿기기에서 모바일버전으로 변경설정" onload="fnOnload" cssclass="frm_Pop_bgTrsprt">
    <Layouts>
      <Layout height="510" width="620" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divMain" taborder="1" left="0" top="0" cssclass="div_WF_SurvPopLine" initvalueid="ivDivAccessibilityOff" width="620" height="510" background="#ffffff">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" text="태블릿에서 데스크탑 버전으로 설정되어 화면이 정상적으로 보이지 않을 경우 모바일 버전 설정을 변경해 주시기 바랍니다." left="20" top="20" width="507" height="70" cssclass="sta_WF_Txt20B" initvalueid="ivStcAccessibilityOn" usedecorate="false" fittocontents="height" onclick="divMain_sta00_onclick"/>
              <Static id="sta02" taborder="1" text="브라우저별 설정 방법" left="20" top="sta00:24" width="560" height="40" cssclass="sta_WF_SurvCautionS" initvalueid="ivStcAccessibilityOn" fittocontents="height" verticalAlign="top"/>
              <Static id="sta03" taborder="2" text="&lt;b v='true'&gt;삼성브라우저&lt;/b&gt;" left="20" top="sta02:20" width="560" height="10" cssclass="sta_WF_survGrayDot14" initvalueid="ivStcAccessibilityOn" usedecorate="true" fittocontents="height" verticalAlign="top" minheight="40" maxheight=""/>
              <Button id="btnClose" taborder="12" top="20" width="36" height="36" cssclass="btn_WF_SurvPopClose" initvalueid="ivBtnAccessibilityButton" right="20" onclick="div00_btnClose_onclick" accessibilitylabel="팝업닫기"/>
              <Static id="staEmp1" taborder="13" left="0" top="0" height="20" cssclass="sta_WF_GDSize" text="20" visible="false" initvalueid="ivStcAccessibilityOff" right="0"/>
              <Static id="staEmp2" taborder="14" left="0" top="20" cssclass="sta_WF_GDSize" text="20" visible="false" initvalueid="ivStcAccessibilityOff" width="20" bottom="0"/>
              <Static id="sta03_01" taborder="3" text="우측 상단의                아이콘 → 모바일 사이트 선택" left="50" top="sta03:-10" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" minheight="40" maxheight="" fittocontents="height" verticalAlign="top" right="10"/>
              <Static id="sta03_02" taborder="15" initvalueid="ivStcAccessibilityOff" background="url('theme://images/icon_set2.png') no-repeat center center" top="sta03:-20" height="30" width="20" left="140" text=""/>
              <Static id="sta04" taborder="4" text="&lt;b v='true'&gt;Safari&lt;/b&gt;" left="20" top="sta03_01:0" width="560" height="10" cssclass="sta_WF_survGrayDot14" initvalueid="ivStcAccessibilityOn" usedecorate="true" fittocontents="height" verticalAlign="top" minheight="40" maxheight=""/>
              <Static id="sta04_01" taborder="5" text="기기설정 → Safari → 데스크탑 웹 사이트 요청 → 모든 웹 사이트 해제" left="50" top="sta04:-10" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" minheight="40" maxheight="" fittocontents="height" verticalAlign="top" right="10"/>
