              <Static id="sta05_02" taborder="16" initvalueid="ivStcAccessibilityOff" background="url('theme://images/icon_set4.png') no-repeat center center" top="sta05:-20" height="30" width="30" left="130"/>
              <Static id="sta06" taborder="8" text="&lt;b v='true'&gt;Whale&lt;/b&gt;" left="20" top="sta05_01:0" width="560" height="10" cssclass="sta_WF_survGrayDot14" initvalueid="ivStcAccessibilityOn" usedecorate="true" fittocontents="height" verticalAlign="top" minheight="40" maxheight=""/>
