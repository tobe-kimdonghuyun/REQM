<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="comm_fileAdd" width="480" height="30" titletext="파일첨부" background="white" onload="comm_fileAdd_onload" oninit="comm_fileAdd_oninit">
    <Layouts>
      <Layout height="30" width="480" screenid="ScreenDeskTop">
        <RaonkUpload id="RaonkUpload" taborder="0" left="510" top="90" text="File Upload/Download" RAONKUPLOAD_UploadComplete="RaonkUpload_RAONKUPLOAD_UploadComplete" RAONKUPLOAD_CreationComplete="RaonkUpload_RAONKUPLOAD_CreationComplete" RAONKUPLOAD_BeforeCreation="RaonkUpload_RAONKUPLOAD_BeforeCreation" HeaderBar="0" RAONKUPLOAD_OnError="RaonkUpload_RAONKUPLOAD_OnError" visible="false" width="480" height="120" RAONKUPLOAD_AfterAddFile="RaonkUpload_RAONKUPLOAD_AfterAddFile" RAONKUPLOAD_BeforeAddFile="RaonkUpload_RAONKUPLOAD_BeforeAddFile" DisableDeleteConfirm="3" RAONKUPLOAD_BeforeUpload="RaonkUpload_RAONKUPLOAD_BeforeUpload" RAONKUPLOAD_AfterAddAllFile="RaonkUpload_RAONKUPLOAD_AfterAddAllFile" RAONKUPLOAD_BeforeOpenFile="RaonkUpload_RAONKUPLOAD_BeforeOpenFile" RAONKUPLOAD_Alert="RaonkUpload_RAONKUPLOAD_Alert" UseAlertEvent="1" MultiFileSelect="0"/>
        <Edit id="edtFile" taborder="1" left="0" top="0" height="30" right="38" text="wewewe" readonly="true" initvalueid="ivEdtNormal"/>
        <Button id="btnFileSelect" taborder="2" left="edtFile:8" top="0" width="30" height="30" cssclass="btn_WF_FileAdd01" onclick="btnFileSelect_onclick" initvalueid="ivBtnAccessibilityLink" accessibilitylabel="첨부하기"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  파일업로드/다운로드
*  @MenuPath    common
*  @FileName 	comm_fileAdd.xfdl
*  @Creator 	홍길동
*  @CreateDate 	2022.6.9
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.6.9     	홍길동 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.comm_fileAdd_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// userProperty작업
	// 필수처리
	if(this.parent.essential && (this.parent.essential=="Y"))
	{
		this.edtFile.set_cssclass("essential")
	}
	
	
	
};

// Form의 init이벤트 - Form안의 component가 생성되기 이전 최초이벤트(onload보다 먼저 생성)
this.comm_fileAdd_oninit = function(obj:nexacro.Form,e:nexacro.EventInfo)
{
	var sBaseUrl = "";
	
	// runtime인 경우에는 해당 정보를 세팅해주어야 함
	if (system.navigatorname.indexOf("nexacro")  > -1) 	{
		// raonkupload_rootUrl이 세팅이 안된경우에만 사용
		if(this.smfIsNull(raonkupload_rootUrl))
		{
			// 현재의 실행모드(서버종류)를 판별한다.
			var sRunMode = nexacro.getEnvironmentVariable("ev_runMode");
			
			//xadl의 url을 구한다
			var sXadlUrl = nexacro.getApplication().xadl;
			var nFindIdx = sXadlUrl.indexOf("nxui");
			
			//trace("====>>>> sXadlUrl="+sXadlUrl);
			if(nFindIdx>-1)
			{
				var nFindIdx2 = sXadlUrl.indexOf("/",nFindIdx);
				sBaseUrl = sXadlUrl.substr(0,nFindIdx2);
				
			}
			
			//trace("====>>>> sBaseUrl="+sBaseUrl);
			raonkupload_rootUrl = sBaseUrl + "/nexacrolib/component/raonkupload";
			//trace("====>>>> raonkupload_rootUrl="+raonkupload_rootUrl);
		}
	}
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback  = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 파일업로드
this.fnFileUpload = function()
{
	this.RaonkUpload.Transfer();
}

// 파일다운로드
this.fnFileDownload = function()
{
	this.RaonkUpload.DownloadAllFile();
}


this.fnGetTotalFileSize = function()
{
	return this.RaonkUpload.GetTotalFileSize();
}

this.fnGetTotalFileCount = function()
{
	return this.RaonkUpload.GetTotalFileCount();
}

this.fnAddUploadedFile = function(handlerCode, atchFileSn, fileSize, backendFilename, frontendFilename, fileSeq, sDownloadPath, sFileEncryptYn, sPrivInfoFiltYn, sFileSaveStg, sFileInfSaveYn)
{ 

	this.parent._fileRefrnId = 	atchFileSn;

	// 파일명표시영역에 파일명을 추가한다.
	this.edtFile.set_value(frontendFilename);
	
	sFileEncryptYn  = this.smfNvl(sFileEncryptYn , "N" );   // 파일암호화여부(Y/N) 
	sPrivInfoFiltYn = this.smfNvl(sPrivInfoFiltYn, "N" );   // 개인정보필터여부(Y/N) 
	sFileSaveStg    = this.smfNvl(sFileSaveStg   , "SV");   // 저장소구분(DB:DB , SV:공유볼륨, OS:오브젝트스토리지)
	sFileInfSaveYn  = this.smfNvl(sFileInfSaveYn , "Y" );   // 공통테이블(FW_SYMSYEFL001NT)에 저장여부(Y/N)
	
	// OS인 경우는 sDownloadPath 를 없앰(SV는?)
	if((sFileSaveStg=="SV")||(sFileSaveStg=="OS")) 
	{
		sDownloadPath = "";
	}
	
	var sCustomValue = handlerCode 
	                 + "," + atchFileSn 
					 + "," + fileSeq 
					 + "," + ((this.smfIsNull(sDownloadPath))?"":sDownloadPath)  // "DB"인 경우 서버에 저장된 Path
					 + "," + sFileEncryptYn
					 + "," + sPrivInfoFiltYn
					 + "," + sFileSaveStg
					 + "," + sFileInfSaveYn;	
	// 3번째 파라메터에 backendFilename을 전달한다
	return this.RaonkUpload.AddUploadedFile(backendFilename, frontendFilename, backendFilename, fileSize, sCustomValue);
	
}

this.fnResetUpload = function()
{
	if(!this.smfIsNull(this.RaonkUpload._UploadID))
	{
		this.RaonkUpload.ResetUpload();
	}
	
	
	this.edtFile.set_value("");
	
	this.parent._fileRefrnId = "";
	
}

this.fnSetEssential = function(bValue)
{
	if(bValue)
	{
		this.edtFile.set_cssclass("essential")
	}
	else
	{
		this.edtFile.set_cssclass("")
	}
}


// 서버로부터 받은 파일업로드결과정보를 신규파일의 customValue에 세팅한다.
this.fnSetCustomValueAfterUpload = function(objRaon:nexacro.RaonkUpload,objDs:nexacro.NormalDataset)
{
	var listInfo = objRaon.GetListInfo("json")	    // 전송완료 후 새롭게 업로드 된 파일, 웹파일, 삭제된 파일 리스트 정보를 리턴해 주는 함수 입니다. ('array', 'json', 'xml', 'text')
	//var jsonNew     = listInfo.newFile;			// 새로 업로드된 파일 정보
    //var jsonDel     = listInfo.deleteFile;		// 삭제된 파일 정보
    //var jsonWebFile = listInfo.webFile;			// 웹파일 정보(이미 업로드 된 파일을 추가한 경우(AddUploadedFile()로 추가한 것- 업로드 대상에서 제외))
	var jsonMerge   = listInfo.mergeFile;		// 신규추가된 파일과 웹파일을 함께 볼수 있는 정보

	var sCustomValue = "";
	var sHandlerCode    = this.smfNvl(this.parent.uploadLocation, ""  );
	var sFileEncryptYn  = this.smfNvl(this.parent.fileEncryptYn , "N" );   // 파일암호화여부(Y/N) 
	var sPrivInfoFiltYn = this.smfNvl(this.parent.privInfoFiltYn, "N" );   // 개인정보필터여부(Y/N) 
	var sFileSaveStg    = this.smfNvl(this.parent.fileSaveStg   , "SV");   // 저장소구분(DB:DB , SV:공유볼륨, OS:오브젝트스토리지)
	var sFileInfSaveYn  = this.smfNvl(this.parent.fileInfSaveYn , "Y" );   // 공통테이블(FW_SYMSYEFL001NT)에 저장여부(Y/N)
	
	if(jsonMerge)
	{
		for(var i=0;i<jsonMerge.fileId.length;i++)
		{
			var sMergeCustomValue = jsonMerge.customValue[i];  // customervalue를 
			var sMergeFileId      = jsonMerge.uploadName [i];  // 변경된 파일이름(이 항목을 사용할 지는 확인 필요)
			
			if(jsonMerge.isWebFile[i]=="0")
			{
				var nIdx = objDs.findRow("atchFileGuid",sMergeFileId);
				if(nIdx>-1)
				{
					var sFileRefrnId = objDs.getColumn(nIdx,"fileRefrnId" );  // 파일 참조번호
					var sFileOrder   = objDs.getColumn(nIdx,"fileId"      );  // 파일 순번
					sCustomValue = sHandlerCode +","+sFileRefrnId+","+sFileOrder+","+sFileEncryptYn+","+sPrivInfoFiltYn+","+sFileSaveStg+","+sFileInfSaveYn;

					nIdx = objRaon.SetFileCustomValue(i,sCustomValue);
				}
			}
			
		}
	}

}


