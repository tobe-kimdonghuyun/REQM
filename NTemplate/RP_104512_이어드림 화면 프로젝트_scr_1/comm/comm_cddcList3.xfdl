              <Button id="btnR10" taborder="16" text="경상북도교육청" top="btnM10:10" height="60" cssclass="btn_WF_Action" initvalueid="ivBtnAccessibilityLink" left="btnQ10:10" width="215" _value="R100000001" onclick="ButtonB_onclick" background="#038667"/>
              <Button id="btnS10" taborder="17" text="경상남도교육청" top="464" height="60" cssclass="btn_WF_Action" initvalueid="ivBtnAccessibilityLink" left="750" width="215" _value="S100000001" onclick="ButtonB_onclick" background="#038667"/>
