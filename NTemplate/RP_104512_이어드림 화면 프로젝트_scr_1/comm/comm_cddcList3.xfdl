        <Static id="staSelectedCddcName" taborder="2" text="현재 선택하신 교육청은&#13;&#10;&lt;fc v='#038667'&gt;&lt;u v='true'&gt;&lt;b v='true'&gt;경상북도교육청&lt;/b&gt;&lt;/u&gt;&lt;/fc&gt; 입니다." left="1248" top="490" width="622" height="153" cssclass="sta_WF_Txt60R" initvalueid="ivStcAccessibilityOff" usedecorate="true" visible="false"/>
      </Layout>
