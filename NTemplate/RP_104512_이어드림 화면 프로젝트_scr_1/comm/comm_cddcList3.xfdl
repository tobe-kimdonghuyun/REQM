              <Button id="btnD10" taborder="4" text="대구광역시교육청" top="254" height="60" cssclass="btn_WF_Action" initvalueid="ivBtnAccessibilityLink" left="btnC10:10" width="215" _value="D100000001" onclick="ButtonB_onclick" background="#038667"/>
              <Button id="btnE10" taborder="5" text="인천광역시교육청" top="254" height="60" cssclass="btn_WF_Action" initvalueid="ivBtnAccessibilityLink" left="btnD10:10" width="215" _value="E100000001" onclick="ButtonB_onclick" background="#038667"/>
              <Button id="btnF10" taborder="6" text="광주광역시교육청" top="btnB10:10" height="60" cssclass="btn_WF_Action" initvalueid="ivBtnAccessibilityLink" left="75" width="215" _value="F100000001" onclick="ButtonB_onclick" background="#038667"/>
              <Button id="btnG10" taborder="7" text="대전광역시교육청" top="btnC10:10" height="60" cssclass="btn_WF_Action" initvalueid="ivBtnAccessibilityLink" left="btnF10:10" width="215" _value="G100000001" onclick="ButtonB_onclick" background="#038667"/>
