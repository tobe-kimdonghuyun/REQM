          <Column id="subSys" type="STRING" size="256" description="서브시스템구분값(예, EWS)"/>
          <Column id="siteId" type="STRING" size="256"/>
          <Column id="securityKey" type="STRING" size="256" description="사이트에 등록된 securityKey"/>
          <Column id="baseUrl" type="STRING" size="256" description="접속하는 디지털원패스URL"/>
          <Column id="desc" type="STRING" size="256" description="설명"/>
