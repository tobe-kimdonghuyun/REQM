<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="comp_calFrm" left="0" top="0" width="173" height="184" titletext="년월팝업" onload="comp_calFrm_onload" background="white">
    <Layouts>
      <Layout screenid="ScreenDeskTop">
        <Div id="divMonth" taborder="0" left="0" top="0" background="#f7f8fa" border="1px solid #646982" right="0" bottom="0" initvalueid="ivDivAccessibilityOn" accessibilitylabel="년,월 팝업">
          <Layouts>
            <Layout>
              <Static id="staTitle" taborder="0" text="2019" left="1" top="5" height="26" uWord="popup.monthselect" cssclass="sta_WF_Txt14B" width="170" textAlign="center" initvalueid="ivStcAccessibilityOn"/>
              <Button id="btnBefore" taborder="1" left="10" top="8" width="26" height="21" cssclass="btn_WF_ShuttleL" initvalueid="ivBtnAccessibilityButton" onclick="divMonth_btnBefore_onclick" accessibilitylabel="이전 년도"/>
              <Button id="btnNext" taborder="2" top="8" width="26" height="21" right="10" cssclass="btn_WF_ShuttleR" initvalueid="ivBtnAccessibilityButton" onclick="divMonth_btnNext_onclick" accessibilitylabel="다음 년도"/>
              <Button id="btn1" taborder="3" text="1" left="10" top="36" width="36" height="44" cssclass="btn_WF_Month01S" initvalueid="ivBtnAccessibilityButton" onclick="divMonthButton_onclick"/>
