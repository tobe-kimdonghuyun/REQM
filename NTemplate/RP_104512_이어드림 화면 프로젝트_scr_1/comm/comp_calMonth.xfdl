        </Div>
      </Layout>
      <Layout screenid="mobile,tablet" name="default0" width="500" height="510">
        <Div id="divMonth" taborder="0" left="0" top="0" background="#f7f8fa" border="1px solid #646982" right="0" bottom="0" text=""/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/*
*프로그램명	: 년월(yyyy.MM)달력 샘플
*작 성 자   	: 
*작 성 일		: 2021-08-16
*설    명		: 달력 컴포넌트를 이용한 년월선택 하기위한 프로그램
*수정일		:
*수정자		:
*수정내용		:
*/

//공통 스크립트 include
//include "lib::utl_script.xjs";

/* form onload */
this.comp_calFrm_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	var myFrame = obj.getOwnerFrame();
};

this.set_refComponent = function(refComponent){
	this.refComponent = refComponent;
};

this.divMonth_btnBefore_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divMonth.form.staTitle.set_text(nexacro.toNumber(this.divMonth.form.staTitle.text) -1);
};

this.divMonth_btnNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divMonth.form.staTitle.set_text(nexacro.toNumber(this.divMonth.form.staTitle.text) +1);
};

/* 년월선택 팝업창 선택값 돌려주기 */
this.divMonthButton_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.refComponent.set_value( this.divMonth.form.staTitle.text+obj.text );
	this.parent.closePopup(this.divMonth.form.staTitle.text+obj.text);
};
]]></Script>
  </Form>
</FDL>
