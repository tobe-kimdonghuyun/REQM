    <Script type="xscript5.1"><![CDATA[include "lib::cm_script.xjs"

// 로드
this.comm_alert_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitPopup(obj);
	//this.smfInitForm(obj);
	trace("this.height="+this.getOffsetHeight() + " , this.parent.height="+this.parent.getOffsetHeight())
	this.pv_params = this.smfGetPopupParams();
	//this.smfUpdatePopupTitle("알림");
	//console.log(this.pv_params);
	
// 	var fnMessage = this.pv_params.message.substring(this.pv_params.message.length-4, 0);
//  	var fnLangCd = this.pv_params.message.substring(this.pv_params.message.length-1);
// 	var fnSurvey = this.pv_params.message.substring(this.pv_params.message.length-4);
// 	fnSurvey = fnSurvey.substring(fnSurvey.length-1, 0);
// 	
// 	fnSurvey == "vff" ? this.div03.form.staMessage.set_text(this.smfStr(fnMessage)) : this.div03.form.staMessage.set_text(this.smfStr(this.pv_params.message));
	this.div03.form.staMessage.set_text(this.smfStr(this.pv_params.message));
	
	if ( this.pv_params.align ) {
	    this.div03.form.staMessage.set_textAlign(this.pv_params.align);
	}
};

this.btnOk_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};

this.comm_alert_onclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	this.smfSendResponseToOpener({});
};

this.comm_alert_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	trace("comm_alert_onsize : e.cy="+e.cy);
};

this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};
]]></Script>
