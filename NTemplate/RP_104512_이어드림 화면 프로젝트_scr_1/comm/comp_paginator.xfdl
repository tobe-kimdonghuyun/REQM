        <Button id="btnAppendData" visible="true" cssclass="btn_WF_CustomR" left="30.78%" top="0" width="246" height="80"/>
        <Static id="staTotalCount" visible="false" left="0" top="162" width="91" height="26"/>
        <Combo id="cboPageSize" visible="false" left="91" top="160" width="113" height="30"/>
        <Button id="imgPrevPage" visible="false" left="290" top="163" width="24" height="24"/>
        <Button id="imgPrev" visible="false" left="313" top="163" width="24" height="24"/>
        <Div id="divPage" visible="false" left="345" top="161" width="201" height="30"/>
        <Button id="imgNext" visible="false" left="552" top="163" width="24" height="24"/>
        <Button id="imgNextPage" visible="false" left="575" top="163" width="24" height="24"/>
