        <Button id="imgNextPage" taborder="6" cssclass="btn_WF_PageN" left="580" top="1" height="28" width="28" visible="true" onclick="fnPagemove_onclick" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="끝페이지"/>
        <Button id="btnAppendData" taborder="7" text="더보기" left="194" top="60" width="246" height="80" cssclass="btn_WF_CustomB" visible="false" initvalueid="ivBtnAccessibilityButton" onclick="btnAppendData_onclick"/>
