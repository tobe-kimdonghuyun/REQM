        <Button id="btnClose" taborder="5" text="닫기" left="370" width="80" height="32" bottom="20" onclick="btnClose_onclick" initvalueid="ivBtnAccessibilityButton"/>
        <Div id="divOption11" taborder="6" text="div00" left="846" top="73" right="-315" bottom="12" visible="false">
          <Layouts>
            <Layout>
              <Static id="staOption00" taborder="0" text="Drag Mode" left="21" top="15" width="120" height="30"/>
              <Button id="btnDragModeMove" taborder="1" text="Move" left="50" top="45" width="70" height="30" onclick="divOption_btnDragModeMove_onclick"/>
