              <Static id="staOption01" taborder="3" text="자르기영역" left="21" top="85" width="120" height="30"/>
              <Radio id="rdoCropRectType" taborder="4" left="47" top="108" width="160" height="30" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" columncount="2" onitemchanged="divOption_rdoCropRectType_onitemchanged" value="free" text="Free" index="0">
                <Dataset id="innerdataset">
                  <ColumnInfo>
                    <Column id="codecolumn" size="256"/>
                    <Column id="datacolumn" size="256"/>
                  </ColumnInfo>
                  <Rows>
                    <Row>
                      <Col id="codecolumn">free</Col>
