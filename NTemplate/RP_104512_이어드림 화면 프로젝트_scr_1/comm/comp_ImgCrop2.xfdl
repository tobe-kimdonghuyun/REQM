        </Div>
        <WebBrowser id="webImageCrop" taborder="1" left="20" top="110" border="1px solid #dddddd" onusernotify="webImageCrop_onusernotify" onloadcompleted="webImageCrop_onloadcompleted" initvalueid="ivWebAccessibilityOn" height="430" width="630"/>
