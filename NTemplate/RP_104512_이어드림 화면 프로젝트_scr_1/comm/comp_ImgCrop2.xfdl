              <Button id="btnScale100" taborder="11" text="100%" left="476" top="39" width="48" height="33" onclick="divOption_btnScale100_onclick" tooltiptext="100%" cssclass="btn_CP_Text" initvalueid="ivBtnAccessibilityButton"/>
              <Button id="btnScaleMinus" taborder="12" text="-10%" left="530" top="39" width="48" height="33" onclick="divOption_btnScaleMinus_onclick" tooltiptext="-10%" cssclass="btn_CP_Text" initvalueid="ivBtnAccessibilityButton"/>
