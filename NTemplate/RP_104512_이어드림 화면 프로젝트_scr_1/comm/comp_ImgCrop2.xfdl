              <Button id="btnCropRectSetting" taborder="24" text="실행" left="1378" top="50" width="30" height="30" onclick="divOption_btnCropRectSetting_onclick" tooltiptext="실행" visible="false"/>
              <Static id="sta01" taborder="25" left="206" top="45" width="10" height="20" cssclass="sta_TF_Section16B" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta01_00" taborder="26" left="316" top="45" width="10" height="20" cssclass="sta_TF_Section16B" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta01_00_00" taborder="27" left="596" top="45" width="10" height="20" cssclass="sta_TF_Section16B" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta01_00_00_00" taborder="28" left="707" top="45" width="10" height="20" cssclass="sta_TF_Section16B" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta01_01" taborder="29" left="99" top="45" width="10" height="20" cssclass="sta_TF_Section16B" initvalueid="ivStcAccessibilityOff"/>
