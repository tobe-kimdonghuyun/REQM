              <Button id="btnReverseHorizon" taborder="15" left="653" top="39" width="33" height="33" onclick="divOption_btnReverseHorizon_onclick" tooltiptext="좌우" cssclass="btn_CP_RightLeft" initvalueid="ivBtnAccessibilityButton"/>
              <Static id="staOption05" taborder="16" text="이미지 자르기" left="708" top="14" width="80" height="20" textAlign="center" initvalueid="ivStcAccessibilityOn"/>
              <Button id="btnCrop" taborder="17" left="732" top="39" width="33" height="33" onclick="divOption_btnCrop_onclick" tooltiptext="자르기" cssclass="btn_CP_ImgCut" initvalueid="ivBtnAccessibilityButton"/>
              <Static id="staOption01" taborder="18" text="자르기영역" left="1218" top="20" width="120" height="30" visible="false"/>
              <Radio id="rdoCropRectType" taborder="19" left="1037" top="28" width="160" height="30" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" columncount="2" onitemchanged="divOption_rdoCropRectType_onitemchanged" value="free" text="Free" index="0" visible="false">
