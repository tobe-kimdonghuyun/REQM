              <Static id="sta00_00" taborder="5" text="W" left="46" top="141" width="15" height="27"/>
              <Edit id="edtCropRectWidth" taborder="6" left="61" top="141" width="57" height="27" enable="true" readonly="true"/>
              <Static id="sta00" taborder="7" text="H" left="128" top="141" width="15" height="27"/>
              <Edit id="edtCropRectHeight" taborder="8" left="142" top="141" width="57" height="27" enable="true" readonly="true"/>
              <Button id="btnCropRectSetting" taborder="9" text="실행" left="203" top="139" width="70" height="30" onclick="divOption_btnCropRectSetting_onclick"/>
              <Static id="staOption02" taborder="10" text="이미지 회전" left="21" top="175" width="120" height="30"/>
              <Button id="btnRotateLeft" taborder="11" text="시계방향" left="50" top="205" width="80" height="30" onclick="divOption_btnRotateLeft_onclick"/>
              <Button id="btnRotateRight" taborder="12" text="반시계방향" left="140" top="205" width="100" height="30" onclick="divOption_btnRotateRight_onclick"/>
              <Static id="staOption03" taborder="13" text="이미지 확대/축소" left="21" top="245" width="120" height="30"/>
              <Button id="btnScalePlus" taborder="14" text="+10%" left="50" top="275" width="60" height="30" onclick="divOption_btnScalePlus_onclick"/>
              <Button id="btnScale100" taborder="15" text="100%" left="115" top="275" width="70" height="30" onclick="divOption_btnScale100_onclick"/>
              <Button id="btnScaleMinus" taborder="16" text="-10%" left="190" top="275" width="60" height="30" onclick="divOption_btnScaleMinus_onclick"/>
              <Edit id="edtScaleRate" taborder="17" left="101" top="315" width="86" height="27" enable="true" readonly="true"/>
              <Static id="sta00_01" taborder="18" text="%" left="194" top="315" width="20" height="30"/>
              <Static id="staOption04" taborder="19" text="이미지 반전" left="21" top="345" width="120" height="30"/>
              <Button id="btnReverseVertical" taborder="20" text="상하" left="50" top="375" width="70" height="30" onclick="divOption_btnReverseVertical_onclick"/>
              <Button id="btnReverseHorizon" taborder="21" text="좌우" left="130" top="375" width="70" height="30" onclick="divOption_btnReverseHorizon_onclick"/>
              <Static id="staOption05" taborder="22" text="이미지 자르기" left="21" top="415" width="120" height="30"/>
              <Button id="btnCrop" taborder="23" text="자르기" left="50" top="445" width="70" height="30" onclick="divOption_btnCrop_onclick"/>
              <Button id="btnCropSave" taborder="24" text="자르기 +저장" left="22" top="480" width="100" height="30" onclick="divOption_btnCropSave_onclick" visible="false"/>
              <ImageViewer id="imgCropped" taborder="25" left="141" top="424" right="39" bottom="12" stretch="fit"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btn00" taborder="7" text="파일선택" left="882" top="42" width="89" height="33" onclick="btn00_onclick" visible="false"/>
        <Static id="staOption00" taborder="8" text="파일선택" left="848" top="15" width="120" height="30" visible="false"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민 - 이미지크롭 공통팝업
*  @MenuPath    공통
*  @FileName 	comp_ImgCrop.xfdl
*  @Creator 	정인혁
*  @CreateDate 	2022.10.4
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.10.4     	정인혁 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvFileName = "crop.png";

this.fvCropImageInfo = {
					      imageType        : ""
						, imageFileName    : ""
						, imageDataBase64  : ""
                       };
// 자른 이미지의 사이즈를	표시하기 위한 처리				   
this.fv_LimitUnitByte     = 1024;  // 1024 : KB, 실제 사이즈 = this.fv_LimitUnitByte * this.fv_LimitByte
this.fv_LimitByte         = 100;
this.fv_ImageDispUnitText = "KB";
this.fv_uselimitsize = false;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
//   
this.comp_ImgCrop_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitPopup(this);
	
	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	
	//http://localhost:8080/html/imagecrop/cropperjs_nexacro.html
	//var sUrlPath = window.location.protocol + "//" + window.location.host;
	var sUrlPath = this.smfGetBaseUrl(); //window.location.protocol + "//" + window.location.host;
	var sUrl =  sUrlPath + "/html/imagecrop/cropperjs_nexacro.html";
	
	// Url세팅
	this.webImageCrop.set_url(sUrl);		
	
	// 파일사이즈 제한을 세팅한다.
	if(this.pv_params.limitFileSize)
	{
		this.fv_uselimitsize = true;
		this.staImageCropByte.set_visible(true);
		
		this.fv_ImageDispUnitText = this.pv_params.limitFileUnit || "KB";
		this.fv_LimitByte = parseInt(this.pv_params.limitFileSize);
		if(this.fv_ImageDispUnitText=="KB")
		{  // KB
			this.fv_LimitUnitByte = 1024;
		}
		else if(this.fv_ImageDispUnitText=="MB")
		{  // MB
			this.fv_LimitUnitByte = 1024*1000;
		}
		else
		{  // GB
			this.fv_LimitUnitByte = 1024*1000*1000;
		}
		
		this.fnDisplayImageCropByteInfo(0);
	}
	else
	{
		this.fv_uselimitsize = false;
		//this.staImageCropByte.set_visible(false);	
	}
	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function()
{

}
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnSetData = function()
{
	
}

// 자른 이미지의 바이트수를 표시한다.
this.fnDisplayImageCropByteInfo = function(nImageByte,nImageReduceByte)
{
	var nLimitByte = this.fv_LimitByte;
	var sUnitText  = this.fv_ImageDispUnitText || "KB";
	var sText = "이미지사이즈 :  " + parseInt(nImageByte / this.fv_LimitUnitByte);
	
	if(this.fv_uselimitsize)
	{
		sText += "\n"+" / " + nLimitByte;
	}
	
	// 단위를 표시
	sText += " (" + sUnitText + ")";
	
	// 압축했을 경우 - 압축이미지를 사용
	if(nImageReduceByte)
	{
		sText += "\n"+ "압축시 : "+parseInt(nImageReduceByte / this.fv_LimitUnitByte)+" ("+sUnitText+")"
	}
	
	this.staImageCropByte.set_text(sText);
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.divOption_btnDragModeMove_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.webImageCrop.callMethod("setDragMode","move");
};

this.divOption_btnDragModeCrop_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.webImageCrop.callMethod("setDragMode","crop");	
};

this.divOption_rdoCropRectType_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	if(e.postvalue=="free")
	{
		this.divOption.form.edtCropRectWidth.set_readonly(true);
		this.divOption.form.edtCropRectHeight.set_readonly(true);
		this.divOption.form.btnCropRectSetting.set_enable(false);
	}
	else
	{
		this.divOption.form.edtCropRectWidth.set_readonly(false);
		this.divOption.form.edtCropRectHeight.set_readonly(false);
		this.divOption.form.btnCropRectSetting.set_enable(true);
	}
};

this.divOption_btnCropRectSetting_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var nWidth  = parseInt(this.divOption.form.edtCropRectWidth.value) || 0;
	var nHeight = parseInt(this.divOption.form.edtCropRectHeight.value) || 0;
	
	var objJson = {width:nWidth , height:nHeight};
	this.webImageCrop.callMethod("setCropBoxData",objJson);	
};

this.divOption_btnRotateLeft_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.webImageCrop.callMethod("rotateLeft");
};

this.divOption_btnRotateRight_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.webImageCrop.callMethod("rotateRight");
};

this.divOption_btnScalePlus_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.webImageCrop.callMethod("zoomPlus");
};

this.divOption_btnScale100_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.webImageCrop.callMethod("zoom100");
};

this.divOption_btnScaleMinus_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.webImageCrop.callMethod("zoomMinus");
};

this.divOption_btnReverseVertical_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.webImageCrop.callMethod("reverseImage","vertical");
};

this.divOption_btnReverseHorizon_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.webImageCrop.callMethod("reverseImage","horizontal");
};

this.divOption_btnCrop_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fvCropImageInfo = this.webImageCrop.callMethod("crop");
	
	if(!this.smfIsNull(this.fvCropImageInfo.imageDataBase64Reduce))
	{
		this.divOption.form.imgCropped.set_image(this.fvCropImageInfo.imageDataBase64Reduce);

		// 자른 이미지의 사이즈를 표시한다.
		var nCropImageSize = this.fvCropImageInfo.imageDataBase64.length;
		var nReduceCropImageSize = this.fvCropImageInfo.imageDataBase64Reduce.length;
		this.fnDisplayImageCropByteInfo(nCropImageSize,nReduceCropImageSize);
	}
	
	
};

this.divOption_btnCropSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objCroppedCanvas = this.webImageCrop.callMethod("crop");
	var sUrlData = objCroppedCanvas.toDataURL();
	
	var vsFileName = this.fvFileName;
	if(vsFileName.lastIndexOf(".png") == -1) {
		vsFileName += ".png";
	}
	
	var a = document.createElement("a");
	a.href = sUrlData;
	a.setAttribute("download", vsFileName);
	document.body.appendChild(a);
	a.click();
	document.body.removeChild(a);
};

this.webImageCrop_onusernotify = function(obj:nexacro.WebBrowser,e:nexacro.WebUserNotifyEventInfo)
{
	if(e.userdata=="detail")
	{
		var sVal = this.webImageCrop.callMethod("getNexacroData");
		//trace("webImageCrop_onusernotify - detail : [" + sVal + "]");
		
		var objDetail = JSON.parse(sVal);
		this.divOption.form.edtCropRectWidth.set_value(parseInt(objDetail.width));
		this.divOption.form.edtCropRectHeight.set_value(parseInt(objDetail.height));
	}
	else if(e.userdata=="zoom")
	{
		var sVal = this.webImageCrop.callMethod("getNexacroData");
		//trace("webImageCrop_onusernotify - zoom : [" + sVal + "]");
		
		var objDetail = JSON.parse(sVal);
		this.divOption.form.edtScaleRate.set_value(parseInt(objDetail.ratio*100));
	}
};

this.btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.webImageCrop.callMethod("fnSelectFile");
};

this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 응답을 
	this.smfSendResponseToOpener({
		"imageInfo": this.fvCropImageInfo
	});
	
	this.close(true);
};

this.webImageCrop_onloadcompleted = function(obj:nexacro.WebBrowser,e:nexacro.WebLoadCompEventInfo)
{
	// 파일선택
	//this.btn00.click();
};
]]></Script>
  </Form>
</FDL>
