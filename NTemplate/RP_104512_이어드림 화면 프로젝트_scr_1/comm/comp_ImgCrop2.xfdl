              <Button id="btnDragModeCrop" taborder="4" left="156" top="39" width="33" height="33" onclick="divOption_btnDragModeCrop_onclick" tooltiptext="Crop" cssclass="btn_CP_Crop" initvalueid="ivBtnAccessibilityButton"/>
