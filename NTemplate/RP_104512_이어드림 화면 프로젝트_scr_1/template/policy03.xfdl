<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmTemp01" width="1200" height="2097" onload="frmTemp01_onload" titletext="[M]저작권보호정책">
    <Layouts>
      <Layout height="2097" width="1200" screenid="ScreenDeskTop">
        <ImageViewer id="imgTitle" taborder="0" text="저작권 보호정책" left="0" top="60" height="54" cssclass="img_WF_SubTit01" width="227" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_02_01_01" taborder="1" text="본 서비스는 저작권자의 동의 없이 게시(or중단)된 저작물로 인하여 저작권을 침해 받은 경우 이를 신고하기 위한 서비스 입니다. '게시중단' 또는 '재게시' 요청신고는 아래 관련양식과 소명자료를 함께 저작권 신고하기에 제출하여 주시기 바랍니다." left="0" top="imgTitle:13" height="50" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" right="40" fittocontents="height"/>
        <ImageViewer id="imgTitle00" taborder="2" text="저작권 신고 접수 수령인(담당자)" left="0" top="sta00_02_01_01:68" height="40" cssclass="img_WF_SubTit02" width="329" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_02" taborder="3" text="성명 및 소속부서 : 해당 시도교육청 개인정보보호 담당자를 참고하세요." left="10" top="imgTitle00:6" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Info16Black" right="30" usedecorate="false" fittocontents="height"/>
        <ImageViewer id="imgTitle00_00" taborder="4" text="저작권신고 및 게시중단 요청 서비스의 대상이 되는 게시물" left="0" top="sta00_00_00_00_00_01_00_00_00_02:64" height="40" cssclass="img_WF_SubTit02" width="583" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_02_00" taborder="5" text="나이스 대국민서비스에 게시된 저작물로 저작권자의 저작물을 무단으로 이용하였거나 또는 저작자의 명예를 훼손한다고 생각되는 게시물" left="10" top="imgTitle00_00:6" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Info16Black" right="30" usedecorate="false" fittocontents="height"/>
        <ImageViewer id="imgTitle00_00_00" taborder="6" text="게시중단요청 신청" left="0" top="sta00_00_00_00_00_01_00_00_00_02_00:62" height="40" cssclass="img_WF_SubTit02" width="193" initvalueid="ivTitleAccessibilityOn" fittocontents="height"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_02_00_00" taborder="7" text="게시중단요청 : 게시된 저작물에 의해 권리를 침해 당하였다고 판단되면 해당 절차에 따라서 게시중단을 요청합니다." left="10" top="imgTitle00_00_00:7" height="28" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Info16Black" right="30" usedecorate="false" fittocontents="height"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_02_00_00_00" taborder="8" text="게시된 자작물의 게시중단(복제·전송 중단)을 요청할 경우에는 아래 문서를 다운로드 하여 작성한 후 저작권 신고하기에 신청 또는 '저작권 담당자'에게 방문 신청합니다." left="10" top="sta00_00_00_00_00_01_00_00_00_02_00_00:-2" height="28" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Info16Black" right="30" usedecorate="false" fittocontents="height"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_02_00_00_00_00" taborder="9" text="적당한 권리 없이 게시중단을 요청하면 법에 의해 손해배상의 책임이 있습니다." left="10" top="sta00_00_00_00_00_01_00_00_00_02_00_00_00:-2" height="28" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Info16Black" right="90" usedecorate="false" fittocontents="height"/>
        <Div id="div00" taborder="10" left="0" top="sta00_00_00_00_00_01_00_00_00_02_00_00_00_00:33" height="590" background="url('theme://images/img_WF_.Copyright01.png') no-repeat center center" initvalueid="ivDivAccessibilityOn" cssclass="div_WF_kinder" right="0" maxwidth="">
          <Layouts>
            <Layout>
              <Button id="btn00" taborder="0" text="양식 다운로드" top="30" height="50" cssclass="btn_WF_dowmload" initvalueid="ivBtnAccessibilityButton" width="180" right="30"/>
            </Layout>
            <Layout name="Layout0">
              <Button id="btn00" top="790" width="248" height="70" right="15" cssclass="btn_WF_formDownload_M"/>
