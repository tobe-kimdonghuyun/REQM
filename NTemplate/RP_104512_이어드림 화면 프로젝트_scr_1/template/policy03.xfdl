        </Div>
        <ImageViewer id="imgTitle00_00_00_00" taborder="11" text="재게시 요청 신청" left="0" top="div00:77" height="40" cssclass="img_WF_SubTit02" width="193" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_02_00_00_00_01" taborder="12" text="게시된 중단된 저작물에 게시한 이용자가 해당 저작물이 정당한 권리에 의한 게시라고 판단되면 해당절차에 따라서 재게시를 요청합니다." left="10" top="imgTitle00_00_00_00:4" height="28" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Info16Black" right="30" usedecorate="false" fittocontents="height"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_02_00_00_00_01_00" taborder="13" text="게시중단을 통보 받은 저작물에 대하여 재 게시를 요청할 경우에는 아래 문서를 다운로드하여 작성한 후 저작권 신고하기에 신청 또는 '저작권 담당자'에게 방문신청합니다." left="10" top="sta00_00_00_00_00_01_00_00_00_02_00_00_00_01:-2" height="28" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Info16Black" right="30" usedecorate="false" fittocontents="height"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_02_00_00_00_01_00_00" taborder="14" text="정당한 권리 없이 게시중단을 요청하면 법에 의해 손해배상의 책임이 있습니다." left="10" top="sta00_00_00_00_00_01_00_00_00_02_00_00_00_01_00:-2" height="28" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Info16Black" right="20" usedecorate="false" fittocontents="height"/>
