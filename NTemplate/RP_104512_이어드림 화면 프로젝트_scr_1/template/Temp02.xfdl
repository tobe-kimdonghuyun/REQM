************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.5.12     	홍길동 	        최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frmTemp02_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(this);
	// 파라메터 세팅
	this.pv_params = this.smfGetFormParams();
	
	this.fnSearch(this.pv_params.prlDataId);

};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(prlDataId)
{
	this.dsMain.setColumn(0,"prlDataId",prlDataId);

 	// 서비스 객체 생성
	this.smfSearchService("select")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});	
};

this.fnDelete = function()
{
 	// 서비스 객체 생성
	// 삭제처리
	/*
	this.smfDeleteService("delete")
		// 데이터 존재 필수
		.requireExistsData(this.dsResult) 
		// 삭제를 위한 검증수행
		.validateFormDelete(thisdsResult)
		.run()
		// 콜백
		.callback(function(callbackParams){ 
			if(callbackParams.errors) return;
			
			var alerter = this.smfAlerter();
			alerter.message = this.smfAfterServiceMessage();
			alerter.onOk = function(){
				// 목록으로 이동
				this.smfSetWorkPage("template::Temp01.xfdl");
			};
			alerter.run();
		})
		;
	*/
	this.smfSetWorkPage("template::Temp01.xfdl");	
}

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// [추가]버튼클릭 처리
this.btnList_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSetWorkPage("template::Temp01.xfdl");
};

// [추가]버튼클릭 처리
this.btnUpdate_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.alert("[개발자용] 수정처리화면으로 이동합니다.(처리생략)");
	//var param = {prlDataId:this.pv_params.prlDataId};
	//this.smfSetWorkPage("template::Temp0xx.xfdl");
};

this.btnDel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.alert("[개발자용] 삭제처리(생략)후 목록으로 이동");
	this.fnDelete();
};
]]></Script>
