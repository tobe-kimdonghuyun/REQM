<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmTemp01" width="1200" height="833" titletext="[M]대국민-자료실목록조회p92 (타이틀+조회+그리드+페이징)" onload="frmTemp01_onload">
    <Layouts>
      <Layout height="833" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="70" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff" tabstop="true">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="자료실 목록조회" left="0" top="0" height="44" cssclass="img_WF_SubTit01" width="247" initvalueid="ivTitleAccessibilityOn" tabstop="false"/>
            </Layout>
            <Layout name="Layout0"/>
          </Layouts>
        </Div>
        <Div id="divSearch" taborder="1" left="0" top="144" height="70" cssclass="div_WF_Search" right="0" initvalueid="ivDivAccessibilityOff" tabstop="true">
          <Layouts>
            <Layout>
              <Static id="Static00" taborder="0" text="자료실 검색" left="0" top="20" width="104" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Combo id="cboSearchType" taborder="1" left="104" width="105" height="30" innerdataset="dsSearchTypeCd" codecolumn="cd" datacolumn="text" index="0" text="제목+내용" top="20" value="ALL" initvalueid="ivCmbNormal" accessibilitylabel="조회조건"/>
              <Edit id="edtSearchKeyword" taborder="2" left="217" top="20" width="503" height="30" initvalueid="ivEdtNormal" accessibilitylabel="조회조건"/>
              <Button id="btnInit" taborder="3" text="초기화" top="20" width="88" height="30" cssclass="btn_WF_Refresh03" onclick="divSearch_btnInit_onclick" right="102" initvalueid="ivBtnAccessibilityButton"/>
              <Button id="btnSearch" taborder="4" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="20" onclick="divSearch_btnSearch_onclick" initvalueid="ivBtnAccessibilityButton"/>
            </Layout>
            <Layout name="Layout0">
              <Edit id="edtSearchKeyword" left="217" top="11" width="223" height="30"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divPageSummary" taborder="2" left="7" top="234" width="331" height="30" url="comm::comp_pageSummary.xfdl" visible="true" text="" initvalueid="ivDivAccessibilityOn" tabstop="true"/>
        <Grid id="grdMain" taborder="3" left="0" top="274" height="439" binddataset="dsResult" autofittype="col" right="0" oncellclick="grdMain_oncellclick" initvalueid="ivGrdAccessibilityOn" selecttype="cell">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="48"/>
                <Column size="50"/>
                <Column size="638"/>
                <Column size="70"/>
                <Column size="110"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell displaytype="checkboxcontrol" edittype="checkbox"/>
                <Cell col="1" text="번호"/>
                <Cell col="2" text="제목"/>
                <Cell col="3" text="첨부"/>
                <Cell col="4" text="작성일" cssclass="LineNo"/>
              </Band>
              <Band id="body">
                <Cell displaytype="checkboxcontrol" edittype="checkbox" text="bind:_chk" accessibilityrole="checkbox" accessibilitylabel="expr:prlDataTitlNm + &quot;첨부파일 : &quot; + fileNm"/>
                <Cell col="1" text="bind:체크박스"/>
                <Cell col="2" displaytype="normal" edittype="none" text="bind:prlDataTitlNm"/>
                <Cell col="3" displaytype="buttoncontrol" edittype="button" cssclass="cell_WF_BtDown"/>
                <Cell col="4" displaytype="mask" edittype="none" text="bind:regDt" cssclass="LineNo" maskedittype="string" maskeditformat="@@@@-@@-@@ @@:@@"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Div id="divPaginator" taborder="4" left="0" top="733" height="30" right="0" url="comm::comp_paginator.xfdl" dsPage="dsPage" pageViewSize="100" initvalueid="ivDivAccessibilityOn" tabstop="true"/>
        <Button id="btnDelete" taborder="5" text="삭제" top="793" height="40" width="120" cssclass="btn_WF_ActionLine" right="130" onclick="btnDelete_onclick" initvalueid="ivBtnAccessibilityButton"/>
        <Button id="btnAdd" taborder="6" text="등록" top="793" height="40" width="120" cssclass="btn_WF_Action" right="0" onclick="btnAdd_onclick" initvalueid="ivBtnAccessibilityButton"/>
        <Static id="Static99_00_00_00_00" taborder="7" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01" taborder="8" left="0" top="114" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_01" taborder="9" left="0" top="214" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_00_00" taborder="10" left="0" top="713" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_01_00" taborder="11" left="0" top="264" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_00_00_00" taborder="12" left="0" top="763" height="30" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
      <Layout name="Layout0" screenid="mobile" width="640" height="1024" mobileorientation="portrait" type="default">
        <Div id="divPaginator" left="0" top="705" height="85" right="0"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 템플릿01
*  @MenuPath    TEMPLATE
*  @FileName 	Temp01.xfdl
*  @Creator 	홍길동
*  @CreateDate 	2022.5.12
*  @Desction    검정고시p72+(공지목록)+(타이틀,그리드)
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.5.12     	홍길동 	        최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_param;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frmTemp01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(this);

	this.fv_param = this.smfGetFormParams();

	// Form의 검색영역 초기화처리를 한다.
	this.fnFormInit();
};

this.fnFormInit = function()
{
	// Form의 검색영역 초기화처리를 한다.(바인딩된 것)
	this.dsSearch.setColumn(0,"searchType"    , "ALL");
	this.dsSearch.setColumn(0,"searchKeyword" , ""   );

	// Form의 검색영역 초기화처리를 한다.(Form의 값 읽음)
	//this.divSearch.form.cboSearchType.set_index(0);
	//this.divSearch.form.edtSearchKeyword.set_value("");

	// 그리드 초기화
	
	
	// Page처리를 위한 값을 초기화한다.
	//this.divPage.form.fnInit();
}


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

}


/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	// 업무콜백 처리
	this.smfAlert("응답결과 ==>"+e.row.Column0+", "+e.row.Column1+", "+e.row.Column2+", "+e.row.Column3);
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(obj, e)
{
 	// 서비스 객체 생성
	this.smfSearchService("select")
		// 데이터 검증
		.validateForm(this.divSearch)
		// 페이징처리
		.paginator(this.grdMain, this.divPaginator, this.divPageSummary, this.dsPageInfo, this.fnSearch, e)
		//.paging(this.grdMain, this.divPageInfo, this.dsPageInfo, obj, e)
		// 데이터가 변경되었으면 확인메시지
		//.confirmIfModifiedDataset(this.dsResult)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});	
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 
this.divSearch_btnInit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 값을 초기화한다.
	this.fnFormInit();
	// 
};

this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//  페이지를 조회한다.
	this.fnSearch();	
};



this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	// 클릭한 셀을 구한다
	var nRow = e.row;
	var nCell = e.cell;
	
	if(nCell == 2) // 제목
	{
		var objDs = obj.getBindDataset();
		// 
		var sPrlDataId = objDs.getColumn(nRow,"prlDataId");
		
		var params = {prlDataId:sPrlDataId};
		this.smfSetWorkPage("template::Temp02.xfdl", params);
	}
	else if(nCell == 3) // 첨부파일다운로드
	{
		var objDs = obj.getBindDataset();
		var sFileRefrnId = objDs.getColumn(nRow,"fileRefrnId");
		
		// 서버에 파일다운로드를 요청한다.(추후에 실시)
		
	}
};


this.btnAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var params = {};
	this.smfSetWorkPage("template::Temp03.xfdl", params);
};

// [삭제]버튼 처리
this.btnDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 삭제처리
	this.smfDeleteService("delete")
		.validateGridDelete(this.grdMain, this.dsResultValid)
		.run()
		// 콜백
		.callback(function(callbackParams){ 
			if(callbackParams.errors) return;
			
			// 삭제하였습니다 알림 후 재조회
			this.smfLiteralAlert(this.smfAfterServiceMessage(), this.div_search_btn_search_onclick);
		})

};
]]></Script>
    <Objects>
      <Dataset id="dsResult" useclientlayout="true">
        <ColumnInfo>
          <Column id="_chk" type="int" size="1"/>
          <Column id="prlDataId" type="string" size="256"/>
          <Column id="prlDataTitlNm" type="string" size="256"/>
          <Column id="prlDataCn" type="string" size="256"/>
          <Column id="fileRefrnId" type="string" size="256"/>
          <Column id="prlDataInqCnt" type="bigdecimal" size="256"/>
          <Column id="regDt" type="string" size="256"/>
          <Column id="rgtrId" type="string" size="256"/>
          <Column id="rgtrNm" type="string" size="256"/>
          <Column id="rgtrDptNm" type="string" size="256"/>
          <Column id="mdfcnDt" type="string" size="256"/>
          <Column id="mdfrId" type="string" size="256"/>
          <Column id="mdfrNm" type="string" size="256"/>
          <Column id="mdfrDptNm" type="string" size="256"/>
          <Column id="fileNm" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="prlDataTitlNm">나이스 검정고시</Col>
            <Col id="fileNm">나이스 검정고시</Col>
          </Row>
          <Row>
            <Col id="prlDataTitlNm">나이스 방과후</Col>
            <Col id="fileNm">나이스 방과후</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsResultValid" useclientlayout="true">
        <ColumnInfo>
          <Column id="_chk" type="STRING" size="256" prop="NONE"/>
          <Column id="prlDataId" type="string" size="256"/>
          <Column id="prlDataTitlNm" type="string" size="256"/>
          <Column id="prlDataCn" type="string" size="256"/>
          <Column id="fileRefrnId" type="string" size="256"/>
          <Column id="prlDataInqCnt" type="bigdecimal" size="256"/>
          <Column id="regDt" type="string" size="256"/>
          <Column id="rgtrId" type="string" size="256"/>
          <Column id="rgtrNm" type="string" size="256"/>
          <Column id="rgtrDptNm" type="string" size="256"/>
          <Column id="mdfcnDt" type="string" size="256"/>
          <Column id="mdfrId" type="string" size="256"/>
          <Column id="mdfrNm" type="string" size="256"/>
          <Column id="mdfrDptNm" type="string" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="_chk"/>
          </Row>
          <Row>
            <Col id="_chk"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">select</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsPageInfo=dsPageInfo</Col>
            <Col id="outDatasets">dsResult=dsResult dsPageInfo=dsPageInfo</Col>
            <Col id="url">pas_mns_cn04_m01.do</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="inDatasets">dsDelList=dsResult:U</Col>
            <Col id="outDatasets"/>
            <Col id="asynctp"/>
            <Col id="url">pas_mns_cn04_m05.do</Col>
            <Col id="id">delete</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsPageInfo" useclientlayout="true">
        <ColumnInfo>
          <Column id="pageIndex" type="INT" size="256"/>
          <Column id="pageSize" type="INT" size="256"/>
          <Column id="totalCount" type="INT" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="pageIndex">1</Col>
            <Col id="pageSize">10</Col>
            <Col id="totalCount">0</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="searchType" type="STRING" size="256"/>
          <Column id="searchKeyword" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="searchType">TITL</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearchTypeCd">
        <ColumnInfo>
          <Column id="cd" type="STRING" size="256"/>
          <Column id="text" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="cd">ALL</Col>
            <Col id="text">제목+내용</Col>
          </Row>
          <Row>
            <Col id="cd">TITL</Col>
            <Col id="text">제목</Col>
          </Row>
          <Row>
            <Col id="cd">CN</Col>
            <Col id="text">내용</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.cboSearchType" propid="value" datasetid="dsSearch" columnid="searchType"/>
      <BindItem id="item1" compid="divSearch.form.edtSearchKeyword" propid="value" datasetid="dsSearch" columnid="searchKeyword"/>
    </Bind>
  </Form>
</FDL>
