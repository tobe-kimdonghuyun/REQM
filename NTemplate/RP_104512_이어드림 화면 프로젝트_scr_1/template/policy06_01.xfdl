                    <Static id="sta00_02_01_00_01" taborder="8" text="「학생서비스,  학부모서비스」&#13;&#10;회원정보" left="0" top="64" height="57" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" textAlign="center" width="197"/>
                    <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00" taborder="9" left="0" top="60" height="16" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
                    <Static id="sta00_02_01_00_01_00" taborder="10" text="[운영근거]&#13;&#10;・ 초·중등교육법 제30조의 4,5 &#13;&#10;・ 교육기본법 제 23의 2&#13;&#10;・ 유아교육정보시스템 및 교육정보시스템의 &#13;&#10;운영 등에 관한 규칙 제8조, 제9조" top="65" height="129" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" textAlign="center" width="301" left="226" letterSpacing="-1px"/>
                    <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_00" taborder="11" left="0" top="253" height="16" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
                    <Static id="sta00_02_01_00_01_00_00" taborder="12" text="[처리목적]&#13;&#10;「학생서비스, 학부모서비스」 운영 관리" top="205" height="50" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" textAlign="center" width="301" left="226"/>
                    <Static id="sta00_02_01_00_01_00_00_00" taborder="13" text="[선택]&#13;&#10;이메일, 연락처(일반, 핸드폰)" left="600" top="205" height="50" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" textAlign="center" width="301"/>
                    <Static id="sta00_02_01_00_01_00_01" taborder="14" text="[필수]&#13;&#10;・ 학생서비스 : 성명, 아이디, 본인확인값(CI), &#13;&#10;생년월일, 학교, 학년, 반, 번호, 계열&#13;&#10;・ 학부모서비스 : 성명, 아이디, 본인확인값(CI),&#13;&#10;생년월일" left="600" top="65" height="129" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" textAlign="center" width="301"/>
                    <Static id="sta00_02_01_00_01_01" taborder="15" text="가입 후 회원 탈퇴시 까지" left="951" top="68" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" textAlign="center" width="187"/>
                  </Layout>
                  <Layout name="Layout0">
                    <Static id="sta00_00" left="0" top="106" width="200" height="420" text="운영근거 / &#13;&#10;처리목적"/>
                    <Static id="sta00_00_00" left="0" top="525" width="200" height="383" text="개인정보파일에&#13;&#10;기록되는 &#13;&#10;개인정보의 항목"/>
                    <Static id="sta00_00_01" left="200" top="106" height="420" right="0"/>
                    <Static id="sta00_00_00_01" left="200" top="525" height="383" right="0"/>
                    <Static id="sta00_00_00_00_00" top="907" height="68" left="200" right="0"/>
                    <Static id="sta00_00_00_00" top="907" width="200" height="68" left="0"/>
                    <Static id="sta00_02_01_00_01_00" left="228" top="109" height="259" textAlign="left" text="[운영근거]&#13;&#10;초·중등교육법 제30조의 4,5 &#13;&#10;교육기본법 제 23의 2&#13;&#10;유아교육정보시스템 및 교육정보시스템의 운영 등에 관한 규칙 제8조, 제9조" cssclass="sta_WF_Txt26L" right="1"/>
                    <Static id="sta00_02_01_00_01_00_00" left="228" top="388" height="120" textAlign="left" cssclass="sta_WF_Txt26L" right="11"/>
                    <Static id="sta00_02_01_00_01_00_00_00" left="228" top="799" height="90" textAlign="left" cssclass="sta_WF_Txt26L" right="1"/>
                    <Static id="sta00_02_01_00_01_00_01" left="228" top="538" height="239" textAlign="left" text="[필수]&#13;&#10;학생서비스 : 성명, 아이디, &#13;&#10;본인확인값(CI), 생년월일, 학교, 학년, 반, 번호, 계열&#13;&#10;학부모서비스 : 성명, 아이디, &#13;&#10;본인확인값(CI), 생년월일" cssclass="sta_WF_Txt26L" right="1"/>
                    <Static id="sta00_02_01_00_01_01" left="228" top="921" height="40" textAlign="left" cssclass="sta_WF_Txt26L" right="1"/>
                    <Static id="sta00_02_01_00_01" left="sta00:29" top="10" height="87" cssclass="sta_WF_Txt26L" textAlign="left" right="10"/>
                    <Static id="sta00" width="200" left="0" top="0" height="107" text="개인정보파일의&#13;&#10;명칭"/>
                    <Static id="sta00_01" left="sta00:0" top="0" height="107" right="0"/>
                    <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00" left="213" top="526" width="111" height="24" visible="false"/>
                    <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_00" left="210" top="764" height="54" right="148" visible="false"/>
                  </Layout>
