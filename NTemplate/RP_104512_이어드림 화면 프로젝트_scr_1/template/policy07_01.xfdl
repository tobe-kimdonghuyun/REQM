                    <Static id="sta00_01" taborder="3" left="0" top="59" width="202" cssclass="sta_WF_PolicyDtlW" initvalueid="ivStcAccessibilityOn" text="학부모서비스" height="60"/>
                    <Static id="sta00_00_01" taborder="4" left="201" top="59" width="370" cssclass="sta_WF_PolicyDtlW" initvalueid="ivStcAccessibilityOn" height="60" text="학부모서비스 신청 자녀등록"/>
                    <Static id="sta00_00_00_00_00" taborder="5" top="59" width="570" cssclass="sta_WF_PolicyDtlW" initvalueid="ivStcAccessibilityOn" height="60" right="0" text="자녀이름, 생년월일, 학교명, 관계, 학년도, 학년, 과정, 계열, 학과, 반, 번호" onclick="div01_div00_00_00_sta00_00_00_00_00_onclick"/>
                  </Layout>
                  <Layout name="Layout0">
                    <Static id="sta00_00" left="0" top="67" width="200" height="60"/>
                    <Static id="sta00_00_01" left="200" top="67" height="60" padding="0px 0px 0px 27px" right="0"/>
                    <Static id="sta00_00_00_00" top="126" width="200" height="150" left="0" text="추가로 &#13;&#10;수집하는 &#13;&#10;개인정보 항목"/>
                    <Static id="sta00_00_00_00_00" top="126" height="150" left="sta00_00_00_00:0" padding="0px 0px 0px 27px" right="0" text="자녀이름, 생년월일, 학교명, &#13;&#10;관계, 학년도, 학년, 과정, &#13;&#10;계열, 학과, 반, 번호"/>
                    <Static id="sta00_01" left="sta00:0" top="0" height="68" padding="0px 0px 0px 27px" right="0"/>
