              <Button id="btn01" taborder="1" top="20" width="36" height="36" cssclass="btn_WF_SurvPopClose" initvalueid="ivBtnAccessibilityButton" right="30"/>
              <Static id="sta01_00" taborder="2" text="검사기간 4월 1일~5월 31일(주말 참여 가능)" left="20" top="91" height="40" cssclass="sta_WF_Txt24B" initvalueid="ivStcAccessibilityOn" width="490"/>
