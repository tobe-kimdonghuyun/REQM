              </Div>
              <Div id="div00" taborder="1" text="div00" top="93" height="588" cssclass="div_WF_Greeting02" initvalueid="ivDivAccessibilityOff" left="461" width="1013">
                <Layouts>
                  <Layout>
                    <Static id="sta00" taborder="0" left="324" top="69" width="237" height="8" cssclass="sta_WF_SurveyUnder03" initvalueid="ivStcAccessibilityOff"/>
                    <Static id="sta00_00" taborder="1" text="지금까지 학생정서·행동특성 검사에 끝까지 참여하시고&#13;&#10;솔직하게 응답해 주셔서 감사합니다." left="192" top="35" width="614" height="90" cssclass="sta_WF_Txt24AC" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta00_00_00" taborder="2" text="검사 결과는 추후 각 가정에 우편으로 제공될 예정이며&#13;&#13;&#10;지속적인 관심이 필요한 학생은 전문기관에서 도움을 받을 수 있도록 안내해 드릴 것입니다." left="79" top="136" width="580" height="55" cssclass="sta_WF_Txt14L" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta00_00_00_01" taborder="3" text="지속적인 관심이 필요한 학생으로 확인된 경우 학부모님의 적극적인 참여와 도움을 요청드립니다.&#13;&#13;&#10;아울러 자녀의 정서 행동적인 측면에서 학교에서 각별히 관심을 갖고 지도해야 할 사항이 있으면 언제든지 담임 선생님이나 담당 선생님께&#13;&#10;알려주시기 &#13;바랍니다.&#13;&#10;&#13;귀 자녀의 건강하고 편안한 생활을 위해 노력하겠습니다. " left="79" top="207" width="831" height="93" cssclass="sta_WF_Txt14L" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta00_00_00_01_00" taborder="4" text="감사합니다." left="79" top="320" width="99" height="27" cssclass="sta_WF_Txt14L" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta00_00_00_00" taborder="5" text="묵호초등학교장" left="79" top="482" width="111" height="30" cssclass="sta_WF_Txt14L" initvalueid="ivStcAccessibilityOn" onclick="div01_div00_sta00_00_00_00_onclick"/>
                    <Static id="sta00_00_00_00_00" taborder="6" left="597" top="340" width="330" height="170" cssclass="sta_WF_school" initvalueid="ivStcAccessibilityOn" onclick="div01_div00_sta00_00_00_00_onclick"/>
                  </Layout>
                  <Layout name="Layout0">
                    <Static id="sta00_00_00_00" left="20" top="806" width="290" height="55" cssclass="sta_WF_Txt24" taborder="5"/>
                    <Static id="sta00_00_00_01_00" left="20" top="681" height="47" right="340" cssclass="sta_WF_Txt24" taborder="4"/>
                    <Static id="sta00_00_00_01" left="20" top="332" height="353" right="20" cssclass="sta_WF_Txt24L" text="지속적인 관심이 필요한 학생으로 확인된 경우 학부모님의 적극적인 참여와 도움을 요청드립니다.&#13;&#13;&#10;아울러 자녀의 정서 행동적인 측면에서 학교에서 각별히 관심을 갖고 지도해야 할 사항이 있으면 언제든지 &#13;&#10;담임 선생님이나 담당 선생님께 알려주시기 &#13;바랍니다.&#13;&#10;&#13;귀 자녀의 건강하고 편안한 생활을 위해 &#13;&#10;노력하겠습니다. " taborder="3"/>
                    <Static id="sta00_00_00" left="20" top="207" height="115" right="20" cssclass="sta_WF_Txt24L" text="검사 결과는 추후 각 가정에 우편으로 제공될 예정이며&#13;&#13;&#10;지속적인 관심이 필요한 학생은 전문기관에서 도움을 &#13;&#10;받을 수 있도록 안내해 드릴 것입니다." taborder="2"/>
                    <Static id="sta00" left="142" top="70" width="290" height="8" taborder="0"/>
                    <Static id="sta00_00" left="20" top="37" height="140" cssclass="sta_WF_Txt30" text="지금까지 학생정서·행동특성 검사에 끝까지 &#13;&#10;참여하시고 솔직하게 응답해 주셔서 &#13;&#10;감사합니다." right="20" taborder="1"/>
