                    <Static id="sta00" taborder="0" left="129" top="40" width="50" height="50" cssclass="sta_WF_Attention" initvalueid="ivStcAccessibilityOff"/>
                    <Static id="sta00_00_00_00" taborder="1" text="꼭 읽어야 할&#13;&#10;유의사항" left="97" top="84" width="115" height="60" cssclass="sta_WF_Txt18BAC" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
                    <Static id="sta01" taborder="2" text="참여번호를 잃어버린경우 담임선생님께 요청하여 재발급 받을 수있습니다.(참여번호 발급은 초기 1회 포함, 총10회발급)" left="300" top="28" width="715" height="26" cssclass="sta_WF_surveyDot14" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00" taborder="3" text="학생의 개인정보는 저장되지 않으며, 참여번호를 통한 개인확인은 불가능합니다." left="300" top="52" width="715" height="26" cssclass="sta_WF_surveyDot14" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_00" taborder="4" text="응답 내용으로 인한 불이익은 전혀없으며 비밀은 꼭 지켜드리겠습니다." left="300" top="77" width="715" height="26" cssclass="sta_WF_surveyDot14" initvalueid="ivStcAccessibilityOn" onclick="div03_sta01_00_00_onclick"/>
                    <Static id="sta01_00_00_00" taborder="5" text="다른사람의 참여번호를 무단으로 이용하여 설문조사에 참여하는경우, 형법상 공무집행방해죄에 처벌을 받을 수 있습니다. " left="300" top="101" width="715" height="26" cssclass="sta_WF_surveyDot14" initvalueid="ivStcAccessibilityOn" onclick="div03_sta01_00_00_onclick"/>
                    <Static id="sta01_00_00_00_00" taborder="6" text="참여번호 입력은 가상키패드(기본 적용) 또는 키보드보안 프로그램(선택)을 통하여 입력이 가능합니다." left="300" top="125" width="715" height="26" cssclass="sta_WF_surveyDot14" initvalueid="ivStcAccessibilityOn" onclick="div03_sta01_00_00_onclick"/>
