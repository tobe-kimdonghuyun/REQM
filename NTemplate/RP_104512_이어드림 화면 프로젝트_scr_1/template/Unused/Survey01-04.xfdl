        <Static id="guide04_00" taborder="8" text="언어선택버튼은 상태값에 따라 각각의 클래스가 적용되어져야합니다.&#13;&#10;&#13;&#10;btn_TF_SurvLang&#13;&#10;btn_TF_SurvLangS" left="2344" top="139" width="293" height="114" cssclass="sta_WF_Size" visible="false" initvalueid="ivStcAccessibilityOff" padding="20px" textAlign="left" verticalAlign="top"/>
      </Layout>
