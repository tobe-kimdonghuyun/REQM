                    <Static id="sta01_00_01_01_00_00" taborder="94" left="938" top="1016" width="185" height="88" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_01_01_00_00_00" taborder="95" left="938" top="1103" width="185" height="110" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_01_01_00_00_01" taborder="96" left="938" top="1212" width="185" height="88" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_01_01_00_00_00_00" taborder="97" left="938" top="1299" width="185" height="110" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_01_01_00_00_00_00_00" taborder="98" left="938" top="1408" width="185" height="110" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
