              <Div id="div00" taborder="1" text="div00" width="1200" height="3011" cssclass="div_WF_Greeting02" initvalueid="ivDivAccessibilityOff" left="360" top="96">
                <Layouts>
                  <Layout>
                    <Static id="sta00" taborder="0" left="63" top="73" width="85" height="8" cssclass="sta_WF_SurveyUnder03" initvalueid="ivStcAccessibilityOff"/>
                    <ImageViewer id="img00" taborder="1" text="CPSQ-Ⅱ" left="57" top="49" width="108" height="40" cssclass="img_WF_SurvTxt24" initvalueid="ivTitleAccessibilityOn"/>
                    <Static id="sta00_00_01" taborder="2" left="60" top="92" width="610" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="Child Personality and Mental Health Screening Questionaire, Second Version"/>
                    <Static id="sta00_01_00" taborder="3" text="01" left="60" top="165" width="64" height="32" cssclass="sta_WF_SurveyStep" initvalueid="ivStcAccessibilityOn"/>
                    <ImageViewer id="img00_00" taborder="4" text="나의 대표적 성격" left="144" top="165" width="132" height="32" cssclass="img_WF_SurvTxt18" initvalueid="ivTitleAccessibilityOn"/>
                    <Static id="sta00_00_01_00_00" taborder="5" left="60" top="208" width="859" height="32" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="자신에 대해 잘 이해하고 발전시키는 것은 행복한 삶의 원동력이 됩니다. 내가 가진 핵심 성격을 통해 자신을 더 잘 알아봅시다."/>
                    <Static id="sta00_00_01_00_00_00" taborder="6" left="60" top="276" width="1050" height="92" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="김OO 학생의 주된 성격 특성은 맡은 바 일을 책임감을 가지고 신중하게 처리할 수 있는 태도를 가지고 있습니다.&#13;&#13;&#10;하지만 이러한 성격 강점이 일상생활에서 두드러지게 드러나지 않을 수 있습니다. 특히 핵심 성격 요인의 발달 수준은 성장 과정에서 계속 변화하므로, 이에 대한 &#13;&#10;관심과 &#13;노력의 정도에 따라 더욱 높은 발전을 기대할 수 있을 것입니다.&#13;&#13;&#10;자신이 중요하게 생각하는 태도임에도 불구하고 이를 실천하는 데에 어려움이 있었다면 그 원인과 해결 방안에 관심을 가져봅시다."/>
                    <Static id="sta00_00_01_00_00_00_00" taborder="7" left="60" top="408" width="1050" height="52" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" text="※ 위의 내용에 입력된 핵심 성격은 동일한 T점수를 받는 성격이 3개 이상으로 나타나는 경우,&#13;&#13;&#10;&quot;성실성-자존감-개방성-타인이해-공동체의식-사회적 주도성&quot;의 순서에 따라 2개의 성격을 대표로 설명한 내용입니다."/>
                    <Static id="sta00_00_01_00_00_00_00_00" taborder="8" left="60" top="490" width="204" height="32" cssclass="sta_WF_Txt16B" initvalueid="ivStcAccessibilityOn" text="핵심 성격 및 핵심 성격의  뜻"/>
                    <Static id="sta01" taborder="9" text="성실성" left="60" top="544" width="120" height="88" cssclass="sta_WF_SurvInput01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00" taborder="10" text="내가 맡은 바를 책임감을 가지고 신중하게 처리하는 태도 " left="179" top="544" width="414" height="88" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_00" taborder="11" text="공동체의식" left="592" top="544" width="120" height="88" cssclass="sta_WF_SurvInput03" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_01" taborder="12" text="내가 속한 집에 대한 소속감을 가지고 긍정적인 상호작용을 하는 태도" left="711" top="544" width="412" height="88" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_01" taborder="13" text="자존감" left="60" top="631" width="120" height="66" cssclass="sta_WF_SurvInput01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_02" taborder="14" text="나에 대해 가치롭고 긍정적으로 생각하는 태도" left="179" top="631" width="414" height="66" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_00_00" taborder="15" text="타인이해" left="592" top="631" width="120" height="66" cssclass="sta_WF_SurvInput03" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_01_00" taborder="16" text="다른 사람의 입장을 공감하고 존중하는 태도" left="711" top="631" width="412" height="66" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_02" taborder="17" text="개방성" left="60" top="696" width="120" height="88" cssclass="sta_WF_SurvInput01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_03" taborder="18" text="다양한 관점으로 생각하고, 나와 다른 생각을 기꺼이 받아들이는 태도" left="179" top="696" width="414" height="88" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_00_01" taborder="19" text="공동체의식" left="592" top="696" width="120" height="88" cssclass="sta_WF_SurvInput03" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_01_01" taborder="20" text="대인관계나 학교생활에서 적극적으로 행동하거나 참여하는 태도 " left="711" top="696" width="412" height="88" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta00_01_00_00" taborder="21" text="02" left="60" top="854" width="64" height="32" cssclass="sta_WF_SurveyStep" initvalueid="ivStcAccessibilityOn"/>
                    <ImageViewer id="img00_00_00" taborder="22" text="성격요인의 대표 인물" left="144" top="854" width="167" height="32" cssclass="img_WF_SurvTxt18" initvalueid="ivTitleAccessibilityOn"/>
                    <Static id="sta00_00_01_00_00_01" taborder="23" left="60" top="897" width="518" height="32" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="성격 요인을 대표하는 사람은 누가 있을지 알아보고, 내 주변에서 찾아봅시다."/>
                    <Static id="sta01_02_00" taborder="24" text="성격요인" left="60" top="951" width="130" height="66" cssclass="sta_WF_SurvInputBG01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_03_00" taborder="25" text="대표인물" left="189" top="951" width="750" height="66" cssclass="sta_WF_SurvInputBG02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_01_01_00" taborder="26" text="내가 찾은 인물" left="938" top="951" width="185" height="66" cssclass="sta_WF_SurvInputBG02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_02_00_00" taborder="27" text="성실성" left="60" top="1016" width="130" height="88" cssclass="sta_WF_SurvInput01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_03_00_00" taborder="28" text="세종대왕(조선의 제4대 왕)은 자신이 세운 목표를 이루기 위해 책임감을 가지고 부지런하게 생활했습니다.&#13;&#10;그는 한글 창제뿐 아니라, 인문, 지리, 농업, 과학, 예술 등 다방면의 분야에서 왕의 책무를 수행하였습니다." left="189" top="1016" width="750" height="88" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_02_00_00_00" taborder="29" text="자존감" left="60" top="1103" width="130" height="110" cssclass="sta_WF_SurvInput01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_03_00_00_00" taborder="30" text="링컨(미국의 제16대 대통령)은 어려웠던 가정환경에도 불구하고, 자기 스스로를 존중하고 높게 &#13;&#10;평가했습니다. 그는 자신이 시민들에게 존경받을 만한 사람임을 증명하겠다는 일념을 가지고 인권 변호사가 되었고, 이후에 미국 대통령에 당선되었습니다." left="189" top="1103" width="750" height="110" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_02_00_00_01" taborder="31" text="개방성" left="60" top="1212" width="130" height="88" cssclass="sta_WF_SurvInput01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_03_00_00_01" taborder="32" text="간디(인도의 민족 지도자)는 한 주제에 재해 새로운 관점으로 생각하고 타인의 관점을 기꺼이 수용했습니다.&#13;&#10;그는 인도를 지해했던 영국의 불평등 정책에 대해 비폭력 저항운동을 했습니다." left="189" top="1212" width="750" height="88" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_02_00_00_00_00" taborder="33" text="타인이해" left="60" top="1299" width="130" height="110" cssclass="sta_WF_SurvInput01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_03_00_00_00_00" taborder="34" text="허준(조선의 의사)은 고통받는 환자의 아픔에 깊이 공감하였고, 병을 이해하기 위해서 환자와 많은 이야기를&#13;&#10;나누었으며 주의 깊게 관찰했습니다. 이러한 깊은 이해를 바탕으로 조선인에게 적합한 의술이 담긴 &#13;&#10;동의보감을 편찬하였습니다." left="189" top="1299" width="750" height="110" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_02_00_00_00_00_00" taborder="35" text="공동체의식" left="60" top="1408" width="130" height="110" cssclass="sta_WF_SurvInput01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_03_00_00_00_00_00" taborder="36" text="창호(교육자)는 지역 공동체는 물론 민족공동체의 일에 앞장서서 일했습니다. &#13;&#10;고향인 평안남도 강서에 남녀공학의 점진 학교를 세웠습니다. 이후 미국으로 건너가 우리 민족의 권익 보호와 &#13;&#10;생활 향상을 위해 한인공동 협회를 만들고 &lt;공립신보&gt;라는 신문을 발간하였습니다." left="189" top="1408" width="750" height="110" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_02_00_00_00_00_00_00" taborder="37" text="사회적 주도성" left="60" top="1517" width="130" height="110" cssclass="sta_WF_SurvInput01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_03_00_00_00_00_00_00" taborder="38" text="김구(독립운동가)는 다른 열사들이 독립운동에 열성적으로 참여하는 것을 돕기 위해 험하고 어려운 일에 &#13;&#10;목숨을 아끼지 않았습니다. 그는 한인 애국단을 조직하여 여러 독립운동을 진두지휘하였고, 대한민국 &#13;&#10;임시정부 조직에 참여하고 주석에 선입되었습니다." left="189" top="1517" width="750" height="110" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta00_01_00_00_00" taborder="39" text="03" left="60" top="1697" width="64" height="32" cssclass="sta_WF_SurveyStep" initvalueid="ivStcAccessibilityOn"/>
                    <ImageViewer id="img00_00_00_00" taborder="40" text="성격요인의 계발 방안" left="144" top="1697" width="167" height="32" cssclass="img_WF_SurvTxt18" initvalueid="ivTitleAccessibilityOn"/>
                    <Static id="sta00_00_01_00_00_01_00" taborder="41" left="60" top="1740" width="518" height="32" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="학교와 가정에서 실천할 수 있는 성격 요인의 계발 방안에 대해 생각해 봅시다."/>
                    <Static id="sta01_02_00_01" taborder="42" text="성격요인" left="60" top="1794" width="130" height="66" cssclass="sta_WF_SurvInputBG01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_03_00_01" taborder="43" text="개발 방안" left="189" top="1794" height="66" cssclass="sta_WF_SurvInputBG02" initvalueid="ivStcAccessibilityOn" width="934"/>
                    <Static id="sta01_02_00_00_02" taborder="44" text="성실성" left="60" top="1859" width="130" height="179" cssclass="sta_WF_SurvInput01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_03_00_00_02" taborder="45" left="189" top="1859" width="934" height="93" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta02" taborder="46" text="일기쓰기, 줄넘기 10분 이상하기, 신발정리하기등 매일 실천할 수 있는 작은 습관을 만들어보세요." left="210" top="1878" width="740" height="30" cssclass="sta_WF_surveyDot16"/>
                    <Static id="sta02_00" taborder="47" text="최근에 세웠던 목표 중  실천하지 않은 항목이 있다면, 목표를 잘 실천하기 위해 어떤 노력이 필요한지 적어 보세요." left="210" top="1902" width="776" height="30" cssclass="sta_WF_surveyDot16"/>
                    <Static id="sta01_00_03_00_00_00_01" taborder="48" text="나만의 계발 방안&#13;&#10;&#13;&#10;" left="189" top="1951" width="934" height="87" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_02_00_00_02_00" taborder="49" text="자존감" left="60" top="2037" width="130" height="179" cssclass="sta_WF_SurvInput01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_03_00_00_02_00" taborder="50" left="189" top="2037" width="934" height="93" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta02_01" taborder="51" text="잠들기 전에 오늘 하루를 보내면서 자신이 잘 해낸 부분을 떠올려보고 스스로를 북돋아 주세요." left="210" top="2056" width="740" height="30" cssclass="sta_WF_surveyDot16"/>
                    <Static id="sta02_00_00" taborder="52" text="친구나 가족들이 생각하는 나의 장점을 하나씩 적어보세요. " left="210" top="2080" width="776" height="30" cssclass="sta_WF_surveyDot16"/>
                    <Static id="sta01_00_03_00_00_00_01_00" taborder="53" text="나만의 계발 방안&#13;&#10;&#13;&#10;" left="189" top="2129" width="934" height="87" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_02_00_00_02_00_00" taborder="54" text="개방성" left="60" top="2215" width="130" height="179" cssclass="sta_WF_SurvInput01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_03_00_00_02_00_00" taborder="55" left="189" top="2215" width="934" height="93" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta02_01_00" taborder="56" text="반에서 나와 가장 다르다고 생각하는 친구의 이야기를 들어보세요. " left="210" top="2234" width="740" height="30" cssclass="sta_WF_surveyDot16"/>
                    <Static id="sta02_00_00_00" taborder="57" text="새로운 분야의 책을 찾아서 읽어보세요." left="210" top="2258" width="776" height="30" cssclass="sta_WF_surveyDot16"/>
                    <Static id="sta01_00_03_00_00_00_01_00_00" taborder="58" text="나만의 계발 방안&#13;&#10;&#13;&#10;" left="189" top="2307" width="934" height="87" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_02_00_00_02_00_00_00" taborder="59" text="타인이해" left="60" top="2393" width="130" height="179" cssclass="sta_WF_SurvInput01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_03_00_00_02_00_00_00" taborder="60" left="189" top="2393" width="934" height="93" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta02_01_00_00" taborder="61" text="친구가 이야기할 때, “응, 그랬구나.”로 얘기해 보세요." left="210" top="2412" width="740" height="30" cssclass="sta_WF_surveyDot16"/>
                    <Static id="sta02_00_00_00_00" taborder="62" text="친구를 만나기 전에 “오늘은 친구의 이야기를 많이 들어봐야지”라고 다짐해 보세요." left="210" top="2436" width="776" height="30" cssclass="sta_WF_surveyDot16"/>
                    <Static id="sta01_00_03_00_00_00_01_00_00_00" taborder="63" text="나만의 계발 방안&#13;&#10;&#13;&#10;" left="189" top="2485" width="934" height="87" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_02_00_00_02_00_00_00_00" taborder="64" text="공동체의식" left="60" top="2571" width="130" height="179" cssclass="sta_WF_SurvInput01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_03_00_00_02_00_00_00_00" taborder="65" left="189" top="2571" width="934" height="93" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta02_01_00_00_00" taborder="66" text="지역신문이나 학교 신문을 읽고 내가 속한 공동체에서 어떤 일들이 일어나고 있는지 알아보세요." left="210" top="2590" width="740" height="30" cssclass="sta_WF_surveyDot16"/>
                    <Static id="sta02_00_00_00_00_00" taborder="67" text="우리 반을 위해 내가 할 수있는 봉사활동을 찾아서 실천해보세요.  " left="210" top="2614" width="776" height="30" cssclass="sta_WF_surveyDot16"/>
                    <Static id="sta01_00_03_00_00_00_01_00_00_00_00" taborder="68" text="나만의 계발 방안&#13;&#10;&#13;&#10;" left="189" top="2663" width="934" height="87" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_02_00_00_02_00_00_00_00_00" taborder="69" text="사회적&#13;&#10;주도성" left="60" top="2749" width="130" height="179" cssclass="sta_WF_SurvInput01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta01_00_03_00_00_02_00_00_00_00_00" taborder="70" left="189" top="2749" width="934" height="93" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta02_01_00_00_00_00" taborder="71" text="친구들과 함께해보고 싶은 일을 생각해 보고 “함께 해보자.&quot;라고 먼저 말해 보세요." left="210" top="2768" width="740" height="30" cssclass="sta_WF_surveyDot16"/>
                    <Static id="sta02_00_00_00_00_00_00" taborder="72" text="친구들 사이에서 필요한 것을 생각해 보고, 그것을 내가 먼저 실천해 보세요." left="210" top="2792" width="776" height="30" cssclass="sta_WF_surveyDot16"/>
                    <Static id="sta01_00_03_00_00_00_01_00_00_00_00_00" taborder="73" text="나만의 계발 방안&#13;&#10;&#13;&#10;" left="189" top="2841" width="934" height="87" cssclass="sta_WF_SurvInput02" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="Static99_00_00_00_00_01_00_00_01_00_00" taborder="74" left="60" top="20" height="40" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="260"/>
                    <Static id="Static99_00_00_00_00_01_00_00_01_00_00_00" taborder="75" left="20" top="60" height="220" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="40"/>
