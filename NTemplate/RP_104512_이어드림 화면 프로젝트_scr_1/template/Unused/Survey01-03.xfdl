        <Div id="div01" taborder="1" left="0" top="200" height="740" cssclass="div_WF_SurveyBG" right="0" initvalueid="ivDivAccessibilityOff" text="">
          <Layouts>
            <Layout>
              <Div id="div00" taborder="0" left="360" top="0" width="1200" height="660" cssclass="div_WF_Greeting" initvalueid="ivDivAccessibilityOff">
                <Layouts>
                  <Layout>
                    <Static id="sta00" taborder="0" left="283" top="85" width="209" height="8" cssclass="sta_WF_SurveyUnder" initvalueid="ivStcAccessibilityOff"/>
                    <Static id="sta00_00" taborder="1" text="학생  여러분! 안녕하세요.  &#13;&#10;여러분의 솔직한 응답이 행복하고 안전한 학교를 만들 수 있습니다." left="40" top="24" width="695" height="80" cssclass="sta_WF_Txt24" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta00_00_00_00" taborder="2" text="&lt;b v='true'&gt;2021년 2학기부터 지금까지 본인이 직접 경험한 학교폭력에 대해 응답해 주세요.&lt;/b&gt; (해결 중에있거나 이미 해결된 경우 모두 포함) " left="40" top="124" width="900" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
                    <Div id="div00" taborder="3" text="div00" top="156" width="1150" height="375" cssclass="div_WF_Greeting02" initvalueid="ivDivAccessibilityOff" left="20">
                      <Layouts>
                        <Layout>
                          <Static id="sta00" taborder="0" text="&lt;b v='true'&gt;학교폭력이란?&lt;/b&gt; 학생에게 이루어지는 학교안과 밖의 폭력" left="78" top="54" width="468" height="36" cssclass="sta_WF_SurvWowP" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
                          <Static id="sta00_00_00_00" taborder="1" text="언어폭력" left="78" top="115" width="90" height="30" cssclass="sta_WF_Txt16B" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
                          <Static id="sta00_00_00_00_00" taborder="2" text="심한 욕설, 놀림, 협박(겁주는 말)을 함" left="78" top="149" width="324" height="30" cssclass="sta_WF_surveyDot" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
                          <Static id="sta00_00_00_00_00_00" taborder="3" text="내가 가지고 있는 돈이나 물건을 빼앗음" left="78" top="175" width="324" height="30" cssclass="sta_WF_surveyDot" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
                          <Static id="sta00_00_00_00_00_00_00" taborder="4" text="성희롱, 성추행, 성폭행 등" left="78" top="201" width="204" height="30" cssclass="sta_WF_surveyDot" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
                          <Static id="sta00_00_00_00_00_00_00_00" taborder="5" text="상대방이 싫다고 하는데도 계속 따라다니며 괴롭힘" left="78" top="227" width="364" height="30" cssclass="sta_WF_surveyDot" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
                          <Static id="sta00_00_00_00_01" taborder="6" text="&lt;b v='true'&gt;강요 :&lt;/b&gt; 친구나 선후배가 하기 싫은 일을 강제로 시킴" left="616" top="115" width="415" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
                          <Static id="sta00_00_00_00_01_00" taborder="7" text="&lt;b v='true'&gt;신체폭력 :&lt;/b&gt; 친구나 후배에게 맞거나 어떤 곳에 갇힘    " left="616" top="152" width="415" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
                          <Static id="sta00_00_00_00_01_00_00" taborder="8" text="&lt;b v='true'&gt;사이버폭력 :&lt;/b&gt; 사이버공간(인터넷, 스마트폰 등)에서 괴롭힘" left="616" top="189" width="415" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
                          <Static id="sta00_00_00_00_01_00_00_00" taborder="9" text="&lt;b v='true'&gt;집단 따돌림 :&lt;/b&gt; 친구나 선후배 여러명이 계속 따돌림" left="616" top="227" width="415" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
                          <Static id="sta00_00_00_00_00_00_00_00_00" taborder="10" text="사소한 괴롭힘이나 장난도 학교폭력이 될 수 있습니다." left="77" top="281" width="394" height="30" cssclass="sta_WF_SurveyDescript02" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
                          <Static id="sta01" taborder="11" left="566" top="123" width="1" height="125" cssclass="sta_WF_SurvSection" initvalueid="ivStcAccessibilityOff"/>
                        </Layout>
                      </Layouts>
                    </Div>
                    <Static id="sta00_00_00_00_00" taborder="4" text="&lt;b v='true'&gt;응답내용은 통계법 제33조에 의해 비밀이 지켜지므로&lt;/b&gt; 안심하고 응답해 주시기 바랍니다." left="40" top="515" width="760" height="35" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
                    <Static id="sta00_00_00_00_00_00" taborder="5" text="감사합니다." left="40" top="546" width="110" height="35" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
                    <Static id="sta00_00_00_00_00_00_00" taborder="6" text="2022.04. 강원도 교육감" left="981" top="576" width="179" height="35" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
                    <Static id="Static99_00_00_00_00_01_00_00_01_00_00_01" taborder="7" left="0" height="18" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" bottom="103" right="40"/>
