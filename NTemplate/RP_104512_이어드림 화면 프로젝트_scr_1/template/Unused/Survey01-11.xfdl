<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmTemp01" width="780" height="575" titletext="교육설문-학교폭력(설문참여_주관식/신고-동의_팝업)" onload="frmTemp01_onload">
    <Layouts>
      <Layout height="575" width="780" screenid="ScreenDeskTop">
        <Div id="div00" taborder="0" text="div00" left="30" top="30" width="720" height="515" cssclass="div_WF_SurvPopup" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="sta01" taborder="0" text="개인정보 수집 및 동의" left="40" top="22" width="182" height="30" cssclass="sta_WF_Txt18B" initvalueid="ivStcAccessibilityOn"/>
              <Button id="btn01" taborder="1" left="654" top="20" width="36" height="36" cssclass="btn_WF_SurvPopClose" initvalueid="ivBtnAccessibilityButton"/>
              <Static id="sta01_00" taborder="2" text="「개인정보 보호법」 제15조 제 1항, 제2항에 의거하여 본인의 동의를 통한 개인정보를 수집·이용하고자 합니다. 수집하는 개인정보는 관련 목적외의 용도로 이용되거나 제3자에게 제공되지 않습니다." top="56" height="75" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" wordSpacing="-2px" left="40" width="640"/>
              <Static id="sta01_00_00" taborder="3" text="개인정보수집 및 이용 목적" left="40" top="164" height="30" cssclass="sta_WF_Txt16B" initvalueid="ivStcAccessibilityOn" width="187" wordSpacing="-2px" onclick="div00_sta01_00_00_onclick"/>
              <Static id="sta01_00_00_00" taborder="4" text="학교폭력 신고 응답에 관한 정확한 사실관계 확인 및 신고(목격)자 상담 " left="40" top="187" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" width="461" wordSpacing="-2px" onclick="div00_sta01_00_00_onclick"/>
              <Static id="sta01_00_00_01" taborder="5" text="개인정보수집 및 이용 항목" left="40" top="224" height="30" cssclass="sta_WF_Txt16B" initvalueid="ivStcAccessibilityOn" width="187" wordSpacing="-2px" onclick="div00_sta01_00_00_onclick"/>
              <Static id="sta01_00_00_00_00" taborder="6" text="학년, 반, 번호, 이름" left="40" top="246" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" width="142" wordSpacing="-2px" onclick="div00_sta01_00_00_onclick"/>
              <Static id="sta01_00_00_01_00" taborder="7" text="개인정보수집 및 이용 기간" left="40" top="283" height="30" cssclass="sta_WF_Txt16B" initvalueid="ivStcAccessibilityOn" width="187" wordSpacing="-2px" onclick="div00_sta01_00_00_onclick"/>
              <Static id="sta01_00_00_00_00_00" taborder="8" text="학교폭력 실태조사 응답 후 해당학년도 종료 시까지 해당 학년도 종료시까지" left="40" top="307" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" width="491" wordSpacing="-2px" onclick="div00_sta01_00_00_onclick"/>
              <Static id="sta02" taborder="9" text="동의하지 않아도 신고 문항 제출은 가능합니다. " left="40" top="383" width="309" height="30" cssclass="sta_WF_SurveyDescript02" initvalueid="ivStcAccessibilityOn"/>
