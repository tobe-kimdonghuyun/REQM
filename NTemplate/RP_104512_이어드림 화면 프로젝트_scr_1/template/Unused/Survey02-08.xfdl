              <Div id="div01" taborder="1" text="div01" left="480" top="114" width="982" height="177" cssclass="div_WF_Greeting" initvalueid="ivDivAccessibilityOff">
                <Layouts>
                  <Layout>
                    <Static id="sta01_00" taborder="0" text="다음은 초등학생 학부모 또는 주 양육자 여러분께 자녀의 성격 및 정서행동 특성을 묻는 설문입니다. " left="40" top="58" width="675" height="26" cssclass="sta_WF_surveyDot14" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta00_00" taborder="1" text="아동·정서행동 특성검사(CPSQ-Ⅱ)" left="40" top="22" width="281" height="30" cssclass="sta_WF_Txt18B" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="Static99_00_00_00_00_01_00_00_01_00_00_00_00_00_01_01_00" taborder="2" left="40" top="0" height="30" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" right="662"/>
                    <Static id="Static99_00_00_00_00_01_00_00_01_00_00_00_00_00_01_01_00_01" taborder="3" left="40" top="47" height="18" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" right="662"/>
                    <Static id="sta01_00_00" taborder="4" text="이 검사에는 옳거나 그른 답이 없으므로 자신의 의견을 있는 그대로 솔직하게 대답하시면 됩니다." left="40" top="81" width="675" height="26" cssclass="sta_WF_surveyDot14" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="Static99_00_00_00_00_01_00_00_01_00_00_00_00_00_01_01_00_01_00" taborder="5" left="40" top="78" height="10" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" right="662"/>
                    <Static id="Static99_00_00_00_00_01_00_00_01_00_00_00_00_00_01_01_00_01_00_00" taborder="6" left="40" top="102" height="10" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" right="662"/>
                    <Static id="sta01_00_00_00" taborder="7" text="다음 각 문항을 읽고, 최근 자녀의 모습에 해당된다고 생각하는 곳에 선택하여 주십시오." left="40" top="104" width="675" height="26" cssclass="sta_WF_surveyDot14" initvalueid="ivStcAccessibilityOn"/>
                  </Layout>
