        <Static id="sta01_00_00_01_01_01" taborder="20" text="&lt;b v='true'&gt;교육급여 :&lt;/b&gt; (동 주민센터 비치서류)사회복지서비스 및 급여 제공(변경) 신청서, 소득·재산서신고서, 금융정보 등 제공동의서" left="0" top="1188" height="30" cssclass="sta_WF_Info16Blue" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="0"/>
        <Static id="sta01_00_00_01_01_01_00" taborder="21" text="&lt;b v='true'&gt;교육비지원 :&lt;/b&gt; 신청서, 소득·재산신고서, 금융정보 등 제공동의서, 임대차 계약서 등 소득·재산 증빙서류, 신분증, 급여를 받고자하는 통장사본" left="0" top="1228" height="30" cssclass="sta_WF_Info16Blue" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="0"/>
        <ImageViewer id="imgTitle00_00_00_00_00_00" taborder="22" text="선정방법" left="0" top="1298" height="40" cssclass="img_WF_SubTit02" width="117" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta01_00_00_01_01_01_00_00" taborder="23" text="&lt;b v='true'&gt;교육급여 :&lt;/b&gt; 보장기주의 &lt;b v='true'&gt;“소득인정액”&lt;/b&gt;이 기준 &lt;b v='true'&gt;중위소득 50% 이하&lt;/b&gt;인 대상자를 선정" left="0" top="1348" height="28" cssclass="sta_WF_Info16Blue" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="0"/>
        <Static id="sta01_00_00_02_00_00_00" taborder="24" text="※ 국민기초생활보장법 제12조의 3항 따라 부양 의무자 기준은 적용하지 아니함" left="79" top="1376" width="556" height="28" cssclass="sta_WF_Txt16" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta01_00_00_01_01_01_00_00_00" taborder="25" text="&lt;b v='true'&gt;교육비지원 :&lt;/b&gt; 신청자 가구원(학생의 부모,형제·자매)의 소득과 재산을 기준으로 가구별 &lt;b v='true'&gt;“소득인정액”&lt;/b&gt;을 산정하여 대상자 선정" left="0" top="1424" height="28" cssclass="sta_WF_Info16Blue" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="0"/>
        <Static id="sta01_00_00_02_00_00_00_00" taborder="26" text="※ 기초생활수급자, 한부모가족지원, 법정차상위 저격 보유자는 소득인정액 산정 없이 대상자 선정 가능" left="94" top="1452" width="727" height="28" cssclass="sta_WF_Txt16" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
