        <Static id="sta01_00_00_02" taborder="16" text="교육비 &lt;b v='true'&gt;원클릭신청(oneclick.neis.go.kr) &lt;/b&gt;또는 &lt;b v='true'&gt;복지로 온라인신청(online.bokjiro.go.kr)&lt;/b&gt;으로 접속  " left="0" top="1006" height="30" cssclass="sta_WF_Txt16" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="0"/>
