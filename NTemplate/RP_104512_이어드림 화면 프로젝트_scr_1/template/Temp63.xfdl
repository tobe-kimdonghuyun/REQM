        <ImageViewer id="imgTitle00" taborder="3" text="유아학비 지원금을 받기 위해, 학부모가 꼭 해야 하는 절차" left="0" top="786" height="40" cssclass="img_WF_SubTit02" width="580" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_00_01" taborder="4" left="0" top="857" width="50" height="50" cssclass="sta_WF_KinderGrayBlTxt" initvalueid="ivStcAccessibilityOff" text="1"/>
        <Static id="sta00_02" taborder="5" text="복지서비스 자격신청 및 국민행복카드 발급(유치원 입학전 준비사항)" left="64" top="862" width="741" height="40" cssclass="sta_WF_Txt20" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_02_01" taborder="6" text="- 유치원에 입학하는 자녀가 국가로부터 유아학비(복지서비스)를 지원받기 위한 자격 신청&#13;&#13;&#10;- 유치원에서 유아학비 지원대상자 확인 및 지원금 청구를 위해 국민행복카드 사용" left="62" top="905" width="741" height="64" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_00_01_00" taborder="7" left="0" top="1032" width="50" height="50" cssclass="sta_WF_KinderGrayBlTxt" initvalueid="ivStcAccessibilityOff" text="2"/>
        <Static id="sta00_02_00" taborder="8" text="유아학비 지원대상자 카드인증(연 1회, 국민행복카드 사용)" left="63" top="1037" width="741" height="40" cssclass="sta_WF_Txt20" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_02_01_00" taborder="9" text="- 유치원에 입학한 자녀가 유아학비 자격을 보유한 지원 대상자인지 확인하는 절차&#13;&#10;&#13;  (확인방법) 인터넷 학부모서비스 이용&#13;&#10;&#13; &lt;fc v='#595959'&gt; *국민행복카드 인증을 통해 학부모의 본인 확인처리&lt;/fc&gt;" left="62" top="1081" width="741" height="80" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
        <Static id="sta00_00_01_00_00" taborder="10" left="0" top="1221" width="50" height="50" cssclass="sta_WF_KinderGrayBlTxt" initvalueid="ivStcAccessibilityOff" text="3"/>
        <Static id="sta00_02_00_00" taborder="11" text="유아학비 학부모 청구(분기별, 국민행복카드 또는 공동인증서)" left="64" top="1226" width="741" height="40" cssclass="sta_WF_Txt20" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_02_01_00_00" taborder="12" text="- 유치원에 유아학비를 산정하고 학부모가 청구하면, 관할 교육청에서 유아학비 지원금을 지급&#13;&#10;&#13;  &#13; &lt;fc v='#595959'&gt;(청구방법) 인터넷 학부모서비스 이용&lt;/fc&gt;" left="61" top="1273" width="741" height="50" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
        <Static id="Static99_00_00_00_00" taborder="13" left="0" top="0" height="60" cssclass="sta_GD_Size" text="60" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
