              <Static id="sta00_00_01_00_00" taborder="1" left="30" top="99" height="42" cssclass="sta_WF_survDot28" initvalueid="ivStcAccessibilityOn" usedecorate="true" text="&lt;b v='true'&gt;제출 후에는 수정, 재 제출 불가합니다.&lt;/b&gt;" right="30"/>
