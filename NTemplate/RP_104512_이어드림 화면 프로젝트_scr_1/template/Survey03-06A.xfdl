<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmTemp01" width="680" height="670" titletext="[M]교육설문3-교원능력(학생학적확인_팝업)" onload="frmTemp01_onload" cssclass="frm_Pop_bgTrsprt">
    <Layouts>
      <Layout height="670" width="680" screenid="ScreenDeskTop">
        <Div id="div00" taborder="0" text="div00" left="30" top="30" cssclass="div_WF_SurvPopLine" initvalueid="ivDivAccessibilityOff" width="619" height="593">
          <Layouts>
            <Layout>
              <Static id="sta01_00_00" taborder="0" text="&lt;b v='true'&gt;꼭 읽어 보세요&lt;/b&gt;" left="226" top="30" height="39" cssclass="sta_WF_SurvCautionL" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" width="167" color="#ff3f3f" usedecorate="true"/>
              <Static id="sta00_00_01_00_00" taborder="1" left="30" top="99" height="22" cssclass="sta_WF_survGrayDot18" initvalueid="ivStcAccessibilityOn" usedecorate="true" text="&lt;b v='true'&gt;제출 후에는 수정, 재 제출 불가합니다.&lt;/b&gt;" width="555"/>
              <Static id="sta01_00" taborder="2" text="의견/만족도조사 참여후에는, 수정하거나 다시 제출하지 못하기에 정확하게&#13;&#10;응답하였는지 확인하고 제출하세요. " left="40" top="136" height="56" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" width="533"/>
              <Static id="sta00_00_01_00_00_01" taborder="3" left="30" top="202" height="28" cssclass="sta_WF_survGrayDot18" initvalueid="ivStcAccessibilityOn" usedecorate="true" text="&lt;b v='true'&gt;익명성은 확보 되어 있나요?&lt;/b&gt;" width="555"/>
              <Static id="sta01_00_02" taborder="4" text="체크리스트형 응답 내용은 통계 처리한 후 결과값을 선생님에게 제공하고,&#13;&#10;서술형 응답 내용 또한 응답자 정보는 제외하고 답 결과만을 제공합니다.&#13;&#10;&#13;즉, 누가 어떻게 응답을 하였는지 전혀 알 수 없습니다." left="40" top="235" height="54" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" width="533"/>
              <Static id="sta01_00_01_00" taborder="5" text="&lt;fc v='red'&gt;※ 누가 어떻게 응답을 하였는지 확인 할 수 있는 기능이 시스템에는 존재하지 않습니다.&lt;/fc&gt;" left="30" top="288" height="26" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" width="534" usedecorate="true"/>
              <Static id="sta01_00_03" taborder="6" text="다만, 서술형 문항에 응답 할때는 자녀가 누군지 유추할수 있는 내용을 기술하지&#13;&#10;않는 것이 적절합니다.  " left="40" top="319" height="50" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" width="533"/>
              <Static id="sta01_00_01_00_00" taborder="7" text="&lt;fc v='red'&gt;※ 잘못 기술한 예 : ‘작년과 금년도에 담임을 맡아 주셔서...’,&#13;&#10; &#13;                                  ‘7월 3일에 지각을 하였던 학생의 학부모입니다.’&lt;/fc&gt;" left="30" top="368" height="44" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" width="534" usedecorate="true"/>
              <Static id="sta00_00_01_00_00_01_00" taborder="8" left="30" top="425" height="54" cssclass="sta_WF_survGrayDot18" initvalueid="ivStcAccessibilityOn" usedecorate="true" text="&lt;b v='true'&gt;서술형 응답시 선생님께 적절하지 않은 언어를 사용하는 것은 교육활동에&#13;&#10;전혀 도움이 되지 않기에 삼가주세요.&lt;/b&gt;" width="555"/>
              <Button id="btn00_01_01" taborder="9" text="확인" top="502" width="160" cssclass="btn_WF_Confirm2" initvalueid="ivBtnAccessibilityButton" left="223" enable="true" height="50"/>
              <Button id="btn01" taborder="10" top="30" width="36" height="36" cssclass="btn_WF_SurvPopClose" initvalueid="ivBtnAccessibilityButton" right="30"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_00_00_00" taborder="11" left="0" top="0" cssclass="sta_WF_GDSize" text="30" visible="false" initvalueid="ivStcAccessibilityOff" width="30" bottom="0"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_00_00" taborder="12" left="0" top="0" height="20" cssclass="sta_WF_GDSize" text="20" visible="false" initvalueid="ivStcAccessibilityOff" right="0"/>
            </Layout>
