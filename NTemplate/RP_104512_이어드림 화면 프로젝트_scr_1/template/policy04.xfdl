<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmTemp01" width="1200" height="1752" onload="frmTemp01_onload" titletext="[M]웹접근성 정책">
    <Layouts>
      <Layout height="1752" width="1200" screenid="ScreenDeskTop">
        <ImageViewer id="imgTitle" taborder="0" text="웹접근성 정책" left="0" top="60" height="54" cssclass="img_WF_SubTit01" width="200" initvalueid="ivTitleAccessibilityOn"/>
        <Div id="div00" taborder="1" text="div00" left="0" top="154" height="154" width="1200" cssclass="div_WF_kinder" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="sta00_00_00_00_00" taborder="1" text="나이스 대국민 서비스는 장애인, 노인 등의 정보취약계층의 사용자가 전문적인 능력없이도 웹 사이트에서 제공하는 정보에 접근할 수 있도록 최선의 노력을 기울이고 있습니다.&#13;&#10;&#13;&#10;나이스 대국민 서비스는 장애인, 노인 등 정보취약계층의 인터넷 정보 접근을 보장하기 위해 국가표준(KICS)으로 제정된 &quot;한국형 웹 콘텐츠 접근성 지침2.1&quot;와&#13;&#10;&quot;전자정부서비스 호환성 준수지침(행정자치부 고시 제1호)&quot;를 준수하여 제작되어 있습니다." left="33" top="28" height="96" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" right="30" letterSpacing="-1px"/>
              <Static id="Static99_00_00_00_00_00" taborder="1" left="0" top="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
              <Static id="Static99_00_00_00_00_00_00" taborder="2" left="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" bottom="0"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="Static99_00_00_00_00_00_00" left="0" height="90" right="0" bottom="0" text="90"/>
              <Static id="sta00_00_00_00_00" cssclass="sta_WF_Txt28C" left="20" top="0" height="508" text="나이스 대국민 서비스는 장애인, 노인 등의 &#13;&#10;정보취약계층의 사용자가 전문적인 능력없이도 &#13;&#10;웹 사이트에서 제공하는 정보에 접근할 수 있도록 &#13;&#10;최선의 노력을 기울이고 있습니다.&#13;&#10;&#13;&#10;나이스 대국민 서비스는 장애인, 노인 등 &#13;&#10;정보취약계층의 인터넷 정보 접근을 보장하기 위해 &#13;&#10;국가표준(KICS)으로 제정된 &#13;&#10;&quot;한국형 웹 콘텐츠 접근성 지침2.1&quot;와&#13;&#10;&quot;전자정부서비스 호환성 준수지침&#13;&#10;(행정자치부 고시 제1호)&quot;를 준수하여 &#13;&#10;제작되어 있습니다." letterSpacing="-2px" minwidth="560" maxwidth="" right="20"/>
              <Static id="Static99_00_00_00_00_00" left="0" top="0" height="30" right="555"/>
            </Layout>
          </Layouts>
        </Div>
        <ImageViewer id="imgTitle00" taborder="2" text="웹접근성 품질마크" left="0" top="380" height="40" cssclass="img_WF_SubTit02" width="190" initvalueid="ivTitleAccessibilityOn"/>
        <Div id="div00_00" taborder="3" text="div00" left="0" top="431" height="156" width="1200" cssclass="div_WF_KinderBox" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" left="30" top="32" width="138" background="url('theme://images/img_common_wa.png') repeat center top" height="91" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00_00_00_00" taborder="1" text="장애인 및 고령자가 웹사이트 이용에 불편이 없도록 웹접근성 표준지침을 준수한 우수 사이트에 대해 웹접근성 수준을 인정하고,&#13;&#10;이를 상징하는 품질마크를 부여하는 인증 제도&#13;&#10;&#13;&#10;나이스 대국민서비스(학생,학부모서비스)는 표준지침을 준수하여 품질마크를 부여받았습니다." left="200" top="28" height="96" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" right="30"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="sta00_00_00_00_00" left="5" top="247" height="432" cssclass="sta_WF_Txt28C" text="장애인 및 고령자가 웹사이트 이용에 불편이 없도록 &#13;&#10;웹접근성 표준지침을 준수한 우수 사이트에 대해 &#13;&#10;웹접근성 수준을 인정하고,&#13;&#10;이를 상징하는 품질마크를 &#13;&#10;부여하는 인증 제도&#13;&#10;&#13;&#10;나이스 대국민서비스(학생,학부모서비스)는 &#13;&#10;표준지침을 준수하여 품질마크를 부여받았습니다." letterSpacing="-2px" taborder="1" maxwidth="" minwidth="570" right="5"/>
              <Static id="sta00" left="147" top="70" height="192" minwidth="306" maxwidth="" background="url('theme://images/img_BF_MA.png') no-repeat center center" taborder="0" right="147"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta00_00_00_00_00_01_00_00_00" taborder="4" text="&lt;b v=&quot;true&quot;&gt;바로접근(Accessibility)링크&lt;/b&gt; : 서비스 문서 시작 부분에 반복되는 메뉴등의 링크가 많은 페이지를 이동시켜 본문을 효율적으로 이동할 수 있도록 스킵 네비게이션(바로가기)&#13;&#10;링크를 제공하고 있습니다. " left="10" top="622" height="48" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Info16Black" usedecorate="true" width="1160"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_01" taborder="5" text="&lt;b v=&quot;true&quot;&gt;문서 제목(title)태그&lt;/b&gt; " left="10" top="681" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Info16Black" usedecorate="true" width="160"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_00" taborder="6" text=" : 모든 문서마다 문서의 제목(&lt;title&gt;)을 제공하고, 문서의 제목은 문서의 특징을 잘 나타내도록 간단명료하게 기술하고 있습니다." left="sta00_00_00_00_00_01_00_00_00_01:-12" top="679" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" usedecorate="false" width="850"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_01_00" taborder="7" text="&lt;b v=&quot;true&quot;&gt;문서의 구조화&lt;/b&gt;" left="10" top="717" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Info16Black" usedecorate="true" width="110"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_00_00" taborder="8" text="                        : 문서는 논리적인 접근 및 키보드 접근이 가능하도록 헤딩(&lt;h1&gt;~&lt;h6&gt;),문단(&lt;p&gt;),목록(&lt;ul&gt;,&lt;ol&gt;,&lt;dl&gt;) 등의 태그를 사용하였습니다. 또한 디자인요소를 &#13;&#10;  css를 사용하여 분리하고 있으며 스타일시트를 제거하더라도 콘텐츠를 이해할 수 있습니다." left="11" top="716" height="50" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" usedecorate="false" width="1129"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_02" taborder="9" text="&lt;b v=&quot;true&quot;&gt;이미지 정보&lt;/b&gt; : 텍스트가 아닌 콘텐츠에는 모두 대체 텍스트가 제공되고 있으며, 대체 텍스트 제공이 어려운 도형이미지는 별도의 텍스트정보를 제공하고 있습니다." left="10" top="774" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Info16Black" usedecorate="true" width="1160"/>
        <ImageViewer id="imgTitle00_00" taborder="10" text="지원 가능한 OS 및 브라우저" left="0" top="866" height="40" cssclass="img_WF_SubTit02" width="290" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_02_00" taborder="11" text="나이스 대국민서비스에서는 마이크로소프트사 윈도우, 애플사 맥 OS 등의 운영체제와 인터넷익스플로서, 파이어폭스, 사파리 등의 다양한 브라우저에서 동일한 서비스 화면을 &#13;&#10;제공하고 있습니다. 단, 일부운영체제와 브라우저에서는 기능의 제한이 있을 수 있습니다." left="10" top="913" height="50" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" usedecorate="false" width="1160"/>
        <Div id="div01" taborder="12" text="div01" left="0" top="995" height="122" initvalueid="ivDivAccessibilityOff" width="1200">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" text="운영체제(OS)" left="0" top="0" width="240" height="57" cssclass="sta_WF_DtlTop04" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00_00_00_00" taborder="1" top="0" cssclass="sta_WF_DtlCnt03" initvalueid="ivStcAccessibilityOn" height="57" left="239" right="0" text="윈도우 10, 11" textAlign="left" padding="0px 0px 0px 30px"/>
              <Static id="sta00_00" taborder="2" text="브라우저" left="0" top="56" width="240" height="57" cssclass="sta_WF_DtlTop04" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00_00_00_00_00" taborder="3" top="56" cssclass="sta_WF_DtlCnt03" initvalueid="ivStcAccessibilityOn" height="57" left="239" right="0" text="크롬, 엣지, 파이어폭스, 오페라" textAlign="left" padding="0px 0px 0px 30px"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="sta00" left="0" top="0" width="200" height="70" cssclass="sta_WF_PolicyDtlG_B" taborder="0"/>
              <Static id="sta00_00_00_00_00" left="200" top="0" height="70" right="0" cssclass="sta_WF_PolicyDtlW" taborder="1"/>
              <Static id="sta00_00" left="0" top="69" width="200" cssclass="sta_WF_PolicyDtlG_B" height="70" taborder="2"/>
              <Static id="sta00_00_00_00_00_00" left="200" top="69" height="70" right="0" cssclass="sta_WF_PolicyDtlW" taborder="3"/>
            </Layout>
          </Layouts>
        </Div>
        <ImageViewer id="imgTitle00_00_00" taborder="13" text="장애인 이용안내" left="0" top="1180" height="40" cssclass="img_WF_SubTit02" width="172" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta_Link01" taborder="14" text="나이스 대국민서비스는 시각장애인을 위한 별도의 홈페이지를 구축하지 않고 이용할 수 있도록 하였습니다. 시각장애인 여러분들께서 나이스 대국민서비스를 이용하시려면 &#13;&#10;화면을 읽어주는 별도의 스크린 리더 프로그램이 필요합니다. 스크린리더 및 기타 보조기기에 대한 안내는 정보통신보조기기&lt;l v='http://at4u.or.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;(http://at4u.or.kr)&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt; 웹사이트에서 안내 받으실 수 있으며, 중앙보조기구센터&lt;l v='http://knat.go.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;(http://knat.go.kr)&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt; 에서 장애인보조기구 지원사업에 대한 각종 정보를 확인하실 수 있습니다." left="10" top="1230" height="100" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" usedecorate="true" width="1160"/>
        <ImageViewer id="imgTitle00_00_00_00" taborder="15" text="키보드 사용법" left="0" top="1386" height="40" cssclass="img_WF_SubTit02" width="147" initvalueid="ivTitleAccessibilityOn"/>
        <Div id="div01_00" taborder="16" text="div01" left="0" top="1435" height="317" initvalueid="ivDivAccessibilityOff" width="1200">
