      <Layout name="Layout0" screenid="mobile" width="640" height="4147" mobileorientation="portrait" type="default">
        <ImageViewer id="imgTitle" cssclass="img_WF_Txt48BC" left="156" top="72" height="80" taborder="0" right="156" minwidth="340" maxwidth=""/>
        <Static id="Static99_00_00_00_00" left="0" top="0" height="90" right="0" taborder="17"/>
        <Div id="div00" left="20" top="imgTitle:22" height="589" cssclass="div_WF_BotLine" taborder="1" right="20"/>
        <ImageViewer id="imgTitle00" left="20" top="div00:59" width="250" height="50" cssclass="img_WF_SubTit03" taborder="2"/>
        <Static id="Static99_00_00_00_00_00" left="0" top="134" height="40" right="0" taborder="18"/>
        <Static id="Static_place00" left="10" top="2428" width="40" height="120" taborder="19"/>
        <Static id="Static99_00_00_00_00_00_00" left="0" top="763" height="70" right="0" text="70" taborder="20"/>
        <Div id="div00_00" left="20" top="imgTitle00:29" height="694" taborder="3" right="20"/>
        <Static id="Static99_00_00_00_00_00_00_00" left="0" top="861" height="40" right="0" text="40" taborder="21"/>
        <Static id="sta00_00_00_00_00_01_00_00_00" left="20" top="div00_00:67" height="192" cssclass="sta_WF_HangTxt_black28_M" text="&lt;b v=&quot;true&quot;&gt;바로접근(Accessibility)링크&lt;/b&gt; : 서비스 문서 시작 부분에 반복되는 메뉴등의 링크가 많은 페이지를 이동시켜 본문을 효율적으로 이동할 수 있도록 스킵 네비게이션(바로가기)링크를 제공하고 있습니다. " fittocontents="height" taborder="4" right="20"/>
        <Static id="Static99_00_00_00_00_00_00_01" left="0" top="1595" height="70" right="0" text="70" taborder="22"/>
        <Static id="Static99_00_00_00_00_00_00_01_00" left="20" top="1824" height="40" right="507" visible="false" text="40" taborder="23"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_01" left="20" top="sta00_00_00_00_00_01_00_00_00:17" width="269" height="42" cssclass="sta_WF_HangTxt_black28_M" taborder="5"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_00" left="20" top="sta00_00_00_00_00_01_00_00_00:19" height="128" text="                                  : 모든 문서마다 문서의 제목(&lt;title&gt;)을 제공하고, 문서의 제목은 문서의 특징을 잘 나타내도록 간단명료하게 기술하고 있습니다." cssclass="sta_WF_Txt28C" letterSpacing="-1px" textAlign="left" fittocontents="height" padding="0px 0px 0px 17px" taborder="6" right="20"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_00_00" left="20" top="sta00_00_00_00_00_01_00_00_00_00:20" height="212" cssclass="sta_WF_Txt28L" text="                        : 문서는 논리적인 접근 및 키보드 접근이 가능하도록 헤딩(&lt;h1&gt;~&lt;h6&gt;),문단(&lt;p&gt;),목록(&lt;ul&gt;,&lt;ol&gt;,&lt;dl&gt;) 등의 태그를 사용하였습니다. 또한 디자인요소를 css를 사용하여 분리하고 있으며 스타일시트를 제거하더라도 콘텐츠를 이해할 수 있습니다." letterSpacing="-1px" fittocontents="height" padding="0px 0px 0px 17px" taborder="8" right="20"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_01_00" left="20" top="sta00_00_00_00_00_01_00_00_00_00:19" width="203" height="42" cssclass="sta_WF_HangTxt_black28_M" taborder="7"/>
        <Static id="Static99_00_00_00_00_00_00_01_00_00" left="20" top="1975" height="40" right="507" text="40" visible="false" taborder="24"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_02" left="20" top="sta00_00_00_00_00_01_00_00_00_00_00:24" height="177" cssclass="sta_WF_HangTxt_black28_M" fittocontents="height" taborder="9" right="20"/>
        <Static id="Static99_00_00_00_00_00_00_01_00_00_00" left="20" top="2210" height="40" right="507" text="40" taborder="25"/>
        <Static id="Static99_00_00_00_00_00_00_01_00_00_00_00" left="0" top="2414" height="90" right="0" text="90" taborder="26"/>
        <ImageViewer id="imgTitle00_00" left="20" top="sta00_00_00_00_00_01_00_00_00_02:66" width="377" height="50" cssclass="img_WF_SubTit03" taborder="10"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_02_00" left="20" top="imgTitle00_00:10" height="252" cssclass="sta_WF_Txt28L" text="나이스 대국민서비스에서는 마이크로소프트사 윈도우, 애플사 맥 OS 등의 운영체제와 인터넷익스플로서, 파이어폭스, 사파리 등의 다양한 브라우저에서 동일한 서비스 화면을 제공하고 있습니다. &#13;&#10;단, 일부운영체제와 브라우저에서는 기능의 제한이 있을 수 있습니다." letterSpacing="-1px" taborder="11" right="20"/>
        <Static id="Static99_00_00_00_00_00_00_01_00_00_00_01" left="0" top="2533" height="30" right="0" text="30" taborder="27"/>
        <Static id="Static99_00_00_00_00_00_00_01_00_00_00_01_00" left="0" top="2807" height="40" right="0" taborder="28"/>
        <Div id="div01" left="20" top="sta00_00_00_00_00_01_00_00_00_02_00:35" height="139" taborder="12" right="20" minwidth="600" maxwidth=""/>
        <Static id="Static99_00_00_00_00_00_00_01_00_00_00_01_00_00" left="0" top="2986" height="80" right="0" taborder="29"/>
        <ImageViewer id="imgTitle00_00_00" left="20" top="div01:69" width="223" height="50" cssclass="img_WF_SubTit03" taborder="13"/>
        <Static id="Static99_00_00_00_00_00_00_01_00_00_00_01_00_00_00" left="0" top="3095" height="30" right="0" text="30" taborder="30"/>
        <Static id="sta_Link01" left="20" top="imgTitle00_00_00:6" height="428" cssclass="sta_WF_Txt28S" text="나이스 대국민서비스는 시각장애인을 위한 별도의 홈페이지를 구축하지 않고 이용할 수 있도록 하였습니다. 시각장애인 여러분들께서 나이스 대국민서비스를 이용하시려면 화면을 읽어주는 별도의 스크린 리더 프로그램이 필요합니다. &#13;&#10;스크린리더 및 기타 보조기기에 대한 안내는 정보통신보조기기 &lt;l v='http://at4u.or.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;(http://at4u.or.kr)&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt; 웹사이트에서 안내 받으실 수 있으며, 중앙보조기구센터&lt;l v='http://knat.go.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;(http://knat.go.kr)&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt; 에서 장애인보조기구 지원사업에 대한 각종 정보를 확인하실 수 있습니다." usedecorate="true" taborder="14" right="20" fittocontents="height"/>
        <ImageViewer id="imgTitle00_00_00_00" left="20" top="sta_Link01:59" width="194" height="50" cssclass="img_WF_SubTit03" taborder="15"/>
        <Static id="Static99_00_00_00_00_00_00_01_00_00_00_01_00_00_01" left="0" top="3528" height="80" right="0" visible="false" taborder="31"/>
        <Div id="div01_00" left="20" top="imgTitle00_00_00_00:29" text="div01" taborder="16" right="20" minwidth="600" maxwidth="" height="468"/>
