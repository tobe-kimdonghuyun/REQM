      <Layout height="4884" width="1200" screenid="ScreenDeskTop">
        <ImageViewer id="imgTitle" taborder="0" text="사이트 이용정책" left="0" top="60" height="54" cssclass="img_WF_SubTit01" width="230" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="Static99_00_00_00_00" taborder="5" left="0" top="0" height="60" cssclass="sta_GD_Size" text="60" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
        <Static id="Static99_00_00_00_00_00" taborder="6" left="0" top="114" height="40" cssclass="sta_GD_Size" text="40" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
        <Button id="btn00" taborder="2" text="조회" top="154" width="80" height="50" cssclass="btn_WF_PolicySch" initvalueid="ivBtnAccessibilityButton" left="1120"/>
        <Combo id="cbo00" taborder="1" text="2022.04.08 개정" top="154" width="210" height="50" cssclass="Pas" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" value="1" index="0" right="btn00:12" initvalueid="ivCmbNormal">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row>
                <Col id="codecolumn">1</Col>
                <Col id="datacolumn">2022.04.08 개정</Col>
              </Row>
              <Row>
                <Col id="codecolumn">2</Col>
                <Col id="datacolumn">2021.04.08 개정</Col>
              </Row>
            </Rows>
          </Dataset>
        </Combo>
        <Div id="div00" taborder="3" text="div00" left="0" top="224" width="1200" height="410" cssclass="div_WF_kinder" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="Static99_00_00_00_00_00_00" taborder="3" left="0" top="0" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="0"/>
              <Static id="Static99_00_00_00_00_00_00_00" taborder="4" left="30" top="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
              <Static id="sta00_02_01" taborder="0" text="「학생서비스, 학부모서비스」는 개인정보보호법 등 관련 법령에서 정한 개인정보보호규정을 준수하고 있으며, 개인정보보호법 제30조에 따라 정보주체의 개인정보를&#13;&#10;보호하고 이와 관련한 고충을 신속하고 원활하게 처리할 수 있도록 하기 위하여 다음과 같이 개인정보 처리지침을 수립·공개합니다." left="30" top="15" width="1158" height="60" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="Static99_00_00_00_00_00_00_01" taborder="5" top="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="30" right="0"/>
              <Static id="sta00_02_01_00" taborder="1" text="「학생서비스, 학부모서비스」의 개인정보처리방침은 다음과 같은 내용으로 구성되어 있습니다." left="30" top="87" width="700" height="30" cssclass="sta_WF_Txt16B" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px"/>
              <Static id="sta00_02_01_01" taborder="2" text="1. 개인정보의 처리목적&#13;&#10;2. 개인정보의 처리 및 보유기간&#13;&#10;3. 개인정보의 제3자 제공(개인정보의 제3자 제공에 관한 사항)&#13;&#10;4. 개인정보처리의 위탁(에 관한 사항)&#13;&#10;5. 정보주체의 권리·의무 및 행사방법에 관한 사항&#13;&#10;6. 처리하는 개인정보의 항목&#13;&#10;7. 개인정보의 파기에 관한 항목&#13;&#10;8. 개인정보의 안전성 확보조치에 관한 사항&#13;&#10;9. 개인정보 보호책임자에 관한 사항&#13;&#10;10. 권익침해 구제방법(정보주체의 권익침해에 대한 구제방법)&#13;&#10;11. 개인정보 처리방침 변경(에 관한 사항)" left="30" top="113" width="679" height="272" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="div00_00" taborder="4" text="div00" left="0" top="672" height="4212" width="1200" initvalueid="ivDivAccessibilityOff" cssclass="div_WF_KinderBox">
          <Layouts>
            <Layout>
              <Static id="Static99_00_00_00_00_00_00_02_00" taborder="59" left="30" top="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="Static99_00_00_00_00_00_00" taborder="56" left="0" top="0" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="-208"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00" taborder="57" left="30" top="46" height="8" cssclass="sta_GD_Size" text="8" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="sta00_02_01_00" taborder="1" text="① 「학생서비스, 학부모서비스」는 다음 각 호의 목적을 위하여 개인정보를 수집/처리하고 있으며, 이용 목적이 변경되는 경우에는 개인정보보호법 제17조 및 &#13;&#10;제18조에 따라 개인정보의 제공에 따라 별도의 동의를 받는 등 필요한 조치를 취하고 있습니다." left="30" top="43" width="1129" height="60" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00" taborder="58" left="30" top="93" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="sta00_02_01_00_00" taborder="2" text="1. 홈페이지 회원 가입 및 관리&#13;&#10;회원제 서비스 제공을 위한 본인 식별·인증, 회원자격 유지·관리, 제한적 본인확인제 시행에 따른 본인확인, 서비스 부정이용 방지, 만 14세 미만 아동의 개인정보 처리 시&#13;&#10;법정대리인의 동의여부 확인, 각종 고지·통지 등을 목적으로 개인정보를 처리합니다.&#13;&#10;2. 서비스 제공 및 민원처리&#13;&#10;학생서비스, 학부모서비스와 기타 본 사이트의 운영 목적 달성을 위해 구축/운영하는 일체의 서 비스의 운영 및 민원처리를 위한 목적으로 개인정보를 처리합니다." left="30" top="113" width="1129" height="130" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_02_01_00_01" taborder="3" text="② 「학생서비스, 학부모서비스」가 개인정보보호법 제32조 에 따라 등록·공개하는 개인정보파일 의 처리목적은 다음과 같습니다." left="30" top="259" width="1090" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00" taborder="60" left="30" top="236" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_00" taborder="61" left="30" top="283" height="60" cssclass="sta_GD_Size" text="60" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <ImageViewer id="imgTitle" taborder="0" text="제1조(개인정보의 처리목적)" left="28" top="22" height="30" cssclass="img_WF_Txt16B" width="202" initvalueid="ivTitleAccessibilityOn"/>
              <Div id="div00" taborder="4" text="div00" left="30" top="343" height="269" right="30" initvalueid="ivDivAccessibilityOff">
                <Layouts>
                  <Layout>
                    <Static id="sta00" taborder="0" text="개인정보파일의 명칭" left="0" top="0" width="202" height="60" cssclass="sta_WF_PolicyDtlG" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta00_00" taborder="1" text="운영근거 / 처리목적" left="201" top="0" width="370" height="60" cssclass="sta_WF_PolicyDtlG" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta00_00_00" taborder="2" text="개인정보파일에 기록되는 개인정보의 항목" left="570" top="0" width="380" height="60" cssclass="sta_WF_PolicyDtlG" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta00_00_00_00" taborder="3" text="보유기간" top="0" width="191" cssclass="sta_WF_PolicyDtlG" initvalueid="ivStcAccessibilityOn" height="60" right="0"/>
                    <Static id="sta00_01" taborder="4" left="0" top="59" width="202" height="210" cssclass="sta_WF_PolicyDtlW" initvalueid="ivStcAccessibilityOff"/>
                    <Static id="sta00_00_01" taborder="5" left="201" top="59" width="370" cssclass="sta_WF_PolicyDtlW" initvalueid="ivStcAccessibilityOff" height="210"/>
                    <Static id="sta00_00_00_01" taborder="6" left="570" top="59" width="380" height="210" cssclass="sta_WF_PolicyDtlW" initvalueid="ivStcAccessibilityOff"/>
                    <Static id="sta00_00_00_00_00" taborder="7" top="59" width="191" cssclass="sta_WF_PolicyDtlW" initvalueid="ivStcAccessibilityOff" height="210" right="0"/>
                    <Static id="sta00_02_01_00_01" taborder="8" text="「학생서비스,  학부모서비스」&#13;&#10;회원정보" left="0" top="64" height="57" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" textAlign="center" width="197"/>
                    <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00" taborder="9" left="0" top="60" height="16" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
                    <Static id="sta00_02_01_00_01_00" taborder="10" text="[운영근거]&#13;&#10;・ 초·중등교육법 제30조의 4,5 &#13;&#10;・ 교육기본법 제 23의 2&#13;&#10;・ 유아교육정보시스템 및 교육정보시스템의 &#13;&#10;운영 등에 관한 규칙 제8조, 제9조" top="65" height="129" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" textAlign="center" width="301" left="226" letterSpacing="-1px"/>
                    <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_00" taborder="11" left="0" top="253" height="16" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
                    <Static id="sta00_02_01_00_01_00_00" taborder="12" text="[처리목적]&#13;&#10;「학생서비스, 학부모서비스」 운영 관리" top="205" height="50" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" textAlign="center" width="301" left="226"/>
                    <Static id="sta00_02_01_00_01_00_00_00" taborder="13" text="[선택]&#13;&#10;이메일, 연락처(일반, 핸드폰)" left="600" top="205" height="50" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" textAlign="center" width="301"/>
                    <Static id="sta00_02_01_00_01_00_01" taborder="14" text="[필수]&#13;&#10;・ 학생서비스 : 성명, 아이디, 본인확인값(CI), &#13;&#10;생년월일, 학교, 학년, 반, 번호, 계열&#13;&#10;・ 학부모서비스 : 성명, 아이디, 본인확인값(CI),&#13;&#10;생년월일" left="600" top="65" height="129" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" textAlign="center" width="301"/>
                    <Static id="sta00_02_01_00_01_01" taborder="15" text="가입 후 회원 탈퇴시 까지" left="951" top="68" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" textAlign="center" width="187"/>
                  </Layout>
                </Layouts>
              </Div>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_00_00" taborder="62" left="30" top="612" height="60" cssclass="sta_GD_Size" text="60" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="sta00_02_01_00_01_00" taborder="5" text="※기타 「학생서비스, 학부모서비스」의 개인정보파일에 기록된 내용의 공개는 개인정보보호위원회 개인정보보호포털" left="30" top="664" width="790" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="false"/>
              <ImageViewer id="imgTitle00" taborder="9" text="제2조(개인정보의 처리 및 보유기간)" left="28" top="736" height="30" cssclass="img_WF_Txt16B" width="252" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01" taborder="63" left="30" top="713" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="sta00_02_01_00_00_00" taborder="10" text="① 「학생서비스, 학부모서비스」는 관계 법령에 따른 개인정보 보유·이용기간 또는 정보주체로부 터 개인정보를 수집 시에 동의 받은 개인정보 보유·이용기간내에서 &#13;&#10;개인정보를 처리·보유합니다." left="30" top="760" width="1129" height="50" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_00" taborder="64" left="30" top="759" height="8" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01" taborder="65" left="30" top="805" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="sta00_02_01_00_00_00_00" taborder="11" text="② 서비스별 개인정보 처리 및 보유 기간은 다음과 같습니다.&#13;&#10;1. 학생서비스 개인정보&#13;&#10;   - 보유근거 : 교육기본법, 초중등교육법, 유아교육정보시스템의 운영 등에 관한 규칙&#13;&#10;   - 보유목적 : 학생서비스 이용(학생본인정보 열람 등)&#13;&#10;   - 보유기간 : 회원가입 후 탈퇴시까지&#13;&#10;2. 학부모서비스 개인정보&#13;&#10;   - 보유근거 : 교육기본법, 초중등교육법, 유아교육정보시스템의 운영 등에 관한 규칙&#13;&#10;   - 보유목적 : 학부모서비스의 이용(자녀정보열람 등)&#13;&#10;   - 보유기간 : 회원가입 후 탈퇴시까지" left="30" top="824" width="1129" height="230" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_02_01_00_01_00_00" taborder="6" text="(www.privacy.go.kr)" left="814" top="664" width="157" height="30" cssclass="sta_WF_PolicyLink" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
              <Static id="sta00_02_01_00_01_00_01" taborder="8" text="→ 개인정보열람등 요구 → 개인정보파일 목록검색 메뉴를 활용해주시기 바랍니다." left="30" top="687" width="650" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="false"/>
              <Static id="sta00_02_01_00_01_00_01_00" taborder="7" text="→ 민원마당 → " left="975" top="664" width="135" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="false"/>
              <Static id="sta00_02_01_00_00_00_00_00" taborder="12" text="③ 다음의 사유에 해당하는 경우에는 해당 사유 종료시까지 개인정보를 처리·보유합니다.&#13;&#10;1) 관계 법령 위반에 따른 수사·조사 등이 진행중인 경우에는 해당 수사·조사 종료시까지&#13;&#10;2) 홈페이지 이용에 따른 채권·채무관계 잔존시에는 해당 채권·채무관계 정산시까지" left="30" top="1055" width="1129" height="100" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00" taborder="66" left="30" top="1045" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="sta00_02_01_00_00_00_00_00_00" taborder="13" text="④ 기존회원의 경우 최종접속일로부터 1년동안 로그인한 기록이 없을 경우 휴면회원으로 전환됩니다." left="30" top="1161" width="1129" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00" taborder="67" left="30" top="1139" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="sta00_02_01_00_00_00_00_00_00_00" taborder="14" text="⑤ 휴면회원 전환 이후 1년까지 추가로 로그인한 기록이 없는 경우 해당 회원을 회원자격 상실시킬 수 있습니다." left="30" top="1208" width="1129" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00_00" taborder="68" left="30" top="1186" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="sta00_02_01_00_00_00_00_00_00_00_00" taborder="15" text="⑥ 고등학교 3학년 졸업 학생의 경우 졸업 이후 해당년도 3월 1일자로 해당 회원을 회원자격 상실시킬 수 있습니다." left="30" top="1255" width="1129" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00_00_00" taborder="69" left="30" top="1233" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <ImageViewer id="imgTitle00_00" taborder="16" text="제3조(개인정보의 제3자 제공)" left="28" top="1303" height="30" cssclass="img_WF_Txt16B" width="213" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00_00_00_00" taborder="70" left="30" top="1279" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="sta00_02_01_00_00_00_00_00_00_00_00_00" taborder="17" text="①「학생서비스, 학부모서비스」는 정보주체의 동의, 법률의 특정한 규정 등 개인정보 보호법 제17 조 및 제18조에 해당하는 경우에만 개인정보를, 제3자에게 제공합니다." left="30" top="1327" width="1129" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00_00_00_00_00" taborder="71" left="30" top="1351" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="sta00_02_01_00_00_00_00_00_00_00_00_00_00" taborder="19" text="① 「학생서비스, 학부모서비스」는 원활한 개인정보 업무처리를 위한 본인확인 업무 수행을 위해 개인정보 처리업무를 다음과 같이 위탁하고 있으며, 업무 처리를 위해 &#13;&#10;위탁한 개인정보는 별도로 저장하지 않습니다." left="30" top="1400" width="1129" height="50" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <ImageViewer id="imgTitle00_00_00" taborder="18" text="제4조(개인정보처리의 위탁)" left="28" top="1374" height="30" cssclass="img_WF_Txt16B" width="198" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_00_00_00_00_00_00_00_00_00_00_00" taborder="20" text="1. 본인확인서비스&#13;&#10;위탁받는 자 (수탁자) : SCI평가정보(주)&#13;&#10;위탁하는 업무의 내용 : 회원정보관리를 위한 본인 확인 등 &#13;&#10;위탁기간 : 위탁계약 종료 시까지&#13;&#10;2. 학생학부모용 인증서 발급서비스 위탁받는 자 (수탁자) : 한국정보인증(KICA)&#13;&#10;위탁하는 업무의 내용 : 인증서 발급을 위한 본인 확인 등 &#13;&#10;위탁기간 : 위탁계약 종료 시까지&#13;&#10;3. 나이스 대국민서비스 운영 및 유지관리 위탁받는 자 (수탁자) : SGA(주)&#13;&#10;위탁하는 업무의 내용 : 나이스 대국민서비스 운영 및 유지관리 &#13;&#10;위탁기간 : 위탁계약 종료 시까지&#13;&#10;4. 나이스 정보시스템 운영 및 유지관리 &#13;&#10;위탁받는 자 (수탁자) : 링네트(주)&#13;&#10;위탁하는 업무의 내용 : 정보시스템 통합 위탁운영 및 유지관리 &#13;&#10;위탁기간 : 위탁계약 종료 시까지" left="30" top="1448" width="720" height="345" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <ImageViewer id="imgTitle00_00_00_00" taborder="21" text="제5조(정보주체의 권리·의무 및 행사방법)" left="28" top="1811" height="30" cssclass="img_WF_Txt16B" width="283" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_00_00_00_00_00_00_00_00_00_00_01" taborder="22" text="① 정보주체는 「학생서비스, 학부모서비스」에 대해 다음 각 호에 해당하는 경우 개인정보 보호 관 련 권리를 행사할 수 있습니다.&#13;&#10;1. 개인정보 열람요구&#13;&#10;2. 오류 등이 있을 경우 정정 요구&#13;&#10;3. 삭제요구&#13;&#10;4. 처리정지 요구&#13;&#10;② 제1항에 명시한 권리는 「학생서비스, 학부모서비스」에 대해 개인정보 처리 방법에 관한 고시 별지 제8호 서식에 따라 서면, 전자우편, 모사전송(FAX) 등을 통하여 요구하실 수 있으며 &#13;&#10;「학생 서비스, 학부모서비스」는 이에 대해 지체없이 조치하겠습니다." left="30" top="1834" width="1129" height="177" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00_00_00_00_00_00" taborder="72" left="30" top="1788" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Edit id="edt00" taborder="23" left="30" top="2004" width="527" height="30" cssclass="edi_WF_InputTxt16" initvalueid="ivEdtReadOnly" readonly="true" value="1. 전자우편 : mykim@keris.or.kr, dain31@keris.or.kr로 접수" text="1. 전자우편 : mykim@keris.or.kr, dain31@keris.or.kr로 접수"/>
              <Edit id="edt00_00" taborder="24" left="30" top="2029" width="250" height="30" cssclass="edi_WF_InputTxt16" initvalueid="ivEdtReadOnly" readonly="true" value="2. FAX : 053-714-0195로 접수" text="2. FAX : 053-714-0195로 접수"/>
              <Static id="sta00_02_01_00_00_00_00_00_00_00_00_00_00_01_00" taborder="25" text="③ 정보주체가 개인정보의 오류 등에 대한 정정 또는 삭제를 요구한 경우에는 「학생서비스, 학부 모서비스」는 정정 또는 삭제를 완료할 때까지 당해 개인정보를 &#13;&#10;이용하거나 제공하지 않습니다.&#13;&#10;④ 회원정보 조회/변경 기능&#13;&#10;로그인을 한 후 회원마당 &gt; 회원정보수정 &gt; 정보조회/정보수정 메뉴에서 회원정보 조회 및 수정할 수 있습니다.&#13;&#10;⑤ 회원탈퇴 기능&#13;&#10;로그인을 한 후 회원마당 &gt; 회원정보수정 &gt; 회원탈퇴 메뉴에서 회원탈퇴를 할 수 있습니다." left="30" top="2052" width="1129" height="153" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00_00_00_00_00_00_00" taborder="73" left="30" top="2199" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <ImageViewer id="imgTitle00_00_00_00_00" taborder="26" text="제6조(처리하는 개인정보 항목)" left="28" top="2222" height="30" cssclass="img_WF_Txt16B" width="217" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_00_00_00_00_00_00_00_00_00_00_01_00_00" taborder="27" text="① 「학생서비스, 학부모서비스」는 다음의 개인정보 항목을 처리하고 있습니다.&#13;&#10;&lt; 학생서비스 &gt;&#13;&#10;필수항목 : 이름, 아이디, 비밀번호, 학교명, 과정, 학년, 신청일자, 반, 번호, 주야, 계열, 학과, 생 년월일&#13;&#10;선택항목 : 이메일, 연락처(일반, 핸드폰), SMS수신여부&#13;&#10;&lt; 학부모서비스 &gt;&#13;&#10;필수항목 : 이름, 아이디, 비밀번호, 학부모 및 학생서비스 이용 유무사항 선택항목 : 이메일, 연락처(일반, 핸드폰), SMS수신여부&#13;&#10;「학생서비스, 학부모서비스」이용과정에서 아래 개인정보 항목이 자동으로 생성되어 수집될 수 있습니다.&#13;&#10;IP 주소, 쿠키, 방문 일시, 서비스 이용 기록, 가입인증정보 등&#13;&#10;② 「학부모서비스」 이용 시 다음과 같은 개인정보가 추가로 수집될 수 있습니다." left="30" top="2235" width="1129" height="248" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Div id="div00_00" taborder="28" text="div00" left="30" top="2527" height="119" right="30" initvalueid="ivDivAccessibilityOff">
                <Layouts>
                  <Layout>
                    <Static id="sta00" taborder="0" text="분류" left="0" top="0" width="202" height="60" cssclass="sta_WF_PolicyDtlG" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta00_00" taborder="1" text="서비스명" left="201" top="0" width="370" height="60" cssclass="sta_WF_PolicyDtlG" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta00_00_00_00" taborder="2" text="추가로 수집하는 개인정보 항목" top="0" width="570" cssclass="sta_WF_PolicyDtlG" initvalueid="ivStcAccessibilityOn" height="60" right="0"/>
                    <Static id="sta00_01" taborder="3" left="0" top="59" width="202" cssclass="sta_WF_PolicyDtlW" initvalueid="ivStcAccessibilityOn" text="학부모서비스" height="60"/>
                    <Static id="sta00_00_01" taborder="4" left="201" top="59" width="370" cssclass="sta_WF_PolicyDtlW" initvalueid="ivStcAccessibilityOn" height="60" text="학부모서비스 신청 자녀등록"/>
                    <Static id="sta00_00_00_00_00" taborder="5" top="59" width="570" cssclass="sta_WF_PolicyDtlW" initvalueid="ivStcAccessibilityOn" height="60" right="0" text="자녀이름, 생년월일, 학교명, 관계, 학년도, 학년, 과정, 계열, 학과, 반, 번호"/>
                    <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_00" taborder="6" left="0" top="253" height="16" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
                  </Layout>
                </Layouts>
              </Div>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00_00_00_00_00_00_00_00" taborder="74" left="30" top="2467" height="60" cssclass="sta_GD_Size" text="60" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00_00_00_00_00_00_00_00_00" taborder="75" left="30" top="2646" height="60" cssclass="sta_GD_Size" text="60" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="sta00_02_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00" taborder="29" text="③ 이용자는 나이스 대국민서비스 회원가입 및 관리를 위한 개인정보 수집에 대하여 거부할 수 있습니다.&#13;&#10;&lt;b v='true'&gt;1. 다만, 제1조 제2항의 필수항목은 나이스 대국민서비스 이용에 필요한 최소한의 정보이므로 이에 대한 수집 거부 시 회원가입이 제한됩니다.&#13;&#10;2. 쿠키(Cookie)는 웹사이트를 접속할 때 자동적으로 만들어지는 임시 파일로서 이용자의 정보 를 담고 있습니다. 이용자는 쿠키의 설치 및 수집에 대해 선택권으로 가지고 있으며 수집을 거부 할 수 있습니다. 다만, 쿠키의 저장을 거부할 경우 로그인을 필요로 하는 서비스 제공에 어려움이 있습니다.&lt;/b&gt;" left="30" top="2692" width="1129" height="115" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
              <Static id="sta00_02_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00" taborder="30" text="1) 쿠키 설정 거부 방법" left="30" top="2817" width="200" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00_00_00_00_00_00_00_00_00_00" taborder="76" left="30" top="2794" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="sta00_02_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00" taborder="31" text="&lt;Internet Explorer&gt;&#13;&#10;웹 브라우저 상단 도구 &gt; 인터넷 옵션 &gt; 개인정보 &gt; 고급 개인정보 설정" left="30" top="2862" width="561" height="60" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00_00_00_00_00_00_00_00_00_00_00" taborder="77" left="30" top="2843" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00_00_00_00_00_00_00_00_00_00_00_00" taborder="78" left="30" top="2913" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="sta00_02_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00" taborder="32" text="&lt;Chrome&gt;&#13;&#10;웹 브라우저 우측 상단 아이콘(크롬 맞춤설정 제어) &gt; 설정 &gt; 맨 하단 고급설정표시 &gt; 개인정보 섹션의 콘텐츠 설정 버튼 &gt; 쿠키 섹션에서 직접 설정" left="30" top="2932" width="1030" height="60" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00_00_00_00_00_00_00_01" taborder="79" left="30" top="2982" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <ImageViewer id="imgTitle00_00_00_00_00_00" taborder="33" text="제7조(개인정보의 파기)" left="28" top="3005" height="30" cssclass="img_WF_Txt16B" width="165" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_00_00_00_00_00_00_00_00_00_00_01_00_00_01" taborder="34" text="① 「학생서비스, 학부모서비스」는 개인정보 보유기간의 경과, 처리목적 달성 등 개인정보가 불필 요하게 되었을 때에는 지체없이 해당 개인정보를 파기합니다.&#13;&#10;② 정보주체로부터 동의 받은 개인정보 보유기간이 경과하거나 처리목적이 달성되었음에도 불구 하고 다른 법령에 따라 개인정보를 계속 보존하여야 하는 경우에는, 해당&#13;&#10;개인정보(또는 개인정보파일)을 별도의 데이터베이스(DB)로 옮기거나 보관장소를 달리하여 보 존합니다.&#13;&#10;③ 개인정보 파기의 절차 및 방법은 다음과 같습니다.&#13;&#10;1. 파기절차&#13;&#10;「학생서비스, 학부모서비스」는 파기하여야 하는 개인정보(또는 개인정보파일)에 대해 개인정보 파기계획을 수립하여 파기합니다. 「학생서비스, 학부모서비스」는 파기&#13;&#10;사유가 발생한 개인정보(또 는 개인정보파일)를 선정하고, 「학생서비스, 학부모서비스」의 개인정보 보호책임자의 승인을 받 아 개인정보(또는 개인정보파일)를 파기합니다." left="30" top="3028" height="178" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" width="1139"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00_00_00_00_00_00_00_01_00" taborder="80" left="30" top="3030" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="sta00_02_01_00_00_00_00_00_00_00_00_00_00_01_00_00_01_00" taborder="35" text="2. 파기방법&#13;&#10;「학생서비스, 학부모서비스」는 전자적 파일 형태로 기록·저장된 개인정보는 기록을 재생할 수 없도록 파기하며, 종이 문서에 기록·저장된 개인정보는 분쇄기로 분쇄하거나&#13;&#10;소각하여 파기합니다." left="30" top="3222" height="73" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" width="1129"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00_00_00_00_00_00_00_01_00_00" taborder="81" left="30" top="3200" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00_00_00_00_00_00_00_01_01" taborder="82" left="30" top="3290" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <ImageViewer id="imgTitle00_00_00_00_00_00_00" taborder="36" text="제8조(개인정보의 안전성 확보조치)" left="28" top="3312" height="30" cssclass="img_WF_Txt16B" width="247" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_00_00_00_00_00_00_00_00_00_00_01_00_00_01_00_00" taborder="37" text="① 「학생서비스, 학부모서비스」는 개인정보의 안전성 확보를 위해 다음과 같은 조치를 취하고 있 습니다.&#13;&#10;1. 관리적 조치 : 내부관리계획 수립·시행, 정기적 직원 교육 등&#13;&#10;2. 기술적 조치 : 개인정보처리시스템 등의 접근권한 관리, 접근통제시스템 설치, 고유식별정보 등의 암호화, 보안프로그램 설치&#13;&#10;3. 물리적 조치 : 전산실, 자료보관실 등의 접근통제" left="30" top="3336" height="103" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" width="1129"/>
              <ImageViewer id="imgTitle00_00_00_00_00_00_00_00" taborder="38" text="제9조(개인정보 보호책임자)" left="28" top="3475" height="30" cssclass="img_WF_Txt16B" width="195" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_00_00_00_00_00_00_00_00_00_00_01_00_00_01_00_00_00" taborder="39" text="① 「학생서비스, 학부모서비스」는 개인정보 처리에 관한 업무를 총괄해서 책임지고, 개인정보 처리와 관련한 정보주체의 불만처리 및 피해구제 등을 위하여 아래와 같이&#13;&#10;개인정보 보호책임자를 지정하고 있습니다.&#13;&#10;1. 교육부&#13;&#10;개인정보책임자 : 교육안전정보국장 &#13;&#10;개인정보담당자 : 교육정보화과 나이스 담당자&#13;&#10;2. 한국교육학술정보원&#13;&#10;개인정보 보호책임자 : 정보보호본부장 권성호(053-714-0234) &#13;&#10;개인정보 분야별책임자 : 교육행정본부장 이두영(053-714-0248)&#13;&#10;학생/학부모서비스 분야별담당자 : 나이스대국민부장 곽재윤(053-714-0318), 선임연구원 김민영(053-714-0329)&#13;&#10;3. 시도교육청&#13;&#10;개인정보 보호책임자 및 취급자는 시도교육청 홈페이지를 참고하시기 바랍니다.&#13;&#10;② 정보주체께서는 「학생서비스, 학부모서비스」의 서비스(또는 사업)를 이용하시면서 발생한 모든 개인정보 보호 관련 문의, 불만처리, 피해구제 등에 관한 사항을 &#13;&#10;개인정보 보호책임자 및 담당 부서로 문의하실 수 있습니다. 「학생서비스, 학부모서비스」는 정보주체의 문의에 대해 지체 없이 답변 및 처리해드릴 것입니다." left="30" top="3497" height="324" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" width="1129"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00_00_00_00_00_00_00_01_01_00" taborder="83" left="30" top="3453" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00_00_00_00_00_00_00_01_01_00_00" taborder="84" left="30" top="4013" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="sta00_02_01_00_00_00_00_00_00_00_00_00_00_01_00_00_01_00_00_00_00" taborder="51" text="※ 행정심판에 대해 자세한 사항은 중앙행정심판위원회" left="30" top="4082" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" width="370"/>
              <Static id="sta00_02_01_00_01_00_00_00_00_00" taborder="52" text="(www.simpan.go.kr)" left="396" top="4082" width="157" height="30" cssclass="sta_WF_PolicyLink" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
              <Static id="sta00_02_01_00_00_00_00_00_00_00_00_00_00_01_00_00_01_00_00_00_00_00" taborder="53" text="홈페이지를 참고 하시기 바랍니다." left="555" top="4082" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" width="263"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00_00_00_00_00_00_00_01_01_00_01" taborder="85" left="30" top="3812" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <ImageViewer id="imgTitle00_00_00_00_00_00_00_00_00" taborder="40" text="제10조(권익침해 구제방법)" left="28" top="3833" height="30" cssclass="img_WF_Txt16B" width="189" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_00_01_00_02" taborder="41" text="정보주체는 개인정보침해로 인한 구제를 받기 위하여 개인정보분쟁조정위원회, 한국인터넷진흥원 개인정보침해신고센터 등에 분쟁해결이나 상담 등을 신청할 수 있습니다.&#13;&#10;이 밖에 기타 개인정보침해의 신고, 상담에 대하여는 아래의 기관에 문의하시기 바랍니다." left="30" top="3858" height="50" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="false" right="30"/>
              <ImageViewer id="imgTitle00_00_00_00_00_00_00_00_00_00" taborder="54" text="제11조(개인정보 처리방침 변경)" left="28" top="4129" height="30" cssclass="img_WF_Txt16B" width="222" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00_00_00_00_00_00_00_01_01_00_01_00" taborder="86" left="30" top="4107" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="sta00_02_01_00_00_00_00_00_00_00_00_00_00_01_00_00_01_00_00_00_00_01" taborder="55" text="① 이 개인정보 처리방침은 2022. 1. 24. 부터 적용됩니다." left="30" top="4158" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" width="450"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00_00_00_00_00_00_00_01_01_00_01_00_00" taborder="87" left="30" top="4182" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100" height="30"/>
              <Static id="sta00_02_01_00_01_00_00_00" taborder="43" text="(www.kopico.go.kr)" left="384" top="3907" width="157" height="30" cssclass="sta_WF_PolicyLink" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
              <Static id="sta00_02_01_00_01_00_03" taborder="42" text="1. 개인정보분쟁조정위원회 : (국번없이) 1833-6972" left="30" top="3907" width="355" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="false"/>
              <Static id="sta00_02_01_00_01_00_00_00_00" taborder="45" text="(privacy.kisa.or.kr)" left="318" top="3934" width="157" height="30" cssclass="sta_WF_PolicyLink" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
              <Static id="sta00_02_01_00_01_00_01_01" taborder="44" text="2. 개인정보침해신고센터 : (국번없이) 118" left="30" top="3934" width="280" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="false"/>
              <Static id="sta00_02_01_00_01_00_00_00_00_01" taborder="47" text="(www.spo.go.kr)" left="238" top="3961" width="157" height="30" cssclass="sta_WF_PolicyLink" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
              <Static id="sta00_02_01_00_01_00_01_00_00" taborder="46" text="3. 대검찰청 : (국번없이) 1301 " left="30" top="3961" width="210" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="false"/>
              <Static id="sta00_02_01_00_01_00_00_00_00_00_00" taborder="49" text="(cyberbureau.police.go.kr)" left="217" top="3988" width="227" height="30" cssclass="sta_WF_PolicyLink" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
              <Static id="sta00_02_01_00_01_00_01_00_00_00" taborder="48" text="4. 경찰청 : (국번없이) 182" left="30" top="3988" width="183" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="false"/>
              <Static id="sta00_02_01_00_00_00_00_00_00_00_00_00_00_01_00_00_01_00_00_00_01" taborder="50" text="「개인정보보호법」제35조(개인정보의 열람), 제36조(개인정보의 정정·삭제), 제37조(개인정보의 처리정지 등)의 규정에 의한 요구에 대하여 공공기관의 장이 &#13;&#10;행한 처분 또는 부작위로 인하여 권리 또는 이익의 침해를 받은 자는 행정심판법이 정하는 바에 따라 행정심판을 청구할 수 있습니다." left="30" top="4033" height="54" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" width="1129"/>
            </Layout>
          </Layouts>
        </Div>
