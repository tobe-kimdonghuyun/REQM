                          <Band id="head">
                            <Cell text="04"/>
                            <Cell col="1" colspan="2" text="정서·행동특성 영역별 설명 및 해석" textAlign="left" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                          </Band>
                          <Band id="body">
                            <Cell colspan="2" text="정서·행동특성" cssclass="TitB"/>
