              <Static id="sta00" taborder="2" left="29" top="65" width="510" height="21" cssclass="sta_WF_Black14" text="본인은 위 목적으로 본인의 개인정보를 수집하는 것에 동의합니다." usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta01_00" taborder="3" text="고유식별 정보동의" left="28" top="119" width="220" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
