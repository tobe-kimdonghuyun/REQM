<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmTemp01" width="800" height="890" titletext="교원 사전동의서상세p141(텍스트박스+알림텍스트+버튼)" onload="frmTemp01_onload">
    <Layouts>
      <Layout height="890" width="800" screenid="ScreenDeskTop">
        <Static id="sta00" taborder="0" left="18" top="17" height="65" cssclass="sta_WF_Black14" text="본인은 계약제교원 임용에 있어 &lt;b v='true'&gt;교육공무원법&lt;/b&gt; 제32조 및 제10조의 4에 의거 결격사유 해당 여부를 조회 할 필요가 있다는 것과 개인정보 수집 목적 등 아래 사항을 이해하였으며, 이를 위해 &lt;b v='true'&gt;개인정보 보호법&lt;/b&gt; 제15조에 따라 OOO교육청 및 결격사유 조회 기관에 제공하는데 동의 합니다." usedecorate="true" right="10" initvalueid="ivStcAccessibilityOn"/>
        <Div id="div00" taborder="1" left="20" height="331" cssclass="div_WF_InfoBOX" right="20" top="114" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="sta01" taborder="0" text="수집·이용에 관한 사항" left="29" top="31" width="220" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00" taborder="1" left="29" top="65" width="200" height="21" cssclass="sta_WF_Black14" text="가. 수집·이용 목적" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00_01_01" taborder="2" left="29" top="96" height="49" cssclass="sta_WF_InfoTxt" text="「교육공무원법」제32조 및 제10조 4에 따른기간제교원 임용에 관한 결격사유 조회 기간에 제공하는데 &#13;&#10;동의합니다. " wordWrap="char" right="25" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00" taborder="3" left="29" top="164" width="200" height="21" cssclass="sta_WF_Black14" text="나. 보유기간" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00_01_01_00" taborder="4" left="29" top="198" height="19" cssclass="sta_WF_InfoTxt" text="수집된 개인정보는 「공공기록물 관리에 관한 법률」에 따라 보유 폐기됩니다." wordWrap="char" right="25" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00_00" taborder="5" left="29" top="240" width="200" height="21" cssclass="sta_WF_Black14" text="다. 수집항목" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00_01_01_00_00" taborder="6" left="29" top="276" height="19" cssclass="sta_WF_InfoTxt" text="고유식별정보(주민등록번호), 성명, 주소, 등록기준지" wordWrap="char" right="25" initvalueid="ivStcAccessibilityOn"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00" taborder="7" left="0" top="0" height="35" cssclass="sta_GD_Size" text="35" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
