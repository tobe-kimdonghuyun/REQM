              <Static id="sta00_00" taborder="5" left="28" top="153" height="41" cssclass="sta_WF_Black14" text="본인은 OOOO교육청 및 교육지원청, 관할 각급학교가 위 목적으로 다음과 같은 본인의 고유 식별정보를 &#13;&#10;수집·이용하는 것에 동의합니다." usedecorate="true" right="30" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00_01_01_00_00" taborder="6" left="29" top="208" height="19" cssclass="sta_WF_InfoTxt" text="고유식별정보 : 주민등록번호(주민등록번호 법령근거 : 개인정보 보호법 제24조)" wordWrap="char" right="27" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta02" taborder="7" left="30" top="103" height="1" cssclass="sta_WF_SectionLine" right="30" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
