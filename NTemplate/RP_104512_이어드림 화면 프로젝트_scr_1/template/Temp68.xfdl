<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmTemp01" width="1200" height="2116" titletext="유치원-국민행복카드 발급방법" onload="frmTemp01_onload">
    <Layouts>
      <Layout height="2116" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="55" height="54" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="국민행복카드 발급방법" left="0" top="0" height="54" cssclass="img_WF_SubTit01" width="310" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00" taborder="1" text="(3가지 방법 중 택일)" left="317" top="14" width="180" height="30" cssclass="sta_WF_GrayTxt20" initvalueid="ivStcAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta00" taborder="1" left="0" top="144" width="140" height="140" initvalueid="ivStcAccessibilityOff" background="url('theme://images/sta_WF_Center.png') no-repeat center center"/>
        <Static id="sta00_01" taborder="2" text="주민센터 방문" left="163" top="175" width="165" height="36" cssclass="sta_WF_Txt24" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_01_00" taborder="3" text="읍, 면, 동 주민센터를 방문하여 지원자격신청 및 카드발급 신청" left="163" top="214" width="537" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_00" taborder="4" left="0" top="318" width="140" height="140" initvalueid="ivStcAccessibilityOff" background="url('theme://images/sta_WF_notebook.png') no-repeat center center"/>
        <Static id="sta00_01_01" taborder="5" text="복지로 사이트" left="162" top="348" width="165" height="36" cssclass="sta_WF_Txt24" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_01_00_00" taborder="6" text="인터넷으로 복지로 사이트(http://www.bokjiro.go.kr)에 접속하여 온라인으로 신청" left="162" top="388" width="718" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_00_00" taborder="7" left="0" top="492" width="140" height="140" initvalueid="ivStcAccessibilityOff" background="url('theme://images/sta_WF_bank.png') no-repeat center center"/>
        <Static id="sta00_01_01_00" taborder="8" text="금융기관 영업점" left="161" top="521" width="175" height="36" cssclass="sta_WF_Txt24" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_01_00_00_00" taborder="9" text="KB국민카드 우리카드 하나카드 NH농협카드 신한카드 롯데카드 비씨카드 삼성카드" left="161" top="561" width="609" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
        <Div id="div00" taborder="10" text="div00" left="0" top="672" height="200" width="1200" initvalueid="ivDivAccessibilityOff" cssclass="div_WF_KinderBox">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" text="꼭 기억하세요!!" left="40" top="34" width="224" height="36" cssclass="sta_WF_KinderCautn" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_01_00_00_00" taborder="1" text="1. 유치원을 타 지역으로 이동하는 경우에도 최초 발급받은 카드로 사용이 가능합니다." left="306" top="32" width="609" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_01_00_00_00_00" taborder="2" text="2. 2명 이상의 자녀가 지원을 받는 경우에도 국민행복카드는 하나만 발급받으시면 됩니다." left="306" top="66" width="609" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_01_00_00_00_00_00" taborder="3" text="3. 유치원 등록은 금융기관 영업점에서 국민행복카드 발급 다음날부터 사용이 가능합니다." left="306" top="100" width="609" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_01_00_00_00_00_00_00" taborder="4" text="4. 재발급의 경우 금융기관의 고객관리 정책에 따른 재발급 수수료가 부과됩니다." left="306" top="134" width="609" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="Static99_00_00_00_00_00_00_02_00" taborder="5" left="40" top="0" height="40" cssclass="sta_GD_Size" text="40" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="860"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_01" taborder="6" left="336" top="55" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="564"/>
            </Layout>
          </Layouts>
        </Div>
        <ImageViewer id="imgTitle" taborder="11" text="카드발급처 안내" left="0" top="943" height="40" cssclass="img_WF_SubTit02" width="170" initvalueid="ivTitleAccessibilityOn"/>
