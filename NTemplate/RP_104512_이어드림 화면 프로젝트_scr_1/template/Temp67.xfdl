        <ImageViewer id="imgTitle" taborder="1" text="유치원에 계속 재원하는 경우" left="0" top="156" height="40" cssclass="img_WF_SubTit02" width="290" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_00" taborder="2" text="‘국민행복카드’ 신규발급 받거나 기존 사용중인 ‘ 아이즐거운카드’, ‘아이행복카드’ 사용가능" left="0" top="198" width="628" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_00_00" taborder="3" text="※ 기존 아이즐거운카드 중 현금 IC카드는 2016년 2월 29일까지 사용가능" left="0" top="222" width="628" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
