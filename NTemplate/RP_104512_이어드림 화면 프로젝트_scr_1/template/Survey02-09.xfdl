                          </Div>
                          <Div id="div01" taborder="2" left="0" top="div00_00:0" height="100" right="0" cssclass="div_WF_S02FAQBox_A01" initvalueid="ivDivAccessibilityOff">
                            <Layouts>
                              <Layout>
                                <Static id="sta00" taborder="0" text="롯데오너스 혜택은 다른 혜택들과 중복 적용 가능합니다.&#13;&#13;&#10;단, 제휴사 및 할인쿠폰 혜택은 각 상품별 운영 방침에 따라 적용될 수 있으므로 제휴 혜택 페이지과 쿠폰 유의 사항을 확인해 주셔야 하며, &#13;상품상세의 &quot;할인적용&quot;을 통해 할인적용을 완료하고 주문서에서 최종 적용 여부를 확인해주셔야 합니다." left="30" top="0" cssclass="sta_WF_S02FAQ_A" initvalueid="ivStcAccessibilityOn" bottom="0" wordWrap="char" right="100"/>
                                <Static id="Static99_00_00_00_00_01_00_00_01" taborder="1" left="0" top="0" cssclass="sta_WF_GDSize" text="30" visible="false" initvalueid="ivStcAccessibilityOff" width="30" height="98"/>
