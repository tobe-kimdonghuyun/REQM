                          <Div id="div00_00" taborder="1" left="0" top="div00:0" height="68" right="0" cssclass="div_WF_S02FAQBox_Q03" text="" initvalueid="ivDivAccessibilityOff">
                            <Layouts>
                              <Layout>
                                <Static id="sta00" taborder="0" text="자녀 확인정보(학교, 학년, 반, 참여번호)를 입력하고 버튼을 클릭 시 “학생의 학적정보(학년, 반)와 입력하신 참여번호가 달라 자녀를 조회 할 수 없으니, &#13;해당학교로 문의 하시기 바랍니다.” 라는 메시지가 나옵니다." left="30" top="0" cssclass="sta_WF_S02FAQ_Q" initvalueid="ivStcAccessibilityOn" bottom="0" wordWrap="char" right="100"/>
                                <Button id="btn00" taborder="1" top="0" width="80" cssclass="btn_WF_FAQDropup" right="0" initvalueid="ivBtnAccessibilityButton" bottom="0"/>
                              </Layout>
                              <Layout name="Layout0">
