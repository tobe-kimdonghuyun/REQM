<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmTemp01" width="1200" titletext="[M]교육비원클릭(신청대상여부조회)" onload="frmTemp01_onload" height="1740">
    <Layouts>
      <Layout height="1740" width="1200" screenid="ScreenDeskTop">
        <Static id="sta01_00_00_01_01" taborder="0" text="&lt;b v='true'&gt;신청 대상 여부 조회 기능이란?&lt;/b&gt;" left="8" top="204" width="250" height="35" cssclass="sta_WF_Info16Blue" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
        <Div id="div00_00" taborder="16" left="0" top="239" right="0" initvalueid="ivDivAccessibilityOff" cssclass="div_WF_GrayBg" formscrollbartype="none none" height="95">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" text="매년 교육비를 신청해야 하는 불편을 덜어드리고자 전년도에 교육비를 지원 받은 학생은 차년도에 교육비를 신청한 것으로 간주하여 처리되므로&#13;&#10;별도로 신청을 할 필요가 없습니다. 따라서 학부모님께서는 신청대상여부조회 기능을 통해 해당 학생이 교육비 지원을 신청해야 하는지 여부를 확인할 수 있습니다." left="30" top="23" height="56" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="30"/>
            </Layout>
            <Layout name="default0">
              <Static id="sta00" taborder="0" text="매년 교육비를 신청해야 하는 불편을 덜어드리고자 전년도에 교육비를 지원 받은 학생은 차년도에 교육비를 신청한 것으로 간주하여 처리되므로&#13;&#10;별도로 신청을 할 필요가 없습니다. 따라서 학부모님께서는 신청대상여부조회 기능을 통해 해당 학생이 교육비 지원을 신청해야 하는지 여부를 확인할 수 있습니다." left="30" top="30" height="270" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="true" verticalAlign="top" right="30" fittocontents="height"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta01_00_00_01_01_00" taborder="1" text="&lt;b v='true'&gt;교육비 지원 신청 대상자 여부 확인 기준&lt;/b&gt;" left="0" top="374" width="308" height="35" cssclass="sta_WF_Info16Blue" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
        <Grid id="grd00_01" taborder="2" left="0" top="409" height="212" autosizingtype="none" autofittype="col" fillareatype="allrow" cssclass="grd_WF_Gray" initvalueid="ivGrdAccessibilityOn" right="0">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="118"/>
                <Column size="644"/>
                <Column size="442"/>
              </Columns>
              <Rows>
                <Row size="60" band="head"/>
                <Row size="75"/>
                <Row size="75"/>
              </Rows>
              <Band id="head">
                <Cell text="구분"/>
                <Cell col="1" text="신청이 필요 없는 학생"/>
                <Cell col="2" text="신청을 해야 하는 학생" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd;"/>
              </Band>
              <Band id="body">
                <Cell rowspan="2" text="대상"/>
                <Cell col="1" rowspan="2" text="      ㆍ  ‘21학년도에 교육비를 신청한 학생 중 교육비를 지원받은 학생’(21년 10월 기준)&#13;&#13;&#10;            ※ 심사 탈락 후 학교장 추천을 받은 경우 포함&#13;&#13;&#10;&#13;&#10;" textAlign="left" padding="40px 0px 0px 40px" font="normal 16px/1.6 &quot;Noto Sans KR&quot;,&quot;NotoSansKR-Regular&quot;,&quot;Malgun Gothic&quot;,&quot;Arial&quot;,&quot;MS PGothic&quot;"/>
                <Cell col="2" rowspan="2" displaytype="normal" text="ㆍ    ‘21학년도에 교육비를 지원받지 못한 학생&#13;&#10;ㆍ    &#13;교육비를 신청한적이 없는 학생&#13;&#10;ㆍ    &#13;’21년 10월 이후 선정되어 지원받은 학생" padding="30px 0px 20px 40px" textAlign="left" verticalAlign="middle" font="normal 16px/1.6 &quot;Noto Sans KR&quot;,&quot;NotoSansKR-Regular&quot;,&quot;Malgun Gothic&quot;,&quot;Arial&quot;,&quot;MS PGothic&quot;" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd;"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
