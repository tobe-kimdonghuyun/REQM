              <Static id="sta00_00_01_01" taborder="1" left="30" top="61" height="34" cssclass="sta_WF_Black14" text="※ 요청파일 작성시 다음과 같은 형식으로 작성하셔야 합니다." wordWrap="char" right="400" initvalueid="ivStcAccessibilityOn"/>
