              <Static id="sta00_00_01_01" taborder="1" left="30" top="65" height="24" cssclass="sta_WF_Red14" text="※ 수신PC의 사양에 맞게 수준을 설정하시면 수신 안정성이 향상됩니다.(PC사양이 높을수록 수신/안정성이 향상됩니다.)" wordWrap="char" right="400" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00_01_01_01_00" taborder="2" left="74" top="109" height="24" cssclass="sta_WF_InfoTxt" text="고사양(권장)" wordWrap="char" initvalueid="ivStcAccessibilityOn" width="82"/>
              <Static id="sta00_00_01_01_01_01" taborder="3" left="172" top="108" height="45" cssclass="sta_WF_Black14" text="- O/S : Windows7&#13;&#10;- &#13;CPU : Core i5 이상" wordWrap="char" initvalueid="ivStcAccessibilityOn" width="142"/>
              <Static id="sta00_00_01_01_01_00_00" taborder="4" left="364" top="109" height="24" cssclass="sta_WF_InfoTxt" text="중간사양" wordWrap="char" initvalueid="ivStcAccessibilityOn" width="82"/>
              <Static id="sta00_00_01_01_01_01_00" taborder="5" left="440" top="108" height="45" cssclass="sta_WF_Black14" text="- O/S : Windows7&#13;&#10;- &#13;CPU : Core 2Duo 등 듀얼Core 이상" wordWrap="char" initvalueid="ivStcAccessibilityOn" width="222"/>
              <Static id="sta00_00_01_01_01_00_00_00" taborder="6" left="739" top="109" height="24" cssclass="sta_WF_InfoTxt" text="저사양" wordWrap="char" initvalueid="ivStcAccessibilityOn" width="52"/>
              <Static id="sta00_00_01_01_01_01_00_00" taborder="7" left="805" top="108" height="45" cssclass="sta_WF_Black14" text="- O/S : WindowsXP&#13;&#10;- &#13;CPU : 펜티엄4 등 싱글Core 이하" wordWrap="char" initvalueid="ivStcAccessibilityOn" width="222"/>
              <Static id="sta00_00_01_01_02" taborder="8" left="29" top="173" height="24" cssclass="sta_WF_Red14" text="※ 두개 이상의 창을 띄워 여러개의 시도에서 동시에 수신 할 경우, 정상적으로 작동이되지 않을 수 있으므로 자료 수신은 반드시 하나의 창에서 한번씩 작업하시기 바랍니다.        " wordWrap="char" right="111" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00_01_01_02_00" taborder="9" left="30" top="201" height="24" cssclass="sta_WF_Blue14" text="※ 건수조회를 더블클릭하면, 해당 시도의 대상 건수를 조회합니다." wordWrap="char" right="400" initvalueid="ivStcAccessibilityOn"/>
