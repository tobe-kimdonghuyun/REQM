  <Form id="frmTemp01" width="780" height="597" titletext="[M]교육설문-학교폭력(설문참여_개인정보수집동의팝업)" onload="frmTemp01_onload" cssclass="frm_Pop_bgTrsprt">
    <Layouts>
      <Layout height="597" width="780" screenid="ScreenDeskTop">
        <Div id="div00" taborder="0" text="div00" left="30" top="30" height="537" width="720" cssclass="div_WF_SurvPopLine" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="sta01" taborder="0" text="개인정보 수집 및 동의" left="40" top="34" width="252" height="30" cssclass="sta_WF_Txt20B" initvalueid="ivStcAccessibilityOn"/>
              <Button id="btn01" taborder="1" top="31" width="36" height="36" cssclass="btn_WF_SurvPopClose" initvalueid="ivBtnAccessibilityButton" right="29"/>
              <Static id="sta01_00" taborder="2" text="「개인정보 보호법」 제15조 제 1항, 제2항에 의거하여 본인의 동의를 통한 개인정보를 수집·이용하고자 합니다. 수집하는 개인정보는 관련 목적외의 용도로 이용되거나 제3자에게 제공되지 않습니다.&#13;" left="40" top="80" height="50" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" right="40"/>
              <Static id="sta01_00_00" taborder="3" text="개인정보수집 및 이용 목적" left="40" top="176" height="30" cssclass="sta_WF_Txt16B" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" width="179"/>
              <Static id="sta01_00_00_01" taborder="4" text="학교폭력 신고 응답에 관한 정확한 사실관계 확인 및 신고(목격)자 상담 " left="40" top="197" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" width="439"/>
