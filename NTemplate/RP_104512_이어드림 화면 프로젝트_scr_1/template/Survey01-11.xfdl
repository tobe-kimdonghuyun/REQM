              <Static id="sta01_00_00_01_00" taborder="6" text="학년, 반, 번호, 이름" left="40" top="252" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" width="175"/>
              <Static id="sta01_00_00_00_00" taborder="7" text="개인정보수집 및 이용 기간 " left="40" top="286" height="30" cssclass="sta_WF_Txt16B" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" width="179"/>
              <Static id="sta01_00_00_01_00_00" taborder="8" text=" 학교폭력 실태조사 응답 후 해당학년도 종료 시까지 해당 학년도 종료시까지" left="40" top="307" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" width="471"/>
