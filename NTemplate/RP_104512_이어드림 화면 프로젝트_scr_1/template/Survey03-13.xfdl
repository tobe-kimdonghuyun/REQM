                    <Combo id="cbo00_00" taborder="3" text="홍길동 / 담임" left="60" top="139" width="527" height="40" initvalueid="ivCmbNormal" cssclass="cmb_WF_SurvGrade" value="" index="-1"/>
                    <Static id="sta00_01" taborder="4" text="&lt;fc v='#6b5dc0'&gt;교원 기본정보&lt;/fc&gt; (홍길동)" left="446" top="194" width="309" height="26" cssclass="sta_WF_S03SubTitB" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
                    <Div id="div00_01" taborder="5" left="60" top="230" height="540" cssclass="div_WF_S03SubTxtBg" initvalueid="ivDivAccessibilityOff" width="1074" formscrollbartype="none none" text="">
                      <Layouts>
                        <Layout>
                          <Static id="sta00_00" taborder="0" text="성명" left="30" top="29" width="49" height="24" cssclass="sta_WF_S03SubTxtB" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
                          <Static id="sta00_00_00" taborder="1" text="교원구분" left="652" top="29" width="78" height="24" cssclass="sta_WF_S03SubTxtB" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
                          <Static id="sta00_00_01" taborder="2" text="담임학급" left="30" top="63" width="68" height="24" cssclass="sta_WF_S03SubTxtB" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
                          <Static id="sta00_00_01_00" taborder="3" text="담당과목" left="30" top="97" width="68" height="24" cssclass="sta_WF_S03SubTxtB" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
                          <Static id="sta00_00_01_00_00" taborder="4" text="&lt;b v='true'&gt;교육활동소개&lt;/b&gt; " left="30" top="211" width="111" height="24" cssclass="sta_WF_S03SubTxtB" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
                          <Static id="sta00_00_01_00_01" taborder="5" text="안녕하세요? 서로 배려하며 스스로를 존중하는 행복한 5학년 2반입니다. &#13;&#13;&#10;2022년 올 한해는 다시 학교에 매일 등교하는 아이들에게 학교에 대한 즐거움과 예쁜 동심들을 많은 추억으로 쌓아보려고 노력했던 날들이었습니다. &#13;저는 제가 가르치는 아이들이 서로 배려하며 스스로를 존중하는 아이들로 성장하길 바랍니다. 학생들이 스스로를 존중하고 수업 시간 및 생활 시간에 있어 서로를 &#13;배려하는 태도를 가질 수 있도록 지도하였습니다. 앞으로 남은 기간 동안도 아이들을 사랑하는 마음으로 최선을 다하는 교사가 되도록 하겠습니다.&#13;&#13;&#13;&#10;&#13;&#10;* 학급 목표: 서로 배려하며 스스로를 존중하는 어린이로 성장하는 우리 반&#13;﻿&#13;&#13;&#10;&#13;&#10;* 주요교육활동&#13;﻿﻿- 학습 지도: 아이들의 흥미와 눈높이에 맞는 동기유발, 다양한 발표법을 통한 바르게 말하기와 경청하기 연습, 교과에 맞는 다양한 놀이 학습,학습활동 및 &#13;바른 인성과 관련된 다양한 그림책 읽기 지도, 수업 연구 및 다양한 교수법을 활용한 학습활동&#13;﻿- 생활 지도: 다양한 질문을 통한 창의성: 표현력을 기르는 주제 글쓰기(1학기), 1인 1역을 통해 학급 구성원으로서의 책임감 기르기&#13;&#13;&#13;&#10;&#13;&#10;* 주요업무&#13;- 학생 자율 동아리 운영및 관리" left="30" top="245" height="258" cssclass="sta_WF_S03SubTxt" usedecorate="true" initvalueid="ivStcAccessibilityOn" fittocontents="height" width="1014"/>
                          <Button id="btn00" taborder="6" text="닫기" top="21" height="40" cssclass="btn_WF_SurveyInfoClose" initvalueid="ivBtnAccessibilityButton" width="130" left="924"/>
