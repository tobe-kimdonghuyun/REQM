  <Form id="frmTemp01" width="1200" height="6320" titletext="유치원-국민행복카드 신청" onload="frmTemp01_onload">
    <Layouts>
      <Layout height="6320" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="55" height="54" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="국민행복카드 신청" left="0" top="0" height="54" cssclass="img_WF_SubTit01" width="261" initvalueid="ivTitleAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="div00" taborder="1" text="div00" left="0" top="144" height="305" width="1200" cssclass="div_WF_kinder" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="img00" taborder="0" left="50" top="50" width="300" height="190" cssclass="display" initvalueid="ivImgAccessibilityOn" text="" image="url('theme://images/img_WF_HappyCard.png')" accessibilitylabel="국민행복카드"/>
              <Static id="sta00_00" taborder="1" text="국민행복카드 란?" left="388" top="84" width="200" height="40" cssclass="sta_WF_Txt24B" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00" taborder="2" text="‘보육료’, ‘유아학비’, ‘건강보험 임신 출산 진료비 지원’, ‘청소년 산모 임신 출산 의료비 지원’ 및 ‘사회서비스&#13;&#13;&#10;전자바우처’ 등 정부의여러 바우처 지원을 공동으로 이용할 수 있는 통합카드입니다. 국민행복카드로 어린이집,&#13;&#10;유치원 어디서나 사용이 가능합니다." left="388" top="135" width="741" height="70" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta00_00_01" taborder="2" left="0" top="489" width="50" height="50" cssclass="sta_WF_KinderGrayBlTxt" initvalueid="ivStcAccessibilityOn" text="1"/>
        <Static id="sta00_02" taborder="3" text="국민행복카드 하나로 어린이집(보육료 결제), 유치원(유아학비 인증), 건강보험 임신・출산 진료비 및 사회서비스&#13;&#13;&#10;전자바우처 등의 사용이 가능합니다." left="64" top="479" width="741" height="70" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_00_01_00" taborder="4" left="0" top="579" width="50" height="50" cssclass="sta_WF_KinderGrayBlTxt" initvalueid="ivStcAccessibilityOn" text="2"/>
        <Static id="sta00_02_00" taborder="5" text="국민행복카드의 복수 발급은 가능하지만, e-유치원(유아학비지원시스템)에서는 가족구성원(신청 시 등록한 가족)&#13;중에서 &#13;&#10;인증용으로 1개 카드만 등록하여 사용 가능합니다." left="64" top="569" width="806" height="70" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_00_01_00_00" taborder="6" left="0" top="669" width="50" height="50" cssclass="sta_WF_KinderGrayBlTxt" initvalueid="ivStcAccessibilityOn" text="3"/>
        <Static id="sta00_02_00_00" taborder="7" text="국민행복카드 신청은 복지로 사이트, 주민센터, 금융기관 영업점에서 가능합니다." left="64" top="669" width="741" height="50" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
        <ImageViewer id="imgTitle" taborder="8" text="2021년, 이렇게 달라졌습니다" left="0" top="790" height="40" cssclass="img_WF_SubTit02" width="310" initvalueid="ivTitleAccessibilityOn"/>
