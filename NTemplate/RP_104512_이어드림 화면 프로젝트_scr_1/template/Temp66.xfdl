        <Static id="sta00_00" taborder="17" text="‘국민행복카드’ 신규발급 받거나 기존 사용중인 ‘ 아이즐거운카드’, ‘아이행복카드’ 사용가능" left="0" top="2068" width="628" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_00_00" taborder="18" text="※ 기존 아이즐거운카드 중 현금 IC카드는 2016년 2월 29일까지 사용가능" left="0" top="2092" width="628" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
        <ImageViewer id="imgTitle00_00" taborder="19" text="어린이집에서 유치원으로 시설 이동하는 경우" left="0" top="2187" height="40" cssclass="img_WF_SubTit02" width="448" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_00_01_01" taborder="20" text="유치원 입학 전에, 유아학비(사회복지서비스 및 급여) 자격신청을 주민센터나 복지로 사이트에서 기존과 동일하게 신청하셔야 합니다." left="0" top="2229" width="910" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_00_01_00_01" taborder="21" text="&lt;fc v='#2b72de'&gt;- 국민행복카드를 신규발급(주민센터/복지로 사이트에서 일괄신청, 혹은 금융기관 영업점에서 발급)&lt;/fc&gt;" left="0" top="2256" width="800" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
        <Static id="sta00_00_01_00_00_00" taborder="22" text="&lt;fc v='#2b72de'&gt;- 기존아이사랑 카드를 유치원에 전환 등록하여 사용&lt;/fc&gt;" left="0" top="2281" width="500" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
