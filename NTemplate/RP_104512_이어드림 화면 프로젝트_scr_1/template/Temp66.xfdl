        <Static id="sta00_01" taborder="34" text="주민센터 방문" left="163" top="4375" width="165" height="36" cssclass="sta_WF_Txt24" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_01_00" taborder="35" text="읍, 면, 동 주민센터를 방문하여 지원자격신청 및 카드발급 신청" left="163" top="4414" width="537" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
