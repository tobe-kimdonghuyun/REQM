        <Static id="sta00_00_01_00_00" taborder="11" text="⑥ 월 소득환산율" left="0" top="1116" width="146" height="23" cssclass="sta_WF_Txt18B" initvalueid="ivStcAccessibilityOn"/>
        <Grid id="grd00_01_00_00" taborder="12" left="0" top="1159" height="187" autosizingtype="none" autofittype="col" fillareatype="allrow" cssclass="grd_WF_Gray" initvalueid="ivGrdAccessibilityOn" right="0">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="400"/>
                <Column size="400"/>
                <Column size="400"/>
              </Columns>
              <Rows>
                <Row size="63" band="head"/>
                <Row size="60" band="head"/>
                <Row size="63"/>
              </Rows>
              <Band id="head">
                <Cell colspan="3" text="    재산종류별로 적용하여 월 소득으로 환산" font="normal 500 16px/normal &quot;Noto Sans KR Medium&quot;,&quot;NotoSansKR-Medium&quot;" background="#ffffff" border="1px solid #dddddd,0px none" color="#333333" textAlign="left"/>
                <Cell row="1" text="일반재산"/>
                <Cell row="1" col="1" text="금융재산"/>
                <Cell row="1" col="2" text="승용차" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd;"/>
              </Band>
              <Band id="body">
                <Cell text="4,17% / 3"/>
                <Cell col="1" displaytype="normal" text="6.26% / 3"/>
                <Cell col="2" displaytype="normal" text="100% / 3" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd;"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <ImageViewer id="imgTitle00_00_00_00" taborder="13" text="소득인정액 계산 예시" left="0" top="1386" height="40" cssclass="img_WF_SubTit02" width="240" initvalueid="ivTitleAccessibilityOn"/>
        <Div id="div02" taborder="14" text="div02" left="0" top="1446" height="793" right="0">
          <Layouts>
            <Layout>
              <Div id="div00" taborder="0" text="div00" left="30" top="30" height="130" cssclass="div_WF_GuideBg" right="30" formscrollbartype="none none">
                <Layouts>
                  <Layout>
                    <Static id="sta01_00_00" taborder="0" text="홍길동 가족은 4인 가구로&lt;fc v='#6095e6'&gt; ①대도시&lt;/fc&gt;에&lt;fc v='#6095e6'&gt; ②전세로 거주하며(보증금 8,000만원)&lt;/fc&gt;, " left="40" top="30" height="23" cssclass="sta_WF_Txt16M" initvalueid="ivStcAccessibilityOn" width="1000" usedecorate="true" onclick="Static_onclick"/>
                    <Static id="sta01_00_00_00" taborder="1" text="홍길동을 S회사에 근무하고 (&lt;fc v='#6095e6'&gt;③월급 110만원&lt;/fc&gt;) 아내는 T회사에서 근무하고 (&lt;fc v='#6095e6'&gt;③월급80만원&lt;/fc&gt;) 있다." left="40" top="53" height="23" cssclass="sta_WF_Txt16M" initvalueid="ivStcAccessibilityOn" width="1000" usedecorate="true" onclick="Static_onclick"/>
                    <Static id="sta01_00_00_00_00" taborder="2" text="&lt;fc v='#6095e6'&gt;④저축 280만원과 보험 200만원&lt;/fc&gt;,&lt;fc v='#6095e6'&gt; ⑤2,000CC 중고차(차량가액 300만원)&lt;/fc&gt;를 보유하고 있으며, 은행에&lt;fc v='#6095e6'&gt; ⑥600만원의 대출&lt;/fc&gt;이 있는 상태이다." left="40" top="76" height="23" cssclass="sta_WF_Txt16M" initvalueid="ivStcAccessibilityOn" width="1000" usedecorate="true" onclick="Static_onclick"/>
                  </Layout>
                  <Layout name="default0">
                    <Static id="sta01_00_00_00" top="sta01_00_00:20" left="30" height="93" fittocontents="height" right="20" cssclass="sta_WF_Txt24"/>
                    <Static id="sta01_00_00_00_00" top="sta01_00_00_00:20" left="30" height="124" fittocontents="height" right="20" cssclass="sta_WF_Txt24"/>
                    <Static id="sta01_00_00" left="30" top="30" height="62" right="20" fittocontents="height" cssclass="sta_WF_Txt24"/>
                  </Layout>
                </Layouts>
              </Div>
              <Static id="sta00" taborder="1" left="30" top="181" height="520" cssclass="sta_WF_Exaple" initvalueid="ivStcAccessibilityOn" right="32"/>
              <Static id="sta01_00_00" taborder="2" text="&lt;b v='true'&gt;[재산의 소득 환산액 계산 서식]&lt;/b&gt; {(8,000만원② + 300만원⑤ - 6,900만원① - 600만원⑥) x 4.17% / 3} + (480만원④ x 6.26% / 3) = 211,360원" left="30" top="711" height="39" cssclass="sta_WF_Txt16M" initvalueid="ivStcAccessibilityOn" usedecorate="true" onclick="Static_onclick" right="32"/>
            </Layout>
            <Layout name="default0">
