          <Layouts>
            <Layout>
              <Div id="div00" taborder="0" text="div00" left="30" top="30" width="550" height="129" cssclass="div_WF_GuideBg">
                <Layouts>
                  <Layout>
                    <Static id="sta00" taborder="0" text="[소득인정액] = 소득평가액 ① + 재산의 소득환산액 ②" left="37" top="44" width="476" height="40" cssclass="sta_WF_TxtBlue_20B" initvalueid="ivStcAccessibilityOn"/>
                  </Layout>
                  <Layout name="default0">
                    <Static id="sta00" cssclass="sta_WF_TxtBlue_28B" left="17" top="0" bottom="0" text="[소득인정액] &#13;&#10;= 소득평가액 ① + 재산의 소득환산액 ②" right="17" fittocontents="height"/>
                  </Layout>
                </Layouts>
              </Div>
              <Static id="sta01_00_00" taborder="1" text="&lt;fc v='#6095e6'&gt;①&lt;/fc&gt; : 가구의 근로소득, 사업소득, 재산소득, 연금소득 등을 월 기준으로 합산&#13;&#13;&#10;" left="647" top="60" height="23" cssclass="sta_WF_Txt16M" initvalueid="ivStcAccessibilityOn" width="490" usedecorate="true" onclick="Static_onclick"/>
              <Static id="sta01_00_00_00" taborder="2" text="&lt;fc v='#6095e6'&gt;②&lt;/fc&gt; : (각종 재산 ③ - 기본공제액 ④ - 부채 ⑤) x 월 소득환산율 ⑥" left="647" top="83" height="23" cssclass="sta_WF_Txt16M" initvalueid="ivStcAccessibilityOn" width="490" usedecorate="true" onclick="Static_onclick"/>
              <Static id="sta01_00_00_00_00" taborder="3" text="&lt;fc v='#f45151'&gt;※ ②의 결과가 음수로 나올 경우, 0으로 처리&lt;/fc&gt;" left="647" top="110" height="22" cssclass="sta_WF_Txt16M" initvalueid="ivStcAccessibilityOn" width="551" usedecorate="true"/>
            </Layout>
            <Layout name="default0">
              <Static id="sta01_00_00" left="30" top="div00:30" height="93" cssclass="sta_WF_Txt24" right="30" fittocontents="height"/>
              <Static id="sta01_00_00_00" left="30" top="sta01_00_00:10" height="62" cssclass="sta_WF_Txt24" right="30" fittocontents="height"/>
