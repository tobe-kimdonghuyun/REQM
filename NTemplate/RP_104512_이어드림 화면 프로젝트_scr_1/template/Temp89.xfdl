              <Div id="div00" left="30" top="30" height="129" right="20"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta00_00" taborder="3" text="③ 각종 재산의 유형" left="0" top="424" width="167" height="23" cssclass="sta_WF_Txt18B" initvalueid="ivStcAccessibilityOn"/>
        <Grid id="grd00_01" taborder="4" left="0" top="467" height="125" autosizingtype="none" autofittype="col" fillareatype="allrow" cssclass="grd_WF_Gray" initvalueid="ivGrdAccessibilityOn" right="0">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="512"/>
                <Column size="343"/>
                <Column size="343"/>
              </Columns>
              <Rows>
                <Row size="60" band="head"/>
                <Row size="63"/>
              </Rows>
              <Band id="head">
                <Cell text="일반재산"/>
                <Cell col="1" text="금융재산"/>
                <Cell col="2" text="승용차" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd;"/>
              </Band>
              <Band id="body">
                <Cell text="토지,건축물(주택), 전·월세보증금, 2,500cc 미만 자동차 등"/>
                <Cell col="1" displaytype="normal" text="예금, 적금, 주식, 보험 등"/>
                <Cell col="2" displaytype="normal" text="2,500cc 이상의 승용차" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd;"/>
              </Band>
            </Format>
            <Format id="mobile">
              <Columns>
                <Column size="400"/>
                <Column size="250"/>
                <Column size="250"/>
              </Columns>
              <Rows>
                <Row size="60" band="head"/>
                <Row size="100"/>
              </Rows>
              <Band id="head">
                <Cell text="일반재산"/>
                <Cell col="1" text="금융재산"/>
                <Cell col="2" text="승용차" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd;"/>
              </Band>
              <Band id="body">
                <Cell text="토지,건축물(주택),&#13;&#10;전·월세보증금,&#13;&#10;2,500cc 미만 자동차 등"/>
                <Cell col="1" displaytype="normal" text="예금, 적금,&#13;&#10;주식, 보험 등"/>
                <Cell col="2" displaytype="normal" text="2,500cc 이상의&#13;&#10;승용차" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd;"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="sta00_00_01" taborder="5" text="④ 기본공제액 (기본 재산액)" left="0" top="632" width="230" height="23" cssclass="sta_WF_Txt18B" initvalueid="ivStcAccessibilityOn"/>
        <Grid id="grd00_01_00" taborder="6" left="0" top="675" height="187" autosizingtype="none" autofittype="col" fillareatype="allrow" cssclass="grd_WF_Gray" initvalueid="ivGrdAccessibilityOn" right="0">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="400"/>
                <Column size="400"/>
                <Column size="400"/>
              </Columns>
              <Rows>
                <Row size="63" band="head"/>
                <Row size="60" band="head"/>
                <Row size="63"/>
              </Rows>
              <Band id="head">
                <Cell colspan="3" text="    보장기구는 기본적 생활 유지에 필요하다고 인정되어 소득확산에서 제외되는 재산가액 (가구 규모와 상관없이 다음 금액을 적용)" font="normal 500 16px/normal &quot;Noto Sans KR Medium&quot;,&quot;NotoSansKR-Medium&quot;" background="#ffffff" border="1px solid #dddddd,0px none" color="#333333" textAlign="left"/>
                <Cell row="1" text="대도시"/>
                <Cell row="1" col="1" text="중소도시"/>
                <Cell row="1" col="2" text="농어촌" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd;"/>
              </Band>
              <Band id="body">
                <Cell text="6,900만원"/>
                <Cell col="1" displaytype="normal" text="4,200만원"/>
                <Cell col="2" displaytype="normal" text="3,500만원" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd;"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="sta02" taborder="7" text="&lt;fc v='#f45151'&gt;대도시 : 특별시, 광역시의 “구” / 중소도시 : 도의 “시” / 농어촌 : 도의 “군”&lt;/fc&gt;" left="0" top="882" width="549" height="30" cssclass="sta_WF_Star16Red" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
        <Static id="sta02_00" taborder="8" text="&lt;fc v='#f45151'&gt;세종특별자치시는 중소도시 기준적용&lt;/fc&gt;" left="0" top="910" width="549" height="30" cssclass="sta_WF_Star16Red" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
        <Static id="sta00_00_01_00" taborder="9" text="⑤ 부채" left="0" top="970" width="76" height="23" cssclass="sta_WF_Txt18B" initvalueid="ivStcAccessibilityOn"/>
        <Div id="div01" taborder="10" text="div01" left="0" top="1013" height="63" right="0" initvalueid="ivDivAccessibilityOff" cssclass="div_WF_Boxline">
          <Layouts>
            <Layout>
              <Static id="sta01_00_00" taborder="0" text="부채는 일반재산, 금융재산 순서로 공제" left="20" top="20" height="23" cssclass="sta_WF_Txt16M" initvalueid="ivStcAccessibilityOn" width="490" usedecorate="true" onclick="Static_onclick"/>
            </Layout>
            <Layout name="default0">
              <Static id="sta01_00_00" cssclass="sta_WF_Txt24M" left="30" top="20" height="62" right="30" fittocontents="height"/>
