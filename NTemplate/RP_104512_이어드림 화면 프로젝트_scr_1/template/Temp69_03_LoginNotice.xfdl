<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="NP70M1" width="876" height="224" titletext="회원가입안내03" onload="samplePortalResize" onsize="samplePortalResize_onsize">
    <Layouts>
      <Layout height="224" width="876" screenid="ScreenDeskTop">
        <Div id="div00_00" taborder="0" left="0" top="0" width="876" height="244" cssclass="div_Login_Notice02">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" left="55" top="107" width="134" height="30" cssclass="sta_Login_MemberNotice01" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta02" taborder="1" text="정부24 민원처리운영창구&lt;l v='http://www.gov.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;(www.gov.kr)&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;또는&#13;&#10;1. 지방자치단체에서 운영하는 무인발급기를 통해 교육제증명 발급 서비스를 이용할 수 있습니다.&#13;&#10;2. 자세한 내용은 홈에듀민원서비스소개-민원버시스현황에서 서비스 제공 현황을 확인하시기 바랍니다.&#13;&#10;&lt;l v='http://www.gov.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;홈에듀민원서비스소개-민원서비스&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt; 현황 바로가기" left="248" top="37" width="613" height="96" cssclass="sta_Login_MemberNotice" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
              <Static id="sta02_00" taborder="2" text="개인민감정보의 입력은 가상키패드(기본)또는 키보드보안 프로그램을 통하여 입력이 가능합니다.&#13;&#10;보안성 향상 및 편의성 보장을 위하여, 키보드보안 프로그램 또한 제공하고 있습니다.(사용권장)&#13;&#10;키보드보안 프로그램을 설치/사용하면 PC 백신/방화벽/메모리 보호 기능이 추가적으로 제공됩니다." left="248" top="140" width="593" height="68" cssclass="sta_Login_MemberNotice" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[]]></Script>
  </Form>
</FDL>
