              <Static id="sta00_00_01_01" taborder="1" left="30" top="67" height="23" cssclass="sta_WF_InfoTxt_Blue" text="외국 학력 소지자는 온라인접수가 불가하오니, 교육청에서 지정한 원서 접수장에서 현장 접수&lt;fc v='#172f57'&gt;하시기 바랍니다.&lt;/fc&gt;" wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="40"/>
              <Static id="sta00_00_01_01_01" taborder="2" left="30" top="102" height="23" cssclass="sta_WF_InfoTxt_Blue" text="제출 후 수정하시는 경우, 반드시 마지막 [step 04. 접수완료]페이지에서 [수정제출버튼]을 클릭&lt;fc v='#172f57'&gt;하셔야 수정하신 내역이 반영됩니다.&lt;/fc&gt;" wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="40"/>
              <Static id="sta00_00_01_01_01_00" taborder="3" left="30" top="137" height="23" cssclass="sta_WF_InfoTxt_Blue" text="접수한 내역을 취소하시려면,  [step 04. 접수완료]페이지에서 &quot;응시원서 삭제&quot; 버튼을 클릭&lt;fc v='#172f57'&gt;하시기 바랍니다.&lt;/fc&gt;" wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="40"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00" taborder="4" left="0" top="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta99_00_00_00_00_01_01" taborder="5" left="0" top="30" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="30" text="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_00" taborder="6" left="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" bottom="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta99_00_00_00_00_01_01_00" taborder="7" top="30" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="30" text="30" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_01" taborder="8" left="30" top="51" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff"/>
