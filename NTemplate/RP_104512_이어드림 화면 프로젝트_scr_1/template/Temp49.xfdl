<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmTemp01" width="800" height="803" titletext="채용-경력합산신청-행정정보이용내역(텍스트박스+알림텍스트+버튼)" onload="frmTemp01_onload">
    <Layouts>
      <Layout height="803" width="800" screenid="ScreenDeskTop">
        <ImageViewer id="imgTitle00" taborder="0" text="행정정보 공동이용 사전동의서" left="20" top="16" width="230" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="staContent00" taborder="1" text="가. 이용기관 명칭" left="19" top="69" width="130" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divContent00" taborder="2" left="20" height="58" cssclass="div_WF_InfoBOX" right="20" top="99" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staContent00" taborder="0" left="24" top="3" height="49" cssclass="sta_WF_Black14" text="가나다라 교육청 및 교육지원청, 관할 각급 학교" wordWrap="char" right="70" initvalueid="ivStcAccessibilityOn" onclick="div00_sta00_00_01_01_onclick"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staContent01" taborder="3" text="나. 이용사무(이용목적)" left="19" top="183" width="150" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divContent01" taborder="4" left="20" height="58" cssclass="div_WF_InfoBOX" top="212" initvalueid="ivDivAccessibilityOff" width="370">
          <Layouts>
            <Layout>
              <Static id="staContent00" taborder="0" left="24" top="3" cssclass="sta_WF_Black14" text="계약제교유원 채용지원" wordWrap="char" initvalueid="ivStcAccessibilityOn" height="49" width="174"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staContent02" taborder="5" text="다. 공동이용 행정정보(구비서류)" left="400" top="183" width="210" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divContent02" taborder="6" left="400" height="58" cssclass="div_WF_InfoBOX" right="20" top="212" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staContent00" taborder="0" left="24" top="3" cssclass="sta_WF_Black14" text="범죄경력, 결격사유 유무조회" wordWrap="char" initvalueid="ivStcAccessibilityOn" height="49" width="184"/>
              <Static id="staGd16" taborder="1" left="0" top="19" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="20" text="20" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staContent02_00" taborder="7" text="라. 정보주체(본인) 동의사항" left="18" top="296" width="220" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divContent02_00" taborder="8" left="20" height="78" cssclass="div_WF_InfoBOX" right="20" top="324" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staContent00" taborder="0" left="24" top="12" cssclass="sta_WF_Black14" text="본인은 위 사무의 처리를 위하여 「전자정부법」 제36조에 따른 행정정보 공동이용을 통해 이용기관의&#13;&#10;업무처리담당자가 전자적으로 본인의 구비서류(공동이용)를 확인하는 것에 동의 합니다." wordWrap="char" right="20" initvalueid="ivStcAccessibilityOn" height="49"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta00_00_01_01_00_00" taborder="9" left="30" top="416" height="51" text="※만일, 본인이 위 행정정보 이용에 대해 동의를 하지 아니할 경우에도 불이익은 없습니다.&#13;&#10;    동의하지 아니한 경우에는 본인이 해당 구비서류를 제출하여야 합니다." wordWrap="char" width="710" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn"/>
        <Div id="div00_00" taborder="10" left="20" height="190" cssclass="div_WF_InfoBOX01" right="20" top="487" text="" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" left="29" top="29" width="701" height="68" cssclass="sta_WF_Black14" text="이용기관은 본인이 동의한 위 공동이용 행정정보를 확인하기 위해 「개인정보 보호법」제 19조에 따라 &#13;&#10;주민등록번호, 여권번호, 운전면허의 면허번호 또는 외국인 등록번호를 이용하여 행정정보를 처리 할 수 있습니다.&#13;&#10;이용기관이 요청하는 경우 기재하여 주십시오." usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta02" taborder="1" left="30" top="111" height="1" cssclass="sta_WF_SectionLine" right="30" initvalueid="ivStcAccessibilityOff"/>
              <Radio id="rdo00_00" taborder="2" top="129" width="490" height="25" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" rowcount="-1" value="1" text="동의" index="0" initvalueid="ivRdoNormal" columncount="0" left="30">
                <Dataset id="innerdataset">
                  <ColumnInfo>
                    <Column id="codecolumn" size="256"/>
                    <Column id="datacolumn" size="256"/>
                  </ColumnInfo>
                  <Rows>
                    <Row>
                      <Col id="codecolumn">1</Col>
                      <Col id="datacolumn">주민번호</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">2</Col>
                      <Col id="datacolumn">여권</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">3</Col>
                      <Col id="datacolumn">외국인등록</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">4</Col>
                      <Col id="datacolumn">운전면허</Col>
                    </Row>
                  </Rows>
                </Dataset>
              </Radio>
              <Static id="sta00_00" taborder="3" left="517" top="129" width="37" height="25" cssclass="sta_WF_Black14" text="번호 : " usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edt00" taborder="4" left="561" top="126" width="170" height="30" initvalueid="ivEdtNormal"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta00_00" taborder="11" left="48" top="692" height="25" cssclass="sta_WF_Black14" text="&lt;b v='true'&gt;위 동의서는 인력풀 등록 유효기간 동안 유효(결격사유 조회에 동의한 것으로 간주)합니다.&lt;/b&gt;" usedecorate="true" right="50" initvalueid="ivStcAccessibilityOn"/>
        <Button id="btn00_02_00_00" taborder="12" text="취소" left="35.00%" width="120" height="40" cssclass="btn_WF_ActionLine" top="743" initvalueid="ivBtnAccessibilityButton"/>
        <Button id="btn00_02_00" taborder="13" text="동의서 확인" width="118" height="40" cssclass="btn_WF_Action" left="btn00_02_00_00:8" top="743" initvalueid="ivBtnAccessibilityButton"/>
