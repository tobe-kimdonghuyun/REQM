<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmTemp01" width="1200" height="1549" titletext="유치원-유아학비란" onload="frmTemp01_onload">
    <Layouts>
      <Layout height="1549" width="1200" screenid="ScreenDeskTop" stepcount="0">
        <Div id="divTitle" taborder="0" left="0" top="56" height="54" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="유아학비란?" left="0" top="0" height="54" cssclass="img_WF_SubTit01" width="180" initvalueid="ivTitleAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <ImageViewer id="imgTitle" taborder="1" text="목적" left="0" top="174" height="40" cssclass="img_WF_SubTit02" width="50" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00" taborder="2" left="410" top="178" width="80" height="80" initvalueid="ivStcAccessibilityOn" background="url('theme://images/img_WF_Purpose01.png') no-repeat center center"/>
        <Static id="sta00_01_00" taborder="3" text="3~5세 유아교육에 대한&#13;" left="402" top="261" width="220" height="40" cssclass="sta_WF_Txt20B" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_01_00_00" taborder="4" text="국가책임강화" left="402" top="299" width="220" height="40" cssclass="sta_WF_Txt20B" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_01_00_00_00" taborder="5" text="모든 유아에게 교육에 대한 동등한 기회 제공" left="402" top="341" width="309" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_00" taborder="6" left="824" top="178" width="80" height="80" initvalueid="ivStcAccessibilityOn" background="url('theme://images/img_WF_Purpose02.png') no-repeat center center"/>
        <Static id="sta00_01_00_01" taborder="7" text="학부모의 유아교육비" left="815" top="260" width="220" height="40" cssclass="sta_WF_Txt20B" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_01_00_00_01" taborder="8" text="경감" left="815" top="298" width="135" height="40" cssclass="sta_WF_Txt20B" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_01_00_00_00_00" taborder="9" text="만 3~5세 유아 국・공립 유치원, 입학금, 수업료 면제" left="815" top="340" width="362" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_02" taborder="10" left="410" top="440" width="80" height="80" initvalueid="ivStcAccessibilityOn" background="url('theme://images/img_WF_Purpose03.png') no-repeat center center"/>
        <Static id="sta00_01_00_02" taborder="11" text="소득에 상관없이 전 계층" left="402" top="523" width="220" height="40" cssclass="sta_WF_Txt20B" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_01_00_00_02" taborder="12" text="유아학비 지원" left="402" top="561" width="220" height="40" cssclass="sta_WF_Txt20B" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_01_00_00_00_01" taborder="13" text="모든 유아에게 교육에 대한 동등한 기회 제공" left="402" top="603" width="309" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_00_00" taborder="14" left="823" top="440" width="80" height="80" initvalueid="ivStcAccessibilityOn" background="url('theme://images/img_WF_Purpose04.png') no-repeat center center"/>
        <Static id="sta00_01_00_01_00" taborder="15" text="복잡한 행정의 간소화" left="815" top="522" width="220" height="40" cssclass="sta_WF_Txt20B" initvalueid="ivStcAccessibilityOn"/>
        <ImageViewer id="imgTitle00" taborder="16" text="지원대상" left="0" top="697" height="40" cssclass="img_WF_SubTit02" width="100" initvalueid="ivTitleAccessibilityOn"/>
        <Div id="div00" taborder="17" text="div00" left="0" top="768" height="240" right="0" cssclass="div_WF_kinder" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" text="・국, 공, 사립 유치원에 다니는 만 3~5세 유아 &lt;fc v='#595959'&gt;(*1~2월 생으로 만 3세 반에 조기취원한 유아 포함)&lt;/fc&gt;" left="44" top="44" width="987" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
              <Static id="sta00_01_00" taborder="1" text="・유치원과 어린이집 등에서 교육부 장관과 보건복지부장관이 협의하여 정하는 공통과정을 제공받는 유아에 대한 무상교육 기간은 3년을 초과할 수 없음" left="44" top="78" width="1000" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Button id="btn00" taborder="2" text="유아교육법 24조(무상교육)" left="50" top="139" width="270" height="50" cssclass="btn_WF_KinderGo" initvalueid="ivBtnAccessibilityLink"/>
              <Button id="btn00_00" taborder="3" text="유아교육법 시행령" left="332" top="139" width="212" height="50" cssclass="btn_WF_KinderGo" initvalueid="ivBtnAccessibilityLink"/>
            </Layout>
          </Layouts>
        </Div>
        <ImageViewer id="imgTitle00_00" taborder="18" text="지원 제외대상" left="0" top="1079" height="40" cssclass="img_WF_SubTit02" width="150" initvalueid="ivTitleAccessibilityOn"/>
        <Div id="div00_00" taborder="19" text="div00" left="0" top="1152" height="224" right="0" cssclass="div_WF_kinder" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" text="・대한민국 국적을 가지고 있지 않은 유아(난민은 예외적으로 인정)" left="44" top="44" width="700" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
              <Static id="sta00_01_00" taborder="1" text="・어린이집을 이용하여 보육료를 지원받고 있는 유아" left="44" top="78" width="700" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_01_00_00" taborder="2" text="・양육수당을 지원받고 있는 유아" left="43" top="113" width="500" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_01_00_00_00" taborder="3" text="・유치원 이용시간에 아이돌봄 서비스 등과 중복지원 불가" left="42" top="149" width="500" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="div01" taborder="20" left="0" top="1396" height="152" cssclass="div_WF_KinderBox" initvalueid="ivDivAccessibilityOff" right="0">
          <Layouts>
            <Layout>
              <Static id="sta00_01_00_00_00" taborder="0" text="・31일 이상 해외체류 유아는 유아학비 지원자격 중지(날짜계산 : 출국일 포함)" left="44" top="42" width="700" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_01_00_00_00_00" taborder="1" text="・유아학비 지원자격 중지 후 유아학비를 다시 지원받기 위해서는 유아학비지원 재신청필요" left="44" top="78" width="800" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="Static99_00_00_00_00" taborder="21" left="0" top="0" height="60" cssclass="sta_GD_Size" text="60" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
