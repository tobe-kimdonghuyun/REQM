                    <Static id="Static99_00_00_00_00_01_00_00_01_00_00_00_00_00_00" taborder="0" left="50" top="0" height="40" cssclass="sta_WF_GDSize" text="40" visible="false" initvalueid="ivStcAccessibilityOff" width="60"/>
                    <Static id="Static99_00_00_00_00_01_00_00_01_00_00_00_00_00_00_00" taborder="1" left="0" top="0" cssclass="sta_WF_GDSize" text="50" visible="false" initvalueid="ivStcAccessibilityOff" width="50" height="100"/>
                    <Div id="div00" taborder="2" left="50" top="40" height="180" cssclass="div_WF_S02SubTitBg" right="50" initvalueid="ivDivAccessibilityOff">
                      <Layouts>
                        <Layout>
                          <Static id="sta00" taborder="0" text="검사결과는 추후 각 가정에 우편으로 제공될 예정이며,&#13;&#13;&#10;지속적인 관심이 필요한 학생은 전문기관에서  도움을 받을 수 있도록 안내해 드릴 것 입니다.&#13;" left="50" top="32" height="70" cssclass="sta_WF_S02Tit_B24" initvalueid="ivStcAccessibilityOn" right="50" letterSpacing="-1px" textAlign="center"/>
                          <Static id="sta00_00" taborder="1" text="지금까지 학생정서·행동특성검사에 끝까지 참여하시고 솔직하게 응답해주셔서 감사합니다." left="179" top="sta00:10" width="737" height="28" cssclass="font20B" initvalueid="ivStcAccessibilityOn" textAlign="center"/>
                        </Layout>
                        <Layout name="Layout0">
                          <Static id="sta00" cssclass="sta_WF_S02Tit_B30" left="40" top="40" height="156" taborder="0" text="검사결과는 추후 각 가정에 우편으로 제공될 예정이며, 지속적인 관심이 필요한 학생은 전문기관에서  도움을 받을 수 있도록 안내해 드릴 것 입니다.&#13;" right="40" textAlign="left" fittocontents="height"/>
                          <Static id="sta00_00" cssclass="sta_WF_S02SubTxt_M" left="40" top="sta00:20" height="102" text="지금까지 학생정서·행동특성검사에 끝까지 참여하시고 솔직하게 응답해주셔서 감사합니다." taborder="1" right="40" textAlign="left" fittocontents="height"/>
                        </Layout>
                        <Layout name="Layout1">
                          <Static id="sta00" cssclass="sta_WF_S02Tit_B30" left="40" top="40" height="156" taborder="0" text="검사결과는 추후 각 가정에 우편으로 제공될 예정이며, 지속적인 관심이 필요한 학생은 전문기관에서  도움을 받을 수 있도록 안내해 드릴 것 입니다.&#13;" right="40" textAlign="left" fittocontents="height"/>
                          <Static id="sta00_00" cssclass="sta_WF_S02SubTxt_M" left="40" top="sta00:20" height="102" text="지금까지 학생정서·행동특성검사에 끝까지 참여하시고 솔직하게 응답해주셔서 감사합니다." taborder="1" right="40" textAlign="left" fittocontents="height"/>
                        </Layout>
                      </Layouts>
                    </Div>
                    <Static id="sta00_00" taborder="3" text="지속적인 관심이 필요한 학생으로 확인된 경우 학부모님의 적극적인 참여와 도움을 요청드립니다." left="50" top="269" width="737" height="24" cssclass="font18B" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta00_00_00" taborder="4" text="아울러 자녀의 정서· 행동적인 측면에서 학교에서 각별히 관심을 갖고 지도해야 할 사항이 있으면 언제든지 담임선생임이나&#13;&#10;&#13;담당선생님께 알려주시기 바랍니다.&#13;귀 자녀의 건강하고 원만한 생활을 위해 노력하겠습니다.&#13;&#13;&#13;&#10;&#13;&#10;감사합니다." left="50" top="309" width="877" height="104" cssclass="font18R" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta00_00_01" taborder="5" text="서울초등학교장" top="453" width="119" height="24" cssclass="font18B" initvalueid="ivStcAccessibilityOn" right="50"/>
                  </Layout>
