  <Form id="frmTemp01" width="1920" height="1080" titletext="[M]교육설문-학교폭력(학생참여번호로그인)" onload="frmTemp01_onload">
    <Layouts>
      <Layout height="1080" width="1920" screenid="ScreenDeskTop">
        <Div id="div00" taborder="0" text="div00" left="0" top="0" height="172" right="0" url="template::Survey01-frametop.xfdl" formscrollbartype="none none" initvalueid="ivDivAccessibilityOn"/>
        <Div id="div01" taborder="1" left="0" top="172" cssclass="div_WF_Survey01" right="0" initvalueid="ivDivAccessibilityOff" height="808" text="">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" width="283" right="0" bottom="0" height="641" cssclass="sta_WF_SurvGraph01" initvalueid="ivStcAccessibilityOff"/>
              <Div id="div01" taborder="1" text="div01" left="360" top="20" width="1200" height="200" cssclass="div_WF_SurvBox16R" initvalueid="ivDivAccessibilityOff" formscrollbartype="none none">
                <Layouts>
                  <Layout>
                    <Static id="sta00" taborder="0" text="꼭 읽어야 할 유의사항" left="82" top="35" width="267" height="40" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_SurvCautionL"/>
                    <Static id="sta00_00_01_00_00" taborder="1" left="371" top="35" width="702" height="30" cssclass="sta_WF_survDot14" initvalueid="ivStcAccessibilityOn" usedecorate="false" text="참여번호를 잃어버린경우 담임선생님께 요청하여 재발급 받을 수있습니다.(참여번호 발급은 초기 1회 포함, 총10회발급)"/>
                    <Static id="sta00_00_01_00_00_01" taborder="2" left="371" top="59" width="476" height="30" cssclass="sta_WF_survDot14" initvalueid="ivStcAccessibilityOn" usedecorate="true" text="학생의 개인정보는 저장되지 않으며, &lt;fc v='#ff3f3f'&gt;참여번호를 통한 개인확인은 불가능합니다.&lt;/fc&gt;"/>
                    <Static id="Static99_00_00_00_00_01_00_00_01_00_00_00_00_00" taborder="11" cssclass="sta_GD_Size" text="44" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="50" bottom="67" left="142" height="47"/>
                    <Static id="sta00_00_01_00_00_00" taborder="3" left="371" top="83" width="463" height="30" cssclass="sta_WF_survDot14" initvalueid="ivStcAccessibilityOn" usedecorate="true" text="응답 내용으로 인한 불이익은 전혀없으며 비밀은 꼭 지켜드리겠습니다." color="#ff3f3f"/>
                    <Static id="sta00_00_01_00_00_00_00" taborder="4" left="371" top="107" width="711" height="30" cssclass="sta_WF_survDot14" initvalueid="ivStcAccessibilityOn" usedecorate="false" text="다른사람의 참여번호를 무단으로 이용하여 설문조사에 참여하는경우, 형법상 공무집행방해죄에 처벌을 받을 수 있습니다. "/>
                    <Static id="Static99_00_00_00_00_01_00_00_01_00_00_00_00" taborder="7" cssclass="sta_GD_Size" text="44" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="867" bottom="0" left="442" height="47"/>
                    <Static id="sta00_00_01_00_00_00_00_00" taborder="5" left="371" top="131" width="621" height="30" cssclass="sta_WF_survDot14" initvalueid="ivStcAccessibilityOn" usedecorate="false" text="참여번호 입력은 가상키패드(기본 적용) 또는 키보드보안 프로그램(선택)을 통하여 입력이 가능합니다. "/>
                    <Static id="Static99_00_00_00_00_01_00_00_01_00_00_00" taborder="6" left="83" top="0" height="44" cssclass="sta_GD_Size" text="44" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="867"/>
