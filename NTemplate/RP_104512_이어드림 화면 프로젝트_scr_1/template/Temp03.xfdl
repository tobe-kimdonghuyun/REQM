<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmTemp02" width="1200" height="606" titletext="대국민-자료실등록p93(디테일+첨부파일)" onload="frmTemp02_onload">
    <Layouts>
      <Layout height="606" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="70" height="44" text="" right="0" tabstop="false" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="자료실 등록" left="0" top="0" height="44" cssclass="img_WF_SubTit01" width="179" initvalueid="ivTitleAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divMain" taborder="1" left="0" height="402" top="134" text="" cssclass="div_WF_Detail" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="sta44" taborder="0" left="189" height="42" cssclass="sta_WF_Input02Top" top="0" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta07" taborder="1" left="0" height="192" cssclass="sta_WF_Input02" top="41" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta44_00_01_00_00" taborder="2" left="189" height="170" cssclass="sta_WF_Input02" top="232" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta45" taborder="3" left="0" width="190" height="42" cssclass="sta_WF_Input01Top" text="제목" top="0" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edt00_00_01" taborder="4" left="195" top="6" height="30" text="나이스 대국민서비스 리플렛" width="415" initvalueid="ivEdtNormal"/>
              <Static id="sta10" taborder="5" left="0" width="190" height="192" cssclass="sta_WF_Input01" text="내용" top="41" initvalueid="ivStcAccessibilityOn"/>
              <TextArea id="txt00" taborder="6" left="195" top="47" height="180" enable="true" scrolltype="both" right="5" initvalueid="ivTxtNormal"/>
              <Static id="sta10_00_01" taborder="7" left="0" width="190" cssclass="sta_WF_Input01" text="첨부파일" top="232" initvalueid="ivStcAccessibilityOn" height="170"/>
              <Div id="div00" taborder="8" left="195" top="238" url="comm::comm_fileAdd.xfdl" text="" initvalueid="ivDivAccessibilityOn" height="160" right="5"/>
            </Layout>
