/* 
스텝의 기본버튼을 사용할 경우, 화면 속성 stepitemgap, stepitemsize 의 값을 삭제,
버튼을 생성하여 따로 사용할 경우, 화면 속성 stepitemgap, stepitemsize 을 0으로 설정하여
 생성한 버튼으로 스텝을 이동하게 한다.

*/

//0501 CF 일괄등록

this.stepNotice_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	/*
	this.title.set_text(this.parent.params.eventTitlNm);		//팝업타이틀
	this.subTitle1.set_text(this.parent.params.popupCn);			//팝업 내용
	this.subTitle2.set_text(this.parent.params.eventYmd);		//팝업 기간
	trace("긴급공지안내 팝업");
	*/
};

// 생성된 step에 Div를 생성하고 set_url 함
this.fnCreateNoticeStep = function(nStep){
	var strUrl = "templateP::notice5.xfdl";

	var objNm = "divNotice"+nStep;
	var pWidth = nexacro.getEnvironmentVariable("ev_isMobile") == "Y" ? "560":"538";
	var pHeigth= nexacro.getEnvironmentVariable("ev_isMobile") == "Y" ? "660":"580";

	var objDiv = new Div();
	objDiv.init(objNm,0,0,pWidth,pHeigth);
	this.addChild(objNm, objDiv);
	objDiv.set_url(strUrl);
	objDiv.set_positionstep(nStep-1);
	objDiv.show();	
};

]]></Script>
  </Form>
</FDL>
