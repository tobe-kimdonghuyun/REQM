<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="stepNotice" width="538" height="580" titletext="공지안내" background="#ffffff" ontouchstart="notice1_ontouchstart" scrollbartype="none none" scrolltype="none" stepitemgap="0" stepitemsize="0">
    <Layouts>
      <Layout height="580" screenid="ScreenDeskTopP" width="538" stepcount="0">
        <Div id="divNotice0" taborder="0" left="0" top="0" width="538" height="660" formscrolltype="none" text="" borderRadius="20px"/>
      </Layout>
      <Layout name="Layout0" screenid="mobileP,tabletP" width="560" height="660" mobileorientation="portrait" type="default"/>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
