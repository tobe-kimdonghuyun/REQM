<body style="margin:0;border:none;-ms-touch-action:none;" onload="oninitframework()">
    <div tabIndex="-1" aria-hidden="true"></div> <!-- 웹접근성 '문서끝' 현상-->
    <script>
        function oninitframework()
        {
            var urlParams = {};
            (function () {
                var match,
                pl     = /\+/g,
                search = /([^&=]+)=?([^&]*)/g,
                decode = function (s) { return decodeURIComponent(s.replace(pl, " ")); },
                query  = window.location.search.substring(1);
                while (match = search.exec(query)) { urlParams[decode(match[1])] = decode(match[2]); }
                })();

            <!-- history -->
            nexacro.urlParams = urlParams;

            nexacro._launch_screenid = urlParams.screenid;      
            <!-- SCREEN_INFORMATION : create screen information defined in Environment > ScreenDefinition -->
            var screeninfo = [
                #{SCREEN_INFORMATION}
            ];

            nexacro._initHTMLSysEvent(window, document);
            nexacro._initEnvironment(screeninfo);
            
            
            <!-- device별 셋팅-->
            var deviceInfo = {};
            deviceInfo = ( function() {
                //deviceInfo.screenid = "ScreenDeskTop";
                //deviceInfo.screenType = "desktop";
                
                var userAgent = navigator.userAgent.toLowerCase();
                var isMobile = /android|iphone|ipad|mobile|nokia|blackbeerry|lgtelecom|natebrowser|sonyericsson|ipod|mobi|sm|samsung/i.test(userAgent);  // linux||macintosh|mac 조건 제거

                if(isMobile)
                {
                    //deviceInfo.screenid = "mobile";
                    //deviceInfo.screenType = "mobile_medium";
                    deviceInfo.isMobile = "Y";

                    <!-- Pad 구분 -->
                    if( /pad|macintosh/i.test(userAgent) )
                    {
                        deviceInfo.screenid = "tablet";
                        deviceInfo.screenType = "mobile_large";
                        deviceInfo.screentype = "mobile_large";
                        //nexacro._curscreenid = deviceInfo.screenid;
                    }else{
                        deviceInfo.screenid = "mobile";
                        deviceInfo.screenType = "mobile_medium";
						deviceInfo.screentype = "mobile_medium";
					}

                //  if( linux|android/i.test(userAgent) && !/mobile/i.test(userAgent) 
                //  {
                //      deviceInfo.screenid = "tablet";
                //      deviceInfo.screenType = "mobile_large";
                //  }
                }

                return deviceInfo;
            })();

            //nexacro._curscreenid = deviceInfo.screenid;
            //nexacro._curscreentype = deviceInfo.screenType;
            nexacro.setInitialVariable("environment", "ev_isMobile", deviceInfo.isMobile);          


            if(util.getParam("eduDgtlOpsUserScCd")){
                nexacro.setInitialVariable("application", "gv_eduDgtlOpsUserScCd", util.getParam("eduDgtlOpsUserScCd"));
            }
            if(util.getParam("subsys")){
                nexacro.setInitialVariable("environment", "ev_subSystemGb", util.getParam("subsys"));
            }
            if(util.getParam("menuType")){
                nexacro.setInitialVariable("environment", "ev_menuType", util.getParam("menuType"));
            }
            if(util.getParam("screenid")){
                //var isMobile = util.getParam("screenid").indexOf("mobile") > -1?"Y":"N"; 
                //nexacro.setInitialVariable("environment", "ev_isMobile", isMobile);
            }
            
            <!-- create internal iframe -->
            <!-- USERFONT_INFORMATION : userfontid property is specified in the Environment -->
            nexacro._prepareManagerFrame(onloadframework#{USERFONT_INFORMATION});
        }
        function onloadframework()
        {
            <!-- application loading -->
            nexacro._loadADL();
        }
        function onfinalframework()
        {
            <!-- application exit -->
        }
    </script>
    
     
