    <script>
    !function(){
        function detectDevTool(allow){
            if(window.location.host.indexOf("local") === -1 &&
               window.location.host.indexOf("dev") === -1 &&
               window.location.host.indexOf("tst") === -1){
               
                if(isNaN(+allow)) allow = 100;
                var start =+ new Date();
                //debugger; 2024.4.17
                var end =+ new Date();
                if(isNaN(start) || isNaN(end) || end - start > allow){
                    //개발자 도구가 open된 것을 감지했을 때 실행할 코드 삽입
                    alert('개발자 도구가 감지되었습니다.');
                }
            }
        }
        
        if(window.attachEvent){
            if(document.readyState === 'complete' || document.readyState === 'interactive'){
                detectDevTool();
                window.attachEvent('onresize', detectDevTool);
                window.attachEvent('onmousemove', detectDevTool);
                window.attachEvent('onfocus', detectDevTool);
                window.attachEvent('onblur', detectDevTool);
            } else {
                setTimeout(argument.callee, 0);
            }
        } else {
            window.addEventListener('load', detectDevTool);
            window.addEventListener('size', detectDevTool);
            window.addEventListener('mousemove', detectDevTool);
            window.addEventListener('blur', detectDevTool);
        }
    }();
    
    if(window.location.host.indexOf("local") === -1 &&
       window.location.host.indexOf("dev") === -1 &&
       window.location.host.indexOf("tst") === -1){
       
        window.addEventListener('keydown', function(e){
            if(
                //01.CMD + Alt + I (Chrome, Firefox, Safari)
                e.metaKey == true && e.altKey == true && e.keyCode == 73 ||
                //02.CMD + Alt + J (Chrome)
                e.metaKey == true && e.altKey == true && e.keyCode == 74 ||
                //03.CMD + Alt + C (Chrome)
                e.metaKey == true && e.altKey == true && e.keyCode == 67 ||
                //04.CMD + Shift + C (Chrome)
                e.metaKey == true && e.shiftKey == true && e.keyCode == 67 ||
                //05.Ctrl + Shift + I (Chrome, Firefox, Safari, Edge)
                e.ctrlKey == true && e.shiftKey == true && e.keyCode == 73 ||
                //06.Ctrl + Shift + J (Chrome, Edge)
                e.ctrlKey == true && e.shiftKey == true && e.keyCode == 74 ||
                //07.Ctrl + Shift + C (Chrome, Edge)
                e.ctrlKey == true && e.shiftKey == true && e.keyCode == 67 ||
                //08.F12 (Chrome, Firefox, Edge)
                e.keyCode == 123 ||
                //09.CMD + Alt + U, Ctrl + U (View source: Chrome, Firefox, Safari, Edge)
                e.metaKey == true && e.altKey == true && e.keyCode == 85 ||
                e.ctrlKey == true && e.keyCode == 85
            ){
                e.preventDefault();
                return false;
            }
        });
        
    }
    </script>

</body>
</html>
