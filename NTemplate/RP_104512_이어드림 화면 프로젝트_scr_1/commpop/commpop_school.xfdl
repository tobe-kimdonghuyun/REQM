<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <TypeDefinition url="..\default_typedef.xml"/>
  <Form id="commpop_school" classname="form" inheritanceid="" titletext="학교찾기" onload="fnOnload" position="absolute" width="865" height="490">
    <Layouts>
      <Layout width="865" height="490" screenid="ScreenDeskTop,tablet">
        <Div id="divSearch" taborder="0" text="div00" left="20" top="20" height="108" accessibilityenable="false" right="20">
          <Layouts>
            <Layout>
              <Static id="staTxt3" taborder="0" left="194" top="0" height="54" cssclass="sta_WF_DtlBg" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staTxt4" taborder="1" left="194" top="53" height="54" cssclass="sta_WF_DtlBg" right="0" text="" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staCddc" taborder="2" text="*시·도 교육청" left="0" top="0" width="195" height="54" cssclass="sta_WF_Essential" accessibilitydescription="필수입력" initvalueid="ivStcEssential"/>
              <Combo id="cboCddc" taborder="3" left="staCddc:20" top="10" width="308" height="35" cssclass="essential" innerdataset="dsCddcList" codecolumn="orgCd" displayrowcount="10" accessibilitylabel="시,도 교육청(필수선택)" initvalueid="ivCmbEssential" datacolumn="kornOrgNm" index="-1"/>
              <Static id="staSchulNm" taborder="4" text="*학교명" left="0" top="53" width="195" height="54" cssclass="sta_WF_Essential" accessibilitydescription="필수입력" initvalueid="ivStcEssential"/>
              <Edit id="edtSchulNm" taborder="5" left="staSchulNm:20" top="63" width="308" height="34" cssclass="essential" onkeydown="schulNm_onkeydown" accessibilitylabel="학교명(필수입력)" maxlength="20" initvalueid="ivEdtEssential" imemode="hangul,full"/>
              <Button id="btnSearch" taborder="6" text="검색" left="edtSchulNm:10" top="63" width="84" height="34" onclick="btnSearch_onclick" initvalueid="ivBtnAccessibilityButton"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="staCddc" width="185" left="0" top="0" height="74" cssclass="sta_WF_Essential_M"/>
              <Static id="staSchulNm" cssclass="sta_WF_Essential_M" width="185" left="0" top="73" height="140"/>
              <Combo id="cboCddc" cssclass="essential_M" height="52" left="205" top="11" right="20" popuptype="center"/>
              <Edit id="edtSchulNm" cssclass="essential_M" left="205" top="85" height="52" right="20"/>
              <Static id="staTxt3" left="184" top="0" height="74" right="0"/>
              <Static id="staTxt4" left="184" top="73" height="140" right="0"/>
              <Button id="btnSearch" height="52" left="205" top="149" width="178" cssclass="btn_WF_btn01M"/>
            </Layout>
          </Layouts>
        </Div>
        <Grid binddataset="dsMain" id="grdMain" left="20" top="148" height="252" taborder="1" autofittype="col" right="20" oncelldblclick="grdMain_oncelldblclick" initvalueid="ivGrdAccessibilityOn" selecttype="cell" accessibilitylabel="학교목록" cellsizingtype="col">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="40"/>
                <Column size="170"/>
                <Column size="173"/>
                <Column size="442"/>
              </Columns>
              <Rows>
                <Row size="25" band="head"/>
                <Row size="24" band="head"/>
                <Row size="24" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell rowspan="3" text="순번" displaytype="normal" font="normal 15px/normal &quot;NotoSansKR-Regular&quot;"/>
                <Cell col="1" rowspan="3" text="관할조직명" displaytype="normal" font="normal 15px/normal &quot;NotoSansKR-Regular&quot;"/>
                <Cell col="2" rowspan="3" text="학교명" font="normal 15px/normal &quot;NotoSansKR-Regular&quot;"/>
                <Cell col="3" rowspan="3" text="주소" displaytype="normal" font="normal 15px/normal &quot;NotoSansKR-Regular&quot;"/>
              </Band>
              <Band id="body">
                <Cell text="expr:currow+1" autosizerow="default" autosizecol="limitmax" displaytype="normal" font="normal 14px/normal &quot;Noto Sans KR,NotoSansKR-Regular,Malgun Gothic,Arial,MS PGothic&quot;"/>
                <Cell col="1" text="bind:cteOrgNm" autosizerow="default" autosizecol="limitmax" displaytype="normal" font="normal 14px/normal &quot;Noto Sans KR,NotoSansKR-Regular,Malgun Gothic,Arial,MS PGothic&quot;"/>
                <Cell col="2" text="bind:kornOrgNm" combodataset="dsUseRelmScCd" combodatacol="unyCdValueNm" combocodecol="unyCdValue" font="normal 14px/normal &quot;Noto Sans KR,NotoSansKR-Regular,Malgun Gothic,Arial,MS PGothic&quot;" autosizecol="limitmax"/>
                <Cell col="3" text="bind:roadNmAddr" autosizerow="default" autosizecol="limitmax" displaytype="normal" font="normal 14px/normal &quot;Noto Sans KR,NotoSansKR-Regular,Malgun Gothic,Arial,MS PGothic&quot;"/>
              </Band>
            </Format>
            <Format id="default_00">
              <Columns>
                <Column size="67"/>
                <Column size="190"/>
                <Column size="190"/>
                <Column size="150"/>
              </Columns>
              <Rows>
                <Row size="60" band="head"/>
                <Row size="50"/>
              </Rows>
              <Band id="head">
                <Cell text="순번" displaytype="normal" font="normal 22px/normal &quot;NotoSansKR-Regular&quot;"/>
                <Cell col="1" text="관할조직명" displaytype="normal" font="normal 22px/normal &quot;NotoSansKR-Regular&quot;"/>
                <Cell col="2" text="조직명" font="normal 22px/normal &quot;NotoSansKR-Regular&quot;"/>
                <Cell col="3" text="조직코드" displaytype="normal" font="normal 22px/normal &quot;NotoSansKR-Regular&quot;"/>
              </Band>
              <Band id="body">
                <Cell text="expr:currow+1" autosizerow="default" autosizecol="limitmin" displaytype="normal" font="normal 20px/normal &quot;NotoSansKR-Regular&quot;"/>
                <Cell col="1" text="bind:cteOrgNm" autosizerow="default" autosizecol="limitmin" displaytype="normal" font="normal 20px/normal &quot;NotoSansKR-Regular&quot;"/>
                <Cell col="2" text="bind:kornOrgNm" combodataset="dsUseRelmScCd" combodatacol="unyCdValueNm" combocodecol="unyCdValue" font="normal 20px/normal &quot;NotoSansKR-Regular&quot;"/>
                <Cell col="3" text="bind:orgCd" autosizerow="default" autosizecol="limitmin" displaytype="normal" font="normal 20px/normal &quot;NotoSansKR-Regular&quot;"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="btnSelect" taborder="2" text="확인" left="39.31%" top="420" width="180" height="50" cssclass="btn_WF_Ok" onclick="btnSelect_onclick" accessibilitylabel="팝업닫기" initvalueid="ivBtnAccessibilityButton"/>
      </Layout>
      <Layout name="Layout0" width="640" height="803" mobileorientation="landscape" type="default" screenid="mobile,tablet">
        <Button id="btnSelect" left="20" top="683" height="80" cssclass="btn_WF_Ok_M" right="20"/>
        <Div id="divSearch" left="20" top="34" height="215" right="20"/>
        <Grid id="grdMain" formatid="default_00" left="20" top="289" height="352" right="20"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsSearch">
        <ColumnInfo>
          <Column id="cddcOrgCd" type="STRING" size="256"/>
          <Column id="kornOrgNm" type="STRING" size="256"/>
          <Column id="orgUseYn" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="orgUseYn">Y</Col>
          </Row>
          <Row>
            <Col id="id">selectCddcList</Col>
            <Col id="url">/sqa_ueu_um00_001.do</Col>
            <Col id="outDatasets">dsCddcList</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">select</Col>
            <Col id="svctp">R</Col>
            <Col id="url">/sac_cmm_cm00_001.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsMain=resultList</Col>
          </Row>
          <Row>
            <Col id="id">selectCddcList</Col>
            <Col id="url">/sqa_ueu_um00_001.do</Col>
            <Col id="outDatasets">dsCddcList</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true">
        <ColumnInfo>
          <Column id="orgCd" type="STRING" size="256" description="조직코드"/>
          <Column id="kornOrgNm" type="STRING" size="256" description="한글조직명"/>
          <Column id="cddcOrgCd" type="STRING" size="256" description="시도교육청조직코드"/>
          <Column id="cddcOrgNm" type="STRING" size="256" description="시도교육청조직명"/>
          <Column id="cteOrgCd" type="STRING" size="256" description="관할조직코드"/>
          <Column id="cteOrgNm" type="STRING" size="256" description="관할조직명"/>
          <Column id="shlKndScCd" type="STRING" size="256" description="학교종류구분코드"/>
          <Column id="shlKndScNm" type="STRING" size="256" description="학교종류구분명"/>
          <Column id="shlKndCrseScCd" type="STRING" size="256" description="학교종류과정구분코드"/>
          <Column id="lotnoZip" type="STRING" size="256" description="지번우편번호"/>
          <Column id="lotnoAddr" type="STRING" size="256" description="지번주소"/>
          <Column id="lotnoDtlAddr" type="STRING" size="256" description="지번상세주소"/>
          <Column id="roadNmZip" type="STRING" size="256" description="도로명우편번호"/>
          <Column id="roadNmAddr" type="STRING" size="256" description="도로명주소"/>
          <Column id="roadNmDtlAddr" type="STRING" size="256" description="도로명상세주소"/>
          <Column id="orgUseYn" type="STRING" size="256" description="조직사용여부"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsCddcScCd" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="FirstCode" type="STRING" size="30" value="SEL" datapath=""/>
          <ConstColumn id="ClfCdValue" type="STRING" size="30" value="CDDC_SC_CD"/>
          <ConstColumn id="FilterExpr" type="STRING" size="30" value=""/>
          <ConstColumn id="UnyCdGrpId" type="STRING" size="30" value=""/>
          <ConstColumn id="BfrClfCdValue" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd1Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd2Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd3Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd4Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd5Value" type="STRING" size="30" value=""/>
          <Column id="pgeId" type="STRING" size="256"/>
          <Column id="clfCdValue" type="STRING" size="30"/>
          <Column id="clfCdValueNm" type="STRING" size="120"/>
          <Column id="clfCdUseYn" type="STRING" size="150"/>
          <Column id="unyCdValue" type="STRING" size="10"/>
          <Column id="unyCdValueNm" type="STRING" size="30"/>
          <Column id="userDfnCd1Value" type="STRING" size="100"/>
          <Column id="userDfnCd2Value" type="STRING" size="100"/>
          <Column id="userDfnCd3Value" type="STRING" size="100"/>
          <Column id="userDfnCd4Value" type="STRING" size="100"/>
          <Column id="userDfnCd5Value" type="STRING" size="100"/>
          <Column id="chk" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsCddcList" useclientlayout="true">
        <ColumnInfo>
          <Column id="orgCd" type="STRING" size="10"/>
          <Column id="kornOrgNm" type="STRING" size="300"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    학교찾기
*  @FileName 	commpop_school.xfdl 
*  @CreateDate 	2022.01.06
*  @Desction    학교찾기 팝업 화면
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.01.06     	KYS 	                최초 생성
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
var pv_params;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 팝업 폼 초기화
	this.smfInitPopup(obj);

	pv_params = this.smfGetPopupParams();
		
	this.smfSearchService("selectCddcList")
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
				this.dsCddcList.insertRow(0);
				this.dsCddcList.setColumn(0, "orgCd", "");
				this.dsCddcList.setColumn(0, "kornOrgNm", "전체");
				this.divSearch.form.cboCddc.set_index(0);
		}) // 콜백
	;
	
	// 공통코드의 코드구분
	this.smfCodeList("code", [this.dsCddcScCd])
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			for(var i = 1; i < this.dsCddcScCd.getRowCount() ; i++){
				this.dsCddcScCd.setColumn(i, "unyCdValue", this.dformat("{unyCdValue}0000001", this.dsCddcScCd, i));
			}
			
			// opener 화면에서 시도교육청 코드를 넘겨주면 세팅
			if(this.isNotNil(pv_params.cddcOrgCd)){
				this.divSearch.form.cboCddc.set_value(pv_params.cddcOrgCd);
			}
		})
	;
	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 /**
 * 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchList = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("select")
		// 데이터 검증
		.validateForm(this.divSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
  /**
 * 학교 선택
 * @param : N/A
 * @param : N/A
 */
 this.fnChoice = function(){
	if(this.dsMain.rowposition <= -1) return;
	
	this.smfSendResponseToOpener({
		"row": this.smfRowToObject(this.dsMain)
	});

	this.close(true);
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 입력창 입력 시
* @param  : obj		   - [object]Edit
* @param  : e		   - [string]KeyEventInfo
* @return : N/A
 */
this.schulNm_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	// 엔터키 이벤트
	if(e.keycode == "13"){
		this.btnSearch_onclick();
	}
};

/**
 * 검색 버튼 클릭 시
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearchList();
};

/**
 * 그리드 셀 더블 클릭 시
* @param  : obj		   - [object]Grid
* @param  : e		   - [string]GridClickEventInfo
* @return : N/A
 */
this.grdMain_oncelldblclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	this.fnChoice();
};

/**
 * 확인 버튼 클릭 시
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
this.btnSelect_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnChoice();
};]]></Script>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.edtSchulNm" propid="value" datasetid="dsSearch" columnid="kornOrgNm"/>
      <BindItem id="item1" compid="divSearch.form.cboCddc" propid="value" datasetid="dsSearch" columnid="cddcOrgCd"/>
    </Bind>
  </Form>
</FDL>
