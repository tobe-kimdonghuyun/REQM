        <TextArea id="txt00" taborder="2" left="20" top="38" width="320" height="98" visible="false"/>
        <Div id="divInner" taborder="0" left="353" top="20" width="1200" bottom="0" text="">
          <Layouts>
            <Layout type="vertical" verticalgap="10">
              <Div id="divMain" taborder="0" left="0" top="0" height="48" initvalueid="ivDivAccessibilityOff" text="" width="100%">
