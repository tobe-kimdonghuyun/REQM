                        </Layout>
                      </Layouts>
                    </Div>
                    <Static id="staCopyright" taborder="1" top="10" initvalueid="ivStcAccessibilityOn" cssclass="sta_BF_Gov_copyright" text="COPYRIGHT ⓒ MINISTRY OF EDUCATION. ALL RIGHTS RESERVED." onclick="divBI_sta01_onclick" height="24" width="480" right="0"/>
                  </Layout>
                  <Layout name="mobile" type="vertical" verticalgap="20" flexmainaxisalign="end">
                    <Div id="divPolicy" width="600" left="0" top="16" height="30" cssclass="gov-dspFlex"/>
                    <Static id="staCopyright" top="divPolicy:10" width="100%" height="30" left="15" textAlign="left" cssclass="sta_BF_Gov_copyright_M" text="COPYRIGHT ⓒ MINISTRY OF EDUCATION. ALL RIGHTS RESERVED."/>
                  </Layout>
                </Layouts>
              </Div>
              <Div id="divIdentifier" taborder="3" text="div00" left="353" width="100%" initvalueid="ivDivAccessibilityOff" cssclass="div_BF_Gov_iden" height="40" top="826">
                <Layouts>
                  <Layout>
                    <Static id="sta00" taborder="0" left="16" top="8" width="60" height="24" cssclass="sta_BF_Gov_idn_moe"/>
                    <Static id="staIdntText" taborder="1" text="이 누리집은 교육부 산하기관 누리집입니다." left="sta00:8" top="8" width="694" height="24" cssclass="sta_BF_Gov_idn_cont"/>
                  </Layout>
                  <Layout name="mobile">
                    <Static id="staIdntText" left="sta00:8" top="10" height="30" right="0" cssclass="sta_BF_Gov_idn_cont_M"/>
                    <Static id="sta00" height="40" left="16" top="5" width="75" cssclass="sta_BF_Gov_idn_moe_M"/>
