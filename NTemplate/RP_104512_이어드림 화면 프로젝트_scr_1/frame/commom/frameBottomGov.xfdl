            <Layout name="mobile" verticalgap="30">
              <Div id="divIdentifier" width="100%" left="353" top="826" height="50" cssclass="div_BF_Gov_iden_M"/>
              <Div id="divCopyright" width="100%" left="353" top="726" height="90" text="div00" cssclass="div_BF_Gov_copy_M gov-dspFlex"/>
              <Div id="divCont" width="divMain:100.00%" left="0" top="88" height="250" text="" cssclass="gov-dspFlex"/>
              <Div id="divMain" height="60" left="0" top="0" width="100%" text="" cssclass="gov-dspFlex" formscrolltype="none"/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
      <Layout height="600" width="640" screenid="mobile,tablet" name="mobile" mobileorientation="portrait">
        <TextArea id="txt00" left="290" top="84" width="320" height="98"/>
        <Div id="divInner" left="20" top="20" bottom="0" text="" cssclass="gov-dspFlex" right="20"/>
        <Static id="sta00" visible="false"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    대국민서브포탈
*  @FileName 	frameBottom
*  @Creator 	투비소프트
*  @CreateDate 	2022.07.22
*  @Desction    대국민포탈 Bottom
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.07.21     	TOBESOFT 	               최초 생성 
*******************************************************************************
*/ 
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.nexacroFrame = nexacro.getApplication().mainframe.VFrameSet.frameMain.form;	// 메인 프레임

// 호환성 유지
this.divBottom = this.divInner.form.divCont.form.divBottom;
this.divMain = this.divInner.form.divMain;
this.divCopyright = this.divInner.form.divCopyright;
this.divPolicy = this.divInner.form.divCopyright.form.divPolicy;

this.USE_LOGGER = false;

/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
this.frameBottom_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	var onMobile = this.smfIsMobile();									// 모바일 여부
	var sSubSystemGb =this.smfGetSubSystemGb();							// 시스템 구분코드
	var oOwnFrmDivMenu = this.getOwnerFrame().form.divTop.form.divMenu;	// 상단 메뉴
	
	// 로컬 모드에서만 로그 출력
	var nRunMode = nexacro.getEnvironmentVariable("ev_runMode");		// 실행 구분
	this.USE_LOGGER = (nRunMode == 1 && system.navigatorname.indexOf("nexacro") < 0) ? true : false;
	
	//@KBR bottom메뉴 copy
	if(oOwnFrmDivMenu)
	{
		var oDsBtMenu = this.getOwnerFrame().form.divTop.form.dsMenuBottom;
		this.dsMenuBottom.copyData(oDsBtMenu);
		this.dsMenuBottom.set_enableevent(false);
		var nRow = this.dsMenuBottom.rowcount;
		for(var i=0; i<nRow; i++)
		{
			this.dsMenuBottom.setColumn(i, "isShow", "");
		}
		this.dsMenuBottom.set_enableevent(true);
	}
	
	this.smfInitDiv(obj);
	
	this.logger("frameBottom_onload :: [" + sSubSystemGb + "]");
	
	var sType = "collapse";
	var objOption = {};
	
	// 서브시스템 별 Bottom divMain, divMain01 셋팅
	this.fnRearrageBottomComp(sSubSystemGb,sType,objOption);
	
	// [BEGIN] 디지털정부 UI/UX 적용 : 서브시스템 별 Bottom 구성요소 및 뷰 조정처리
	var setViewMap = {};
	setViewMap["MOBILE"] = onMobile;
	switch(sSubSystemGb){
		case "SQA" :	// 3.검정고시
		case "HES" :	// 4.학원서비스
		case "BDM" :	// 5.비영리법인
		case "AFS" :	// 6.학교업무지원(방과 후 학교 운영지원)
		case "PHE" :	// 6.학교업무지원(체육 학교 운동부 및 스포츠 클럽 관리)
		case "SML" :	// 6.학교업무지원(급식 위생관리 지원)
		case "ECC" :	// 6.학교업무지원(초등 돌봄교실 운영지원)
		case "IBM" :	// 6.학교업무지원(교과용도서 주문정보 조회)
		case "SEM" :	// 6.학교업무지원(학교 환경관리 위생점검 등록)
			setViewMap["INFO"] = {
				 "staTelNum_01" : {show: true, value: "<b v='true'>1600-7440</b> <font size='2'>(평일 08:00 ~ 18:00)</font>"}
				, "staTelNum_02" : {show: false}
				, "staOperTime" : {show: false}
// 				 "staTelNum_01" : {show: true, value: "<b v='true'>1600-8400</b> (나이스)"}
// 				, "staTelNum_02" : {show: true, value: "<b v='true'>1600-7440</b> (대국민 서비스)"}
			};
			setViewMap["UTIL"] = {
				"btnRemote" : {show: (onMobile ? false : true)}
				, "btnSetTablet" : {show: false}
			};
			break;
		case "EWS" : 	// 7.교육비원클릭
			setViewMap["INFO"] = {
				"staTelNum_01" : {show: true, value: "<b v='true'>1544-9654</b> <font size='2'>(평일 09:00 ~ 18:00)</font>"}
				, "staTelNum_02" : {show: false}
				, "staOperTime" : {show: false}
// 				"staTelNum_01" : {show: true, value: "<b v='true'>1544-9654</b> (교육비 원클릭)"}
// 				, "staTelNum_02" : {show: false, value: null}
// 				, "staOperTime" : {show: true, value: "운영시간 : 09:00 ~ 18:00, 주중 운영"}
			};
			setViewMap["UTIL"] = {
				"btnRemote" : {show: (onMobile ? false : true)}
				, "btnSetTablet" : {show: false}
			};
			break;
		case "UDA" :	// 8.대입전형자료(학교생활기록부)
			setViewMap["INFO"] = {
				"staTelNum_01" : {show: true, value: "<b v='true'>1600-7440</b> <font size='2'>(평일 08:00 ~ 18:00)</font>"}
				, "staTelNum_02" : {show: false}
				, "staOperTime" : {show: false}
// 				 "staTelNum_01" : {show: true, value: "<b v='true'>1600-7440</b> (대국민 서비스)"}
// 				, "staTelNum_02" : {show: false, value: null}
			};
			setViewMap["UTIL"] = {
				"btnRemote" : {show: (onMobile ? false : true)}
				, "btnSetTablet" : {show: false}
			};
			break;
		case "ORE" :	// 온라인채용(교원채용)
		case "HRD" :	// 온라인채용(계약제 교원 인력풀)
			setViewMap["INFO"] = {
			/*	[일반행정-교직원온라인채용] 채용 포털 대국민상담센터 전화번호 수정 (-/SR00243925)
				"staInfoTitle" : {show: true, value: "교직원 온라인채용 서비스 이용 문의"}
				,"staTelNum_01" : {show: true, value: "<b v='true'>1551-3231</b> <font size='2'>(평일 09:00 ~ 18:00)</font>"}
				, "staTelNum_02" : {show: false}
				, "staOperTime" : {show: false}*/
 				"staInfoTitle" : {show: true, value: "교직원 온라인채용 서비스 이용 문의"}
 				,"staTelNum_01" : {show: true, value: "<b v='true'>1600-8400</b> (나이스)"}
 				, "staTelNum_02" : {show: true, value: "<b v='true'>1600-7440</b> (대국민 서비스)"}
 				, "staOperTime" : {show: true, value: "운영시간 : 09:00 ~ 18:00, 주중 운영"}
			};
			setViewMap["UTIL"] = {
				"btnRemote" : {show: (onMobile ? false : true)}
				, "btnSetTablet" : {show: false}
			};
			break;
		case "UDS" :	// 대입전형자료수신(일반)
			setViewMap["INFO"] = {
				 "staTelNum_01" : {show: true, value: "<b v='true'>1600-8400</b> (나이스)"}
				, "staTelNum_02" : {show: true, value: "<b v='true'>1600-7440</b> (대국민 서비스)"}
			};
			setViewMap["UTIL"] = {
				"btnRemote" : {show: (onMobile ? false : true)}
				, "btnSetTablet" : {show: false}
			};
			break;
		case "PAR" :	// 학부모서비스(유치원)
			setViewMap["INFO"] = {
				 "staTelNum_01" : {show: true, value: "<b v='true'>1600-6565</b> (유치원 학부모서비스)"}
				, "staTelNum_02" : {show: true, value: "<b v='true'>1600-7440</b> (대국민 서비스)"}
			};
			setViewMap["UTIL"] = {
				"btnRemote" : {show: (onMobile ? false : true)}
				, "btnSetTablet" : {show: false}
			};
			break;
		default :
			break;
	}
	
	this.setFooterView(setViewMap);
	// [ END ] 디지털정부 UI/UX 적용 : 서브시스템 별 Bottom 구성요소 및 뷰 조정처리
	
	//@KBR 서브시스템 별 이용약관 버튼 visible처리(divPolicy 활성화인 경우에만)
	if(this.divCopyright.form.divPolicy.visible){
		this.fnSetPolicyBtn();
	}
	
	//@KBR [웹접근성 - 전용브라우저]
	if(sSubSystemGb == "UDS"){
		this.divInner.form.divCopyright.form.staCopyright.set_accessibilitydescription("<문서끝>");
		
		//copyright에  hotkey설정
		this.divInner.form.divCopyright.form.staCopyright.set_hotkey("CTRL+END");
	}
};

/**
 * 시스템 구분에 따른 레이아웃/정보 조정 처리
 */
this.setFooterView = function(oSetInfo){
	
	this.logger("[BEGIN] setFooterView", oSetInfo);
	
	var isMobile = oSetInfo["MOBILE"];
	var innerBase = this.divInner;										// 푸터 영역
	var contBase = this.divInner.form.divCont;							// 연락처, 유틸리티 영역
	var infoBase = this.divInner.form.divCont.form.divBottom;			// 연락처 정보 영역
	var utilLinkBase = this.divInner.form.divCont.form.divServiceLink;	// 유틸리티 링크 영역
	
	// 영역별 Layour 설정 값
	// 푸터 영역
	var innerLayTopPos = innerBase.top;												// 푸터 영역 Top Position;
	var innerLayType = innerBase.form._control_element._client_elem._layouttype;	// Layout Type;
	var innerLayGap = innerLayType == "vertical" ? innerBase.form._control_element._client_elem._layoutverticalgap : 
					innerLayType == "horizontal" ? innerBase.form._control_element._client_elem._layouthorizontalgap : 0;
	
	// 연락처, 유틸리티 영역
	var contLayType = contBase.form._control_element._client_elem._layouttype;		// Layout Type;
	var contLayGap = contLayType == "vertical" ? contBase.form._control_element._client_elem._layoutverticalgap : 0;
	
	// 연락처 정보 영역
	var infoLayType = infoBase.form._control_element._client_elem._layouttype;		// Layout Type;
	var infoLayGap = infoLayType == "vertical" ? infoBase.form._control_element._client_elem._layoutverticalgap : 0;
	
	// 유틸리티 링크 영역
	var utilLinkLayType = utilLinkBase.form._control_element._client_elem._layouttype;		// Layout Type;
	var utilLinkLayGap = utilLinkLayType == "vertical" ? utilLinkBase.form._control_element._client_elem._layoutverticalgap : 0;
	
	// 레이아웃 적용 값 확인 로그
// 	var logStr = "\r\n================================================";
// 	logStr += "\r\nisMobile = " + isMobile;
// 	logStr += "\r\n------------------------------------------------";
// 	logStr += "\r\ninnerLayTopPos = " + innerLayTopPos;
// 	logStr += "\r\n------------------------------------------------";
// 	logStr += "\r\ninnerLayGap = [" + innerLayType + "] " + innerLayGap;
// 	logStr += "\r\ncontLayGap = [" + contLayType + "] " + contLayGap;
// 	logStr += "\r\n------------------------------------------------";
// 	logStr += "\r\ninfoLayGap = [" + infoLayType + "] " + infoLayGap;
// 	logStr += "\r\nutilLinkLayGap = [" + utilLinkLayType + "] " + utilLinkLayGap;
// 	logStr += "\r\n================================================";
// 	this.logger(logStr);
	
	// 연락처 정보 설정
	var dspInfo = oSetInfo["INFO"];
	var hideInfoCnt = 0;
	for(var sKey in dspInfo){
		var compCfg = dspInfo.hasOwnProperty(sKey) ? dspInfo[sKey] : null;
		if(compCfg != null){
			var tgComp = infoBase.form[sKey];
			var tgCompShow = compCfg["show"];
			var tgCompVal = compCfg["value"];
			if(!tgCompShow){
				hideInfoCnt++;
			}
			tgComp.set_visible(tgCompShow);
			if(tgCompVal != null){
				tgComp.set_text(tgCompVal);
			}
		}
	}
	
	// 유틸리티 링크 설정
	var dspUtilInfo = oSetInfo["UTIL"];
	var utilLinkArr = utilLinkBase.form._child_list;
	var viewUtilLinkCnt = 0;
	utilLinkArr.forEach(function(item, index){
		var itemId = item.id;
		var itemCfg = dspUtilInfo.hasOwnProperty(itemId) ? dspUtilInfo[itemId] : null;
		if(itemCfg != null){
			var tgItemShow = itemCfg["show"];
			item.set_visible(tgItemShow);
		}
		if(item.visible){
			viewUtilLinkCnt++;
		}
	});
	if(viewUtilLinkCnt == 0){
		utilLinkBase.set_visible(false);
	}
	
	// 정책 링크 설정 - 이용약관, 웹접근성정책
	//@KBR 서브시스템 별 이용약관 버튼 visible처리(divPolicy 활성화인 경우에만)
	if(this.divInner.form.divCopyright.form.divPolicy.visible){
		// TODO
	}
	
	// 영역내 출력 요소 대응 영역 높이 계산
	var oViewCtrl = this;
	var getViewHeight = function(tgComp, verticalGap){
		var result = 0;
		var childArr = tgComp._child_list;
		var vGapCnt = -1;
		childArr.forEach(function(item, index){
			var inItemVisible = item.visible;
			if(inItemVisible){
				var inItemH = parseInt(item.height);
				result += inItemH;
				vGapCnt++;
			}
		});
		result += (verticalGap * vGapCnt);
		return result;
	}
	
	// Form 높이설정
	var reFormSize = true;//isMobile ? true : (hideInfoCnt > 0 ? true : false);
	if(reFormSize){
	
		var bottomSpace = 0;	// 프레임 높이 설정 시 하단 추가 여백 높이
	
		// [divCont > divBottom] - Info 영역 설정
		var reContBtmH = getViewHeight(infoBase.form, infoLayGap);
		infoBase.set_height(reContBtmH);

		// [divCont > divServiceLink] Service Link 영역 설정
		var reContSevLinkView = viewUtilLinkCnt == 0 ? false : true;
		var reContSevLinkH = isMobile ? (reContSevLinkView ? getViewHeight(utilLinkBase.form, utilLinkLayGap) : 0) : reContBtmH;
		utilLinkBase.set_height(reContSevLinkH);
	
		// [divCont] Info, Service Link 영역 설정
		var reContH = isMobile ? getViewHeight(contBase.form, contLayGap) : reContBtmH;
		contBase.set_height(reContH);
		
		// 최종 높이 설정
		var reFormH = getViewHeight(innerBase.form, innerLayGap);
		reFormH += (innerLayTopPos * 2);
		reFormH += bottomSpace;	// 추가 하단 여백 높이
		
		// Form, 프레임 설정
//		this.logger("Reform Size >> Form, 프레임 설정", reFormH);
		
		this.set_height(reFormH);
		this.getOwnerFrame().form.fvFrameBottom.set_height(reFormH);
	}else{
	
//		this.logger("None Reform Size >> Call OwnerFrame.form.fnResizeProc()");
	
		this.getOwnerFrame().form.fnResizeProc();
	}
//	this.logger("Form, 프레임 설정 확인", this.height, this.getOwnerFrame().form.fvFrameBottom.height);
	
	this.frameBottom_onsize();
	
	this.logger("[ END ] setFooterView");
};

// Center 정렬 
this.frameBottom_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	var nMaxWidth = 1200;
	var nLeft = 0;
	var nFormWidth = this.parent.getOffsetWidth();
	
	var isMobile = this.smfIsMobile();
	if(isMobile)
	{ 
		// 모바일 - 별도 조정 필요 없음
// 		nLeft = parseInt((nFormWidth-this.divPolicy.getOffsetWidth())/2);
// 		this.divPolicy.setOffsetLeft(nLeft);
// 		
// 		//divMain, Main01 width 동일함 (640px)
// 		nLeft = parseInt((nFormWidth-this.divMain.getOffsetWidth())/2);
// 		this.divMain.setOffsetLeft(nLeft);
	}else{
		var nLeft = (nFormWidth > nMaxWidth) ? parseInt((nFormWidth-nMaxWidth)/2) : 0;
		this.divInner.setOffsetLeft(nLeft);
	}
	
	this.resetScroll();
};


/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

// 서브시스템별로 콤포넌트 구성을 다시 한다.(업무지원/교육설문/온라인채용 위주)
this.fnRearrageBottomComp = function(sSubSystemGb,sType,objOption)
{
	this.resetScroll(this);
}

this.fnSetPolicyBtn = function()
{
	var sSubSystemGb = this.smfGetSubSystemGb();
	var sSubSystemDetailGb = this.smfGetSubSystemDetailGb();

	var nWidth = 0;

	var objBtnUse = this.divInner.form.divCopyright.form.divPolicy.form.btnUse;						// 이용약관
	var objBtnAccessBility = this.divInner.form.divCopyright.form.divPolicy.form.btnAccessBility;	// 웹접근성정책

	//이용약관 버튼 visible 처리
	if((sSubSystemGb=="ORE")   	  // 온라인채용(교원채용)
	  || (sSubSystemGb=="HRD")    // 온라인채용(계약제교원인력풀)
	  || (sSubSystemGb=="PAR")    // 유치원
	  || (sSubSystemGb=="HES")    // 학원민원
	  || (sSubSystemGb=="BDM")    // 비영리법인
	  || ((sSubSystemGb=="SQA")&&(sSubSystemDetailGb!="103"))    // 검정고시(대입전형 제외)
	  || (sSubSystemGb=="UDA")    // 대입전형자료온라인생성신청-대입전형자료(학교생활기록부)
	  )
	{
		//this.divPolicy.form.sta03.set_visible(true);
		objBtnUse.set_visible(true);  // 이용약관
		
		nWidth = objBtnUse.getOffsetRight();	
	}	
	else{
		//this.divPolicy.form.sta03.set_visible(false);
		objBtnUse.set_visible(false);
		
		nWidth = objBtnAccessBility.getOffsetRight();
	}
	
	//원격지원서비스 버튼 visible 처리
	if(sSubSystemGb == "UDS")
	{
		this.divInner.form.divCont.form.divServiceLink.form.btnRemote.set_visible(false);
	}
	
	var isShow =  objBtnUse.visible==true? "" : "N";
	var nRow = this.dsMenuBottom.findRow("menuName" , "이용약관");
	this.dsMenuBottom.setColumn(nRow, "isShow", isShow);

	//모바일일 경우 divPolicy width 수정
	//if(this.smfIsMobile()){
	//	this.divPolicy.setOffsetWidth(nWidth);
	//}
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

// 정책버튼 클릭시
this.divPolicy_btnCrtl_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//this.nexacroFrame.divAll.form.vscrollbar.set_pos(0);
	if ( this.smfIsMobile() )
	{
		//mobile B mode 만 사용	
		this.getOwnerFrame().form.divTop.form.fnTopMode("B");
	}else
	{
		this.smfChangeDiv("W");		
	}

	//menuId = 5000, sUrl = "pa_pas_mms_sp::pas_mmssp00_m02.xfdl";
	var sUrl ="";
	if (obj.id =="btn01") {			// 개인정보처리방침
		sUrl = this.getOwnerFrame().form.divTop.form.dsMenu.lookup("menuId","9300","menuUrlAddr");	
	}
	else if (obj.id =="btn03") {	//저작권 보호 정책
		sUrl = this.getOwnerFrame().form.divTop.form.dsMenu.lookup("menuId","9100","menuUrlAddr");
	}
	else if (obj.id =="btn04") {	//웹접근성정책
		sUrl = this.getOwnerFrame().form.divTop.form.dsMenu.lookup("menuId","9200","menuUrlAddr");	
	}

	if(!this.smfIsNull(sUrl))
	{
		var params = {};
		this.smfSetWorkPage(sUrl, params);
	}	
};

this.divPolicy_btnFamilySite_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var nLeft = obj.getOffsetWidth() - this.pdvFamilySite.getOffsetWidth();
	var nTop = (-1) * this.pdvFamilySite.getOffsetHeight();
	
	this.pdvFamilySite.trackPopupByComponent(this.divPolicy.form.btnFamilySite,nLeft,nTop);
};

/**
 * 개인정보처리방침 버튼 클릭 이벤트 핸들러
 */
this.divPolicy_btnIndvInfo_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objParams = {};
	var sUrl = "frame::commom/framePolicy01.xfdl";
		
	this.smfSetWorkPage(sUrl,objParams);
};

/**
 * 이용약관 버튼 클릭 이벤트 핸들러
 */
this.divPolicy_btnUse_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
	var objParams = {
		menu:"B002"
	};	
	var sUrl = "";
	
	var sSubSys = this.smfGetSubSystemGb();
	
	if(  (sSubSys == "ORE") // 온라인채용(교원채용)
	  || (sSubSys == "HRD") // 온라인채용(계약제교원인력풀)
	  )
	{
		sUrl = "frame::commom/framePolicy02.xfdl";
	}
	else if(  (sSubSys == "SQA")   // 검정고시
	       || (sSubSys == "HES")   // 학원민원
	       || (sSubSys == "BDM")   // 비영리법인
		   || (sSubSys == "UDA")   // 대입전형자료온라인생성신청-대입전형자료(학교생활기록부)
	       )
	{
		sUrl = "frame::commom/framePolicy02_01.xfdl";
	}
	else if (sSubSys == "PAR")   // 학부모서비스 - 유치원
	{
		sUrl = "frame::commom/framePolicy02_02.xfdl";
	}
	
	if(!this.smfIsNull(sUrl))
	{
		this.smfSetWorkPage(sUrl,objParams);	
	}
};

this.divPolicy_btnLicense_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objParams = {};
	var sUrl = "frame::commom/framePolicy03.xfdl";
	this.smfSetWorkPage(sUrl,objParams);	
};

this.divPolicy_btnAccessBility_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objParams = {};
	var sUrl = "frame::commom/framePolicy04.xfdl";
	this.smfSetWorkPage(sUrl,objParams);
	
};

/**
 * 원격지원서비스 버튼 클릭 이벤트 핸들러
 */
this.divServiceLink_btnRemote_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 운영만 있음.
	var sUrl = "https://as2.neis.go.kr/"; 
	var param = {};
	param.options = "width=600,height=600,scrollbars=yes";
	this.smfSetServiceLink(sUrl,"link",param);
};



// ====개발용 메시지=== UserAgent 표시
this.divMain_staCopyright_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	var nRunMode = nexacro.getEnvironmentVariable("ev_runMode");
	//로컬에서만 textArea 활성화  
	//런타임 제외 
	if(nRunMode == 1 && system.navigatorname.indexOf("nexacro") < 0){
		if(this.txt00.visible){
			this.txt00.set_visible(false);
		}else{
			this.txt00.set_visible(true);
			this.txt00.set_value("=== 개발용 메세지 === \n 스크린타입 : " + nexacro._curscreentype 
													+ "\n 스크린ID : " + nexacro._curscreenid
													+ "\n agent : " + navigator.userAgent);
		}
	}
};


// ====개발용 메시지=== UserAgent 표시
this.divBI_sta01_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	var nRunMode = nexacro.getEnvironmentVariable("ev_runMode");
	
	//로컬에서만 textArea 활성화
	if(nRunMode == 1 && system.navigatorname.indexOf("nexacro") < 0 ){
		if(this.txt00.visible){
			this.txt00.set_visible(false);
		}else{
			this.txt00.set_visible(true);
			this.txt00.set_value("=== 개발용 메세지 === \n 스크린타입 : " + nexacro._curscreentype 
										+ "\n 스크린ID : " + nexacro._curscreenid
										+ "\n agent : " + navigator.userAgent);
		}
	}	
};


