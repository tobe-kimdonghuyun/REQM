              </Div>
              <Div id="divCont" taborder="1" left="0" top="88" width="100.00%" height="130">
                <Layouts>
                  <Layout>
                    <Div id="divBottom" taborder="0" left="7" top="0" width="893" maxwidth="" initvalueid="ivDivAccessibilityOff" text="" height="130">
                      <Layouts>
                        <Layout type="vertical" verticalgap="5">
                          <Static id="staInfoTitle" taborder="0" text="중앙상담센터" top="0" width="600" height="25" cssclass="sta_BF_Gov_baseTxt bold" initvalueid="ivStcAccessibilityOn" left="0"/>
                          <Static id="staTelNum_01" taborder="1" text="&lt;b v='true'&gt;1600-8400&lt;/b&gt; (나이스)" left="487" top="41" width="600" height="25" usedecorate="true" cssclass="sta_BF_Gov_baseTxt"/>
                          <Static id="staTelNum_02" taborder="2" text="&lt;b v='true'&gt;1600-7440&lt;/b&gt; (대국민 서비스)" left="487" top="41" width="600" height="25" usedecorate="true" cssclass="sta_BF_Gov_baseTxt"/>
                          <Static id="staOperTime" taborder="3" text="운영시간 : 08:00 ~ 18:00 평일(월~금, 주말 및 공휴일 제외)" top="82" height="25" cssclass="sta_BF_Gov_baseTxt" initvalueid="ivStcAccessibilityOn" left="0" width="600"/>
                        </Layout>
                        <Layout name="mobile">
                          <Static id="staOperTime" width="600" left="0" top="82" height="30" cssclass="sta_BF_Gov_baseTxt_M" text="운영시간 : 08:00 ~ 18:00 평일(월~금, 주말 및 공휴일 제외)"/>
                          <Static id="staInfoTitle" cssclass="sta_BF_Gov_baseTxt_M bold" height="30" left="0" top="0" width="600" text="중앙상담센터"/>
                          <Static id="staTelNum_01" height="30" left="487" top="41" width="600" cssclass="sta_BF_Gov_baseTxt_M"/>
                          <Static id="staTelNum_02" cssclass="sta_BF_Gov_baseTxt_M" height="30" left="487" top="41" width="600"/>
                        </Layout>
                      </Layouts>
                    </Div>
                    <Div id="divServiceLink" taborder="1" text="div00" top="0" height="divBottom:100.00%" width="200" left="divBottom:24">
                      <Layouts>
                        <Layout type="vertical" verticalgap="5">
                          <Button id="btnRemote" taborder="0" text="원격지원서비스" top="0" width="125" height="24" cssclass="btn_BF_Gov_servlink" initvalueid="ivBtnAccessibilityLink" onclick="divServiceLink_btnRemote_onclick" left="0" textAlign="left"/>
                          <Button id="btnSetTablet" taborder="1" text="태블릿화면 설정방법" top="0" width="180" height="24" cssclass="btn_BF_Gov_servlink" initvalueid="ivBtnAccessibilityLink" onclick="divServiceLink_btnSetTablet_onclick" left="0" textAlign="left" visible="false"/>
                        </Layout>
                        <Layout name="mobile">
                          <Button id="btnRemote" textAlign="left" cssclass="btn_BF_Gov_servlink_M" height="30" left="0" top="0" width="165"/>
                          <Button id="btnSetTablet" cssclass="btn_BF_Gov_servlink_M" height="30" left="0" top="0" width="190"/>
                        </Layout>
                      </Layouts>
                    </Div>
                  </Layout>
                  <Layout name="mobile" type="vertical" verticalgap="20">
                    <Div id="divServiceLink" left="-10" top="divBottom:20" width="200" height="70" cssclass="gov-dspFlex"/>
                    <Div id="divBottom" width="600" left="0" top="0" height="150" cssclass="gov-dspFlex"/>
                  </Layout>
                </Layouts>
              </Div>
              <Div id="divCopyright" taborder="2" text="div00" left="353" width="100%" height="45" cssclass="div_BF_Gov_copy" top="726">
