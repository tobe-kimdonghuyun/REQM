/**
 * 테블릿 화면 설정방법
 */
this.divServiceLink_btnSetTablet_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var popupParams = {
		callback: this.fnPopupCallback,
		sender: obj, // sender 지정
		params: {
			procType : 'none'
		},
		titlebar : false,
	};

	this.smfIsMobile() ? this.smfDialog("_auto", "comm::comm_browser_notice.xfdl", popupParams, null, null, 600, 960) : this.smfDialog("_auto", "comm::comm_browser_notice.xfdl", popupParams);
};

this.fnPopupCallback = function(e, sender){
};

/**
 * 디지털정부 UI/UX 적용 관련
 * 로그 출력
 */
this.logger = function(){
	if(this.USE_LOGGER){
		var baseLog = this._orgurl.replace(".xfdl","") + " > ";
		trace(baseLog, ...arguments);
	}
}]]></Script>
