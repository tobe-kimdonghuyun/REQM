                  <Layout type="horizontal" horizontalgap="10">
                    <Button id="btnMoe" taborder="0" top="0" width="92" height="48" cssclass="btn_BF_Gov_moe" initvalueid="ivBtnAccessibilityLink" left="0" accessibilitylabel="교육부 로고" onclick="divMain_btnMoe_onclick"/>
                    <ImageViewer id="img00_00_00_00_01_00_00" taborder="1" text="17개 시도교육청" left="btnMoe:16" top="0" width="130" height="48" cssclass="imv_BF_Gov_baseTxt bold txt_center" initvalueid="ivTitleAccessibilityOn"/>
                    <Button id="btnKeris" taborder="2" top="0" width="83" height="48" cssclass="btn_BF_Gov_keris" initvalueid="ivBtnAccessibilityLink" left="img00_00_00_00_01_00_00:16" accessibilitylabel="한국교육학술정보원 로고" onclick="divMain_btnKeris_onclick"/>
                    <Button id="btnWa" taborder="3" top="0" width="72" height="42" cssclass="btn_BF_wa" initvalueid="ivBtnAccessibilityLink" left="btnKeris:16" accessibilitylabel="웹접근성인증 로고" visible="false"/>
                  </Layout>
                  <Layout name="mobile" type="horizontal" horizontalgap="20">
                    <Button id="btnMoe" cssclass="btn_BF_Gov_moe_M" height="60" left="0" top="0" width="110"/>
                    <Button id="btnKeris" cssclass="btn_BF_Gov_keris_M" height="60" left="img00_00_00_00_01_00_00:16" top="0" width="110"/>
                    <Button id="btnWa" cssclass="btn_BF_Gov_wa_M" height="60" left="btnKeris:16" top="0" width="72"/>
                    <ImageViewer id="img00_00_00_00_01_00_00" height="60" left="btnMoe:16" top="0" width="150" cssclass="imv_BF_Gov_17edu_M"/>
                  </Layout>
