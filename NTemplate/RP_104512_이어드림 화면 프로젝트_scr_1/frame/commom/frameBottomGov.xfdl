                    <Div id="divPolicy" taborder="1" left="0" top="10" width="700" height="24" initvalueid="ivDivAccessibilityOff">
                      <Layouts>
                        <Layout type="horizontal">
                          <Button id="btnIndvInfo" taborder="0" text="개인정보처리방침" left="0" top="0" width="140" height="24" cssclass="btn_BF_Gov_policy indv" initvalueid="ivBtnAccessibilityLink" onclick="divPolicy_btnIndvInfo_onclick"/>
                          <Button id="btnUse" taborder="1" text="이용약관" left="140" top="0" width="80" height="24" cssclass="btn_BF_Gov_policy" initvalueid="ivBtnAccessibilityLink" visible="false" onclick="divPolicy_btnUse_onclick"/>
                          <Button id="btnLicense" taborder="2" text="저작권보호정책" left="220" top="0" height="24" cssclass="btn_BF_Gov_policy" initvalueid="ivBtnAccessibilityLink" onclick="divPolicy_btnLicense_onclick" width="133"/>
                          <Button id="btnAccessBility" taborder="3" text="웹접근성정책" left="353" top="0" width="113" height="24" cssclass="btn_BF_Gov_policy" initvalueid="ivBtnAccessibilityLink" onclick="divPolicy_btnAccessBility_onclick"/>
                        </Layout>
                        <Layout name="mobile" horizontalgap="10">
                          <Button id="btnIndvInfo" cssclass="btn_BF_Gov_policy_M indv" height="30" left="0" top="0" width="185"/>
                          <Button id="btnUse" cssclass="btn_BF_Gov_policy_M" height="30" left="140" top="0" width="100"/>
                          <Button id="btnLicense" cssclass="btn_BF_Gov_policy_M" height="30" left="220" top="0" width="165"/>
