        <ImageViewer id="imgTitle" cssclass="img_WF_Txt48B" height="80" left="112" top="71" width="417" taborder="0"/>
        <Static id="Static99_00_00_00_00" left="0" top="0" height="90" right="0" text="90" taborder="10"/>
        <Div id="div00" left="20" top="234" width="600" height="568" taborder="1"/>
        <ImageViewer id="imgTitle00" left="20" top="880" height="50" cssclass="img_WF_SubTit04S" width="590" taborder="2"/>
        <Static id="sta00_00_00_00_00" left="20" top="927" height="210" cssclass="sta_WF_Txt28L" text="1) 누구든지 인터넷 홈페이지 운영자 또는 관리자의 사전동의 없이 인터넷 홈페이지에서 자동으로 전자우편주소를 수집하는 프로그램이나 그 밖의 기술적 장치를 이용하여 전자우편주소를 수집하여서는 아니된다." width="600" taborder="3"/>
        <Static id="sta00_00_00_00_00_01" left="20" top="1169" height="100" cssclass="sta_WF_Txt28L" width="600" taborder="4"/>
        <Static id="sta00_00_00_00_00_01_00" left="20" top="1303" height="120" cssclass="sta_WF_Txt28L" width="600" taborder="5"/>
        <ImageViewer id="imgTitle00_00" left="20" top="1496" width="592" height="90" cssclass="img_WF_SubTit04S" text="제70조 (벌칙)에 따라 7년 이하의 징역 또는 5천만원&#13;&#10;이하의 벌금에 처한다." taborder="6"/>
        <Static id="sta00_00_00_00_00_00" left="20" top="1587" height="120" width="600" taborder="7"/>
