<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="scr_site04" width="1340" height="482" titletext="저작권보호정책" onload="form_onload">
    <Layouts>
      <Layout height="482" width="1340" screenid="desktopScr">
        <Static id="Static09" taborder="0" text="저작권보호정책" left="20" top="0" height="95" cssclass="sta_WF_Title" accessibilityrole="heading" right="0"/>
        <Static id="Static00" taborder="1" text="저작권법 제24조의 2(공공저작물의 자유이용)에 따라 온라인 학부모 소통 서비스 홈페이지를 통해 제공하는 공개 자료는 저작재산권의 전부를 보유한 저작물(이하 저작물)의 경우, 별도의 이용허락 없이 자유 이용이 가능합니다.&#10;   &#10;단, 자유이용이 가능한 저작물은 공공저작물 자유이용허락 표시 기준(공공누리, KOGL) 제1유형을 부착하여 공개된 자료입니다. 이용자께서는 반드시 저작물의 출처를 구체적으로 표시해주십시오. 공공누리가 부착되지 않은 경우 혹은 저작물로 수익을 얻는 등 혜택을 누리고자 하는 경우, 해당 서비스 담당자와 사전 협의 후 이용하여 주시기 바랍니다.&#10;   &#10;저작물은 저작권법에 의해 보호를 받으므로 무단 변경·복제·배포·사용(홈페이지 링크 연결 등)할 경우, 저작권법에 의하여 저작재산권 침해 죄에 해당될 수 있습니다. 적법한 절차에 따라 저작물을 사용하는 경우에도 위의 사항을 어길시 처벌 받을 수 있습니다." left="20" top="Static09:0" height="144" fittocontents="height" cssclass="sta_WF_SiteTxtBox" right="0"/>
        <Static id="Static01_00_00" taborder="2" text="출처표시 준수사항" left="30" top="Static00:30" height="24" right="0" cssclass="sta_WF_SiteTitle01"/>
        <Static id="Static04_00_00" taborder="3" text="출처표시 예시를 활용하여 작성연도, 해당 기관명, 홈페이지 주소, 작성자명을 기입합니다.&#10;온라인에서 출처 웹사이트에 대한 하이퍼링크를 제공하는 것이 가능한 경우, 반드시 링크를 제공합니다.&#10;제3자의 입장에서 이용자와 본 기관이 특수한 관계에 높여있다는 여지를 두는 등 오인 가능성이 있는 표시를 해서는 안 됩니다." left="30" top="Static01_00_00:15" height="60" right="0" cssclass="sta_WF_SiteTxt01" fittocontents="height"/>
        <Static id="Static01_00_00_00" taborder="4" text="출처표시 예시" left="30" top="Static04_00_00:35" height="24" right="0" cssclass="sta_WF_SiteTitle01"/>
        <Static id="Static04_00_00_00" taborder="5" text="본 저작물은 온라인 학부모 소통 서비스(교육부)에서 공공누리 제1유형으로 개방한 저작물입니다. 저작물명(작성자:  )을 이용하였으며, 해당 저작물은 (작성년도)년에 온라인 학부모 소통 서비스에서 작성된 게시물로 sotong.neis.go.kr에서  무료로 다운받으실 수 있습니다." left="30" top="Static01_00_00_00:15" height="40" right="0" cssclass="sta_WF_SiteTxt01" fittocontents="height"/>
      </Layout>
      <Layout height="514" mobileorientation="Portrait" name="tablet" type="default" width="800" screenid="desktopScr,tabletScr">
        <Static id="Static04_00_00" left="30" top="Static01_00_00:15" height="60" right="0"/>
        <Static id="Static04_00_00_00" left="30" top="Static01_00_00_00:15" height="40" right="0"/>
        <Static id="Static00" left="20" top="Static09:0" height="176" right="0"/>
      </Layout>
      <Layout height="685" mobileorientation="Portrait" name="mobile" type="default" width="480" screenid="desktopScr,mobieScr">
        <Static id="Static09" left="15" top="0" height="60" right="15" cssclass="sta_WF_TitleM"/>
        <Static id="Static01_00_00" left="15" top="Static00:30" height="24" right="15"/>
        <Static id="Static04_00_00" left="15" top="Static01_00_00:15" height="120" right="15"/>
        <Static id="Static01_00_00_00" left="15" top="Static04_00_00:35" height="24" right="15"/>
        <Static id="Static04_00_00_00" left="15" top="Static01_00_00_00:15" height="80" right="15"/>
