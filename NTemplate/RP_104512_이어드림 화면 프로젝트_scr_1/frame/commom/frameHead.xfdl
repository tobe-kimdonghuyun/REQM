    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    TEMPLATE
*  @FileName 	frameHead.xfdl
*  @Creator 	홍길동
*  @CreateDate 	2022.5.27
*  @Desction    검정고시p72+(공지목록)+(타이틀,그리드)
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.5.27     	홍길동 	        최초 생성 
*******************************************************************************
*/


/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::sm_script.xjs";
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_filter = "";
this.fv_lastMenu_url = "";
this.fv_lastMenu_param = {};
/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitDiv(obj);
};

/**
 * @description 화면 onsize시 처리
*/
this.form_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnSetMenu = function(sUrl, pParam)
{
	// 상단의 TopFrame의 데이터셋을 가져온다.
	// dsMenu가 변경이 되어 있을 수도 있어서 항산 받아오는 것으로
	//if(this.dsMenu.rowcount==0)
	//{
		this.dsMenu.copyData(this.getOwnerFrame().form.divTop.form.dsMenu);
	//}

	this.fv_lastMenu_url = sUrl;
	this.fv_lastMenu_param = pParam;

	// sUrl로 메뉴레벨별 메뉴아이디를 구한다.
	// 메뉴아이디가 있으면 메뉴아이디로 검색한다.
	// 메뉴아이디가 없으면 메뉴URL로 검색한다. (복수개인 경우 맨 처음 것)
	var nFindRow = -1;
	
	var sMenuId = "";
	if(pParam && (pParam.menu))
	{
		sMenuId = pParam.menu;
	}
	
	if(this.smfIsNull(sMenuId))
	{
		nFindRow =this.dsMenu.findRow("menuUrl",sUrl);
	}
	else
	{
		nFindRow =this.dsMenu.findRow("menuId",sMenuId);
	}
	
	
	
	// 일치하는 URL이 없는 경우(클리어할 것인지 확인필요)
	if(nFindRow < 0)
	{
		return;
	}
	

	// 현재의 레벨을 구한다.
	var nlvl = this.dsMenu.lookup("menuUrl" , sUrl, "lvl");
	//trace(" nlvl : " + nlvl );

	var aMenuPathInfo,sMenuIdLevel0,sMenuIdLevel1;

//@KBR 주석처리  pParam.menuLvl 던지지 않음.
//	if ( pParam && pParam.menuLvl  == 1)
//	{
//		aMenuPathInfo = this.fnGetMenuPathInfo(nFindRow);		
//		sMenuIdLevel0 = aMenuPathInfo[0];
//		sMenuIdLevel1 = aMenuPathInfo[1];
//	}else
//	{
		if ( nlvl == 0 )
		{
			aMenuPathInfo = this.fnGetMenuPathInfoByTopDown(nFindRow);
			sMenuIdLevel0 = aMenuPathInfo[0];
			sMenuIdLevel1 = aMenuPathInfo[1];

		}else
		{
			aMenuPathInfo = this.fnGetMenuPathInfo(nFindRow);		
			sMenuIdLevel0 = aMenuPathInfo[0];
			sMenuIdLevel1 = aMenuPathInfo[1];		
		}
//	}


	// 데이터셋을 가져간다.
	if ( this.dsMenuLevel1.rowcount == 0 )
	this.dsMenuLevel1.copyData(this.dsMenu);
	if ( this.dsMenuLevel2.rowcount == 0 )
	this.dsMenuLevel2.copyData(this.dsMenu);
	
	
	var sAppendedFilterStr = (this.smfIsNull(this.fv_filter)?"":("&&("+this.fv_filter+")"))
	//menu text 셋팅
	this.dsMenuLevel0.filter("lvl=='0'" + sAppendedFilterStr);
	var menuName = this.dsMenu.lookup("menuId",sMenuIdLevel0,"menuName");
	this.divMenuIndicator.form.btnMenuLevel0.set_text(menuName);
	this.divMenuIndicator.form.btnMenuLevel0.set_visible(true);

	
	//타이틀 셋팅을 위한 변수
	var sMenu, cboMenu; 
	if( !this.smfIsMobile() ){	
		//this.dsMenuLevel1.filter("lvl=='1'&&parentMenuId=='"+sMenuIdLevel0+"'" + sAppendedFilterStr);
		this.dsMenuLevel1.filter("lvl=='1'&&parentMenuId=='"+sMenuIdLevel0+"'&&isShow!='N'" + sAppendedFilterStr);
		if ( aMenuPathInfo.length == 1 )
		{
			this.divMenuIndicator.form.cboMenuLevel1.set_visible(false);
			this.divMenuIndicator.form.staSectionLine01.set_visible(false);
			
		}else if(aMenuPathInfo.length > 1 )
		{
			if(this.dsMenuLevel1.rowcount == 0 ){
				this.divMenuIndicator.form.cboMenuLevel1.set_visible(false);
				this.divMenuIndicator.form.staSectionLine01.set_visible(false);		
			}else if(this.dsMenuLevel1.rowcount > 1){
				this.divMenuIndicator.form.cboMenuLevel1.set_visible(true);
				this.divMenuIndicator.form.staSectionLine01.set_visible(true);	
			}
		}
		
		var nRow = this.dsMenuLevel1.findRow("menuId",sMenuIdLevel1);
		if ( nRow > -1 ) 
		{
			this.divMenuIndicator.form.cboMenuLevel1.set_index(nRow);
		}	
		
		sMenu = this.divMenuIndicator.form.btnMenuLevel0.text;
		cboMenu = this.divMenuIndicator.form.cboMenuLevel1.text;		
	}
	else{
		if ( aMenuPathInfo.length == 1 )
		{
			this.divMenuIndicator.form.btnMenuLevel1.set_visible(false);
			this.divMenuIndicator.form.staSectionLine01.set_visible(false);
		}else if(aMenuPathInfo.length > 1 )
		{
			this.divMenuIndicator.form.btnMenuLevel1.set_visible(true);
			this.divMenuIndicator.form.staSectionLine01.set_visible(true);
		}
		
		//@KBR 모바일 btnMenuLevel1 text셋팅
		var menuLv1Name = this.dsMenu.lookup("menuId",sMenuIdLevel1,"menuName");
		this.divMenuIndicator.form.btnMenuLevel1.set_text(menuLv1Name);	
		
		//@KBR 모바일 버튼 fittoncontents위함.
		this.divMenuIndicator.form.resetScroll();
		
		sMenu =  this.divMenuIndicator.form.btnMenuLevel0.text;
		cboMenu = this.divMenuIndicator.form.btnMenuLevel1.text;
	}
	
	if (!this.smfIsNull(cboMenu))	cboMenu = sMenu +"|"+ cboMenu;
	else cboMenu = sMenu;
	
	if (!this.smfIsNull(cboMenu)) {
		this.getOwnerFrame().form.fnSetTitleText( cboMenu );
	}	
}


this.fnSetCddcName = function()
{
	var sCddcCode = this.smfGetCddcCode();
	var sCddcName = this.dsCddcList.lookup("cddcCd",sCddcCode,"cddcNm");
	
	if(this.smfIsNull(sCddcName)) sCddcName = "";
	
	this.divMenuIndicator.form.staCddcName.set_text(sCddcName);
}


////메뉴 level 1 
this.fnGetMenuPathInfo = function(nTargetRow)
{
	var aMenuPathInfo = [];
	
	var nCurLevel = parseInt(this.dsMenu.getColumn(nTargetRow,"lvl")); 
	var aMenuId = ["","",""];
	for(var i=nTargetRow;i>=0;i--)
	{
	
		var nLevel = parseInt(this.dsMenu.getColumn(i,"lvl")); 
		var sMenuId = this.dsMenu.getColumn(i,"menuId"); 
		
		if(nCurLevel>=nLevel)
		{	
			aMenuId[nCurLevel] =  sMenuId; 
			
			if(nCurLevel==0) break;
			
			nCurLevel--;
		}
		
	}	
	
	return aMenuId;
	
}


//메뉴 level 0 
this.fnGetMenuPathInfoByTopDown = function(nTargetRow)
{
	//해당 row 레벨 포함 하위 첫번째 메뉴 Id 반환
	var nMax = this.dsMenu.getMax("lvl");
	//trace(" Max : " + nMax );
	var sTargetMenuId = this.dsMenu.getColumn(nTargetRow,"menuId");
	var aMenuId = new Array();
	aMenuId[0] = sTargetMenuId;
	for( var i= 1 ;i < nMax + 2 ;i++)
	{
		if ( sTargetMenuId )
		{
			var menuId = this.dsMenu.lookup("parentMenuId",sTargetMenuId,"menuId");
			var isShow = this.dsMenu.lookup("parentMenuId",sTargetMenuId,"isShow");
			if(this.smfIsNull(isShow)) isShow = "Y";  //isShow default "Y"

			if ( menuId && isShow == "Y")
			{
				sTargetMenuId = menuId;
				aMenuId[i] = menuId;
			}
		}
	}

	return aMenuId;
};


// filter를 세팅한다.
this.fnSetFilter = function(sFilter)
{
	if(sFilter==this.fv_filter) return;
	
	
	this.fv_filter	= sFilter;
	
	// 전체 데이터셋을 처리한다.	
	this.dsMenu.filter(sFilter); 
	
	// 메뉴를 다시 그림
	this.fnSetMenu(this.fv_lastMenu_url,this.fv_lastMenu_param);
}

// 현재 세팅된 filter정보를 가져온다.
this.fnGetFilter = function()
{
	this.fv_filter;
}

// 현재 필터를 클리어 한다.
this.fnClearFilter = function()
{
	this.fnSetFilter("");
	
	this.fv_lastMenu_url = "";
	this.fv_lastMenu_param = {};	
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/


this.Combo_ondropdown = function(obj:nexacro.Combo,e:nexacro.EventInfo)
{
	obj.set_cssclass("cbo_LNB_F");		
};

this.Combo_oncloseup = function(obj:nexacro.Combo,e:nexacro.ComboCloseUpEventInfo)
{
	obj.set_cssclass("cbo_LNB_N");	
	
//@KBR 주석처리
// 	var params = {};
// 	params.IsHeadChange = false;
// 	params.menuLv1 = 1;
	
	var sUrl = this[obj.innerdataset].getColumn(e.postindex,"menuUrl");	
	var sMenuId = this[obj.innerdataset].getColumn(e.postindex,"menuId");	
	
	if(!this.smfIsNull(sUrl))
	{	
		//@KBR param menu,_url 셋팅
		var params = {menu : sMenuId, 
					  _url:sUrl};
		this.smfSetWorkPage(sUrl, params);	
	}		
};

this.divMenuIndicator_btnHome_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objFrame = this.getOwnerFrame();

	if(objFrame.form.divAll)
	{
		// Top 에 값을 세팅
		var sMainUrl = objFrame.form.fv_firstformUrl;
		
		// 메인URL로 이동한다.
		if(!this.smfIsNull(sMainUrl))
		{
			
			//@KBR 채용/업무지원 Top영역 조절
			var sSubSystemGb =  this.smfGetSubSystemGb();
			if(  (sSubSystemGb=="AFS")   // 업무지원(외부강사)
			  || (sSubSystemGb=="ECC")   // 업무지원(돌봄인력서비스)
			  || (sSubSystemGb=="IBM")   // 업무지원(교과용도서)
			  || (sSubSystemGb=="SEM")   // 업무지원(학교환경관리)
			  || (sSubSystemGb=="PHE")   // 업무지원(체육)
			  || (sSubSystemGb=="SML")   // 업무지원(급식)
			  || (sSubSystemGb=="SPR")   // 업무지원(교육복지)
			  //|| (sSubSystemGb=="ORE")   // 온라인채용(교원임용)
			  //|| (sSubSystemGb=="HRD")   // 온라인채용(계약제교원인력풀)	
			 )
			{
				objFrame.form.divTop.form.fnRearrageTopComp(sSubSystemGb,"collapse");
			}			
			if(sSubSystemGb == "ORE" || sSubSystemGb=="HRD"){
				sMainUrl = objFrame.form.fv_mainformUrl;
			}
			// 메인화면으로 이동한다.
			objFrame.form.fnSetMainpage(sMainUrl);	
		}
	}
};

this.divMenuIndicator_cboMenuLevel1_onmouseenter = function(obj:nexacro.Combo,e:nexacro.MouseEventInfo)
{
	obj.set_cssclass("cbo_LNB_O");
};

this.divMenuIndicator_cboMenuLevel1_onmouseleave = function(obj:nexacro.Combo,e:nexacro.MouseEventInfo)
{
	obj.set_cssclass("cbo_LNB_N");	
};

this.divMenuIndicator_cboMenuLevel2_onmouseleave = function(obj:nexacro.Combo,e:nexacro.MouseEventInfo)
{
	obj.set_cssclass("cbo_LNB_O");	
	
};

this.divMenuIndicator_cboMenuLevel2_onmousemove = function(obj:nexacro.Combo,e:nexacro.MouseEventInfo)
{
	obj.set_cssclass("cbo_LNB_N");	
	
};
]]></Script>
  </Form>
</FDL>
