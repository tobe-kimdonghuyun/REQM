<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmTemp01" width="1200" height="864" onload="frmTemp01_onload" titletext="원격지원서비스">
    <Layouts>
      <Layout height="864" width="1200" screenid="ScreenDeskTop">
        <ImageViewer id="imgTitle" taborder="0" text="원격지원서비스" left="0" top="60" height="54" cssclass="img_WF_SubTit01" width="217" initvalueid="ivTitleAccessibilityOn"/>
        <ImageViewer id="imgTitle00" taborder="1" text="이용안내사항" left="0" top="145" height="40" cssclass="img_WF_SubTit02" width="140" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00" taborder="2" text="본 서비스는 고객님의 PC에 상담원이 원격으로 접속하여 문제해결을 지원하여 드리는 서비스 입니다." left="10" top="192" width="1000" height="26" cssclass="sta_WF_Info16Black" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_00" taborder="3" text="기술지원센터 또는 소속 시도교육청 상담원과 통화 연결상태에서 본 서비스를 이용하실 수 있습니다." left="10" top="228" width="1000" height="26" cssclass="sta_WF_Info16Black" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_00_00" taborder="4" text="서비스 이용 시 고객님의 PC에서 작업중인 개인데이터, 비밀이나 보안을 요구하는 자료는 반드시 종료 후 서비스를 요청하시기 바라며, 원격서비스를 하는 중에 고객님의&#13;&#10;정보가 열람 될 수 있습니다." left="10" top="262" width="1130" height="50" cssclass="sta_WF_Info16Black" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_00_00_00" taborder="5" text="입력하신 개인 정보는 개인 정보보호정책에 의하여 기밀로 유지됩니다." left="10" top="319" width="800" height="26" cssclass="sta_WF_Info16Black" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_00_00_00_00" taborder="6" text="서비스 도중 발생할 수 있는 데이터의 손실이나 소멸, 컴퓨터의 오작동 등 서비스와 연관된 모든 직, 간접, 특수, 우연 또는 결과적 손상에 대하여 일체의 책임을 지지 않습니다." left="10" top="354" width="1150" height="26" cssclass="sta_WF_Info16Black" initvalueid="ivStcAccessibilityOn"/>
        <Div id="div00" taborder="7" text="div00" left="0" top="454" height="200" width="1200" cssclass="div_WF_KinderBox" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle00" taborder="0" text="이용동의" left="27" top="31" height="40" cssclass="img_WF_SubTit02" width="100" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_00_00_00_00" taborder="1" text="본 서비스 사용시에는 고객님의 PC의 원격지원 프로그램을 설치하여야 하며, 문의사항 해결을 위해 상담직원이 고객님의 pc를 원격으로 지원할 수 있습니다.&#13;&#10;본 서비스 중 발생한 문제에 대하여 일체의 책임은 없습니다." left="30" top="72" width="1150" height="50" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16"/>
              <CheckBox id="chk00" taborder="2" text="원격지원서비스 이용에 동의합니다." left="895" top="143" width="275" height="40" cssclass="Pas" initvalueid="ivChkNormal"/>
              <Static id="Static99_00_00_00_00_00_00_00_00_00_00" taborder="3" left="0" top="0" height="40" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="Static99_00_00_00_00_00_00_00_00_00_00_00" taborder="4" left="0" top="40" height="90" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30"/>
              <Static id="Static99_00_00_00_00_00_00_00_00_00_00_01" taborder="5" left="30" top="64" height="14" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
              <Static id="Static99_00_00_00_00_00_00_00_00_00_00_00_00" taborder="6" left="970" height="30" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100" bottom="0"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta00_00_00_00_00_00" taborder="8" text="※고객님께서는 정보주체로서 원격지원서비스 동의 거부권이 있으시며, 미동의 시 원격지원서비스 이용에 제약이 있을 수 있습니다." left="10" top="687" width="900" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16"/>
        <Static id="sta00_00_00_00_00_00_00" taborder="9" text=" IE가 아닌 멀티 브라우저 고객은 '여기'를 클릭해 실행 해 주시기 바랍니다." left="10" top="709" width="700" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16B"/>
        <Edit id="edt00" taborder="10" left="326" width="420" height="50" displaynulltext="인증번호를 입력해주세요" cssclass="edi_WF_Policy" top="814" initvalueid="ivEdtNormal"/>
        <Button id="btn00" taborder="11" text="서비스 시작" top="814" width="114" height="50" cssclass="btn_WF_PolicySch" initvalueid="ivBtnAccessibilityButton" left="edt00:12"/>
        <Static id="Static99_00_00_00_00" taborder="12" left="0" top="0" height="60" cssclass="sta_GD_Size" text="60" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
        <Static id="Static99_00_00_00_00_00" taborder="13" left="0" top="114" height="40" cssclass="sta_GD_Size" text="40" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
        <Static id="Static99_00_00_00_00_00_00" taborder="14" left="0" top="178" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
        <Static id="Static99_00_00_00_00_00_00_00" taborder="15" left="0" top="213" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
        <Static id="Static99_00_00_00_00_00_00_00_00" taborder="16" left="0" top="249" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
        <Static id="Static99_00_00_00_00_00_00_00_00_00" taborder="17" left="0" top="306" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
        <Static id="Static99_00_00_00_00_00_00_00_00_00_00" taborder="18" left="0" top="340" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
        <Static id="Static99_00_00_00_00_00_01" taborder="19" left="0" top="374" height="80" cssclass="sta_GD_Size" text="80" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
        <Static id="Static99_00_00_00_00_00_01_00" taborder="20" left="0" top="654" height="40" cssclass="sta_GD_Size" text="40" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
        <Static id="Static99_00_00_00_00_00_01_00_00" taborder="21" left="0" top="733" height="80" cssclass="sta_GD_Size" text="80" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
      </Layout>
    </Layouts>
