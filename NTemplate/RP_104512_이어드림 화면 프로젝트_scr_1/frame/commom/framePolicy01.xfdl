    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    샘플
*  @FileName 	framePolicy01.xfdl
*  @Creator 	정인혁
*  @CreateDate 	2022.10.12
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.10.12     	정인혁 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 this.framePolicy01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitForm(this);
	
	// 서브시스템에 따라 다른 화면으로 이동
	var sSubSys = this.smfGetSubSystemGb();
	
	var sUrl = "frame::commom/framePolicy_New_01.xfdl";
	if(  (sSubSys=="ORE")   // 온라인채용
	  || (sSubSys=="HRD")   // 온라인채용(계약직)
	  )
	{
		sUrl = "frame::commom/framePolicy_New_02.xfdl";
	}
	else if(sSubSys=="PAR")  // 유치원
	{
		sUrl = "frame::commom/framePolicy_New_03.xfdl";
	}
	else if(sSubSys=="EWS")  // 학교행정
	{
		sUrl = "frame::commom/framePolicy_New_04.xfdl";
	}
	else if(sSubSys=="SQA" 		// 검정고시
		 || sSubSys=="HES" 		// 학원민원
		 || sSubSys=="BDM") 	// 비영리법인민원 
	{
		sUrl = "frame::commom/framePolicy_New_05.xfdl";
	}else
	{
		sUrl = "frame::commom/framePolicy_New_01.xfdl";
	}
	
	this.divPolicy.set_url(sUrl);
	
	// 화면을 맨 위로 이동
	this.getOwnerFrame().form.divAll.form.scrollTo(0,0);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
	
};
