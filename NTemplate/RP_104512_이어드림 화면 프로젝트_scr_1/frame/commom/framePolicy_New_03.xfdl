              <Static id="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_01_00_00_00_00_00" taborder="150" text="1. 개인정보보호 관련 고객 상담 및 신고" top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_00:10" height="39" cssclass="font26R_M" initvalueid="ivStcAccessibilityOn" left="55" fittocontents="height" letterSpacing="-1px" usedecorate="false" right="17"/>
              <Static id="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_01_00_00_00_00_01" taborder="151" text="- 소속: 한국교육학술정보원 교육행정본부 4세대나이스부&#13;&#10;- 담당자: 박유나연구원&#13;&#10;- 전자우편: &lt;l v='mailto:think1111@keris.or.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;think1111@keris.or.kr&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;&#13;&#10;- 연락처: 044-410-1235" top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_01_00_00_00_00_00:0" height="195" cssclass="font26R_M" initvalueid="ivStcAccessibilityOn" left="52" fittocontents="height" letterSpacing="-1px" usedecorate="true" right="17"/>
              <Static id="sta01_02_00_00_01_01_01_01_01_02_01_00_01_01_00_00" taborder="152" text="③" left="17" top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_01_00_00_00_00_01:20" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="세 번째"/>
              <Static id="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_00_00" taborder="153" text="「개인정보보호법」 제35조(개인정보의 열람), 제36조(개인정보의 정정·삭제), 제37조(개인정보의 처리정지 등)의 규정에 의한 요구에 대하여 공공기관의 장이 행한 처분 또는 부작위로 인하여 권리 또는 이익의 침해를 받은 자는 「행정심판법」이 정하는 바에 따라 행정심판을 청구할 수 있습니다. " top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_01_00_00_00_00_01:20" height="234" cssclass="font26R_M" initvalueid="ivStcAccessibilityOn" left="52" fittocontents="height" letterSpacing="-1px" right="17"/>
              <Static id="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_00_00_00" taborder="154" text="1. 중앙행정심판원: (국번없이) 118(&lt;l v='http://www.simpan.go.kr'&gt;&lt;fc v='#2b72de'&gt;www.simpan.go.kr&lt;/fc&gt;&lt;/l&gt;)" top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_00_00:10" height="74" cssclass="font26R_M" initvalueid="ivStcAccessibilityOn" left="52" fittocontents="height" letterSpacing="-1px" usedecorate="true" right="17"/>
              <ImageViewer id="img00_00_00_00_00_00_00_00_00_00_00_00_01_00" taborder="155" text="제15조 개인정보처리방침 변경에 관한 사항" left="10" top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_00_00_00:40" height="115" cssclass="font26B_icon" initvalueid="ivTitleAccessibilityOn" image="url('imagerc::policy_M/Ico15S_M.png')" imagealign="left middle" right="17"/>
              <Static id="sta01_02_00_00_01_01_01_01_01_02_01_00_01_01_01" taborder="156" text="① " left="17" top="img00_00_00_00_00_00_00_00_00_00_00_00_01_00:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_02" taborder="157" text="나이스플러스 및 유아나이스는 「개인정보보호법」제30조(개인정보 처리방침의 수립 및 공개)에 따라 개인정보처리방침을 변경하는 경우 정보주체가 쉽게 확인할 수  있도록 홈페이지에 공개하고 변경이력을 관리하고 있습니다." top="img00_00_00_00_00_00_00_00_00_00_00_00_01_00:15" height="195" cssclass="font26R_M" initvalueid="ivStcAccessibilityOn" left="52" fittocontents="height" letterSpacing="-1px" right="17"/>
              <Static id="sta01_02_00_00_01_01_01_01_01_02_01_00_01_01_01_00" taborder="158" text="② " left="17" top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_02:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_02_00" taborder="159" text="이 개인정보 처리방침은 2023년 6월 19일부터 적용됩니다." top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_02:15" height="78" cssclass="font26R_M" initvalueid="ivStcAccessibilityOn" left="52" fittocontents="height" letterSpacing="-1px" right="17"/>
              <Static id="sta01_02_00_00_01_01_01_01_01_02_01_00_01_01_01_00_00" taborder="160" text="③ " left="17" top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_02_00:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_02_00_00" taborder="161" text="이전의 개인정보처리방침은 아래에서 확인하실 수 있습니다." top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_02_00:15" height="78" cssclass="font26R_M" initvalueid="ivStcAccessibilityOn" left="52" fittocontents="height" letterSpacing="-1px" right="17"/>
              <Button id="btnButton150000" left="52" top="btnButton1500:10" width="474" height="60"/>
              <Button id="btnButton1500" height="60" left="52" top="sta01_02_00_00_01_01_00_00_01_01_02_00_00_00_00_00_00:10" width="474"/>
              <Combo id="cboBeforePrivetePolicy" cssclass="cbo_WF_M" height="100" left="52" top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_02_00_00:24" right="52"/>
            </Layout>
