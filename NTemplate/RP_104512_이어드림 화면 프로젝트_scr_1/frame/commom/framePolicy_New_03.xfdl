              <Static id="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_02_00" taborder="160" text="이 개인정보 처리방침은 2023년 6월 19일부터 적용됩니다." top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_02:15" height="21" cssclass="sta_WF_Txt16L" initvalueid="ivStcAccessibilityOn" left="55" fittocontents="height" letterSpacing="-1px" right="30"/>
              <Static id="sta01_02_00_00_01_01_01_01_01_02_01_00_01_01_01_00_00" taborder="161" text="③ " left="30" top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_02_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="첫 번째" visible="false"/>
              <Static id="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_02_00_00" taborder="162" text="이전의 개인정보처리방침은 아래에서 확인하실 수 있습니다." top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_02_00:15" height="21" cssclass="sta_WF_Txt16L" initvalueid="ivStcAccessibilityOn" left="55" fittocontents="height" letterSpacing="-1px" right="30" visible="false"/>
              <Combo id="cboBeforePrivetePolicy" taborder="163" text="이력보기" width="365" height="50" value="" index="-1" left="55" initvalueid="ivCmbNormal" top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_02_00_00:24" innerdataset="dsBeforePolicyList" codecolumn="file" datacolumn="name" onitemchanged="cboBeforePrivetePolicy_onitemchanged" cssclass="Pas" visible="false"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00" taborder="164" left="30" top="0" height="36" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="28"/>
            </Layout>
            <Layout name="default0">
              <ImageViewer id="img00" taborder="0" text="제1조 개인정보의 처리 목적" left="10" top="31" height="115" cssclass="font26B_icon" initvalueid="ivTitleAccessibilityOn" image="url('imagerc::policy_M/Ico01S_M.png')" imagealign="left middle" right="17"/>
              <Static id="sta01" taborder="1" text="① " left="17" top="img00:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta01_00" taborder="2" text="학부모서비스는 다음의 목적을 위하여 최소한의 개인정보를 처리합니다. 처리하고 있는 개인정보는 다음의 목적 이외의 용도로는 이용되지 않으며, 이용 목적이 변경되는 경우 「개인정보 보호법」 제18조에 따라 별도의 동의를 받는 등 필요한 조치를 이행할 예정입니다. " left="52" top="img00:15" height="234" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_01" taborder="3" text="1. 회원가입" left="46" top="sta01_00:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_00_00" taborder="4" text="- 회원제 서비스 제공에 따른 본인 식별 및 인증은 인증 시 동의한 서비스 이용 약관에 준합니다.&#13;&#10;- 학부모서비스는 만 14세 미만 아동의 경우 회원가입이 불가합니다." left="52" top="sta01_01:4" height="156" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_01_00" taborder="5" text="2. 회원 관리" left="46" top="sta01_00_00:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_00_00_00" taborder="6" text="- 회원자격 유지·관리, 서비스 부정 이용 방지, 각종 고지 및 통지 업무" left="52" top="sta01_01_00:4" height="78" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_01_00_00" taborder="7" text="3. 민원사무" left="46" top="sta01_00_00_00:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_00_00_00_00" taborder="8" text="- 개인정보 열람 등 요구 처리를 위한 행정 업무, 민원인의 신원 확인, 민원 사항 확인을 위한 연락·통지, 처리 결과 통보&#13;&#10;- 민원 처리 등을 위한 원활한 의사소통 경로의 확보&#13;&#10;- 향후 분쟁 조정을 위한 기록보존" left="52" top="sta01_01_00_00:4" height="195" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_01_00_00_00" taborder="9" text="4. 서비스 운영 및 개선" left="46" top="sta01_00_00_00_00:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_00_00_00_00_00" taborder="10" text="- 신규 서비스 개발 및 특화, 이벤트 정보의 안내" left="52" top="sta01_01_00_00_00:4" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <ImageViewer id="img00_00" taborder="11" text="제2조 개인정보 처리 및 보유 기간" left="10" top="sta01_00_00_00_00_00:40" height="115" cssclass="font26B_icon" initvalueid="ivTitleAccessibilityOn" image="url('imagerc::policy_M/Ico02S_M.png')" imagealign="left middle" right="17"/>
              <Static id="sta01_02_00_00" taborder="12" text="① " left="17" top="img00_00:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta01_00_01_00_00" taborder="13" text="학부모서비스에서 법령에 따른 개인정보 보유·이용 기간 또는 정보주체로부터 개인정보 수집 시에 동의받은 개인정보 보유·이용 기간 내에서 개인정보를 처리하고 보유합니다." left="52" top="img00_00:15" height="156" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_00" taborder="14" text="② " left="17" top="sta01_00_01_00_00:20" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="두 번째"/>
              <Static id="sta01_00_01_00_00_00" taborder="15" text="학부모서비스에서 이용하는 개인정보의 보유 기간은 다음과 같습니다. " left="52" top="sta01_00_01_00_00:20" height="78" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_01_01" taborder="16" text="1. 회원가입·관리 및 민원사무" left="46" top="sta01_00_01_00_00_00:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="30" width="522"/>
              <Static id="sta01_00_00_01" taborder="17" text="- 회원탈퇴 전까지&#13;&#10;- 최종 접속(로그인 기준)일로부터 2년&#13;&#10;- 서비스 이용에 따른 민원사무 처리 종료 후 10년" left="52" top="sta01_01_01:4" height="117" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_01_01_00" taborder="18" text="2. 다만, 다음의 사유에 해당하면, 해당 사유 종료 시까지" left="46" top="sta01_00_00_01:15" height="78" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="30" width="522"/>
              <Static id="sta01_00_00_01_00" taborder="19" text="- 회원이 사전에 동의한 경우&#13;&#10;- 법령 등에서 일정 기간 보관을 규정하는 경우 &#13;&#10;- 관계 법령 위반에 따른 수사·조사 등이 진행 중이면 해당 수사·조사 종료 시까지" left="52" top="sta01_01_01_00:4" height="156" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <ImageViewer id="img00_00_00" taborder="20" text="제3조 처리하는 개인정보 항목" left="10" top="sta01_00_00_01_00:40" height="115" cssclass="font26B_icon" initvalueid="ivTitleAccessibilityOn" image="url('imagerc::policy_M/Ico07S_M.png')" imagealign="left middle" right="17"/>
              <Static id="sta01_02_00_00_01" taborder="21" text="① " left="17" top="img00_00_00:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta01_00_01_00_00_01" taborder="22" text="학부모서비스는 다음의 개인정보 항목을 처리하고 있습니다." left="52" top="img00_00_00:16" height="78" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_01_01_00_00" taborder="54" text="1. 회원가입·관리 및 민원사무" left="46" top="sta01_00_01_00_00_01:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_01_01_00_00_00" taborder="55" text="‣ 학부모&#13;&#10;- (필수) 이름, 아이디, 이메일 주소" left="56" top="sta01_01_01_00_00:5" height="78" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_01_01_00_00_00_00" taborder="56" text="‣ 자녀 정보&#13;&#10;- (필수) 이름, 소속 및 학적(반, 번호)" left="56" top="sta01_01_01_00_00_00:5" height="78" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_01_01_00_00_01" taborder="57" text="2. 서비스 운영 및 개선" left="46" top="sta01_01_01_00_00_00_00:10" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_01_01_00_00_00_00_00" taborder="58" text="‣ 학부모&#13;&#10;- (필수) 서비스 이용기록, 접속 이력" left="56" top="sta01_01_01_00_00_01:5" height="78" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_00" taborder="23" text="② " left="17" top="sta01_01_01_00_00_00_00_00:20" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="두 번째"/>
              <Static id="sta01_00_01_00_00_01_00" taborder="24" text="회원은 학부모서비스 회원가입, 회원 관리, 민원사무, 서비스 운영 및 개선을 위한 개인정보 수집에 대하여 거부할 수 있습니다. 다만 제3조 제1항 필수 항목은 학부모서비스 이용에 필요한 최소한의 정보로 이에 대한 수집 거부 시 회원가입이 제한됩니다." left="52" top="sta01_01_01_00_00_00_00_00:20" height="195" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <ImageViewer id="img00_00_00_00" taborder="25" text="제4조 개인정보의 제3자 제공" left="10" top="sta01_00_01_00_00_01_00:40" height="115" cssclass="font26B_icon" initvalueid="ivTitleAccessibilityOn" image="url('imagerc::policy_M/Ico03S_M.png')" imagealign="left middle" right="17"/>
              <Static id="sta01_02_00_00_01_01" taborder="26" text="① " left="17" top="img00_00_00_00:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta01_02_00_00_01_01_00" taborder="27" text="학부모서비스는 원칙적으로 정보주체의 개인정보를 이용하기 위한 목적으로 명시한 범위 내에서 처리하며, 다음의 경우를 제외하고는 정보주체의 사전 동의 없이는 제3자에게 제공하지 않습니다." left="52" top="img00_00_00_00:15" height="156" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_01_01_01" taborder="28" text="1." left="46" top="sta01_02_00_00_01_01_00:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" width="20"/>
              <Static id="sta01_00_00_01_01" taborder="29" text="정보 주체로부터 별도의 동의를 받는 경우" left="70" top="sta01_02_00_00_01_01_00:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_01_01_01_00" taborder="30" text="2." left="46" top="sta01_00_00_01_01:10" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" width="20"/>
              <Static id="sta01_00_00_01_01_01" taborder="31" text="법률에 특별한 규정이 있는 경우" left="70" top="sta01_00_00_01_01:10" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_00_00_01_01_01_00" taborder="60" text="정보 주체 또는 법정대리인이 의사표시를 할 수 없는 상태에 있거나 주소불명 등으로 사전 동의를 받을 수 없는 경우로서 명백히 정보주체 또는 제3자의 급박한 생명, 신체, 재산의 이익을 위하여 필요하다고 인정되는 경우" left="70" top="sta01_00_00_01_01_01:10" height="195" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_00_00_01_01_01_00_00" taborder="62" text="통계작성 및 학술연구 등의 목적을 위하여 필요한 경우로서 특정 개인을 알아볼 수 없는 형태로 개인정보를 제공하는 경우" left="70" top="sta01_00_00_01_01_01_00:10" height="117" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_00_00_01_01_01_00_00_00" taborder="63" text="개인정보를 목적 외의 용도로 이용하거나 이를 제3자에게 제공하지 않으면 다른 법률에서 정하는 소관 업무를 수행할 수 없는 경우로서 보호위원회의 심의·의결을 거친 경우" left="70" top="sta01_00_00_01_01_01_00_00:10" height="156" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_00_00_01_01_01_00_00_00_00" taborder="66" text="조약, 그 밖의 국제협정의 이행을 위하여 외국정보 또는 국제기구에 제공하기 위하여 필요한 경우" left="70" top="sta01_00_00_01_01_01_00_00_00:10" height="78" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_00_00_01_01_01_00_00_00_00_00" taborder="68" text="범죄의 수사와 공소의 제기 및 유지를 위하여 필요한 경우" left="70" top="sta01_00_00_01_01_01_00_00_00_00:10" height="78" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_00_00_01_01_01_00_00_00_00_00_00" taborder="70" text="법원의 재판업무 수행을 위하여 필요한 경우" left="70" top="sta01_00_00_01_01_01_00_00_00_00_00:10" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_00_00_01_01_01_00_00_00_00_00_00_00" taborder="72" text="형 및 감호, 보호처분의 집행을 위하여 필요한 경우" left="70" top="sta01_00_00_01_01_01_00_00_00_00_00_00:10" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <ImageViewer id="img00_00_00_00_00" taborder="32" text="제5조 개인정보의 위탁" left="10" top="sta01_00_00_01_01_01_00_00_00_00_00_00_00:40" width="556" height="115" cssclass="font26B_icon" initvalueid="ivTitleAccessibilityOn" image="url('imagerc::policy_M/Ico04S_M.png')" imagealign="left middle"/>
              <Static id="sta01_02_00_00_01_01_01_01" taborder="33" text="① " left="17" top="img00_00_00_00_00:20" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01" taborder="34" text="학부모서비스는 원활한 개인정보 업무처리를 위하여 다음과 같이 개인정보 처리업무를 위탁하고 있습니다." left="52" top="img00_00_00_00_00:20" height="117" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_00_00_01" taborder="39" text="1. 위탁받는 자: 쌍용정보통신㈜, 에스지에이㈜, ㈜타임소프트&#13;&#10;2. 위탁하는 업무의 내용: 나이스플러스 서비스, 유아나이스 구축 및 운영 지원&#13;&#10;3. 위탁기간: 위탁계약 종료시까지" left="40" top="sta01_02_00_00_01_01_00_00_01:10" height="195" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" usedecorate="false" right="17"/>
              <Static id="sta01_02_00_00_01_01_01_01_00" taborder="35" text="② " left="17" top="sta01_02_00_00_01_01_00_00_01_00_00_01:20" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="두 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_00" taborder="36" text="학부모서비스는 위탁체결 시 「개인정보 보호법」 제26조에 따라 위탁업무 수행 목적 외 개인정보의 처리 금지, 안전성 확보 조치, 재위탁 제한, 수탁자에 대한 관리·감독, 손해배상 등 책임에 관한 사항 등을 문서에 명시하고 있습니다." left="52" top="sta01_02_00_00_01_01_00_00_01_00_00_01:20" height="195" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_01_01_00_00" taborder="37" text="③ " left="17" top="sta01_02_00_00_01_01_00_00_01_00:20" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="세 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_00_00" taborder="38" text="위탁업무의 내용이나 수탁자가 변경되면 지체없이 본 개인정보처리방침을 통하여 공개하도록 하겠습니다." left="52" top="sta01_02_00_00_01_01_00_00_01_00:20" height="117" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <ImageViewer id="img00_00_00_00_00_00" taborder="40" text="제6조 개인정보의 파기" left="10" top="sta01_02_00_00_01_01_00_00_01_00_00:40" height="115" cssclass="font26B_icon" initvalueid="ivTitleAccessibilityOn" image="url('imagerc::policy_M/Ico05S_M.png')" imagealign="left middle" right="17"/>
              <Static id="sta01_02_00_00_01_01_01_01_01" taborder="41" text="① " left="17" top="img00_00_00_00_00_00:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01" taborder="42" text="나이스 온라인 교직원 채용은 개인정보 보유기간의 경과, 처리목적 달성 등 개인정보가 불필요하게 되었을 때에는 지체없이 해당 개인정보를 파기합니다." left="52" top="img00_00_00_00_00_00:15" height="117" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_01_01_01_00" taborder="43" text="② " left="17" top="sta01_02_00_00_01_01_00_00_01_01:20" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="두 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00" taborder="44" text="정보주체로부터 동의받은 개인정보 보유기간이 경과하거나 처리목적이 달성되었음에도 불구하고 다른 법령에 따라 개인정보를 계속 보존하여야 하는 경우에는, 해당 개인정보를 별도의 데이터베이스(DB)로 옮기거나 보관장소를 달리하여 보존합니다." left="52" top="sta01_02_00_00_01_01_00_00_01_01:20" height="195" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01" taborder="45" text="1. 법령 근거 : 「공공기록물 관리에 관한 법률」제21조제1항" left="46" top="sta01_02_00_00_01_01_00_00_01_01_00:5" height="78" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_00" taborder="46" text="2. 보존하는 개인정보 항목: 홈페이지를 통해 제공하는 모든 서비스 사용에 필요한 사용자 정보" left="46" top="sta01_02_00_00_01_01_00_00_01_01_00_01:5" height="78" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_01_01_01_00_00" taborder="47" text="③ " left="17" top="sta01_02_00_00_01_01_00_00_01_01_00_01_00:20" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="세 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_00" taborder="48" text="나이스 온라인 교직원 채용은 개인정보 보유기간의 경과, 처리목적 달성 등 개인정보가 불필요하게 되었을 때에는 지체없이 해당 개인정보를 파기합니다." left="55" top="sta01_02_00_00_01_01_00_00_01_01_00_01_00:20" height="117" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_01" taborder="49" text="1. 파기 절차" left="46" top="sta01_02_00_00_01_01_00_00_01_01_00_00:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00" taborder="50" text="나이스 온라인 교직원 채용은 파기 사유가 발생한 개인정보를 선정하고, 나이스 온라인 교직원 채용의 개인정보 보호책임자의 승인을 받아 파기합니다." left="59" top="sta01_02_00_00_01_01_00_00_01_01_00_01_01:4" height="156" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_00_00" taborder="51" text="2. 파기 방법" left="46" top="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_00" taborder="52" text="나이스 온라인 교직원 채용은 전자적 파일 형태로 기록·저장된 개인정보는 기록을 재생할 수 없도록 파기하며, 종이 문서에 기록·저장된 개인정보는 분쇄기로 분쇄하거나 소각하여 파기합니다." left="59" top="sta01_02_00_00_01_01_00_00_01_01_00_01_00_00:4" height="156" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <ImageViewer id="img00_00_00_00_00_00_00" taborder="53" text="제7조 정보주체와 법정대리인의 권리·의무 및 행사 방법" left="10" top="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_00:40" height="115" cssclass="font26B_icon" initvalueid="ivTitleAccessibilityOn" image="url('imagerc::policy_M/Ico04S_M.png')" imagealign="left middle" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_02" taborder="74" text="정보주체는 학부모서비스에 대해 언제든지 개인정보 열람·정정·삭제·처리 정지 요구 등의 권리를 행사할 수 있습니다." left="52" top="img00_00_00_00_00_00_00:15" height="117" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_02_00" taborder="75" text="※ 만 14세 미만 아동에 관한 개인정보의 열람 등 요구는 법정대리인이 직접 해야 하며, 만 14세 이상의 미성년자인 정보주체는 정보주체의 개인정보에 관하여 미성년자 본인이 권리를 행사하거나 법정대리인을 통하여 권리를 행사할 수도 있습니다." left="52" top="sta01_02_00_00_01_01_00_00_01_01_02:5" height="195" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_02_00_00" taborder="81" text="권리 행사는 학부모서비스에 대해 「개인정보 보호법」 시행령 제41조 제1항에 따라 ”개인정보 처리 방법에 관한 고시(제2020-7호)“ 별지8호 서식을 서면, 전자우편, 모사전송(FAX) 등을 통하여 하실 수 있으며. 학부모서비스는 이에 대해 지체 없이 조치하겠습니다. " left="52" top="sta01_02_00_00_01_01_00_00_01_01_02_00:20" height="234" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_02_00_00_00" taborder="82" text="권리 행사는 정보주체의 법정대리인이나 위임을 받은 자 등 대리인을 통하여 하실 수 있습니다. 이 경우 ”개인정보 처리 방법에 관한 고시(제2020-7호)“ 별지 제11호 서식에 따른 위임장을 제출하셔야 합니다." left="52" top="sta01_02_00_00_01_01_00_00_01_01_02_00_00:20" height="156" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_02_00_00_00_00" taborder="83" text="개인정보 열람 및 처리정지 요구는 「개인정보 보호법」 제35조 제4항, 제37조 제2항에 의하여 정보주체의 권리가 제한될 수 있습니다." left="52" top="sta01_02_00_00_01_01_00_00_01_01_02_00_00_00:20" height="117" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_02_00_00_00_00_00" taborder="84" text="개인정보의 정정 및 삭제 요구는 다른 법령에서 그 개인정보가 수집 대상으로 명시되어 있는 경우에는 그 삭제를 요구할 수 없습니다." left="52" top="sta01_02_00_00_01_01_00_00_01_01_02_00_00_00_00:20" height="117" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_02_00_00_00_00_00_00" taborder="85" text="학부모서비스는 정보주체 권리에 따른 열람·정정·삭제·처리정지 요구 등 요구를 한 자가 본인이거나 정당한 대리인인지를 확인합니다." left="52" top="sta01_02_00_00_01_01_00_00_01_01_02_00_00_00_00_00:20" height="117" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <ImageViewer id="img00_00_00_00_00_00_00_00" taborder="54" text="제8조 개인정보의 안전성 확보조치" left="30" top="btnButton150000:40" height="115" cssclass="font26B_icon" initvalueid="ivTitleAccessibilityOn" image="url('imagerc::policy_M/Ico09S_M.png')" imagealign="left middle" right="17"/>
              <Static id="sta01_02_00_00_01_01_01_01_01_02" taborder="55" text="① " left="17" top="img00_00_00_00_00_00_00_00:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01" taborder="56" text="학부모서비스는 개인정보의 안전성 확보를 위해 다음과 같은 조치를 취하고 있습니다." left="52" top="img00_00_00_00_00_00_00_00:15" height="78" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" width="513"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_00_00" taborder="57" text="1. " left="46" top="sta01_02_00_00_01_01_00_00_01_01_01:10" height="78" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" width="20"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_00_01" taborder="58" text="관리적 조치: 내부관리계획 수립·시행, 정기적 직원 교육" left="71" top="sta01_02_00_00_01_01_00_00_01_01_01:10" height="78" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_00_00_00" taborder="59" text="2. " left="46" top="sta01_02_00_00_01_01_00_00_01_01_01_00_01:10" height="78" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" width="20"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_00_01_00" taborder="60" text="기술적 조치: 개인정보처리시스템 등의 접근 권한 관리, 접근통제시스템 설치, 고유식별정보 등의 암호화, 보안프로그램 설치" left="71" top="sta01_02_00_00_01_01_00_00_01_01_01_00_01:10" height="117" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_00_00_00_00" taborder="61" text="3. " left="46" top="sta01_02_00_00_01_01_00_00_01_01_01_00_01_00:10" height="78" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" width="20"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_00_01_00_01" taborder="62" text="물리적 조치: 전산실, 자료보관실 등의 접근통제" left="71" top="sta01_02_00_00_01_01_00_00_01_01_01_00_01_00:10" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <ImageViewer id="img00_00_00_00_00_00_00_00_00" taborder="63" text="제9조 개인정보를 자동으로 수집하는 장치의 설치·운영 및 그 거부에 관한 사항" left="10" top="sta01_02_00_00_01_01_00_00_01_01_01_00_01_00_01:40" height="115" cssclass="font26B_icon" initvalueid="ivTitleAccessibilityOn" image="url('imagerc::policy_M/Ico08S_M.png')" imagealign="left middle" right="17"/>
              <Static id="sta01_02_00_00_01_01_01_01_01_02_01" taborder="64" text="① " left="17" top="img00_00_00_00_00_00_00_00_00:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01" taborder="65" text="학부모서비스는 정보주체의 이용정보를 저장하고 수시로 불러오는 `쿠키(cookie)`를 사용하지 않습니다." left="52" top="img00_00_00_00_00_00_00_00_00:15" height="117" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <ImageViewer id="img00_00_00_00_00_00_00_00_00_00" taborder="66" text="제10조 가명정보의 처리" left="10" top="sta01_02_00_00_01_01_00_00_01_01_01_01:40" height="115" cssclass="font26B_icon" initvalueid="ivTitleAccessibilityOn" image="url('imagerc::policy_M/Ico09S_M.png')" imagealign="left middle" right="17"/>
              <Static id="sta01_02_00_00_01_01_01_01_01_02_01_00" taborder="67" text="① " left="17" top="img00_00_00_00_00_00_00_00_00_00:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_01" taborder="68" text="학부모서비스는 개인정보를 가명 처리하는 경우, 본 개인정보처리방침을 통하여 아래와 같은 가명 정보 처리에 관한 사항을 안내드리겠습니다. " left="52" top="img00_00_00_00_00_00_00_00_00_00:15" height="117" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_00_01" taborder="69" text="1." left="46" top="sta01_02_00_00_01_01_00_00_01_01_01_01_01:10" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" width="20"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_00_01_01" taborder="121" text="가명 정보의 처리 목적" left="71" top="sta01_02_00_00_01_01_00_00_01_01_01_01_01:10" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_00_01_01_00" taborder="122" text="가명 정보의 처리 및 보유 기간" left="71" top="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_00_01_01:10" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_00_01_01_00_00" taborder="123" text="가명 정보의 제3자 제공에 관한 사항" left="71" top="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_00_01_01_00:10" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_00_01_01_00_00_00" taborder="124" text="가명 정보 처리의 위탁에 관한 사항" left="71" top="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_00_01_01_00_00:10" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
