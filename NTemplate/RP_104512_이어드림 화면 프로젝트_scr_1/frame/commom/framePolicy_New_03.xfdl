              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_00_01_01_00_00_00_00_00" taborder="126" text="법 제28조의4(가명 정보에 대한 안정 조치 의무 등)에 따른 가명 정보의 안전성 확보 조치에 관한 사항" left="71" top="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_00_01_01_00_00_00_00:10" height="78" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <ImageViewer id="img00_00_00_00_00_00_00_00_00_00_00" taborder="70" text="제11조 개인정보 보호책임자" left="10" top="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_00_01_01_00_00_00_00_00:40" height="115" cssclass="font26B_icon" initvalueid="ivTitleAccessibilityOn" image="url('imagerc::policy_M/Ico10S_M.png')" imagealign="left middle" right="17"/>
              <Static id="sta01_02_00_00_01_01_01_01_01_02_01_00_01" taborder="71" text="① " left="17" top="img00_00_00_00_00_00_00_00_00_00_00:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01" taborder="72" text="학부모서비스는 개인정보 처리에 관한 업무를 총괄해서 책임지고, 개인정보 처리와 관련한 정보주체의 불만처리 및 피해구제 등을 위하여 아래와 같이 개인정보 보호책임자를 지정하고 있습니다. " left="52" top="img00_00_00_00_00_00_00_00_00_00_00:15" height="156" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_00" taborder="73" text="1. 교육부" left="35" top="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01:10" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" usedecorate="false" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_00_00" taborder="127" text="- 개인정보 책임자: 디지털교육기확관&#13;&#10;- 개인정보 담당자: 디지털인프라담당관 나이스담당자" left="50" top="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_00:5" height="117" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" usedecorate="false" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_00_01" taborder="128" text="2. 한국교육학술정보원" left="35" top="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_00_00:10" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" usedecorate="false" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_00_00_00" taborder="129" text="- 개인정보 보호책임자: 정보보호본부 김태우본부장&#13;&#10;                                      (053-714-0299)&#13;&#10;- 개인정보 보호담당자: 개인정보보호부 이상엽연구원&#13;&#10;                                      (053-714-439)&#13;&#10;- 학부모서비스 책임자: 교육행정본부 김은재본부장&#13;&#10;                                      (053-714-248)&#13;&#10;- 학부모서비스 담당자: 4세대나이스부 박유나연구원&#13;&#10;                                      (044-410-1235)" left="40" top="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_00_01:5" height="312" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" usedecorate="false" right="10"/>
              <Static id="sta01_02_00_00_01_01_01_01_01_02_01_00_01_00" taborder="74" text="②" left="17" top="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_00_00_00:20" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="두 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_01" taborder="75" text="정보주체는 학부모서비스의 서비스를 이용하시면서 발생한 모든 개인정보 보호 관련 문의, 불만 처리, 피해구제 등에 관한 사항을 개인정보 보호책임자 및 담당부서로 문의할 수 있습니다. 학부모서비스는 정보 주체의 문의에 대해 지체 없이 답변 및 처리해드릴 것입니다." left="52" top="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_00_00_00:20" height="234" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <ImageViewer id="img00_00_00_00_00_00_00_00_00_00_00_00" taborder="76" text="제12조 개인정보 열람 청구를 접수·처리하는 부서" left="10" top="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_01:40" height="115" cssclass="font26B_icon" initvalueid="ivTitleAccessibilityOn" image="url('imagerc::policy_M/Ico11S_M.png')" imagealign="left middle" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_02" taborder="131" text="정보주체는 「개인정보 보호법」 제35조에 따른 개인정보의 열람 청구을 아래의 부서에 할 수 있습니다. 학부모서비스는 정보주체의 개인정보 열람 청구가 신속하게 처리되도록 노력하겠습니다." left="52" top="img00_00_00_00_00_00_00_00_00_00_00_00:15" height="156" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_00_02" taborder="132" text="1. 개인정보 열람 청구에 대한 접수·처리 담당" left="46" top="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_02:10" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" usedecorate="false" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_00_00_00_00" taborder="133" text="- 소속: 한국교육학술정보원 교육행정본부 4세대나이스부&#13;&#10;- 담당자: 박유나연구원&#13;&#10;- 전자우편: &lt;l v='mailto:think1111@keris.or.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;think1111@keris.or.kr&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;&#13;&#10;- 연락처: 044-410-1235" left="56" top="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_00_02:0" height="195" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" usedecorate="true" right="17"/>
              <ImageViewer id="img00_00_00_00_00_00_00_00_00_00_00_00_00" taborder="77" text="제13조 추가적인 이용·제공 판단기준" left="10" top="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_00_00_00_00:40" height="115" cssclass="font26B_icon" initvalueid="ivTitleAccessibilityOn" image="url('imagerc::policy_M/Ico13S_M.png')" imagealign="left middle" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_02_00" taborder="135" text="학부모서비스는 「개인정보 보호법」 제15조 제3항 및 제17조 제4항에 따라 「개인정보 보호법 시행령」 제14조의2에 따른 사항을 고려하여 정보 주체의 동의 없이 개인정보를 추가적으로 이용·제공할 수 있습니다. " left="52" top="img00_00_00_00_00_00_00_00_00_00_00_00_00:15" height="195" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_02_00_00" taborder="136" text="이에 따라 학부모서비스가 정보주체의 동의 없이 추가적인 이용·제공을 하기 위해서는 다음과 같은 사항을 고려하였습니다." left="52" top="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_02_00:5" height="117" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_02_00_00_01" taborder="138" text="개인정보를 추가적으로 이용·제공하려는 목적이 당초 수집 목적과 관련성이 있는지 여부" left="80" top="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_02_00_00:10" height="78" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_02_00_00_01_00" taborder="140" text="개인정보를 수집한 정황 또는 처리 관행에 비추어 볼 때 추가적인 이용·제공에 대한 예측 가능성이 있는지 여부" left="80" top="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_02_00_00_01:10" height="117" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_02_00_00_01_00_00" taborder="142" text="개인정보의 추가적인 이용·제공이 정보주체의 이익을 부당하게 침해하는지 여부" left="80" top="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_02_00_00_01_00:10" height="78" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_02_00_00_01_00_00_00" taborder="144" text="가명 처리 또는 암호화 등 안전성 확보에 필요한 조치를 하였는지 여부" left="80" top="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_02_00_00_01_00_00:10" height="78" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" fittocontents="height" right="17"/>
              <ImageViewer id="img00_00_00_00_00_00_00_00_00_00_00_00_01" taborder="78" text="제14조 권익침해 구제방법" left="10" top="sta01_02_00_00_01_01_00_00_01_01_01_01_01_01_02_00_00_01_00_00_00:40" height="115" cssclass="font26B_icon" initvalueid="ivTitleAccessibilityOn" image="url('imagerc::policy_M/Ico12S_M.png')" imagealign="left middle" right="17"/>
              <Static id="sta01_02_00_00_01_01_01_01_01_02_01_00_01_01" taborder="79" text="① " left="17" top="img00_00_00_00_00_00_00_00_00_00_00_00_01:15" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00" taborder="80" text="정보주체는 개인정보침해로 인한 구제를 받기 위하여 개인정보분쟁조정위원회, 한국인터넷진흥원 개인정보침해신고센터 등에 분쟁 해결이나 상담 등을 신청할 수 있습니다. 이 밖에 기타 개인정보침해의 신고, 상담에 대하여는 아래의 기관에 문의하시기 바랍니다." top="img00_00_00_00_00_00_00_00_00_00_00_00_01:15" height="234" cssclass="font26R_M" initvalueid="ivStcAccessibilityOn" left="52" fittocontents="height" letterSpacing="-1px" right="17"/>
              <Static id="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_01" taborder="145" text="※ 아래의 기관은 ‘한국교육학술정보원’과는 별개의 기관으로서, ‘한국교육학술정보원’의 자체적인 개인정보 불만 처리, 피해구제 결과에 만족하지 못하시거나 보다 자세한 도움이 필요하시면 문의하여주시기 바랍니다. " top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00:5" height="195" cssclass="font26R_M" initvalueid="ivStcAccessibilityOn" left="52" fittocontents="height" letterSpacing="-1px" right="17"/>
              <Static id="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_01_00" taborder="146" text="1. 개인정보분쟁조정위원회: (국번없이) 1833-6972(&lt;l v='http://www.kopico.go.kr'&gt;&lt;fc v='#2b72de'&gt;www.kopico.go.kr&lt;/fc&gt;&lt;/l&gt;)" top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_01:10" height="74" cssclass="font26R_M" initvalueid="ivStcAccessibilityOn" left="52" fittocontents="height" letterSpacing="-1px" usedecorate="true" right="17"/>
              <Static id="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_01_00_00" taborder="147" text="2. 개인정보침해신고센터: (국번없이) 118(&lt;l v='http://privacy.kisa.or.kr'&gt;&lt;fc v='#2b72de'&gt;privacy.kisa.or.kr&lt;/fc&gt;&lt;/l&gt;)" top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_01_00:10" height="74" cssclass="font26R_M" initvalueid="ivStcAccessibilityOn" left="52" fittocontents="height" letterSpacing="-1px" usedecorate="true" right="17"/>
              <Static id="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_01_00_00_00" taborder="148" text="3. 대검찰청: (국번없이) 1301(&lt;l v='http://www.spo.go.kr'&gt;&lt;fc v='#2b72de'&gt;www.spo.go.kr&lt;/fc&gt;&lt;/l&gt;)" top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_01_00_00:10" height="37" cssclass="font26R_M" initvalueid="ivStcAccessibilityOn" left="52" fittocontents="height" letterSpacing="-1px" usedecorate="true" right="17"/>
              <Static id="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_01_00_00_00_00" taborder="149" text="4. 경찰청: (국번없이) 182(&lt;l v='http://ecrm.police.go.kr'&gt;&lt;fc v='#2b72de'&gt;ecrm.police.go.kr&lt;/fc&gt;&lt;/l&gt;)" top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_01_00_00_00:10" height="37" cssclass="font26R_M" initvalueid="ivStcAccessibilityOn" left="52" fittocontents="height" letterSpacing="-1px" usedecorate="true" right="17"/>
              <Static id="sta01_02_00_00_01_01_01_01_01_02_01_00_01_01_00" taborder="81" text="② " left="17" top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_01_00_00_00_00:20" height="39" initvalueid="ivStcAccessibilityOn" cssclass="font26R_M" width="30" fittocontents="height" accessibilitylabel="두 번째"/>
              <Static id="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_00" taborder="82" text="학부모서비스는 정보주체의 개인정보자기결정권을 보장하고, 개인정보침해로 인한 상담 및 피해 구제를 위해 노력하고 있으며, 신고나 상담이 필요한 경우 아래의 담당부서로 연락해 주시기 바랍니다." top="sta00_02_01_00_01_00_00_01_00_00_01_00_00_00_00_00_00_00_01_00_00_00_00:20" height="156" cssclass="font26R_M" initvalueid="ivStcAccessibilityOn" left="52" fittocontents="height" letterSpacing="-1px" right="17"/>
