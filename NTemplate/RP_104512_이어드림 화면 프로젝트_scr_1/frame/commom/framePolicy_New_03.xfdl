    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    샘플
*  @FileName 	framePolicy_New_03.xfdl
*  @Creator 	정인혁
*  @CreateDate 	2023.5.31
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2023.5.31     	정인혁 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 this.framePolicy_New_03_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitForm(this);
	
	// 화면을 맨 위로 이동
	this.getOwnerFrame().form.divAll.form.scrollTo(0,0);
};

this.framePolicy_New_03_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.resetScroll();
	
	var plusHeight = 0;
	
	if(this.smfIsMobile())
	{
		plusHeight = 140;
	}
	else
	{
		plusHeight = 30;
	}

	//this.staDetail.setOffsetHeight((parseInt(this.sta00_03_00_00_1_01_00_00_00_01_00_00_00_00_00_00_00.getOffsetBottom(),10) + plusHeight) - (this.divTop.getOffsetBottom()+40)  );
	
	this.smfResetScroll(this.div00.form);
	this.smfResetScroll(this.div01.form);	
	//this.smfResetScroll(this);	
	//this.smfResetScroll(this.parent);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
	
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnMovePosition = function(objComp)
{
	var nTop = objComp.getOffsetTop() + this.parent.getOffsetTop() + 130;
	this.parent.parent.parent.parent.scrollTo(0, nTop);	
}
//컨텐츠 리사이징
this.fnSetResize = function(){
	this.divTop.form.resetScroll();
	this.divTop.setOffsetHeight(parseInt(this.divTop.form.sta02_00.getOffsetBottom(),10)+40);
	this.smfResetScroll(this.div00.form);
	this.smfResetScroll(this.div01.form);
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 

this.Button_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnMovePosition(this[obj.moveComp]);
};

this.div01_cboBeforePrivetePolicy_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	var sUrl = obj.value;
	trace("URL : " + sUrl);
	
	if(!this.smfIsNull(sUrl))
	{
		var sBaseUrl= window.location.protocol + "//" + window.location.host;
		trace("sBaseUrl : " + sBaseUrl);
	
		system.execBrowser(sBaseUrl + sUrl);
	}
};
]]></Script>
  </Form>
</FDL>
