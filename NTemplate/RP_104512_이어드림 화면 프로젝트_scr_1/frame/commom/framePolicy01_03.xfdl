              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_02_00_00_01_00" taborder="133" text="▶ " left="68" top="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_00_01_00:4" height="21" initvalueid="ivStcAccessibilityOff" cssclass="sta_WF_Txt16L" fittocontents="height" width="20"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_00_00_01_00" taborder="134" text="개인정보 열람청구 접수·처리 부서&#13;&#10;성명: 진경희&#13;&#10;소속: 정보보호팀&#13;&#10;연락처: 044-203-6514, heeyajin@korea.kr, 044-203-6185" left="91" top="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_00_01_00:4" height="84" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
