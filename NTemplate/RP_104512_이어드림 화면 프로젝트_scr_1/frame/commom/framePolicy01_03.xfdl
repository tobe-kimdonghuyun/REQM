                            <Cell row="6" col="3" wordWrap="char" autosizerow="limitmin" textAlign="center" text="해당 기관의 지침에 따름" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd"/>
                            <Cell row="7" wordWrap="char" autosizerow="limitmin" textAlign="center" text="보건복지부"/>
