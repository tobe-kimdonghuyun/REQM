              <Static id="sta01_02_00_00_01_01_01_01_01_02_01_00" taborder="127" text="① " left="30" top="img00_00_00_00_00_00_00_00_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_01" taborder="128" text="정보주체는 「개인정보 보호법」제35조에 따른 개인정보의 열람 청구를 아래의 부서에서 할 수 있습니다. 나이스 온라인 교직원 채용은 정보주체의 개인정보 열람청구가 신속하게 처리되도록 노력하겠습니다." left="55" top="img00_00_00_00_00_00_00_00_00_00:15" height="42" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
