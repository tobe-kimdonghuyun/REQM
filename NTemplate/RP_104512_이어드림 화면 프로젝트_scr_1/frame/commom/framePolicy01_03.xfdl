<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmTemp01" width="1200" height="9300" onload="frmTemp01_onload" titletext="개인정보처리방침(23.05.16)">
    <Layouts>
      <Layout height="9300" width="1200" screenid="ScreenDeskTop">
        <Div id="div00" taborder="0" left="0" top="0" height="1842" cssclass="div_WF_KinderBox" initvalueid="ivDivAccessibilityOff" width="1200">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" text="나이스 온라인 교직원 채용은 교육부 및 17개 시·도 교육청(소속 지원청, 학교 포함)으로부터 시스템 개발 및 운영·유지관리 업무를 위탁받은 수탁사인 한국교육학술정보원(이하 KERIS)는 개인정보 보호법 제30조(개인정보처리방침의 수립 및 공개)에 따라 정보주체의 개인정보를 보호하고 이와 관련한 고충을 신속하고 원활하게 처리할 수 있도록 하기 위하여 다음과 같이 개인정보처리방침을 수립·공개합니다." left="30" top="30" width="1140" height="65" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L"/>
              <Static id="sta00_00" taborder="1" text="주요 개인정보 처리 표시(라벨링)" left="30" top="sta00:63" height="24" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16B" right="860"/>
              <Button id="btn00" taborder="2" text="제1조&#13;&#10;처리목적" left="30" top="sta00_00:17" width="11.67%" height="140" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextB" icon="url('theme://images/PolicyV2_link01B.png')"/>
              <Button id="btn00_00" taborder="3" text="제2조&#13;&#10;보유 기간" left="btn00:20" top="sta00_00:17" width="11.67%" height="140" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextB" icon="url('theme://images/PolicyV2_link02B.png')"/>
              <Button id="btn00_00_00" taborder="4" text="제3조&#13;&#10;제3자 제공" left="btn00_00:20" top="sta00_00:17" width="11.67%" height="140" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextB" icon="url('theme://images/PolicyV2_link04B.png')"/>
              <Button id="btn00_00_01" taborder="5" text="제4조&#13;&#10;처리위탁" left="btn00_00_00:20" top="sta00_00:17" width="11.67%" height="140" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextB" icon="url('theme://images/PolicyV2_link05B.png')"/>
              <Button id="btn00_00_02" taborder="6" text="제5조&#13;&#10;정보주체의 권리의무" left="btn00_00_01:20" top="sta00_00:17" width="11.67%" height="140" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextB" icon="url('theme://images/PolicyV2_link06B.png')"/>
              <Button id="btn00_00_03" taborder="7" text="제6조&#13;&#10;파기" left="btn00_00_02:20" top="sta00_00:17" width="11.67%" height="140" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextB" icon="url('theme://images/PolicyV2_link09B.png')"/>
              <Button id="btn00_00_04" taborder="8" text="제7조&#13;&#10;안전성확보조치" top="sta00_00:17" height="140" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextB" icon="url('theme://images/PolicyV2_link10B.png')" left="btn00_00_03:20" right="69"/>
              <Button id="btn00_01" taborder="9" text="제8조&#13;&#10;자동화 수집" left="30" top="btn00:20" width="11.67%" height="140" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextB" icon="url('theme://images/PolicyV2_link08B.png')"/>
              <Button id="btn00_00_05" taborder="10" text="제9조&#13;&#10;개인정보보호책임자" left="btn00_01:20" top="btn00_00:20" width="11.67%" height="140" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextB" icon="url('theme://images/PolicyV2_link11B.png')"/>
              <Button id="btn00_00_00_00" taborder="11" text="제10조&#13;&#10;열람청구" left="btn00_00_05:20" top="btn00_00_00:20" width="11.67%" height="140" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextB" icon="url('theme://images/PolicyV2_link12B.png')"/>
              <Button id="btn00_00_01_00" taborder="12" text="제11조&#13;&#10;권익침해 구제" left="btn00_00_00_00:20" top="btn00_00_01:20" width="11.67%" height="140" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextB" icon="url('theme://images/PolicyV2_link13B.png')" letterSpacing="-1px"/>
              <Button id="btn00_00_02_00" taborder="13" text="제12조&#13;&#10;가명정보 처리" left="btn00_00_01_00:20" top="btn00_00_02:20" width="11.67%" height="140" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextB" icon="url('theme://images/PolicyV2_link16B.png')"/>
              <Button id="btn00_00_03_00" taborder="14" text="제13조&#13;&#10;추가적 이용" left="btn00_00_02_00:20" top="btn00_00_03:20" width="11.67%" height="140" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextB" icon="url('theme://images/PolicyV2_link14B.png')"/>
              <Button id="btn00_00_03_00_00" taborder="15" text="제14조&#13;&#10;처리방침 변경" left="btn00_00_03_00:20" top="btn00_00_04:20" height="140" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextB" icon="url('theme://images/PolicyV2_link15B.png')" right="69"/>
              <Static id="sta00_01" taborder="16" text="위 표의 이미지를 클릭하면 해당 개인정보 처리방침으로 이동합니다." left="30" top="btn00_00_00_00:42" width="847" height="24" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L"/>
              <Static id="sta00_00_00" taborder="17" text="&lt;목차&gt;" left="30" top="sta00_01:50" width="640" height="24" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16B"/>
              <Button id="btn00_01_00" taborder="18" text="제1조 개인정보의 처리목적" left="25" top="sta00_00_00:16" width="530" height="70" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextS" icon="url('theme://images/PolicyV2_link01S.png')"/>
              <Button id="btn00_01_00_00" taborder="19" text="제2조 개인정보의 처리 및 보유기간" left="25" top="btn00_01_00:9" width="530" height="70" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextS" icon="url('theme://images/PolicyV2_link02S.png')"/>
              <Button id="btn00_01_00_01" taborder="20" text="제3조 개인정보 제3자 제공" left="25" top="btn00_01_00_00:9" width="530" height="70" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextS" icon="url('theme://images/PolicyV2_link04S.png')"/>
              <Button id="btn00_01_00_02" taborder="21" text="제4조 개인정보처리의 위탁" left="25" top="btn00_01_00_01:9" width="530" height="70" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextS" icon="url('theme://images/PolicyV2_link05S.png')"/>
              <Button id="btn00_01_00_03" taborder="22" text="제5조 정보주체와 법정대리인의 권리·의무 및 행사방법" left="25" top="btn00_01_00_02:9" width="530" height="70" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextS" icon="url('theme://images/PolicyV2_link06S.png')"/>
              <Button id="btn00_01_00_04" taborder="23" text="제6조 개인정보의 파기" left="25" top="btn00_01_00_03:9" width="530" height="70" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextS" icon="url('theme://images/PolicyV2_link09S.png')"/>
              <Button id="btn00_01_00_05" taborder="24" text="제7조 개인정보의 안전성 확보 조치" left="25" top="btn00_01_00_04:9" width="530" height="70" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextS" icon="url('theme://images/PolicyV2_link10S.png')"/>
              <Button id="btn00_01_00_06" taborder="25" text="제8조 개인정보 자동 수집 장치의 설치·운영 및 거부에 관한 사항" left="25" top="btn00_01_00_05:9" width="530" height="70" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextS" icon="url('theme://images/PolicyV2_link08S.png')"/>
              <Button id="btn00_01_00_07" taborder="26" text="제9조 개인정보 보호책임자에 관한 사항" left="25" top="btn00_01_00_06:9" width="530" height="70" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextS" icon="url('theme://images/PolicyV2_link11S.png')"/>
              <Button id="btn00_01_00_08" taborder="27" text="제10조 개인정보 열람청구" left="25" top="btn00_01_00_07:9" width="530" height="70" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextS" icon="url('theme://images/PolicyV2_link12S.png')"/>
              <Button id="btn00_01_00_09" taborder="28" text="제11조 권익침해 구제방법" left="25" top="btn00_01_00_08:9" width="530" height="70" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextS" icon="url('theme://images/PolicyV2_link13S.png')"/>
              <Button id="btn00_01_00_10" taborder="29" text="제12조 가명정보의 처리" left="25" top="btn00_01_00_09:9" width="530" height="70" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextS" icon="url('theme://images/PolicyV2_link16S.png')"/>
              <Button id="btn00_01_00_11" taborder="30" text="제13조 추가적인 이용·제공 판단기준" left="25" top="btn00_01_00_10:9" width="530" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextS" icon="url('theme://images/PolicyV2_link14S.png')" height="70"/>
              <Button id="btn00_01_00_10_00" taborder="31" text="제14조 개인정보 처리방침의 변경" left="25" top="btn00_01_00_11:9" width="530" height="70" initvalueid="ivBtnAccessibilityButton" cssclass="btn_polivy_linkTextS" icon="url('theme://images/PolicyV2_link15S.png')"/>
              <Static id="sta00_01_00" taborder="32" text="목차를 클릭하면 해당 개인정보 처리방침으로 이동합니다." left="30" top="btn00_01_00_10_00:40" width="847" height="24" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L"/>
              <Static id="Static99_00_00_00_00_00_00_02_00_00_00_00_01_01_00_00" taborder="33" left="30" top="1812" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="100"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="div01" taborder="1" left="0" top="div00:35" width="1200" cssclass="div_WF_kinder" initvalueid="ivDivAccessibilityOff" height="7423" text="">
          <Layouts>
            <Layout>
              <ImageViewer id="img00" taborder="0" text="제1조(개인정보의 처리목적)" left="30" top="31" width="341" height="70" cssclass="font16B_icon" initvalueid="ivTitleAccessibilityOn" image="url('theme://images/PolicyV2_link01S.png')" imagealign="left middle"/>
              <Static id="sta01" taborder="1" text="① " left="30" top="img00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta01_00" taborder="2" text="나이스 온라인 교직원 채용은 다음의 목적을 위하여 개인정보를 처리합니다. 처리하고 있는 개인정보는 다음의 목적 이외의 용도로는 이용되지 않으며, 이용 목적이 변경되는 경우에는 「개인정보 보호법」제18조에 따라 별도의 동의를 받는 등 필요한 조치를 이행할 예정입니다." left="55" top="img00:15" height="44" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_01" taborder="3" text="1. 홈페이지 회원 가입 및 관리" left="46" top="sta01_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_00_00" taborder="4" text="회원 가입의사 확인, 회원제 서비스 제공에 따른 본인 식별·인증, 회원자격 유지·관리, 제한적 본인확인제 시행에 따른 본인확인, 서비스 부정이용 방지(가입 및 가입횟수 제한), 만 14세 미만 아동의 개인정보 처리 시 법정대리인의 동의여부 확인, 향후 분쟁조정을 위한 기록보존, 불만처리 등을 위한 원활한 의사소통 경로의 확보, 각종 고지·통지 등을 목적으로 개인정보를 처리합니다." left="59" top="sta01_01:4" height="65" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_01_00" taborder="5" text="2. 홈페이지를 통한 나이스 업무 정보 조회 및 확인" left="46" top="sta01_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_00_00_00" taborder="6" text="나이스 온라인 교직원 채용은 통해 응시자 원서접수, 정보 확인 및 조회의 목적으로 개인정보를 처리합니다. " left="59" top="sta01_01_00:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_01_00_00" taborder="7" text="3. 웹사이트 관리" left="46" top="sta01_00_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_00_00_00_00" taborder="8" text="서비스 이용에 따른 사용자 정보 수집 및 관리, 서비스 부정이용 방지, 각종 고지·통지, 고충처리 목적으로 개인정보를 처리합니다." left="59" top="sta01_01_00_00:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_01_00_00_00" taborder="9" text="4. 민원사무 처리" left="46" top="sta01_00_00_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_00_00_00_00_00" taborder="10" text="민원인의 신원 확인, 민원사항 확인, 사실조사를 위한 연락·통지, 처리결과 통보의 목적으로 개인정보를 처리합니다." left="59" top="sta01_01_00_00_00:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_01_00_00_00_00" taborder="11" text="5. 서비스 개선" left="46" top="sta01_00_00_00_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_00_00_00_00_00_00" taborder="12" text="신규 서비스 개발 및 특화, 개인별 맞춤서비스를 제공하기 위한 자료, 접속 빈도 파악, 회원의 서비스 이용에 대한 통계, 새로운 서비스 및 이벤트 정보 등의 안내를 위해 개인정보를 처리합니다." left="59" top="sta01_01_00_00_00_00:4" height="44" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02" taborder="13" text="② " left="30" top="sta01_00_00_00_00_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="두 번째"/>
              <Static id="sta01_00_01" taborder="14" text="나이스 온라인 교직원 채용이 「개인정보 보호법」제32조에 따라 등록·공개하는 개인정보파일의 처리목적은 아래와 같습니다." left="55" top="sta01_00_00_00_00_00_00:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Div id="div00" taborder="15" left="30" top="sta01_00_01:15" height="333" initvalueid="ivDivAccessibilityOff" right="30">
                <Layouts>
                  <Layout>
                    <Grid id="grd00" taborder="0" left="0" top="0" binddataset="ds00" initvalueid="ivGrdAccessibilityOn" cssclass="grd_policy_detail" right="0" bottom="0" autofittype="col" selecttype="cell" autosizingtype="row" accessibilitylabel="개인정보파일 처리목적">
                      <Formats>
                        <Format id="default">
                          <Columns>
                            <Column size="150"/>
                            <Column size="150"/>
                            <Column size="150"/>
                            <Column size="150"/>
                            <Column size="200"/>
                            <Column size="80"/>
                          </Columns>
                          <Rows>
                            <Row size="60" band="head"/>
                            <Row size="61"/>
                          </Rows>
                          <Band id="head">
                            <Cell text="서비스명" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                            <Cell col="1" text="개인정보&#13;&#10;파일의 명칭" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                            <Cell col="2" text="운영근거" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                            <Cell col="3" text="처리목적" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                            <Cell col="4" text="기록되는 개인정보의 항목" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                            <Cell col="5" text="보유&#13;&#10;기간" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                          </Band>
                          <Band id="body">
                            <Cell text="온라인 교직원 채용" autosizerow="limitmin" wordWrap="char" textAlign="center"/>
                            <Cell col="1" text="원서접수 서비스&#13;&#10;개인정보" autosizerow="limitmin" wordWrap="char" textAlign="center"/>
                            <Cell col="2" text="- 초중등교육법 시행령&#13;&#10;제106조의3" autosizerow="limitmin" wordWrap="char" textAlign="center"/>
                            <Cell col="3" text="-온라인 교직원 채용&#13;&#10;원서접수" autosizerow="limitmin" wordWrap="char" textAlign="center"/>
                            <Cell col="4" text="(필수) 성명, 주민등록번호, 연락처(자택전화번호, 휴대전화번호, 주소, 이메일 주소), 사진 군복무사항, 교육경력사항, 대학학적사항(교원자격증관련, 대학성적 등). 취업지원대상자(보훈번호 포함), 장애정보 등 합격자 선발을 위한 가(산)점 확인 사항, 원서접수 내용 외 응시원서 접수사이트 로그인 시 사용하는 비밀번호, 응시수수료 납부과정에서의 결제 정보" autosizerow="limitmin" wordWrap="char" textAlign="center"/>
                            <Cell col="5" text="5년" autosizerow="limitmin" wordWrap="char" textAlign="center" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd"/>
                          </Band>
                        </Format>
                      </Formats>
                    </Grid>
                  </Layout>
                </Layouts>
              </Div>
              <Static id="sta01_02_00" taborder="16" text="③ " left="30" top="div00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="세 번째"/>
              <Static id="sta01_00_01_00" taborder="17" text="상세한 개인정보파일 등록사항 공개는 행정안전부 개인정보보호 종합지원 포털(www.privacy.go.kr) → 개인서비스 → 개인정보 열람등요구 → 개인정보파일 목록검색 → 기관명에 ‘한국교육학술정보원’ 혹은 해당 시도교육청 입력 후 조회하실 수 있습니다." left="55" top="div00:15" height="44" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <ImageViewer id="img00_00" taborder="18" text="제2조(개인정보 처리 및 보유기간)" left="30" top="sta01_00_01_00:40" width="379" height="70" cssclass="font16B_icon" initvalueid="ivTitleAccessibilityOn" image="url('theme://images/PolicyV2_link02S.png')" imagealign="left middle"/>
              <Static id="sta01_02_00_00" taborder="19" text="① " left="30" top="img00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta01_00_01_00_00" taborder="20" text="나이스 온라인 교직원 채용은 법령에 따른 개인정보 보유·이용기간 또는 정보주체로부터 개인정보를 수집 시에 동의받은 개인정보 보유·이용기간 내에서 개인정보를 처리·보유합니다." left="55" top="img00_00:15" height="44" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_00" taborder="21" text="② " left="30" top="sta01_00_01_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="두 번째"/>
              <Static id="sta01_00_01_00_00_00" taborder="22" text="각각의 개인정보 처리 및 보유기간은 다음과 같습니다.(제1조 3항 참조)" left="55" top="sta01_00_01_00_00:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_01_01" taborder="23" text="1. 홈페이지를 통한 서비스 이용 및 개인정보 보유기간" left="46" top="sta01_00_01_00_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_00_00_01" taborder="24" text="- 제1조(개인정보의 처리목적)5항③에 따름" left="59" top="sta01_01_01:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_01_01_00" taborder="25" text="2. 다만, 다음의 사유에 해당하는 경우에는 해당 사유 종료 시까지" left="46" top="sta01_00_00_01:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_00_00_01_00" taborder="26" text="1) 관계 법령 위반에 따른 수사․조사 등이 진행 중인 경우에는 해당 수사․조사 종료 시까지" left="59" top="sta01_01_01_00:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_00_00_01_00_00" taborder="27" text="2) 홈페이지 이용에 따른 채권․채무관계 잔존 시에는 해당 채권․채무관계 정산 시까지" left="59" top="sta01_00_00_01_00:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <ImageViewer id="img00_00_00" taborder="28" text="제3조(개인정보 제3자 제공)" left="30" top="sta01_00_00_01_00_00:40" width="389" height="70" cssclass="font16B_icon" initvalueid="ivTitleAccessibilityOn" image="url('theme://images/PolicyV2_link04S.png')" imagealign="left middle"/>
              <Static id="sta01_02_00_00_01" taborder="29" text="① " left="30" top="img00_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta01_00_01_00_00_01" taborder="30" text="나이스 온라인 교직원 채용은 정보주체의 개인정보를 제1조(개인정보의 처리 목적)에서 명시한 범위 내에서만 처리하며, 정보주체의 동의, 법률의 특별한 규정 등 「개인정보 보호법」제17조 및 제18조에 해당하는 경우에만 개인정보를 제3자에게 제공합니다." left="55" top="img00_00_00:15" height="44" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_00" taborder="31" text="② " left="30" top="sta01_00_01_00_00_01:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="두 번째"/>
              <Static id="sta01_00_01_00_00_01_00" taborder="32" text="나이스 온라인 교직원 채용은 다음과 같이 개인정보를 제3자에게 제공하고 있습니다. " left="55" top="sta01_00_01_00_00_01:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
