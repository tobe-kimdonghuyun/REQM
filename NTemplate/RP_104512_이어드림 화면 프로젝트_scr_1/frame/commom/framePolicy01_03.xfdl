              <Static id="sta01_02_00_00_01_01" taborder="35" text="① " left="30" top="img00_00_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta01_02_00_00_01_01_00" taborder="36" text="나이스 온라인 교직원 채용은 원활한 개인정보 업무처리를 위하여 다음과 같이 개인정보 처리업무를 위탁하고 있습니다." left="55" top="img00_00_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_01_01_01" taborder="37" text="1. 상담센터 운영" left="46" top="sta01_02_00_00_01_01_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_00_00_01_01" taborder="38" text="- 위탁받는 자(수탁자) :" left="59" top="sta01_01_01_01:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_00_00_01_01_00" taborder="39" text="- 위탁하는 업무의 내용 : 상담센터 운영" left="59" top="sta01_00_00_01_01:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_01_01_01_00" taborder="40" text=" 2. 서비스 운영 및 유지관리" left="46" top="sta01_00_00_01_01_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_00_00_01_01_01" taborder="41" text="- 위탁받는 자(수탁자) : " left="59" top="sta01_01_01_01_00:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_00_00_01_01_00_00" taborder="42" text="- 위탁하는 업무의 내용 : 홈페이지 운영 및 유지관리 " left="59" top="sta01_00_00_01_01_01:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_01_01_01_00_00" taborder="43" text="3. 간편인증 사업자" left="46" top="sta01_00_00_01_01_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_00_00_01_01_01_00" taborder="44" text="- 위탁받는 자(수탁자) : " left="59" top="sta01_01_01_01_00_00:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_00_00_01_01_00_00_00" taborder="45" text="- 위탁하는 업무의 내용 : 홈페이지 로그인 및 사용을 위한 본인인증" left="59" top="sta01_00_00_01_01_01_00:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_01_01_01_00_00_00" taborder="46" text="4. 본인확인기관" left="46" top="sta01_00_00_01_01_00_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_00_00_01_01_01_00_00" taborder="47" text="- 위탁받는 자(수탁자) :" left="59" top="sta01_01_01_01_00_00_00:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_00_00_01_01_00_00_00_00" taborder="48" text="- 위탁하는 업무의 내용 : 홈페이지 로그인 및 사용을 위한 본인인증" left="59" top="sta01_00_00_01_01_01_00_00:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_01_01_01_00_00_00_00" taborder="49" text="5. 모바일신분증 서비스 제공기관" left="46" top="sta01_00_00_01_01_00_00_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_00_00_01_01_01_00_00_00" taborder="50" text="- 위탁받는 자(수탁자) :" left="59" top="sta01_01_01_01_00_00_00_00:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_00_00_01_01_00_00_00_00_00" taborder="51" text="- 위탁하는 업무의 내용 : 홈페이지 로그인 및 사용을 위한 본인인증" left="59" top="sta01_00_00_01_01_01_00_00_00:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_01" taborder="52" text="② " left="30" top="sta01_00_00_01_01_00_00_00_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="두 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00" taborder="53" text="나이스 온라인 교직원 채용은 위탁계약 체결 시 「개인정보 보호법」제26조에 따라 위탁업무 수행목적 외 개인정보 처리금지, 기술적․관리적 보호조치, 재위탁 제한, 수탁자에 대한 관리․감독, 손해배상 등 책임에 관한 사항을 계약서 등 문서에 명시하고, 수탁자가 개인정보를 안전하게 처리하는지를 감독하고 있습니다." left="55" top="sta01_00_00_01_01_00_00_00_00_00:15" height="42" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_01_00" taborder="54" text="③ " left="30" top="sta01_02_00_00_01_01_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="세 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_00" taborder="55" text="위탁업무의 내용이나 수탁자가 변경될 경우에는 지체 없이 본 개인정보 처리방침을 통하여 공개하도록 하겠습니다." left="55" top="sta01_02_00_00_01_01_00_00:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <ImageViewer id="img00_00_00_00_00" taborder="56" text="제5조(정보주체와 법정대리인의 권리․의무 및 행사방법)" left="30" top="sta01_02_00_00_01_01_00_00_00:40" width="556" height="70" cssclass="font16B_icon" initvalueid="ivTitleAccessibilityOn" image="url('theme://images/PolicyV2_link06S.png')" imagealign="left middle"/>
              <Static id="sta01_02_00_00_01_01_01_01" taborder="57" text="① " left="30" top="img00_00_00_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01" taborder="58" text="정보주체(만14세 미만인 경우에는 법정대리인을 말함)는 나이스 온라인 교직원 채용에 대해 언제든지 개인정보 열람·정정·삭제·처리정지 요구 등의 권리를 행사할 수 있습니다." left="55" top="img00_00_00_00_00:15" height="42" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_01_01_00" taborder="59" text="② " left="30" top="sta01_02_00_00_01_01_00_00_01:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="두 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_00" taborder="60" text="제1항에 따른 권리 행사는 나이스 온라인 교직원 채용에 대해 「개인정보 보호법」시행령 제41조제1항에 따라 서면, 전자우편, 모사전송(FAX) 등을 통하여 하실 수 있으며, 나이스 온라인 교직원 채용은 이에 대해 지체 없이 조치하겠습니다." left="55" top="sta01_02_00_00_01_01_00_00_01:15" height="42" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_01_01_00_00" taborder="61" text="③ " left="30" top="sta01_02_00_00_01_01_00_00_01_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="세 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_00_00" taborder="62" text="제1항에 따른 권리 행사는 정보주체의 법정대리인이나 위임을 받은 자 등 대리인을 통하여 하실 수 있습니다. 이 경우 “개인정보 처리 방법에 관한 고시(제2020-7호)” 별지 제11호 서식에 따른 위임장을 제출하셔야 합니다. " left="55" top="sta01_02_00_00_01_01_00_00_01_00:15" height="42" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_00_00_01" taborder="63" text="▶개인정보(열람, 정정·삭제, 처리정지)요구서  &lt;l v=' '&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;[다운로드]&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;" left="55" top="sta01_02_00_00_01_01_00_00_01_00_00:4" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" usedecorate="true" width="1113"/>
              <Static id="sta01_02_00_00_01_01_01_01_00_00_00" taborder="64" text="④ " left="30" top="sta01_02_00_00_01_01_00_00_01_00_00_01:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="네 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_00_00_00" taborder="65" text="개인정보 열람 및 처리정지 요구는 「개인정보 보호법」제35조제4항, 제37조제2항에 의하여 정보주체의 권리가 제한 될 수 있습니다." left="55" top="sta01_02_00_00_01_01_00_00_01_00_00_01:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" width="1113"/>
              <Static id="sta01_02_00_00_01_01_01_01_00_00_00_00" taborder="66" text="⑤ " left="30" top="sta01_02_00_00_01_01_00_00_01_00_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="다섯 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_00_00_00_00" taborder="67" text="개인정보의 정정 및 삭제 요구는 다른 법령에서 그 개인정보가 수집 대상으로 명시되어 있는 경우에는 그 삭제를 요구할 수 없습니다." left="55" top="sta01_02_00_00_01_01_00_00_01_00_00_00:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" width="1113"/>
              <Static id="sta01_02_00_00_01_01_01_01_00_00_00_00_00" taborder="68" text="⑥ " left="30" top="sta01_02_00_00_01_01_00_00_01_00_00_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="여섯 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_00_00_00_00_00" taborder="69" text="나이스 온라인 교직원 채용 정보주체 권리에 따른 열람의 요구, 정정·삭제의 요구, 처리정지의 요구 시 열람 등 요구를 한 자가 본인이거나 정당한 대리인인지를 확인합니다." left="55" top="sta01_02_00_00_01_01_00_00_01_00_00_00_00:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" width="1113"/>
              <ImageViewer id="img00_00_00_00_00_00" taborder="70" text="제6조(개인정보의 파기)" left="30" top="sta01_02_00_00_01_01_00_00_01_00_00_00_00_00:40" width="432" height="70" cssclass="font16B_icon" initvalueid="ivTitleAccessibilityOn" image="url('theme://images/PolicyV2_link09S.png')" imagealign="left middle"/>
              <Static id="sta01_02_00_00_01_01_01_01_01" taborder="71" text="① " left="30" top="img00_00_00_00_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01" taborder="72" text="나이스 온라인 교직원 채용은 개인정보 보유기간의 경과, 처리목적 달성 등 개인정보가 불필요하게 되었을 때에는 지체없이 해당 개인정보를 파기합니다." left="55" top="img00_00_00_00_00_00:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_01_01_01_00" taborder="73" text="② " left="30" top="sta01_02_00_00_01_01_00_00_01_01:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="두 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00" taborder="74" text="정보주체로부터 동의받은 개인정보 보유기간이 경과하거나 처리목적이 달성되었음에도 불구하고 다른 법령에 따라 개인정보를 계속 보존하여야 하는 경우에는, 해당 개인정보를 별도의 데이터베이스(DB)로 옮기거나 보관장소를 달리하여 보존합니다." left="55" top="sta01_02_00_00_01_01_00_00_01_01:15" height="42" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01" taborder="75" text="1. 법령 근거 : 「공공기록물 관리에 관한 법률」제21조제1항" left="46" top="sta01_02_00_00_01_01_00_00_01_01_00:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_00" taborder="76" text="2. 보존하는 개인정보 항목: 홈페이지를 통해 제공하는 모든 서비스 사용에 필요한 사용자 정보" left="46" top="sta01_02_00_00_01_01_00_00_01_01_00_01:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_01_01_01_00_00" taborder="77" text="③ " left="30" top="sta01_02_00_00_01_01_00_00_01_01_00_01_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="세 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_00" taborder="78" text="나이스 온라인 교직원 채용은 개인정보 보유기간의 경과, 처리목적 달성 등 개인정보가 불필요하게 되었을 때에는 지체없이 해당 개인정보를 파기합니다." left="55" top="sta01_02_00_00_01_01_00_00_01_01_00_01_00:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_01" taborder="79" text="1. 파기 절차" left="46" top="sta01_02_00_00_01_01_00_00_01_01_00_00:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00" taborder="80" text="나이스 온라인 교직원 채용은 파기 사유가 발생한 개인정보를 선정하고, 나이스 온라인 교직원 채용의 개인정보 보호책임자의 승인을 받아 파기합니다." left="59" top="sta01_02_00_00_01_01_00_00_01_01_00_01_01:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_00_00" taborder="81" text="2. 파기 방법" left="46" top="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_00" taborder="82" text="나이스 온라인 교직원 채용은 전자적 파일 형태로 기록·저장된 개인정보는 기록을 재생할 수 없도록 파기하며, 종이 문서에 기록·저장된 개인정보는 분쇄기로 분쇄하거나 소각하여 파기합니다." left="59" top="sta01_02_00_00_01_01_00_00_01_01_00_01_00_00:4" height="42" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <ImageViewer id="img00_00_00_00_00_00_00" taborder="83" text="제7조(개인정보의 안전성 확보 조치)" left="30" top="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_00:40" width="422" height="70" cssclass="font16B_icon" initvalueid="ivTitleAccessibilityOn" image="url('theme://images/PolicyV2_link10S.png')" imagealign="left middle"/>
              <Static id="sta01_02_00_00_01_01_01_01_01_01" taborder="84" text="나이스 온라인 교직원 채용은 개인정보의 안전성 확보를 위해 다음과 같은 조치를 취하고 있습니다." left="30" top="img00_00_00_00_00_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_02" taborder="85" text="1. 관리적 조치 : 내부관리계획 수립·시행, 정기적 직원 교육 등" left="40" top="sta01_02_00_00_01_01_01_01_01_01:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_01" taborder="86" text="- (내부관리계획의 수립) 안전한 개인정보 처리를 위하여 내부관리계획 수립 및 시행" left="53" top="sta01_02_00_00_01_01_00_00_01_01_00_01_02:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_01_00" taborder="87" text="- (정기적 점검) 안전성 확보를 위해 개인정보 파일 보유현황 정기적 점검 실시" left="53" top="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_01:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_01_00_00" taborder="88" text="- (개인정보취급자 교육) 개인정보취급자 최소화 관리 및 개인정보 보호 교육 실시" left="52" top="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_01_00:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_02_00" taborder="89" text="2. 기술적 조치 : 개인정보처리시스템 등의 접근권한 관리, 접근통제시스템 설치, 고유식별정보 등 암호화, 보안프로그램 설치 " left="40" top="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_01_00_00:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_01_01" taborder="90" text="- (개인정보 접근 제한 관리) 개인정보를 처리하는 데이터베이스시스템에 대한 접근권한의 부여, 변경, 말소 등 접근 권한 관리를 통한 접근통제 및 침입차단시스템 운영으로 외부에서 불법 접근 원천 차단" left="53" top="sta01_02_00_00_01_01_00_00_01_01_00_01_02_00:4" height="42" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_01_00_01" taborder="91" text="- (개인정보의 암호화) 개인정보(고유식별정보 등) 저장·전송 시 암호화 및 파일 잠금 기능을 사용하여 보안 강화" left="53" top="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_01_01:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_01_00_00_00" taborder="92" text="- (접속기록의 보관 및 위·변조 방지) 개인정보처리시스템 접속기록 최소 1년 이상 보관·관리 및 위·변조, 도난, 분실 예방관리" left="52" top="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_01_00_01:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_01_00_00_00_00" taborder="93" text="※ 다만, 5만 명 이상의 정보주체의 개인정보 처리, 고유식별정보 또는 민감정보를 처리하는 개인정보처리시스템의 경우 2년 이상 보관관리" left="62" top="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_01_00_00_00:0" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_01_00_00_00_01" taborder="94" text="- (보안프로그램 설치 및 주기적 점검·갱신) 해킹·악성코드 등 개인정보 유출 및 훼손 방지를 위한 보안프로그램을 설치·운영하고 주기적 갱신 및 점검 실시" left="52" top="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_01_00_00_00_00:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_02_00_00" taborder="95" text="3. 물리적 조치 : 전산실, 자료보관실 등의 접근통제 " left="40" top="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_01_00_00_00_01:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_01_00_00_00_01_00" taborder="96" text="- (비인가자에 대한 출입 통제) 개인정보 보관 장소를 물리적으로 분리하여 출입통제 실시" left="52" top="sta01_02_00_00_01_01_00_00_01_01_00_01_02_00_00:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_01_00_00_00_01_00_00" taborder="97" text="- (문서보안을 위한 잠금장치 사용) 개인정보 포함 서류 및 보조저장매체 등은 잠금장치가 있는 안전한 장소에 보관·관리" left="52" top="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_01_00_00_00_01_00:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <ImageViewer id="img00_00_00_00_00_00_00_00" taborder="98" text="제8조(개인정보 자동 수집 장치의 설치·운영 및 거부에 관한 사항)" left="30" top="sta01_02_00_00_01_01_00_00_01_01_00_01_01_00_01_00_00_00_01_00_00:40" width="589" height="70" cssclass="font16B_icon" initvalueid="ivTitleAccessibilityOn" image="url('theme://images/PolicyV2_link08S.png')" imagealign="left middle"/>
              <Static id="sta01_02_00_00_01_01_01_01_01_02" taborder="99" text="① " left="30" top="img00_00_00_00_00_00_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01" taborder="100" text="나이스 온라인 교직원 채용은 이용자에게 개별적인 맞춤서비스를 제공하기 위해 이용정보를 저장하고 수시로 불러오는 ‘쿠키(Cookie)’를 사용합니다." left="55" top="img00_00_00_00_00_00_00_00:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_01_01_01_02_00" taborder="101" text="② " left="30" top="sta01_02_00_00_01_01_00_00_01_01_01:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="두 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_00" taborder="102" text="쿠키는 웹사이트를 운영하는데 이용되는 서버(http)가 이용자의 컴퓨터 브라우저에게 보내는 소량의 정보이며 이용자의 PC 컴퓨터내의 하드디스크에 저장되기도 합니다." left="55" top="sta01_02_00_00_01_01_00_00_01_01_01:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_00_00" taborder="103" text="가." left="46" top="sta01_02_00_00_01_01_00_00_01_01_01_00:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" width="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_00_01" taborder="104" text="쿠키의 사용목적: 이용자가 방문한 각 서비스와 웹 사이트들에 대한 방문 및 이용형태, 인기 검색어, 보안접속 여부 등을 파악하여 이용자에게 최적화된 정보 제공을 위해 사용됩니다." left="76" top="sta01_02_00_00_01_01_00_00_01_01_01_00:4" height="42" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_00_00_00" taborder="105" text="나." left="46" top="sta01_02_00_00_01_01_00_00_01_01_01_00_01:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" width="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_00_01_00" taborder="106" text="쿠키의 설치∙운영 및 거부 : 브라우저 옵션 설정을 통해 쿠키 허용, 쿠키 차단 등의 설정을 할 수 있습니다." left="76" top="sta01_02_00_00_01_01_00_00_01_01_01_00_01:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_00_01_00_00" taborder="107" text="- Internet Explorer: 웹브라우저 우측 상단의 도구 메뉴 &gt; 인터넷 옵션 &gt; 개인정보 &gt; 설정 &gt; 고급" left="76" top="sta01_02_00_00_01_01_00_00_01_01_01_00_01_00:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_00_01_00_00_00" taborder="108" text="- Edge: 웹브라우저 우측 상단의 설정 메뉴 &gt; 쿠키 및 사이트 권한 &gt; 쿠키 및 사이트 데이터 관리 및 삭제" left="76" top="sta01_02_00_00_01_01_00_00_01_01_01_00_01_00_00:4" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_00_01_00_00_00_00" taborder="109" text="- Chrome: 웹브라우저 우측 상단의 설정 메뉴 &gt; 개인 정보 보호 및 보안 &gt; 쿠키 및 기타 사이트 데이터" left="76" top="sta01_02_00_00_01_01_00_00_01_01_01_00_01_00_00_00:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_00_00_00_00" taborder="110" text="다." left="46" top="sta01_02_00_00_01_01_00_00_01_01_01_00_01_00_00_00_00:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" width="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_00_01_00_01" taborder="111" text="쿠키 저장을 거부할 경우 맞춤형 서비스 이용에 어려움이 발생할 수 있습니다." left="76" top="sta01_02_00_00_01_01_00_00_01_01_01_00_01_00_00_00_00:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <ImageViewer id="img00_00_00_00_00_00_00_00_00" taborder="112" text="제9조(개인정보 보호책임자에 관한 사항)" left="30" top="sta01_02_00_00_01_01_00_00_01_01_01_00_01_00_01:40" width="432" height="70" cssclass="font16B_icon" initvalueid="ivTitleAccessibilityOn" image="url('theme://images/PolicyV2_link11S.png')" imagealign="left middle"/>
              <Static id="sta01_02_00_00_01_01_01_01_01_02_01" taborder="113" text="① " left="30" top="img00_00_00_00_00_00_00_00_00:15" height="23" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" width="20" fittocontents="height" accessibilitylabel="첫 번째"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01" taborder="114" text="나이스 온라인 교직원 채용은 개인정보 처리에 관한 업무를 총괄해서 책임지고, 개인정보 처리와 관련한 정보주체의 불만처리 및 피해구제 등을 위하여 아래와 같이 개인정보 보호책임자를 지정하고 있습니다." left="55" top="img00_00_00_00_00_00_00_00_00:15" height="42" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_00" taborder="115" text="1. 교육부" left="55" top="sta01_02_00_00_01_01_00_00_01_01_01_01:4" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_02" taborder="116" text="▶ " left="68" top="sta01_02_00_00_01_01_00_00_01_01_01_01_00:4" height="21" initvalueid="ivStcAccessibilityOff" cssclass="sta_WF_Txt16L" fittocontents="height" width="20"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00" taborder="117" text="개인정보 보호 책임자&#13;&#10;성명: 심민철&#13;&#10;소속: 교육부 디지털교육기획관" left="91" top="sta01_02_00_00_01_01_00_00_01_01_01_01_00:4" height="63" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_02_00" taborder="118" text="▶ " left="68" top="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00:15" height="21" initvalueid="ivStcAccessibilityOff" cssclass="sta_WF_Txt16L" fittocontents="height" width="20"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_01" taborder="119" text="개인정보 보호 담당자&#13;&#10;성명: 진경희&#13;&#10;소속: 교육부 정보보호팀&#13;&#10;연락처: 044-203-6514, heeyajin@korea.kr, 044-203-6185" left="91" top="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00:10" height="84" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_00_01" taborder="120" text="2. 17개 시도교육청: 해당 시도교육청 홈페이지 참조" left="55" top="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_01:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_00" taborder="121" text="3. 한국교육학술정보원(나이스 온라인 교직원 채용의 운영 및 유지관리 수탁사)" left="55" top="sta01_02_00_00_01_01_00_00_01_01_01_01_00_01:15" height="21" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" fittocontents="height" right="30"/>
              <Static id="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_02_00_00" taborder="122" text="▶ " left="68" top="sta01_02_00_00_01_01_00_00_01_01_01_01_00_00_00:4" height="21" initvalueid="ivStcAccessibilityOff" cssclass="sta_WF_Txt16L" fittocontents="height" width="20"/>
