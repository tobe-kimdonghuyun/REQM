    <Objects>
      <Dataset id="ds_data01">
        <ColumnInfo>
          <Column id="data01" type="STRING" size="256"/>
          <Column id="data02" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="data01">운영체제(OS)</Col>
            <Col id="data02">윈도우 10, 11</Col>
          </Row>
          <Row>
            <Col id="data01">브라우저</Col>
            <Col id="data02">크롬, 엣지, 파이어폭스, 오페라</Col>
          </Row>
        </Rows>
