<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="scr_site05" width="1340" height="787" titletext="웹접근성정책" onload="form_onload">
    <Layouts>
      <Layout height="787" width="1340" screenid="desktopScr">
        <Static id="Static09" taborder="0" text="웹접근성정책" left="20" top="0" height="95" cssclass="sta_WF_Title" accessibilityrole="heading" right="0"/>
        <Static id="Static00" taborder="1" text="나이스 대국민 서비스는 장애인, 노인 등의 정보취약계층의 사용자가 전문적인 능력없이도 웹 사이트에서 제공하는 정보에 접근할 수 있도록 최선의 노력을 기울이고 있습니다.&#13;&#13;&#10;정보취약계층의 인터넷 정보 접근을 보장하기 위해 국가표준(KICS)으로 제정된 &quot;한국형 웹 콘텐츠 접근성 지침2.1&quot;과 &quot;전자정부서비스 호환성 준수지침(행정자치부 고시 제1호)&quot;을 준수하여 제작되어 있습니다." left="20" top="Static09:0" height="64" fittocontents="height" cssclass="sta_WF_SiteTxtBox" right="0"/>
        <Static id="Static01_00_00" taborder="2" text="지원 가능한 OS 및 브라우저" left="30" top="Static00:30" height="24" right="0" cssclass="sta_WF_SiteTitle01"/>
        <Static id="Static04_00_00" taborder="3" text="나이스 대국민서비스에서는 마이크로소프트사 윈도우, 애플사 맥 OS 등의 운영체제와 크롬, 엣지, 파이어폭스, 사파리 등의 다양한 브라우저에서 동일한 서비스 화면을 제공하고 있습니다. &#13;&#10;(일부 운영체제 및 브라우저에서 특정 기능이 제한될 수 있습니다.)" left="30" top="Static01_00_00:15" height="40" right="0" cssclass="sta_WF_SiteTxt01" fittocontents="height"/>
        <Grid id="Grid00" taborder="4" left="30" top="Static04_00_00:20" height="94" right="0" binddataset="ds_data01" cssclass="grd_WF_Site" selecttype="cell" scrollbartype="none none" autofittype="col" initvalueid="iv_Grid0_TabstopF" scrolltype="none" formatid="default" showcellselection="true" showselection="true">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="270" band="left"/>
                <Column size="500"/>
              </Columns>
              <Rows>
                <Row size="47"/>
              </Rows>
              <Band id="body">
                <Cell text="bind:data01" background="#F4F5F7" displaytype="text"/>
                <Cell col="1" text="bind:data02" cssclass="cell_WF_End" padding="0px 0px 0px 40px"/>
              </Band>
            </Format>
            <Format id="format00">
              <Columns>
                <Column size="120" band="left"/>
                <Column size="48"/>
              </Columns>
              <Rows>
                <Row size="47"/>
              </Rows>
              <Band id="body">
                <Cell text="bind:data01" background="#F4F5F7" displaytype="text"/>
                <Cell col="1" text="bind:data02" cssclass="cell_WF_End" padding="0px 0px 0px 10px"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="Static01_00_00_00" taborder="5" text="장애인이용안내" left="30" top="Grid00:35" height="24" right="0" cssclass="sta_WF_SiteTitle01"/>
        <Static id="Static04_00_00_00" taborder="6" text="나이스 대국민서비스는 시각장애인을 위한 별도의 홈페이지를 구축하지 않고 이용할 수 있도록 하였습니다. 시각장애인 사용자가 나이스 대국민서비스를 이용하기 위해서는 화면을 읽어주는 별도의 스크린 리더 프로그램이 필요합니다." left="30" top="Static01_00_00_00:15" height="20" right="0" cssclass="sta_WF_SiteTxt01" fittocontents="height"/>
        <Static id="Static04_00_00_00_01" taborder="7" text="스크린리더 및 기타 보조기기에 대한 안내는 정보통신보조기기" left="30" top="Static04_00_00_00:2" height="20" cssclass="sta_WF_SiteTxt01" fittocontents="height" width="336"/>
        <Button id="Button00" taborder="8" text="(www.at4u.or.kr)" left="Static04_00_00_00_01:2" top="Static04_00_00_00:2" width="105" height="20" cssclass="btn_WF_SiteLink" initvalueid="iv_Button" accessibilitydescription="새창열기"/>
        <Static id="Static04_00_00_00_01_01" taborder="9" text="웹사이트에서" left="477" top="Static04_00_00_00:2" height="20" cssclass="sta_WF_SiteTxt01" fittocontents="height" onclick="Static04_00_00_00_01_01_onclick" right="790" width="73"/>
        <Static id="Static04_00_00_00_01_01_00" taborder="10" text="안내 받으실 수 있으며, " left="Static04_00_00_00_01_01:2" top="Static04_00_00_00:2" height="20" cssclass="sta_WF_SiteTxt01" fittocontents="height" onclick="Static04_00_00_00_01_01_onclick" right="0"/>
        <Static id="Static04_00_00_00_01_00" taborder="11" text="중앙보조기구센터" left="30" top="Static04_00_00_00_01_01:2" height="20" cssclass="sta_WF_SiteTxt01" fittocontents="height" width="97"/>
        <Button id="Button00_00" taborder="12" text="(www.knat.or.kr)" left="Static04_00_00_00_01_00:2" top="Static04_00_00_00_01_01:2" width="104" height="20" cssclass="btn_WF_SiteLink" initvalueid="iv_Button" accessibilitydescription="새창열기"/>
        <Static id="Static04_00_00_00_01_00_00" taborder="13" text="에서" left="Button00_00:4" top="Static04_00_00_00_01_01:2" height="20" cssclass="sta_WF_SiteTxt01" fittocontents="height" right="1078" width="25"/>
        <Static id="Static04_00_00_00_01_00_00_00" taborder="14" text="장애인보조기구 지원사업에 대한 각종 정보를 확인하실 수 있습니다." left="Static04_00_00_00_01_00_00:2" top="Static04_00_00_00_01_01:2" height="20" cssclass="sta_WF_SiteTxt01" fittocontents="height" right="0"/>
        <Static id="Static01_00_00_00_00" taborder="15" text="키보드 사용법" left="30" top="Static04_00_00_00_01_00_00_00:35" height="24" right="0" cssclass="sta_WF_SiteTitle01"/>
        <Grid id="grdEnd" taborder="16" left="30" top="Static01_00_00_00_00:20" height="188" right="0" binddataset="ds_data02" cssclass="grd_WF_Site" selecttype="cell" scrollbartype="autoindicator none" autofittype="col" initvalueid="iv_Grid0_TabstopF" formatid="default" showcellselection="true" showselection="true" scrolltype="horizontal">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="270" band="left"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="47"/>
              </Rows>
              <Band id="body">
                <Cell text="bind:data01" displaytype="imagecontrol" background="#F4F5F7" imagestretch="fit" padding="0px 30px 0px 30px"/>
                <Cell col="1" text="bind:data02" padding="0px 0px 0px 40px" cssclass="cell_WF_End"/>
              </Band>
            </Format>
            <Format id="format00">
              <Columns>
                <Column size="180" band="left"/>
                <Column size="550"/>
              </Columns>
              <Rows>
                <Row size="47"/>
              </Rows>
              <Band id="body">
                <Cell background="#F4F5F7" displaytype="imagecontrol" text="bind:data01" imagestretch="fit" padding="0px 10px 0px 10px"/>
                <Cell col="1" text="bind:data02" padding="0px 0px 0px 10px" cssclass="cell_WF_End"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
      </Layout>
