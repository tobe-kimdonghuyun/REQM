              <Static id="sta00_02_01_0_01_00_01" taborder="188" left="25" top="sta00_02_01_00_01_01_01_02_01:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="② " fittocontents="height" accessibilitylabel="두 번째" width="35"/>
              <Static id="sta00_02_01_0_01_00_00_00" taborder="190" left="25" top="sta00_02_01_00_01_01_01_02_00_01_00_00_00_00_00_00:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="③ " fittocontents="height" accessibilitylabel="세 번째" width="35"/>
              <Static id="sta00_02_01_0_00_00" taborder="199" left="25" top="imgTitle00_01_0_00_00_00_00:5" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="① " fittocontents="height" accessibilitylabel="첫 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_01_00_00" taborder="200" left="65" top="imgTitle00_01_0_00_00_00_00:5" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="회원이 서비스의 이용 권한, 기타 이용 계약상의 지위를 타인에게 양도, 증여할 수 없으며 이를 담보로 제공할 수 없습니다. " fittocontents="height" right="20"/>
              <ImageViewer id="imgTitle00_01_0_00_00_00_00_00" taborder="201" text="제21조 면책조항" left="14" top="sta00_02_01_00_01_01_01_00_00:23" height="40" cssclass="img_WF_SubTit04" width="316" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_0_00_00_00" taborder="202" left="25" top="imgTitle00_01_0_00_00_00_00_00:5" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="① " fittocontents="height" accessibilitylabel="첫 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00" taborder="203" left="65" top="imgTitle00_01_0_00_00_00_00_00:5" height="168" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 천재지변, 국가비상사태 및 기타 이에 준하는 불가항력으로 인해 서비스가 제공되지 않아 피해가 발생할 경우 책임이 면제됩니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_0_00_00_00_00" taborder="204" left="25" top="sta00_02_01_00_01_01_01_00_00_00:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="② " fittocontents="height" accessibilitylabel="두 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00_00" taborder="205" left="65" top="sta00_02_01_00_01_01_01_00_00_00:15" height="210" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 천재지변, 국가비상사태 및 기타 이에 준하는 불가항력으로 인해 자료, 메시지 및 각종 게시물 등이 분실, 삭제, 변형되었거나 전송되지 못하는 등으로 데이터의 손실이 발생된 경우 책임이 면제됩니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_0_00_00_00_00_00" taborder="206" left="25" top="sta00_02_01_00_01_01_01_00_00_00_00:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="③ " fittocontents="height" accessibilitylabel="세 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00_00_00" taborder="207" left="65" top="sta00_02_01_00_01_01_01_00_00_00_00:15" height="168" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 긴급한 시스템 점검, 증설, 교체, 공사, 시스템관리자의 고의·과실 없는 디스크 장애, 시스템다운 등 부득이한 사유로 발생한 손해에 대하여 책임이 면제됩니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_0_00_00_00_00_00_00" taborder="208" left="25" top="sta00_02_01_00_01_01_01_00_00_00_00_00:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="④ " fittocontents="height" accessibilitylabel="네 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00_00_00_00" taborder="209" left="65" top="sta00_02_01_00_01_01_01_00_00_00_00_00:15" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 회원이 이용하는 컴퓨터, 모바일 등의 전자기기 오류로 피해가 발생할 경우 책임이 면제됩니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_0_00_00_00_00_00_00_00" taborder="210" left="25" top="sta00_02_01_00_01_01_01_00_00_00_00_00_00:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="⑤ " fittocontents="height" accessibilitylabel="다섯 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00_00_00_00_00" taborder="211" left="65" top="sta00_02_01_00_01_01_01_00_00_00_00_00_00:15" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 회원의 귀책 사유에 의한 서비스 이용 장애 등으로 피해가 발생할 경우 책임이 면제됩니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_0_00_00_00_00_00_00_00_00" taborder="212" left="25" top="sta00_02_01_00_01_01_01_00_00_00_00_00_00_00:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="⑥ " fittocontents="height" accessibilitylabel="여섯 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00_00_00_00_00_00" taborder="213" left="65" top="sta00_02_01_00_01_01_01_00_00_00_00_00_00_00:15" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 회원이 서비스를 이용하며 기대하는 손익이나 서비스를 통하여 얻은 정보로 피해가 발생할 경우 책임이 면제됩니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_0_00_00_00_00_00_00_00_00_00" taborder="214" left="25" top="sta00_02_01_00_01_01_01_00_00_00_00_00_00_00_00:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="⑦ " fittocontents="height" accessibilitylabel="일곱 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00_00_00_00_00_00_00" taborder="215" left="65" top="sta00_02_01_00_01_01_01_00_00_00_00_00_00_00_00:15" height="168" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 인터넷서비스 및 통신사업자의 전기통신서비스가 중지되거나 정상적으로 제공되지 않아 피해가 발생할 경우 책임이 면제됩니다." fittocontents="height" right="20"/>
