              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00_00_00" taborder="157" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00_01:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="회원이 나이스 학부모서비스의 서비스 중지에 대한 공지를 인지하지 못하여 발생하는 불이익에 대한 모든 책임은 회원에게 있습니다." fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00" taborder="158" left="40" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="④ " fittocontents="height" accessibilitylabel="네 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00_00_00_00" taborder="159" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00_00_00:15" height="54" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 긴급한 시스템 점검, 증설 및 교체 등 부득이한 사유로 인하여 공지 없이 일시적으로 서비스를 중단할 수 있습니다. 또한 통제할 수 없는 사유(시스템관리자의 고의·과실 없는 디스크 장애, 시스템다운 등)나 다른 사람(인터넷서비스 및 통신사업자 등)의 고의·과실로 인한 시스템중단 등의 경우도 공지 없이 서비스를 중단할 수 있습니다." fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00" taborder="160" left="40" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="⑤ " fittocontents="height" accessibilitylabel="다섯 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00_00_00_00_00" taborder="161" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00_00_00_00:15" height="36" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 새로운 서비스로 교체 등 적절하다고 판단하는 사유에 의하여 현재 제공되는 서비스를 사전 공지 후 영구적으로 중단할 수 있습니다. 다만, 이 경우 사전 공지 기간은 1개월로 합니다. " fittocontents="height" right="30"/>
              <ImageViewer id="imgTitle00_01_0" taborder="162" text="제16조 임의의 임시조치" left="30" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00_00_00_00_00:23" height="30" cssclass="img_WF_Txt16B" width="198" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_0" taborder="163" left="40" top="imgTitle00_01_0:0" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="① " fittocontents="height" accessibilitylabel="첫 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_01" taborder="164" left="65" top="imgTitle00_01_0:0" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 회원이 게시한 게시물 등이 다음의 각 호에 해당하는 경우 사전통지 없이 이동하거나 등록 거부 또는 삭제할 수 있습니다." fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_01_01_01_01" taborder="165" left="60" top="sta00_02_01_00_01_01_01:8" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="1. 나이스 학부모서비스 이용약관 제7장 이용 정지에 해당하는 경우" fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_01_01_01_01_00" taborder="166" left="60" top="sta00_02_01_00_01_01_01_01:10" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="2. 나이스 학부모서비스의 성격에 부합하지 않는 게시물" fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_01_01_01_01_00_00" taborder="167" left="60" top="sta00_02_01_00_01_01_01_01_00:10" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="3. 범죄적 행위에 결부된다고 인정되는 내용" fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_01_01_01_01_00_00_00" taborder="168" left="60" top="sta00_02_01_00_01_01_01_01_00_00:10" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="4. 기타 관계 법령에 위배되는 내용" fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00_00_00_00_0" taborder="169" left="40" top="sta00_02_01_00_01_01_01_01_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="② " fittocontents="height" accessibilitylabel="두 번째" width="20"/>
              <Static id="sta00_02_01_00_0" taborder="170" left="65" top="sta00_02_01_00_01_01_01_01_00_00_00:15" height="36" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="권리의 침해 여부를 판단하기 어렵거나 이해당사자 간에 다툼이 예상되는 경우에는 해당 정보에 대한 접근을 임시로 차단하는 조치를 할 수 있으며, 이 경우 임시 조치의 기간은 30일 이내로 합니다." fittocontents="height" right="30"/>
              <ImageViewer id="imgTitle00_01_0_00" taborder="171" text="제17조 정보의 제공 및 홍보물 게재" left="30" top="sta00_02_01_00_0:23" height="30" cssclass="img_WF_Txt16B" width="270" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_0_01" taborder="172" left="40" top="imgTitle00_01_0_00:0" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="① " fittocontents="height" accessibilitylabel="첫 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_01_02" taborder="173" left="65" top="imgTitle00_01_0_00:0" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 서비스 운영에 필요한 경우나 공익성이 있는 홍보물을 게재할 수 있습니다." fittocontents="height" right="30"/>
              <Static id="sta00_02_01_0_01_00" taborder="174" left="40" top="sta00_02_01_00_01_01_01_02:12" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="② " fittocontents="height" accessibilitylabel="두 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_01_02_00" taborder="175" left="65" top="sta00_02_01_00_01_01_01_02:12" height="36" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스와 연계되는 교육 관련 홈페이지에 각종 통계자료(회원 접속 정보 등)가 제공될 수 있으며, 나이스 학부모서비스 정책에 따라 추가 및 제외될 수 있습니다." fittocontents="height" right="30"/>
              <Static id="sta00_02_01_0_01_00_00" taborder="176" left="40" top="sta00_02_01_00_01_01_01_02_00:12" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="③ " fittocontents="height" accessibilitylabel="세 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_01_02_00_00" taborder="177" left="65" top="sta00_02_01_00_01_01_01_02_00:12" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 서비스를 운영함에 있어 전자우편 등으로 회원에게 정보를 제공할 수 있습니다. " fittocontents="height" right="30"/>
              <ImageViewer id="imgTitle00_01_0_00_00" taborder="178" text="제18조 게시물의 관리 및 운영" left="30" top="sta00_02_01_00_01_01_01_02_00_00:23" height="30" cssclass="img_WF_Txt16B" width="270" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_0_01_01" taborder="179" left="40" top="imgTitle00_01_0_00_00:0" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="① " fittocontents="height" accessibilitylabel="첫 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_01_02_01" taborder="180" left="65" top="imgTitle00_01_0_00_00:0" height="36" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스에 게시한 게시물의 내용에 대한 권리는 회원에게 있으며, 회원의 게시물이 타인의 저작권을 침해함으로써 발생하는 민 형사상의 책임은 전적으로 회원이 부담하여야 합니다. " fittocontents="height" right="30"/>
              <Static id="sta00_02_01_0_01_00_01" taborder="181" left="40" top="sta00_02_01_00_01_01_01_02_01:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="② " fittocontents="height" accessibilitylabel="두 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_01_02_00_01" taborder="182" left="65" top="sta00_02_01_00_01_01_01_02_01:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 게시된 내용을 사전 통지없이 이동할 수 있는 권리를 보유하며, 다음 각 호에 해당하는 게시물인 경우 사전통지 없이 삭제할 수 있습니다. " fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_01_01_01_02_00_01_00" taborder="183" left="60" top="sta00_02_01_00_01_01_01_02_00_01:10" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="- 본 서비스 약관에 위배되거나 상용 또는 불법, 음란 등 저속하다고 판단되는 내용인 경우" fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_01_01_01_02_00_01_00_00" taborder="184" left="60" top="sta00_02_01_00_01_01_01_02_00_01_00:10" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="- 다른 회원 또는 제3자를 비방하거나 중상모략 등으로 명예를 손상시키는 내용인 경우" fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_01_01_01_02_00_01_00_00_00" taborder="185" left="60" top="sta00_02_01_00_01_01_01_02_00_01_00_00:10" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="- 공공질서 및 미풍양속에 위반되는 내용인 경우" fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_01_01_01_02_00_01_00_00_00_00" taborder="186" left="60" top="sta00_02_01_00_01_01_01_02_00_01_00_00_00:10" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="- 범죄적 행위에 결부된다고 인정되는 내용인 경우" fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_01_01_01_02_00_01_00_00_00_00_00" taborder="187" left="60" top="sta00_02_01_00_01_01_01_02_00_01_00_00_00_00:10" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="- 제3자의 저작권 등 기타 권리를 침해하는 내용인 경우" fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_01_01_01_02_00_01_00_00_00_00_00_00" taborder="188" left="60" top="sta00_02_01_00_01_01_01_02_00_01_00_00_00_00_00:10" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="- 기타 관계 법령에 위배되는 경우" fittocontents="height" right="30"/>
              <Static id="sta00_02_01_0_01_00_00_00" taborder="189" left="40" top="sta00_02_01_00_01_01_01_02_00_01_00_00_00_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="③ " fittocontents="height" accessibilitylabel="세 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_01_02_00_00_00" taborder="190" left="65" top="sta00_02_01_00_01_01_01_02_00_01_00_00_00_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="회원이 게시한 게시물이 타인의 저작권을 침해함으로써 발생하는 민형사상의 책임은 전적으로 회원에게 있습니다. " fittocontents="height" right="30"/>
              <ImageViewer id="imgTitle02_00_00_00_00" taborder="191" text="제5장 기타사항" left="32" top="sta00_02_01_00_01_01_01_02_00_00_00:50" height="44" cssclass="img_WF_SubTit02" initvalueid="ivTitleAccessibilityOn" width="236" fittocontents="height"/>
              <ImageViewer id="imgTitle00_01_0_00_00_00" taborder="192" text="제19조 손해배상" left="30" top="imgTitle02_00_00_00_00:10" height="30" cssclass="img_WF_Txt16B" width="132" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_0_00" taborder="193" left="40" top="imgTitle00_01_0_00_00_00:0" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="① " fittocontents="height" accessibilitylabel="첫 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_01_00" taborder="194" left="65" top="imgTitle00_01_0_00_00_00:0" height="36" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스가 제공하는 서비스와 관련하여 회원에게 어떤 손해가 발생하더라도 나이스 학부모서비스가 고의로 행한 범죄행위를 제외하고는 이에 대하여 책임지지 않습니다. " fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00_00_00_00_0_00" taborder="195" left="40" top="sta00_02_01_00_01_01_01_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="② " fittocontents="height" accessibilitylabel="두 번째" width="20"/>
              <Static id="sta00_02_01_00_0_01" taborder="196" left="65" top="sta00_02_01_00_01_01_01_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="본 약관을 위반하여 나이스 학부모서비스 및 유관 서비스에 손해를 끼친 경우, 회원은 나이스 학부모서비스에 대하여 그 손해를 배상할 책임이 있습니다. " fittocontents="height" right="30"/>
              <ImageViewer id="imgTitle00_01_0_00_00_00_00" taborder="197" text="제20조 양도금지" left="30" top="sta00_02_01_00_0_01:23" height="30" cssclass="img_WF_Txt16B" width="137" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_0_00_00" taborder="198" left="40" top="imgTitle00_01_0_00_00_00_00:0" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="① " fittocontents="height" accessibilitylabel="첫 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_01_00_00" taborder="199" left="65" top="imgTitle00_01_0_00_00_00_00:0" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="회원이 서비스의 이용 권한, 기타 이용 계약상의 지위를 타인에게 양도, 증여할 수 없으며 이를 담보로 제공할 수 없습니다. " fittocontents="height" right="30"/>
              <ImageViewer id="imgTitle00_01_0_00_00_00_00_00" taborder="200" text="제21조 면책조항" left="30" top="sta00_02_01_00_01_01_01_00_00:23" height="30" cssclass="img_WF_Txt16B" width="137" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_0_00_00_00" taborder="201" left="40" top="imgTitle00_01_0_00_00_00_00_00:0" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="① " fittocontents="height" accessibilitylabel="첫 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00" taborder="202" left="65" top="imgTitle00_01_0_00_00_00_00_00:0" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 천재지변, 국가비상사태 및 기타 이에 준하는 불가항력으로 인해 서비스가 제공되지 않아 피해가 발생할 경우 책임이 면제됩니다." fittocontents="height" right="30"/>
              <Static id="sta00_02_01_0_00_00_00_00" taborder="203" left="40" top="sta00_02_01_00_01_01_01_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="② " fittocontents="height" accessibilitylabel="두 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00_00" taborder="204" left="65" top="sta00_02_01_00_01_01_01_00_00_00:15" height="36" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 천재지변, 국가비상사태 및 기타 이에 준하는 불가항력으로 인해 자료, 메시지 및 각종 게시물 등이 분실, 삭제, 변형되었거나 전송되지 못하는 등으로 데이터의 손실이 발생된 경우 책임이 면제됩니다." fittocontents="height" right="30"/>
              <Static id="sta00_02_01_0_00_00_00_00_00" taborder="205" left="40" top="sta00_02_01_00_01_01_01_00_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="③ " fittocontents="height" accessibilitylabel="세 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00_00_00" taborder="206" left="65" top="sta00_02_01_00_01_01_01_00_00_00_00:15" height="36" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 긴급한 시스템 점검, 증설, 교체, 공사, 시스템관리자의 고의·과실 없는 디스크 장애, 시스템다운 등 부득이한 사유로 발생한 손해에 대하여 책임이 면제됩니다." fittocontents="height" right="30"/>
              <Static id="sta00_02_01_0_00_00_00_00_00_00" taborder="207" left="40" top="sta00_02_01_00_01_01_01_00_00_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="④ " fittocontents="height" accessibilitylabel="네 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00_00_00_00" taborder="208" left="65" top="sta00_02_01_00_01_01_01_00_00_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 회원이 이용하는 컴퓨터, 모바일 등의 전자기기 오류로 피해가 발생할 경우 책임이 면제됩니다." fittocontents="height" right="30"/>
              <Static id="sta00_02_01_0_00_00_00_00_00_00_00" taborder="209" left="40" top="sta00_02_01_00_01_01_01_00_00_00_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="⑤ " fittocontents="height" accessibilitylabel="다섯 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00_00_00_00_00" taborder="210" left="65" top="sta00_02_01_00_01_01_01_00_00_00_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 회원의 귀책 사유에 의한 서비스 이용 장애 등으로 피해가 발생할 경우 책임이 면제됩니다." fittocontents="height" right="30"/>
              <Static id="sta00_02_01_0_00_00_00_00_00_00_00_00" taborder="211" left="40" top="sta00_02_01_00_01_01_01_00_00_00_00_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="⑥ " fittocontents="height" accessibilitylabel="여섯 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00_00_00_00_00_00" taborder="212" left="65" top="sta00_02_01_00_01_01_01_00_00_00_00_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 회원이 서비스를 이용하며 기대하는 손익이나 서비스를 통하여 얻은 정보로 피해가 발생할 경우 책임이 면제됩니다." fittocontents="height" right="30"/>
              <Static id="sta00_02_01_0_00_00_00_00_00_00_00_00_00" taborder="213" left="40" top="sta00_02_01_00_01_01_01_00_00_00_00_00_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="⑦ " fittocontents="height" accessibilitylabel="일곱 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00_00_00_00_00_00_00" taborder="214" left="65" top="sta00_02_01_00_01_01_01_00_00_00_00_00_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 인터넷서비스 및 통신사업자의 전기통신서비스가 중지되거나 정상적으로 제공되지 않아 피해가 발생할 경우 책임이 면제됩니다." fittocontents="height" right="30"/>
              <Static id="sta00_02_01_0_00_00_00_00_00_00_00_00_00_00" taborder="215" left="40" top="sta00_02_01_00_01_01_01_00_00_00_00_00_00_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="⑨ " fittocontents="height" accessibilitylabel="아홉 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00_00_00_00_00_00_00_00" taborder="216" left="65" top="sta00_02_01_00_01_01_01_00_00_00_00_00_00_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 회원이 서비스를 이용하면서 다른 회원으로 인해 발생하는 물리적·정신적 피해가 발생할 경우 책임이 면제됩니다." fittocontents="height" right="30"/>
              <Static id="sta00_02_01_0_00_00_00_00_00_00_00_00_00_00_00" taborder="217" left="40" top="sta00_02_01_00_01_01_01_00_00_00_00_00_00_00_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="⑩ " fittocontents="height" accessibilitylabel="열 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00_00_00_00_00_00_00_00_00" taborder="218" left="65" top="sta00_02_01_00_01_01_01_00_00_00_00_00_00_00_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 회원과 제3자간에 나이스 학부모서비스를 매개로 하여 물품·금전 거래 등에 대하여 책임이 면제됩니다." fittocontents="height" right="30"/>
              <ImageViewer id="imgTitle00_01_0_00_00_00_00_00_00" taborder="219" text="제22조 권익침해 구제 방법" left="30" top="sta00_02_01_00_01_01_01_00_00_00_00_00_00_00_00_00_00_00:23" height="30" cssclass="img_WF_Txt16B" width="230" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_0_00_00_00_01" taborder="220" left="40" top="imgTitle00_01_0_00_00_00_00_00_00:0" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="① " fittocontents="height" accessibilitylabel="첫 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00_01" taborder="221" left="65" top="imgTitle00_01_0_00_00_00_00_00_00:0" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스 이용과 관련하여 아래의 부서에 문의할 수 있습니다" fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00_01_00" taborder="222" left="60" top="sta00_02_01_00_01_01_01_00_00_00_01:8" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="1. 초·중등 학부모서비스 담당부서 및 담당자" fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00_01_00_00" taborder="223" left="70" top="sta00_02_01_00_01_01_01_00_00_00_01_00:5" height="72" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="- 소속: 한국교육학술정보원 교육행정본부 4세대나이스부&#13;&#10;- 담당자: 박유나연구원&#13;&#10;- 전자우편: &lt;l v='mailto:think1111@keris.or.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;think1111@keris.or.kr&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;&#13;&#10;- 연락처: 044-410-1235" fittocontents="height" right="30" usedecorate="true"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00_01_00_01" taborder="224" left="60" top="sta00_02_01_00_01_01_01_00_00_00_01_00_00:10" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="2. 유치원 학부모서비스 담당부서 및 담당자" fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00_01_00_00_00" taborder="225" left="70" top="sta00_02_01_00_01_01_01_00_00_00_01_00_01:5" height="72" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="- 소속: 한국교육학술정보원 교육재정본부 유치원나이스부&#13;&#10;- 담당자: 김창규 책임연구원&#13;&#10;- 전자우편: &lt;l v='mailto:ckkim@keris.or.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;ckkim@keris.or.kr&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;&#13;&#10;- 연락처: 044-410-1263" fittocontents="height" right="30" usedecorate="true"/>
              <Static id="sta00_02_01_0_00_00_00_01_00" taborder="226" left="40" top="sta00_02_01_00_01_01_01_00_00_00_01_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="② " fittocontents="height" accessibilitylabel="두 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00_01_01" taborder="227" left="65" top="sta00_02_01_00_01_01_01_00_00_00_01_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스와 관련하여 발생한 분쟁에 대해 당사자간 협의를 통해 분쟁을 해결할 수 있습니다." fittocontents="height" right="30"/>
              <Static id="sta00_02_01_0_00_00_00_01_00_00" taborder="228" left="40" top="sta00_02_01_00_01_01_01_00_00_00_01_01:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="③ " fittocontents="height" accessibilitylabel="두 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_01_00_00_00_01_01_00" taborder="229" left="65" top="sta00_02_01_00_01_01_01_00_00_00_01_01:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="본 조 제2항의 협의에서도 분쟁이 해결되지 않을 경우 양 당사자는 소송을 제기할 경우, 그 관할법원은 나이스 학부모서비스의 운영 소재지를 관할하는 법원으로 합니다." fittocontents="height" right="30"/>
              <ImageViewer id="imgTitle02_00_00_00_00_00" taborder="230" text="부칙" left="30" top="sta00_02_01_00_01_01_01_00_00_00_01_01_00:50" height="44" cssclass="img_WF_SubTit02" initvalueid="ivTitleAccessibilityOn" width="84" fittocontents="height"/>
              <ImageViewer id="imgTitle00_01_0_00_00_00_00_00_00_00" taborder="231" text="제1조 이용 약관의 적용에 관한 사항" left="30" top="imgTitle02_00_00_00_00_00:10" height="30" cssclass="img_WF_Txt16B" width="290" initvalueid="ivTitleAccessibilityOn"/>
