              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_01_00_00" taborder="134" left="40" top="imgTitle00_01_00_00_00_00_00_00_00_00:0" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="① " fittocontents="height" accessibilitylabel="첫 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_01_00_00" taborder="135" left="65" top="imgTitle00_01_00_00_00_00_00_00_00_00:0" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="아이디(ID), 비밀번호 등의 발급, 이용, 관리 등에 관한 내용은 다음과 같습니다." fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_01_00" taborder="136" left="60" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_01_00_00:8" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="1. 아이디(ID)는 회원에게 1개 발급되며, 발급받은 대상자만 이용해야 합니다." fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_00_00_01" taborder="137" left="60" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_01_00:10" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="2. 비밀번호는 3개월에 1회 이상 변경해야 합니다." fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01" taborder="138" left="40" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_00_00_01:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="② " fittocontents="height" accessibilitylabel="두 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02" taborder="139" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_00_00_01:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="본 서비스는 이용자가 본 약관 제15조(회원의 의무) 등의 내용에 위배되는 행동을 한 경우, 임의로 이용자의 서비스 사용을 제한·중지·금지할 수 있습니다." fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_01_00_00" taborder="140" left="60" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02:8" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="1. 유치원 자녀정보, 유치원생활, 유아건강, 유아학비 등의 서비스" fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_00_00_01_00" taborder="141" left="60" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_01_00_00:10" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="2. 초·중등 자녀의 학교 및 수업 정보, 학교생활, 평가, 자녀 건강, 교육활동신청 등의 서비스" fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_01_00_00_00" taborder="142" left="60" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_00_00_01_00:10" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="3. 기타 나이스 학부모서비스의 운영 목적 달성을 위해 제공하는 일체의 서비스" fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_00_00_01_00_00" taborder="143" left="60" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_01_00_00_00:10" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="4. 나이스 학부모서비스에서 제공하는 서비스 종류, 서비스 내용 등은 나이스 학부모서비스의 사정에 따라 변경될 수 있습니다." fittocontents="height" right="30"/>
