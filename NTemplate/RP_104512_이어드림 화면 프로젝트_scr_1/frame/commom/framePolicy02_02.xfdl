            <Layout name="default0">
              <ImageViewer id="imgTitle02" taborder="114" text="제1장 총칙" left="14" top="20" height="50" cssclass="img_WF_SubTit02" initvalueid="ivTitleAccessibilityOn" width="191" fittocontents="height"/>
              <ImageViewer id="imgTitle" taborder="0" text="제1조 목적" left="14" top="imgTitle02:10" height="40" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn" width="212"/>
              <Static id="sta00_02_01_00" taborder="1" left="25" top="imgTitle:5" height="168" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="본 약관은 나이스 학부모서비스에서 제공하는 모든 서비스의 이용 조건 및 절차, 이용자와 나이스 학부모서비스의 권리, 의무, 책임 및 기타 필요한 사항을 규정함을 목적으로 합니다." fittocontents="height" right="20"/>
              <ImageViewer id="imgTitle01" taborder="2" text="제2조 용어정의" left="14" top="sta00_02_01_00:23" height="40" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn" width="252"/>
              <Static id="sta00_02_01_00_00" taborder="3" left="25" top="imgTitle01:5" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="①" fittocontents="height" accessibilitylabel="첫 번째" width="35"/>
              <Static id="sta00_02_01_00_01" taborder="4" left="65" top="imgTitle01:5" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="“이용 계약”은 서비스 이용과 관련하여 나이스 학부모서비스와 회원간 체결하는 계약입니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_02" taborder="5" left="25" top="sta00_02_01_00_01:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="② " fittocontents="height" width="35" accessibilitylabel="두 번째"/>
              <Static id="sta00_02_01_00_01_00" taborder="6" left="65" top="sta00_02_01_00_01:15" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="“가입”은 나이스 학부모서비스가 제공하는 로그인 방식을 통해서 본 약관에 동의하여 서비스 이용 계약을 성립하는 행위입니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_02_00" taborder="7" left="25" top="sta00_02_01_00_01_00:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="③ " fittocontents="height" width="35" accessibilitylabel="세 번째"/>
              <Static id="sta00_02_01_00_01_00_00" taborder="8" left="65" top="sta00_02_01_00_01_00:15" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="“회원”은 나이스 학부모서비스에 개인정보 등을 제공하여 가입한 자입니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_02_00_00" taborder="9" left="25" top="sta00_02_01_00_01_00_00:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="④ " fittocontents="height" width="35" accessibilitylabel="네 번째"/>
              <Static id="sta00_02_01_00_01_00_00_00" taborder="10" left="65" top="sta00_02_01_00_01_00_00:15" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="“기존회원”은 대국민서비스(neis.go.kr)에서 이미 회원가입을 한 자입니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_02_00_00_00" taborder="11" left="25" top="sta00_02_01_00_01_00_00_00:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="⑤ " fittocontents="height" width="35" accessibilitylabel="다섯 번째"/>
              <Static id="sta00_02_01_00_01_00_00_00_00" taborder="12" left="65" top="sta00_02_01_00_01_00_00_00:15" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="“휴면회원”은 회원자격을 얻은 후 서비스 최종 접속일부터 1년 이내 로그인을 1회 이상 하지 않은 자입니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_02_00_00_01" taborder="13" left="25" top="sta00_02_01_00_01_00_00_00_00:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="⑥ " fittocontents="height" width="35" accessibilitylabel="여섯 번째"/>
              <Static id="sta00_02_01_00_01_00_00_00_00_00" taborder="14" left="65" top="sta00_02_01_00_01_00_00_00_00:15" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="“회원 자격 상실”은 나이스 학부모서비스 이용약관에 따라 회원 자격 등으로 회원가입 자격이 없어진 경우입니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_00_00_00_00_00_00" taborder="116" left="65" top="sta00_02_01_00_01_00_00_00_00_00:15" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="“회원자격 취소”는 나이스 학부모서비스가 회원의 동의를 구하지 않고 서비스를 이용할 수 없도록 이용 계약을 정지하는 행위를 말합니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_00_00_00_00_00_00_00" taborder="118" left="65" top="sta00_02_01_00_01_00_00_00_00_00_00:15" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="“탈퇴”는 이용 계약을 종료하는 행위를 말합니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_00_00_00_00_00_00_00_00" taborder="120" left="65" top="sta00_02_01_00_01_00_00_00_00_00_00_00:15" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="“아이디(ID)”는 회원 식별과 서비스 이용을 위하여 나이스 학부모서비스에서 사전에 지정한 영문, 숫자의 조합입니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_00_00_00_00_00_00_00_00_00" taborder="122" left="65" top="sta00_02_01_00_01_00_00_00_00_00_00_00_00:15" height="168" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="“비밀번호”는 이용자가 등록회원과 동일인인지 신원을 확인하고 통신상의 자신의 개인정보 보호를 위하여 이용자가 선정한 문자, 숫자, 특수문자의 조합입니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_00_00_00_00_00_00_00_00_00_00" taborder="124" left="65" top="sta00_02_01_00_01_00_00_00_00_00_00_00_00_00:15" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="“단말기”는 서비스를 제공 받기 위해 회원이 이용하는 개인용 컴퓨터, 태블릿, 모바일 기기 등입니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_00_00_00_00_00_00_00_00_00_00_00" taborder="126" left="65" top="sta00_02_01_00_01_00_00_00_00_00_00_00_00_00_00:15" height="168" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="“관계 법령”은 「정보통신망 이용촉진 및 정보보호 등에 관한 법률」, 「개인정보 보호법」, 「전기통신기본법」, 「전기통신사업법」, 기타 관계 법령(교육 관련) 등을 통칭합니다." fittocontents="height" right="20"/>
              <ImageViewer id="imgTitle01_00" taborder="15" text="제3조 약관의 효력과 변경" left="14" top="sta00_02_01_00_01_00_00_00_00_00_00_00_00_00_00_00:23" height="40" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn" width="352"/>
              <Static id="sta00_02_01_00_00_01" taborder="16" left="25" top="imgTitle01_00:5" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="①" fittocontents="height" accessibilitylabel="첫 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01" taborder="17" left="65" top="imgTitle01_00:5" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="본 약관의 내용은 나이스 학부모서비스에 공시함으로써 효력이 발생합니다. " fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_02_01" taborder="18" left="25" top="sta00_02_01_00_01_01:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="② " fittocontents="height" width="35" accessibilitylabel="두 번째"/>
              <Static id="sta00_02_01_00_01_00_01" taborder="19" left="65" top="sta00_02_01_00_01_01:15" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 대국민서비스 기존회원(학부모 회원)은 나이스 학부모서비스 이용을 위한 약관 동의를 함으로써 효력이 발생합니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_02_00_01" taborder="20" left="25" top="sta00_02_01_00_01_00_01:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="③ " fittocontents="height" width="35" accessibilitylabel="세 번째"/>
              <Static id="sta00_02_01_00_01_00_00_01" taborder="21" left="65" top="sta00_02_01_00_01_00_01:15" height="210" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="본 약관에 동의하는 것은 정기적으로 나이스 학부모서비스에 접속하여 약관의 변경사항을 확인하는 것에 동의함을 의미합니다. 회원이 변경된 약관에 대한 정보를 알지 못해 발생한 결과에 대한 모든 책임은 회원에게 있습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_02_00_00_02" taborder="22" left="25" top="sta00_02_01_00_01_00_00_01:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="④ " fittocontents="height" width="35" accessibilitylabel="네 번째"/>
              <Static id="sta00_02_01_00_01_00_00_00_01" taborder="23" left="65" top="sta00_02_01_00_01_00_00_01:15" height="168" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 합리적인 사유가 발생한 경우 약관을 변경할 수 있으며, 변경된 약관은 지체없이 나이스 학부모서비스에 게시함으로써 효력이 발생합니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_00_00_00_01_00" taborder="128" left="65" top="sta00_02_01_00_01_00_00_00_01:15" height="252" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="회원은 변경된 약관에 동의하지 않을 경우 서비스 이용을 중단하고, 이용 계약을 종료할 수 있습니다. 그러나 회원이 변경된 약관의 효력 발생일로부터 7일 이후에도 거부 의사를 표시하지 않고 서비스를 계속 이용할 경우 개정된 약관에 동의한 것으로 간주합니다. " fittocontents="height" right="20"/>
              <ImageViewer id="imgTitle00" taborder="24" text="제4조 약관의 준칙" left="14" top="sta00_02_01_00_01_00_00_00_01_00:23" height="40" cssclass="img_WF_SubTit04" width="322" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_00_01_01_00" taborder="25" left="25" top="imgTitle00:0" height="168" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="본 약관에 명시되지 않은 사항은 관계 법령에 규정되어 있을 경우 그 규정에 따르며, 그렇지 않은 경우 나이스 학부모서비스에서 제공하는 이용약관 및 운영 정책에 따릅니다. " fittocontents="height" right="20"/>
              <ImageViewer id="imgTitle02_00" taborder="129" text="제2장 서비스 이용 계약" left="14" top="sta00_02_01_00_01_01_00:50" height="50" cssclass="img_WF_SubTit02" initvalueid="ivTitleAccessibilityOn" fittocontents="height" right="200"/>
              <ImageViewer id="imgTitle00_01" taborder="26" text="제5조 이용 계약의 성립" left="14" top="imgTitle02_00:10" height="40" cssclass="img_WF_SubTit04" width="336" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_00_00_01_01" taborder="27" left="25" top="imgTitle00_01:5" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="①" fittocontents="height" accessibilitylabel="첫 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00" taborder="28" left="65" top="imgTitle00_01:5" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="이용 계약은 이용자가 학부모 서비스 이용약관 등에 대하여 회원가입 시 ‘동의’라는 버튼을 누르고 회원가입을 완료하는 것으로 성립됩니다." fittocontents="height" right="20"/>
              <ImageViewer id="imgTitle00_01_00" taborder="29" text="제6조 회원가입 및 자격 유지" left="14" top="sta00_02_01_00_01_01_00_00:23" height="40" cssclass="img_WF_SubTit04" width="456" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_00_00_01_01_00" taborder="30" left="25" top="imgTitle00_01_00:5" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="①" fittocontents="height" accessibilitylabel="첫 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01" taborder="31" left="65" top="imgTitle00_01_00:5" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스의 회원가입 자격은 유치원, 초등학교, 중학교, 고등학교 자녀의 학부모입니다. " fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_01_01_00_00" taborder="32" left="25" top="sta00_02_01_00_01_01_00_00_01:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="② " fittocontents="height" accessibilitylabel="두 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00" taborder="33" left="65" top="sta00_02_01_00_01_01_00_00_01:15" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스 이용을 원하는 경우 나이스 학부모서비스에서 정한 절차에 따라 회원으로 가입할 수 있습니다. " fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_01_01_00_00_00" taborder="34" left="25" top="sta00_02_01_00_01_01_00_00_01_00:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="③ " fittocontents="height" accessibilitylabel="세 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00" taborder="35" left="65" top="sta00_02_01_00_01_01_00_00_01_00:15" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스에서 자녀 등록을 하지 않았을 경우 서비스 이용이 제한됩니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_01_01_00_00_00_00" taborder="36" left="25" top="sta00_02_01_00_01_01_00_00_01_00_00:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="④ " fittocontents="height" accessibilitylabel="네 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00" taborder="37" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00:15" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="기존회원은 나이스 학부모서비스에서 신규 서비스 이용약관 및 개인정보처리방침 동의 후 서비스 이용이 가능합니다. " fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_01_01_00_00_00_00_00" taborder="38" left="25" top="sta00_02_01_00_01_01_00_00_01_00_00_00:10" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="⑤ " fittocontents="height" accessibilitylabel="다섯 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00" taborder="39" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00:10" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="회원가입을 거부하는 경우는 다음과 같습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_00_00_01_00_01_00_01" taborder="130" left="56" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00:8" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="1. 법령 또는 약관을 위반하여 회원가입이 취소된 적이 있는 이용자가 신청했을 때" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_00_00_01_00_01_00_01_00" taborder="131" left="56" top="sta00_02_01_00_01_01_00_00_00_00_01_00_01_00_01:10" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="2. 나이스 학부모서비스가 정한 회원가입 요건이 미비 되었을 때" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_00_00_01_00_01_00_01_00_00" taborder="132" left="56" top="sta00_02_01_00_01_01_00_00_00_00_01_00_01_00_01_00:10" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="3. 회원의 행위로 인하여 나이스 학부모서비스에 손해가 발생한 경우" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_01" taborder="134" left="65" top="sta00_02_01_00_01_01_00_00_00_00_01_00_01_00_01_00_00:10" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="회원이 최종 접속일로부터 1년 이내 로그인을 1회 이상 하지 않을 경우 휴면회원으로 전환되며 관련 내용은 다음과 같습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_00_00_01_00_01_00_01_01" taborder="135" left="56" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_01:8" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="1. 휴면회원으로 전환된 후 1년이 지나기 전에 로그인을 하면, 로그인한 시점 기준으로 회원자격이 있을 경우 휴면을 해지할 수 있습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_00_00_01_00_01_00_01_00_01" taborder="136" left="56" top="sta00_02_01_00_01_01_00_00_00_00_01_00_01_00_01_01:10" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="2. 휴면회원으로 전환된 이후부터 1년 이내 로그인한 기록이 없는 회원은 이용 자격을 상실하여 나이스 학부모서비스를 이용할 수 없습니다." fittocontents="height" right="20"/>
              <ImageViewer id="imgTitle00_01_00_00" taborder="40" text="제7조 회원자격 상실" left="14" top="sta00_02_01_00_01_01_00_00_00_00_01_00_01_00_01_00_01:23" height="40" cssclass="img_WF_SubTit04" width="300" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_00_00_01_01_00_01" taborder="41" left="25" top="imgTitle00_01_00_00:5" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="①" fittocontents="height" accessibilitylabel="첫 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00" taborder="42" left="65" top="imgTitle00_01_00_00:05" height="168" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 다음의 사유에 해당하는 경우 회원자격을 취소할 수 있으며, 회원자격을 취소하는 즉시 나이스 학부모서비스를 이용할 수 없습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00" taborder="43" left="56" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00:15" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="1. 본인의 아이디(ID) 등의 개인정보를 다른 사람이 이용할 수 있게 하는 행위" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00" taborder="44" left="56" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00:10" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="2. 다른 사람의 명의로 나이스 학부모서비스를 이용하는 행위" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00" taborder="45" left="56" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00:10" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="3. 정당한 권한 없이 다른 사람의 개인정보를 수집하거나 저장하는 행위" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_00_00_01_00_01_00" taborder="46" left="56" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00:10" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="4. 나이스 학부모서비스에 게시된 정보를 임의로 변경하는 행위" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_00_00_01_00_01_00_00" taborder="47" left="56" top="sta00_02_01_00_01_01_00_00_00_00_01_00_01_00:10" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="5. 영리를 추구할 목적으로 나이스 학부모서비스를 이용하고자 하는 경우" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_00_00_01_00_01_00_00_00" taborder="48" left="56" top="sta00_02_01_00_01_01_00_00_00_00_01_00_01_00_00:10" height="168" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="6. 다른 사람의 명예를 훼손·모욕하거나 다른 사람의 사생활을 침해할 수 있는 내용을 전자메일 또는 기타의 방법으로 전송, 게시, 게재하는 행위" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_00_00_01_00_01_00_00_00_00" taborder="49" left="56" top="sta00_02_01_00_01_01_00_00_00_00_01_00_01_00_00_00:10" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="7. 나이스 학부모서비스를 통하여 전송된 내용의 출처를 위장하는 행위" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00" taborder="50" left="56" top="sta00_02_01_00_01_01_00_00_00_00_01_00_01_00_00_00_00:10" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="8. 나이스 학부모서비스의 약관에 위반되는 내용이나 광고, 판촉물 또는 다양한 방법으로 권유하는 내용을 전송, 게시, 게재하는 행위" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00" taborder="51" left="56" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00:10" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="9. 다른 사람의 특허, 상표, 영업비밀, 저작권, 기타 저작 재산권 등의 권리를 침해하는 행위" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01" taborder="137" left="56" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00:10" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="10. 다른 사람의 서비스 이용을 방해하는 행위" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00" taborder="138" left="56" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01:10" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="11. 공공질서 혹은 미풍양속에 위반하는 행위" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00" taborder="139" left="56" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00:10" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="12. 범죄행위를 목적으로 하거나 기타 범죄행위와 관련된 행위" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00" taborder="140" left="56" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00:10" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="13. 해킹 또는 컴퓨터 바이러스의 유포행위 등의 방법으로 정보통신망을 침해하는 행위" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00" taborder="141" left="56" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00:10" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="14. 나이스 학부모서비스의 안정적인 운영에 지장을 주거나 줄 우려가 있는 모든 행위" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00" taborder="142" left="56" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00:10" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="15. 본 약관 및 나이스 학부모서비스의 운영기준, 기타 관계 법령 등에 위배 되는 행위" fittocontents="height" right="20"/>
              <ImageViewer id="imgTitle00_01_00_00_00" taborder="52" text="제8조 아이디 부여 및 변경" left="14" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00:23" height="40" cssclass="img_WF_SubTit04" width="360" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00" taborder="53" left="25" top="imgTitle00_01_00_00_00:5" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="① " fittocontents="height" accessibilitylabel="첫 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00" taborder="54" left="65" top="imgTitle00_01_00_00_00:5" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스학부모서비스는 회원가입 완료됨에 다라 이용자 아이디를 부여하여 서비스를 이용할 수 있습니다. " fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_00" taborder="55" left="25" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00:10" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="② " fittocontents="height" accessibilitylabel="두 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_00" taborder="56" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00:10" height="168" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스 아이디는 원칙적으로 변경이 불가하나 부득이한 사유로 인하여 변경하고자 하는 경우 본 사이트에 안내되어있는 사용문의 게시판으로 문의 바랍니다. " fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_00_00" taborder="144" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_00:10" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스의 이용자 아이디는 이용자 본인의 동의 하에 타 부처의 웹사이트의 이용자 아이디와 연결될 수 있습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_00_00_00" taborder="146" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_00_00:10" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스 아이디는 다음 각 호에 해당하는 경우 이용자 또는 기관의 요청으로 변경할 수 있습니다. " fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01" taborder="147" left="56" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_00_00_00:8" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="1. 이용자 아이디가 이용자의 전화번호 또는 주민등록번호 등으로 등록되어 개인정보 유출 가능성이 있는 경우" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_01" taborder="148" left="56" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01:10" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="2. 타인에게 혐오감을 주거나 미풍양속에 어긋나는 경우" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00" taborder="149" left="56" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_01:10" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="3. 기타 합리적인 사유가 있는 경우" fittocontents="height" right="20"/>
              <ImageViewer id="imgTitle00_01_00_00_00_00" taborder="57" text="제9조 서비스 이용 계약 종료" left="14" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00:23" height="40" cssclass="img_WF_SubTit04" width="430" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01" taborder="58" left="25" top="imgTitle00_01_00_00_00_00:5" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="① " fittocontents="height" accessibilitylabel="첫 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01" taborder="59" left="65" top="imgTitle00_01_00_00_00_00:5" height="210" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="회원은 나이스 학부모서비스 회원가입 이후 나이스 학부모서비스에서 제공하는 서비스를 이용할 의사가 없을 때 언제든지 본인이 나이스 학부모서비스에서 정한 절차에 따라 회원탈퇴를 할 수 있습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00" taborder="60" left="25" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="② " fittocontents="height" accessibilitylabel="두 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00" taborder="61" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01:15" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="회원 자격을 상실하는 경우 나이스 학부모서비스를 이용할 수 없습니다. 회원 자격을 상실하는 조건은 다음과 같습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00" taborder="150" left="56" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00:8" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="1. 휴면회원으로 전환된 이후부터 1년 이내 로그인한 기록이 없는 회원" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_01" taborder="152" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00:15" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="이용 계약의 종료 시 개인정보 및 개인 자료에 관한 내용은 다음과 같습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00" taborder="153" left="56" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_01:8" height="168" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="1. 회원이 직접 탈퇴한 경우 즉시 이용 계약이 종료되어 개인정보 및 개인 자료 등은 파기됩니다. 단, 각종 신청정보에 대한 자료는 삭제되지 않습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_00" taborder="154" left="56" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00:10" height="168" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="2. 휴면회원이 회원자격을 상실하는 경우 즉시 이용 계약이 종료되어 개인정보 및 개인 자료 등은 파기됩니다. 단, 각종 신청 정보에 대한 자료는 삭제되지 않습니다." fittocontents="height" right="20"/>
              <ImageViewer id="imgTitle00_01_00_00_00_00_00" taborder="62" text="제10조 회원 재가입 " left="14" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_00:23" height="40" cssclass="img_WF_SubTit04" width="308" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_01" taborder="63" left="25" top="imgTitle00_01_00_00_00_00_00:5" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="① " fittocontents="height" accessibilitylabel="첫 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_01" taborder="64" left="65" top="imgTitle00_01_00_00_00_00_00:5" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="회원탈퇴 등으로 이용 계약을 종료한 경우 회원 자격을 갖춘 후 나이스 학부모서비스에 재가입할 수 있습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00" taborder="65" left="25" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_01:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="② " fittocontents="height" accessibilitylabel="두 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00" taborder="66" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_01:15" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="재가입 시 기존의 ID(동일한 ID를 이용하는 회원이 없는 경우)를 이용할 수 있습니다." fittocontents="height" right="20"/>
