              <Static id="sta00_02_01_00_01_01_01_00_00_00_01_01_00_00_00" taborder="234" left="40" top="imgTitle00_01_0_00_00_00_00_00_00_00_00:0" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="본 약관의 시행에 필요한 세부사항은 운영기관이 정하는 바에 따른다." fittocontents="height" right="30"/>
