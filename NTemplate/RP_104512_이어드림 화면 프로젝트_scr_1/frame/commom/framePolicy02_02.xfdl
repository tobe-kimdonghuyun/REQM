              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_01_00_00_00" taborder="85" left="25" top="imgTitle00_01_00_00_00_00_00_00_00_00_00:5" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="① " fittocontents="height" accessibilitylabel="첫 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_01_00_00_00" taborder="86" left="65" top="imgTitle00_01_00_00_00_00_00_00_00_00_00:5" height="210" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 업무상 또는 기술상 특별한 이유가 없는 한 서비스 이용 시간은 연중무휴, 1일 24시간을 원칙으로 합니다. 단, 나이스 학부모서비스의 정기 점검 등을 위하여 필요한 시간은 예외로 합니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00" taborder="87" left="25" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_01_00_00_00:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="② " fittocontents="height" accessibilitylabel="두 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00" taborder="88" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_01_00_00_00:15" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 서비스별 이용할 수 있는 시간을 별도로 지정할 수 있으며, 필요한 경우 이를 조정할 수 있습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00" taborder="89" left="25" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="③ " fittocontents="height" accessibilitylabel="세 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00_00" taborder="90" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00:15" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 회원의 소속, 유형(자녀 등록 여부 등)에 따라 제공하는 서비스가 다릅니다." fittocontents="height" right="20"/>
              <ImageViewer id="imgTitle00_01_00_00_00_00_00_00_00_00_00_00" taborder="91" text="제15조 서비스 중지" left="14" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00_00:23" height="40" cssclass="img_WF_SubTit04" width="370" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_01_00_00_00_00" taborder="92" left="25" top="imgTitle00_01_00_00_00_00_00_00_00_00_00_00:5" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="① " fittocontents="height" accessibilitylabel="첫 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_01_00_00_00_00" taborder="93" left="65" top="imgTitle00_01_00_00_00_00_00_00_00_00_00_00:5" height="294" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 국가비상사태, 정전, 서비스 설비의 장애 또는 서비스 이용의 폭주 등으로 정상적인 서비스 제공이 불가능할 경우, 서비스의 전부 또는 일부를 수정·변경·제한하거나 중지할 수 있습니다. 다만 이 경우 그 사유 및 기간 등을 이용자에게 사전 또는 사후에 공지합니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_01" taborder="94" left="25" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_01_00_00_00_00:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="② " fittocontents="height" accessibilitylabel="두 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00_01" taborder="95" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_01_00_00_00_00:15" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 공지 후에도 부득이한 경우 공지 기간을 단축하거나 생략할 수 있습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00" taborder="96" left="25" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00_01:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="③ " fittocontents="height" accessibilitylabel="세 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00_00_00" taborder="97" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00_01:15" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="회원이 나이스 학부모서비스의 서비스 중지에 대한 공지를 인지하지 못하여 발생하는 불이익에 대한 모든 책임은 회원에게 있습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00" taborder="98" left="25" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00_00_00:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="④ " fittocontents="height" accessibilitylabel="네 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00_00_00_00" taborder="99" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00_00_00:15" height="336" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 긴급한 시스템 점검, 증설 및 교체 등 부득이한 사유로 인하여 공지 없이 일시적으로 서비스를 중단할 수 있습니다. 또한 통제할 수 없는 사유(시스템관리자의 고의·과실 없는 디스크 장애, 시스템다운 등)나 다른 사람(인터넷서비스 및 통신사업자 등)의 고의·과실로 인한 시스템중단 등의 경우도 공지 없이 서비스를 중단할 수 있습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00_00_00_00_00" taborder="175" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00_00_00_00:15" height="210" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 새로운 서비스로 교체 등 적절하다고 판단하는 사유에 의하여 현재 제공되는 서비스를 사전 공지 후 영구적으로 중단할 수 있습니다. 다만, 이 경우 사전 공지 기간은 1개월로 합니다. " fittocontents="height" right="20"/>
              <ImageViewer id="imgTitle00_01_0" taborder="100" text="제16조 임의의 임시조치" left="14" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_02_00_00_00_00_00:23" height="40" cssclass="img_WF_SubTit04" width="346" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_0" taborder="101" left="25" top="imgTitle00_01_0:5" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="① " fittocontents="height" accessibilitylabel="첫 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_01" taborder="102" left="65" top="imgTitle00_01_0:5" height="168" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 회원이 게시한 게시물 등이 다음의 각 호에 해당하는 경우 사전통지 없이 이동하거나 등록 거부 또는 삭제할 수 있습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_01_01" taborder="176" left="60" top="sta00_02_01_00_01_01_01:8" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="1. 나이스 학부모서비스 이용약관 제7장 이용 정지에 해당하는 경우" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_01_01_00" taborder="177" left="60" top="sta00_02_01_00_01_01_01_01:10" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="2. 나이스 학부모서비스의 성격에 부합하지 않는 게시물" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_01_01_00_00" taborder="178" left="60" top="sta00_02_01_00_01_01_01_01_00:10" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="3. 범죄적 행위에 결부된다고 인정되는 내용" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_01_01_00_00_00" taborder="179" left="60" top="sta00_02_01_00_01_01_01_01_00_00:10" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="4. 기타 관계 법령에 위배되는 내용" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00_00_00_00_0" taborder="103" left="25" top="sta00_02_01_00_01_01_01_01_00_00_00:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="② " fittocontents="height" accessibilitylabel="두 번째" width="35"/>
              <Static id="sta00_02_01_00_0" taborder="104" left="65" top="sta00_02_01_00_01_01_01_01_00_00_00:15" height="210" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="권리의 침해 여부를 판단하기 어렵거나 이해당사자 간에 다툼이 예상되는 경우에는 해당 정보에 대한 접근을 임시로 차단하는 조치를 할 수 있으며, 이 경우 임시 조치의 기간은 30일 이내로 합니다." fittocontents="height" right="20"/>
              <ImageViewer id="imgTitle00_01_0_00" taborder="105" text="제17조 정보의 제공 및 홍보물 게재" left="14" top="sta00_02_01_00_0:23" height="40" cssclass="img_WF_SubTit04" width="486" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_00_01_01_01_02" taborder="181" left="65" top="imgTitle00_01_0_00:5" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 서비스 운영에 필요한 경우나 공익성이 있는 홍보물을 게재할 수 있습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_01_02_00" taborder="183" left="65" top="sta00_02_01_00_01_01_01_02:12" height="168" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스와 연계되는 교육 관련 홈페이지에 각종 통계자료(회원 접속 정보 등)가 제공될 수 있으며, 나이스 학부모서비스 정책에 따라 추가 및 제외될 수 있습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_01_02_00_00" taborder="185" left="65" top="sta00_02_01_00_01_01_01_02_00:12" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 서비스를 운영함에 있어 전자우편 등으로 회원에게 정보를 제공할 수 있습니다. " fittocontents="height" right="20"/>
              <ImageViewer id="imgTitle00_01_0_00_00" taborder="106" text="제18조 게시물의 관리 및 운영" left="14" top="sta00_02_01_00_01_01_01_02_00_00:23" height="40" cssclass="img_WF_SubTit04" width="436" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_00_01_01_01_02_01" taborder="187" left="65" top="imgTitle00_01_0_00_00:5" height="210" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스에 게시한 게시물의 내용에 대한 권리는 회원에게 있으며, 회원의 게시물이 타인의 저작권을 침해함으로써 발생하는 민 형사상의 책임은 전적으로 회원이 부담하여야 합니다. " fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_01_02_00_01" taborder="189" left="65" top="sta00_02_01_00_01_01_01_02_01:15" height="168" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 게시된 내용을 사전 통지없이 이동할 수 있는 권리를 보유하며, 다음 각 호에 해당하는 게시물인 경우 사전통지 없이 삭제할 수 있습니다. " fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_01_02_00_01_00" taborder="192" left="60" top="sta00_02_01_00_01_01_01_02_00_01:10" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="- 본 서비스 약관에 위배되거나 상용 또는 불법, 음란 등 저속하다고 판단되는 내용인 경우" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_01_02_00_01_00_00" taborder="193" left="60" top="sta00_02_01_00_01_01_01_02_00_01_00:10" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="- 다른 회원 또는 제3자를 비방하거나 중상모략 등으로 명예를 손상시키는 내용인 경우" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_01_02_00_01_00_00_00" taborder="194" left="60" top="sta00_02_01_00_01_01_01_02_00_01_00_00:10" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="- 공공질서 및 미풍양속에 위반되는 내용인 경우" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_01_02_00_01_00_00_00_00" taborder="195" left="60" top="sta00_02_01_00_01_01_01_02_00_01_00_00_00:10" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="- 범죄적 행위에 결부된다고 인정되는 내용인 경우" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_01_02_00_01_00_00_00_00_00" taborder="196" left="60" top="sta00_02_01_00_01_01_01_02_00_01_00_00_00_00:10" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="- 제3자의 저작권 등 기타 권리를 침해하는 내용인 경우" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_01_02_00_01_00_00_00_00_00_00" taborder="197" left="60" top="sta00_02_01_00_01_01_01_02_00_01_00_00_00_00_00:10" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="- 기타 관계 법령에 위배되는 경우" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_01_02_00_00_00" taborder="191" left="65" top="sta00_02_01_00_01_01_01_02_00_01_00_00_00_00_00_00:15" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="회원이 게시한 게시물이 타인의 저작권을 침해함으로써 발생하는 민형사상의 책임은 전적으로 회원에게 있습니다. " fittocontents="height" right="20"/>
              <ImageViewer id="imgTitle02_00_00_00_00" taborder="198" text="제5장 기타사항" left="14" top="sta00_02_01_00_01_01_01_02_00_00_00:50" height="50" cssclass="img_WF_SubTit02" initvalueid="ivTitleAccessibilityOn" fittocontents="height" right="270"/>
              <ImageViewer id="imgTitle00_01_0_00_00_00" taborder="107" text="제19조 손해배상" left="14" top="imgTitle02_00_00_00_00:10" height="40" cssclass="img_WF_SubTit04" width="360" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_0_00" taborder="108" left="25" top="imgTitle00_01_0_00_00_00:5" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="① " fittocontents="height" accessibilitylabel="첫 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_01_00" taborder="109" left="65" top="imgTitle00_01_0_00_00_00:5" height="168" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스가 제공하는 서비스와 관련하여 회원에게 어떤 손해가 발생하더라도 나이스 학부모서비스가 고의로 행한 범죄행위를 제외하고는 이에 대하여 책임지지 않습니다. " fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00_00_00_00_0_00" taborder="110" left="25" top="sta00_02_01_00_01_01_01_00:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="② " fittocontents="height" accessibilitylabel="두 번째" width="35"/>
              <Static id="sta00_02_01_00_0_01" taborder="111" left="65" top="sta00_02_01_00_01_01_01_00:15" height="168" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="본 약관을 위반하여 나이스 학부모서비스 및 유관 서비스에 손해를 끼친 경우, 회원은 나이스 학부모서비스에 대하여 그 손해를 배상할 책임이 있습니다. " fittocontents="height" right="20"/>
