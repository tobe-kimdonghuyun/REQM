              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_01" taborder="69" left="65" top="imgTitle00_01_00_00_00_00_00_00:5" height="168" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 법령과 본 약관이 금지하거나 미풍양속에 반하는 행위를 하지 않으며, 계속적이고 안정적으로 서비스를 제공하기 위해 노력합니다. " fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00" taborder="70" left="25" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_01:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="② " fittocontents="height" accessibilitylabel="두 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00" taborder="71" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_01:15" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스는 회원이 안전하게 서비스를 이용할 수 있도록 보안시스템을 갖추어 회원의 개인정보를 보호하고 있습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_01" taborder="157" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00:15" height="252" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스에서는 계속적이고 안정적인 서비스 제공을 위하여 천재지변, 비상사태, 서비스 개선 과정에서 장애가 발생하거나 데이터 등의 소실, 현재 기술로 해결 불가능한 결함 및 장애 등 부득이한 사유가 없는 한 지체없이 복구하도록 최선을 다하겠습니다." fittocontents="height" right="20"/>
              <ImageViewer id="imgTitle00_01_00_00_00_00_00_00_00" taborder="72" text="제12조 회원의 의무 및 책임" left="14" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_01:23" height="40" cssclass="img_WF_SubTit04" width="376" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_01_00" taborder="73" left="25" top="imgTitle00_01_00_00_00_00_00_00_00:5" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="① " fittocontents="height" accessibilitylabel="첫 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_01_00" taborder="74" left="65" top="imgTitle00_01_00_00_00_00_00_00_00:5" height="210" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="회원은 본 약관에서 규정하는 사항과 `개인정보처리방침`, `서비스 이용 안내`, `공지사항` 또는 `주의사항` 등을 준수해야 하며 이를 위반하여 발생한 결과에 대한 모든 책임은 회원에게 있습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00" taborder="75" left="25" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_01_00:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="② " fittocontents="height" accessibilitylabel="두 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00" taborder="76" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_01_00:15" height="168" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="회원은 나이스 학부모서비스의 서비스를 이용하여 어떠한 영리 행위도 할 수 없으며, 이를 위반하여 발생한 결과에 대한 모든 책임은 회원에게 있습니다. " fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_00" taborder="77" left="25" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00:15" height="42" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="③ " fittocontents="height" accessibilitylabel="세 번째" width="35"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01" taborder="78" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00:15" height="210" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="회원가입 시 요구되는 정보는 정확하게 입력해야 하고 나이스 학부모서비스에 제공한 본인의 정보를 최신 정보로 유지·갱신해야 합니다. 본인의 정보를 최신으로 하지 않아서 발생하는 결과에 대한 모든 책임은 회원에게 있습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00" taborder="159" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01:15" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="나이스 학부모서비스의 회원가입을 완료한 순간부터 본인의 정보에 대한 비밀 유지 등에 관한 모든 책임은 회원에게 있습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_01" taborder="160" left="60" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00:8" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="1. 아이디(ID), 인증수단 등의 관리에 관한 모든 책임은 회원에게 있습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_00_00" taborder="161" left="60" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_01:10" height="84" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="2. 제3자가 회원의 개인정보를 이용하여 발생하는 결과에 대한 모든 책임은 회원에게 있습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_00_00_00" taborder="162" left="60" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_00_00:10" height="210" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="3. 회원 아이디(ID), 인증수단 등이 부정하게 사용되었다는 사실을 발견한 즉시 나이스 학부모서비스에 신고해야 하며, 이를 신고하지 않아서 발생하는 결과에 대한 모든 책임은 회원에게 있습니다" fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00" taborder="164" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_00_00_00:15" height="210" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="회원은 나이스 학부모서비스를 이용하여 취득한 정보를 나이스 학부모서비스의 사전 승인 없이 복사, 복제, 변경, 번역, 출판, 방송, 공중송신, 기타의 방법으로 이용하거나 이를 다른 사람에게 제공할 수 없습니다." fittocontents="height" right="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00" taborder="166" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00:15" height="126" cssclass="sta_WF_Txt28S" initvalueid="ivStcAccessibilityOn" text="회원이 나이스 학부모서비스에 게시, 전송, 등록 등의 모든 형태의 정보에 대한 책임은 회원에게 있습니다. " fittocontents="height" right="20"/>
