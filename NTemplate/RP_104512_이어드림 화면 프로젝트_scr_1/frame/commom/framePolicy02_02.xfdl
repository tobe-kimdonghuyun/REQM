              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_00_00_00" taborder="127" left="60" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_00_00:10" height="36" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="3. 회원 아이디(ID), 인증수단 등이 부정하게 사용되었다는 사실을 발견한 즉시 나이스 학부모서비스에 신고해야 하며, 이를 신고하지 않아서 발생하는 결과에 대한 모든 책임은 회원에게 있습니다" fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_00_00_00" taborder="128" left="40" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_00_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="⑤ " fittocontents="height" accessibilitylabel="다섯 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00" taborder="129" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_01_00_00_00_01_00_00_00_00_00:15" height="36" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="회원은 나이스 학부모서비스를 이용하여 취득한 정보를 나이스 학부모서비스의 사전 승인 없이 복사, 복제, 변경, 번역, 출판, 방송, 공중송신, 기타의 방법으로 이용하거나 이를 다른 사람에게 제공할 수 없습니다." fittocontents="height" right="30"/>
              <Static id="sta00_02_01_00_00_01_01_00_01_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_00_00_00_00" taborder="130" left="40" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="⑥ " fittocontents="height" accessibilitylabel="여섯 번째" width="20"/>
              <Static id="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00" taborder="131" left="65" top="sta00_02_01_00_01_01_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00_00_00_00_00_00_00_00_00_00_01_00_00:15" height="18" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" text="회원이 나이스 학부모서비스에 게시, 전송, 등록 등의 모든 형태의 정보에 대한 책임은 회원에게 있습니다. " fittocontents="height" right="30"/>
