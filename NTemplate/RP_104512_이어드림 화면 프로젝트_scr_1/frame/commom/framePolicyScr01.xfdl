  <Form id="framePolicyScr01" width="1340" height="5441" titletext="개인정보처리방침(25.7.1)" onload="form_onload" onsize="form_onsize">
    <Layouts>
      <Layout height="5441" width="1340" screenid="desktopScr">
        <Static id="staTitle" taborder="0" text="개인정보처리방침" left="20" top="0" height="95" cssclass="sta_WF_Title" accessibilityrole="heading" right="0" onclick="staTitle_onclick"/>
        <Static id="Static00" taborder="1" text="한국교육학술정보원이 취급하는 모든 개인정보는 관련 법령에 근거하거나 정보주체로부터 동의를 받고 수집·보유 및 처리되고 있습니다.  &quot;한국교육학술정보원&quot;은 정보주체의 권리 보호를 위해 「개인정보 보호법」 및 관련 법령이 정한 바에 따라 개인정보를 처리하고 안전하게 관리하고 있습니다. 이에 「개인정보 보호법」제30조에 따라 정보주체에게 개인정보 처리에 관한 절차 및 기준을 안내하고, 이와 관련한 고충을 신속하고 원활하게 처리할 수 있도록 다음과 같이 개인정보 처리방침을 수립·공개합니다." left="20" top="staTitle:0" height="80" fittocontents="height" cssclass="sta_WF_SiteTxtBox" right="0"/>
        <Static id="Static01" taborder="2" text="주요 개인정보 처리 표시(라벨링)" left="30" top="Static00:40" height="24" right="0" cssclass="sta_WF_SiteTitle01"/>
        <Static id="Static02" taborder="3" text="&lt;fs v='18'&gt;&lt;b v='true'&gt;&lt;fc v='#000000'&gt;처리 항목&lt;/fc&gt;&lt;/b&gt;&lt;/fs&gt;&#13;&#10;&#13;&#10;※ 한국교육학술정보원 홈페이지에서는 &#13;&#10;처리하는 개인정보가 없음" left="20" top="Static01:26" width="49.18%" height="271" cssclass="sta_WF_SiteLabel01" usedecorate="true"/>
