    <Script type="xscript5.1"><![CDATA[/**
*  학부모소통시스템
*  @MenuPath    공통
*  @FileName 	framePolicyScr01.xfdl
*  @Creator 	tobesoft
*  @CreateDate 	2025.03.17
*  @Desction    개인정보처리방침(25.7.1)
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2025.03.17     	tobesoft 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::scr_script.xjs";	//SCR공통라이브러리(필수)

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.objApp = nexacro.getApplication();
this.invlInfoSts = true; // 개인정보파일및홈페이지보기
this.infoMbySts = true; // 정보주체의 개인정보 열람, 정정·삭제, 처리정지 요구 절차


/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.scrInitForm(obj);	//화면초기화 공통함수(필수)
	
	this.resetScroll();
};


/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 this.fnMovePosition = function(objComp)
{
	var nTop = objComp.getOffsetTop() + this.parent.getOffsetTop();
	//	this.parent.parent.parent.parent.scrollTo(0, nTop);
	this.parent.parent.parent.scrollTo(0, nTop);
}


/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.form_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	//trace("form_onsize====");
	var nFormHeight = this.staInfoEnd.getOffsetBottom();
	this.parent.setOffsetHeight(nFormHeight);
};

/* 목차에서 이동 */
this.Button_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//trace("this[obj.moveComp] ::: " + this[obj.moveComp] );
	//trace("obj.moveComp] ::: " +obj.moveComp );
	this.fnMovePosition(this[obj.moveComp]);
};

/* 개인정보(열람, 정정·삭제, 처리정지, 동의철회) 요구서 PDF(다운로드) */
this.Button01_00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sBaseUrl= window.location.protocol + "//" + window.location.host;
	system.execBrowser(sBaseUrl + obj.sUrl);
};

/* 위임장 PDF(다운로드) */
this.Button01_00_00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sBaseUrl= window.location.protocol + "//" + window.location.host;
	system.execBrowser(sBaseUrl + obj.sUrl);
};

/* 이의신청서 PDF(다운로드) */
this.Button01_00_00_00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sBaseUrl= window.location.protocol + "//" + window.location.host;
	system.execBrowser(sBaseUrl + obj.sUrl);
};

/* 개인정보파일 검색 (URL 이동)*/
this.Button01_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sUrl = "https://www.privacy.go.kr/front/wcp/dcl/per/personalInfoFileSrhList.do?searchInsttCode=B550629&searchInsttNm=%ED%95%9C%EA%B5%AD%EA%B5%90%EC%9C%A1%ED%95%99%EC%88%A0%EC%A0%95%EB%B3%B4%EC%9B%90&searchPrsnInfoFileNm=";
	system.execBrowser(sUrl);	
};

/* 개인정보파일 및 홈페이지 보기 (화면숨김처리) */
this.Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var nFormHeight = this.getOwnerFrame().form.divAll.form.fv_WorkFormHeight;
	if(this.invlInfoSts){
		this.invlInfoSts = false;
		this.Grid00.setOffsetHeight(0);
		if ( this.objApp.gv_appScreenType == "M" ) { // 모바일
			this.getOwnerFrame().form.divAll.form.divWork.setOffsetHeight(nFormHeight - 168);
		}else {
			this.getOwnerFrame().form.divAll.form.divWork.setOffsetHeight(nFormHeight - 93);
		}
	}else{
		this.invlInfoSts = true;
		if ( this.objApp.gv_appScreenType == "M" ) { // 모바일
			this.Grid00.setOffsetHeight(168);
		}else {
			this.Grid00.setOffsetHeight(93);
		}
	}
	this.resetScroll();
	this.getOwnerFrame().form.divAll.form.resetScroll();
};

