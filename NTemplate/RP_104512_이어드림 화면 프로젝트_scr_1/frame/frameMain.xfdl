//세로 스크롤 (divQuickMenu 위치 이동)
this.divAll_onvscroll = function(obj:nexacro.Div,e:nexacro.ScrollEventInfo)
{
    var nTopGap = 32;   // Top으로부터 떨어진 거리
    
    if(this.divAll.form.divQuickMenu.visible)
    {
        this.divAll.form.divQuickMenu.setOffsetTop(e.pos+nTopGap);
    }
    
            if(typeof(mtk)=="object" && mtk!=null && mtk.now!=null){
                mtk.setPosition();
            }else if(typeof(tk)=="object" && tk!=null && tk.now!=null){
                tk.setPosition();
            }   
};


//가로 스크롤 (divTop 가로스크롤 이동)
this.divAll_onhscroll = function(obj:nexacro.Div,e:nexacro.ScrollEventInfo)
{
    this.divTop.form.fnTopMenuOnhscroll(e.pos);
    this.divNotice.form.fnDivNoticeOnhscroll(e.pos);
};

/**
 * 디지털정부 UI/UX 적용 관련
 * 로그 출력
 */
this.logger = function(){
	if(this.USE_LOGGER){
		var baseLog = this._orgurl.replace(".xfdl","") + " > ";
		trace(baseLog, ...arguments);
	}
