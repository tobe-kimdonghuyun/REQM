/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.btnNotiNew_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var procType = "none";
	
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback : this.fnPopupCallback, // 콜백함수 지정
		sender : obj, // sender 지정
		// 팝업 전달 파라메터 지정
		params : {
			// 처리타입 지정
			procType : procType,
			// 파라메터 전달
			notiScCd : "ALL",
			dataset: this.parent.parent.divPARLink.form.dsStuIduzEduYn
		},
	};
	
	if(this.smfIsMobile()){
		var srcInfo = this.smfCurScreenInfo();
		var srcInfoW = srcInfo[0];
		var srcInfoH = srcInfo[1];
		srcInfoH = 965;
		this.smfDialog("_auto", "pa_par_sps_sl::par_spssl05_p02.xfdl", popupParams, "", "", srcInfoW, srcInfoH);
	}else{
		this.smfDialog("_auto", "pa_par_sps_sl::par_spssl05_p02.xfdl", popupParams);
	}
};

this.btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form.fnHome();
};]]></Script>
    <Objects>
