      </Dataset>
      <Dataset id="dsStuIduzEduYn" useclientlayout="true">
        <ColumnInfo>
          <Column id="shlCd" type="STRING" size="256" description="학교코드"/>
          <Column id="shlNm" type="STRING" size="256" description="유치원명"/>
          <Column id="ayr" type="STRING" size="256" description="학년도"/>
          <Column id="sem" type="STRING" size="256" description="학기"/>
          <Column id="semBgngYmd" type="STRING" size="256" description="학기 시작일자"/>
          <Column id="semEndYmd" type="STRING" size="256" description="학기 종료일자"/>
          <Column id="stuInvlNo" type="STRING" size="256" description="학생번호"/>
          <Column id="stuDtcNo" type="STRING" size="18" description="학생고유번호"/>
          <Column id="stuFlnm" type="STRING" size="256" description="학생이름"/>
          <Column id="clsScCd" type="STRING" size="256" description="학급구분코드"/>
          <Column id="clsScNm" type="STRING" size="256"/>
          <Column id="clsNm" type="STRING" size="256" description="반명"/>
          <Column id="stuClsNo" type="STRING" size="256" description="반번호"/>
          <Column id="acclaNm" type="STRING" size="256" description="담임명"/>
          <Column id="iduzEduYn" type="STRING" size="256" description="개별화교육 수강여부"/>
          <Column id="yearAge" type="STRING" size="256" description="만나이"/>
          <Column id="stuRoadAddr" type="STRING" size="256" description="유아도로명주소"/>
          <Column id="cddcScCd" type="STRING" size="3" description="시도코드"/>
          <Column id="toDay" type="STRING" size="256" description="오늘일자"/>
          <Column id="dayOfWeek" type="STRING" size="256" description="오늘요일"/>
          <Column id="schpaDtcNo" type="STRING" size="256" description="학부모고유번호"/>
          <Column id="startYmd" type="STRING" size="256" description="학년도 시작일자"/>
          <Column id="endYmd" type="STRING" size="256" description="학년도 종료일자"/>
          <Column id="sprtYr" type="STRING" size="4" description="지원연도"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="false">
        <ColumnInfo>
          <Column id="shlCd" type="STRING" size="10" sumtext="" description="학교코드"/>
          <Column id="stuInvlNo" type="STRING" size="10" sumtext="" description="학생개인번호"/>
          <Column id="stuDtcNo" type="STRING" size="18" description="학생고유번호"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsStuAyrList" useclientlayout="true">
        <ColumnInfo>
          <Column id="shlCd" type="STRING" size="256"/>
          <Column id="stuInvlNo" type="STRING" size="256"/>
          <Column id="ayr" type="STRING" size="256"/>
          <Column id="ayrNm" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsPageInfo" useclientlayout="true">
        <ColumnInfo>
          <Column id="pageIndex" type="INT" size="256"/>
          <Column id="pageSize" type="INT" size="256"/>
          <Column id="totalCount" type="INT" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="pageIndex">1</Col>
            <Col id="pageSize">1</Col>
            <Col id="totalCount">0</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
  </Form>
</FDL>
