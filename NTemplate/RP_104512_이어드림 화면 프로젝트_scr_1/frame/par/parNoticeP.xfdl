    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 > 학부모서비스(유) > 신청서 알림
*  @FileName 	par_spssl05_p02
*  @Creator 	문형선
*  @CreateDate 	2022.11.17
*  @Desction    신청서 알림 팝업
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.11.17            문형선                   최초 생성 
*******************************************************************************
*/ 

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
//include "lib::cm_script.xjs";
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{ 
	// 폼을 초기화
	//this.smfInitPopup(obj);
}

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd <= -1) return;
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
//전체선택
this.grdNoti_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
    var columnName = obj.getCellProperty("body",e.cell,"text");
	if ("bind:_chk" == columnName){
		this.smfToggleChkHeader(obj, e);
	}else{
		// 정렬
		this.smfCheckAndSort(obj, e);
	}
};

//닫기
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//오늘 다시 보지 않기
	this.smfSetNoticePopupToday(this.divPop.form.chkOpen.value);
	
	var paramObj = this.dsParam;
	this.smfClose(paramObj);
};

this.form_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.div00.form.grdNoti.set_enableredraw(false);
	
	this.div00.form.grdNoti.set_enableredraw(true);
};


this.chkOpen_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	
};
]]></Script>
    <Objects>
      <Dataset id="dsParam">
        <ColumnInfo>
          <Column id="lnkTypCd" type="STRING" size="256"/>
          <Column id="lnkUrl" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
  </Form>
