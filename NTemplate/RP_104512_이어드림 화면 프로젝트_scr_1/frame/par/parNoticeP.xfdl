          <Layouts>
            <Layout/>
            <Layout name="Layout0">
              <ImageViewer id="imgTitle" height="65" left="0" top="0" width="424"/>
            </Layout>
            <Layout name="default2"/>
          </Layouts>
        </Div>
        <Div id="div00" taborder="1" left="20" top="94" height="439" right="20" initvalueid="ivDivAccessibilityOff" text="팝업 테스트">
          <Layouts>
            <Layout/>
            <Layout name="default2"/>
          </Layouts>
        </Div>
        <Static id="Static99_00_00_00_00_00_00_00" taborder="4" left="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" top="583"/>
        <Button id="btnClose" taborder="2" text="닫기" width="50" height="30" cssclass="btn_WF_Custom" accessibilitylabel="팝업닫기" top="Static99_00_00_00_00_00_00_00:0" onclick="btnClose_onclick" initvalueid="ivBtnAccessibilityButton" left="46.88%"/>
        <CheckBox id="chkOpen" taborder="5" text="오늘 다시보지 않기" width="154" height="30" initvalueid="ivChkNormal" top="Static99_00_00_00_00_00_00_00:0" color="black" onclick="chkOpen_onclick" left="10"/>
      </Layout>
      <Layout width="640" height="901" screenid="mobile,tablet" name="default2" position="" mobileorientation="portrait">
        <Div id="divTitle" taborder="0" left="20" top="70" height="65" text="" right="20" initvalueid="ivDivAccessibilityOff"/>
        <Div id="div00" taborder="2" left="20" top="193" height="412" right="20" cssclass="div_WF_GridBox_M" formscrollbarsize="1"/>
        <Button id="btnClose" taborder="4" text="닫기" width="45.31%" height="80" cssclass="btn_WF_Custom" accessibilitylabel="팝업닫기" top="Static99_00_00_00_00_00_00_00:30" left="20"/>
        <Static id="Static99_00_00_00_00_00_00_00" taborder="8" left="20" height="60" cssclass="sta_GD_Size" text="60" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" top="696"/>
        <CheckBox id="chkOpen" left="20" top="Static99_00_00_00_00_00_00_00:0" width="154" height="30"/>
