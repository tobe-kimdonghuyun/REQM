<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="parNoticeP" width="800" height="663" titletext="알림" onload="form_onload" onsize="form_onsize">
    <Layouts>
      <Layout width="800" height="663" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="3" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
