          <Column id="popupCn" type="string" size="256"/>
          <Column id="comPopupYn" type="STRING" size="256"/>
          <Column id="popupTypCd" type="string" size="256"/>
          <Column id="popupTptCd" type="string" size="256"/>
          <Column id="pstStsCd" type="string" size="256"/>
