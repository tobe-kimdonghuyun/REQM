          <Column id="stuInvlNo" type="STRING" size="10"/>
          <Column id="nttId" type="STRING" size="20"/>
          <Column id="sType" type="STRING" size="1" description="실행타입(1:목록, 2:조회, 3:답변, 4:메인용)"/>
          <Column id="cddcScCd" type="STRING" size="3" description="연계시도코드"/>
          <Column id="schpaDtcNo" type="STRING" size="256" description="학부모고유번호"/>
        </ColumnInfo>
        <Rows>
