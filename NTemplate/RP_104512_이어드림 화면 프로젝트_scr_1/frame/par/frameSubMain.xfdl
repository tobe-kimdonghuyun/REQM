this.grdSchneList_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var procType = "none";
	var sType = "2";
	
	this.dsSearchSchne.copyRow(0, this.dsSearch, 0);

	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback : this.fnPopupCallback, // 콜백함수 지정
		sender : obj, // sender 지정
		// 팝업 전달 파라메터 지정
		params : {
			// 처리타입 지정
			procType	: procType,
			// 파라메터 전달
			dataset 	: this.dsSearchSchne,
			nttId 		: this.dsSchneList.getColumn(e.row, "nttId"),
			sType 		: sType
		},
	};
	
	if(this.smfIsMobile()){
		var srcInfo = this.smfCurScreenInfo();
		var srcInfoW = srcInfo[0];
		var srcInfoH = srcInfo[1];
		this.smfDialog("_auto", "pa_par_sps_sl::par_spssl06_p01.xfdl", popupParams, "", "", srcInfoW, srcInfoH);
	}else{
		this.smfDialog("_auto", "pa_par_sps_sl::par_spssl06_p01.xfdl", popupParams);
	}
};

