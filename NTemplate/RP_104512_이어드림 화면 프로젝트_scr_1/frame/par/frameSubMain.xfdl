          <Column id="aplcnEndYmd" type="string" size="256"/>
          <Column id="aplcnBgngTm" type="STRING" size="256"/>
          <Column id="aplcnEndTm" type="STRING" size="256"/>
          <Column id="expsrSn" type="STRING" size="256"/>
          <Column id="lnkTypCd" type="STRING" size="256"/>
          <Column id="pafrBbsScCd" type="STRING" size="256"/>
          <Column id="pafrBbsId" type="STRING" size="256"/>
          <Column id="popupUrl" type="STRING" size="256"/>
          <Column id="lnkNm" type="STRING" size="256"/>
          <Column id="newinYn" type="STRING" size="256"/>
          <Column id="fileRefrnId" type="STRING" size="256"/>
          <Column id="rplcText" type="STRING" size="256"/>
          <Column id="eventTitlNm" type="STRING" size="256"/>
          <Column id="eventBgngYmd" type="STRING" size="256"/>
          <Column id="eventEndYmd" type="STRING" size="256"/>
          <Column id="eventBgngTm" type="STRING" size="256"/>
          <Column id="eventEndTm" type="STRING" size="256"/>
          <Column id="emrgYn" type="STRING" size="256"/>
          <Column id="jobCn" type="STRING" size="256"/>
          <Column id="haltWrkCn" type="STRING" size="256"/>
          <Column id="useYn" type="STRING" size="256"/>
          <Column id="rgtrNm" type="STRING" size="256"/>
          <Column id="rgtrDptNm" type="STRING" size="256"/>
          <Column id="mdfrNm" type="STRING" size="256"/>
          <Column id="mdfrDptNm" type="STRING" size="256"/>
          <Column id="rgtrId" type="STRING" size="256"/>
          <Column id="regDt" type="STRING" size="256"/>
          <Column id="mdfrId" type="STRING" size="256"/>
          <Column id="mdfcnDt" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    샘플
*  @FileName 	frameSubMain.xfdl
*  @Creator 	정인혁
*  @CreateDate 	2023.1.6
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2023.1.6     	정인혁 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::pam_script.xjs";
include "lib::par_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_workPageParams = {};	//화면전환시 넘길 parameter
this.fv_isMobile;	//모바일로 접속여부
this.fv_device;		//device 종류

this.fv_toDayOfWeek; //오늘 일자 정보
this.fv_objParForm; //유치원 학부모서비스 TOP FORM

this.paramDsList;	//모바일에서 파라메터로 넘길 조회결과
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frameSubMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{	
	this.smfInitForm(this);
	
	this.fv_param = this.smfGetFormParams();

	// 메인 페이지를 보여주기 위한 정보를 표시한다.
	var objMainForminfo = {
						  quickmenu : {
										  use : "N"                      //
										, url : "frame::/ore/frameQuickMenu.xfdl"   //
									  }
						, toplink : {
										  use   : "N"                                 //
										, link  : [                                   // 링크정보(배열)
												   { 
													   title : "원서접수"            //
													 , width : 150                    // 링크버튼의 넓이
													 , url   : "frame::/ore/xxx.xfdl" // 링크하여 이동할 화면의 URL
													}
												   ]
									  }
						, wildmode : "Y"	
						, noticeband : {
										  use   : "N"                 //
										, serviceurl : "/xxxxx.do"    //  
									   }
					  }	
	this.pamfSetMainPageInfo(objMainForminfo);

	if(this.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form.fv_stuLoad){
		this.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form.fnSelectStuIduzEduYn();
 	}
	
};

this.frameSubMain_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnRearrageCenter();
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/ 
//오늘 일정 조회
this.fnSelectAaFx = function()
{
	this.dsSearch.setColumn(0, "aaFxType", "3"); //aaFxType : 3 - 오늘일정
	this.dsAaFxList.clearData(); //연계를 통한 경우 빈dataset을 생성하지 못함. 가비지 데이터를 삭제하기 위해 clearData
 	// 서비스 객체 생성
	this.smfSearchService("selectAaFx")		
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});	
};

//최근 가정통신문 조회
this.fnSearchSchne = function()
{
	this.dsSearch.setColumn(0, "sType", "1"); // 2 : 조회, 1 : 목록, 3 : 답변
	
	if(this.smfIsMobile()){
		this.dsPageInfo.setColumn(0, "pageSize", 3);
	}else{
		this.dsPageInfo.setColumn(0, "pageSize", 4);
	}
 	// 서비스 객체 생성
	this.smfSearchService("selectSchneList")		
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});	
};

//오늘 식단 조회
this.fnSelectToDayDiet = function()
{
	this.dsDietList.clearData(); //연계를 통한 경우 빈dataset을 생성하지 못함. 가비지 데이터를 삭제하기 위해 clearData
	// 서비스 객체 생성
	this.smfSearchService("selectToDayDiet")		
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});	

};

//학생 알러지정보 조회
this.fnSelectStuAgy = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("selectStuAgy")
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});	
};

this.fnSelectSchInfo = function()
{		
 	// 서비스 객체 생성
	this.smfSearchService("selectSchInfo")
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){		
			if(callbackParams.errors) return;
			
			//유치원명			
			var shlNm = this.smfStr(fv_objParForm.dsStuIduzEduYn.getColumn(0, "shlNm"));
			this.div01.form.div00.form.div00_01.form.sta01.set_text(shlNm);
			
			var addr = this.dsInfo.getColumn(0, "roadNmAddr");
			var detailAddr = this.dsInfo.getColumn(0, "roadNmDtailAddr");
			this.div01.form.div00.form.div00_01.form.sta01_00.set_text(addr + "\n" + detailAddr);
			
			if(this.smfIsMobile()){
				this.div01.form.div00.form.div00_01.form.resetScroll();
				//this.smfResetScroll(this.div01.form.div00.form.div00_01.form.sta01);			
			}
			
			var severToday = this.dsInfo.getColumn(0, "severToday");
			
			if(severToday >= '202411150900' && severToday < '202411300000') {
			// 2024년 11월 15일 09시 ~ 2024년 11월 30일 00시
				//팝업 설정
				this.popInfo = {};
				this.popInfo.id = "frameNoticeP";
				this.popInfo.pUrl = "frame::/par/frameNoticeP.xfdl";
				
				this.popInfo.callbackScope = this;
				this.popInfo.callbackFunc = "fnframeNoticeP";
				
				//팝업 데이터셋 설정
				this.dsListPopup.setColumn(0, "popupTypCd", "IMG");
				this.popInfo.dsListPopup =this.dsListPopup;
				this.smfDivPop(this.popInfo);
			}
		});	
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(svcid == "selectAaFx"){
		var event = "";
		if(this.dsAaFxList.getRowCount() > 0){
			for(i = 0; i < this.dsAaFxList.getRowCount(); i++){
				if(i > 0) event += "\n";
				event += this.dsAaFxList.getColumn(i, "event1");
			}
		}else{
			event = "</br></br>조회된 데이터가 없습니다.";
		}
		
		//학사일정 오늘일자
		this.div01.form.div00.form.div00_00.form.sta00.set_text(fv_toDayOfWeek);		
		//오늘 학사일정 SET
		this.div01.form.div00.form.div00_00.form.sta01_00.set_text(event);
	}else if(svcid == "selectLatestSchne"){
		var schnoCn = "";
	
		if(this.dsSchneDetail.getRowCount() > 0){
			//오늘 일자정보를 SET
			var mdfYmd 		= this.dsSchneDetail.getColumn(0, "mdfYmd"); //가정통신문수정-일자
			var mdfYmdWeek 	= this.dsSchneDetail.getColumn(0, "dayOfWeek"); //가정통신문수정-요일
			
			var mdfYmdOfWeek = mdfYmd.substr(0, 4) + "년 " + this.smfLtrim(mdfYmd.substr(4, 2), "0") + "월 " + this.smfLtrim(mdfYmd.substr(6, 2), "0") + "일";
			mdfYmdOfWeek += "(" + mdfYmdWeek + ")";
			
			//가정통신문 내용
			schnoCn = this.smfStr(this.dsSchneDetail.getColumn(0, "nttCn"));
		}else{
			mdfYmdOfWeek = fv_toDayOfWeek;
			schnoCn = "</br></br>조회된 데이터가 없습니다.";
		}
		//최근 가정통신문 일자
		this.div01.form.div00.form.div00_00_00_00.form.sta00.set_text(mdfYmdOfWeek);
		//가정통신문 내용
		this.div01.form.div00.form.div00_00_00_00.form.sta01_00.set_text(schnoCn);
	}else if(svcid == "selectToDayDiet"){
		//식단내용
		if(this.dsDietList.getRowCount() > 0){
			var dietNm = this.fnDiteText(this.dsDietList.getColumn(0, "dietNm"));
					
			this.div01.form.div00.form.div00_00_00.form.staDiet.set_text(dietNm);
		}else{
			this.div01.form.div00.form.div00_00_00.form.staDiet.set_text("</br></br>조회된 데이터가 없습니다.");
		}
	}else if(svcid == "selectStuAgy"){//알레르기 정보
		this.fnSelectToDayDiet();
	}
}
/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){

};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 // Form의 검색영역 초기화처리 후 자료조회 TRANSACTION 서비스 호출.
this.fnFormInit = function(){
	//유아정보에서 검색조건을 복사한다.
	fv_objParForm = this.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form;
//trace(fv_objParForm.dsStuIduzEduYn.saveXML());
//	if(this.smfIsNull(fv_objParForm.dsStuIduzEduYn.getColumn(0, "stuInvlNo"))){
//		fv_objParForm.dsStuIduzEduYn.setColumn(0, "stuInvlNo", 	"TTT3686004");
//	}
//	if(this.smfIsNull(fv_objParForm.dsStuIduzEduYn.getColumn(0, "ayr"))){
//		fv_objParForm.dsStuIduzEduYn.setColumn(0, "ayr", 	"2024");
//	}
	this.dsSearch.copyRow(0, fv_objParForm.dsStuIduzEduYn, 0);

	//소재정보, 개인번호 체크
	var validate = this.parfValidate(this.dsSearch);	
	if(validate){		
		//학교정보 조회
		this.fnSelectSchInfo();
	
		//자녀정보 SET
		this.fnSetChildInfo();
		
		//오늘의 일정 조회
		this.fnSelectAaFx();
		
		//최근 가정통신문 조회
		this.fnSearchSchne();
	}
	
	//오늘 일자정보를 SET
	toDay 		= fv_objParForm.dsStuIduzEduYn.getColumn(0, "toDay"); //오늘-일자
	dayOfWeek 	= fv_objParForm.dsStuIduzEduYn.getColumn(0, "dayOfWeek"); //오늘-요일
	
	//fv_toDayOfWeek = toDay.substr(0, 4) + "년 " + this.smfLtrim(toDay.substr(4, 2), "0") + "월 " + this.smfLtrim(toDay.substr(6, 2), "0") + "일";
	fv_toDayOfWeek = this.smfLtrim(toDay.substr(4, 2), "0") + "월 " + this.smfLtrim(toDay.substr(6, 2), "0") + "일";
	fv_toDayOfWeek += "(" + dayOfWeek + ")";
	
	//오늘의식단 오늘일자
	this.div01.form.div00.form.div00_00_00.form.sta00.set_text(fv_toDayOfWeek);
	
	//오늘 식단 조회조건 설정
	this.dsSearch.setColumn(0, "mlsvYmd", 		toDay);									//급식년월일
	this.dsSearch.setColumn(0, "mlsvInqScCd", 	"3"); 									//급식조회구분코드(1 월간 2 주간 3 일간)
	this.dsSearch.setColumn(0, "mmealScCd", 	"2");									//식사구분코드(1 조식 2 중식 3 석식, 파라미터가 널일 경우 기본값 중식(2) 설정)
	this.dsSearch.setColumn(0, "wlkMntlyScCd", 	"tday"); 								//tday : 당일조회
	this.dsSearch.setColumn(0, "instCd", 		this.dsSearch.getColumn(0, "shlCd"));
	this.dsSearch.setColumn(0, "userId", 		fv_objParForm.dsStuIduzEduYn.getColumn(0, "schpaDtcNo"));
	
	//유아 알레르기 조회
	this.fnSelectStuAgy();
	
	//공지사항 조회
	this.fnNoticeInfo();
}

this.fnRearrageCenter = function()
{
	// 모바일
	if(this.smfIsMobile())
	{
		this.smfResetScroll(this);
	}
	// 데스크탑
	else
	{
		var nWidth = this.getOffsetWidth();
		if(nWidth > 1200)
		{
			var nLeftGap = parseInt((nWidth-1200)/2);
			
			// 가운데 정렬 처리를 한다.
			this.div01.setOffsetLeft(nLeftGap);
			this.smfResetScroll(this);
		}	
	}
}
/**
 * 하단의 링크에 의한 ㄷ이동처리를 한다 
 * @param : objDs - 정보를 가진 데이터셋 오브젝트
 */ 
this.fnRedirectFuncLink = function(obj)
{
	var sUrl = "";
	var sMessage = "";
	var sCddcCd = this.smfGetCddcCode();

	switch(obj._linkNo)
	{
		case "100" :    // 유치원생활기록부
			sUrl = 'pa_par_sps_ci::par_spsci00_m00.xfdl';
			//sMessage = "유치원 생활기록은 2024년 3월 서비스 예정입니다.";
			break;
	
		case "200" :    // 유아건강기록
			sUrl = 'pa_par_sps_ih::par_spsih00_m00.xfdl';
			//sMessage = "건강기록은 2024년 3월 서비스 예정입니다.";
			break;
			
		case "300" :   // 교외학습체험
			sUrl = 'pa_par_sps_sl::par_spssl05_m00.xfdl';
			break;
		
		case "400" :    // 복지서비스 자격신청 방법
			sUrl = 'pa_par_sps_se::par_spsse01_m00.xfdl';
			break;
			
		case "500" :    // 유아학비카드인증
			sUrl = 'pa_par_sps_pc::par_spspc00_m00.xfdl';
			//sMessage = "국민행복카드 인증은 2024년 3월 서비스 예정입니다.";
			break;
	
		case "600" :    /// 유아학비학부모청구
			sUrl = 'pa_par_sps_pc::par_spspc01_m00.xfdl';
			//sMessage = "유아학비 학부모 청구는 2024년 3월 서비스 예정입니다.";
			break;
			
		case "700" :    /// 월간일정
			sUrl = 'pa_par_sps_sl::par_spssl02_m01.xfdl';
			break;
			
		case "800" :    /// 주간식단
			sUrl = 'pa_par_sps_sl::par_spssl03_m01.xfdl';
			break;
			
		case "900" :    /// 가정통신문
			sUrl = 'pa_par_sps_sl::par_spssl06_m00.xfdl';
			break;
		case "1000" :    
			sUrl = 'pa_par_sps_cm::par_spscm00_m00.xfdl';
			break;
	}	
	
	var params = {
					
				 };
				 
	// 개발용 메세지(추후 삭제필요)
	if(this.smfIsNull(sUrl))
	{
		this.smfAlert(sMessage);
		return;
	}
				 
	this.smfSetWorkPage(sUrl, params);  //자주묻는질문 세번째 탭으로 이동
	
}

//자녀정보 설정
this.fnSetChildInfo = function(){
	//이름 설정
	var stuNm = fv_objParForm.cboStuList.text;
	this.div01.form.div00.form.div00.form.sta01.set_text(stuNm);
	
	//유치원명, 반명, 담임명
	var dsStuInfo = fv_objParForm.dsStuIduzEduYn;
	
	var clsNm =  this.smfStr(dsStuInfo.getColumn(0, "clsNm"));
	var stuClsNo = this.smfStr(dsStuInfo.getColumn(0, "stuClsNo")) + "번";
	
// 	if(!this.smfIsNull(dsStuInfo.getColumn(0, "acclaNm"))){
// 		stuInfoText += "\n" + this.smfStr(dsStuInfo.getColumn(0, "acclaNm")) + " 선생님";
// 	}
	
	//반명
	this.div01.form.div00.form.div00.form.sta01_00.set_text(clsNm + " " + stuClsNo);
}

this.fnDisplayText = function(obj,nCell,nRow,sLongText,sImptYn)
{
	var sFont = this.smfIsMobile() ? 'normal 400 28px/normal "Noto Sans KR","NotoSansKR-Regular"':'normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular"';
	var nPadding = this.smfIsMobile() ? 10:20;

//div01.form.div02.form.div00_00_00_00.form.grdNoticeList
//div01.form.div02.form.div00_00_00_00_00.form.grdQnaList
//expr:comp.parent.parent.parent.parent.parent.parent.parent.fnDisplayText(comp, 1, currow, faqTitlNm, "", 20)
//expr:imptYn == 'Y' ? comp.parent.parent.parent.parent.parent.parent.parent.fnDisplayText(comp, 0, currow, ntcMteTitlNm, "", 80) : comp.parent.parent.parent.parent.parent.parent.parent.smfDispLongTextGrid(comp, 0, currow, ntcMteTitlNm)
		if(sImptYn=="Y") nPadding += 110;

	return this.smfDispLongTextGrid(obj,nCell,nRow,sLongText,sFont,nPadding);
}; 

this.fnframeNoticeP = function( pObj )
{
	if ( pObj instanceof nexacro.NormalDataset ){
		if(pObj.rowcount > 0){
			//var vLnkTypCd = pObj.getColumn(0,"lnkTypCd");
			//var vLnkUrl = pObj.getColumn(0,"lnkUrl");
			var vLnkTypCd = 1;
			var vLnkUrl = pObj.getColumn(0,"lnkUrl");
			
			this.fnLinkPrcs(vLnkTypCd, vLnkUrl);
		}
	}
};

this.fnLinkPrcs = function(lnkTypCd, lnkUrl){
	if(lnkTypCd == 1){ //url 링크
		this.smfSetServiceLink(lnkUrl,"redirect");		//해당 url로 이동
		
	}else{		//게시물 링크
		var vBbsScCd = lnkUrl.substring(0,3);	//게시물 ID 앞 3자리가 게시판 코드
		var params = {pafrBbsId:lnkUrl};	
		
		switch(vBbsScCd)
		{
			case "NTC": // 공지사항 
				this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn00_m02.xfdl", "open", params);
				break;
			case "FAQ": // 자주묻는질문 TO-DO 목록으로 되어 있어서 어떻게 처리할지 고민 필요!!!
				this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn01_m01.xfdl");
				break;
			case "PUB": // 공모전
				this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn03_m03.xfdl", "open", params);
				break;
			case "EVT": // 이벤트
				this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn03_m02.xfdl", "open", params);
				break;
		}
	}
}

