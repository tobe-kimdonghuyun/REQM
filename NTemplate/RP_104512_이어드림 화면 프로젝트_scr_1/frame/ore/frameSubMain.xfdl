    <Objects>
      <Dataset id="ds00">
        <ColumnInfo>
          <Column id="공지" type="STRING" size="256"/>
          <Column id="전화번호" type="STRING" size="256"/>
          <Column id="날짜" type="STRING" size="256"/>
        </ColumnInfo>
