// 하단 공지 자세히 보기
this.divBottomNotice_staNoticeText_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	// 공지 상세 내용 페이지로 보낼 파라미터 설정
	var sNtcMteId = this.dsListBottomNotice.getColumn(bottomIndex, "ntcMteId");
	var sNtcMteClfCd = this.dsListBottomNotice.getColumn(bottomIndex, "ntcMteClfCd");
	var sAppoExamScCd = this.smfGetAppoExamScCd();
	var sMenuId;
	
	// 임용코드에 따라 메뉴id가 달라 각 조건에 맞게 설정
	if(this.smfGetAppoExamScCd() == 1 || this.smfGetAppoExamScCd() == 2 || this.smfGetAppoExamScCd() == 3) {
		sMenuId = "6000";	// 유초등, 중등, 지방공무원은 공지사항 menuId "6000"
	}
	if(this.smfGetAppoExamScCd() == 4) {
		sMenuId = "8000";	// 지방공무원은 "8000"
	}
	if(this.smfGetAppoExamScCd() == 5) {
		sMenuId = "5000";	// 계약제교원은 "5000"
	}
	
	var params = {
			ntcMteId : sNtcMteId,
			ntcMteClfCd : sNtcMteClfCd,
			appoExamScCd : sAppoExamScCd,
			menuId : sMenuId	//공지 메뉴id 파라미터 설정
			};
			
	this.smfSetWorkPage("pa_ore_oew_bd::ore_oewbd00_m01.xfdl", params); //상세내용 페이지로 넘기기
};

// 공고 제목 클릭 시 팝업
this.ntc_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{


	// 공지 상세 내용 페이지로 보낼 파라미터 설정
	var sNtcMteId = this.dsListTopNotice.getColumn(e.row, "ntcMteId");
	var sNtcMteClfCd = this.dsListTopNotice.getColumn(e.row, "ntcMteClfCd");
	var sAppoExamScCd = this.smfGetAppoExamScCd();
	var sMenuId;
	
	// 임용코드에 따라 메뉴id가 달라 각 조건에 맞게 설정
	if(this.smfGetAppoExamScCd() == 1 || this.smfGetAppoExamScCd() == 2 || this.smfGetAppoExamScCd() == 3) {
		sMenuId = "6000";	// 유초등, 중등, 지방공무원은 공지사항 menuId "6000"
	}
	if(this.smfGetAppoExamScCd() == 4) {
		sMenuId = "8000";	// 지방공무원은 "8000"
	}
	if(this.smfGetAppoExamScCd() == 5) {
		sMenuId = "5000";	// 계약제교원은 "5000"
	}
	
	var params = {
			ntcMteId : sNtcMteId,
			ntcMteClfCd : sNtcMteClfCd,
			appoExamScCd : sAppoExamScCd,
			menuId : sMenuId	//공지 메뉴id 파라미터 설정
			};
			
	this.smfSetWorkPage("pa_ore_oew_bd::ore_oewbd00_m01.xfdl", params); //상세내용 페이지로 넘기기
	
	
	// TODO: 팝업으로 공고 내용 보이게
	
// 	this.popInfo = {};
// 	this.popInfo.id = "oreNotice";
// 	this.popInfo.pUrl = "pa_ore_oew_bd::oreNotice.xfdl";
// 	this.popInfo.callbackScope = this;
// 	this.popInfo.callbackFunc = "fncommNoticeAll";
	
		// 클릭한 셀을 구한다
	var nRow = e.row;
	var nCell = e.cell;
	if(nCell == 0) // 제목
	{
		var objDs = obj.getBindDataset();
		
		// 데이터셋 파라미터 세팅
		var sNtcMteId = objDs.getColumn(nRow,"ntcMteId"); // 게시물 ID
		var sNtcMteClfCd = objDs.getColumn(nRow,"ntcMteClfCd"); // 공지사항분류코드
		var sNtcMteTitlNm = objDs.getColumn(nRow,"ntcMteTitlNm"); //제목
		var sNtcMteCn = objDs.getColumn(nRow,"ntcMteCn");	// 내용
		var sCddcCd = objDs.getColumn(nRow, "cddcCd") + "0000001";	// 시도교육청코드
		var sFileId = objDs.getColumn(nRow, "fileRefrnId"); // 파일참조ID
 		var sAppoExamScCd = objDs.getColumn(nRow,"appoExamScCd");

// 		var params = {
// 				eventTitlNm : sNtcMteTitlNm,
// 				popupCn : sNtcMteCn
// 			};

		var popupParams = {
			callback: this.fnPopupNotice, // 콜백함수 지정
			sender: obj, // sender 지정
			titlebar:false,  // 타이틀바를 표시하지 않는다.
			// 팝업 전달 파라메터 지정
			params: {
				// 처리타입 지정(필수)
				procType : "none",  // "none","search","insert","update","delete"
				// 파라메터 전달
				eventTitlNm : sNtcMteTitlNm,
				popupCn : sNtcMteCn,
				fileRefrnId : sFileId,
				ntcMteId : sNtcMteId,
				ntcMteClfCd : sNtcMteClfCd,
				cddcCd : sCddcCd,
				appoExamScCd : sAppoExamScCd
				}
			};				
		/*this.smfSetWorkPage("pa_ore_oew_bd::oreNotice.xfdl", params);*/
		
		// 팝업 실행
		this.smfDialog("_auto", "pa_ore_oew_bd::oreNoticeFrame.xfdl", popupParams);
	}
};
