    <Script type="xscript5.1"><![CDATA[/**
*  교육디지털 원패스
*  @MenuPath    frame > frameMain
*  @FileName 	frameMain.xfdl 
*  @Creator 	kmp
*  @CreateDate 	2021.12.27
*  @Desction    base가 되는 화면
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
*  2021.12.27     		kmp		 	  			최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::pam_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_workPageParams = {};	//화면전환시 넘길 parameter
this.fv_isMobile;	//모바일로 접속여부
this.fv_device;		//device 종류
var objMainForminfo;
var bannerIndex = 0; // 배너 공고 인덱스
var bottomIndex = 0; //하단 공지 인덱스
var cddcName = this.smfGetCddcName();
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 
/**
 * 화면 onload시 처리내역
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{	
	this.smfInitForm(this);
	//pbancNtcScCd 
	//pbancNtcDtlCd
	this.fv_param = this.smfGetFormParams();
	this.divPageSummary.form.fnSetInitPageSize(5);
	this.divPageSummaryBotton.form.fnSetInitPageSize(5);
	
	// 로딩시 상단 배너 교육청 이름 세팅
	//this.div03.form.divTopNotice.form.staCddcNm.set_text(cddcName);
	// 로딩시 상담센터 교육청 이름 세팅
	this.divTelInfo.form.staCddcName.set_text("<fc v='#038667'>" + cddcName + "</fc> 상담센터");
	
	var quickUse = "N";	//퀵메뉴 사용여부 변수
	
	if(this.smfGetAppoExamScCd() != "5") {	//계약제인력풀은 퀵메뉴 사용하지 않음
		quickUse = "Y";
	}
// 	var objForm = nexacro.getApplication().mainframe.VFrameSet.frameMain.form;
// 	objForm.fnResizeQuickMenu();
	// 메인 페이지를 보여주기 위한 정보를 표시한다.
	objMainForminfo = {
						  quickmenu : {
										  use : quickUse                      // 퀵메뉴 사용여부 변수로 처리
										, url : "frame::/ore/frameQuickMenu.xfdl"   //
									  }
						, toplink : {
										  use   : "Y"                                 //
										, link  : [                                   // 링크정보(배열)
												   { 
													   title : "공고자세히보기"            //
													 , width : 150                    // 링크버튼의 넓이
													 , url   : "pa_ore_oew_bd::ore_oewbd00_m01.xfdl" // 링크하여 이동할 화면의 URL
													}
												   ]
									  }
						, wildmode : "N"
						, noticeband : {
										  use   : "N"                 //
										, serviceurl : "/xxxxx.do"    //  
									   }						
					  }	
	/*this.pamfSetMainPageInfo(objMainForminfo);*/

	//팝업 설정
  	this.popInfo = {};
  	this.popInfo.id = "commNoticeAll";
  	this.popInfo.pUrl = "frame::bdm/commNoticeAll.xfdl"; //bdm에서 관리하는 팝업공지를 따라감
  	this.popInfo.callbackScope = this;
  	this.popInfo.callbackFunc = "fncommNoticeAll";
	
	
	
	// @KBR divmargin 80
	this.parent.divmargin = 80;	
	
	this.fnRearrageCenter();
	
	// Form의 검색영역 초기화처리를 한다.
	this.fnFormInit();
	//공고 타이틀 설정
	this.fnSetTitle ();
	// 상담센터 웹에디터 초기화
	this.divTelInfo.form.divCddcInfoWebEditor.form.fnInit(this,this.fnWebEditorCallback,this.fnWebEditorSetHtmlCallback);
	
	// 개인정보 보유기간 5년 데이터 삭제
// 	if(this.smfGetAppoExamScCd() == "5") {	//계약제인력풀
// 		this.fnDelPast5YDt();
// 	}
	
};
/**
* 개인정보 보유기간 5년 데이터 삭제
*/
// this.fnDelPast5YDt = function ()
// {
// 	this.smfDeleteService("deletePast5YDt")
// 		// 메세지 표시 여부
// 		.showConfirm(false)
// 		// 실행
// 		.run()
// 		// 콜백
// 		.callback(function(callbackParams){
// 			if(callbackParams.errors) return;
// 			
// 		});
// };
this.fnFormInit = function()
{
	//계약제교원 인력풀일 경우
	if(this.smfGetAppoExamScCd() == "5"){
		this.divLink.form.btnRedirect00.set_text("모집분야");
		this.divLink.form.btnRedirect04.set_text("신청서 작성방법");
		this.divLink.form.btnRedirect01.set_text("증빙서류");
		this.divLink.form.btnRedirect05.set_text("표준근로계약서");
	}
	
	// Form의 검색영역 초기화처리를 한다.(바인딩된 것)
	// 메인 배너 공고 dsSearch setColumn
	// 시도교육청 코드 
	this.dsSearch.setColumn(0,"cddcCd",  this.smfGetCddcCode());
	this.dsSearch.setColumn(0,"appoExamScCd", this.smfGetAppoExamScCd());
	
	// 임용코드 5번은 HRD, 나머지는 ORE
	if (this.smfGetAppoExamScCd() == "5") {
		this.dsSearch.setColumn(0,"pafrSysClfCd", "HRD");
		this.dsSearch.setColumn(0,"topClfCd", "51");
		this.dsSearch.setColumn(0,"botClfCd", "50");
		this.dsSearch.setColumn(0,"rprsClfCd", "52");
	} else {
		this.dsSearch.setColumn(0,"pafrSysClfCd", "ORE");
		this.dsSearch.setColumn(0,"topClfCd", "31");
		this.dsSearch.setColumn(0,"botClfCd", "30");
		this.dsSearch.setColumn(0,"rprsClfCd", "33");
	}
	
	// 임용코드에 따라 각 코드에 맞는 게시물 코드를 set하도록 함
// 	if (this.smfGetAppoExamScCd() != "5") {
// 		this.dsSearch.setColumn(0,"topClfCd", "31");
// 		this.dsSearch.setColumn(0,"botClfCd", "30");
// 	} else if (this.smfGetAppoExamScCd() == "5") {
// 		this.dsSearch.setColumn(0,"topClfCd", "51");
// 		this.dsSearch.setColumn(0,"botClfCd", "50");
// 	}
	
	/*this.fnRefreshCddcInfo();*/
};
//	공지사항, 임용/채용공고 제목 설정
this.fnSetTitle = function()
{
	
	var appoExamScCd = this.smfGetAppoExamScCd();
	
	if(appoExamScCd == "1" || appoExamScCd == "2" || appoExamScCd == "3"){
		this.staNotTitle.set_text("임용공고");
	}else if(appoExamScCd == "4"){
		this.staNotTitle.set_text("채용공고");
	}else if(appoExamScCd == "5"){
		this.staNotTitle.set_text("모집공고");
	}else{
		this.staNotTitle.set_text("공고");
	}
	
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 this.fnSearchMain = function(obj, e){

	if(!this.smfIsNull(this.smfGetCddcCode())){

	/*this.fnSetData(); //메인화면 문구 및 공지사항 셋팅*/
	
	this.dsSearch.setColumn(0,"cddcCd",  this.smfGetCddcCode());
		// 서비스 객체 생성
	this.smfSearchService("selectMainList") 
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			
			
			
			// 페이지 데이터 세팅
			this.pamfSetMainPageInfo(objMainForminfo);
			//this.divTelInfo.set_tooltiptext(this.dsRprsInfo.getColumn(0, "rprsTime"));
			
			this.fnOreHrdSessionChk(); // 세션체크
			
			var objQuickMenu = this.getOwnerFrame().form.divAll.form.divQuickMenu;
			if(objQuickMenu && objQuickMenu.form.fv_isLoaded == "Y")	//퀵메뉴 세팅
			{
				objQuickMenu.form.fnSetQuickMenu();
			}
			
			//this.fnSetDots();	// 공지 / 공고 갯수 표시 점 갯수 세팅			
			this.fnSetPopup();	// 팝업 세팅
			this.fnRprsTelno();	// 교육청 이름, 상담센터 세팅
			
			this.fnSearchTop();
			this.fnSearchBotton();
		});
	} 	
};

this.fnSearchTop = function(obj, e){

	if(!this.smfIsNull(this.smfGetCddcCode())){
	//this.divPageSummary.form.cboPageSize.set_innerdataset(this.dsPageCombo);
	//this.divPageSummary.form.cboPageSize.set_codecolumn("codecolumn");
	//this.divPageSummary.form.cboPageSize.set_datacolumn("datacolumn");
	
	
		// 서비스 객체 생성
	this.smfSearchService("selectTopNotice") 
		// 페이지네이션
		.paginator(this.divGrid.form.grd00, this.divPaginator, this.divPageSummary, 
					this.dsPageInfoTop, this.fnSearchTop, e)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.dsListTopNotice.getRowCount() < 1){
				this.divPaginator.set_visible(false);
			}else{
				this.divPaginator.set_visible(true);
			}
		});
	} 	
};

this.fnSearchBotton = function(obj, e){

	if(!this.smfIsNull(this.smfGetCddcCode())){
	
		// 서비스 객체 생성
	this.smfSearchService("selectBottonNotice") 
		// 페이지네이션
		.paginator(this.divGridBotton.form.grd00, this.divPaginatorBotton, this.divPageSummaryBotton, 
					this.dsPageInfoBotton, this.fnSearchBotton, e)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.dsListBottomNotice.getRowCount() < 1){
				this.divPaginatorBotton.set_visible(false);
			}else{
				this.divPaginatorBotton.set_visible(true);
			}
	
		});
	} 	
};


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/ 
 this.fnTransCallback = function(svcid,errcd,errmsg)
{

}
this.fnPopupNotice = function(e, sender)
{
	
};
/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){

};

/**
 * 상담센터 웹에디터콜백
 */
this.fnWebEditorCallback = function(obj)
{
	this.fnSearchMain();
};

/**
 * 상담센터 웹에디터 SET 콜백
 */
this.fnWebEditorSetHtmlCallback = function(obj,contentHeight)
{
	trace("***  웹에디터에 Text를 세팅했습니다.["+obj.id+"] contentHeight[=" + contentHeight + "]");
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnRearrageCenter = function()
{
	return true;
	// 모바일
	if(this.smfIsMobile())
	{

	}
	// 데스크탑
	else
	{
		var nWidth = this.getOffsetWidth();
		if(nWidth > 1200)
		{
			var nLeftGap = parseInt((nWidth-1200)/2);
			
			// 이미지를 조정한다.
			var nImageWidth = nWidth - 230; // 190: right gap
			if(nImageWidth<(nLeftGap+1200)) nImageWidth = nLeftGap+1200;
			else if(nImageWidth<1200) nImageWidth = 1200;
			
			this.div03.setOffsetWidth(nImageWidth);
			
			// 가운데 정렬 처리를 한다.
			//this.div03.form.divTopNotice.setOffsetLeft(nLeftGap);
			
			
			this.divLink.setOffsetLeft(nLeftGap);
			
			//this.smfResetScroll(this.div03.form.divTopNotice.form);
		}	
	}
};

this.fnRefreshCddcInfo = function()
{

	var sCddcCd = this.smfNvl(this.smfGetCddcCode(),"");  // 교육청코드를 가져온다.(없으면,서울교육청)
	// 값이 없으면 처리를 중단(혹시나 해서...)
	if(this.smfIsNull(sCddcCd)) return;
	
	// 담당자정보를 가져온다.
	// Form의 검색영역 초기화처리를 한다.(바인딩된 것)
	this.dsSearch.setColumn(0,"cddcCd", sCddcCd);  // sCddcCd
	
	/*this.div03.form.divTopNotice.form.staCddcNm.set_text(cddcName);*/
};

this.fncommNoticeAll = function( pObj )
{
	if ( pObj instanceof nexacro.NormalDataset ){
		
		if(pObj.rowcount > 0){
			var vLnkTypCd = pObj.getColumn(0,"lnkTypCd");
			var vLnkUrl = pObj.getColumn(0,"lnkUrl");
			
			this.fnLinkPrcs(vLnkTypCd, vLnkUrl);
		}
	}
};

this.fnLinkPrcs = function(lnkTypCd, lnkUrl){
	
	if(lnkTypCd == 1){ //url 링크
		this.smfSetServiceLink(lnkUrl,"redirect");		//해당 url로 이동
		
	}else{		//게시물 링크
		var vBbsScCd = lnkUrl.substring(0,3);	//게시물 ID 앞 3자리가 게시판 코드
		var params = {pafrBbsId:lnkUrl};	
		
		switch(vBbsScCd)
		{
			case "NTC": // 공지사항 
				this.smfSetServiceLink("pa_ore_oew_bd::ore_oewbd00_m00.xfdl", "open", params);
				break;
			case "FAQ": // 자주묻는질문 TO-DO 목록으로 되어 있어서 어떻게 처리할지 고민 필요!!!
				this.smfSetServiceLink("pa_ore_oew_bd::ore_oewbd02_m00.xfdl");
				break;
		}
	}
};

/**
 * 담당자 전화번호를 세팅한다
 * @param : objDs - 정보를 가진 데이터셋 오브젝트
 */ 
this.fnRprsTelno = function(objDs)	// 배너 교육청 이름, 하단 상담센터 정보 세팅
{
	// 상단 배너 교육청 이름 세팅
	/*this.div03.form.divTopNotice.form.staCddcNm.set_text(cddcName);*/
	
	/*this.divTelInfo.form.staCddcName.set_text("<fc v='#038667'>" + cddcName + "</fc> 상담센터");*/
	this.divTelInfo.form.staMeqTelno.set_text(this.dsRprsInfo.getColumn(0, "rprsTel"));
	// 에디터 값 static에 표시 할경우 특수문자가 표시 됨.
	// 에디터(비표시)에 값 세팅후 이너 텍스트를 static에 set
	// this.divTelInfo.form.staCddcInfo.set_text(this.dsRprsInfo.getColumn(0, "rprsTime"));
	// 웹에디터셋
	
	/*this.divTelInfo.form.divCddcInfoWebEditor.form.fnInit(this, this.fnWebEditorCallback, this.fnWebEditorSetHtmlCallback)*/
	
	this.divTelInfo.form.divCddcInfoWebEditor.form.fnSetHtml(this.dsRprsInfo.getColumn(0,"rprsTime"));
	// 웹에디터에서 Preview inner Text
	var previewTxt =  this.divTelInfo.form.divCddcInfoWebEditor.form.fnGetInnerText();
	// 웹에디터 숨김
	this.divTelInfo.form.divCddcInfoWebEditor.set_visible(false);
	// 상담센터 전화번호
	this.divTelInfo.form.staCddcInfo.set_text(previewTxt);
	// 상담센터 tooltip set
	this.divTelInfo.form.staCddcInfo.set_tooltiptext(previewTxt);
	this.divTelInfo.form.staCddcInfo.set_accessibilitydescription(previewTxt);
	/*
	유지관리 상담센터 번호 표시 2024.09.
	nexacro.getApplication().mainframe.VFrameSet.frameMain.form.divAll.form.divBottom.form.divBottom.form.set_visible("false");//20240716 고객요청사항(2차 기능개선 목록 2-01 항목)
	*/
};

/**
 * 하단의 링크에 의한 ㄷ이동처리를 한다 
 * @param : objDs - 정보를 가진 데이터셋 오브젝트
 */ 
this.fnRedirectFuncLink = function(obj)
{
	var sUrl = "pa_ore_oew_bd::ore_oewbd02_m00.xfdl"; 
	var sCddcCd = this.smfGetCddcCode();
	var sIndex = 0;
	var sExamScd = this.smfGetAppoExamScCd() ;
	switch(obj._linkNo)
	{
		case "100" :    // 원서접수 안내
			sIndex = '0';
			break;
		case "200" :    // 수험표 출력안내
			sIndex = '2';
			if(sExamScd == "5") sIndex = '1';
			break;
		case "300" :     // 합격자발표안내  
			sIndex = '3';
			if(sExamScd == "5") sIndex = '2';
			break;
		case "400" :    // 임용(채용)후보자 안내 
			sIndex = '4';
			if(sExamScd == "5") sIndex = '3';
			break;
	}	
	var params = {
					cddcCd        : sCddcCd
				 ,  sIndex        : sIndex
				 };
			 
	this.smfSetWorkPage(sUrl, params);  //자주묻는질문 세번째 탭으로 이동
	
};

/**
* 체용포털 세션 체크 : 프론트 로그아웃 상태에서 서버 세션이 있으면 로그인처리
*/
this.fnOreHrdSessionChk = function()
{

	// 서버 세션이 있을경우
	if(this.dsOreHrdSession.getRowCount() >0) {
		// 선택 시도 교육청코드
		this.dsOreHrdSession.setColumn(0, 'cddcCd', this.smfGetCddcCode());
		// 선택 시도교육청명
		this.dsOreHrdSession.setColumn(0, 'cddcNm', this.smfGetCddcName());
		// 선택 임용시험구분코드
		this.dsOreHrdSession.setColumn(0, 'appoExamScCd', this.smfGetAppoExamScCd());
		// 클라이언트세션 SET
		this.smfSetSessionDataset(this.dsOreHrdSession); 
		
		// 서버세션이 있는경우 강제로그인	
		if(!this.smfIsLogin()){
			console.log("서버세션있음 : 로그인");
			// 로그인 상태 SET
			this.smfSetLoginState(true);
			// 세션타임과 로그아웃 버튼 설정
			this.getOwnerFrame().form.divTop.form.fnLoginAfter();
		}
		
	}else{
		// 서버 세션이 없는 상태에서 로그인 상태의 경우
		if(this.smfIsLogin()){
			console.log("서버세션없음 : 로그아웃");
			// 글로벌 변수 로그인 여부 수정
			this.smfSetLoginState(false);
			// 세션타임과 로그아웃 버튼 설정
			this.getOwnerFrame().form.divTop.form.fnLogoutAfter();
		}
	}
	//console.log(this.dsOreHrdSession.saveJSON());
	
}

// 배너 부분 점 표시 갯수를 공고 데이터 갯수 만큼 보이게
this.fnSetDots = function(objDs)
{
	var topCount = this.dsListTopNotice.getRowCount();
	var botCount = this.dsListBottomNotice.getRowCount();
	//var topArr = this.div03.form.divTopNotice.form.divBtn.form.components;
	

	if(topCount < 5) {
		for (var i = topCount; i < 5 ; i++) {
			topArr[i].set_visible(false);
		}
	}

		// 하단 공지 점들은 onclick과 공통이 부딪혀서 제대로 작동 안 하는 것 같음.
// 		if(botCount < 5) {
// 		for (var i = botCount; i < 5 ; i++) {
// 			botArr[i].set_visible(false);
// 		}
// 	}
}

this.fnSetPopup = function(objDs)
{
	for(var i = 0; i < this.dsListPopup.getRowCount(); i++) {
		if(this.dsListPopup.getColumn(i, "popupTypCd") == "TMP" && this.dsListPopup.getColumn(i, "popupTptCd") == "01") {
			this.dsListPopup.setColumn(i, "popupTptCd", "02");
		}		
		this.dsListPopup.setColumn(i, "lnkTypCd", "0");
	}
		
		if(this.dsListPopup.getCount() > 0){
			this.popInfo.dsListPopup = this.dsListPopup;
			this.smfDivPop(this.popInfo);
		}
}
