    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    샘플
*  @FileName 	frameFirstMain.xfdl
*  @Creator 	정인혁
*  @CreateDate 	2022.11.11
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.11.11     	정인혁 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::pam_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_workPageParams = {};	//화면전환시 넘길 parameter
this.fv_isMobile;	//모바일로 접속여부
this.fv_device;		//device 종류


this.fv_SelSubSystemCd       = "";
this.fv_SelSubSystemTypeCd   = "";
this.fv_SelSubSystemTypeName = ""; 
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frameFirstMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitForm(this);
	
	// 모바일인 경우, 다른 화면으로 이동을 시킨다.
	if(this.smfIsMobile())
	{
		var sMsg = "온라인 교직원 채용은 모바일을 지원하지 않습니다. PC에서 사용하여 주시기 바랍니다.";
	
		this.smfAlert(sMsg, [], function ()
		{
			var sUrl = this.fnGetPortalUrl();
			
			// 화면을 이동시킨다.
			window.location.href = sUrl;				
			
			// 화며을 닫는다.
			//window.open('','_self').close();
		});
		return;
			
	}
	
	//pbancNtcScCd 
	//pbancNtcDtlCd
	this.fv_param = this.smfGetFormParams();
	this.divConts.form.divPageSummary.form.cboPageSize.set_value("5"); // 5개씩 보이도록. divPageSummary는 visible false 처리돼있음
	// 메인 페이지를 보여주기 위한 정보를 표시한다.
	var objMainForminfo = {
						  quickmenu : {
										  use : "N"                      //
										, url : ""   //
									  }
						, toplink : {
										  use   : "N"                                 //
										, link  : [ ]                                  // 링크정보(배열)
									  }
						, noticeband : {
										  use   : "N"                 //
										, serviceurl : ""    //  
									   }
						, wildmode : "N"			   
						,formbottommagin : 350
					  }	
	this.pamfSetMainPageInfo(objMainForminfo);
	
	//@KBR divmargin 80으로 수정
	//this.parent.divmargin = 350;
	this.parent.divmargin = 80;
	
	// 중간으로 정렬
	this.fnArrangeMiddlePos();
	
	//@KBR taborder때문에 뒤로 밀림
	var elem = this.divConts.form.divNotTab.getElement();
	if(elem)
	{ //겹쳐진 컴포넌트의 z-index 조절
		elem.setElementZIndex("1");
	}	
// 	//// 퀵메뉴 visible false
// 	var quickMenu = nexacro.getApplication().mainframe.VFrameSet.frameMain.form.divAll.form.divQuickMenu.form;
// 	quickMenu.set_visible("false");
	nexacro.getApplication().mainframe.VFrameSet.frameMain.form.divAll.form.divBottom.form.divBottom.form.set_visible("true");//20240716 고객요청사항(2차 기능개선 목록 2-01 항목)
	this.fnSearch();

};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	
}
/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender)
{
	// 선택된 것을 기준으로 TopFrame을 변경한다.
	var objOption={ appoExamScCd:this.fv_SelSubSystemTypeCd     // 선택된 임용시험구분코드
	              , appoExamScNm:this.fv_SelSubSystemTypeName   // 선택된 임용시험구분코드명
				  };
	var objTopFrameForm = this.getOwnerFrame().form.divTop.form;
	if(objTopFrameForm)		objTopFrameForm.fnRearrageTopComp(this.fv_SelSubSystemCd,"expand",objOption);
	
	var oParam = {};	
	
	if(this.fv_SelSubSystemCd=="ORE")
	{
		// 선택된 서브값을 세팅(유초등 등)
		oParam.selSubSysType = this.fv_SelSubSystemTypeCd;
	}
	
	// 실제 메인화면으로 이동(hrd도 포함)
	this.smfSetWorkPage("frame::ore/frameSubMain.xfdl",oParam,false);
	
};

this.fnPopupNotice = function(e, sender)
{
	
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(obj, e)
{
 	// 서비스 객체 생성
	this.smfSearchService("select")
		// 페이지네이션
		.paginator(this.divConts.form.divGrid.form.grd00, this.divConts.form.divPaginator, this.divConts.form.divPageSummary, 
					this.dsPageInfo, this.fnSearch, e)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.divConts.form.divGrid.form.grd00.set_nodatatext("교육현장에서 당신의 뛰어난 역량을 펼쳐주십시오");
			
			for(var i = 0; i < this.dsResult.getRowCount(); i++) {
				switch(this.dsResult.getColumn(i, "cddcCd")) {	//시도교육청코드에 따라 공지 구분 머릿말 설정		
					case "A00":
					this.dsResult.setColumn(i, "cddcNm", "[교육부]");
					break;					
					case "B10":
					this.dsResult.setColumn(i, "cddcNm", "[서울]");
					break;					
					case "C10":
					this.dsResult.setColumn(i, "cddcNm", "[부산]");		
					break;					
					case "D10":
					this.dsResult.setColumn(i, "cddcNm", "[대구]");	
					break;					
					case "E10":
					this.dsResult.setColumn(i, "cddcNm", "[인천]");	
					break;					
					case "F10":
					this.dsResult.setColumn(i, "cddcNm", "[광주]");	
					break;					
					case "G10":
					this.dsResult.setColumn(i, "cddcNm", "[대전]");	
					break;					
					case "H10":
					this.dsResult.setColumn(i, "cddcNm", "[울산]");	
					break;
					case "I10":
					this.dsResult.setColumn(i, "cddcNm", "[세종]");	
					break;					
					case "J10":
					this.dsResult.setColumn(i, "cddcNm", "[경기]");	
					break;					
					case "K10":
					this.dsResult.setColumn(i, "cddcNm", "[강원]");	
					break;					
					case "M10":
					this.dsResult.setColumn(i, "cddcNm", "[충북]");	
					break;					
					case "N10":
					this.dsResult.setColumn(i, "cddcNm", "[충남]");	
					break;					
					case "P10":
					this.dsResult.setColumn(i, "cddcNm", "[전북]");	
					break;				
					case "Q10":
					this.dsResult.setColumn(i, "cddcNm", "[전남]");	
					break;
					case "R10":
					this.dsResult.setColumn(i, "cddcNm", "[경북]");	
					break;			
					case "S10":
					this.dsResult.setColumn(i, "cddcNm", "[경남]");	
					break;				
					case "T10":
					this.dsResult.setColumn(i, "cddcNm", "[제주]");	
					break;
					case "V10":
					this.dsResult.setColumn(i, "cddcNm", "[재외]");	
					break;		
				}
			}
		});
		
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnArrangeMiddlePos = function()
{
	return true;
	var nLeft,nWidth;
	// divAll center 정렬
	if(this.fv_isMobile)	//모바일일 경우
	{
		//this.divTop.setOffsetWidth(640);
		nWidth = 640;
		var nLeft = (this.width / 2) - (this.divAll.getOffsetWidth()/2);
		if(nLeft < 0) nLeft = 0;
	}
	else
	{	
		var bWildMode = false;
		
		var nAllWidth = this.width;  // 전체 form의 사이즈
		var nMaxWidth = 1200;
		
		if((nAllWidth >= nMaxWidth)&&(!bWildMode))	//1200 사용
		{
			nLeft = parseInt((nAllWidth - nMaxWidth) / 2);
			if(nLeft < 0) nLeft = 0;
			
			nWidth = nMaxWidth;
		}
		else
		{
			nLeft = 0;
			nWidth = nAllWidth;
		}
		
		// Top 배경이미지
		this.divTop.form.staTopTitle.set_left(nLeft);
		this.divTop.setOffsetRight(nLeft+nWidth);

		this.divConts.set_left(nLeft);
		this.divConts.setOffsetWidth(nWidth);
		
		// Top 배경이미지 하단 작은 반원이미지
		var nBg01Left = (nLeft-83)<0?0:(nLeft-83);
		this.staBg01.set_left(nBg01Left);
		
	}
	
};

