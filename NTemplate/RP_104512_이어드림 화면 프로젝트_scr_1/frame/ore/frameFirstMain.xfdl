this.ntc_oncellclick1 = function(obj:nexacro.Grid,e:nexacro.KeyEventInfo)
{
	if(e.keycode==13)
	{
		var objDs = obj.getBindDataset();
		var nRow =objDs.rowposition;

		this.gonggoOpen(objDs,nRow,1);
	}
};

this.gonggoOpen = function(obj,nRow,nCell)
{	
	if(nCell == 1) // 제목
	{
		var objDs = obj;
		
		// 데이터셋 파라미터 세팅
		var sNtcMteId = objDs.getColumn(nRow,"ntcMteId"); // 게시물 ID
		var sNtcMteClfCd = objDs.getColumn(nRow,"ntcMteClfCd"); // 공지사항분류코드
		var sNtcMteTitlNm = objDs.getColumn(nRow,"ntcMteTitlNm"); //제목
		var sNtcMteCn = objDs.getColumn(nRow,"ntcMteCn");	// 내용
		var sCddcCd = objDs.getColumn(nRow, "cddcCd") + "0000001";	// 시도교육청코드
		var sFileId = objDs.getColumn(nRow, "fileRefrnId"); // 파일참조ID
 		var sAppoExamScCd = objDs.getColumn(nRow,"appoExamScCd");

// 		var params = {
// 				eventTitlNm : sNtcMteTitlNm,
// 				popupCn : sNtcMteCn
// 			};

		var popupParams = {
			callback: this.fnPopupNotice, // 콜백함수 지정
			sender: obj, // sender 지정
			titlebar:false,  // 타이틀바를 표시하지 않는다.
			// 팝업 전달 파라메터 지정
			params: {
				// 처리타입 지정(필수)
				procType : "none",  // "none","search","insert","update","delete"
				// 파라메터 전달
				eventTitlNm : sNtcMteTitlNm,
				popupCn : sNtcMteCn,
				fileRefrnId : sFileId,
				ntcMteId : sNtcMteId,
				ntcMteClfCd : sNtcMteClfCd,
				cddcCd : sCddcCd,
				appoExamScCd : sAppoExamScCd
				}
			};				
		/*this.smfSetWorkPage("pa_ore_oew_bd::oreNotice.xfdl", params);*/
		
		// 팝업 실행
		this.smfDialog("_auto", "pa_ore_oew_bd::oreNoticeFrame.xfdl", popupParams);
	}	
}
