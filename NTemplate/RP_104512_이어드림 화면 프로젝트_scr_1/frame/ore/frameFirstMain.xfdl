this.Button1_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfAlert('현재 유초등 임용시험 성적조회 및 합격발표 기간이 아닙니다.\n※ 유초등 임용시험 합격 발표: 2025.2.5. 10:00');
	return;
};
this.Button2_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
