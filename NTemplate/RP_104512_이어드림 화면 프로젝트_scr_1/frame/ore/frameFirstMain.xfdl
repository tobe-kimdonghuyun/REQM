// 모바일인 경우, redirect할 URL을 구한다.
this.fnGetPortalUrl = function()
{
	var sPortalUrl = "";
	var sRunMode = nexacro.getEnvironmentVariable("ev_runMode");  // "1" : 로컬,
	switch(sRunMode)
	{
		case "1" :  // 로컬
		   sPortalUrl = "http://localhost:8080/nxuiPortal/index.html";break;
		case "2" :  // 개발
		   sPortalUrl = "http://dev.neis.go.kr";break;
		case "3" :  // 운영
		   //sPortalUrl = "neis.go.kr";break;
		   sPortalUrl = "https://www.neis.go.kr";break;  
		case "4" :  // 검증
		   sPortalUrl = "http://tst.neis.go.kr";break;
	}
	
	return sPortalUrl;
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 this.Button_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 현재 선택된 것만을 남기고 cssclass를 클리어한다
	var arrComps = this.divConts.form.divOre.form.components;
	for(var i=0;i<arrComps.length;i++)
	{
		if(obj.id==arrComps[i].id)
		{
			arrComps[i].set_cssclass("btn_WF_MapTapGS02");
		}
		else if(obj.id != arrComps[i].id && (i != 0 && i != 4))	// 가운데 세 개 버튼은 선택 안 됐을 시 직사각형 형태
		{
			arrComps[i].set_cssclass("btn_WF_MapTapG02");
		}
		else if(obj.id != arrComps[i].id && i == 0)	// 첫번째 버튼 선택 안 됐을 시 왼쪽 둥근 버튼 css
		{
			arrComps[i].set_cssclass("btn_WF_MapTapG01");
		}
		else if(obj.id != arrComps[i].id && i == 4) // 다섯번째 버튼 선택 안 됐을 시 오른쪽 둥근 버튼 css
		{
			arrComps[i].set_cssclass("btn_WF_MapTapG03");
		}
	}


	this.fv_SelSubSystemCd       = obj.btnSubSys;
	this.fv_SelSubSystemTypeCd   = obj.btnValue;
	this.fv_SelSubSystemTypeName = obj.text; 

	// 선택된 서브시스템코드를 세팅한다.
	this.smfSetSubSystemGb(this.fv_SelSubSystemCd);
	this.smfSetSubSystemDetailGb(this.lpad(this.fv_SelSubSystemTypeCd,"0",3));

	//임용시험구분코드
	this.smfSetAppoExamScCd(this.fv_SelSubSystemTypeCd);
	//this.smfSetSubSystemDetailGb(this.fv_SelSubSystemTypeCd);
	
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: this.fnPopupCallback, // 콜백함수 지정
		sender: obj, // sender 지정
		titlebar:false,  // 타이틀바를 표시하지 않는다.
		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정(필수)
			procType : "none",  // "none","search","insert","update","delete"
			// 파라메터 전달
			sysCd    : this.fv_SelSubSystemCd,
			subSysNm : this.fv_SelSubSystemTypeName
		}
	};

	// 모달팝업 실행
	this.smfDialog("_auto", "comm::comm_cddcList3.xfdl", popupParams);
};
 
this.frameFirstMain_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	// 중간으로 정렬
	this.fnArrangeMiddlePos();	
};

// 공지사항 탭 click
this.TabButton_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	
	switch(obj.name) {	// 클릭한 공고탭 버튼 name에 따라 임용코드 설정
		case "btnNot01":
		this.fv_SelSubSystemTypeCd = "1";
		break;
		case "btnNot02":
		this.fv_SelSubSystemTypeCd = "2";
		break;		
		case "btnNot03":
		this.fv_SelSubSystemTypeCd = "3";
		break;		
		case "btnNot04":
		this.fv_SelSubSystemTypeCd = "4";
		break;		
		case "btnNot05":
		this.fv_SelSubSystemTypeCd = "5";
		break;
	}
	
	var tabId = 0;
	// 현재 선택된 것만을 남기고 cssclass를 클리어한다
	var arrComps = this.divConts.form.divNotTab.form.components;
	for(var i=0;i<arrComps.length;i++)
	{	
		if(obj.id==arrComps[i].id)
		{
			arrComps[i].set_cssclass("btn_WF_NoticeTabS02"); // 가운데 세 개 버튼은 선택 안 됐을 시 직사각형 형태
		}
		else if(obj.id != arrComps[i].id && (i != 0 && i != 4))
		{
			arrComps[i].set_cssclass("btn_WF_NoticeTab02");
		}
		else if(obj.id != arrComps[i].id && i == 0) // 첫번째 버튼 선택 안 됐을 시 왼쪽 둥근 버튼 css
		{
			arrComps[i].set_cssclass("btn_WF_NoticeTab01");
		}
		else if(obj.id != arrComps[i].id && i == 4) // 다섯번째 버튼 선택 안 됐을 시 오른쪽 둥근 버튼 css
		{
			arrComps[i].set_cssclass("btn_WF_NoticeTab03");
		}
	}
	
	if (this.fv_SelSubSystemTypeCd == "1" || this.fv_SelSubSystemTypeCd == "2" ||
		 this.fv_SelSubSystemTypeCd == "3" || this.fv_SelSubSystemTypeCd == "4") {
			this.fv_SelSubSystemCd = "ORE";	// 1, 2, 3, 4번째 버튼 선택 시 온라인채용 코드(ORE)로 설정
			this.dsSearch.setColumn(0, "ntcMteClfCd", "31");	// 게시물구분코드 31(온라인채용 임용/채용 공고)
	} else {
		this.fv_SelSubSystemCd = "HRD"; // 나머지 경우(5번 클릭) 계약제인력풀(HRD)
		this.dsSearch.setColumn(0, "ntcMteClfCd", "51");	// 게시물코드 51(계약제 모집공고)
	}
	
	this.dsSearch.setColumn(0, "appoExamScCd", this.fv_SelSubSystemTypeCd);	// 클릭한 탭버튼에 따라 임용코드 파라미터 설정
	this.dsSearch.setColumn(0, "pafrSysClfCd",  this.fv_SelSubSystemCd);	// 시스템 분류코드(ORE / HRD) 파라미터 설정

	this.fnSearch();	// 클릭하면 fnSearch 함수 작동(공고글 검색해 가져오기)

// 	this.fv_SelSubSystemCd       = obj.btnSubSys;
// 	this.fv_SelSubSystemTypeCd   = obj.btnValue;
// 	this.fv_SelSubSystemTypeName = obj.text; 

// 	// 선택된 서브시스템코드를 세팅한다.
// 	this.smfSetSubSystemGb(this.fv_SelSubSystemCd);
// 	this.smfSetSubSystemDetailGb(this.lpad(this.fv_SelSubSystemTypeCd,"0",3));
// 
// 	//임용시험구분코드
// 	this.smfSetAppoExamScCd(this.fv_SelSubSystemTypeCd);
// 	//this.smfSetSubSystemDetailGb(this.fv_SelSubSystemTypeCd);
// 	alert(this.fv_SelSubSystemCd);
};

// 공고 제목 클릭 시 팝업
this.ntc_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	// TODO: 팝업으로 공고 내용 보이게
	
// 	this.popInfo = {};
