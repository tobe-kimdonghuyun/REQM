<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frameMainP" width="1160" height="1190" scrollbartype="auto auto" onsize="frameMain_onsize" left="0" top="0" titletext="나이스 대국민포탈" onload="frameMain_onload">
    <Layouts>
      <Layout height="260" mobileorientation="portrait" width="1160" screenid="ScreenDeskTopP">
        <Div id="divTop" taborder="0" left="0" top="0" async="false" tabstop="true" accessibilityrole="heading" formscrollbartype="none none" height="100" formscrolltype="none" right="17" text="" accessibilitylabel="상단 메인메뉴" url="frame::frameTopP.xfdl"/>
        <Div id="divAll" taborder="1" left="0" top="0" formscrollbartype="auto auto" text="" tabstop="true" accessibilitylabel="전체영역" formscrolltype="both" right="0" onvscroll="divAll_onvscroll" initvalueid="ivDivAccessibilityOff" bottom="0" maxwidth="" onhscroll="divAll_onhscroll">
          <Layouts>
            <Layout>
              <Div id="divHead" taborder="0" left="0" top="0" async="false" tabstop="true" right="0" accessibilitylabel="화면영역_Head" formscrollbartype="none none" height="0" url="frame::pas/frameHead.xfdl" text="" formscrolltype="none" accessibilityrole="heading" maxwidth=""/>
              <Div id="divWork" taborder="1" left="0" top="divHead:0" tabstop="true" accessibilitylabel="화면영역" formscrollbartype="none none" height="754" text="" formscrolltype="none" divmargin="0" async="false" accessibilityrole="heading" maxwidth="" right="-1">
                <Layouts>
                  <Layout/>
                  <Layout name="Layout0"/>
                </Layouts>
              </Div>
              <Div id="divGrade" taborder="2" left="0" async="false" tabstop="true" right="0" accessibilitylabel="화면영역_grade" formscrollbartype="none none" top="divWork:0" height="0" url="frame::commom/frameGrade.xfdl" visible="false" accessibilityrole="heading"/>
              <Div id="divBottom" taborder="3" left="0" async="false" tabstop="true" right="0" accessibilitylabel="Bottom영역" accessibilityrole="heading" formscrollbartype="none none" top="divGrade:0" height="0" text="" url="frame::pas/frameBottom.xfdl" maxwidth=""/>
            </Layout>
            <Layout name="Layout0">
              <Div id="divWork" left="0" top="divHead:0" right="0" height="654" taborder="0"/>
              <Div id="divGrade" taborder="1"/>
              <Div id="divBottom" left="0" right="0" top="divGrade:0" taborder="2" height="200" text=""/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
      <Layout name="Layout0" screenid="mobileP,tabletP" width="640" height="1024" mobileorientation="portrait" type="default" scrollbartype="autoindicator autoindicator">
        <Div id="divAll" left="0" top="100" formscrolltype="vertical" right="0" bottom="0" formscrollbartype="autoindicator autoindicator"/>
        <Div id="divTop" right="0" left="0" top="0" height="100"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  대국민포탈
*  @MenuPath    frame > frameMainP
*  @FileName 	frameMainP.xfdl 
*  @Creator 	TOBESOFT
*  @CreateDate 	2022.07.12
*  @Desction    base가 되는 화면
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.07.12     		cwi		 	  			최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/


/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_workPageParams = {};	//화면전환시 넘길 parameter
this.fv_isMobile = false;		//모바일로 접속여부
this.fv_device;					//device 종류
this.fv_prevPos;			//마우스로 위아래 스크롤시 위치값

this.fv_workPageWidth = 1280;
this.fv_minwidth;


//각 Frame을 변수로 보관
this.fvFrameTop = this.divTop;
this.fvFrameWork = this.divAll.form.divWork;
this.fvFrameGrade = this.divAll.form.divGrade;
this.fvFrameBottom = this.divAll.form.divBottom;
this.mainUrl = "pa_pas_mms_pc::pas_mmspc00_m01.xfdl";

this.fvUseHistory = true;   // 뒤로가기 기능 사용여부(true:사용, false:미사용)

// History
this.param = {
		"menu"    : "",
		"keyword" : "",
		"page"	  : 1,
		"postId"  : "", 
		"params"  : {},
		"headArea" : "",
		"menuText" : ""
	};

// [BEGIN] 디지털정부 UI/UX 가이드 적용관련
this.APPLY_GOV_MODE = ["1","2"];	// 적용 실행 모드(임시)
this.APPLY_GOV_GUIDE = false;
this.USE_LOGGER = false;
// [ END ] 디지털정부 UI/UX 가이드 적용관련

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frameMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 뒤로가기 기능을 위한 초기설정
	this.fnSetHistoryInit();
	
	// 폼을 초기화
	//this.smfInitForm(obj);
	//nexacro.setPrivateProfile("chkToday","");
	
	//this.divSkip.set_left(0);
	//this.divSkip.set_height(0);
	
	// 최소사이즈
	this.fv_minwidth = this.fv_workPageWidth - nexacro.toNumber(this._getHScrollBarSize());	//1263

	this.fv_isMobile = nexacro.getEnvironmentVariable("ev_isMobile") == "Y"?true:false;
	this.fv_device = "pc";

	//접속 기기 확인
	if (system.navigatorname.indexOf("nexacro")  < 0) 	
	{
		var arrPhone = ['samsug-', 'sch-', 'shw-', 'sph-','sgh-','lg-', 'canu', 'iphone','nokia'
				, 'blackberry', 'lgtelecom', 'natebrowser', 'sonyericsson', 'mobile', 'android', 'ipad'];
		for(i = 0 ; i < arrPhone.length; i++ )
		{
			if(navigator.userAgent.toLowerCase().indexOf(arrPhone[i]) > -1)
			{
				this.fv_isMobile = true;
				this.fv_device = "mobile";
			}
		}

		//tablet 여부 확인
		if( this.smfIsMobile() )	//모바일이면 tablet 체크 시작
		{
			if(navigator.userAgent.toLowerCase().indexOf('ipad') > -1 || 
				(navigator.userAgent.toLowerCase().indexOf('android') > -1 && navigator.userAgent.toLowerCase().indexOf('mobile') == -1))
			{
				this.fv_isMobile = false;
				this.fv_device = "tablet";
			}
			//갤럭시 탭 위한 리다이렉트. mobile이라는 단어가 안들어오면 지워도 됨.
			var galaxyTabModel =  new Array('shw-');
			for(i =0; i < galaxyTabModel.length; i++)
			{
				if(navigator.userAgent.toLowerCase().indexOf(galaxyTabModel[i]) > -1)
				{
					this.fv_isMobile = false;
					this.fv_device = "tablet";
				}
			}
		}
	}
	
	// [BEGIN] 디지털정부 UI/UX 가이드 적용
	
	// 로컬 모드에서만 로그 출력
	var nRunMode = nexacro.getEnvironmentVariable("ev_runMode");		// 실행 구분 : [1] 로컬, [2] 개발
	this.USE_LOGGER = (nRunMode == 1 && system.navigatorname.indexOf("nexacro") < 0) ? true : false;
	
	// 실행구분에 따른 적용여부 설정 - 운영 정식 반영전 적용 방지
	// 운영반영 시 this.APPLY_GOV_MODE 에 실행구분값 추가 또는 this.APPLY_GOV_GUIDE = true 설정
	this.APPLY_GOV_GUIDE = true;	// this.APPLY_GOV_MODE.includes(nRunMode);
	
	// Footer 전환
	if(this.APPLY_GOV_GUIDE){
	
		// [BEGIN] Style 추가
		this.logger("[BEGIN] 디지털정부 UI/UX 적용 관련 CSS 확인");
		// Nexacro 설정 불가 Style 설정 CSS 적용 확인 및 추가(CSS 파일 배포 또는 로드 오류 대비)
		var docStyleSheets = document.styleSheets;	// 신규 StyleSheet 생성 여부
		var hasNxuiExt = false;	// 확장 StyleSheet 링크 여부
		var onNxuiExt = null;	// 확장 StyleSheet
		var doCreateStyle = false;//hasNxuiExt ? false : true;					// 확장 CSS 추가 설정 여부
		for(var sKey in docStyleSheets){
			var appStyle = docStyleSheets[sKey];
			var appStyleHref = appStyle.href;
			if(appStyleHref == null){
				continue;
			}else{
				doCreateStyle = (appStyleHref.indexOf("css/nuxi_ext") > -1) ? false : true;	// 신규 StyleSheet 생성 여부(확장 StyleSheet 링크 확인)
				onNxuiExt = doCreateStyle ? null : appStyle;								// 확장 StyleSheet
				break;
			}
		}

		this.logger("└ StyleSheet CSS 생성(적용) 확인 :: doCreateStyle = " + doCreateStyle);
		
		if(doCreateStyle){
			this.logger("└ 신규 StyleSheet 생성");
			// 신규추가
			var style = document.createElement("style");
			style.rel = "stylesheet";
			style.type = "text/css";
			var addStyleStr = ".btn_BF_Gov_policy.indv > div.nexacontentsbox {left: 6px !important;}";
			addStyleStr += ".gov-dspFlex > .Form > .nexacontainer {display: flex !important;}";
			style.innerHTML = addStyleStr;
			document.getElementsByTagName("head")[0].appendChild(style);
		}else{
			// 확장 StyleSheet CSS 내용 확인 및 추가
			var onNxuiExtRulsLeng = onNxuiExt.cssRules.length;
			var isBlankNxuiExt = onNxuiExtRulsLeng > 0 ? false : true;	// 확장 StyleSheet CSS 내용 확인
			if(isBlankNxuiExt){
				this.logger("└ 빈 확장 StyleSheet > CSS 추가");
				onNxuiExt.insertRule(".btn_BF_Gov_policy.indv > div.nexacontentsbox {left: 6px !important;}", onNxuiExt.cssRules.length);
				onNxuiExt.insertRule(".gov-dspFlex > .Form > .nexacontainer {display: flex !important;}", onNxuiExt.cssRules.length);
			}
		}
		this.logger("[ END ] 디지털정부 UI/UX 적용 관련 CSS 확인");
		// [ END ] Style 추가
	
		this.logger("[BEGIN] 디지털 정부 UI/UX 가이드 적용 - Footer(frame::pas/frameBottomGov) 전환");
		this.divAll.form.divBottom.set_height(474);
		this.divAll.form.divBottom.set_url("frame::pas/frameBottomGov.xfdl");
		this.logger("[ END ] 디지털 정부 UI/UX 가이드 적용");
	}
	// [ END ] 디지털정부 UI/UX 가이드 적용

	if( !this.smfIsMobile() ) {
		// divWork의 width를 HScrollBarSize사이즈 만큼 빼야 하단에 스크롤이 보이지 않음
		this.divAll.form.divWork.setOffsetWidth(this.width - nexacro.toNumber(this._getHScrollBarSize()) );
		this.divAll.form.divBottom.set_minwidth(this.fv_minwidth);
		
		// Top 영역에 스크롤을 생성
		this.divTop.set_formscrollbartype("auto auto");
		this.divTop.set_formscrolltype("horizontal");
		this.divTop.set_formscrollbarsize(0);
		this.divTop.form.resetScroll();
	}
	
	//History - 히스토리 초기화
	if (nexacro._Browser!="Runtime")  MyHistory.init(this.onChangeHistory, this);
	//최초접속시 페이지 이동 처리 함수 호출
	this.initPage();


	/* - @RHS
	//EnvironmentVariable[ev_menuType] 값 체크
	var sUdsVpnRequest = nexacro.getEnvironmentVariable("ev_vpnrequest");
	var extReqMenu = nexacro.getEnvironmentVariable("ev_menuType");
	if(extReqMenu) {
		if (extReqMenu.split("___")[0]) {
			//nexacro.getApplication().mainframe.VFrameSet.frameMain.set_formurl();
		}
	}else if(sUdsVpnRequest=="Y") {
		this.smfSetWorkPage("pa_pas_uum_cm::pas_uumcm00_m00.xfdl", {}, true);
		this.setOffsetWidth(this.getOffsetWidth()+1);
		this.setOffsetWidth(this.getOffsetWidth()-1);
	}else {
		if(!this.smfIsHistory(this))
		{
			this.fnFormInit();
		}
		else
		{
			var hash = MyHistory.getLocationHash();		
			if ( hash )
			{
				// 데이터가 필수가 아니면 체크할 일이 없겠네요
				var data = MyHistory.getData(hash);
				if ( data )
				{
					if(hash==this.mainUrl)
					{
						this.fnFormInit();
					}
					else
					{
						this.smfChangeDiv("W");
						this.onChangeHistory(hash, data);
					}
				}
			}
		}
	}
	*/

	//@KBR
	if( this.width > 1920)
	{
		// 2025.03.26 - 최초 중앙정렬 처리를 위해 주석처리
		//this.setOffsetWidth(1920);
		return;
	}

	//this.resetScroll();
};

this.fnFormInit = function()
{	
	//최초 메인 화면 설정.
	this.fnSetMain();

	//@KBR divTop을 divAll보다 위로 올리기
	var elem = this.divTop.getElement();
	if(elem)
	{ //겹쳐진 컴포넌트의 z-index 조절
		elem.setElementZIndex(1);
	}
	
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/ 
/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){

};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
//서브시스템에 따라 메인화면을 세팅한다.
this.fnSetMain = function()
{
	var sSubSystemGb = "PAS";
	this.smfSetWorkPage(this.mainUrl, {}, true);	
	//this.smfSetWorkPage("frame::"+ sSubSystemGb.toLowerCase() +"/frameSubMain.xfdl");
};

//웹접근성- MainFrame의 titletext를 변경
this.fnChangeFrameTitle = function(menuText, srcName)
{
	if (this.smfIsNull(menuText)) return;

	var sMenuText = nexacro.getApplication().gv_appTtiletext +"|"+ menuText;
	if (menuText == "MAIN") sMenuText = nexacro.getApplication().gv_appTtiletext;
	/*
	if (!this.smfIsNull(srcName)) {
		var objApp = nexacro.getApplication();
		sMenuText = objApp.mainframe.titletext;
		 sMenuText = sMenuText+ " | "+menuText;
	}else {
		sMenuText += "|"+ menuText;
	}
	*/

	nexacro.getApplication().mainframe.set_titletext(sMenuText);
};

/**
* 메뉴변경
* @param 필수 {String} menuUrl – 체크할 값
* @param option {Object} params - 새로열릴 페이지 parameter
* @param : {String} btnText - 메뉴Text
* @return N/A
*/
this.fnSetWorkpage = function(menuUrl, params, bTemp, menuText, hisTime)
{
	if(this.isNil(menuUrl)) return;
	
	// 뒤로가기 세팅을 한다.
	//this.fnSetHistoryHash(menuUrl,params,bTemp, menuText);

	//History
	var sUrl = "";
	var sHash = "";
	var sData = params;
	var objDate = new Date();

	if (menuUrl == this.mainUrl) {
		this.param.menu = menuUrl;
		//History 에 저장될 hash값 만들기
		sHash = "menu="+ this.param.menu;
		sUrl = "./";
	}else {
		this.param.menu = menuUrl;
		//sHash = "menu="+ this.param.menu;
		if(!this.smfIsNull(hisTime)) sHash = "menu="+ this.param.menu +"&v="+ hisTime;
		else 						 sHash = "menu="+ this.param.menu +"&v="+ objDate.getTime();

		sUrl = ".?" + sHash;
	}

	this.param.params = params;
	this.param.headArea = bTemp;

	//History Hash  생성
	if (nexacro._Browser!="Runtime")  MyHistory.setLocationHash(sHash, sData, sUrl);
	//trace("▶▶ getData(sHash) "+ MyHistory.getData(sHash) , sHash);


	this.fv_workPageParams = {};
	if(!this.smfIsNull(params)) this.fv_workPageParams = params;

	this.divAll.form.vscrollbar.set_pos(0);
	if ( !this.smfIsMobile() )	this.divAll.form.hscrollbar.set_pos(0);
	if (this.divAll.form.divWork.url==menuUrl)
	{
		this.divAll.form.divWork.reload();
	}else	
	{
		this.divAll.form.divWork.set_url(menuUrl);
	}
	//this.divAll.setFocus();
	trace("★ fnSetWorkpage() 오픈화면 : "+ menuUrl +"   menuText : "+  menuText );


	if ( this.divAll.form.divWork.url == this.mainUrl ){
		menuText = "MAIN";
		this.divAll.form.divHead.set_visible(false);
		this.divAll.form.divBottom.setOffsetTop("divGrade:0");
	
		if ( this.smfIsMobile() ) 
			this.divAll.form.divBottom.setOffsetTop("divGrade:50");
		
		if ( !this.smfIsMobile() ) {
			// divWork의 width를 HScrollBarSize사이즈 보다 작으면 하단에 스크롤이 생성되게 width 설정
			if (this.divAll.form.divWork.getOffsetWidth() < this.fv_minwidth)
				this.divAll.form.divWork.setOffsetWidth(this.fv_minwidth);
		}

	}else {
		this.divAll.form.divHead.set_visible(true);	
		
		this.divAll.form.divBottom.setOffsetTop("divGrade:100");
		if ( this.smfIsMobile() ) 
			this.divAll.form.divBottom.setOffsetTop("divGrade:70");

		if ( !this.smfIsMobile() ) {
			if ( this.width  < this.fv_minwidth) {
				var nWidthPix = this.divAll.form.divHead.getOffsetWidth();
				this.divAll.form.divWork.setOffsetWidth(nWidthPix);
				this.divAll.form.divWork.set_minwidth();
			}
		}
	}
	
	//전체 높이 >  기본높이(984) - top영역 높이 - bottom 영역 높이
	var nHeight = this.divAll.form.divWork.form.nHeight;
	var nMainframeHeight = nexacro.getApplication().mainframe.height;

	//업무화면의 높이 세팅
	if(this.isNil(nHeight) )
	{
		// 가장 아래에 있는 bottom값에 보전값 지정
		var nMaxHeight = this._smfGetMaxBottomPos(this.divAll.form.divWork.form);
		this.divAll.form.divWork.setOffsetHeight(nMaxHeight + this.fv_DIV_MARGIN);
	}else
	{
		if(nHeight < nMainframeHeight )
		//if(nHeight < (950 - this.divAll.form.divFrameTop.getOffsetHeight() - this.divAll.form.divFrameBottom.getOffsetHeight()))
		{
			var nFormHeight = nMainframeHeight;
			this.divAll.form.divWork.setOffsetHeight(nFormHeight);	//defalut 높이 설정
		}else
		{
			this.divAll.form.divWork.setOffsetHeight(nHeight);
		}
	}

	// divHead의 값 및 높이를 세팅한다.
	if(!bTemp)
	{
		this.divAll.form.divHead.form.fnSetMenu(menuUrl,params);
		if (this.smfIsMobile()) {
			this.divAll.form.divHead.setOffsetHeight(70);
			this.divAll.form.divHead.form.divMenuIndicator2.set_visible(true);	
		}else {
			if ( this.divAll.form.divHead.getOffsetHeight() != 130 )
			{
				this.divAll.form.divHead.setOffsetHeight(130);			
			}
			this.divAll.form.divHead.form.divMenuIndicator.set_visible(true);
		}

		//if (params.menuId =="7000") {
		//	this.set_width(this.width-1 ); // divAll.form.divWork.setOffsetWidth(this.width-1);
		//}
	}else
	{
		this.divAll.form.divHead.setOffsetHeight(0);
		this.divAll.form.divHead.form.divMenuIndicator.set_visible(false);
		this.divAll.form.divHead.form.divMenuIndicator2.set_visible(false);
	}
	
	//전체 영역 높이는  top영역 높이 +  bottom 영역 높이 + 업무영역높이
	//this.divAll.setOffsetHeight( this.divAll.form.divTop.getOffsetHeight()+this.divAll.form.divWork.getOffsetHeight()+this.divAll.form.divBottom.getOffsetHeight()); 
	//this.divAll.setOffsetHeight( this.divAll.form.divHead.getOffsetHeight()+this.divAll.form.divWork.getOffsetHeight()+this.divAll.form.divGrade.getOffsetHeight()+this.divAll.form.divBottom.getOffsetHeight()); 
	this.divAll.form.divWork.form.resetScroll();	//업무영역 resetScroll
	this.divAll.form.resetScroll(); //전체 영역 resetScroll
	this.resetScroll();	//form  영역 resetScroll

	// [BEGIN] 범정부 UIUX 적용 관련
	if(this.APPLY_GOV_GUIDE){
		// TODO
	}else{
		if ( this.smfIsMobile() )
		{
			this.divAll.form.divBottom.setOffsetHeight(580);		
		}else
		{
			this.divAll.form.divBottom.setOffsetHeight(280);
		}
	}
	// [ END ] 범정부 UIUX 적용 관련

	//웹접근성- MainFrame의 titletext를 변경
	this.fnChangeFrameTitle(menuText);
	

	//if ( this.isNil(this.divAll.form.divBottom.url) )
	//	this.divAll.form.divBottom.set_url("frame::pas/frameBottom.xfdl");
};


