/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 사이즈 변경시 위치변경
*/
this.frameMain_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
//	if( e.cx > 1920)
//	{
//		this.setOffsetWidth(1920);
//		return;
//	}

	var objParentFrame = this.getOwnerFrame();
	var arrPopFrame = nexacro.getPopupFrames();
	var changHeight = 200;

	// 검색화면이 팝업일경우
	if (arrPopFrame["_PotalSearch"]) {
		arrPopFrame["_PotalSearch"].setFocus();
		
		if(this.smfIsMobile() )
			arrPopFrame["_PotalSearch"].move(0, 0,null,420,0);
		else 
			arrPopFrame["_PotalSearch"].move(0, 0,null,200,0);
	
		arrPopFrame["_PotalSearch"].form.fnMiddleAlign();
	}

	// divAll center 정렬
	if(this.smfIsMobile() )	//모바일일 경우
	{
		this.divAll.set_left(0);
		this.divAll.set_right(0);
		this.divTop.set_left(0);
		
		// 팝업(공지) 위치 변경
		if (this.isValidObject("commNoticeAll")) {
			this["commNoticeAll"].setFocus();
			this["commNoticeAll"].form.resetScroll();
		}
		
		
		// 일반팝업 가로세로회전시 위치 변경
		var srcInfo = this.smfCurScreenInfo();
		var srcWidth = parseInt(srcInfo[0],10);
		var srcHeight = parseInt(srcInfo[1],10);

		for (var k=0; k<arrPopFrame.length; k++) {
			var objPop = arrPopFrame[k];
			

			var nPopTop = 0;
			//@orgFormHeight : 해당 팝업 form onload시 지정한 높이
			//@orgPopHeight : 팝업 호출 시 지정한 높이
			//팝업 호출 시 지정한 사이즈를 우선으로 함. 사이즈를 지정하지 않았다면 form 크기에 맞춤.
			var nPopHeight = 0;
			if(this.smfIsNull(objPop.orgPopHeight)){
				nPopHeight = parseInt(objPop.orgFormHeight) + objPop.titlebarheight; //폼사이즈 + Titlebar 높이
			}else{
				nPopHeight = parseInt(objPop.orgPopHeight); //입력한 팝업 사이즈
			}			
			var nPopWidth =  this.smfIsNull(objPop.orgPopWidth)? parseInt(objPop.orgFormWidth):parseInt(objPop.orgPopWidth);
			var nPopLeft = ( srcWidth - nPopWidth ) / 2;	//left는 중앙으로 위치
			
			
			// Left,Top 이 없으면 처음오픈시 값으로 셋팅
			if ( !this.smfIsNull(objPop.orgPopTop) && !this.smfIsNull(objPop.orgPopLeft) ) {
				if (!this.smfIsNull(objPop.orgPopTop))	nPopTop = objPop.orgPopTop;
				//if (!this.smfIsNull(objPop.orgPopLeft))	nPopLeft = objPop.orgPopLeft;
				var nTpos = parseInt(nPopTop) + nPopHeight;
	
			
				//가로전환시 화면높이가 더 크면
				if (srcHeight <= nTpos) {
					nPopTop = 15;
					objPop.setOffsetHeight(srcHeight-30);
				}else{
					objPop.setOffsetHeight(nPopHeight);
				}
			}else {
				var nTpos = parseInt(objPop.getOffsetTop()) + nPopHeight;
				
				//가로전환시 화면높이가 더 크면
				// - 모바일Combo 에서도 적용됨
				if (srcHeight <= nTpos) {
					nPopTop = 15;
					objPop.setOffsetHeight(srcHeight-30);
				}else{
					objPop.setOffsetHeight(nPopHeight);
					nPopTop = parseInt((srcHeight - nPopHeight) / 2);
				}
			}
			
			objPop.setOffsetLeft(nPopLeft);
			objPop.setOffsetTop(nPopTop);				
			
			objPop.form.resetScroll();
		}

		this.divAll.form.divWork.form.resetScroll();
		this.divAll.form.resetScroll();
		this.resetScroll();
	}else
	{
		var nAllWidth = this.width - this._getHScrollBarSize();  // 전체 form의 사이즈
		var nMaxWidth = 1200;
		var nLeft,nWidth;

		if(nAllWidth >= nMaxWidth)	//1280 사용
		{
			nLeft = parseInt((nAllWidth - nMaxWidth) / 2);
			if(nLeft < 0) nLeft = 40;
			
			nWidth = nMaxWidth;
		}else
		{
			nLeft = 40;
			nWidth = nAllWidth;
		}

		if ( this.divAll.form.divWork.url == this.mainUrl ){		
			this.divAll.form.divWork.setOffsetLeft(0);
			this.divAll.form.divWork.setOffsetWidth(e.cx - this._getHScrollBarSize());

			// divWork의 width를 HScrollBarSize사이즈 만큼 빼야 하단에 스크롤이 보이지 않음
			if (this.divAll.form.divWork.getOffsetWidth() < this.fv_minwidth)
				this.divAll.form.divWork.set_minwidth(this.fv_minwidth);
	
		}else
		{
			// 가운데 정렬
			this.divAll.form.divHead.setOffsetLeft(nLeft);
			this.divAll.form.divWork.setOffsetLeft(nLeft);
			this.divAll.form.divHead.setOffsetWidth(nWidth);
			this.divAll.form.divWork.setOffsetWidth(nWidth);
			
			this.divAll.form.divGrade.setOffsetLeft(nLeft);
			this.divAll.form.divGrade.setOffsetWidth(nWidth);
		}		
//trace("@@ frameMain_onsize()  " + this.width +"======> nLeft="+nLeft+",nWidth="+nWidth + " e.cx : " + e.cx);

		this.__smfResetScroll(this.divAll.form.divWork.form);

		this.divAll.form.divHead.form.resetScroll();
		this.divAll.form.divWork.form.resetScroll();
		this.divAll.form.divGrade.form.resetScroll();
		this.divAll.form.resetScroll();
		this.divTop.form.resetScroll();
		this.resetScroll();
	}
};

/**
 @divAll VScroll  = 0 이면,SiteMap(이용문의) 상단 우측 에 보여질것
  divAll Top = 0 && divAll VScroll > 0 이면,SiteMap(이용문의) 삭제
*/
this.divAll_onvscroll = function(obj:nexacro.Div,e:nexacro.ScrollEventInfo)
{
	if ( nexacro.getEnvironmentVariable("ev_isMobile") == "Y" )	return;
	if ( this.divAll.form.divWork.url != this.mainUrl )	return;

	var nPos = e.pos;
	if (nPos > this.divTop.height ) {
		this.divTop.form.fnTopMode("W");  // 흰배경
		
		// divAll의 Top변경
		this.divAll.setOffsetTop(this.divTop.getOffsetHeight());
		// divTop의 right 변경
		this.divTop.set_right(0);  // this._getHScrollBarSize()
	}else 
	{
		this.divTop.form.fnTopMode("B");  // 투명배경
		
		// divAll의 Top변경
		this.divAll.setOffsetTop(0);
		// divTop의 right 변경
		this.divTop.set_right(this.divAll.form._getHScrollBarSize());  
	}
		
	this.fv_prevPos = nPos;

};

//가로 스크롤 이동시 divTop 가로스크롤 이동시킨다
this.divAll_onhscroll = function(obj:nexacro.Div,e:nexacro.ScrollEventInfo)
{
	this.divTop.form.fnTopMenuOnhscroll(e.pos);

	/*
	//상단 동적 메뉴(공지사항,원격지원서비스) 제어
	var nPos = parseInt(this.getOwnerFrame().form.divAll.getVScrollPos(),0);
	if (nPos > this.divTop.height ) {
	
	if (this.getOwnerFrame().form.divTop.form.divTopB.minwidth > this.getOwnerFrame().form.divTop.getOffsetWidth() &&
	    parseInt(this.getOwnerFrame().form.divAll.form.getHScrollPos(),0) > parseInt(this.getOwnerFrame().form.divTop.form.getHScrollPos(),10) )
	{
			this.getOwnerFrame().form.divTop.form.fnTopMode("W");	
	}
	*/
};

/**
 * @description 웹접근성 안내 페이지 클릭
*/
this.divSkip_btnAccessbilty_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
		var procType = "search";

	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: this.fnPopupCallback, // 콜백함수 지정
		sender: obj, // sender 지정
		
		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: procType,
		},
	};
	// 모달팝업 실행
	this.smfDialog("_auto", "comm::accessibilityGuide.xfdl", popupParams);	
};

/**
 * @description skip에서 포커스가 빠졌을때
*/
this.divSkip_onkillfocus = function(obj:nexacro.Div,e:nexacro.KillFocusEventInfo)
{

	this.divSkip.set_height(0);

	var elem = this.divSkip.getElement();
	if(elem)
	{ //겹쳐진 컴포넌트의 z-index 조절
		elem.setElementZIndex("");
	}
};
/**
 * @description skip에서 포커스가 들어올때
*/
this.divSkip_onsetfocus = function(obj:nexacro.Div,e:nexacro.SetFocusEventInfo)
{
	this.divSkip.set_height(70);
	this.divSkip.bringToFront();
	
	var elem = this.divSkip.getElement();
	if(elem)
	{ //겹쳐진 컴포넌트의 z-index 조절
		elem.setElementZIndex(1);
	}	
};

// 본문 바로가기
this.divSkip_btnGoBody_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 팝업공지 close
	this.fnCommNoticeClose();

	var divWork = this.divAll.form.divWork;
	var comp = divWork.form.components;
	for(var i=0; i<comp.length; i++)
	{
		//접근성 enable true인 첫번째 컴포넌트
		if(comp[i].accessibilityenable==true)
		{
			comp[i].setFocus();
			break;
		}
	}
};

// 팝업공지 close
this.fnCommNoticeClose = function() {

	if (this.divAll.form.divWork.url == this.mainUrl) {		
		if (this.isValidObject("commNoticeAll")) {		
			var objDiv = this.removeChild("commNoticeAll");
			objDiv.destroy();
			objDiv = null;
		}	
	}
};

/**
 * 디지털정부 UI/UX 적용 관련
 * 로그 출력
 */
this.logger = function(){
	if(this.USE_LOGGER){
		var baseLog = this._orgurl.replace(".xfdl","") + " > ";
		trace(baseLog, ...arguments);
	}
}]]></Script>
