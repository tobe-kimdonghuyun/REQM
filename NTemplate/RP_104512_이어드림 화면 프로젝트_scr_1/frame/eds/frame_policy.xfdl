    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    샘플
*  @FileName 	frame_policy.xfdl
*  @editor 	김지영
*  @CreateDate 	2023.7.10
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2023.5.31     	정인혁 	        최초 생성 
*  2023.7.10     	김지영 	        교육설문용 수정 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.framePolicy_New_01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitDiv(obj);
	
	this.staDetail.set_height(10920);
	
	//이전개인정보처리방침 셋팅
	this.fnSetPolicyList();
}; 

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

}
/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){

};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

//이전개인정보처리방침 셋팅
this.fnSetPolicyList = function()
{
	var sSubSystemGb = this.smfGetSubSystemGb();
	this.cboBeforePrivetePolicy.set_index(0);
};


/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 설문 개인정보처리방침 focus
 * @param  : obj			- [object]ImageViewer
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.Button_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var short = obj.moveComp;
	
	for(var i=1; i < 16; i++){
		if(i == short){
			var tt = this["imgTit0" + i].setFocus(true);
		}else if(short >= 10){
			 this["imgTit" + short].setFocus(true);
		}
	}
};

/**
 * 이전개인정보처리방침 pdf
 * @param  : obj			- [object]Combo
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.cboBeforePrivetePolicy_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	var sUrl = obj.value;
	trace("URL : " + sUrl);
	
	if(!this.smfIsNull(sUrl))
	{
		var sBaseUrl= window.location.protocol + "//" + window.location.host;
		trace("sBaseUrl : " + sBaseUrl);
	
		system.execBrowser(sBaseUrl + sUrl);
	}
};

