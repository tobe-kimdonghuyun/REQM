              <Grid id="grd03" cssclass="grd_policy_detail_M" autofittype="none" formatid="default_00" left="0" top="0" height="1179" right="0" autosizingtype="row" cellclickbound="cell" scrollbartype="default default"/>
            </Layout>
          </Layouts>
        </Div>
        <ImageViewer id="imgTit02" taborder="20" text="제2조(개인정보 처리 및 보유기간)" left="30" top="div01:30" width="350" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/ico230301_02_s.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_02_01_00_00" taborder="21" text="①" left="30" top="imgTit02:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="첫 번째"/>
        <Static id="sta00_04_00_00" taborder="22" text="나이스 대국민서비스는 법령에 따른 개인정보 보유·이용기간 또는 정보주체로부터 개인정보를 수집 시에 동의받은 개인정보 보유·이용기간 내에서 개인정보를 처리·보유합니다." left="sta00_02_01_00_00:5" top="imgTit02:20" height="50" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01_00_00_00" taborder="23" text="② " left="30" top="sta00_04_00_00:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="두 번째"/>
        <Static id="sta00_04_00_00_00" taborder="24" text="각각의 개인정보 처리 및 보유기간은 다음과 같습니다.(제1조 3항 참조)" left="sta00_02_01_00_00_00:5" top="sta00_04_00_00:20" height="25" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_00" taborder="25" text="1. 홈페이지를 통한 서비스 이용 및 개인정보 보유기간" left="50" top="sta00_04_00_00_00:10" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_00_02" taborder="26" text="- 제1조(개인정보의 처리목적)5항③에 따름" left="60" top="sta00_01_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_00_03" taborder="27" text="2. 다만, 다음의 사유에 해당하는 경우에는 해당 사유 종료 시까지" left="50" top="sta00_01_00_02:10" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_00_02_00" taborder="28" text="1) 관계 법령 위반에 따른 수사․조사 등이 진행 중인 경우에는 해당 수사․조사 종료 시까지" left="60" top="sta00_01_00_03:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_00_02_00_00" taborder="29" text="2) 홈페이지 이용에 따른 채권․채무관계 잔존 시에는 해당 채권․채무관계 정산 시까지" left="60" top="sta00_01_00_02_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <ImageViewer id="imgTit03" taborder="30" text="제3조(개인정보 제3자 제공)" left="30" top="sta00_01_00_02_00_00:30" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/ico230301_03_s.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn" right="30"/>
        <Static id="sta00_02_01_00_00_01" taborder="31" text="①" left="30" top="imgTit03:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="첫 번째"/>
        <Static id="sta00_04_00_00_01" taborder="32" text="나이스 대국민서비스는 정보주체의 개인정보를 제1조(개인정보의 처리 목적)에서 명시한 범위 내에서만 처리하며, 정보주체의 동의, 법률의 특별한 규정 등 「개인정보 보호법」제17조 및 제18조에 해당하는 경우에만 개인정보를 제3자에게 제공합니다." left="sta00_02_01_00_00_01:5" top="imgTit03:20" height="50" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01_00_00_01_00" taborder="33" text="② " left="30" top="sta00_04_00_00_01:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="두 번째"/>
        <Static id="sta00_04_00_00_01_00" taborder="34" text="나이스 대국민서비스는 다음과 같이 개인정보를 제3자에게 제공하고 있습니다." left="sta00_02_01_00_00_01_00:5" top="sta00_04_00_00_01:20" height="25" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
