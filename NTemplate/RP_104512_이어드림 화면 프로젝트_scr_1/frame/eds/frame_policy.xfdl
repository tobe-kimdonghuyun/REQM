                    <Rows>
                      <Row size="40" band="head"/>
                      <Row size="50"/>
                    </Rows>
                    <Band id="head">
                      <Cell text="서비스명" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                      <Cell col="1" text="회원정보 조회/변경 기능" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd"/>
                    </Band>
                    <Band id="body">
                      <Cell text="학원서비스" textAlign="center"/>
                      <Cell col="1" text="홈페이지 로그인 → [마이페이지] → [사용자 정보변경] 메뉴" textAlign="center" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd"/>
                    </Band>
                  </Format>
                  <Format id="default_00">
                    <Columns>
                      <Column size="200"/>
                      <Column size="400"/>
                    </Columns>
                    <Rows>
                      <Row size="50" band="head"/>
                      <Row size="150"/>
                    </Rows>
                    <Band id="head">
                      <Cell text="서비스명" font="normal 700 26px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                      <Cell col="1" text="회원정보 조회/변경 기능" font="normal 700 26px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd"/>
                    </Band>
                    <Band id="body">
                      <Cell text="학원서비스" textAlign="center"/>
                      <Cell col="1" text="홈페이지 로그인 →&#13;&#10;[마이페이지] →&#13;&#10;[사용자 정보변경] 메뉴" textAlign="center" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd"/>
