                      <Cell row="19" col="1" rowspan="3" text="학생·학부모&#13;&#10;참여교육설문&#13;&#10;(에듀로)" textAlign="center" wordWrap="char" autosizerow="default"/>
                      <Cell row="19" col="2" autosizerow="default" wordWrap="char" textAlign="center" text="학교폭력 실태조사"/>
                      <Cell row="19" col="3" autosizerow="default" wordWrap="char" text="- 초‧중등교육법 제30조의4,5&#13;&#10;- 교육기본법 제23조의2,&#13;&#10;- 학교폭력예방 및 대책에 관한 - 법률 제11조, 제11조의2, 제20조의4&#13;&#10;- 학교폭력예방 및 대책에 관한 법률 시행령 제31조" textAlign="left"/>
                      <Cell row="19" col="4" autosizerow="default" wordWrap="char" textAlign="center" text="학교폭력 실태조사 서술(신고)문항"/>
