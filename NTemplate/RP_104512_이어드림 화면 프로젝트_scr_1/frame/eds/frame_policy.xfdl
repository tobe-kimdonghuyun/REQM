        <ImageViewer id="imgTit04" taborder="36" text="제4조 (개인정보처리 위탁)" left="30" top="div02:30" width="250" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/ico230301_04_s.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_02_01_00_00_01_01" taborder="37" text="①" left="30" top="imgTit04:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="첫 번째"/>
        <Static id="sta00_04_00_00_01_01" taborder="38" text="나이스 대국민서비스는 원활한 개인정보 업무처리를 위하여 다음과 같이 개인정보 처리업무를 위탁하고 있습니다." left="sta00_02_01_00_00_01_01:5" top="imgTit04:20" height="25" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_00_00" taborder="39" text="1. 위탁기관(수탁자)" left="50" top="sta00_04_00_00_01_01:10" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30" onclick="sta00_01_00_00_onclick"/>
        <Static id="sta00_01_00_02_01" taborder="40" text="- 위탁받는 자: 한국교육학술정보원" left="60" top="sta00_01_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_00_02_01_00" taborder="41" text="- 위탁하는 업무의 내용: 나이스 대국민서비스 운영" left="60" top="sta00_01_00_02_01:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_00_02_01_00_01" taborder="155" text="- 위탁범위: 나이스 대국민서비스 운영 업무에 필요한 최소한의 정보" left="60" top="sta00_01_00_02_01_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_00_00_00" taborder="42" text="2. 위탁기관(재수탁자)" left="50" top="sta00_01_00_02_01_00_01:10" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_00_02_01_01" taborder="43" text="가. 서비스 운영 및 유지관리, 기술지원" left="60" top="sta00_01_00_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_00_02_01_00_00" taborder="44" text="- 위탁받는 자(수탁자) : 아이티센엔텍(주)" left="70" top="sta00_01_00_02_01_01:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_00_02_01_00_00_01" taborder="156" text="- 위탁하는 업무의 내용 : 나이스 대국민서비스 유지관리, 기능개선 및 사용자 편의성 개선, 서비스 성능 개선" left="70" top="sta00_01_00_02_01_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_00_02_01_00_00_01_00" taborder="157" text="- 위탁범위: 나이스 대국민 업무 처리를 위해 필요한 최소한의 정보" left="70" top="sta00_01_00_02_01_00_00_01:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_00_00_00_00" taborder="45" text="나. 상담센터 운영" left="60" top="sta00_01_00_02_01_00_00_01_00:10" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_00_02_01_01_00" taborder="46" text="- 위탁받는 자(수탁자) : 효성아이티엑스(주)" left="70" top="sta00_01_00_00_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_00_02_01_00_00_00" taborder="47" text="- 위탁하는 업무의 내용: 나이스 사용자를 위한 다각적인 상담 외 서비스 제공" left="70" top="sta00_01_00_02_01_01_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_00_02_01_00_00_00_00" taborder="158" text="- 위탁범위: 나이스 사용자 상담을 위해 필요한 최소한의 정보" left="70" top="sta00_01_00_02_01_00_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01_00_00_01_01_00" taborder="48" text="②" left="30" top="sta00_01_00_02_01_00_00_00_00:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="두 번째"/>
        <Static id="sta00_04_00_00_01_01_00" taborder="49" text="나이스 대국민서비스는 위탁계약 체결 시「개인정보 보호법」제26조에 따라 위탁업무 수행목적 외 개인정보 처리금지, 안전성 확보조치, 재위탁 제한, 수탁자에 대한 관리·감독, 손해배상 등 책임에 관한 사항을 계약서 등 문서에 명시하고, 수탁자가 개인정보를 안전하게 처리하는지를 감독하고 있습니다." left="sta00_02_01_00_00_01_01_00:5" top="sta00_01_00_02_01_00_00_00_00:20" height="50" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_00_00_01" taborder="159" text="1. 위탁업무의 목적 및 범위" left="50" top="sta00_04_00_00_01_01_00:10" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30" onclick="sta00_01_00_00_onclick"/>
        <Static id="sta00_01_00_00_01_00" taborder="164" text="2. 위탁업무 수행 목적 외 개인정보의 처리 금지에 관한 사항" left="50" top="sta00_01_00_00_01:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30" onclick="sta00_01_00_00_onclick"/>
        <Static id="sta00_01_00_00_01_00_00" taborder="165" text="3. 기술적·관리적 보호조치에 관한 사항" left="50" top="sta00_01_00_00_01_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30" onclick="sta00_01_00_00_onclick"/>
        <Static id="sta00_01_00_00_01_00_01" taborder="169" text="4. 재위탁 제한에 관한 사항" left="50" top="sta00_01_00_00_01_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30" onclick="sta00_01_00_00_onclick"/>
        <Static id="sta00_01_00_00_01_00_02" taborder="170" text="5. 수탁기관 및 재수탁기관에 대한 관리·감독, 손해배상 등 책임에 관한 사항" left="50" top="sta00_01_00_00_01_00_01:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30" onclick="sta00_01_00_00_onclick"/>
        <Static id="sta00_02_01_00_00_01_01_00_00" taborder="171" text="③" left="30" top="sta00_01_00_00_01_00_02:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="세 번째"/>
        <Static id="sta00_04_00_00_01_01_00_00" taborder="172" text="위탁업무의 내용이나 수탁자가 변경될 경우에는 지체 없이 본 개인정보 처리방침을 통하여 공개하도록 하겠습니다." left="sta00_02_01_00_00_01_01_00_00:5" top="sta00_01_00_00_01_00_02:20" height="25" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <ImageViewer id="imgTit05" taborder="50" text="제5조(정보주체와 법정대리인의 권리․의무 및 행사방법)" left="30" top="sta00_04_00_00_01_01_00_00:30" width="450" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/ico230301_06_s.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_02_01_00_00_01_01_01" taborder="51" text="①" left="30" top="imgTit05:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="첫 번째"/>
        <Static id="sta00_04_00_00_01_01_01" taborder="52" text="정보주체(만14세 미만인 경우에는 법정대리인을 말함)는 나이스 대국민서비스에 대해 언제든지 개인정보 열람·정정·삭제·처리정지 요구 등의 권리를 행사할 수 있습니다." left="sta00_02_01_00_00_01_01_01:5" top="imgTit05:20" height="50" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_00_00_01_01" taborder="160" text="※ 만 14세 미만 아동에 관한 개인정보의 열람 등 요구는 법정대리인이 직접 해야 하며, 만 14세 이상의 미성년자인 정보주체는 정보주체의 개인정보에 관하여 미성년자 본인이 권리를 행사하거나 법정대리인을 통하여 권리를 행사할 수도 있습니다." left="50" top="sta00_04_00_00_01_01_01:5" height="50" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30" onclick="sta00_01_00_00_onclick"/>
        <Static id="sta00_02_01_00_00_01_01_01_00" taborder="53" text="② " left="30" top="sta00_01_00_00_01_01:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="두 번째"/>
        <Static id="sta00_04_00_00_01_01_01_00" taborder="54" text="제1항에 따른 권리 행사는 나이스 대국민서비스에 대해 「개인정보 보호법」시행령 제41조제1항에 따라 서면, 전자우편, 모사전송(FAX) 등을 통하여 하실 수 있으며, 나이스 대국민서비스는 이에 대해 지체 없이 조치하겠습니다." left="sta00_02_01_00_00_01_01_01_00:5" top="sta00_01_00_00_01_01:20" height="50" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_04_00_00_01_01_01_00_00_00_00" taborder="161" text="▶개인정보(열람, 정정·삭제, 처리정지, 동의철회)요구서" left="50" top="sta00_04_00_00_01_01_01_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" width="450" onclick="sta00_04_00_00_01_01_01_00_00_00_onclick" visible="true"/>
        <Static id="sta00_02_01_00_00_01_01_01_00_00" taborder="55" text="③ " left="30" top="sta00_04_00_00_01_01_01_00_00_00_00:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="세 번째"/>
        <Static id="sta00_04_00_00_01_01_01_00_00" taborder="56" text="제1항에 따른 권리 행사는 정보주체의 법정대리인이나 위임을 받은 자 등 대리인을 통하여 하실 수 있습니다. 이 경우 교육부 개인정보 보호지침 서식에 따른 위임장을 제출하셔야 합니다. " left="sta00_02_01_00_00_01_01_01_00_00:5" top="sta00_04_00_00_01_01_01_00_00_00_00:20" height="50" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_04_00_00_01_01_01_00_00_00" taborder="57" text="▶위임장" left="50" top="sta00_04_00_00_01_01_01_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" width="100" onclick="sta00_04_00_00_01_01_01_00_00_00_onclick" visible="true"/>
        <Button id="btnButton1500" taborder="58" text="서식 다운로드" top="sta00_04_00_00_01_01_01_00_00:5" height="24" width="120" left="sta00_04_00_00_01_01_01_00_00_00:10" cssclass="btn_WF_Custom" visible="true" initvalueid="ivBtnAccessibilityLink" accessibilitydescription="새창열림" onclick="btnButton1500_onclick"/>
        <Static id="sta00_02_01_00_00_01_01_01_00_00_00" taborder="59" text="④ " left="30" top="sta00_04_00_00_01_01_01_00_00_00:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="네 번째"/>
        <Static id="sta00_04_00_00_01_01_01_00_00_01" taborder="60" text="개인정보 열람 및 처리정지 요구는 「개인정보 보호법」제35조제4항, 제37조제2항에 의하여 정보주체의 권리가 제한 될 수 있습니다." left="sta00_02_01_00_00_01_01_01_00_00_00:5" top="sta00_04_00_00_01_01_01_00_00_00:20" height="25" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01_00_00_01_01_01_00_00_00_00" taborder="61" text="⑤ " left="30" top="sta00_04_00_00_01_01_01_00_00_01:20" height="26" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="다섯 번째"/>
        <Static id="sta00_04_00_00_01_01_01_00_00_01_00" taborder="62" text="개인정보의 정정 및 삭제 요구는 다른 법령에서 그 개인정보가 수집 대상으로 명시되어 있는 경우에는 그 삭제를 요구할 수 없습니다." left="55" top="sta00_04_00_00_01_01_01_00_00_01:20" height="26" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01_00_00_01_01_01_00_00_00_00_00" taborder="63" text="⑥ " left="30" top="sta00_04_00_00_01_01_01_00_00_01_00:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="여섯 번째"/>
        <Static id="sta00_04_00_00_01_01_01_00_00_01_00_00" taborder="64" text="나이스 대국민서비스 정보주체 권리에 따른 열람의 요구, 정정·삭제의 요구, 처리정지의 요구 시 열람 등 요구를 한 자가 본인이거나 정당한 대리인인지를 확인합니다." left="sta00_02_01_00_00_01_01_01_00_00_00_00_00:5" top="sta00_04_00_00_01_01_01_00_00_01_00:20" height="50" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01_00_00_01_01_01_00_00_00_00_00_00" taborder="65" text="⑦ " left="30" top="sta00_04_00_00_01_01_01_00_00_01_00_00:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="일곱 번째"/>
        <Static id="sta00_04_00_00_01_01_01_00_00_01_00_00_00" taborder="66" text="회원정보 조회/변경 기능을 통해 홈페이지에서 회원정보를 조회 및 변경할 수 있습니다." left="sta00_02_01_00_00_01_01_01_00_00_00_00_00_00:5" top="sta00_04_00_00_01_01_01_00_00_01_00_00:20" height="25" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Div id="div03" taborder="67" left="30" top="sta00_04_00_00_01_01_01_00_00_01_00_00_00:10" height="91" initvalueid="ivDivAccessibilityOff" right="30">
          <Layouts>
            <Layout>
              <Grid id="grd00" taborder="0" left="0" top="0" height="91" initvalueid="ivGrdAccessibilityOn" cssclass="grd_policy_detail" selecttype="cell" right="0" binddataset="ds03" autofittype="col" accessibilitylabel="회원정보 조회/변경 기능">
                <Formats>
