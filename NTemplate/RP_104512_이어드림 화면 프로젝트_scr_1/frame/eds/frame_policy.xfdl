        </Div>
        <Static id="sta00_04_00_00_01_01_01_00_00_01_00_00_00_00" taborder="68" text=" ※ 위 항목에 해당되는 서비스에 대한 정보를 확인하실 수 있습니다." left="30" top="div03:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <ImageViewer id="imgTit06" taborder="69" text="제6조(개인정보의 파기)" left="30" top="sta00_04_00_00_01_01_01_00_00_01_00_00_00_00:30" width="250" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/ico230301_05_s.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00" taborder="70" text="① " left="30" top="imgTit06:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="첫 번째"/>
        <Static id="sta00_04_00_00_01_01_01_01_01_00" taborder="71" text="나이스 대국민서비스는 개인정보 보유기간의 경과, 처리목적 달성 등 개인정보가 불필요하게 되었을 때에는 지체없이 해당 개인정보를 파기합니다. 파기하는 개인정보는 제1조(개인정보의 처리목적) 제3항의 개인정보파일과 같습니다." left="sta00_02_01_00_00_01_01_01_01_00_00:5" top="imgTit06:20" height="50" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00" taborder="72" text="② " left="30" top="sta00_04_00_00_01_01_01_01_01_00:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="두 번째"/>
        <Static id="sta00_04_00_00_01_01_01_01_01_00_00" taborder="73" text="정보주체로부터 동의받은 개인정보 보유기간이 경과하거나 처리목적이 달성되었음에도 불구하고 다른 법령에 따라 개인정보를 계속 보존하여야 하는 경우에는, 해당 개인정보를 별도의 데이터베이스(DB)로 옮기거나 보관장소를 달리하여 보존합니다." left="sta00_02_01_00_00_01_01_01_01_00_00_00:5" top="sta00_04_00_00_01_01_01_01_01_00:20" height="50" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_04_00_00_01_01_01_01_01_00_00_00" taborder="74" text="1. 법령 근거 : 「공공기록물 관리에 관한 법률」제21조제1항" left="50" top="sta00_04_00_00_01_01_01_01_01_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_04_00_00_01_01_01_01_01_00_00_00_00" taborder="75" text="2. 보존하는 개인정보 항목: 홈페이지를 통해 제공하는 모든 서비스 사용에 필요한 사용자 정보" left="50" top="sta00_04_00_00_01_01_01_01_01_00_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00" taborder="76" text="③ " left="30" top="sta00_04_00_00_01_01_01_01_01_00_00_00_00:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="세 번째"/>
        <Static id="sta00_04_00_00_01_01_01_01_01_00_00_01" taborder="77" text="개인정보 파기의 절차 및 방법은 다음과 같습니다." left="sta00_02_01_00_00_01_01_01_01_00_00_00_00:5" top="sta00_04_00_00_01_01_01_01_01_00_00_00_00:20" height="25" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_04_00_00_01_01_01_01_01_00_00_00_01" taborder="78" text="1. 파기 절차" left="50" top="sta00_04_00_00_01_01_01_01_01_00_00_01:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_04_00_00_01_01_01_01_01_00_00_00_01_00" taborder="79" text="나이스대국민서비스는 파기 사유가 발생한 개인정보를 선정하고, 적법한 절차에 따라 나이스 대국민서비스 개인정보 보호책임자의 승인을 받아 파기합니다. " left="60" top="sta00_04_00_00_01_01_01_01_01_00_00_00_01:5" height="50" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_04_00_00_01_01_01_01_01_00_00_00_01_01" taborder="80" text="2. 파기 방법" left="50" top="sta00_04_00_00_01_01_01_01_01_00_00_00_01_00:10" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_04_00_00_01_01_01_01_01_00_00_00_01_00_00" taborder="81" text="나이스 대국민서비스는 전자적 파일 형태로 기록·저장된 개인정보는 기록을 재생할 수 없도록 파기하며, 종이 문서에 기록·저장된 개인정보는 분쇄기로 분쇄하거나 소각하여 파기합니다." left="60" top="sta00_04_00_00_01_01_01_01_01_00_00_00_01_01:5" height="50" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <ImageViewer id="imgTit07" taborder="82" text="제7조(개인정보의 안전성 확보 조치)" left="30" top="sta00_04_00_00_01_01_01_01_01_00_00_00_01_00_00:30" width="350" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/ico230301_07_s.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_03_00_00_00_00_01_00" taborder="83" text="나이스 대국민서비스는 개인정보의 안전성 확보를 위해 다음과 같은 조치를 취하고 있습니다." left="30" top="imgTit07:20" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_03_00_00_00_00_01_00_01" taborder="84" text="1. 관리적 조치 : 내부관리계획 수립·시행, 정기적 직원 교육 등" left="50" top="sta00_03_00_00_00_00_01_00:10" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_03_00_00_00_00_01_00_01_00" taborder="85" text="- (내부관리계획의 수립) 안전한 개인정보 처리를 위하여 내부관리계획 수립 및 시행" left="60" top="sta00_03_00_00_00_00_01_00_01:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_03_00_00_00_00_01_00_01_00_00" taborder="86" text="- (정기적 점검) 안전성 확보를 위해 개인정보 파일 보유현황 정기적 점검 실시" left="60" top="sta00_03_00_00_00_00_01_00_01_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_03_00_00_00_00_01_00_01_00_00_00" taborder="87" text="- (개인정보취급자 교육) 개인정보취급자 최소화 관리 및 개인정보 보호 교육 실시" left="60" top="sta00_03_00_00_00_00_01_00_01_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_03_00_00_00_00_01_00_01_01" taborder="88" text="2. 기술적 조치 : 개인정보처리시스템 등의 접근권한 관리, 접근통제시스템 설치, 고유식별정보 등 암호화, 보안프로그램 설치 " left="50" top="sta00_03_00_00_00_00_01_00_01_00_00_00:10" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_03_00_00_00_00_01_00_01_00_00_00_00" taborder="89" text="- (개인정보 접근 제한 관리) 개인정보를 처리하는 데이터베이스시스템에 대한 접근권한의 부여, 변경, 말소 등 접근 권한 관리를 통한 접근통제 및 침입차단시스템 운영으로 외부에서 불법 접근 원천 차단" left="60" top="sta00_03_00_00_00_00_01_00_01_01:5" height="50" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_03_00_00_00_00_01_00_01_00_00_00_00_00" taborder="90" text="- (개인정보의 암호화) 개인정보(고유식별정보 등) 저장·전송 시 암호화 및 파일 잠금 기능을 사용하여 보안 강화" left="60" top="sta00_03_00_00_00_00_01_00_01_00_00_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_03_00_00_00_00_01_00_01_00_00_00_00_00_00" taborder="91" text="- (접속기록의 보관 및 위·변조 방지) 개인정보처리시스템 접속기록 최소 1년 이상 보관·관리 및 위·변조, 도난, 분실 예방관리" left="60" top="sta00_03_00_00_00_00_01_00_01_00_00_00_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_03_00_00_00_00_01_00_01_00_00_00_00_00_00_00" taborder="92" text="※ 다만, 5만 명 이상의 정보주체의 개인정보 처리, 고유식별정보 또는 민감정보를 처리하는 개인정보처리시스템의 경우 2년 이상 보관관리" left="70" top="sta00_03_00_00_00_00_01_00_01_00_00_00_00_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_03_00_00_00_00_01_00_01_00_00_00_00_00_00_00_00" taborder="93" text="- (보안프로그램 설치 및 주기적 점검·갱신) 해킹·악성코드 등 개인정보 유출 및 훼손 방지를 위한 보안프로그램을 설치·운영하고 주기적 갱신 및 점검 실시" left="60" top="sta00_03_00_00_00_00_01_00_01_00_00_00_00_00_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_03_00_00_00_00_01_00_01_01_00" taborder="94" text="3. 물리적 조치 : 전산실, 자료보관실 등의 접근통제" left="50" top="sta00_03_00_00_00_00_01_00_01_00_00_00_00_00_00_00_00:10" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_03_00_00_00_00_01_00_01_01_00_00" taborder="95" text="- (비인가자에 대한 출입 통제) 개인정보 보관 장소를 물리적으로 분리하여 출입통제 실시" left="60" top="sta00_03_00_00_00_00_01_00_01_01_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_03_00_00_00_00_01_00_01_01_00_00_00" taborder="96" text="- (문서보안을 위한 잠금장치 사용) 개인정보 포함 서류 및 보조저장매체 등은 잠금장치가 있는 안전한 장소에 보관·관리" left="60" top="sta00_03_00_00_00_00_01_00_01_01_00_00:8" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <ImageViewer id="imgTit08" taborder="97" text="제8조(개인정보 자동 수집 장치의 설치·운영 및 거부에 관한 사항)" left="30" top="sta00_03_00_00_00_00_01_00_01_01_00_00_00:30" width="500" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/ico230301_08_s.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00" taborder="98" text="① " left="30" top="imgTit08:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="첫 번째"/>
        <Static id="sta00_03_00_00_1" taborder="99" text="나이스 대국민서비스는 이용자에게 개별적인 맞춤서비스를 제공하기 위해 이용정보를 저장하고 수시로 불러오는 ‘쿠키(Cookie)’를 사용합니다." left="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00:5" top="imgTit08:20" height="25" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00" taborder="100" text="② " left="30" top="sta00_03_00_00_1:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="두 번째"/>
        <Static id="sta00_03_00_00_1_00" taborder="101" text="쿠키는 웹사이트를 운영하는데 이용되는 서버(http)가 이용자의 컴퓨터 브라우저에게 보내는 소량의 정보이며 이용자의 PC 컴퓨터내의 하드디스크에 저장되기도 합니다." left="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00:5" top="sta00_03_00_00_1:20" height="50" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00" taborder="102" text="가." left="50" top="sta00_03_00_00_1_00:10" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00" taborder="103" text="쿠키의 사용목적: 이용자가 방문한 각 서비스와 웹 사이트들에 대한 방문 및 이용형태, 인기 검색어, 보안접속 여부 등을 파악하여 이용자에게 최적화된 정보 제공을 위해 사용됩니다." left="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00:5" top="sta00_03_00_00_1_00:10" height="50" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_01" taborder="104" text="나. " left="50" top="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00:10" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00_00" taborder="105" text="쿠키의 설치∙운영 및 거부 : 브라우저 옵션 설정을 통해 쿠키 허용, 쿠키 차단 등의 설정을 할 수 있습니다." left="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_01:5" top="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00:10" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00_00_00" taborder="106" text="▶ 웹 브라우저에서 쿠키 허용/차단" left="70" top="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00_00_00_00" taborder="107" text="- 크롬(Chrome) : 웹 브라우저 설정 &gt; 개인정보 보호 및 보안 &gt; 인터넷 사용 기록 삭제" left="90" top="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00_00_00_00_00" taborder="108" text="- 엣지(Edge) : 웹 브라우저 설정 &gt; 쿠키 및 사이트 권한 &gt; 쿠키 및 사이트 데이터 관리 및 삭제" left="90" top="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00_00_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00_00_00_00_00_01" taborder="163" text="- 웨일(Whale) : 웹 브라우저 설정 &gt; 개인정보 보호 &gt; 인터넷 사용 기록 삭제" left="90" top="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00_00_00_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00_00_00_01" taborder="166" text="▶ 모바일 브라우저에서 쿠키 허용차단" left="70" top="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00_00_00_00_00_01:10" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00_00_00_00_01" taborder="167" text="- 크롬(Chrome) : 모바일 브라우저 설정 &gt; 개인정보 보호 및 보안 &gt; 인터넷 사용 기록 삭제" left="90" top="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00_00_00_01:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00_00_00_00_00_02" taborder="168" text="- 사파리(Safari) : 모바일 기기 설정 &gt; 사파리(Safari) &gt; 고급 &gt; 모든 쿠키 차단" left="90" top="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00_00_00_00_01:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00_00_00_00_00_01_00" taborder="173" text="- 삼성 인터넷 : 모바일 브라우저 설정 &gt; 인터넷 사용 기록 &gt; 인터넷 사용 기록 삭제" left="90" top="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00_00_00_00_00_02:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_01_00" taborder="174" text="다. " left="50" top="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00_00_00_00_00_01_00:10" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00_00_00_00_00_00" taborder="175" text="쿠키 저장을 거부할 경우 맞춤형 서비스 이용에 어려움이 발생할 수 있습니다." left="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_01_00:5" top="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00_00_00_00_00_01_00:10" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <ImageViewer id="imgTit09" taborder="109" text="제9조(개인정보 보호책임자에 관한 사항)" left="30" top="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_00_00_00_00_00_00_00_00:30" width="400" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/ico230301_10_s.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_03_00_00_1_01" taborder="110" text="나이스 대국민서비스는 개인정보 처리에 관한 업무를 총괄해서 책임지고, 개인정보 처리와 관련한 정보주체의 불만처리 및 피해구제 등을 위하여 아래와 같이 개인정보 보호책임자를 지정하고 있습니다." left="30" top="imgTit09:20" height="50" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_03_00_00_00_00_01_00_00_00" taborder="111" text="1. 교육부" left="50" top="sta00_03_00_00_1_01:10" height="25" cssclass="font16R, top" width="100" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <Static id="sta00_03_00_00_00_00_01_00_00_00_00" taborder="112" text="▶ 개인정보 보호 책임자&#13;&#10;       성명: 송근현&#13;&#10;       소속: 교육부 디지털교육기획관" left="60" top="sta00_03_00_00_00_00_01_00_00_00:5" height="70" cssclass="font16R, top" width="300" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <Static id="sta00_03_00_00_00_00_01_00_00_00_00_01" taborder="113" text="▶ 개인정보 보호 담당자&#13;&#10;       성명: 진경희&#13;&#10;       소속: 교육부 디지털인프라담당관 정보보호팀" left="60" top="sta00_03_00_00_00_00_01_00_00_00_00:5" height="70" cssclass="font16R, top" width="400" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <Static id="sta00_03_00_00_00_00_01_00_00_00_01_00" taborder="114" text="2. 한국교육학술정보원" left="50" top="sta00_03_00_00_00_00_01_00_00_00_00_01:10" height="25" cssclass="font16R, top" width="300" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <Static id="sta00_03_00_00_00_00_01_00_00_00_00_01_00" taborder="115" text="▶ 개인정보 보호 책임자&#13;&#10;       성명: 김태우&#13;&#10;       소속: 정보보호본부&#13;&#10;       직급: 본부장" left="60" top="sta00_03_00_00_00_00_01_00_00_00_01_00:5" height="100" cssclass="font16R, top" width="250" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <Static id="sta00_03_00_00_00_00_01_00_00_00_00_01_00_00" taborder="116" text="▶ 개인정보 보호 분야별 책임자&#13;&#10;       성명: 김은재&#13;&#10;       소속: 교육행정본부&#13;&#10;       직급: 본부장" left="60" top="sta00_03_00_00_00_00_01_00_00_00_00_01_00:5" height="100" cssclass="font16R, top" width="500" initvalueid="ivStcAccessibilityOn" fittocontents="height" usedecorate="true"/>
        <Static id="sta00_03_00_00_00_00_01_00_00_00_00_01_00_00_01" taborder="152" text="▶ 개인정보 보호 분야별 담당자(대국민서비스)&#13;&#10;       성명: 김성진&#13;&#10;       소속: 교육행정본부 나이스일반행정부&#13;&#10;       직급: 연구원" left="60" top="sta00_03_00_00_00_00_01_00_00_00_00_01_00_00:5" height="100" cssclass="font16R, top" width="400" initvalueid="ivStcAccessibilityOn" fittocontents="height" usedecorate="true"/>
        <Static id="sta00_03_00_00_00_00_01_00_00_00_01_00_01" taborder="153" text="3. 17개 시도교육청" left="50" top="sta00_03_00_00_00_00_01_00_00_00_00_01_00_00_01:10" height="25" cssclass="font16R, top" width="200" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <Static id="sta00_03_00_00_00_00_01_00_00_00_00_01_00_00_01_00" taborder="154" text="▶ 개인정보 보호 책임자 및 취급자는 해당 시도교육청 홈페이지를 참고하시기 바랍니다." left="60" top="sta00_03_00_00_00_00_01_00_00_00_01_00_01:5" height="24" cssclass="font16R, top" width="700" initvalueid="ivStcAccessibilityOn" fittocontents="height" usedecorate="true" onclick="sta00_03_00_00_00_00_01_00_00_00_00_01_00_00_01_00_onclick"/>
        <ImageViewer id="imgTit10" taborder="117" text="제10조(개인정보 열람청구)" left="30" top="sta00_03_00_00_00_00_01_00_00_00_00_01_00_00_01_00:30" width="300" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/ico230301_11_s.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_01_00" taborder="118" text="① " left="30" top="imgTit10:20" height="26" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="첫 번째"/>
        <Static id="sta00_03_00_00_1_01_00" taborder="119" text="정보주체는 「개인정보 보호법」제35조에 따른 개인정보의 열람 청구를 아래의 부서에서 할 수 있습니다. 나이스 대국민서비스는 정보주체의 개인정보 열람청구가 신속하게 처리되도록 노력하겠습니다." left="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_01_00:5" top="imgTit10:20" height="50" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_03_00_00_00_00_01_00_00_00_01_00_00" taborder="120" text="1. 한국교육학술정보원" left="50" top="sta00_03_00_00_1_01_00:5" height="25" cssclass="font16R, top" width="300" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <Static id="sta00_03_00_00_00_00_01_00_00_00_00_01_00_00_00" taborder="121" text="▶ 개인정보 열람청구 접수·처리 부서(대국민서비스)&#13;&#10;       성명: 김성진&#13;&#10;       소속: 교육행정본부 나이스일반행정부&#13;&#10;       연락처: 053-714-0141, &lt;l v='mailto:kimsj@keris.or.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;kimsj@keris.or.kr&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;" left="60" top="sta00_03_00_00_00_00_01_00_00_00_01_00_00:5" height="100" cssclass="font16R, top" width="500" initvalueid="ivStcAccessibilityOn" fittocontents="height" usedecorate="true"/>
        <Static id="sta00_03_00_00_00_00_01_00_00_00_01_00_00_00" taborder="122" text="2. 교육부" left="50" top="sta00_03_00_00_00_00_01_00_00_00_00_01_00_00_00:10" height="25" cssclass="font16R, top" width="200" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <Static id="sta00_03_00_00_00_00_01_00_00_00_00_01_00_00_00_00" taborder="123" text="▶ 개인정보 열람청구 접수·처리 부서&#13;&#10;       성명: 진경희&#13;&#10;       소속: 디지털인프라담당관&#13;&#10;       연락처: 044-203-6514, &lt;l v='mailto:heeyajin@korea.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;heeyajin@korea.kr&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;" left="60" top="sta00_03_00_00_00_00_01_00_00_00_01_00_00_00:5" height="100" cssclass="font16R, top" width="450" initvalueid="ivStcAccessibilityOn" fittocontents="height" usedecorate="true"/>
        <Static id="sta00_03_00_00_00_00_01_00_00_00_01_00_00_00_00" taborder="124" text="3. 17개 시도교육청" left="50" top="sta00_03_00_00_00_00_01_00_00_00_00_01_00_00_00_00:10" height="25" cssclass="font16R, top" width="300" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <Static id="sta00_03_00_00_00_00_01_00_00_00_00_01_00_00_00_00_00" taborder="125" text="▶ 개인정보 열람청구 접수·처리 부서는 해당 시도교육청 홈페이지를 참조하시기 바랍니다." left="60" top="sta00_03_00_00_00_00_01_00_00_00_01_00_00_00_00:5" height="24" cssclass="font16R, top" width="700" initvalueid="ivStcAccessibilityOn" fittocontents="height" usedecorate="false"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_01_00_00" taborder="126" text="② " left="30" top="sta00_03_00_00_00_00_01_00_00_00_00_01_00_00_00_00_00:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="두 번째"/>
        <Static id="sta00_03_00_00_1_01_00_00" taborder="127" text="정보주체는 제1항의 열람청구 담당부서 이외에, ‘개인정보보호 포털’ 웹사이트(&lt;l v='http://www.privacy.go.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;www.privacy.go.kr&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;)를 통하여서도 개인정보 열람청구를 하실 수 있습니다. " left="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_01_00_00:5" top="sta00_03_00_00_00_00_01_00_00_00_00_01_00_00_00_00_00:20" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" usedecorate="true" right="30"/>
        <Static id="sta00_03_00_00_00_00_01_00_00_00_00_01_00_00_00_00_00_00" taborder="128" text="▶ 개인정보보호 포털 → 민원마당 → 개인정보 열람등 요구 (휴대폰 본인인증 필요)" left="60" top="sta00_03_00_00_1_01_00_00:5" height="24" cssclass="font16R, top" width="700" initvalueid="ivStcAccessibilityOn" fittocontents="height" usedecorate="false"/>
        <ImageViewer id="imgTit11" taborder="129" text="제11조(권익침해 구제방법)" left="30" top="sta00_03_00_00_00_00_01_00_00_00_00_01_00_00_00_00_00_00:30" width="300" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/ico230301_12_s.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_01_00_00_00" taborder="130" text="① " left="30" top="imgTit11:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="첫 번째"/>
        <Static id="sta00_03_00_00_1_01_00_00_00" taborder="131" text="정보주체는 개인정보침해로 인한 구제를 받기 위하여 개인정보분쟁조정위원회, 한국인터넷진흥원 개인정보침해신고센터 등에 분쟁해결이나 상담 등을 신청할 수 있습니다. 이 밖에 기타 개인정보침해의 신고, 상담에 대하여는 아래의 기관에 문의하시기 바랍니다." left="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_01_00_00_00:5" top="imgTit11:20" height="50" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_03_00_00_1_01_00_00_00_00" taborder="132" text="1. 개인정보분쟁조정위원회 : (국번없이) 1833-6972 (&lt;l v='http://www.kopico.go.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;www.kopico.go.kr&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;)" left="50" top="sta00_03_00_00_1_01_00_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" usedecorate="true" right="30"/>
        <Static id="sta00_03_00_00_1_01_00_00_00_00_00" taborder="133" text="2. 개인정보침해신고센터 : (국번없이) 118 (&lt;l v='http://www.privacy.kisa.or.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;privacy.kisa.or.kr&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;)" left="50" top="sta00_03_00_00_1_01_00_00_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" usedecorate="true" right="30"/>
        <Static id="sta00_03_00_00_1_01_00_00_00_00_00_00" taborder="134" text="3. 대검찰청 : (국번없이) 1301 (&lt;l v='http://www.spo.go.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;www.spo.go.kr&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;)" left="50" top="sta00_03_00_00_1_01_00_00_00_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" usedecorate="true" right="30"/>
        <Static id="sta00_03_00_00_1_01_00_00_00_00_00_00_00" taborder="135" text="4. 경찰청 : (국번없이) 182 (&lt;l v='http://ecrm.police.go.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;ecrm.police.go.kr&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;)" left="50" top="sta00_03_00_00_1_01_00_00_00_00_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" usedecorate="true" right="30"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_01_00_00_00_00" taborder="136" text="②" left="30" top="sta00_03_00_00_1_01_00_00_00_00_00_00_00:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="두 번째"/>
        <Static id="sta00_03_00_00_1_01_00_00_00_01" taborder="137" text="「개인정보 보호법」제35조(개인정보의 열람), 제36조(개인정보의 정정·삭제), 제37조(개인정보의 처리정지 등)의 규정에 의한 요구에 대하여 공공기관의 장이 행한 처분 또는 부작위로 인하여 권리 또는 이익의 침해를 받은 자는 행정심판법이 정하는 바에 따라 행정심판을 청구할 수 있습니다." left="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_01_00_00_00_00:5" top="sta00_03_00_00_1_01_00_00_00_00_00_00_00:20" height="50" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_03_00_00_1_01_00_00_00_01_00" taborder="138" text="※ 행정심판에 대해 자세한 사항은 중앙행정심판위원회((국번없이) 110, &lt;l v='http://www.simpan.go.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;www.simpan.go.kr&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;) 홈페이지를 참고하시기 바랍니다." left="60" top="sta00_03_00_00_1_01_00_00_00_01:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" usedecorate="true" right="30"/>
        <ImageViewer id="imgTit12" taborder="139" text="제12조(가명정보의 처리)" left="30" top="sta00_03_00_00_1_01_00_00_00_01_00:30" width="300" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/ico230301_09_s.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_03_00_00_00_00_01_00_00_00_02_01_01" taborder="140" text="나이스 대국민서비스에서 가명정보를 처리하는 경우, 본 개인정보 처리방침을 통해 아래와 같은 가명정보 처리에 관한 사항을 안내드리겠습니다." left="30" top="imgTit12:20" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_00_01_00_00_00_00_00_00_00_00_00_00_00_00" taborder="141" text="▶ 가명정보의 처리 목적&#13;&#10;▶ 가명정보의 처리 및 보유기간&#13;&#10;▶ 가명정보의 제3자 제공에 관한 사항&#13;&#10;▶ 가명정보 처리의 위탁에 관한 사항&#13;&#10;▶ 처리하는 가명정보의 항목&#13;&#10;▶「개인정보 보호법」제28조의4(가명정보에 대한 안전조치 의무 등)에 따른 가명정보의 안전성 확보조치에 관한 사항" left="40" top="sta00_03_00_00_00_00_01_00_00_00_02_01_01:10" height="130" cssclass="font16R, top" width="1000" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <ImageViewer id="imgTit13" taborder="142" text="제13조(추가적인 이용·제공 판단기준)" left="30" top="sta00_01_00_01_00_00_00_00_00_00_00_00_00_00_00_00:30" width="400" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/ico230301_13_s.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_03_00_00_00_00_01_00_00_00_02_01_01_00" taborder="143" text="나이스 대국민서비스는 「개인정보 보호법」제15조제3항 및 제17조제4항에 따라 동법 시행령 제14조의2에 따른 사항을 고려하여 정보주체의 동의없이 개인정보를 추가적으로 이용·제공할 수 있습니다. 이에 따라 나이스 대국민서비스는 정보주체의 동의없이 추가적인 이용·제공을 하기 위해서 다음과 같은 사항을 고려하였습니다." left="30" top="imgTit13:20" height="70" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="staLast" taborder="144" text="▶ 개인정보를 추가적으로 이용·제공하려는 목적이 당초 수집 목적과 관련성이 있는지 여부&#13;&#10;▶ 개인정보를 수집한 정황 또는 처리 관행에 비추어 볼 때 추가적인 이용·제공에 대한 예측 가능성이 있는지 여부&#13;&#10;▶ 개인정보의 추가적인 이용·제공이 정보주체의 이익을 부당하게 침해하는지 여부&#13;&#10;▶ 가명처리 또는 암호화 등 안전성 확보에 필요한 조치를 하였는지 여부" left="40" top="sta00_03_00_00_00_00_01_00_00_00_02_01_01_00:10" height="80" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <ImageViewer id="imgTit14" taborder="145" text="제14조(개인정보 처리방침 변경)" left="30" top="staLast:30" width="400" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/ico230301_14_s.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_01_00_00_00_00_00" taborder="146" text="① " left="30" top="imgTit14:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="첫 번째"/>
        <Static id="sta00_03_00_00_1_01_00_00_00_01_00_00" taborder="147" text="이 개인정보 처리방침은 2025. 3. 20.부터 적용됩니다." left="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_01_00_00_00_00_00:5" top="imgTit14:20" height="25" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_01_00_00_00_00_00_00" taborder="148" text="② " left="30" top="sta00_03_00_00_1_01_00_00_00_01_00_00:10" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="두 번째"/>
        <Static id="sta00_03_00_00_1_01_00_00_00_01_00_00_00" taborder="149" text="이전의 개인정보 처리방침은 [이력보기 드롭박스]에서 확인하실 수 있습니다." left="sta00_02_01_00_00_01_01_01_01_00_00_00_00_00_01_00_00_00_00_00_00:5" top="sta00_03_00_00_1_01_00_00_00_01_00_00:10" height="25" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="staBeforePrivetePolicy" taborder="150" text="▶ 나이스 대국민서비스" left="50" top="sta00_03_00_00_1_01_00_00_00_01_00_00_00:5" height="50" cssclass="font16R, top" width="200" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <Combo id="cboBeforePrivetePolicy" taborder="151" text="이전 개인정보 처리방침 보기" width="280" height="50" value="" index="0" left="staBeforePrivetePolicy:10" initvalueid="ivCmbNormal" top="sta00_03_00_00_1_01_00_00_00_01_00_00_00:5" innerdataset="dsBeforePolicyList" codecolumn="file" datacolumn="name" onitemchanged="cboBeforePrivetePolicy_onitemchanged" cssclass="Pas"/>
