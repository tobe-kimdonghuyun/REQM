        <ImageViewer id="imgTit01" taborder="1" text="제1조(개인정보의 처리목적)" left="30" top="divTop:30" width="350" height="70" cssclass="font16B_icon" imagealign="left middle" image="url('imagerc::policy/ico230301_01_s.png')" background="transparent" stretch="none" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_02" taborder="2" text="①" left="30" top="imgTit01:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="첫 번째"/>
        <Static id="sta00" taborder="3" text="나이스 대국민서비스는 다음의 목적을 위하여 개인정보를 처리합니다. 처리하고 있는 개인정보는 다음의 목적 이외의 용도로는 이용되지 않으며, 이용 목적이 변경되는 경우에는 「개인정보 보호법」제18조에 따라 별도의 동의를 받는 등 필요한 조치를 이행할 예정입니다.&#13;&#10;이에 「개인정보 보호법」 제30조에 따라 정보주체에게 개인정보 처리에 관한 절차 및 기준을 안내하고, 이와 관련한 고충을 신속하고 원활하게 처리할 수 있도록 하기 위하여 다음과 같이 개인정보 처리방침을 수립·공개합니다." left="sta00_02:5" top="imgTit01:20" height="90" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01" taborder="4" text="1. 홈페이지 회원 가입 및 관리" left="50" top="sta00:10" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" width="250"/>
        <Static id="sta00_01_03" taborder="5" text="회원 가입의사 확인, 회원제 서비스 제공에 따른 본인 식별·인증, 회원자격 유지·관리, 제한적 본인확인제 시행에 따른 본인확인, 서비스 부정이용 방지(가입 및 가입횟수 제한), 만 14세 미만 아동의 개인정보 처리 시 법정대리인의 동의여부 확인, 향후 분쟁조정을 위한 기록보존, 불만처리 등을 위한 원활한 의사소통 경로의 확보, 각종 고지·통지 등을 목적으로 개인정보를 처리합니다." left="60" top="sta00_01:5" height="70" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_01" taborder="6" text="2. 홈페이지를 통한 나이스 업무 정보 조회 및 확인" left="50" top="sta00_01_03:10" height="24" cssclass="font16R, top" width="400" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <Static id="sta00_01_03_00" taborder="7" text="나이스 대국민서비스(검정고시, 교육비 원클릭 신청시스템, 업무지원, 학생·학부모 참여 설문조사)를 통해 응시자 정보 확인, 학부모의 학생 정보 조회, 외부 업체와 교육행정기관 및 교육기관의 업무처리 정보 조회의 목적으로 개인정보를 처리합니다. " left="60" top="sta00_01_01:5" height="50" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_01_00" taborder="8" text="3. 웹사이트 관리" left="50" top="sta00_01_03_00:10" height="24" cssclass="font16R, top" width="130" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <Static id="sta00_01_03_00_00" taborder="9" text="서비스 이용에 따른 사용자 정보 수집 및 관리, 서비스 부정이용 방지, 각종 고지·통지, 고충처리 목적으로 개인정보를 처리합니다." left="60" top="sta00_01_01_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_01_00_00" taborder="10" text="4. 민원사무 처리" left="50" top="sta00_01_03_00_00:10" height="24" cssclass="font16R, top" width="130" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <Static id="sta00_01_03_00_00_00" taborder="11" text="민원인의 신원 확인, 민원사항 확인, 사실조사를 위한 연락·통지, 처리결과 통보의 목적으로 개인정보를 처리합니다." left="60" top="sta00_01_01_00_00:5" height="24" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_01_01_00_00_00" taborder="12" text="5. 서비스 개선" left="50" top="sta00_01_03_00_00_00:10" height="24" cssclass="font16R, top" width="130" initvalueid="ivStcAccessibilityOn" fittocontents="height"/>
        <Static id="sta00_01_03_00_00_00_00" taborder="13" text="신규 서비스 개발 및 특화, 개인별 맞춤서비스를 제공하기 위한 자료, 접속 빈도 파악, 회원의 서비스 이용에 대한 통계, 새로운 서비스 및 이벤트 정보 등의 안내를 위해 개인정보를 처리합니다." left="60" top="sta00_01_01_00_00_00:5" height="50" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Static id="sta00_02_01" taborder="14" text="②" left="30" top="sta00_01_03_00_00_00_00:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="두 번째"/>
        <Static id="sta00_04" taborder="15" text="나이스 대국민서비스가 홈페이지를 통해 제공하는 서비스 항목은 다음과 같습니다." left="sta00_02_01:5" top="sta00_01_03_00_00_00_00:20" height="25" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Div id="div00" taborder="16" left="30" top="sta00_04:10" height="391" initvalueid="ivDivAccessibilityOff" right="30">
          <Layouts>
            <Layout>
              <Grid id="grd00" taborder="0" left="0" top="0" height="391" binddataset="ds00" cssclass="grd_policy_detail" initvalueid="ivGrdAccessibilityOn" autofittype="col" selecttype="cell" accessibilitylabel="제공하는 서비스 항목" right="0">
                <Formats>
                  <Format id="default">
                    <Columns>
                      <Column size="80"/>
                      <Column size="952"/>
                    </Columns>
                    <Rows>
                      <Row size="40" band="head"/>
                      <Row size="50"/>
                    </Rows>
                    <Band id="head">
                      <Cell text="번호" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                      <Cell col="1" text="서비스명" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                    </Band>
                    <Band id="body">
                      <Cell text="bind:번호" textAlign="center"/>
                      <Cell col="1" text="bind:서비스명" textAlign="center" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd"/>
                    </Band>
                  </Format>
                  <Format id="default_00">
                    <Columns>
                      <Column size="150"/>
                      <Column size="450"/>
                    </Columns>
                    <Rows>
                      <Row size="60" band="head"/>
                      <Row size="100"/>
                    </Rows>
                    <Band id="head">
                      <Cell text="번호" font="normal 700 26px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                      <Cell col="1" text="서비스명" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd" font="normal 700 26px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                    </Band>
                    <Band id="body">
                      <Cell text="bind:번호" textAlign="center" autosizerow="default" wordWrap="char"/>
                      <Cell col="1" text="bind:서비스명" textAlign="center" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd" autosizerow="default" wordWrap="char"/>
                    </Band>
                  </Format>
                </Formats>
              </Grid>
            </Layout>
            <Layout name="Layout0">
              <Grid id="grd00" cssclass="grd_policy_detail_M" height="763" left="0" top="0" right="0" autofittype="col" formatid="default_00" autosizingtype="none"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta00_02_01_00" taborder="17" text="③" left="30" top="div00:20" height="25" cssclass="font16R, top" width="20" initvalueid="ivStcAccessibilityOn" fittocontents="height" accessibilitylabel="세 번째"/>
        <Static id="sta00_04_00" taborder="18" text="나이스 대국민서비스가 「개인정보 보호법」제32조에 따라 등록·공개하는 개인정보파일의 처리목적은 아래와 같습니다." left="sta00_02_01_00:5" top="div00:20" height="25" cssclass="font16R, top" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="30"/>
        <Div id="div01" taborder="19" left="30" top="sta00_04_00:10" initvalueid="ivDivAccessibilityOff" right="30" height="3851">
          <Layouts>
            <Layout>
              <Grid id="grd03" taborder="0" left="0" top="0" cssclass="grd_policy_detail" initvalueid="ivGrdAccessibilityOn" accessibilitylabel="개인정보파일의 처리 목적" binddataset="ds01" autofittype="col" selecttype="cell" autosizingtype="row" width="1140" height="3851">
                <Formats>
                  <Format id="default">
                    <Columns>
                      <Column size="50"/>
                      <Column size="120"/>
                      <Column size="150"/>
                      <Column size="200"/>
                      <Column size="150"/>
                      <Column size="48"/>
                      <Column size="280"/>
                      <Column size="70"/>
                    </Columns>
                    <Rows>
                      <Row size="50" band="head"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                    </Rows>
                    <Band id="head">
                      <Cell text="번호" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                      <Cell col="1" text="서비스명" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                      <Cell col="2" text="개인정보&#13;&#10;파일의 명칭" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                      <Cell col="3" text="운영근거" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                      <Cell col="4" text="처리목적" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                      <Cell col="5" colspan="2" text="기록되는 개인정보의 항목" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;"/>
                      <Cell col="7" text="보유&#13;&#10;기간" font="normal 700 15px/normal &quot;Noto Sans KR Bold&quot;,&quot;NotoSansKR-Bold&quot;,&quot;Malgun Gothic&quot;" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd"/>
                    </Band>
                    <Band id="body">
                      <Cell text="1" textAlign="center" autosizerow="limitmin" wordWrap="char"/>
                      <Cell col="1" text="검정고시" textAlign="center" autosizerow="limitmin" wordWrap="char"/>
                      <Cell col="2" text="원서접수 서비스&#13;&#10;개인정보" textAlign="center" autosizerow="limitmin" wordWrap="char"/>
                      <Cell col="3" text="초중등교육법 시행령 제106조의3, 정보주체의 동의" textAlign="left" autosizerow="limitmin" wordWrap="char"/>
                      <Cell col="4" text="검정고시&#13;&#10;원서접수" textAlign="center" autosizerow="limitmin" wordWrap="char"/>
                      <Cell col="5" colspan="2" text="(필수) 성명, 성별, 생년월일, 주민등록번호(외국인등록번호), 사진, 휴대전화, 주소(상세주소), 이메일, 응시자구분, 학력구분, 졸업/재적/합격일자, 과목별응시정보, 최종학력증명서첨부, 고사장정보(선택) 일반전화, 장애구분(장애인구분, 장애유형, 편의제공 신청내용), 재소구분, 학교명, 기합격과목정보" wordWrap="char" autosizerow="limitmin" textAlign="left"/>
                      <Cell col="7" text="3년" textAlign="center" autosizerow="limitmin" wordWrap="char" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd"/>
                      <Cell row="1" rowspan="5" textAlign="center" text="2" autosizerow="limitmin" wordWrap="char"/>
                      <Cell row="1" col="1" rowspan="5" textAlign="center" text="학원서비스" autosizerow="limitmin" wordWrap="char"/>
                      <Cell row="1" col="2" textAlign="center" text="학원민원 신고대상&#13;&#10;강사정보" autosizerow="limitmin" wordWrap="char"/>
                      <Cell row="1" col="3" textAlign="left" text="학원의 설립‧운영 및 과외교습에 관한 법률 시행령 제19조, 정보주체의 동의" autosizerow="limitmin" wordWrap="char"/>
                      <Cell row="1" col="4" textAlign="center" text="학원민원 신고대상&#13;&#10;강사정보" autosizerow="limitmin" wordWrap="char"/>
                      <Cell row="1" col="5" colspan="2" text="(필수) 성명, 주민등록번호, 전화번호, 이메일, 전공, 자격증, 채용일, 교습과목, 증빙서류제출방식(직접방문, 등기우편, 온라인), 주소, 학력, 강사구분, 자격구분, 외국인강사체류자코드, 증빙서류첨부, 강사 성범죄 및 아동학대 정보(성범죄경력여부, 경찰서명, 아동학대여부, 회신받은날자), 강사학력정보(학교,학과,학위번호, 졸업일자(필수입력)), 채용일, 해임일, 해임사유" wordWrap="char" autosizerow="limitmin" textAlign="left"/>
                      <Cell row="1" col="7" textAlign="center" text="1년" autosizerow="limitmin" wordWrap="char" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd"/>
                      <Cell row="2" col="2" textAlign="center" text="학원민원 신청인 정보" autosizerow="limitmin" wordWrap="char"/>
                      <Cell row="2" col="3" textAlign="left" text="학원의 설립‧운영 및 과외교습에 관한 법률 시행령 제19조, 정보주체의 동의" autosizerow="limitmin" wordWrap="char"/>
                      <Cell row="2" col="4" textAlign="center" text="학원민원 신청인" autosizerow="limitmin" wordWrap="char"/>
                      <Cell row="2" col="5" colspan="2" text="(필수)성명, 주민등록번호, 전화번호, 휴대폰, 주소" wordWrap="char" autosizerow="limitmin" textAlign="left"/>
                      <Cell row="2" col="7" textAlign="center" text="1년" autosizerow="limitmin" wordWrap="char" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd"/>
                      <Cell row="3" col="2" textAlign="center" text="신고대상&#13;&#10;임시 교습자/&#13;&#10;보조요원 정보" autosizerow="limitmin" wordWrap="char"/>
                      <Cell row="3" col="3" textAlign="left" text="학원의 설립‧운영 및 과외교습에 관한 법률 시행령 제19조, 정보주체의 동의" autosizerow="limitmin" wordWrap="char"/>
                      <Cell row="3" col="4" textAlign="center" text="신고대상 임시 교습자/&#13;&#10;보조요원 정보" autosizerow="limitmin" wordWrap="char"/>
                      <Cell row="3" col="5" colspan="2" text="(필수) 성명, 주민등록번호, 이메일, 학력, 전공, 채용일, 자격구분, 증빙자료 제출방식(직접방문, 등기우편, 온라인), 전화번호, 주소, 증빙서류, 성범죄 및 아동학대정보(성범죄경력여부, 경찰서명, 아동학대여부, 회신받은일자), 채용일, 해임일, 해임사유" wordWrap="char" autosizerow="limitmin" textAlign="left"/>
                      <Cell row="3" col="7" textAlign="center" text="1년" autosizerow="limitmin" wordWrap="char" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd"/>
                      <Cell row="4" col="2" textAlign="center" text="교습소 민원&#13;&#10;신청인 정보" autosizerow="limitmin" wordWrap="char"/>
                      <Cell row="4" col="3" textAlign="left" text="학원의 설립‧운영 및 과외교습에 관한 법률 시행령 제19조, 정보주체의 동의" autosizerow="limitmin" wordWrap="char"/>
                      <Cell row="4" col="4" textAlign="center" text="교습소 민원 신청" autosizerow="limitmin" wordWrap="char"/>
                      <Cell row="4" col="5" colspan="2" text="(필수) 성명, 주민등록번호(외국인등록번호), 전화번호, 휴대전화, 주소" wordWrap="char" autosizerow="limitmin" textAlign="left"/>
                      <Cell row="4" col="7" textAlign="center" text="1년" autosizerow="limitmin" wordWrap="char" border="1px solid #dddddd,0px none,1px solid #dddddd,1px solid #dddddd"/>
                      <Cell row="5" col="2" textAlign="center" text="개인과외교습자&#13;&#10;민원정보" autosizerow="limitmin" wordWrap="char"/>
                      <Cell row="5" col="3" textAlign="left" text="학원의 설립‧운영 및 과외교습에 관한 법률 시행령 제19조, 정보주체의 동의" autosizerow="limitmin" wordWrap="char"/>
                      <Cell row="5" col="4" textAlign="center" text="개인과외교습자&#13;&#10;민원신청" autosizerow="limitmin" wordWrap="char"/>
