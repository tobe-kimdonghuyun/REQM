  <Form id="framePolicy_New_01" width="1200" height="13550" titletext="개인정보처리방침 (기본 서브포탈)" top="0" onload="framePolicy_New_01_onload">
    <Layouts>
      <Layout height="13550" screenid="ScreenDeskTop" width="1200">
        <Div id="divTop" taborder="0" left="0" top="0" height="1730" cssclass="div_roundBox20_BG" initvalueid="ivDivAccessibilityOn" text="" right="0">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" text="나이스 대국민서비스와 관련하여 교육부 및 17개 시도교육청(소속 지원청, 학교 포함)으로부터 시스템 유지관리 및 서비스운영 업무를 위탁받은 수탁사인 한국교육학술정보원(이하 KERIS)는 개인정보 보호법 제30조(개인정보처리방침의 수립 및 공개)에 따라 정보주체의 개인정보를 보호하고 이와 관련한 고충을 신속하고 원활하게 처리할 수 있도록 하기 위하여 다음과 같이 개인정보처리방침을 수립·공개합니다." left="30" top="30" height="90" cssclass="font16R" initvalueid="ivStcAccessibilityOn" right="30"/>
              <Static id="sta01" taborder="1" text="[주요 개인정보 처리 표시(라벨링)]" left="30" top="sta00:30" width="270" height="24" cssclass="font16B" initvalueid="ivStcAccessibilityOn"/>
              <Button id="btnLinkText1" taborder="2" text="제1조&#13;&#10;처리목적" left="33" top="sta01:20" width="140" height="140" cssclass="btn_polivy_linkTextB" initvalueid="ivBtnAccessibilityButton" icon="url('imagerc::policy/ico230301_01.png')" onclick="Button_onclick" moveComp="1"/>
              <Button id="btnLinkText2" taborder="3" text="제2조&#13;&#10;보유기간" left="193" top="sta01:20" width="140" height="140" cssclass="btn_polivy_linkTextB" initvalueid="ivBtnAccessibilityButton" icon="url('imagerc::policy/ico230301_02.png')" onclick="Button_onclick" moveComp="2"/>
