<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frameTop2" width="1920" height="140" titletext="학생정서-헤더" onload="fnOnload" onsize="frameTop2_onsize" ontimer="frameTop2_ontimer">
    <Layouts>
      <Layout height="140" width="1920" screenid="ScreenDeskTop">
        <Button id="btnFirstFocus" taborder="0" left="-46" top="0" width="96" height="0" accessibilityrole="static"/>
        <Div id="divSkip" taborder="1" left="0" top="0" height="60" background="#2c569b" onkillfocus="divSkip_onkillfocus" onsetfocus="divSkip_onsetfocus" visible="true" initvalueid="ivDivAccessibilityOff" width="1920">
          <Layouts>
            <Layout>
              <Button id="btnGobody" taborder="0" text="본문바로가기" left="18" top="5" width="190" onclick="divSkip_btnGobody_onclick" borderRadius="6px" border="0px none" height="50" initvalueid="ivBtnAccessibilityButton"/>
              <Static id="sta00" taborder="1" text="해당 시스템을 이용하실 때 스크린리더를 사용하는 분들을 위한 안내페이지를 참조하시기 바랍니다." left="226" top="5" wordWrap="char" right="50" color="#ffffff" height="50" initvalueid="ivStcAccessibilityOn"/>
            </Layout>
            <Layout name="Layout0"/>
          </Layouts>
        </Div>
        <Div id="divMain" taborder="2" left="0" top="0" height="140" cssclass="div_TF_Survey02" initvalueid="ivDivAccessibilityOff" text="" right="0">
          <Layouts>
            <Layout>
              <Static id="staRightBg" taborder="0" width="321" height="136" right="0" bottom="0" initvalueid="ivStcAccessibilityOff" cssclass="sta_TF_SurvGraph02"/>
              <Static id="staTitle" taborder="1" text="&lt;b v='true'&gt;학생정서ㆍ행동특성검사&lt;/b&gt;" left="360" top="8" width="600" height="55" cssclass="sta_WF_SurvMainTxt" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
              <Static id="staPtptPrd" taborder="2" left="360" top="69" width="940" height="29" cssclass="sta_WF_YellowTxt" initvalueid="ivStcAccessibilityOn" usedecorate="false" wordWrap="english"/>
              <Static id="staPtptCn" taborder="3" text="본 검사는 학생들의 성격특성과 정서행동발달 경향을 이해하고 정서적으로 건강하게 성장할 수 있도록, 도움을 주기 위해 실시하는 검사입니다." left="360" top="99" width="1200" height="27" cssclass="sta_WF_SurvSubTxt" initvalueid="ivStcAccessibilityOn" usedecorate="false" font="17px/1.2 &quot;Noto Sans KR&quot;,&quot;NotoSansKR-Regular&quot;,&quot;Malgun Gothic&quot;,&quot;Arial&quot;,&quot;MS PGothic&quot;"/>
              <Div id="div00" taborder="4" top="7" width="428" height="24" initvalueid="ivDivAccessibilityOff" left="staTitle:179">
                <Layouts>
                  <Layout>
                    <Button id="btnHome" taborder="0" text="처음화면" left="0" top="0" width="59" height="24" cssclass="btn_TF_SurvHome" initvalueid="ivBtnAccessibilityButton" enable="true" onclick="divMain_btnHome_onclick"/>
                    <Static id="sta00" taborder="1" left="58" top="8" width="5" height="9" cssclass="sta_TF_SectionLine02" initvalueid="ivStcAccessibilityOff"/>
                    <Button id="btnGudn" taborder="2" text="검사참여안내" left="65" top="0" width="81" height="24" cssclass="btn_TF_Survbtn" initvalueid="ivBtnAccessibilityButton" enable="true" onclick="fnBtnGudn"/>
                    <Static id="sta01" taborder="3" left="145" top="8" width="5" height="9" cssclass="sta_TF_SectionLine02" initvalueid="ivStcAccessibilityOff"/>
                    <Button id="btnQna" taborder="4" text="자주 묻는 질문" left="152" top="0" width="86" height="24" cssclass="btn_TF_Survbtn" initvalueid="ivBtnAccessibilityButton" enable="true" onclick="fnBtnQna"/>
                    <Static id="sta02" taborder="5" left="238" top="8" width="5" height="9" cssclass="sta_TF_SectionLine02" initvalueid="ivStcAccessibilityOff" visible="true"/>
                    <Button id="btnCddcdInfo" taborder="7" text="시도교육청 문의 및 상담번호 안내" top="0" width="176" height="24" cssclass="btn_TF_SurvAdvcNmb" initvalueid="ivBtnAccessibilityButton" textAlign="right" left="248" onclick="divMain_btnCddcdInfo_onclick" visible="true"/>
                  </Layout>
                  <Layout name="Layout0">
                    <Button id="btnQna" left="152" top="0" width="86" height="24"/>
                  </Layout>
                </Layouts>
              </Div>
              <Button id="btnBfr" taborder="5" top="40" height="32" cssclass="btn_TF_SurveyBack" initvalueid="ivBtnAccessibilityButton" width="32" left="staTitle:568" enable="true" visible="false" onclick="divMain_btnBfr_onclick" accessibilitylabel="뒤로가기"/>
              <Button id="btnHome" taborder="6" top="40" height="32" initvalueid="ivBtnAccessibilityButton" width="32" left="2068" enable="true" visible="false" onclick="divMain_btnHome_onclick"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="staTitle" cssclass="sta_WF_WhiteTxt36B" left="20.00%" top="27" height="50" textAlign="center" minwidth="300" maxwidth="" taborder="0" text="학생정서ㆍ행동특성검사" right="10.94%"/>
              <Static id="staPtptCn" visible="false" left="1172" top="385" width="330" height="30" taborder="3"/>
              <Static id="staPtptPrd" left="20" height="68" cssclass="sta_WF_YellowTxt24,back0f6b3e_M" right="20" taborder="1" top="96"/>
              <Static id="staRightBg" visible="false" width="80" height="66" right="-627" bottom="-346" taborder="2"/>
              <Button id="btnBfr" left="72" top="34" width="5%" height="32" taborder="3" visible="false"/>
              <Div id="div00" visible="false"/>
              <Button id="btnHome" left="20" top="34" width="5%" height="32" cssclass="btn_TF_SurvHome" visible="true"/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
      <Layout name="Layout0" screenid="mobile,tablet" width="640" height="174" mobileorientation="portrait" type="default">
        <Div id="divMain" height="174" left="0" top="0" right="0" cssclass="div_TF_Survey02_M"/>
      </Layout>
    </Layouts>
    <Objects/>
    <Script type="xscript5.1"><![CDATA[ /**
*  @MenuPath    교육설문 > 학생정서행동특성검사(헤더)
*  @FileName 	frameTop2.xfdl
*  @Creator 	kangchaeyoon
*  @CreateDate 	2022.11.24
*  @Desction    학생정서행동특성검사(헤더)
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.11.24           Kangchaeyoon                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::eds_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
//세션 잔여시간
this.fvMaxTimeoutMin = 30; //총잔여시간
this.fvTimerId = 1800;	//타이머ID
this.sesnTime = new Date().setMinutes(new Date().getMinutes() + Number(this.fvMaxTimeoutMin));	//현재시각 + 세션시간

this.fv_cddcCd;	// 시도교육청코드	
this.fv_cddcNm;	// 시도교육청명
this.fvBackArray = new Array();
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.setTimer(this.fvTimerId, 1000);
	
	this.divSkip.set_height(0);

	if( nexacro.getEnvironment().enableaccessibility && !this.smfIsMobile() ) {
		this.btnFirstFocus.set_text("Ctrl + Shift + F11 키를 동시에 눌러 스크린리더의 가상커서를 설정하신 후 이용하시기 바랍니다.");
	}
	this.btnFirstFocus.setFocus();
	
	if( this.smfIsMobile()){
		this.divSkip.set_visible(false);
	}

	//검사참여기간 세팅
	this.fnSetPtptPrd();
	
	this.fnDisplAlign();
	
	var sUrl = this.parent.parent.parent.url;
	this.fvBackArray = this.getOwnerFrame().form._eds_back_formUrl || (new Array());
	if (!this.smfIsNull(this.fvBackArray)) {
		var backUrl = this.fvBackArray[this.fvBackArray.length-1];
		if(sUrl == backUrl) this.fvBackArray.pop();
		this.getOwnerFrame().form._eds_back_formUrl = this.fvBackArray;
	}
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnPopupCallback = function(e, sender){
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 검사기간 세팅
*/
this.fnSetPtptPrd = function()
{
	//임시 날짜 데이터 세팅
	var prdText = this.fnChkPeriod("seo", null);
	this.divMain.form.staPtptPrd.set_text(prdText[5]);
}

/**
 * @description 검사참여안내 화면 호출
*/
this.fnBtnGudn = function()
{
	//'<-' 버튼 클릭 시 돌아갈 url 세팅
	var sUrl = this.parent.parent.parent.url;
	if (this.smfIsNull(this.getOwnerFrame().form._eds_back_formUrl)) {
		this.fvBackArray.push(sUrl);
	}else{
		this.fvBackArray = this.getOwnerFrame().form._eds_back_formUrl;
		if (this.fvBackArray[this.fvBackArray.length -1] != sUrl) {
			this.fvBackArray.push(sUrl);
		}
	}
	this.fnSetInfo(sUrl);
	
	var param = {
		cddcCd : this.fv_cddcCd,
		cddcNm : this.fv_cddcNm
	};
	var sUrl = "pa_eds_seg_oi::eds_segoi01_m02.xfdl";
	this.smfSetWorkPage(sUrl,param, false);
};

/**
 * @description 자주묻는질문 화면 호출
*/
this.fnBtnQna = function()
{
	//'<-' 버튼 클릭 시 돌아갈 url 세팅
	var sUrl = this.parent.parent.parent.url;
	if (this.smfIsNull(this.getOwnerFrame().form._eds_back_formUrl)) {
		this.fvBackArray.push(sUrl);
	}else{
		this.fvBackArray = this.getOwnerFrame().form._eds_back_formUrl;
		if (this.fvBackArray[this.fvBackArray.length -1] != sUrl) {
			this.fvBackArray.push(sUrl);
		}
	}
	this.fnSetInfo(sUrl);
	
	var param = {
		cddcCd : this.fv_cddcCd,
		cddcNm : this.fv_cddcNm
	};
	var sUrl = "pa_eds_seg_oi::eds_segoi01_m04.xfdl";
	this.smfSetWorkPage(sUrl,param, false);
};

/**
 * @description 이전 페이지 url 불러오기
*/
this.fnSetInfo = function(sUrl)
{
	this.getOwnerFrame().form._eds_back_formUrl = this.fvBackArray;
}

/**
 * @description 이전 페이지 url 세팅
*/
this.fnGetInfo = function()
{
	this.fvBackArray = this.getOwnerFrame().form._eds_back_formUrl;
	var backUrl = this.fvBackArray[this.fvBackArray.length-1];
	this.fvBackArray.pop();
	this.getOwnerFrame().form._eds_back_formUrl = this.fvBackArray;
	return backUrl;
}

/**
 * @description '<-' 버튼 활성화
*/
this.fnBtnBack = function()
{
	var sUrl = this.fnGetInfo();
	this.divMain.form.btnBfr._url = sUrl;
	
	this.fnSetInfo(sUrl);
}

/**
 * @description '홈', '<-' 버튼 비활성화 처리(모바일)
*/
this.fnSetTopFrameBtnVisible = function(bShow1, bShow2)
{
	this.divMain.form.btnHome.set_visible(bShow1);
	this.divMain.form.btnBfr.set_visible(bShow2);
}

/**
 * 헤더 화면 정렬
 * @param : N/A
 */
this.fnDisplAlign = function(){
	if(!this.smfIsMobile()){ // PC
		var nMaxWidth = 1200;
		var nFormWidth = this.parent.getOffsetWidth();
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.divMain.form.staTitle.setOffsetLeft(nLeft);
			this.divMain.form.staPtptPrd.setOffsetLeft(nLeft);
			this.divMain.form.staPtptCn.setOffsetLeft(nLeft);
		}else{
			var nLeft = 0;
			this.divMain.form.staTitle.setOffsetLeft(nLeft);
			this.divMain.form.staPtptPrd.setOffsetLeft(nLeft);
			this.divMain.form.staPtptCn.setOffsetLeft(nLeft);
		}
		this.divMain.form.resetScroll();
	}
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description '처음화면' 버튼 클릭 시
*/
this.divMain_btnHome_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	window.location.replace(window.location.protocol + "//" + window.location.host);
};

/**
 * @description '시도교육청 문의 및 상담번호 안내' 버튼 클릭 시
*/
this.divMain_btnCddcdInfo_onclick = function()	// 2023 연락처 전달 받을 시 수정
{
	var popupParams = {
		callback: this.fnPopupCallback,		// 콜백함수 지정
		sender: obj, 						// sender 지정
		params: {							// 팝업 전달 파라메터 지정
			procType: "none"				// 처리타입 지정
		},
		titlebar : false
	};
	this.smfDialog("_auto", "pa_eds_seg_oi::eds_segoi01_p01.xfdl" ,popupParams);
};

/**
 * @description '<-' 버튼 클릭 시
*/
this.divMain_btnBfr_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//sUrl 세팅
	this.fnBtnBack();
	
	var sUrl = obj._url;
	if(this.smfIsNull(sUrl)){ //sUrl이 없을 때 처리
		return false;
	}

	var param = {
		ptptKndCd : '2',
		cddcCd : this.fv_cddcCd,
		cddcNm : this.fv_cddcNm
	};
	var sUrl = sUrl;
	this.smfSetWorkPage(sUrl,param, false);	
}

this.divSkip_onkillfocus = function(obj:nexacro.Div,e:nexacro.KillFocusEventInfo)
{
	this.divSkip.set_height(0);

	var elem = this.divSkip.getElement();
	if(elem)
	{ //겹쳐진 컴포넌트의 z-index 조절
		elem.setElementZIndex("");
	}	
};

this.divSkip_onsetfocus = function(obj:nexacro.Div,e:nexacro.SetFocusEventInfo)
{
	//this.divSkip.set_height(60);
	this.divSkip.move(0, 0, null, 60, 0);
	this.resetScroll();
	
	var elem = this.divSkip.getElement();
	if(elem)
	{ //겹쳐진 컴포넌트의 z-index 조절
		elem.setElementZIndex(1);
	}		
};

this.divSkip_btnGobody_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var divWork = this.getOwnerFrame().form.divAll.form.divWork.form.divMain;
	
	//첫번째 컴포넌트로 setFocus();
	this.fnFindFirstComp(divWork.form);
};

this.fnFindFirstComp = function(scope)
{
	var comps = scope.components;
	
	
	for(var i=0; i<comps.length; i++)
	{
		//div인 경우 내부에서 재검색
		if( comps[i].visible==true && comps[i] instanceof nexacro.Div){
			this.fnFindFirstComp(comps[i].form);
			break;
		}
		else if(comps[i].visible==true && comps[i].accessibilityenable==true){
			comps[i].setFocus();
			break;
		}
	}
};

this.frameTop2_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnDisplAlign();
};

this.frameTop2_ontimer = function(obj:nexacro.Form,e:nexacro.TimerEventInfo)
{
	if (e.timerid == this.fvTimerId) {
		var currTime = new Date().setMinutes(new Date().getMinutes());	
		var secLeft = Math.floor((this.sesnTime - currTime)/1000);	//남은 초

		// 연장팝업 (남은시간<=연장체크시간) (초로 계산)
		if(secLeft <=  0){
			this.killTimer(this.fvTimerId);
			alert("세션이 타임아웃 되었습니다. 다시 설문(검사)에 참여해 주시기 바랍니다.");
			// 메인URL로 이동한다.
			location.href="/";
		}
	}
};
]]></Script>
  </Form>
</FDL>
