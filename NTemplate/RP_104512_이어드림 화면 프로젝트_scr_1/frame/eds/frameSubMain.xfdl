    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    샘플
*  @FileName 	frameSubMain.xfdl
*  @Creator 	정인혁
*  @CreateDate 	2022.11.1
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.11.1     	정인혁 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::eds_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_ptptKndCd;		// 설문 구분

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frameSubMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitForm(this);
	
	// 메인정렬
	this.edsMainAlign();
	
	//this.divBottom.setOffsetHeight(50); 
	//this.getOwnerFrame().form.divAll.form.divWork.set_right(0);
	//this.smfResetScroll(this.divMain.form);
	
	//this.divBottom.form.fnSetBtn(0);
	
	//팝업조회
	this.fnSearchPop();
	
	// 진행중 div 표시 활성화 여부
	this.fnSelectDate();
}; 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
}

/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
}
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 서버 날짜, 시간 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSelectDate = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("select")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.edsValidate();
	});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 공통메세지 팝업 화면 호출
*/
this.fnSearchPop = function(){
	
	//팝업 설정
 	this.popInfo = {};
 	this.popInfo.id = "commNoticeAll";
 	this.popInfo.pUrl = "frame::eds/commNoticeAll.xfdl";
 	this.popInfo.callbackScope = this;
 	this.popInfo.callbackFunc = "fncommNoticeAll";
	
	//팝업조회
	this.smfSearchService("listPop")
	// 실행
	.run()
	// 콜백
	.callback(function(callbackParams){
		if(callbackParams.errors) return;

			if(this.dsListPopup.rowcount > 0){
				this.popInfo.dsListPopup =this.dsListPopup;
				this.smfDivPop(this.popInfo);
			}
	});	
}

this.fncommNoticeAll = function( pObj )
{
	if ( pObj instanceof nexacro.NormalDataset ){
		if(pObj.rowcount > 0){
			var vLnkTypCd = pObj.getColumn(0,"lnkTypCd");
			var vLnkUrl = pObj.getColumn(0,"lnkUrl");
			
			this.fnLinkPrcs(vLnkTypCd, vLnkUrl);
		}
	}
};

/**
 * @description 시도교육청 선택 화면 호출
*/
this.fnChcCddcPageCall = function(ptptKndCd){
	var param = {
		ptptKndCd : ptptKndCd
	};
	
	this.smfSetWorkPage("frame::eds/frameMap.xfdl",param,false);
}

/**
* 설문기간에 따른 div property 비활성화
* @param : N/A
* @return :  N/A
*/
this.edsValidate = function(){
	var edsList = ["seo", "vff", "shf"];
	//var edsList = ["seo", "vff", "tad", "shf"];
	var surveyDate = this.dsSearch.getColumn(0, "date");
	var surveyTime = this.dsSearch.getColumn(0, "time");
	
	var vffBgngYmd = this.dsVffDate.getColumn(0, "vffBgngYmd");
	var vffEndYmd = this.dsVffDate.getColumn(0, "vffEndYmd");
	var vffBgngTm = this.dsVffDate.getColumn(0, "vffBgngTm");
	var vffEndTm = this.dsVffDate.getColumn(0, "vffEndTm");
	
	for(var i = 0; i < 3; i++){
		if(i == 1 && ((vffBgngYmd <= surveyDate) && (surveyDate <= vffEndYmd)) && ((vffBgngTm <= surveyTime) && (surveyTime <= vffEndTm))){
			this.divMain.form.divLinkGroup.form["divLink01"].set_enable(false);
			this.divMain.form.divLinkGroup.form["divLink01"].form.btnLink.set_enable(false);
			this.divMain.form.divLinkGroup.form["divLink01"].form.btnTitle.set_enable(false);
			this.divMain.form.divLinkGroup.form["divLink01"].form.staStatus.set_text("준비중");
			
			continue;
		}

		if (this.fnChkPeriod(edsList[i], 'main', surveyDate, surveyTime)[4] == "N") {
			this.divMain.form.divLinkGroup.form["divLink0"+i].set_enable(false);
			this.divMain.form.divLinkGroup.form["divLink0"+i].form.btnLink.set_enable(false);
			this.divMain.form.divLinkGroup.form["divLink0"+i].form.btnTitle.set_enable(false);
			this.divMain.form.divLinkGroup.form["divLink0"+i].form.staStatus.set_text("준비중");
		}
	}
}

/**
* 메인화면 자동 정렬(center)
* @param : N/A
* @return :  N/A
*/
this.edsMainAlign = function ()
{
	if(!this.smfIsMobile()){
		var mainAlign = Math.floor((this.divMain.getOffsetWidth() - this.divMain.form.divLinkGroup.getOffsetWidth()) / 2);
		this.divMain.form.divLinkGroup.set_left(mainAlign);
	}
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 학교폭력 '참여하기' 버튼 클릭 시
*/
this.divMain_divLinkGroup_divLink01_btnLink_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.getOwnerFrame().form._surveyInfo_surveytype = "1";
	this.fv_ptptKndCd = '1';
	
	//시도교육청 선택 화면 호출
	this.fnChcCddcPageCall(this.fv_ptptKndCd);
};

/**
 * @description 학생정서 '참여하기' 버튼 클릭 시
*/
this.divMain_divLinkGroup_divLink00_btnLink_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	// 지정된 설문 종류를 저장해 준다(학생정서)
	this.getOwnerFrame().form._surveyInfo_surveytype = "2";
	this.fv_ptptKndCd = '2';
	
	//시도교육청 선택 화면 호출
	this.fnChcCddcPageCall(this.fv_ptptKndCd);
	
	//============= 기존 url ========
// 	var param = {};
// 	this.smfSetWorkPage("pa_eds_seg_oi::eds_segoi01_m01.xfdl",param,false);
	//================================
};

/**
 * @description 특수교육 '참여하기' 버튼 클릭 시
*/
this.divMain_divLinkGroup_divLink02_btnLink_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.getOwnerFrame().form._surveyInfo_surveytype = "4";
	this.fv_ptptKndCd = '4';
	
	//시도교육청 선택 화면 호출
	this.fnChcCddcPageCall(this.fv_ptptKndCd);
	

};

/**
 * @description 교원능력 '참여하기' 버튼 클릭 시
*/
this.divMain_divLinkGroup_divLink03_btnLink_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.getOwnerFrame().form._surveyInfo_surveytype = "3";
	this.fv_ptptKndCd = '3';
	
	// 사용자 선택화면
	var param = {
	};
	
	this.smfSetWorkPage("frame::eds/frameSelectTarget.xfdl",param,false);
	
	//============= 기존 url ========
	// 	var param = {};
	// 	this.smfSetWorkPage("pa_eds_tad_os::eds_tados01_m01.xfdl",param,false);
	//================================
	
};

/**
 * @description 화면 사이즈 변경 시
*/
this.divMain_onsize = function(obj:nexacro.Div,e:nexacro.SizeEventInfo)
{
	this.edsMainAlign();
};
]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsSearch=dsSearch dsVffDate=dsVffDate</Col>
            <Col id="url">/eds_vff_os04_001.do</Col>
            <Col id="id">select</Col>
          </Row>
          <Row>
            <Col id="id">listPop</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsListPopup=dsList</Col>
            <Col id="svctp">R</Col>
            <Col id="url">/eds_cmm_cm00_001.do</Col>
            <Col id="callback">fnTransCallBack</Col>
            <Col id="message">조회</Col>
            <Col id="asynctp"/>
            <Col id="service"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="date" type="STRING" size="256"/>
          <Column id="time" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsVffDate" useclientlayout="true">
        <ColumnInfo>
          <Column id="vffBgngYmd" type="STRING" size="256"/>
          <Column id="vffEndYmd" type="STRING" size="256"/>
          <Column id="vffBgngTm" type="STRING" size="256"/>
          <Column id="vffEndTm" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsListPopup" useclientlayout="true">
        <ColumnInfo>
          <Column id="popupId" type="string" size="256"/>
          <Column id="popupTitlNm" type="STRING" size="256"/>
          <Column id="popupCn" type="string" size="256"/>
          <Column id="comPopupYn" type="STRING" size="256"/>
          <Column id="popupTypCd" type="string" size="256"/>
          <Column id="popupTptCd" type="string" size="256"/>
          <Column id="pstStsCd" type="string" size="256"/>
          <Column id="aplcnBgngYmd" type="string" size="256"/>
          <Column id="aplcnEndYmd" type="string" size="256"/>
          <Column id="aplcnBgngTm" type="STRING" size="256"/>
          <Column id="aplcnEndTm" type="STRING" size="256"/>
          <Column id="expsrSn" type="STRING" size="256"/>
          <Column id="lnkTypCd" type="STRING" size="256"/>
