    <Objects/>
    <Script type="xscript5.1"><![CDATA[ /**
*  @MenuPath    교육설문 >  특수교육대상자인권실태조사(헤더)
*  @FileName 	frameTop4.xfdl
*  @Creator 	kangchaeyoon
*  @CreateDate 	2023.02.06
*  @Desction    특수교육대상자인권실태조사(헤더)
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.02.06          Kangchaeyoon                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::eds_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
//세션 잔여시간
this.fvMaxTimeoutMin = 30; //총잔여시간
this.fvTimerId = 1800;	//타이머ID
this.sesnTime = new Date().setMinutes(new Date().getMinutes() + Number(this.fvMaxTimeoutMin));	//현재시각 + 세션시간
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.setTimer(this.fvTimerId, 1000);
	
	this.divSkip.set_height(0);

	if( nexacro.getEnvironment().enableaccessibility && !this.smfIsMobile() ) {
		this.btnFirstFocus.set_text("Ctrl + Shift + F11 키를 동시에 눌러 스크린리더의 가상커서를 설정하신 후 이용하시기 바랍니다.");
	}
	this.btnFirstFocus.setFocus();
	
	if( this.smfIsMobile()){
		this.divSkip.set_visible(false);
	}
	
	//검사참여기간 세팅
	this.fnSetPtptPrd();
	
	// 화면 정렬
	this.fnDisplAlign();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnPopupCallback = function(e, sender){
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
	var param = {};
	this.smfSetWorkPage("frame::eds/frameSubMain.xfdl",param,false);
}
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 검사기간 세팅
*/
this.fnSetPtptPrd = function()
{
	var periodArray = this.fnChkPeriod("shf", null);
	this.divMain.form.staPtptPrd.set_text(periodArray[5]);
}

/**
 * 헤더 화면 정렬
 * @param : N/A
 */
this.fnDisplAlign = function(){
	if(!this.smfIsMobile()){ // PC
		var nMaxWidth = 1200;
		var nFormWidth = this.parent.getOffsetWidth();
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.divMain.form.staTitle.setOffsetLeft(nLeft);
			this.divMain.form.staPtptPrd.setOffsetLeft(nLeft);
			this.divMain.form.staPtptCn.setOffsetLeft(nLeft);
		}else{
			var nLeft = 0;
			this.divMain.form.staTitle.setOffsetLeft(nLeft);
			this.divMain.form.staPtptPrd.setOffsetLeft(nLeft);
			this.divMain.form.staPtptCn.setOffsetLeft(nLeft);
		}
		this.divMain.form.resetScroll();
	}
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description '처음화면' 버튼 클릭 시
*/
this.divMain_btnHome_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	window.location.replace(window.location.protocol + "//" + window.location.host);
};

/**
 * @description '시도교육청 문의 및 상담번호 안내' 버튼 클릭 시
*/
this.divMain_btnCddcdInfo_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)	// 2023 연락처 전달 받을 시 수정
{
	var popupParams = {
		callback: this.fnPopupCallback,		// 콜백함수 지정
		sender: obj, 						// sender 지정
		params: {							// 팝업 전달 파라메터 지정
			procType: "none"				// 처리타입 지정
		},
		titlebar : false
	};
	this.smfDialog("_auto", "frame::eds/frameTelnoListPopup.xfdl" ,popupParams);
};


this.divSkip_onkillfocus = function(obj:nexacro.Div,e:nexacro.KillFocusEventInfo)
{
	this.divSkip.set_height(0);

	var elem = this.divSkip.getElement();
	if(elem)
	{ //겹쳐진 컴포넌트의 z-index 조절
		elem.setElementZIndex("");
	}	
};

this.divSkip_onsetfocus = function(obj:nexacro.Div,e:nexacro.SetFocusEventInfo)
{
	//this.divSkip.set_height(60);
	this.divSkip.move(0, 0, null, 60, 0);
	this.resetScroll();
	
	var elem = this.divSkip.getElement();
	if(elem)
	{ //겹쳐진 컴포넌트의 z-index 조절
		elem.setElementZIndex(1);
	}		
};

this.divSkip_btnGobody_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var divWork = this.getOwnerFrame().form.divAll.form.divWork.form.divMain;
	
	//첫번째 컴포넌트로 setFocus();
	this.fnFindFirstComp(divWork.form);
};

this.fnFindFirstComp = function(scope)
{
	var comps = scope.components;
	
	
	for(var i=0; i<comps.length; i++)
	{
		//div인 경우 내부에서 재검색
		if( comps[i].visible==true && comps[i] instanceof nexacro.Div){
			this.fnFindFirstComp(comps[i].form);
			break;
		}
		else if(comps[i].visible==true && comps[i].accessibilityenable==true){
			comps[i].setFocus();
			break;
		}
	}
};

this.frameTop4_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnDisplAlign();
};

this.frameTop4_ontimer = function(obj:nexacro.Form,e:nexacro.TimerEventInfo)
{
	if (e.timerid == this.fvTimerId) {
		var currTime = new Date().setMinutes(new Date().getMinutes());	
		var secLeft = Math.floor((this.sesnTime - currTime)/1000);	//남은 초
		
		// 연장팝업 (남은시간<=연장체크시간) (초로 계산)
		if(secLeft <=  0){
			this.killTimer(this.fvTimerId);
			alert("세션이 타임아웃 되었습니다. 다시 설문(검사)에 참여해 주시기 바랍니다.");
			// 메인URL로 이동한다.
			location.href="/";
		}
	}
};
]]></Script>
  </Form>
</FDL>
