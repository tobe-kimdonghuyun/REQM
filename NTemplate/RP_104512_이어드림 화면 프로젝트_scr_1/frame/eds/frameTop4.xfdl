              <Button id="btnCddcdInfo" left="1436" top="52" width="118" height="24" visible="false" taborder="5"/>
              <Static id="sta00" left="1262" top="188" width="5" height="9" taborder="6" visible="false"/>
              <Static id="sta00_00" left="1217" top="283" width="100" height="12" taborder="7"/>
              <Static id="staRightBg" visible="false" width="80" height="66" right="-627" bottom="-346" taborder="3"/>
