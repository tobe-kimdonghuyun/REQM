            <Layout name="Layout1">
              <Static id="staTitle" cssclass="sta_WF_WhiteTxt36B" left="127" top="27" height="50" textAlign="center" minwidth="300" maxwidth="" taborder="0" right="126" text="특수교육대상자 인권실태조사"/>
              <Static id="staPtptCn" visible="false" left="1172" top="385" width="330" height="30" taborder="4"/>
              <Static id="staPtptPrd" left="20" height="58" cssclass="sta_WF_YellowTxt24,backa53c05_M" right="20" taborder="1" top="106"/>
              <Button id="btnHome" left="20" top="34" width="6.25%" height="40" color="transparent" taborder="2" enable="true" cssclass="btn_TF_SurvHome" text="처음화면"/>
              <Button id="btnCddcdInfo" left="1436" top="52" width="118" height="24" visible="false" taborder="5"/>
