              <Static id="staPtptPrd" taborder="2" left="360" top="69" width="651" height="29" cssclass="sta_WF_YellowTxt" initvalueid="ivStcAccessibilityOn" usedecorate="false"/>
              <Static id="staPtptCn" taborder="3" text="학교 안팍에서 발생하는 학교폭력 관련 경험과 학교폭력에 대한 학생들의 인식을 조사합니다. 학생 개인정보는 저장되지 않습니다." left="360" top="99" width="1200" height="27" cssclass="sta_WF_SurvSubTxt" initvalueid="ivStcAccessibilityOn" usedecorate="false"/>
              <Button id="btnHome" taborder="4" text="처음화면" left="staTitle:401" top="7" width="59" height="24" cssclass="btn_TF_Survbtn" initvalueid="ivBtnAccessibilityButton" enable="true" onclick="divMain_btnHome_onclick"/>
              <Static id="sta00" taborder="5" left="1376" top="15" width="5" height="9" cssclass="sta_TF_SectionLine02" initvalueid="ivStcAccessibilityOff" visible="false"/>
              <Button id="btnCddcdInfo" taborder="6" text="시도교육청 문의 및 상담번호 안내" top="7" width="178" height="24" cssclass="btn_TF_SurvAdvcNmb" initvalueid="ivBtnAccessibilityLink" textAlign="right" left="btnHome:4" onclick="divMain_btnCddcdInfo_onclick" visible="false"/>
              <Static id="sta00_00" taborder="7" left="1461" top="0" height="12" cssclass="sta_WF_GDSize" text="12" visible="false" initvalueid="ivStcAccessibilityOff" width="100"/>
