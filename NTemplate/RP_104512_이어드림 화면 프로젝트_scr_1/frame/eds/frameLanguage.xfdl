*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.11.3     	정인혁 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frameLanguage_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
}; 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
}
/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){

};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * 버튼 css 설정
 * @param : langCd			- 언어코드
 */
this.fnSetSelectCss = function(langCd){
	for(var i = 0; i < 8; i++){
		this['btnSelLang0' + i].set_cssclass('btn_TF_LanggChoice');
	}
	this['btnSelLang0' + (langCd-1)].set_cssclass('btn_TF_LanggChoiceS');
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.parent.closePopup("");
};

this.Button_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	for(var i = 0; i < 8; i++){
		this['btnSelLang0' + i].set_cssclass('btn_TF_LanggChoice');
	}
	this['btnSelLang0' + (obj.langVal-1)].set_cssclass('btn_TF_LanggChoiceS');
	
	this.parent.closePopup(obj.langVal+"|"+obj.text);	
};]]></Script>
  </Form>
</FDL>
