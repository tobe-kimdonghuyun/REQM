    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 교육청 선택(지도)
*  @FileName 	frameMap.xfdl 
*  @Creator 	kangchaeyoon
*  @CreateDate 	2023.02.07
*  @Desction    교육설문 - 교육청선택(지도)
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.02.07           Kangchaeyoon                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::eds_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_param;					// 파라메터 세팅
this.fv_ptptKndCd;				// 설문 구분
this._cddcCd;					// 시도교육청코드	
this._cddcNm;					// 시도교육청명	
this.fv_bscCssclassNm;			// 배경 css
this.fv_subCssclassNm;			// 우측 배경 css
this.fv_mapCssclassNm;			// 지역 선택 텍스트 색상
this.fv_btnCssclassNm;			// 버튼 css
this.fv_btnMobileCssclassNm;	// 모바일 버튼 css
this.fv_mobile ="";				// 모바일일 때
this.tstYn = false;				// test를 위한 변수

// 시도코드 구분
var sSelectedCddcCode = this.div01.form.divKorMap.form.fnGetSelectCode();
var sSelectedCddcName = this.div01.form.divKorMap.form.fnGetSelectName();

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	// 전달받은 파라메터 값 세팅
	this.fv_param = this.smfGetFormParams();
	this.fv_ptptKndCd = this.fv_param.ptptKndCd;
	this.fv_mobile = this.smfIsMobile() ? (this.fv_ptptKndCd == '1' ? "" : "_M") : "";

	//divTop url, css 세팅
	this.fnPtptKndInfoSet();

	// 서버 날짜, 시간 세팅
	this.fnSelectDate();
	
	// 화면 정렬
	this.fnDisplAlign();
	
	//@KBR
	var	sText = "지도에서 <fc v='"+ this.fv_mapCssclassNm +"'>교육청</fc>을\n선택해주세요";
	this.div01.form.div00.form.staChcCddcNm.set_text(sText);
	//지도 text배경색 변경
	this.div01.form.divKorMap.selTextFillColor = this.fv_mapCssclassNm;
	this.div01.form.divKorMap.form.fnChangeFillColor(this.fv_mapCssclassNm);
	
	this.div01.form.btnQstnPtpt.set_visible(false);
	this.div01.form.divKorMap.form.fnSetInit(this,this.fnMapSelecetCallback);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
}

this.fnPopupCallback = function(e, sender){
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 서버 날짜, 시간 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSelectDate = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("select")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			// 설문기간 value
			this.edsValidate();
	});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description divTop url, css 세팅
*/
this.fnPtptKndInfoSet = function(){
	if(this.fv_ptptKndCd == '1'){			//학교폭력

		this.divTop.set_url('frame::eds/frameTop1.xfdl');
		this.fv_bscCssclassNm = 'div_WF_Survey01';
		this.fv_subCssclassNm = 'sta_WF_SurvGraph01';
		this.fv_mapCssclassNm = '#415b90';
		this.fv_btnCssclassNm = 'btn_WF_Survey';
		this.fv_btnMobileCssclassNm = 'btn_WF_SurvMain01';
		
	}else if(this.fv_ptptKndCd == '2'){		//학생정서
	
		this.divTop.set_url('frame::eds/frameTop2.xfdl');
		this.fv_bscCssclassNm = 'div_WF_Survey02'+this.fv_mobile;
		this.fv_subCssclassNm = 'sta_WF_SurvGraph02'+this.fv_mobile;
		this.fv_mapCssclassNm = '#13864d';
		this.fv_btnCssclassNm = 'btn_WF_Survey2'+this.fv_mobile;
		this.fv_btnMobileCssclassNm = 'btn_WF_SurvMain02';
		
	}else if(this.fv_ptptKndCd == '3' || this.fv_ptptKndCd == '5'){		//교원능력
	
		this.divTop.set_url(this.fv_ptptKndCd == '3' ? 'frame::eds/frameTop3.xfdl' : 'frame::eds/frameTop5.xfdl');
		this.fv_bscCssclassNm = 'div_WF_Survey03'+this.fv_mobile;
		this.fv_subCssclassNm = 'sta_WF_SurvGraph03'+this.fv_mobile;
		this.fv_mapCssclassNm = '#6b5dc0';
		this.fv_btnCssclassNm = 'btn_WF_Survey3'+this.fv_mobile;
		this.fv_btnMobileCssclassNm = 'btn_WF_SurvMain03';
		this.div01.form.btnQstnPtpt.set_text("평가참여하기");
		
		//푸터에 시도교육청 안내 팝업 안보이게 처리
		if(this.smfIsMobile()){
			this.divBottom.form.div00.form.btn01.set_visible(false);
			this.divBottom.form.div00.form.sta00.set_visible(false);
			this.divBottom.set_url("frame::eds/frameBottom2.xfdl");
		}
		
	}else if(this.fv_ptptKndCd == '4'){		//특수설문
	
		this.divTop.set_url('frame::eds/frameTop4.xfdl');
		this.fv_bscCssclassNm = 'div_WF_Survey04'+this.fv_mobile;
		this.fv_subCssclassNm = 'sta_WF_SurvGraph04'+this.fv_mobile;
		this.fv_mapCssclassNm = '#f2662a';
		this.fv_btnCssclassNm = 'btn_WF_Survey4'+this.fv_mobile;
		this.fv_btnMobileCssclassNm = 'btn_WF_SurvMain04';
		this.div01.form.btnQstnPtpt.set_text("조사참여하기");
	}
	
	this.div01.set_cssclass(this.fv_bscCssclassNm);
	this.div01.form.btnQstnPtpt.set_cssclass(this.fv_btnCssclassNm);
	this.div01.form.staRightBg.set_cssclass(this.fv_subCssclassNm);
	
	//버튼 css 변경
	this.fnSetCddcCssclass();
};

/**
 * 맵클릭 CALLBACK
 */
this.fnMapSelecetCallback = function (sSelCode,sSelName)
{
	if (!this.smfIsNull(sSelCode)) {
		this.div01.form.btnQstnPtpt.set_visible(true);
		this.smfSetCddcCode(sSelCode);
	}else{
		this.div01.form.btnQstnPtpt.set_visible(false);
	}
	
	var sText = "";
	var sColor= this.fv_mapCssclassNm;
	
	if(this.smfIsNull(sSelName)){
		sText = "지도에서 <fc v='"+sColor+"'>교육청</fc>을\n선택해주세요";
	}
	else{	
		sText = "현재 선택하신 교육청은\n<fc v='"+sColor+"'><u v='true'>"+sSelName+"</u></fc> \n입니다.";
	}

	this.div01.form.div00.form.staChcCddcNm.set_text(sText);	
	this.smfResetScroll(this.div01.form.div00.form);
	this.div01.set_height(778);
	this.smfResetScroll(this);
	
	this.dsCddcList.filter("");
	
	// combo의 값을 변경한다.
	this.div01.form.cboCddcList.set_value(sSelCode);
};

 /**
 * @description 시도교육청 버튼 css 변경
*/
 this.fnSetCddcCssclass = function(objBtn)
{
	var objComps = this.div01.form.divCddcList.form.components;
	for(var i in objComps){
		var objComp = objComps[i];
		if(objComp.cddcCd){
			objComp.set_cssclass(this.fv_btnMobileCssclassNm + this.fv_mobile); //clear
		}
	}
}

/**
* 설문기간에 따른 button property 비활성화 및 정서 버튼명
* @param : N/A
* @return :  N/A
*/
this.edsValidate = function(){
	 var edsSc;
	if (this.smfContainsStr(window.location.host, "mom")) {
		edsSc = "seo"
	}else if (this.smfContainsStr(window.location.host, "survey")) {
		edsSc = "vff"
	}else if (this.smfContainsStr(window.location.host, "human")) {
		edsSc = "shf"
	}else{	// map화면
		if(this.fv_ptptKndCd == '1'){	// 학폭
			edsSc = "vff"
		}
		if(this.fv_ptptKndCd == '2'){	// 정서
			edsSc = "seo"
			this.div01.form.btnQstnPtpt.set_text("검사참여하기");
		}
		if(this.fv_ptptKndCd == '3'){	// 교평
			edsSc = "tad"
		}
		if(this.fv_ptptKndCd == '4'){	// 특수
			edsSc = "shf"
		}
	}
	
	var surveyDate = this.dsSearch.getColumn(0, "date");
	var surveyTime = this.dsSearch.getColumn(0, "time");
	
	var vffBgngYmd = this.dsVffDate.getColumn(0, "vffBgngYmd");
	var vffEndYmd = this.dsVffDate.getColumn(0, "vffEndYmd");
	var vffBgngTm = this.dsVffDate.getColumn(0, "vffBgngTm");
	var vffEndTm = this.dsVffDate.getColumn(0, "vffEndTm");
	
	// 학생정서
	if (edsSc == "seo") { // 날짜 eds_script.xjs 맞추기
		if (surveyDate <= "20250430") {
			this.div01.form.btnQstnPtpt.set_text("검사참여하기");
		} else if ((surveyDate > "20250430") && (surveyDate < "20250631")) {
			this.div01.form.btnQstnPtpt.set_text("검사결과조회하기");
		}
	}	
	
	if (edsSc == "vff") { // 날짜 eds_script.xjs 맞추기
		if (((vffBgngYmd <= surveyDate) && (surveyDate <= vffEndYmd)) && ((vffBgngTm <= surveyTime) && (surveyTime <= vffEndTm))) {
			this.div01.form.btnQstnPtpt.set_enable(false);
			this.smfAlertEds("현재는 설문조사 참여 시간이 아닙니다.\n 설문조사 참여 제한시간 : 오전 7:00 ~ 10:00 \n\n 이용에 불편을 드려 죄송합니다.");
			return;
		}
	}	

	if (this.fnChkPeriod(edsSc, null, surveyDate, surveyTime)[4] == "N") {
		this.div01.form.btnQstnPtpt.set_enable(false);
	}
}

/**
* 화면 정렬
* @param : N/A
* @return :  N/A
*/
this.fnDisplAlign = function(){
	if(!this.smfIsMobile()){ // PC
		var nMaxWidth = 1200;
		var nFormWidth = this.parent.getOffsetWidth();
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.div01.form.sta00.setOffsetLeft(nLeft);
			this.div01.form.div00.setOffsetLeft(nLeft);
			this.div01.form.btnQstnPtpt.setOffsetLeft(nLeft);
		}else{
			var nLeft = 0;
			this.div01.form.sta00.setOffsetLeft(nLeft);
			this.div01.form.div00.setOffsetLeft(nLeft);
			this.div01.form.btnQstnPtpt.setOffsetLeft(nLeft);
		}
		this.div01.form.resetScroll();
	}
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description '설문참여하기' 버튼 클릭 시
*/
this.div01_btnQstnPtpt_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo,sSelCode,sSelName)
{	
	//설문참여 url 세팅
	var sUrl = '';
	if(this.fv_ptptKndCd == '1'){			//학교폭력
		sUrl = 'pa_eds_vff_os::eds_vffos03_m01.xfdl';
	}else if(this.fv_ptptKndCd == '2'){		//학생정서
		sUrl = 'pa_eds_seg_oi::eds_segoi02_m01.xfdl';
	}else if(this.fv_ptptKndCd == '3'){		//교원능력(학교)
		sUrl = 'pa_eds_tad_os::eds_tados02_m01.xfdl';
	}else if(this.fv_ptptKndCd == '4'){		//특수설문
		sUrl = 'pa_eds_shf_os::eds_shfos02_m01.xfdl';
	}else if(this.fv_ptptKndCd == '5'){		//교원능력(유치원)
		sUrl = 'pa_ktd_tad_os::ktd_tados06_m01.xfdl';
	}
	
	var sCddcCd = "";
	var sCddcNm = "";
	if ( this.fv_ptptKndCd == '3' || this.fv_ptptKndCd == '5'){
		sCddcCd = this.smfIsMobile()? this.smfGetCddcCode(sSelCode) : this.div01.form.cboCddcList.value;
		sCddcNm = this.smfIsMobile()? this.smfGetCddcName(sSelName) : this.div01.form.cboCddcList.text;
		//sCddcCd = this.smfGetCddcCode(sSelCode);
		//sCddcNm = this.smfGetCddcName(sSelName);
	} else {
		sCddcCd = this.smfIsMobile()? this._cddcCd : this.div01.form.cboCddcList.value;
		sCddcNm = this.smfIsMobile()? this._cddcNm : this.div01.form.cboCddcList.text;
		//sCddcNm = this.smfIsMobile()? this._cddcNm : this.smfGetCddcName(sSelName);
		//sCddcCd = this.smfIsMobile()? this._cddcCd : this.smfGetCddcCode(sSelCode);
	}
	/* 2024년 1차 참여한다고 해서 주석처리 함
	if(this.fv_ptptKndCd == '1'){
		if(sCddcCd == 'P100000001'){
			this.smfAlertEds("전북특별자치도 교육청은 자체적으로 실태조사를 실시하오니, 교육청으로 문의하시기 바랍니다.");
			return;
		}
	}
	*/

	var param = {
		cddcCd: sCddcCd,
 		cddcNm: sCddcNm,
		dsInfo: this.dsInfo.saveXML()
	};
	
	this.smfSetWorkPage(sUrl, param, false);
};

/**
 * @description '콤보박스' 변경 시
*/
this.cboCddcList_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	var sCddcCd = e.postvalue;
	var sSelName = e.posttext;
	
	if(!this.smfIsNull(sCddcCd))
	{
		this.div01.form.divKorMap.form.fnSetCddcCode(sCddcCd);
	}
	
	var sText = "";
	if(this.smfIsNull(sSelName))
	{
		sText = "지도에서 교육청을\n선택해주세요";
		this.div01.form.btnQstnPtpt.set_visible(false);
	}
	else
	{
		var sColor= this.fv_mapCssclassNm;
		sText = "현재 선택하신 교육청은\n<fc v='"+sColor+"'><u v='true'>"+sSelName+"</u></fc> \n입니다.";
		this.div01.form.btnQstnPtpt.set_visible(true);
	}

	this.div01.form.div00.form.staChcCddcNm.set_text(sText);	
	this.smfResetScroll(this.div01.form.div00.form);	
	this.div01.set_height(778);
	this.smfResetScroll(this);
};

/**
 * @description '시도교육청 버튼' 클릭 시(모바일)
*/
this.cddcCdBtn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sCddcCd = obj.cddcCd;
	var dataset = this.dsCddcList;
	var findRow;
	var rowCnt = [];
	var popInfo;
	
	//시도교육청 문의전화 안내글 세팅
	if( (['3', '5'].indexOf(this.fv_ptptKndCd) > -1) && this.smfIsMobile() ){	//교원능력이고 모바일일 때 안보이게
	
		this.div01.form.divCddcList.form.sta02.set_visible(false);
		this.div01.form.divCddcList.form.staCddcNm.set_visible(false);
		this.div01.form.divCddcList.form.stacddcInfo1.set_visible(false);
		this.div01.form.divCddcList.form.stacddcInfo2.set_visible(false);
		
	}else{
		if(this.fv_ptptKndCd == '2' || this.fv_ptptKndCd == '4'){		// 학생정서
			dataset = this.dsSegCddcList;
 			rowCnt = this.dsSegCddcList.extractRows("cddcCd=='"+sCddcCd+"'");	
 			findRow = rowCnt[0];
 			popInfo = "시도교육청 문의 및 상담번호 정보를 확인해주세요.";
			
		}
		if(this.fv_ptptKndCd == '1'){	// 학폭설문
			findRow = this.dsCddcList.findRow("cddcCd",sCddcCd);
			var cddcName = this.dsCddcList.getColumn(findRow,"cddcNm");
			var callInfo = dataset.getColumn(findRow, "callInfo");
			if(rowCnt.length > 1){
				callInfo = popInfo;
			}
			var info = dataset.getColumn(findRow, "info");
			
			this.div01.form.divCddcList.form.staCddcNm.set_text(cddcName+" 문의전화");
			this.div01.form.divCddcList.form.stacddcInfo1.set_text(callInfo);
			this.div01.form.divCddcList.form.stacddcInfo2.set_text(info);
		}
		else{
			var cddcName = dataset.getColumn(findRow,"cddcNm");
			findRow = dataset.findRow("cddcCd",sCddcCd);
			var callInfo = "시도교육청 문의 및 상담번호 정보를 확인해주세요.";	// 추 후 해당 코드줄 삭제 (305~320라인까지 주석풀기)*
			if(rowCnt.length > 1){
			callInfo = popInfo;
			}
			var info = dataset.getColumn(findRow, "info");
			
			this.div01.form.divCddcList.form.staCddcNm.set_text(cddcName+" 문의전화");
			this.div01.form.divCddcList.form.stacddcInfo1.set_text(callInfo);
			this.div01.form.divCddcList.form.stacddcInfo2.set_text(info);
		}
	}

	//버튼 css 변경
	this.fnSetCddcCssclass();
	obj.set_cssclass(this.fv_btnMobileCssclassNm + "S" + this.fv_mobile);  //select
	
	//'설문참여하기' 버튼 활성화
	this.div01.form.btnQstnPtpt.set_visible(true);
	
	//스크롤바 갱신
	this.div01.form.divCddcList.form.resetScroll();
	
	//시도교육청 정보 세팅
	this._cddcCd = obj.cddcCd;
	this._cddcNm = cddcName;
	this.smfSetCddcCode(this._cddcCd);
	
	this.div01.form.btnQstnPtpt.setFocus();
};

/**
 * @description 콤보박스 리스트 표시할 때
*/
this.div01_cboCddcList_ondropdown = function(obj:nexacro.Combo,e:nexacro.EventInfo)
{
	obj.getInnerDataset().filter("cddcCd != ''");
};

/**
 * @description 시도교육청 문의 및 상담번호 안내 팝업 호출
*/
this.div01_divCddcList_stacddcInfo1_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	if(this.fv_ptptKndCd == '2'){		//학생정서
		var popupParams = {
			callback: this.fnPopupCallback,		// 콜백함수 지정
			sender: obj, 						// sender 지정
			params: {							// 팝업 전달 파라메터 지정
				procType: "none"				// 처리타입 지정
			},
			titlebar : false
		};
		this.smfDialog("_auto", "pa_eds_seg_oi::eds_segoi01_p01.xfdl" ,popupParams);
	}
};

this.div01_cboCddcList_oncloseup = function(obj:nexacro.Combo,e:nexacro.ComboCloseUpEventInfo)
{
	if(obj.text == ""){
		this.dsCddcList.filter("");
		obj.set_index(0);
	}
};

// 화면 폼 사이즈 변경 시
this.frameMap_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnDisplAlign();
};]]></Script>
  </Form>
</FDL>
