 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
}

/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
};

/**
 * 언어선택팝업DIV의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnSelectLangCallback = function(sObjId, sReturnVal){
	if(!this.smfIsNull(sReturnVal))	{
		var objReturnVal = sReturnVal.split("|");
	
		this.divMain.form.btnSelectLang.set_text(objReturnVal[1]);
		var objForm = this.parent.parent;
		
		// '언어' txt 설정
		this.divMain.form.staLanguage.set_text(objReturnVal[0] == 1 ? "언어" : "language");
		
// 		this.divMain.form.staSurveyPeriod.set_text(this.dsLang.getColumn(objReturnVal[0] -1, 'surveyText'));
// 		this.divMain.form.staComment.set_text(this.dsLang.getColumn(objReturnVal[0] -1, 'surveyContents'));
// 		if(objReturnVal[0] == 2){
// 			this.divMain.form.staComment.set_cssclass("sta_WF_Txt14");
// 		}else{
// 			this.divMain.form.staComment.set_cssclass("sta_WF_SurvSubTxt");
// 		}
		
		this.fvLangCd = objReturnVal[0];
		objForm.fnSelectLang(this.fvLangCd);
	}
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
	var param = {};
	this.smfSetWorkPage("frame::eds/frameSubMain.xfdl",param,false);
}
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * 언어선택, 뒤로가기, TTS 버튼 보여주기 유무 설정
 * @param : bShow			- true/false
 */
this.fnSetTopFrameBtnVisible = function(bShow1, bShow2, bShow3)
{
	this.divMain.form.staLanguage.set_visible(bShow1);
	this.divMain.form.btnSelectLang.set_visible(bShow1);
	this.divMain.form.btnBack.set_visible(bShow2);
	this.divMain.form.btnTTS.set_visible(bShow3);
}

/**
 * 처음화면 버튼 보여주기 유무 설정
 * @param : bShow			- true/false
 */
this.fnSetTopFrameBtnHomeVisible = function(bShow)
{
	this.divMain.form.btnHome.set_visible(bShow);
	this.divMain.form.sta02.set_visible(bShow);
}

/**
 * 언어설정 css, 언어선택 문구 설정
 * @param : langCd			- 언어코드
 */
this.fnSetSelect = function(langCd){
	this.pdivSelectLang.form.fnSetSelectCss(langCd);
	this.divMain.form.btnSelectLang.set_text(this.dsLangNm.getColumn(langCd - 1, 'value'))
	this.divMain.form.staLanguage.set_text(langCd == 1 ? "언어" : "language");
	
// 	this.divMain.form.staSurveyPeriod.set_text(this.dsLang.getColumn(langCd -1, 'surveyText'));
// 	this.divMain.form.staComment.set_text(this.dsLang.getColumn(langCd -1, 'surveyContents'));
};

/**
 * 참여기간 설정
 * @param : N/A
 */
this.fnSetSurveyPeriod =  function(){
	var periodArray = this.fnChkPeriod("vff", null);
	this.divMain.form.staSurveyPeriod.set_text(periodArray[5]);
};

/**
 * TTS플레이를 실행
 * @param : N/A
 */
this.fnSetTTSUrl = function(url)
{
	this.vpTTS.set_url(url);
}

/**
 * TTS플레이를 실행
 * @param : N/A
 */
this.fnPlay = function()
{
	this.vpTTS.play();
}

/**
 * TTS플레이를 일시중단
 * @param : N/A
 */
this.fnPause = function()
{
	this.vpTTS.pause();
}

/**
 * TTS플레이를 중지
 * @param : N/A
 */
this.fnStop = function()
{
	this.vpTTS.stop();
}

/**
 * TTS 버튼 이벤트 설문문항에서 사용
 * @param : N/A
 */
this.fnEventTTS = function()
{
/*
	//if (this.divMain.form.btnTTS.cssclass == 'btn_TF_SoundOff'){
	if (this.divMain.form.btnTTS.cssclass == 'btn_TF_SoundOn'){
		this.divMain_btnTTS_onclick(null, null);
	}
*/
	if (this.divMain.form.btnTTS.cssclass == 'btn_TF_SoundOn'){
		this.fnPause();
	}
}

/**
 * 설문문항에서 cdn 자동 실행 시 사용
 * @param : N/A
 */
this.fnAutoTTS = function(){
	// 각 해당화면에서 cdn url 가져오기
	var urlTTS = this.parent.parent.fnCallAuto();
	this.fnSetTTSUrl(urlTTS);
	this.fnPlay();
	this.divMain.form.btnTTS.set_cssclass('btn_TF_SoundOn');
}

/**
 * 헤더 화면 정렬
 * @param : N/A
 */
this.fnDisplAlign = function(){
	if(!this.smfIsMobile()){ // PC
		var nMaxWidth = 1200;
		var nFormWidth = this.parent.getOffsetWidth();
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.divMain.form.staTitle.setOffsetLeft(nLeft);
			this.divMain.form.staSurveyPeriod.setOffsetLeft(nLeft);
			this.divMain.form.staComment.setOffsetLeft(nLeft);
		}else{
			var nLeft = 0;
			this.divMain.form.staTitle.setOffsetLeft(nLeft);
			this.divMain.form.staSurveyPeriod.setOffsetLeft(nLeft);
			this.divMain.form.staComment.setOffsetLeft(nLeft);
		}
		this.divMain.form.resetScroll();
	}
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 처음으로 버튼 클릭 시
