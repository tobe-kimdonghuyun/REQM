      <Dataset id="dsLang">
        <ColumnInfo>
          <Column id="language" type="STRING" size="256"/>
          <Column id="mainText" type="STRING" size="256"/>
          <Column id="surveyDate" type="STRING" size="256"/>
          <Column id="surveText" type="STRING" size="256"/>
          <Column id="surveyText" type="STRING" size="256"/>
          <Column id="surveyContents" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="language">언어</Col>
            <Col id="surveyText">참여기간 : 9월 18일(월) 09:00 ~ 10월 17일(화) 18:00</Col>
            <Col id="surveyContents">학교 안팎에서 발생하는 학교폭력 관련 경험과 학교폭력에 대한 학생들의 인식을 조사합니다. 학생 개인정보는 저장되지 않습니다.</Col>
          </Row>
          <Row>
            <Col id="language">language</Col>
            <Col id="surveyText">Period: 09:00 (Mon, Sep 18) to 18:00 (Tue, Oct 17)</Col>
            <Col id="surveyContents">This survey is conducted on students' perceptions on school violence and related experiences that occur inside and outside of the school. Students’ personal information is not stored.</Col>
          </Row>
          <Row>
            <Col id="surveyText">参与时间 9月18日（月）09:00 - 10月17日（周二）18:00</Col>
            <Col id="surveyContents">调查学生是否在校内外遭受过校园暴力及对校园暴力的认识。学生个人信息不会被保存。 </Col>
          </Row>
          <Row>
            <Col id="surveyText">参加期間 09月18日(月) 09:00～10月17日(火) 18:00、</Col>
            <Col id="surveyContents">校内・校外で発生する暴力に関する経験や、校内暴力に対する生徒の認識について調査を行います。生徒の個人情報は保存されません。 </Col>
          </Row>
          <Row>
            <Col id="surveyText">Thời hạn tham gia 09:00, (Thứ Hai) ngày 18 Tháng 9 ~ 18:00, (Thứ Ba) ngày 17 Tháng 10</Col>
            <Col id="surveyContents">Khảo sát nhận thức của học sinh về bạo lực học đường và trải nghiệm liên quan đến bạo lực học đường xảy ra ở trong &amp; ngoài trường học. Thông tin cá nhân của học sinh hoàn toàn không bị lưu lại. </Col>
          </Row>
          <Row>
            <Col id="surveyText">Panahon ng Paglahok Setyembre 18(Lunes) 09:00 - Oktubre 17(Martes) 18:00,</Col>
            <Col id="surveyContents">Ito ay isang pagsisiyasat kaugnay sa karanasan ng karahasan sa paaralan at kaalaman ng mga mag-aaral tungkol sa karahasan sa paaralan na nangyayari sa loob at labas ng paaralan. Ito ay isang pagsisiyasat kaugnay sa karanasan ng karahasan sa paaralan at kaalaman ng mga mag-aaral tungkol sa karahasan sa paaralan na nangyayari sa loob at labas ng paaralan.</Col>
          </Row>
          <Row>
            <Col id="surveyText">Период участия 09/18 (Пн.) 09:00 - 10/17 (Вт.) 18:00</Col>
            <Col id="surveyContents">Проводится исследование восприятия учащимися школьного опыта, связанного с насилием, и школьного насилия, которое происходит внутри и за пределами школы. Личные данные учащихся не будут сохранены.</Col>
          </Row>
          <Row>
            <Col id="surveyText">ระยะเวลาการเข้าร่วม วกันยายน17(จันทร์) เดือน0 เวลา09:00 - วตุลาคม่18(อังคาร) เดือน0 เวลา18:00</Col>
            <Col id="surveyContents">สำรวจประสบการณ์ความรุนแรงทั้งภายในและภายนอกโรงเรียนและการรับรู้ของนักเรียนเกี่ยวกับความรุนแรงในโรงเรียน ข้อมูลส่วนตัวของนักเรียนจะไม่ถูกบันทึก </Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    샘플
*  @FileName 	frameTop1.xfdl
*  @Creator 	정인혁
*  @CreateDate 	2022.11.3
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.11.3     	정인혁 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::eds_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvLangCd = 1;

//세션 잔여시간
this.fvMaxTimeoutMin = 30; //세션시간
this.fvTimerId = 1800;	//타이머ID
this.sesnTime = new Date().setMinutes(new Date().getMinutes() + Number(this.fvMaxTimeoutMin));	//현재시각 + 세션시간

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frameTop1_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.setTimer(this.fvTimerId, 1000);

	this.divSkip.set_height(0);

	if( nexacro.getEnvironment().enableaccessibility && !this.smfIsMobile() ) {
		this.btnFirstFocus.set_text("Ctrl + Shift + F11 키를 동시에 눌러 스크린리더의 가상커서를 설정하신 후 이용하시기 바랍니다.");
	}
	this.btnFirstFocus.setFocus();
	
	if(this.smfIsMobile()){
		this.divSkip.set_visible(false);
	}
	
	// 기간설정
	this.fnSetSurveyPeriod();
	
	this.fnDisplAlign();
	
	if (this.parent.parent.name == 'frameMap'){
		this.fnSetTopFrameBtnVisible(false, false, false);
	}
	
	this.pdivSelectLang.set_url('frame::eds/frameLanguage.xfdl');
	
	this.divMain.form.btnTTS.set_cssclass("btn_TF_SoundOff");
}; 
