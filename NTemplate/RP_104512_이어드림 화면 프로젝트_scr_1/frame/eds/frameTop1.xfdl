		window.location.replace(window.location.protocol + "//" + window.location.host);
//	}
};

/**
 * 시도교육청 문의 및 상담번호 안내 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.divMain_btnPopup_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var popupParams = {
		callback: this.fnPopupCallback,
		sender: obj, // sender 지정
		params: {
			procType : 'search'
		},
		titlebar : false,
	};
	this.smfDialog("popupTelNoinfo", "frame::eds/frameTelnoListPopup.xfdl", popupParams);
};

/**
 * 언어선택 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.divMain_btnSelectLang_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 언어선택
	var nWidth = this.pdivSelectLang.getOffsetWidth();
	var nHeight = this.pdivSelectLang.getOffsetHeight();
	
	var nLeft = 0 + obj.getOffsetWidth() - nWidth;
	if (this.smfIsMobile()){
		nLeft = obj.getOffsetWidth() * 2 - nWidth;
	}
	var nTop = obj.getOffsetHeight()+1;
	var sCallback = "fnSelectLangCallback";
	
	this.pdivSelectLang.trackPopupByComponent(obj,nLeft,nTop,nWidth,nHeight,sCallback);
};

/**
 * 뒤로가기 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.divMain_btnBack_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.parent.parent.fnMoveBack)
	{
		this.parent.parent.fnMoveBack();
	}
};

/**
 * TTS 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.divMain_btnTTS_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 재생전
	if(this.divMain.form.btnTTS.cssclass == 'btn_TF_SoundOff'){		
		// 각 해당화면에서 cdn url 가져오기
		var urlTTS = this.parent.parent.fnCallTTS();
		this.fnSetTTSUrl(urlTTS);
		this.fnPlay();
		this.divMain.form.btnTTS.set_cssclass('btn_TF_SoundOn');
	}else{
		this.parent.parent.fnCallTTS();	//tst
		this.fnPause();
		this.divMain.form.btnTTS.set_cssclass('btn_TF_SoundOff');
	}
};

/**
 * 언어선택 div 오픈 시
 * @param  : obj		   - [object]PopupDiv
 * @param  : e		       - [string]EventInfo
 * @return : N/A
 */
this.pdivSelectLang_onpopup = function(obj:nexacro.PopupDiv,e:nexacro.EventInfo)
{
	if (this.smfIsMobile()){
	}else{
		this.divMain.form.btnSelectLang.set_cssclass("btn_TF_SurvLanggS");
	}
};

/**
 * 언어선택 div 클로즈 시
 * @param  : obj		   - [object]PopupDiv
 * @param  : e		       - [string]EventInfo
 * @return : N/A
 */
this.pdivSelectLang_oncloseup = function(obj:nexacro.PopupDiv,e:nexacro.EventInfo)
{
	if (this.smfIsMobile()){
	}else{
		this.divMain.form.btnSelectLang.set_cssclass("btn_TF_SurvLangg");
	}
};

/**
 * 플레이더 상태값 변경 시
 * @param  : obj		   - [object]VideoPlayer
 * @param  : e		       - [string]VideoPlayStateChangedEventInfo
 * @return : N/A
 */
this.vpTTS_onplaystatuschanged = function(obj:nexacro.VideoPlayer,e:nexacro.VideoPlayStateChangedEventInfo)
{
	if (e.newstate == 'ended'){
		//this.divMain.form.btnTTS.set_cssclass('btn_TF_SoundOn');
		this.divMain.form.btnTTS.set_cssclass('btn_TF_SoundOff');
	}
};


this.divSkip_onkillfocus = function(obj:nexacro.Div,e:nexacro.KillFocusEventInfo)
{
	this.divSkip.set_height(0);

	var elem = this.divSkip.getElement();
	if(elem) {
		//겹쳐진 컴포넌트의 z-index 조절
		elem.setElementZIndex("");
	}	
};

this.divSkip_onsetfocus = function(obj:nexacro.Div,e:nexacro.SetFocusEventInfo)
{
	this.divSkip.move(0, 0, null, 60, 0);
	this.resetScroll();
	
	var elem = this.divSkip.getElement();
	if(elem){
		//겹쳐진 컴포넌트의 z-index 조절
		elem.setElementZIndex(1);
	}		
};

this.divSkip_btnGobody_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var divWork = this.getOwnerFrame().form.divAll.form.divWork.form.divMain;
	
	//첫번째 컴포넌트로 setFocus();
	this.fnFindFirstComp(divWork.form);
};

this.fnFindFirstComp = function(scope)
{
	var comps = scope.components;
	for(var i=0; i<comps.length; i++) {
		//div인 경우 내부에서 재검색
		if( comps[i].visible==true && comps[i] instanceof nexacro.Div){
			this.fnFindFirstComp(comps[i].form);
			break;
		}
		else if(comps[i].visible==true && comps[i].accessibilityenable==true){
			comps[i].setFocus();
			break;
		}
	}
};

// pc화면 정렬
this.frameTop1_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnDisplAlign();
};

this.frameTop1_ontimer = function(obj:nexacro.Form,e:nexacro.TimerEventInfo)
{
	if (e.timerid == this.fvTimerId) {
		var currTime = new Date().setMinutes(new Date().getMinutes());	
		var secLeft = Math.floor((this.sesnTime - currTime)/1000);	//남은 초

		// 연장팝업 (남은시간<=연장체크시간) (초로 계산)
		if(secLeft <=  0){
			this.killTimer(this.fvTimerId);
			alert("세션이 타임아웃 되었습니다. 다시 설문(검사)에 참여해 주시기 바랍니다.");
			// 메인URL로 이동한다.
			location.href="/";
		}
	}	
};
]]></Script>
  </Form>
