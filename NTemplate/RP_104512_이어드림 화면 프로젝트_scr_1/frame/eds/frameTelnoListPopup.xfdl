    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    교육설문 > 학교폭력실태조사 > 교육설문-학교폭력(시도별문의안내팝업)
*  @FileName 	frameTelnoListPopup.xfdl
*  @Creator 	김민성
*  @CreateDate 	2022.11.1
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.11.3     	김민성 	        최초 생성
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	this.fnSetcompSize();
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * 컴포넌트 사이즈 조절
 * @param  : N/A
 * @return : N/A
 */
this.fnSetcompSize = function(){
	if (this.smfIsMobile()){
		this.div00.setOffsetWidth(this.div00.form.sta03.getOffsetWidth() + this.div00.form.div00.getOffsetWidth() + this.div00.form.sta04.getOffsetWidth());
		this.div00.set_left((this.getOffsetWidth() - this.div00.getOffsetWidth())/2);
	}
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * X 버튼 클릭 시
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
this.div00_btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};

/**
 * 사이즈 변경 시
* @param  : obj		   - [object]Static
* @param  : e		   - [string]SizeEventInfo
* @return : N/A
 */
this.div00_sta00_onsize = function(obj:nexacro.Static,e:nexacro.SizeEventInfo)
{
	this.fnSetcompSize();
};]]></Script>
