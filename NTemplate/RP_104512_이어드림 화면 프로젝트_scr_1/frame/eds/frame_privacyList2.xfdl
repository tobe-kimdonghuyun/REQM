    <Script type="xscript5.1"><![CDATA[/**
 * 설문 개인정보처리방침(정서) 항목 focus
 * @param  : obj			- [object]ImageViewer
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.img00_onclick = function(obj:nexacro.ImageViewer,e:nexacro.ClickEventInfo)
{
	var short = obj.num;
	
	for(var i=1; i < 11; i++){
		if(i == short){
			var tt = this["div00_0" + i].form.img00_1.setFocus(true);
		}else if(short == 10){
			 this.div00_10.form.img00_1.setFocus(true);
		}
	}
};]]></Script>
