  <Form id="frmTemp01" width="914" height="3838" titletext="(정서)개인정보취급방침 리스트" onload="frmTemp01_onload">
    <Layouts>
      <Layout height="3838" width="914" screenid="ScreenDeskTop">
        <Div id="div00" taborder="0" text="div00" left="0" top="0" height="710" cssclass="div_WF_KinderBox" right="10" borderRadius="3px" formscrollbartype="none none">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" text="「학생정서·행동특성 검사」는 개인정보보호법 등 관련 법령에서 정한 개인정보보호규정을 준수하고 있으며, 개인정보 보호법&#13;&#10;  30조에 따라 정보주체의 개인정보를 보호하고 이와 관련한 고충을 신속하고 원활하게 처리할 수 있도록 하기 위하여 다음과&#13;&#10;  같이 개인정보 처리지침을 수립·공개합니다." left="30" top="30" height="77" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16L" right="30" verticalAlign="top"/>
              <Div id="div00_00_01" taborder="10" left="230" top="290" width="130" height="100" cssclass="div_WF_WhiteBox_R20">
