<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frameTop3" width="1920" height="140" titletext="교평-헤더" onload="fnOnload" onsize="frameTop3_onsize" ontimer="frameTop3_ontimer">
    <Layouts>
      <Layout height="140" width="1920" screenid="ScreenDeskTop" mobileorientation="portrait">
        <Button id="btnFirstFocus" taborder="0" left="-46" top="0" width="96" height="0" accessibilityrole="static"/>
        <Div id="divSkip" taborder="1" left="0" top="0" height="60" background="#2c569b" onkillfocus="divSkip_onkillfocus" onsetfocus="divSkip_onsetfocus" visible="true" initvalueid="ivDivAccessibilityOff" width="1920">
          <Layouts>
            <Layout>
              <Button id="btnGobody" taborder="0" text="본문바로가기" left="18" top="5" width="190" onclick="divSkip_btnGobody_onclick" borderRadius="6px" border="0px none" height="50" initvalueid="ivBtnAccessibilityButton"/>
              <Static id="sta00" taborder="1" text="해당 시스템을 이용하실 때 스크린리더를 사용하는 분들을 위한 안내페이지를 참조하시기 바랍니다." left="226" top="5" wordWrap="char" right="50" color="#ffffff" height="50" initvalueid="ivStcAccessibilityOn"/>
            </Layout>
            <Layout name="Layout0"/>
            <Layout name="Layout1"/>
          </Layouts>
        </Div>
        <Div id="divMain" taborder="2" left="0" top="0" height="140" cssclass="div_TF_Survey03" initvalueid="ivDivAccessibilityOff" text="" width="1920">
          <Layouts>
            <Layout>
              <Static id="staRightBg" taborder="0" width="321" height="136" right="0" bottom="0" initvalueid="ivStcAccessibilityOff" cssclass="sta_TF_SurvGraph03"/>
              <Static id="staTitle" taborder="1" text="&lt;b v='true'&gt;교원능력개발평가&lt;/b&gt; 학생ㆍ학부모 만족도조사" left="360" top="8" width="723" height="55" cssclass="sta_WF_SurvMainTxt" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
              <Static id="staPtptPrd" taborder="2" text="참여기간 : 4월 1일(토) ~ 4월 30일(일)" left="360" top="69" width="651" height="29" cssclass="sta_WF_YellowTxt" initvalueid="ivStcAccessibilityOn" usedecorate="false"/>
              <Static id="staPtptCn" taborder="3" text="선생님들이 학생·학부모와의 소통을 통하여 자신의 교육활동에 대해 진단하여 좋은 점은 발전시키고, 부족한 점은 개선하도록 하는데 목적이 있습니다." left="360" top="99" width="1200" height="27" cssclass="sta_WF_SurvSubTxt" initvalueid="ivStcAccessibilityOn" usedecorate="false"/>
              <Button id="btnHome" taborder="4" text="처음화면" left="staTitle:390" top="7" height="24" cssclass="btn_TF_Survbtn" initvalueid="ivBtnAccessibilityButton" enable="true" onclick="divMain_btnHome_onclick" width="59"/>
              <Static id="sta99" taborder="5" left="1461" top="0" height="12" cssclass="sta_WF_GDSize" text="12" visible="false" initvalueid="ivStcAccessibilityOff" width="100" onclick="divMain_Static99_00_00_00_00_01_00_00_01_00_00_01_00_00_onclick"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="staTitle" cssclass="sta_WF_WhiteTxt36B" text="교원능력개발평가" taborder="1" left="101" top="27" height="50" right="81" minwidth="300" maxwidth="" textAlign="center"/>
              <Static id="staRightBg" taborder="3" visible="false"/>
              <Static id="staPtptCn" left="1172" top="99" width="1200" height="27" visible="false" taborder="4"/>
              <Static id="staPtptPrd" cssclass="sta_WF_YellowTxt24,back564a9a_M" taborder="2" text="참여기간 : 4월 1일(토) 09:00 ~ 4월 30일(일) 18:00" left="20" top="93" height="68" right="20"/>
              <Button id="btnHome" taborder="0" left="20" top="34" width="6.25%" height="40" cssclass="btn_TF_SurvHome" text=" "/>
              <Static id="sta99" visible="false" taborder="5"/>
            </Layout>
            <Layout name="Layout1">
              <Static id="staTitle" cssclass="sta_WF_WhiteTxt36B" text="교원능력개발평가" taborder="1" left="127" top="27" height="50" right="126" minwidth="300" maxwidth="" textAlign="center"/>
              <Static id="staRightBg" taborder="3" visible="false"/>
              <Static id="staPtptCn" left="1172" top="99" width="1200" height="27" visible="false" taborder="4"/>
              <Static id="staPtptPrd" cssclass="sta_WF_YellowTxt24,back564a9a_M" taborder="2" text="참여기간 : 4월 1일(토) 09:00 ~ 4월 30일(일) 18:00" left="20" top="96" height="58" right="20"/>
              <Button id="btnHome" taborder="0" left="20" top="34" width="6.25%" height="40" cssclass="btn_TF_SurvHome" text=" "/>
