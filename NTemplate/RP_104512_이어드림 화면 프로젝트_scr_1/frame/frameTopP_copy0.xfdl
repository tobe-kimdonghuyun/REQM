// 통합검색 화면으로
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: this.fnPopupCallback, // 콜백함수 지정
		sender: this.getOwnerFrame(), 		// sender 지정
		titlebar:false,  	// 타이틀바를 표시하지 않음
		popuptype:"modalsync",

		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: "search"
		},
	};
	
	var compHeight = 200;
	if (this.smfIsMobile())	{
		compHeight = 420;
		
		// 팝업이 있다면 close해줌
		if( this.getOwnerFrame().form["commpop_menu"] ) 
		{
			var objDel = this.getOwnerFrame().form.removeChild("commpop_menu");
			objDel.destroy();
			objDel = null;
			
			if ( this.divTopB.form.btnSitemap.cssclass == "btn_Top_close_M") {
				this.divTopB.form.btnSitemap.set_cssclass("btn_Top_sitemap_M");
			}
		}
	}

	// 모달팝업 실행
	this.smfDialog("_PotalSearch", "pa_pas_mms_pc::pas_mmspc01_m07.xfdl", popupParams, 0,0, this.width, compHeight);

};

/**
 * @description skip에서 포커스가 빠졌을때
*/
this.divSkip_onkillfocus = function(obj:nexacro.Div,e:nexacro.KillFocusEventInfo)
{
	this.divSkip.set_height(0);
	//this.divSkip.set_visible(false);

	var elem = this.divSkip.getElement();
	if(elem)
	{ //겹쳐진 컴포넌트의 z-index 조절
		elem.setElementZIndex("");
	}
};

/**
 * @description skip에서 포커스가 들어올때
*/
this.divSkip_onsetfocus = function(obj:nexacro.Div,e:nexacro.SetFocusEventInfo)
{
	this.divSkip.set_height(70);
	if (this.smfIsMobile())	this.divSkip.set_height(90);
	//this.divSkip.set_visible(true);
	//this.divSkip.bringToFront();

	var elem = this.divSkip.getElement();
	if(elem)
	{ //겹쳐진 컴포넌트의 z-index 조절
		elem.setElementZIndex(1);
	}	
};

