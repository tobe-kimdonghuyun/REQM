/**
 * @description 메뉴버튼 클릭시
*/ 
this.divTopB_btnSitemap_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if ( this.smfIsMobile() )
	{
		if ( obj.cssclass == "btn_Top_sitemap_M")
		{
			obj.set_cssclass("btn_Top_close_M");
			obj.set_accessibilitylabel("메뉴닫기");
		}else if( obj.cssclass == "btn_Top_close_M" )
		{
			obj.set_cssclass("btn_Top_sitemap_M");
			obj.set_accessibilitylabel("메뉴열기");
		}
	}

	if( this.getOwnerFrame().form["commpop_menu"] ) 
	{
		var objDel = this.getOwnerFrame().form.removeChild("commpop_menu");
		objDel.destroy();
		objDel = null;
		return;
	}
	
 	if (  this.smfIsMobile() )
 	{	
		this.popInfo = {};
		this.popInfo.id     = "commpop_menu";
		this.popInfo.pUrl   = "comm::comp_mobileMenu.xfdl";		
		//this.popInfo.pScope = this.getOwnerFrame().form.divAll.form;

		this.smfDivPop(this.popInfo,false);	
	}else
	{
		this.fnSitemapView();
	}
};

// 사이트맵버튼 클릭시
this.divTopW_btnSitemap_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSitemapView();
};

// Sitemap
this.fnSitemapView = function() {
	this.divSkip.set_visible(false);
	
	// Create Object  
	var objDiv = new Div();  
	objDiv.init("commSitemap", 0, 0, null, null,0,0);
	objDiv.set_initvalueid("ivDivAccessibilityOn");
	objDiv.set_accessibilitylabel("대국민 사이트맵 팝업");
	 
	// Add Object to Parent Form  
	this.getOwnerFrame().form.addChild("commSitemap", objDiv); 
	
	// Show Object  
	objDiv.show();
	objDiv.set_url("frame::pas/commSitemap.xfdl");
};

this.fnSitemapResize = function(obj,e)
{
	var srcInfoW = parseInt(this.getOwnerFrame().width,10);	
	if( srcInfoW > 1920)	//e.cx
	{
		obj.setOffsetWidth(1920);
		return;
	}

	var nAllWidth = this.width;  // 전체 form의 사이즈
	var nMaxWidth = 1200;
	var nLeft;

	if(nAllWidth >= nMaxWidth)	//1280 사용
	{
		nLeft = parseInt((nAllWidth - nMaxWidth) / 2);
		if(nLeft < 0) nLeft = 40;
	}else
	{
		nLeft = 40;
	}

	// 가운데 정렬
	var oDiv = this.getOwnerFrame().form["commSitemap"];
	oDiv.form.divSitemap.setOffsetLeft(nLeft);
	oDiv.form.resetScroll();
	//this.getOwnerFrame().form["commSitemap"].form.divSitemap.setOffsetLeft(nLeft);
	//this.getOwnerFrame().form["commSitemap"].form.resetScroll();
};


this.frameTopP_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	if (this.getOwnerFrame().form["commSitemap"]) {
		this.fnSitemapResize(obj,e);		
	}
	this.resetScroll();
};

