<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frameTopP" width="1200" height="100" titletext="대국민 Top" background="transparent" scrollbartype="none none" scrolltype="none" onsize="frameTopP_onsize">
    <Layouts>
      <Layout height="100" width="1200" screenid="ScreenDeskTopP">
        <Button id="btnFirstFocus" taborder="0" left="50" top="2" width="0" height="0" accessibilitylabel="Ctrl + Shift + F12 키를 동시에 눌러 스크린리더의 가상커서를 해제하신 후 이용하시기 바랍니다."/>
        <Div id="divTopB" taborder="2" left="0" top="0" height="100" cssclass="div_top_N" formscrollbartype="none none" initvalueid="ivDivAccessibilityOff" formscrolltype="none" right="0" formscrollbarsize="5">
          <Layouts>
            <Layout>
              <Static id="sta_logo" taborder="0" left="50" top="24" width="270" height="52" cssclass="sta_Top_logoW" initvalueid="ivStcAccessibilityOn" onclick="divTopB_sta_logo_onclick" accessibilityrole="link" accessibilitylabel="메인으로 가기"/>
              <Div id="divTopBtn" taborder="1" left="26.67%" top="28" height="48" formscrollbartype="none none" initvalueid="ivDivAccessibilityOff" formscrolltype="none" right="165">
                <Layouts>
                  <Layout/>
                  <Layout name="mobile"/>
                </Layouts>
              </Div>
              <Button id="btnSearch" taborder="2" top="28" width="48" height="48" right="107" cssclass="btn_Top_search_W" initvalueid="ivBtnAccessibilityButton" onclick="btnSearch_onclick" accessibilitylabel="검색하기"/>
              <Button id="btnSitemap" taborder="3" top="0" width="84" cssclass="btn_Top_sitemap" right="0" bottom="0" initvalueid="ivBtnAccessibilityButton" onclick="divTopB_btnSitemap_onclick" accessibilitylabel="사이트맵 열기"/>
              <Button id="btnClose" taborder="4" top="18" width="48" cssclass="btn_Top_close_M" right="20" initvalueid="ivBtnAccessibilityButton" height="48" visible="false" enable="false"/>
            </Layout>
            <Layout name="mobile">
              <Static id="sta_logo" cssclass="sta_Top_logo_M" width="372" left="20" top="12" height="70" text=""/>
              <Button id="btnSitemap" width="48" top="18" right="20" height="48" cssclass="btn_Top_sitemap_M" accessibilitylabel="메뉴 열기"/>
              <Button id="btnSearch" width="48" top="23" height="48" right="94" cssclass="btn_Top_search_M"/>
              <Div id="divTopBtn" visible="false" formscrolltype="none" enableevent="false" left="26.72%" top="28" width="127" height="48"/>
              <Button id="btnClose" top="23" width="48" height="48" right="20" accessibilitylabel="메뉴닫기"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divTopW" taborder="3" left="0" top="0" height="100" right="0" cssclass="div_top_O" initvalueid="ivDivAccessibilityOff" visible="false" formscrolltype="none" formscrollbartype="none none" formscrollbarsize="10">
          <Layouts>
            <Layout>
              <Static id="sta_logo1" taborder="1" left="50" top="44" width="270" height="52" cssclass="sta_Top_logoB" initvalueid="ivStcAccessibilityOff" onclick="divTopW_sta_logo_onclick" accessibilityrole="link" accessibilitylabel="메인으로 가기"/>
              <Div id="divTopBtn" taborder="2" left="26.77%" top="28" height="48" formscrollbartype="none none" initvalueid="ivDivAccessibilityOff" formscrolltype="none" right="165">
