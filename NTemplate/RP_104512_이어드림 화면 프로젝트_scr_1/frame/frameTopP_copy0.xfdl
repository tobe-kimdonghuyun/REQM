    <Script type="xscript5.1"><![CDATA[/**
*  대국민포탈 - 메인
*  @MenuPath    frame
*  @FileName 	frameTopP.xfdl 
*  @Creator 	TOBESOFT
*  @CreateDate 	2022.08.01
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.08.22	     	consulting			    최초 생성
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::sm_script.xjs";
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_TopBtnPrefix = "TOP_";
this.fvSubSysGb = "";
this.fvLastLeftW=0;
this.fvLastLeftB=0;
this.objApp = nexacro.getApplication();

/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
/**
 * 화면 onload시 처리내역(필수)
 * @edu.cloud.pa.pas.ui.xadl Application_onloadforms 이벤트 콜 함수 
*/
this.fnTopFormload = function()
{
	if (!this.smfIsMobile()) {
		this.divTopB.set_minwidth(1200);
		this.divTopW.set_minwidth(1200);	//1184		
	}

	this.smfChangeDiv("B");
	this.smfInitDiv(this);

	var sSubSystemGb = "PAS";
	this.fvSubSysGb = sSubSystemGb;

	this.divSkip.set_left(0);
	this.divSkip.set_height(0);
	if (this.smfIsMobile()) {
		this.divSkip.form.btnGoMenu.set_visible(false);
		this.divSkip.form.btnAccessbilty.set_left(141);
		this.divSkip.form.sta00.set_left(304);
	}

	// 임시처리
	//this.dsMenu.copyData(this["dsMenu_"+sSubSystemGb.toLowerCase()]);

	var objSubSystemName = {
							 "PAS" : "대국민포털"
						 };
	sSubSystemName = objSubSystemName[sSubSystemGb];
	//this.divDispArea.form.staLogo.set_text(sSubSystemName);

	this.smfSearchService("select")
	// 실행
	.run()
	// 콜백
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		// top 영역 메뉴는 항상 나오게 함
		//if ( nexacro.getApplication().mainframe.getOffsetWidth() > 1280) 
		//{		
			// 메뉴를 로드(테스트를 위해)
			this.fnLoad();			
		//}else
		//{
		//	this.divTopW.form.divTopBtn.setOffsetWidth(0);
		//	this.divTopB.form.divTopBtn.setOffsetWidth(0);			
		//}
	});
	
	this.fnFormInit();
};

this.fnFormInit = function()
{			
	if( nexacro.getEnvironment().enableaccessibility ) {
		this.btnFirstFocus.set_text("Ctrl + Shift + F12 키를 동시에 눌러 스크린리더의 가상커서를 해제하신 후 이용하시기 바랍니다.");	
	}
	this.btnFirstFocus.setFocus();
	this.resetScroll();
};

//divTopB : Main Page or divTopW : 업무메뉴
this.fnTopMode = function(pMode)
{
	if ( pMode == "B" )
	{
		this.set_background("transparent");
		this.divTopW.set_visible(false);
		this.divTopW.bringToPrev();
		this.divTopB.set_visible(true);
		this.divTopB.bringToFront();

		//TopSiteMap 생성		
		//this.smfCreateTopSiteMap();
		
	}else if ( pMode == "W" )
	{
		this.set_background("#ffffff");
		this.divTopW.set_visible(true);
		this.divTopW.bringToFront();
		this.divTopB.set_visible(false);
		this.divTopB.bringToPrev();

		//TopSiteMap 삭제
		//this._smfDestroyTopSitemap();
	}
};


/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
};

