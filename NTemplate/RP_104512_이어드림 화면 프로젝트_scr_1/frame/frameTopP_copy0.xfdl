	// 팝업공지 close
	this.fnCommNoticeClose();

	//웹접근성정책
	var	sMenuUrl = this.dsMenu.lookup("menuId","7000","menuUrlAddr");
	if(!this.smfIsNull(sMenuUrl))
	{		
		this.smfSetServiceLink(sMenuUrl,"open", null, String(this.dsMenu.lookup("menuId","7000","menuNm")));		
	}

	var divWork = this.getOwnerFrame().form.divAll.form.divWork;
	this.fnFormSetFocus(divWork);
};

this.fnFormSetFocus = function(oForm) {
	var comp = oForm.form.components;
	for(var i=0; i<comp.length; i++)
	{
		//접근성 enable true인 첫번째 컴포넌트
		if(comp[i].accessibilityenable==true)
		{
			comp[i].setFocus();
			break;
		}
	}
};

