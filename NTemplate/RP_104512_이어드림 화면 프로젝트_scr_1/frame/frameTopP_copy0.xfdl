/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
* @class fnLoad
* @description topmenu 0 level 생성
* @param N/A
* @return N/A
*/ 
this.fnLoad = function ()
{
	if ( !this.smfIsMobile() )
	{
		// 대분류만추출
		this.dsMenu.filter("menuLvl==0");
		
		// 메뉴를 재생성
		this.fnSetTopMenu("btn_Top_menuW");
		this.fnSetTopMenu("btn_Top_menuB");	
		// 필터를 해제
		this.dsMenu.filter("");		
	}

	//EnvironmentVariable[ev_menuType] 값 체크.
	if ( this.extReqMenu.menuId )
	{
		this.fnOpenMenu(this.extReqMenu);
	}
};

// 외부에서 요청받은 화면을 오픈
this.fnOpenMenu = function(objMenuInfo)
{
	var sMenuUrl = this.dsMenu.lookup("menuId", objMenuInfo.menuId, "menuUrlAddr"); 
	this.smfSetServiceLink(sMenuUrl,"open",objMenuInfo);
};

/**
* @class fnSetTopMenu
* @description topmenu세팅
* @param N/A
* @return N/A
*/ 
this.fnSetTopMenu = function(pCssclass)
{
	var btnObj;

	for (var i = 0; i < this.dsMenu.getRowCount(); i++) 
	{
		var strID   = this.dsMenu.getColumn(i, this.objApp.gv_menuColumns.menuId );  			// 메뉴아이디
		var strName = this.dsMenu.getColumn(i, this.objApp.gv_menuColumns.menuNm );  			// 메뉴명
		var strUrl = this.dsMenu.getColumn(i, this.objApp.gv_menuColumns.pageUrl);  			// 메뉴URL
		var isShow = this.dsMenu.getColumn(i, this.objApp.gv_menuColumns.isShow );  			// 탑(Top 메뉴) 여부
		var parentMenuId = this.dsMenu.getColumn(i, this.objApp.gv_menuColumns.parentMenuId );	
		if ( isShow != "N" && strID != "8000" )
			this.fnCreateTopMenu(strID, strName, strUrl, i,pCssclass);
	}
};

/**
*	@class fnCreateTopMenu
*	@description Top menu creation
*	@param  필수 {String} strID - 버튼아이디
*	@param	필수 {String} strName - 버튼 text
*	@param	필수 {String} strUrl - 버튼 Url(없는 경우는 "")
*	@param	필수 {Number} index - 버튼 순번		
*	@return N/A
*/
this.fnCreateTopMenu = function (strID, strName, strUrl, index,pCssclass)
{
	// Creating page button
	var strFont = 'normal 500 22px/normal "Noto Sans KR Medium","NotoSansKR-Medium"'; // this.btn03._getCurrentStyleInheritValue("font").value;
	var nWidth = nexacro.getTextSize( strName, strFont).nx + 30;  // 40: padding

	var objBtn = new Button();
	
	if ( this.fvLastLeftW > 0 ) this.fvLastLeftW += 40;
	if ( this.fvLastLeftB > 0 ) this.fvLastLeftB += 40;

	if ( pCssclass == "btn_Top_menuW" ) 
	{
		objBtn.init(this.fv_TopBtnPrefix + strID, this.fvLastLeftW, 0, nWidth, 48);	
		this.fvLastLeftW += nWidth;	
		this.divTopB.form.divTopBtn.addChild(objBtn.name, objBtn);
	}else if ( pCssclass == "btn_Top_menuB" )
	{
		objBtn.init(this.fv_TopBtnPrefix + strID, this.fvLastLeftB, 0, nWidth, 48);		
		this.fvLastLeftB += nWidth;		
		this.divTopW.form.divTopBtn.addChild(objBtn.name, objBtn);		
	}

	objBtn.set_text(strName);
	objBtn.set_cssclass(pCssclass);
	objBtn.menuid = strID;
	//objBtn.set_cssclass("TF_menu");

	objBtn.setEventHandler("onclick", this.fnMenuOnClick, this);
	objBtn.set_visible(true);
	objBtn.show();
	
	objBtn._pageUrl = strUrl;
	objBtn._menuId = strID;	
};

this.fnCddcPopup = function()
{
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: this.fnPopupCallback, // 콜백함수 지정
		sender: obj, // sender 지정

		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: "insert"
		},
	};

	// 모달팝업 실행
	this.smfDialog("_auto", "comm::comm_cddcList.xfdl", popupParams);	
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 0 level 메뉴 클릭
 *	Top 메뉴 접근(클릭) 시,
 *   1. 0 level 클릭 시, 1레벨 첫 번째 메뉴 url 폼 오픈 한다.(1레벨 존재 시)
 *   2. 0 level 클릭 시, 0 level url 폼 존재 & 1 level url 폼 미 존재 시, 0 레벨 url 폼 오픈 한다. ( LNB 1레벨 표시 visible = false ( > 표시 포함) )
 *   3. 모바일 메뉴 0레벨 클릭 시 (하위 메뉴 보이기 & 숨기기) 한다.( (↑,↓) 표시 )
 *   4. 모바일 메뉴 0레벨 하위 메뉴 없다면, (↑,↓) 표시 없음, 클릭 시,0 레벨 url 폼 오픈 한다.
 *   5. 모바일 메뉴 0레벨 클릭(펼치기) 시1,2 기능 적용한다. 
*/ 
this.fnMenuOnClick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sMenuId = obj._menuId;

	var aMenuPathInfo,sMenuIdLevel0,sMenuIdLevel1;
	var nFindRow = this.dsMenu.findRow("menuId",sMenuId);
	
	aMenuPathInfo = this.getOwnerFrame().form.divAll.form.divHead.form.fnGetMenuPathInfoByTopDown(nFindRow);
	sMenuIdLevel0 = aMenuPathInfo[0];
	sMenuIdLevel1 = aMenuPathInfo[1];

	if ( sMenuIdLevel1 )
	{
		sMenuUrl = this.dsMenu.lookup("menuId",sMenuIdLevel1,"menuUrlAddr"); 
		this.smfSetServiceLink(sMenuUrl,"open", null, String(obj.text));
	}else
	{
		this.smfSetServiceLink(obj._pageUrl,"open", null, String(obj.text));
	}
};

