 ************************************************************************************************/ 
this.fnTransCallback = function(svcid,errcd,errmsg)
{

}
/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){

};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnRearrageCenter = function()
{
	// 모바일
	if(this.smfIsMobile())
	{

	}
	// 데스크탑
	else
	{
		var nWidth = this.getOffsetWidth();
		if(nWidth > 1200)
		{
			var nLeftGap = parseInt((nWidth-1200)/2);

			// 이미지를 조정한다.
			var nImageWidth = nWidth - 230; // 190: right gap
			if(nImageWidth<(nLeftGap+1200)) nImageWidth = nLeftGap+1200;
			else if(nImageWidth<1200) nImageWidth = 1200;
			
			this.divTop.setOffsetWidth(nImageWidth);	
			
			this.divTop.form.divTitle.setOffsetLeft(nLeftGap);
			
			this.div00.setOffsetLeft(nLeftGap);

		}	
	}
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.btnLink01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSetSubSystemGb(obj.btnValue);
	this.smfSetSubSystemDetailGb(obj.btnSubValue);
	
	var objDivBottom = this.getOwnerFrame().form.divAll.form.divBottom;
	objDivBottom.form.divPolicy.set_visible(true);
	objDivBottom.form.divPolicy.setOffsetHeight(60);
	
	var oParam = {};	
	this.smfSetWorkPage("frame::uds/frameSubMain.xfdl",oParam,false);
};

this.btnLink02_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSetSubSystemGb(obj.btnValue);
	this.smfSetSubSystemDetailGb(obj.btnSubValue);
	
	var objDivBottom = this.getOwnerFrame().form.divAll.form.divBottom;
	objDivBottom.form.divPolicy.set_visible(true);
	objDivBottom.form.divPolicy.setOffsetHeight(60);
	
	var oParam = {};	
	this.smfSetWorkPage("frame::sqa/frameSubMain3.xfdl",oParam,false);
};

this.frameFirstMain_oninit = function(obj:nexacro.Form,e:nexacro.EventInfo)
{
return;
	if(!this.smfIsLogin()){
		trace(" this.smfIsLogin() : " + this.smfIsLogin());
		var oParam = {};
		this.smfSetWorkPage("pa_uds_cmm_cm::uds_cmmcm00_m00.xfdl",oParam,false);
	} else {
		var objDivTop = this.getOwnerFrame().form.divTop;
		objDivTop.set_visible(true);
		objDivTop.setOffsetHeight(45);
		
		// divDispArea
		// objDivTop.form.divDispArea.form.btnLogin.set_visible(false);
		objDivTop.form.divDispArea.form.btnSitemap.set_visible(false);
		
		var objDivNotice = this.getOwnerFrame().form.divNotice;
		objDivNotice.set_visible(false);
		objDivNotice.setOffsetHeight(0);
		
		var objDivBottom = this.getOwnerFrame().form.divAll.form.divBottom;
		objDivBottom.form.divPolicy.set_visible(false);
		objDivBottom.form.divPolicy.setOffsetHeight(0);
	}
};

this.btnIsInstalled_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var bResult = this.divInstallCheck.form.fnCheckInstall();
	
	if(!bResult)
	{
		// this.divInstallCheck
		this.divInstallCheck.set_visible(true);
		
		this.div00.form.btnLink01.set_enable(false);
		this.div00.form.btnLink02.set_enable(false);
	}
	
	// TEST를 위해
	this.divInstallCheck.set_visible(true);
	
};

]]></Script>
