<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frameFirstMain" width="1920" height="846" onload="frameFirstMain_onload" titletext="대입전형(학생부) 게이트화면" onsize="frameFirstMain_onsize" oninit="frameFirstMain_oninit">
    <Layouts>
      <Layout height="846" width="1920" screenid="ScreenDeskTop">
        <Div id="divTop" taborder="0" left="0" top="0" height="500" cssclass="div_WF_Main06" initvalueid="ivDivAccessibilityOn" formscrollbartype="none none" formscrolltype="none" width="1700">
          <Layouts>
            <Layout>
              <Div id="divTitle" taborder="0" text="div00" left="351" top="120" width="588" height="234">
                <Layouts>
                  <Layout>
                    <Static id="staTitle" taborder="0" text="대입전형 자료수신" left="0" top="62" width="580" height="75" cssclass="sta_WF_MainTxt" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="staSTitle" taborder="1" text="대입전형 자료를 온라인으로 제공하는 서비스입니다." left="0" top="147" width="565" height="40" cssclass="font18R" initvalueid="ivStcAccessibilityOn"/>
                  </Layout>
                  <Layout name="Layout0"/>
                </Layouts>
              </Div>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta00" taborder="1" left="0" top="500" width="247" height="214" cssclass="sta_WF_Graphic_Left" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta00_00" taborder="2" width="280" height="296" cssclass="sta_WF_Graphic" initvalueid="ivStcAccessibilityOff" right="0" bottom="0" visible="false"/>
        <Div id="div00" taborder="3" text="div00" left="370" top="530" width="1284" height="202">
          <Layouts>
            <Layout>
              <Static id="sta01" taborder="0" text="원하는 &#13;&#10;업무를&#13;&#10;선택해주세요." left="0" top="0" width="280" height="148" cssclass="sta_WF_Txt34B" initvalueid="ivStcAccessibilityOn" usedecorate="true" verticalAlign="top"/>
              <Button id="btnLink01" taborder="1" text="학생부" top="2" width="332" height="134" cssclass="btn_WF_CollegeStud" left="554" initvalueid="ivBtnAccessibilityLink" onclick="btnLink01_onclick" btnValue="UDS" btnSubValue=""/>
              <Button id="btnLink02" taborder="2" text="검정고시" top="2" height="134" cssclass="btn_WF_CollegeGED" left="914" initvalueid="ivBtnAccessibilityLink" width="332" onclick="btnLink02_onclick" btnValue="SQA" btnSubValue="103"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divInstallCheck" taborder="4" text="div01" left="1019" top="153" width="501" height="147" url="frame::uds/frameInstallCheck.xfdl" cssclass="div_WF_Complain" visible="false"/>
        <Button id="btnIsInstalled" taborder="5" text="Install여부 확인(Test용)" left="219" top="679" width="184" height="40" onclick="btnIsInstalled_onclick" visible="false"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
