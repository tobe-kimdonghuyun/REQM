    <Script type="xscript5.1"><![CDATA[/**
*  교육디지털 원패스
*  @MenuPath    frame > frameMain
*  @FileName    frameMain.xfdl 
*  @Creator     kmp
*  @CreateDate  2021.12.27
*  @Desction    base가 되는 화면
************** 소스 수정 이력 ***********************************************
*  date                 Modifier                Description
*******************************************************************************
*  2021.12.27           kmp                     최초 생성 
*******************************************************************************
*/ 
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::pam_script.xjs";
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_workPageParams = {};    //화면전환시 넘길 parameter
this.fv_isMobile;   //모바일로 접속여부
this.fv_device;     //device 종류
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
/**
 * 화면 onload시 처리내역
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{   
    this.smfInitForm(this);
    
    // Top영역의 사용자메뉴얼을 보여준다.
    this.fnShowManualDiv(true);

    // 메인 페이지를 보여주기 위한 정보를 표시한다.
    var objMainForminfo = {
                          quickmenu : {
                                          use : "N"                      //
                                        , url : ""   //
                                      }
                        , toplink : {
                                          use   : "N"                                 //
                                        , link  : [ ]                                  // 링크정보(배열)
                                      }
                        , noticeband : {
                                          use   : "N"                 //
                                        , serviceurl : ""    //  
                                       }
                      } 
    this.pamfSetMainPageInfo(objMainForminfo);
};

/**
 * @description 사이즈 변경시 위치변경
*/
this.frameMain_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/ 
this.fnTransCallback = function(svcid,errcd,errmsg)
{
}
/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// Top영역의 사용자메뉴얼을 보여준다.
this.fnShowManualDiv = function(bShow)
{
    var objTopDiv = this.getOwnerFrame().form.divTop;
    
    if(objTopDiv)
    {
        objTopDiv.form.fnShowTopDiv(bShow);
    }   
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 들어가기 버튼 클릭 시
 * @param  : obj        - [object]Button
 * @param  : e          - [string]ClickEventInfo
 * @return : N/A
 */
this.Button_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
    this.smfSetSubSystemGb(obj.btnValue);
    
    this.fnShowManualDiv(false);
    
    var oParam = {};
    this.smfSetWorkPage("comm::comm_cddcList.xfdl",oParam,false);
};

/**
 * 포커스 시
 * @param  : obj        - [object]Div
 * @param  : e          - [string]SetFocusEventInfo
 * @return : N/A
 */
this.Div_onsetfocus = function(obj:nexacro.Div,e:nexacro.SetFocusEventInfo)
{
    for(var i = 0; i < 6; i++){
        obj.parent["div0" + i + "S"].set_visible(false);
    }
    obj.parent[obj.id + "S"].set_visible(true);
};

/**
 * 마우스 포인트 들어올 시
 * @param  : obj        - [object]Div
 * @param  : e          - [string]MouseEventInfo
 * @return : N/A
 */
this.Div_onmouseenter = function(obj:nexacro.Div,e:nexacro.MouseEventInfo)
{
    this.Div_onsetfocus(obj, e);
};

/**
 * 포커스아웃 시
 * @param  : obj        - [object]Div
 * @param  : e          - [string]MouseEventInfo
 * @return : N/A
 */
this.Div_onkillfocus = function(obj:nexacro.Div,e:nexacro.KillFocusEventInfo)
{
    for(var i = 0; i < 6; i++){
        this.div00.form["div0" + i + "S"].set_visible(false);
    }
};

/**
 * 마우스 포인트 나갈 시
 * @param  : obj        - [object]Div
 * @param  : e          - [string]MouseEventInfo
 * @return : N/A
 */
this.Div_onmouseleave = function(obj:nexacro.Div,e:nexacro.MouseEventInfo)
{
    if ((e.canvasx < 0 || e.canvasy < 0) || (e.canvasx + 6 > obj.getOffsetWidth() || e.canvasy + 6 > obj.getOffsetHeight())){
        for(var i = 0; i < 6; i++){
            this.div00.form["div0" + i + "S"].set_visible(false);
        }
    }
};

/**
 * 화면 사이즈 변경 시
 * @param  : obj        - [object]Form
 * @param  : e          - [string]SizeEventInfo
 * @return : N/A
 */
this.frameSubMain_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
    if (this.smfIsMobile()){
        this.divTopNotice.form.sta01.setOffsetLeft((this.getOffsetWidth() - this.divTopNotice.form.sta01.getOffsetWidth()) /2);
        this.smfResetScroll(this);
    }
};]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
  </Form>
</FDL>
