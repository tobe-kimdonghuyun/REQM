<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frameTopDiv" width="200" height="43" onload="fnOnload" scrollbartype="none none" scrolltype="none" titletext="사용자매뉴얼영역">
    <Layouts>
      <Layout height="43" width="200" screenid="ScreenDeskTop">
        <Button id="btn00" taborder="0" text="사용자매뉴얼" left="15" top="7" height="30" initvalueid="ivBtnAccessibilityButton" visible="true" right="55" onclick="btn00_onclick" cssclass="btn_WF_Function"/>
      </Layout>
      <Layout height="63" mobileorientation="portrait" name="Layout0" type="default" width="250" screenid="mobile,tablet">
        <Button id="btn00" left="0" top="0" right="0" bottom="0" cssclass="btn_WF_FunctionB"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    업무지원 사용자 매뉴얼
*  @FileName 	frameTopDiv
*  @Creator 	김민성
*  @CreateDate 	2023.06.23
*  @Desction    업무지원 사용자 매뉴얼
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.06.23            김민성                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitDiv(obj);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

this.fnPopupCallback = function(){
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: this.fnPopupCallback,
		internalCallback : this.fnPopupCallback,
		sender: obj, // sender 지정
		params: {
			// 처리타입 지정
			procType : 'none'
		},
	};

	this.smfDialog("_auto", "frame::afs/frameManualPopup.xfdl", popupParams, null, null, this.smfIsMobile() ? 640 : null, this.smfIsMobile() ? 635 : null);
};]]></Script>
    <Objects/>
  </Form>
</FDL>
