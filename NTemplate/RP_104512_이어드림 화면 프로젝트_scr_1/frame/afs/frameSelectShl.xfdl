<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frameSelectShl" width="600" height="650" titletext="조직목록" onload="fnOnload">
    <Layouts>
      <Layout height="650" width="600" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="20" top="20" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="조직목록" left="0" top="0" height="44" cssclass="img_WF_SubTit01" width="170" initvalueid="ivTitleAccessibilityOn"/>
            </Layout>
            <Layout name="Layout0">
              <ImageViewer id="imgTitle" height="65" left="0" top="0" width="199"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta00" taborder="2" left="0" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta01" taborder="3" left="20" top="64" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Button id="btnClose" taborder="1" text="확인" height="30" width="50" left="45.83%" fittocontents="width" initvalueid="ivBtnAccessibilityButton" onclick="btnClose_onclick" top="600"/>
        <Static id="sta03" taborder="5" left="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff" bottom="0" height="20"/>
        <Static id="sta04" taborder="6" left="0" top="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="20" bottom="0"/>
        <Static id="sta05" taborder="7" top="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="20" bottom="0" right="0"/>
        <Static id="sta02" taborder="4" left="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff" height="20" top="580"/>
        <Div id="divMain" taborder="8" left="20" top="94" height="486" right="20">
          <Layouts>
            <Layout>
              <Grid id="grdMain" taborder="0" left="0" top="0" right="0" binddataset="dsMainSet" autofittype="col" selecttype="cell" formatid="default" oncelldblclick="grdMain_oncelldblclick" bottom="0">
                <Formats>
                  <Format id="default">
                    <Columns>
                      <Column size="65"/>
                      <Column size="250"/>
                    </Columns>
                    <Rows>
                      <Row size="36" band="head"/>
                      <Row size="40"/>
                    </Rows>
                    <Band id="head">
                      <Cell text="순번"/>
                      <Cell col="1" text="조직명"/>
                    </Band>
                    <Band id="body">
                      <Cell text="expr:currow + 1" cursor="pointer" textAlign="center"/>
                      <Cell col="1" text="bind:shlNm" cursor="pointer" textAlign="center"/>
                    </Band>
                  </Format>
                  <Format id="format00">
                    <Columns>
                      <Column size="65"/>
                      <Column size="250"/>
                    </Columns>
                    <Rows>
                      <Row size="60" band="head"/>
                      <Row size="70"/>
                    </Rows>
                    <Band id="head">
                      <Cell text="순번"/>
                      <Cell col="1" text="조직명"/>
                    </Band>
                    <Band id="body">
                      <Cell text="expr:currow + 1" cursor="pointer" textAlign="center"/>
                      <Cell col="1" text="bind:shlNm" cursor="pointer" textAlign="center"/>
                    </Band>
                  </Format>
                </Formats>
              </Grid>
            </Layout>
            <Layout name="Layout0">
              <Grid id="grdMain" formatid="format00"/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
      <Layout name="Layout0" screenid="mobile,tablet" width="600" height="650" mobileorientation="portrait" type="default">
        <Button id="btnClose" left="41.50%" top="570" width="108" height="60" taborder="1"/>
        <Static id="sta02" left="20" top="510" height="60" right="20" text="60" taborder="4"/>
        <Div id="divTitle" height="65" left="20" top="70" right="20" taborder="0"/>
        <Static id="sta01" left="20" top="136" height="60" right="20" text="60" taborder="3"/>
        <Static id="sta00" left="20" top="0" height="70" right="20" text="70" taborder="2"/>
        <Static id="sta04" left="0" top="0" width="20" bottom="0" taborder="6"/>
        <Static id="sta05" top="0" width="20" right="0" bottom="0" taborder="7"/>
        <Static id="sta03" left="20" height="20" right="20" taborder="5" top="630"/>
        <Div id="divMain" left="20" top="196" height="314" right="20"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsMain" useclientlayout="true">
        <ColumnInfo>
          <Column id="invlNo" type="STRING" size="256" description="조직코드"/>
          <Column id="shlCd" type="STRING" size="256"/>
          <Column id="shlNm" type="STRING" size="256"/>
          <Column id="itemCd" type="STRING" size="256"/>
          <Column id="pheSscSn" type="STRING" size="256"/>
          <Column id="type" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsMainSet" useclientlayout="true">
        <ColumnInfo>
          <Column id="invlNo" type="STRING" size="256" description="조직코드"/>
          <Column id="shlCd" type="STRING" size="256"/>
          <Column id="shlNm" type="STRING" size="256"/>
          <Column id="itemCd" type="STRING" size="256"/>
          <Column id="pheSscSn" type="STRING" size="256"/>
          <Column id="type" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    조직목록
*  @FileName 	frameSelectShl.xfdl 
*  @Creator 	김민성
*  @CreateDate 	2023.05.22
*  @Desction    조직목록
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.05.22            김민성                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	
	this.pv_params = this.smfGetPopupParams();
	this.dsMain.loadXML(this.pv_params.dataset);
	var shlCdSet = new Set();
	for(var i = 0; i < this.dsMain.rowcount; i++){
		shlCdSet.add(this.dsMain.getColumn(i, 'shlCd'));
	}
	
	for(var value of shlCdSet){
		this.dsMainSet.copyRow(this.dsMainSet.addRow(), this.dsMain, this.dsMain.findRow('shlCd', value));
	}
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
  /**
 * 조직 선택
 * @param : N/A
 * @param : N/A
 */
 this.fnChoice = function(){
	if(this.dsMain.rowposition <= -1) return;
	
	this.smfSendResponseToOpener({
		"shlCd": this.dsMainSet.getColumn(this.dsMainSet.rowposition, 'shlCd')
	});

	this.close(true);
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 확인 버튼 클릭 시
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnChoice();
};

/**
 * 그리드 셀 더블 클릭 시
* @param  : obj		   - [object]Grid
* @param  : e		   - [string]GridClickEventInfo
* @return : N/A
 */
this.grdMain_oncelldblclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	this.fnChoice();
};]]></Script>
  </Form>
</FDL>
