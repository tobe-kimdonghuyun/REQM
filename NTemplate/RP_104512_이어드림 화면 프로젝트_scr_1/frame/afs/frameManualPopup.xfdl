    <Objects/>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    매뉴얼다운로드팝업
*  @FileName 	frameManualPopup.xfdl 
*  @Creator 	김민성
*  @CreateDate 	2023.06.23
*  @Desction    매뉴얼다운로드팝업
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.06.23            김민성                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	this.smfResetScroll(this);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 다운로드 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.Button_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sBaseUrl= window.location.protocol + "//" + window.location.host;
	system.execBrowser(sBaseUrl + obj.sUrl);
};

/**
 * 닫기 클릭 시
 * @param  : obj		   - [object]Static
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.div00_staClose_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	this.close(false);
};]]></Script>
  </Form>
