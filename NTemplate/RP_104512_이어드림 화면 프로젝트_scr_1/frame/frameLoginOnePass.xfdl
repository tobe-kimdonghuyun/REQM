<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frameLoginOnePass" width="1200" height="745" titletext="교육부 디지털원패스 로그인" onload="fnOnload">
    <Layouts>
      <Layout height="745" width="1200" screenid="ScreenDeskTop">
        <ImageViewer id="img00" taborder="0" text="로그인" left="527" top="117" height="58" cssclass="font34B_C" width="147" initvalueid="ivTitleAccessibilityOn" onkeyup="img00_onkeyup" onkeydown="img00_onkeydown" onclick="img00_onclick"/>
        <Div id="div00" taborder="1" left="250" top="170" height="350" text="" initvalueid="ivDivAccessibilityOff" right="250">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" left="212" top="40" height="115" cssclass="sta_Login_onepass" text="" width="276" initvalueid="ivStcAccessibilityOn"/>
              <Button id="btnLogin" taborder="1" text="교육 디지털원패스 로그인" left="176" top="193" width="348" height="60" cssclass="btn_WF_Custom" initvalueid="ivBtnAccessibilityButton" onclick="div00_btnLogin_onclick"/>
              <Edit id="edt00" taborder="3" left="176" top="193" width="220" height="60" displaynulltext="testID" onkeyup="edt00_onkeyup" visible="false"/>
              <Button id="btnLogin00" taborder="2" text="ID로그인" left="410" top="193" width="114" height="60" initvalueid="ivBtnAccessibilityButton" onclick="div00_btnLogin00_onclick" visible="false"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="sta00" left="182" top="0" height="115" right="182" background="url('theme://images/PolicyV2_link03B_M.png') no-repeat center"/>
              <Button id="btnLogin" left="80" top="143" height="60" right="80" cssclass="btn_WF_CustomR"/>
              <Button id="btnLogin00" left="edt00:20" top="143" height="60" right="80"/>
              <Edit id="edt00" left="80" top="143" width="270" height="60"/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
      <Layout height="700" mobileorientation="portrait" name="Layout0" type="default" width="640" screenid="mobile,tablet">
        <ImageViewer id="img00" left="247" top="67" height="58" right="246" cssclass="font34B_C_M"/>
        <Div id="div00" left="0" top="189" height="305" right="0"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    업무지원 > 로그인
*  @FileName 	frameLoginOnePass.xfdl 
*  @Creator 	김민성
*  @CreateDate 	2023.01.05
*  @Desction    업무지원 디지털원패스 로그인
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.01.05            김민성                   최초 생성
*******************************************************************************
*/
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.tmpLoginYn = false;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);	
	this.pv_params = this.smfGetFormParams();
	this.dsSearch.setColumn(0, 'cddcCd', this.smfGetCddcCode());
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 팝업의 콜백함수
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	for(var i = this.dsMainPhe.rowcount-1; i > -1; i--){
		if (this.dsMainPhe.getColumn(i, 'shlCd') != e.shlCd){
			this.dsMainPhe.deleteRow(i);
		}
	}
	this.dsMain.setColumn(0, 'orgCd', e.shlCd);
	
	this.dsMain.setColumn(0, 'kornFlnm', this.dsMain.getColumn(0, 'userNm'));
	this.smfSetSessionDataset(this.dsMain);
	this.smfSendLoginLog(this, "LG004");
	this.fnUpdateSession();
};

/**
 * 테스트로그인
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallbackShl = function(e, sender){
	// 서버에서 세션 설정
	this.dsSearch.setColumn(0, 'userNm', 'testUser');
	this.dsSearch.setColumn(0, 'userId', this.div00.form.edt00.value);
	this.dsSearch.setColumn(0, 'shlCd', e ? e.row.orgCd : null);
	this.dsSearch.setColumn(0, 'lgnMthScCd', '01'); // 로그인 구분 01: 교육디지털원패스, 02: 공동인증서, 03: 간편인증
	this.dsSearch.setColumn(0, 'sysCd', this.smfGetSubSystemGb());
	this.fnSearchSession();
};

/**
 * 디지털원패스 팝업의 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnEdoPopupCallback = function(e, sender){
	if (e.data == "User Close"){
		return;
	}
	
	var obj = JSON.parse(e.data);
	for(var id in obj){
		this.dsSearch.setColumn(0, id, obj[id]);
	}
	if(this.dsSearch.getColumn(0, 'resultCode') == '000') {
		// 서버에서 세션 설정
		this.dsSearch.setColumn(0, 'lgnMthScCd', '01'); // 로그인 구분 01: 교육디지털원패스, 02: 공동인증서, 03: 간편인증
		this.dsSearch.setColumn(0, 'sysCd', this.smfGetSubSystemGb());
		this.fnSearchSession();
	}else {
		this.smfAlert('LI155', ['관리자에 문의하세요']);
		return;
	}
	
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 로그인 세션 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchSession = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("check")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				return;
			}
			
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){
				if (this.dsApiResponseList.getColumn(0, 'usePslYn') == 'Y'){
					if (this.smfGetSubSystemGb() == "PHE"){
						this.fnPheLoginChk();
					}else{
						this.dsMain.setColumn(0, 'kornFlnm', this.dsMain.getColumn(0, 'userNm'));
						this.smfSetSessionDataset(this.dsMain);
						this.smfSendLoginLog(this, "LG004");
						this.fnCallbackConfirmAuth();
					}
				}else{
					this.smfAlert('LI155', ['로그인 정보가 올바르지 않습니다.']);
					return;
				}
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')]);
			}
		});
};

/**
 * 로그인 세션 수정
 * @param : N/A
 * @param : N/A
 */
this.fnUpdateSession = function()
{
 	// 서비스 객체 생성
	this.smfSaveService("update")
		.showConfirm(false)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.fnCallbackConfirmAuth();
		});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * 체육 로그인 체크
 * @param : N/A
 * @param : N/A
 */
this.fnPheLoginChk = function(){
	if (this.dsMainPhe.rowcount == 0){
		this.smfAlert('LI155', ['해당 로그인에 대한 정보가 없습니다.']);
		return;
	}
	
	var firstShlCd = this.dsMainPhe.getColumn(0, 'shlCd');
	var otherShlCnt = this.dsMainPhe.getCaseCount("shlCd != '" + firstShlCd + "'");
	
	if(otherShlCnt == 0){
		this.dsMain.setColumn(0, 'kornFlnm', this.dsMain.getColumn(0, 'userNm'));
		this.smfSetSessionDataset(this.dsMain);
		this.smfSendLoginLog(this, "LG004");
		this.fnCallbackConfirmAuth();
	}else {
		var popupParams = {
			callback: this.fnPopupCallback,	// 콜백함수 지정
			sender: obj, 						// sender 지정
			titlebar : false,
			params: {							// 팝업 전달 파라메터 지정
				procType: "search",				// 처리타입 지정
				dataset : this.dsMainPhe.saveXML()
			},
		};
		this.smfDialog("_auto", "frame::afs/frameSelectShl.xfdl" ,popupParams);
	}
};

/**
 * 인증 처리
 * @param : N/A
 * @param : N/A
 */
this.fnCallbackConfirmAuth = function(){

	// 로그인 됐다고 판정
	this.smfSetLoginState(true);
	
	// Top영역을 변경
	var objTopFrameForm = this.getOwnerFrame().form.divTop.form;
	if(objTopFrameForm)	{
		objTopFrameForm.fnLoginAfter();
	}
	
	// 다음화면으로 이동
	var params = {};
	
	var sSubSystemGb = this.smfGetSubSystemGb();
	if(  (sSubSystemGb=="AFS")   // 업무지원(방과후학교)
		  || (sSubSystemGb=="ECC")   // 업무지원(초등돌봄)
		  || (sSubSystemGb=="PHE")   // 업무지원(체육)
		  || (sSubSystemGb=="SML")   // 업무지원(급식)
		  ) {
		if(objTopFrameForm)		objTopFrameForm.fnRearrageTopComp(sSubSystemGb,"expand");
		// 메뉴의 첫번째화면으로 이동
		var sUrl = this.fnFindFirstWorkPageUrl(sSubSystemGb);
		var bShowHead = true;
		this.smfSetWorkPage(sUrl,params,false);
	}
};

/**
 * 서브시스템에 맞는 URL가져오기
 * @param : sSubSystemGb	- 서브시스템코드
 * @return : sUrl			- URL
 */
this.fnFindFirstWorkPageUrl = function(sSubSystemGb)
{
	var sUrl = "";
	var objTopFrameForm = this.getOwnerFrame().form.divTop.form;
	var objDs = objTopFrameForm.divMenu.form['dsMenu_' + sSubSystemGb.toLowerCase() + (this.smfIsMobile() ? '_m' : '')];
	
	/************************************************************************
		급식 메뉴 구성
		1001	CCP관리
		1002	식재료검수처리
		1003	운영평가점검표및배점관리
		1004	위생안전점검표및배점관리
		1005	(유)급식관리
		1006	(유)운영평가항목및배점관리
		1007	(유)위생안전점검표및배점관리
	 ************************************************************************/
	if(sSubSystemGb=="SML"){
		if (this.dsMain.getColumn(0, 'instClfCd') < 4){ // 교육청, 교육지원청
			for(var i = 0; i < objDs.rowcount; i++){
				if (['1000', '1001', '1002', '1003', '1004', '1006', '1007'].indexOf(objDs.getColumn(i, "menuId")) > -1){
					objDs.setColumn(i, "isShow", null);
				}else{
					objDs.setColumn(i, "isShow", 'N');
				}
			}
		}else{
			if (this.dsMain.getColumn(0, 'shlCrseScCd') == 1){ // 유치원
				for(var i = 0; i < objDs.rowcount; i++){
					if (['1000', '1002', '1005'].indexOf(objDs.getColumn(i, "menuId")) > -1){
						objDs.setColumn(i, "isShow", null);
					}else{
						objDs.setColumn(i, "isShow", 'N');
					}
				}
			}else{ // 학교
				for(var i = 0; i < objDs.rowcount; i++){
					if (['1000', '1001', '1002'].indexOf(objDs.getColumn(i, "menuId")) > -1){
						objDs.setColumn(i, "isShow", null);
					}else{
						objDs.setColumn(i, "isShow", 'N');
					}
				}
			}
		}
	}else if(sSubSystemGb=="PHE"){
		objDs.setColumn(objDs.findRow('menuId', '1001'), "isShow", this.dsMainPhe.getCaseCount("type == 'SPORTS'") == 0 ? 'N' : null);
		objDs.setColumn(objDs.findRow('menuId', '1002'), "isShow", this.dsMainPhe.getCaseCount("type == 'WORKOUT'") == 0 ? 'N' : null);
	}
	objTopFrameForm.dsMenu.copyData(objDs);
	
	for(var i=0; i < objDs.rowcount; i++){
		var sMenuUrl = objDs.getColumn(i, "menuUrl");
		var sIsShow = objDs.getColumn(i, "isShow");
		
		if((!this.smfIsNull(sMenuUrl)) && sIsShow!="N"){
			sUrl =  sMenuUrl;
			break;
		}
	}
	return sUrl;
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 공동인증서 로그인 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.div00_btnLogin_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objParam = {objForm:this, popupcallback :this.fnEdoPopupCallback};
	this.smfExecEduDOAuth(objParam);
};

// 임시 로그인 소스 코드 삭제예정 start//
this.div00_btnLogin00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (this.smfIsNull(this.div00.form.edt00.value)){
		this.smfAlert('LI155', ['ID를 입력해주세요.']);
		return;
	}
	this.fnPopupCallbackShl();
};

this.edt00_onkeyup = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if (e.keycode == 13){
		this.div00_btnLogin00_onclick(null, null);
	}
};

this.img00_onkeydown = function(obj:nexacro.ImageViewer,e:nexacro.KeyEventInfo)
{
	this.tmpLoginYn = e.ctrlkey && e.shiftkey ? true : false;
};
this.img00_onkeyup = function(obj:nexacro.ImageViewer,e:nexacro.KeyEventInfo)
{
	if (this.tmpLoginYn && e.keycode == 32){
		var isVisible = this.div00.form.btnLogin.visible ? false : true;
		
		this.div00.form.btnLogin.set_visible(isVisible);
		this.div00.form.btnLogin00.set_visible(!isVisible);
		this.div00.form.edt00.set_visible(!isVisible);
	}
};

this.img00_onclick = function(obj:nexacro.ImageViewer,e:nexacro.ClickEventInfo)
{
	if(this.smfContainsStr(window.location.host, "dev") && this.smfIsMobile()){
		this.div00.form.btnLogin.set_visible(false);
		this.div00.form.btnLogin00.set_visible(true);
		this.div00.form.edt00.set_visible(true);
	}
};
// 임시 로그인 소스 코드 삭제예정 end//

]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">check</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsMain=dsMain dsMainPhe=dsMainPhe dsApiResponseList=dsApiResponseList</Col>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">R</Col>
            <Col id="bindingControls"/>
            <Col id="url">/sac_cmm_cm00_004.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
          <Row>
            <Col id="id">update</Col>
            <Col id="inDatasets">dsMain=dsMain</Col>
            <Col id="outDatasets"/>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">R</Col>
            <Col id="bindingControls"/>
            <Col id="url">/sac_cmm_cm00_005.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="cddcNm" type="STRING" size="256"/>
          <Column id="lgnMthScCd" type="STRING" size="256"/>
          <Column id="sysCd" type="STRING" size="256"/>
          <Column id="resultCode" type="STRING" size="256"/>
          <Column id="userId" type="STRING" size="256"/>
          <Column id="userDtcNo" type="STRING" size="256"/>
          <Column id="userPswd" type="STRING" size="256"/>
          <Column id="userNm" type="STRING" size="256"/>
          <Column id="eduDgtlOpsUserScCd" type="STRING" size="256"/>
          <Column id="userStsCd" type="STRING" size="256"/>
          <Column id="cetInstIdfNo" type="STRING" size="256"/>
          <Column id="certDtcNm" type="STRING" size="256"/>
          <Column id="useYn" type="STRING" size="256"/>
          <Column id="userScCd" type="STRING" size="256"/>
          <Column id="ogdpInstCd" type="STRING" size="256"/>
          <Column id="ogdpInstNm" type="STRING" size="256"/>
          <Column id="hffcStsCd" type="STRING" size="256"/>
          <Column id="invlNo" type="STRING" size="256"/>
          <Column id="mnrAuthCd" type="STRING" size="256"/>
          <Column id="lastLgnDt" type="STRING" size="256"/>
          <Column id="sxdsScCd" type="STRING" size="256"/>
          <Column id="stuInvlNo" type="STRING" size="256"/>
          <Column id="shlCrseScCd" type="STRING" size="256"/>
          <Column id="shlCd" type="STRING" size="256"/>
          <Column id="shlNm" type="STRING" size="256"/>
          <Column id="ayr" type="STRING" size="256"/>
          <Column id="grd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsApiResponseList" useclientlayout="true">
        <ColumnInfo>
          <Column id="code" type="STRING" size="256" description="연계상태값"/>
          <Column id="message" type="STRING" size="256"/>
          <Column id="usePslYn" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true">
        <ColumnInfo>
          <Column id="userId" type="STRING" size="256"/>
