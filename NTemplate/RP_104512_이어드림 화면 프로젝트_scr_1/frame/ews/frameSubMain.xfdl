/**
 * 하단의 링크에 의한 이동처리를 한다 
 */ 
this.fnRedirectFuncLink = function(obj)
{
	var sUrl = ""; 
	var sCddcCd = this.smfGetCddcCode();
/*
                    <Button id="btnRedirect00" taborder="4" text="시도교육청별&#13;&#10;지원기준" left="90" top="20" width="120" height="120" cssclass="btn_OneClick_linkText" initvalueid="ivBtnAccessibilityLink" icon="url('theme://images/ico_Main_OneClick01.png')" onclick="ButtonLink_onclick" _linkNo="100"/>
                    <Button id="btnRedirect01" taborder="5" text="소득인정액&#13;&#10;산정기준" left="391" top="20" width="120" height="120" cssclass="btn_OneClick_linkText" initvalueid="ivBtnAccessibilityLink" icon="url('theme://images/ico_Main_OneClick02.png')" onclick="ButtonLink_onclick" _linkNo="200"/>
                    <Button id="btnRedirect02" taborder="6" text="교육비 지원&#13;&#10;온라인 신청 바로가기" left="671" top="20" width="160" height="120" cssclass="btn_OneClick_linkText" initvalueid="ivBtnAccessibilityLink" icon="url('theme://images/ico_Main_OneClick03.png')" onclick="ButtonLink_onclick" _linkNo="300"/>
                    <Button id="btnRedirect03" taborder="7" text="교육급여&#13;&#10;온라인 신청 바로가기" left="969" top="20" width="160" height="120" cssclass="btn_OneClick_linkText" initvalueid="ivBtnAccessibilityLink" icon="url('theme://images/ico_Main_OneClick04.png')" onclick="ButtonLink_onclick" _linkNo="400"/>
                    <Button id="btnRedirect04" taborder="8" text="교육비 지원 신청&#13;&#10;대상여부조회" left="90" top="184" width="120" height="120" cssclass="btn_OneClick_linkText" initvalueid="ivBtnAccessibilityLink" icon="url('theme://images/ico_Main_OneClick05.png')" onclick="ButtonLink_onclick" _linkNo="500"/>
                    <Button id="btnRedirect05" taborder="9" text="교육급여 · 교육비지원&#13;&#10;수혜현황 확인" left="371" top="184" width="160" height="120" cssclass="btn_OneClick_linkText" initvalueid="ivBtnAccessibilityLink" icon="url('theme://images/ico_Main_OneClick06.png')" onclick="ButtonLink_onclick" _linkNo="600"/>
                    <Button id="btnRedirect06" taborder="10" text="교육비지원 소득인정액&#13;&#10;모의계산 바로가기" left="662" top="184" width="180" height="120" cssclass="btn_OneClick_linkText" initvalueid="ivBtnAccessibilityLink" icon="url('theme://images/ico_Main_OneClick07.png')" onclick="ButtonLink_onclick" _linkNo="700"/>
                    <Button id="btnRedirect07" taborder="11" text="시도교육청별&#13;&#10;교육복지 사업신청" left="980" top="184" width="140" height="120" cssclass="btn_OneClick_linkText" initvalueid="ivBtnAccessibilityLink" icon="url('theme://images/ico_Main_OneClick08.png')" onclick="ButtonLink_onclick" _linkNo="800"/>
*/

	var params = {
				cddcCd        : sCddcCd
			 };
	switch(obj._linkNo)
	{
	
				 
		case "100" :    // 시도교육청별&#13;&#10;지원기준
			sUrl = 'pa_ews_ocl_in::ews_oclin01_m00.xfdl';
			break;
	
		case "200" :    // 소득인정액&#13;&#10;산정기준
			sUrl = 'pa_ews_ocl_in::ews_oclin02_m00.xfdl';
			break;
			
		case "300" :    // 교육비 지원&#13;&#10;온라인 신청 바로가기
			system.execBrowser("www.bokjiro.go.kr");
			break;
			
		case "400" :    // 교육급여&#13;&#10;온라인 신청 바로가기
			system.execBrowser("www.bokjiro.go.kr");
			break;
	
		case "500" :    // 교육비 지원 신청&#13;&#10;대상여부조회
			params.linkNo =  obj._linkNo;
			sUrl = 'pa_ews_ocl_mn::ews_oclmn01_m00.xfdl', params;
			break;
			
		case "600" :    // 교육급여 · 교육비지원&#13;&#10;수혜현황 확인
			params.linkNo =  obj._linkNo;
			sUrl = 'pa_ews_ocl_mn::ews_oclmn01_m00.xfdl', params;
			break;
			
		case "700" :    // 교육급여 바우처 신청하기
			system.execBrowser("e-voucher.kosaf.go.kr");
			break;
			
		case "800" :    // 시도교육청별&#13;&#10;교육복지 사업신청
			params.linkNo =  obj._linkNo;
			sUrl = 'pa_ews_ocl_mn::ews_oclmn01_m00.xfdl', params;
			break;
			
		case "900" :    // 자주묻는질문
			sUrl = 'pa_ews_ocl_sm::ews_oclsm01_m00.xfdl';
			break;
			
		case "1000" :    // 질의응답
			sUrl = 'pa_ews_ocl_sm::ews_oclsm02_m00.xfdl';
			break;
			
			
	}
	
	// 개발용 메세지(추후 삭제필요)
// 	if(this.smfIsNull(sUrl))
// 	{
// 		alert("[개발자용메세지] 해당하는 버튼의 URL이 지정되어 있지 않습니다.");
// 		return;
// 	}
				 
	this.smfSetWorkPage(sUrl, params);  //자주묻는질문 세번째 탭으로 이동
	
}

/**
 * @description 메인이미지, content 위치 조절
 */
this.fnArrangeMiddlePos = function()
{
	var nLeft,nWidth;
	// divAll center 정렬
	if( !this.smfIsMobile() ) //PC 화면 위치 조절
	{
		var bWildMode = false;
		
		var nAllWidth = this.width;  // 전체 form의 사이즈
		var nMaxWidth = 1200;
		//var nMaxWidth = 1920;
		
		if((nAllWidth >= nMaxWidth)&&(!bWildMode))	//1200 사용
		{
			nLeft = parseInt((nAllWidth - nMaxWidth) / 2);
			if(nLeft < 0) nLeft = 0;
			
			nWidth = nMaxWidth;
		}
		else
		{
			nLeft = 0;
			nWidth = nAllWidth;
		}
		
		// Top 배경이미지
		//this.div01.form.div03.setOffsetRight(nLeft+nWidth+150);


		// content영역
		this.div01.form.divLink.set_left(nLeft);
		this.div01.form.divBottomNotice.set_left(nLeft);
		this.div04.form.sta00.set_left(nLeft);
		this.div04.form.div02.set_left(nLeft);
		this.div04.form.divCddcList.set_left(nLeft);
		
		this.div01.form.resetScroll();
		this.div04.form.resetScroll();
		this.div01.form.resetScroll();
	}
}

/**
 * @description 상담센터 설정
 */
this.fnSetCddcTelInfo = function(obj){
	var sCssClassSel   = "btn_WF_RegionNumS";
	var sCssClassUnSel = "btn_WF_RegionNum" ;
	
	if(this.smfIsMobile())
	{
		sCssClassSel   = "btn_WF_RegionNumS_M";
		sCssClassUnSel = "btn_WF_RegionNum_M" ;
	}
	
	var sObjId = this.smfIsNull(obj) ? 'btn00' : obj.id;
	var objDiv = this.div04.form.divCddcTelInfoBg.form.divCddcTelInfo;
	var arrBtn = [ this.div04.form.divCddcList.form.divButtonList.form.btn00
	             , this.div04.form.divCddcList.form.divButtonList.form.btn01
	             , this.div04.form.divCddcList.form.divButtonList.form.btn02
	             , this.div04.form.divCddcList.form.divButtonList.form.btn03
	             , this.div04.form.divCddcList.form.divButtonList.form.btn04
	             , this.div04.form.divCddcList.form.divButtonList.form.btn05
				 ];
	for(var i=0; i<arrBtn.length; i++)			 
	{
		if(arrBtn[i].id == sObjId)
		{
			arrBtn[i].set_cssclass(sCssClassSel);
		}
		else 
		{
			arrBtn[i].set_cssclass(sCssClassUnSel);
		}
	}

	var sBtnIdx = sObjId.substr(sObjId.length-2,2);

	objDiv.set_url("frame::ews/frameDiv"+sBtnIdx + ".xfdl");
};

this.fnDispLongTextGrid = function(comp,row,currow,longTextCol)
{
	//return longTextCol;
	var sFont = this.smfIsMobile()?'normal 400 28px/normal "Noto Sans KR","NotoSansKR-Regular"':'normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular"';  // 대국민 포털용
	//var sFont = this.smfIsMobile()?'normal 400 28px "Noto Sans KR","NotoSansKR-Regular"':'normal 400 16px "Noto Sans KR","NotoSansKR-Regular"';    // 서브포털용
	//var objFont = new nexacro._PaddingObject(sFont);
	//var sFont = null;  // cell의 font값을 이용 (데이터가 많으면, 속도가 느려질 수 있음)
	var objFont = null;
	var nPadding = this.smfIsMobile()?40:20;  // default : 10
	//var nPadding=null;
	
	return this.smfDispLongTextGrid(comp,row,currow,longTextCol, sFont, nPadding);
}

// 메인화면 팝업 기능★
this.fnSetPopup = function(objDs)
{
	var todayDate = this.smfToday();	// 현재 날짜
	for(var j = 0; j < this.dsListPopup.getRowCount(); j++){
		if(!(todayDate >= this.dsListPopup.getColumn(j, "bgngYmd") && todayDate < this.dsListPopup.getColumn(j, "endYmd")) && todayDate < this.dsListPopup.getColumn(j, "endYmd")){	// 팝업게시기간 전
			this.dsListPopup.setColumn(j, "popupIng", "N");
		}else if(!(todayDate >= this.dsListPopup.getColumn(j, "bgngYmd")  && todayDate < this.dsListPopup.getColumn(j, "endYmd")) && todayDate > this.dsListPopup.getColumn(j, "endYmd")){	// 팝업게시기간 후
			this.dsListPopup.setColumn(j, "popupIng", "N");	// 팝업기간(당일)
		}else if(todayDate == this.dsListPopup.getColumn(j, "bgngYmd") || todayDate == this.dsListPopup.getColumn(j, "endYmd")){
			this.dsListPopup.setColumn(j, "popupIng", "Y");
			this.dsListPopup.setColumn(j, "eventTitlNm", "교육비원클릭 시스템에서 알려드립니다!");
		}else{ // 팝업게시기간
			this.dsListPopup.setColumn(j, "popupIng", "Y");
			this.dsListPopup.setColumn(j, "eventTitlNm", "교육비원클릭 시스템에서 알려드립니다!");
		}
	}
	
	// 팝업게시날짜에 적합한 데이터만 this.dsListPopupCopy로 복사
	this.dsListPopup.filter("popupIng == 'Y'");	// 해당 게시날짜에 들어온 것만 'Y'
	this.dsListPopupCopy.copyData(this.dsListPopup, true);
	// 사용여부 Y인 것만 filtering해줌 ('계속' useYn Y / '오늘하루만' useYn N)
	this.dsListPopupCopy.set_filterstr("useYn == '계속'");
	
	for(var i = 0; i < this.dsListPopupCopy.getRowCount(); i++) {
		this.dsListPopupCopy.setColumn(i, "popupTptCd", "02");	//popupTptCd 팝업템플릿코드 01 / 02 / 03
		this.dsListPopupCopy.setColumn(i, "lnkTypCd", "0");	//lnkTypCd 링크유형코드 0:없음 / 1:직접입력 / 2:게시물
		
	}
	
	// 팝업 게시
	if(this.dsListPopupCopy.getCount() > 0){
		this.popInfo.dsListPopup = this.dsListPopupCopy;
		this.smfDivPop(this.popInfo);
	}
}

// 팝업창과 관련있는 함수임... (없으면 안 닫힘...)
this.fncommNoticeAll = function( pObj )
{
	if ( pObj instanceof nexacro.NormalDataset ){
		//trace("pObj", pObj.saveXML());
		if(pObj.rowcount > 0){
			var vLnkTypCd = pObj.getColumn(0,"lnkTypCd");
			var vLnkUrl = pObj.getColumn(0,"lnkUrl");
			
			this.fnLinkPrcs(vLnkTypCd, vLnkUrl);
		}
	}
};

// 팝업창과 관련있는 함수임2...
