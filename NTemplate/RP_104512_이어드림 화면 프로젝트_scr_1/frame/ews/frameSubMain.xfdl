    <Script type="xscript5.1"><![CDATA[/** 
*  나이스 - 대국민
*  @MenuPath    샘플
*  @FileName 	frameSubMain.xfdl
*  @Creator 	정인혁
*  @CreateDate 	2023.1.13
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2023.1.13     	정인혁 	        최초 생성 
*******************************************************************************
*/ 
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::pam_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frameSubMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

	this.smfInitForm(this);
	//pbancNtcScCd 
	//pbancNtcDtlCd
	this.fv_param = this.smfGetFormParams();

	// 메인 페이지를 보여주기 위한 정보를 표시한다.
	var objMainForminfo = {
						  quickmenu : {
										  use : "N"                      //
									  }
						, wildmode : "N"
						, noticeband : {
										  use   : "N"                 //
									   }
					  }	
	this.pamfSetMainPageInfo(objMainForminfo);
	
	this.fnSetCddcTelInfo(null);
	
	this.fnSearch();
	
	if(this.smfIsMobile()) this.div01.form.divLink.form.btnRedirect07.set_visible(false);
	
	//@KBR 위치 조절
	this.fnArrangeMiddlePos();	
	
	this.resetScroll();
	
	//팝업 설정
  	this.popInfo = {};
  	this.popInfo.id = "commNoticeAll";
  	this.popInfo.pUrl = "frame::bdm/commNoticeAll.xfdl"; //bdm에서 관리하는 팝업공지를 따라감
  	this.popInfo.callbackScope = this;
  	this.popInfo.callbackFunc = "fncommNoticeAll";
	this.fnPopupSelect(); // 팝업리스트 조회서비스
}; 

this.frameMain_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnArrangeMiddlePos();
	this.smfResetScroll(this.div01.form);
	this.smfResetScroll(this.div04.form);	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

};

/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender)
{
	
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function()
{
	// 서비스 객체 생성
	this.smfSearchService("selectNtcMte")
	.run()	// 실행
	// 콜백
	.callback(function(callbackParams){		
		if(callbackParams.errors) return;
		
		this.div04.form.divCddcTelInfoBg.form.divCddcTelInfo.form.fnSetDataset(this.dsDscsnCer.saveXML());
	});	
}

// 팝업 조회 서비스
this.fnPopupSelect = function()
{
	// 서비스 객체 생성
	this.smfSearchService("listPopup")
	.run()	// 실행
	// 콜백
	.callback(function(callbackParams){		
		if(callbackParams.errors) return;
		
		this.fnSetPopup();	// 팝업 세팅 tst
	});	
}

/************************************************************************************************
 * 사용자 FUNCTION 영역
