};

/**
 * @description 공지사항 목록 클릭
 */
this.div01_divBottomNotice_grd00_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	// 클릭한 셀을 구한다
	var nRow = e.row;
	var nCell = e.cell;
	
	var titlNo = 0;
	if(this.smfIsMobile()){
		titlNo = 0;
	}
	if(nCell == titlNo){ // 제목
		var objDs = obj.getBindDataset();
		var sNtcMteId = objDs.getColumn(nRow,"ntcMteId");
		var params = {pafrBbsId:sNtcMteId};
		this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm00_s00_01.xfdl", params);
	}
};

