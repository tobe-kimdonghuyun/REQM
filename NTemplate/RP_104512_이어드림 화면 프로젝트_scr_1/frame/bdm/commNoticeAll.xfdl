<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="commNoticeAll" width="1200" height="1024" titletext="대국민포탈 공지팝업" cssclass="frm_Pop_bg40" onload="commNoticeAll_onload" onsize="commNoticeAll_onsize">
    <Layouts>
      <Layout height="1024" screenid="ScreenDeskTop" width="1200">
        <Static id="staPopupTitleAss" taborder="0" left="355" top="25" width="60" height="35" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divPop" taborder="1" left="301" top="29" width="598" height="769" initvalueid="ivDivAccessibilityOn" maxheight="" accessibilitylabel="대국민포탈 공지 팝업">
          <Layouts>
            <Layout>
              <Div id="divHScroll" taborder="0" left="30" top="41" width="538" height="580" cssclass="div_Pop_shadowBox_C" initvalueid="ivDivAccessibilityOn" url="frame::bdm/NoticeAll.xfdl" text="" formscrollbartype="none none" formscrolltype="none" ontouchend="divPop_divHScroll_ontouchend" ontouchstart="divPop_divHScroll_ontouchstart" accessibilitylabel="이벤트팝업"/>
              <Div id="divStep" taborder="1" left="42" top="divHScroll:25" width="121" height="50" url="frame::bdm/commStep.xfdl" initvalueid="ivDivAccessibilityOff" onkillfocus="divPop_divStep_onkillfocus"/>
              <CheckBox id="chkOpen" taborder="2" text="오늘 다시보지 않기" width="154" height="30" cssclass="chk_white" right="71" initvalueid="ivChkNormal" top="0"/>
              <Button id="btnClose" taborder="3" width="30" height="30" cssclass="btn_Pop_close_W" initvalueid="ivBtnAccessibilityButton" right="30" top="0" onclick="divPop_btnClose_onclick" accessibilitylabel="공지사항 팝업닫기"/>
            </Layout>
            <Layout name="mobile">
              <Div id="divHScroll" width="550" left="25" top="93" height="660"/>
              <CheckBox id="chkOpen" cssclass="chk_WF_M_W" top="29" width="278" height="48" right="63"/>
              <Button id="btnClose" cssclass="btn_Pop_close_W_M" width="48" top="30" height="48" right="20"/>
              <Div id="divStep" left="240" top="divHScroll:9" width="121" height="50" formscrolltype="none" formscrollbartype="none none"/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
      <Layout name="mobile" screenid="mobile,tablet" width="640" height="1024" mobileorientation="portrait" type="default">
        <Div id="divPop" left="20" top="0" width="600" bottom="0" minheight="820" maxheight=""/>
        <Static id="staPopupTitleAss" left="95" top="25" width="60" height="35"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    commP
*  @FileName 	commpopNoticeAll.xfdl
*  @Creator 	TOBESOFT
*  @CreateDate 	2022.8.09
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.8.09     	TOBESOFT 	        최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvWidth = 50;
this.fvAddWidth = 36;

this.popCnt = 0;	//전체 팝업 수
this.popNum = 0;	//현재 선택된 팝업

//터치 이벤트를 위한 정보
this.popClientX = 0;     //처음 눌렸을때의 x좌표
this.popMvSize = 80;    //x좌표가 어느만큼 움직여야 이미지 전환을 할지 지정

this.commNoticeAll_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.dsListPopup.copyData(this.parent.pPopInfo.dsListPopup);
	
	//this.set_background("transparent");	
	//step1일 경우
	//10 + 30 + 10 = 50
	//step2일 경우	
	//10 + 30 + 6 + 30 + 10 = 86
	//step3일 경우
	//10 + 30 + 6 + 30 + 6 + 30 + 10 = 122  
	//step4일 경우
	//10 + 30 + 6 + 30 + 6 + 30 + 6 + 30 + 10 = 158  
	//step5일 경우
	//10 + 30 + 6 + 30 + 6 + 30 + 6 + 30 + 6 + 30 + 10 = 194  	
	
	//최초 50 
	//한 스텝 추가일 경우 36 추가

	this.popCnt = this.dsListPopup.getRowCount();
	//조회된 팝업 개수가 최대 개수를 넘을 경우 최대 개수로 세팅
	if(this.popCnt > this.maxNoticeStep){
		this.popCnt = this.maxNoticeStep;
	}
			
	var fvWidth = this.fvWidth + ( this.popCnt - 1 ) * this.fvAddWidth;
			
	this.divPop.form.divStep.setOffsetWidth(fvWidth);		//버튼수에 맞춰서 DIV길이 조절
	this.divPop.form.divStep.form.resetScroll();
			
	this.divPop.form.divStep.form.fnCreateBtn(this.popCnt, this);	//버튼 생성

	//좌우정렬
	//var nAllWidth = nexacro.getEnvironmentVariable("ev_isMobile") == "Y" ? "640" : this.width;  // 전체 form의 사이즈
	var nAllWidth = this.width;
	var nMaxWidth = this.divPop.getOffsetWidth();
	var nLeft,nLeft2,nWidth;
	
	nLeft  = parseInt((nAllWidth - nMaxWidth) / 2);	
 	nLeft2 = parseInt((nMaxWidth -  this.divPop.form.divStep.getOffsetWidth()) / 2);
 	
 	this.divPop.setOffsetLeft(nLeft);
 	this.divPop.form.divStep.setOffsetLeft(nLeft2);


	//상하정렬
	var nAllHeight = this.getOwnerFrame().height;  // 전체 form의 사이즈

	if (this.smfIsMobile()) {
		var srcInfo = this.smfCurScreenInfo();
		if (srcInfo[0] < srcInfo[1]) {
			var nMaxHeight = this.divPop.minheight;
			
			nTop = parseInt((nAllHeight - nMaxHeight) / 2);		
			this.divPop.setOffsetTop(nTop);
		}
	}else {
		//var nMaxHeight = this.divPop.getOffsetHeight();

		//nTop = parseInt((nAllHeight - nMaxHeight) / 2);		
		this.divPop.setOffsetTop(100);
	}


	//팝업 화면 생성
	this.setPopImg();
	
	//this.divPop.form.setFocus();
};

//팝업 닫기
this.divPop_btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//오늘 다시 보지 않기
	this.smfSetNoticePopupToday(this.divPop.form.chkOpen.value);
	
	var paramObj = this.dsParam;
	this.smfClose(paramObj);
};

// 센터 정렬
this.commNoticeAll_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
 	var fvWidth = this.fvWidth + ( this.maxNoticeStep - 1 ) * this.fvAddWidth;	
 	this.divPop.form.divStep.setOffsetWidth(fvWidth);
	this.divPop.form.divStep.form.resetScroll();
	var nMaxWidth = this.divPop.getOffsetWidth();
	var nWidth    = this.getOffsetWidth();
	var nLeft = ( nWidth - nMaxWidth ) / 2;
	this.divPop.setOffsetLeft(nLeft);

	//모바일일 경우
	if (this.smfIsMobile() ) {
		var nTop = 0;
		var srcInfo = this.smfCurScreenInfo();

		if (srcInfo[0] > srcInfo[1]) {
		}else {
			var nMaxHeight = this.divPop.minheight;
			nTop = parseInt((srcInfo[1] - nMaxHeight) / 2);
		}

		this.divPop.setOffsetTop(nTop);
	}
	this.divPop.form.chkOpen.setFocus();
};

this.setPopImg  = function(){
	var popForm =  this.divPop.form.divHScroll.form;
	var comLen = popForm.components.length;
	var pWidth = nexacro.getEnvironmentVariable("ev_isMobile") == "Y" ? "560":"538";
	var pHeigth= nexacro.getEnvironmentVariable("ev_isMobile") == "Y" ? "660":"580";

	//팝업 개수에 맞게 step 생성
	popForm.setStepCount(this.popCnt);

	//팝업 생성
	for(var i=0; i<this.popCnt; i++){
		var objNm = "divNotice"+i;
		//var objLeft = (i*pWidth)+20;
	
		if(this.dsListPopup.getColumn(i,"popupTypCd") == "IMG"){	//이미지형
			if(i!=0){	// 첫 팝업은 이미 프레임이 생성되어 있음
				var objDiv = new Div();
				//objDiv.init(objNm,objLeft,0,pWidth,pHeigth);
				objDiv.init(objNm,0,0,pWidth,pHeigth);
				popForm.addChild(objNm, objDiv);
				objDiv.set_positionstep(i);
				objDiv.show();
			}

			var objBtn = new Button();
			objBtn.init("img00",0,0,pWidth,pHeigth);
			popForm.components[i].form.addChild("img00", objBtn);
			
			var sUrl = this.smfGetImageUrl(this.dsListPopup.getColumn(i,"fileRefrnId"),0);
			objBtn.set_background("url("+sUrl+") no-repeat center center /cover");
			objBtn.set_initvalueid("ivBtnAccessibilityButton");
			objBtn.set_accessibilitylabel(this.dsListPopup.getColumn(i,"popupTitlNm"));
			//@KBR 버튼 기본속성 border 2px.
			objBtn.set_border("0px none");

			objBtn.setEventHandler("onclick", function(obj,e){
				this.fnClickEvt(obj,e);
			}, this);

			objBtn.show();

		}else{	//템플릿형
			var ymdStr = String(this.dsListPopup.getColumn(i,"eventBgngYmd")).dateFormat("yyyy.MM.dd. ") 
			             + String(this.dsListPopup.getColumn(i,"eventBgngTm")).substr(0,2)
						 + ":"
						 + String(this.dsListPopup.getColumn(i,"eventBgngTm")).substr(2,2)
						 + " ~ " 
						 + String(this.dsListPopup.getColumn(i,"eventEndYmd")).dateFormat("yyyy.MM.dd. ")
						 + String(this.dsListPopup.getColumn(i,"eventEndTm")).substr(0,2)
						 + ":"
						 + String(this.dsListPopup.getColumn(i,"eventEndTm")).substr(2,2);
			var params = {eventTitlNm:this.dsListPopup.getColumn(i,"eventTitlNm")
						 ,popupCn:this.dsListPopup.getColumn(i,"popupCn")
						 ,lnkNm:this.dsListPopup.getColumn(i,"lnkNm")
						 ,rplcText:this.dsListPopup.getColumn(i,"rplcText")
						 ,jobCn:this.dsListPopup.getColumn(i,"jobCn")
						 ,haltWrkCn:this.dsListPopup.getColumn(i,"haltWrkCn")
						 ,lnkTypCd:this.dsListPopup.getColumn(i,"lnkTypCd")
						 ,eventYmd:ymdStr
						 ,popNo:i
			};
			
			if(i!=0){
				var objDiv = new Div();
				//objDiv.init(objNm,objLeft,0,pWidth,pHeigth);
				objDiv.init(objNm,0,0,pWidth,null,null,0);
				popForm.addChild(objNm, objDiv);
				objDiv.set_positionstep(i);
				objDiv.show();
			}
			
			popForm.components[i].params=params;

			if(this.dsListPopup.getColumn(i,"popupTptCd") == "01"){  //1번 템플릿
				popForm.components[i].set_url("frame::bdm/notice4.xfdl");

			}else if(this.dsListPopup.getColumn(i,"popupTptCd") == "02"){ //2번 템플릿
				popForm.components[i].set_url("frame::bdm/notice5.xfdl");

			}else{	//3번 템플릿
				popForm.components[i].set_url("frame::bdm/notice3.xfdl");

			}
		}
	}
};

this.fnClickEvt = function(obj,e){
	var popNo = String(obj.parent.parent.name).substr(obj.parent.parent.name.length-1);
	if(this.dsListPopup.getColumn(popNo,"lnkTypCd") == 1){	//url링크
		if(this.dsListPopup.getColumn(popNo,"newinYn") == "Y"){		//새창
			var win = window.open(this.dsListPopup.getColumn(popNo,"popupUrl"),"_blank");
		}else{
				
			this.dsParam.addRow();
			this.dsParam.setColumn(0,"lnkTypCd",this.dsListPopup.getColumn(popNo,"lnkTypCd"));
			this.dsParam.setColumn(0,"lnkUrl",this.dsListPopup.getColumn(popNo,"popupUrl"));
					
			this.smfClose(this.dsParam);
		}
					
	}else if(this.dsListPopup.getColumn(popNo,"lnkTypCd") == 2){	//게시판 링크
		if(this.dsListPopup.getColumn(popNo,"newinYn") == "Y"){		//새창
			var pageUrl = null;
			var type = "link";
			var param = {};

			var vBbsScCd = this.dsListPopup.getColumn(popNo,"pafrBbsScCd");
			switch(vBbsScCd)
			{
				case "NTC": // 공지사항 
					param.menuId = "3011";
					param.pafrBbsId = this.dsListPopup.getColumn(popNo,"pafrBbsId");	//게시물ID
					break;
				case "FAQ": // 자주묻는질문
					param.menuId = "4001";
					param.pafrBbsId = this.dsListPopup.getColumn(popNo,"pafrBbsId");	//게시물ID
				case "PUB": // 공모전
					param.menuId = "3022";
					param.pafrBbsId = this.dsListPopup.getColumn(popNo,"pafrBbsId");	//게시물ID
					break;
				case "EVT": // 이벤트
					param.menuId = "3021";
					param.pafrBbsId = this.dsListPopup.getColumn(popNo,"pafrBbsId");	//게시물ID
					break;
			}
			if(this.smfContainsStr(window.location.host, "local")){		//로컬인 경우
				param.server = "local";
			}else if (this.smfContainsStr(window.location.host, "dev")){	//개발인 경우
				param.server = "dev";
			}
			param.subSys = "PAS";
			this.smfSetServiceLink(pageUrl,type,param); 
		}else{		
			this.dsParam.addRow();
			this.dsParam.setColumn(0,"lnkTypCd",this.dsListPopup.getColumn(popNo,"lnkTypCd"));
			this.dsParam.setColumn(0,"lnkUrl",this.dsListPopup.getColumn(popNo,"pafrBbsId"));
					
			this.smfClose(this.dsParam);
		}
					
	}
};

this.fnStepClik = function(popNo){
	var objNotice = this.divPop.form.divHScroll.form;
	
	objNotice.setStepIndex(popNo);
};

this.divPop_divHScroll_ontouchend = function(obj:nexacro.Div,e:nexacro.TouchEventInfo)
{
	//alert("터치끝");
	var vForm = this.divPop.form.divStep.form;
	
	//현재 선택된 화면 번호
	var nStepNo = vForm.stepNo;
	//alert("화면번호:" + nStepNo);
	
	var nStepCnt = (this.popCnt-1);
	var nStepIdx;
	
	
	//var newClientX = parseInt(e.touchinputinfos[0].clientx,10);
	var newClientX = parseInt(e.touchinputinfos[0].screenx,10);
	var moveX = 0;

	//alert("newClientX:" + newClientX);

	//step  이동
	if(newClientX > this.popClientX){		// 왼쪽에서 오른쪽으로 이동 (앞페이지)
		moveX = parseInt(newClientX,10) - parseInt(this.popClientX,10);
		if(moveX > this.popMvSize){ 	//페이지 이동할 만큼 움직인 경우
			nStepIdx = nStepNo-1;
			if(nStepIdx<0) nStepIdx = 0;
		}else {
			nStepIdx = nStepNo;
		}
	}else{		// 오른쪽에서 왼쪽으로 이동 (다음페이지)
		moveX = this.popClientX - newClientX;
		if(moveX > this.popMvSize){ 	//페이지 이동할 만큼 움직인 경우
			nStepIdx = nStepNo+1;
			if (nStepNo==nStepCnt)	nStepIdx = nStepNo;
			
		}else {
			nStepIdx = nStepNo;
		}		
	}

	//alert("nStepIdx:" + nStepIdx);

	this.divPop.form.divStep.form.btnStepMv(nStepIdx);
	//this.divNotice.set_positionstep(nStepIdx);
};

this.divPop_divHScroll_ontouchstart = function(obj:nexacro.Div,e:nexacro.TouchEventInfo)
{
	//alert("터치시작");
	this.popClientX = parseInt(e.touchinputinfos[0].screenx,10);	//현재 위치 저장
};


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

};

this.divPop_divStep_onkillfocus = function(obj:nexacro.Div,e:nexacro.KillFocusEventInfo)
{
	//this.getOwnerFrame().form.divTop.setFocus();
};



]]></Script>
    <Objects>
      <Dataset id="dsListPopup" useclientlayout="true">
        <ColumnInfo>
          <Column id="popupId" type="string" size="256"/>
          <Column id="popupTitlNm" type="STRING" size="256"/>
          <Column id="popupCn" type="string" size="256"/>
          <Column id="comPopupYn" type="STRING" size="256"/>
          <Column id="popupTypCd" type="string" size="256"/>
          <Column id="popupTptCd" type="string" size="256"/>
          <Column id="pstStsCd" type="string" size="256"/>
          <Column id="aplcnBgngYmd" type="string" size="256"/>
          <Column id="aplcnEndYmd" type="string" size="256"/>
          <Column id="aplcnBgngTm" type="STRING" size="256"/>
          <Column id="aplcnEndTm" type="STRING" size="256"/>
          <Column id="expsrSn" type="STRING" size="256"/>
          <Column id="lnkTypCd" type="STRING" size="256"/>
          <Column id="pafrBbsScCd" type="STRING" size="256"/>
          <Column id="pafrBbsId" type="STRING" size="256"/>
          <Column id="popupUrl" type="STRING" size="256"/>
          <Column id="lnkNm" type="STRING" size="256"/>
          <Column id="newinYn" type="STRING" size="256"/>
          <Column id="fileRefrnId" type="STRING" size="256"/>
          <Column id="rplcText" type="STRING" size="256"/>
          <Column id="eventTitlNm" type="STRING" size="256"/>
          <Column id="eventBgngYmd" type="STRING" size="256"/>
          <Column id="eventEndYmd" type="STRING" size="256"/>
          <Column id="eventBgngTm" type="STRING" size="256"/>
          <Column id="eventEndTm" type="STRING" size="256"/>
          <Column id="emrgYn" type="STRING" size="256"/>
          <Column id="jobCn" type="STRING" size="256"/>
          <Column id="haltWrkCn" type="STRING" size="256"/>
          <Column id="useYn" type="STRING" size="256"/>
          <Column id="rgtrNm" type="STRING" size="256"/>
          <Column id="rgtrDptNm" type="STRING" size="256"/>
          <Column id="mdfrNm" type="STRING" size="256"/>
          <Column id="mdfrDptNm" type="STRING" size="256"/>
          <Column id="rgtrId" type="STRING" size="256"/>
          <Column id="regDt" type="STRING" size="256"/>
          <Column id="mdfrId" type="STRING" size="256"/>
          <Column id="mdfcnDt" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsParam">
        <ColumnInfo>
          <Column id="lnkTypCd" type="STRING" size="256"/>
          <Column id="lnkUrl" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
  </Form>
</FDL>
