<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="notice1" width="538" height="580" titletext="긴급공지안내" background="transparent" onload="notice1_onload">
    <Layouts>
      <Layout height="580" screenid="ScreenDeskTop" width="538">
        <ImageViewer id="img00" taborder="0" left="115" top="60" width="296" height="250" cssclass="display" image="url('imagerc::common/img_popup_3.png')" initvalueid="ivImgAccessibilityOn" accessibilitylabel="대국민서버점검 안내 이미지" stretch="fit"/>
        <Static id="title" taborder="1" text="긴급공지 안내" left="60" top="366" height="60" cssclass="font48B" textAlign="center" right="60" initvalueid="ivStcAccessibilityOn"/>
        <Static id="subTitle1" taborder="2" text="서버점검 안내 공지드립니다." left="60" top="439" height="30" cssclass="font18R" initvalueid="ivStcAccessibilityOn" textAlign="center" right="60"/>
        <Static id="subTitle2" taborder="3" text="2022-00-00 ~ 2022-00-00" left="60" top="465" height="30" cssclass="font18R" initvalueid="ivStcAccessibilityOn" textAlign="center" right="60"/>
      </Layout>
      <Layout name="Layout0" screenid="tablet,mobile" width="560" height="660" mobileorientation="portrait" type="default">
        <ImageViewer id="img00" width="320" left="120" top="76" height="269" image="url('imagerc::common_M/img_popup_3_M.png')"/>
        <Static id="title" left="60" top="415" height="100" cssclass="font60B" right="60"/>
        <Static id="subTitle1" left="60" top="515" height="40" right="60" cssclass="font24R"/>
        <Static id="subTitle2" left="60" top="551" height="40" right="60" cssclass="font24R"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
this.notice1_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.title.set_text(this.parent.params.eventTitlNm);		//팝업타이틀
	this.subTitle1.set_text(this.parent.params.popupCn);			//팝업 내용
//	this.btnLink.set_text(this.parent.params.lnkNm);			//팝업 버튼 명
	this.img00.set_accessibilitylabel(this.parent.params.rplcText);	//팝업 이미지 대체 텍스트
	this.subTitle2.set_text(this.parent.params.eventYmd);		//팝업 기간
	trace("긴급공지안내 팝업");
};
]]></Script>
  </Form>
</FDL>
