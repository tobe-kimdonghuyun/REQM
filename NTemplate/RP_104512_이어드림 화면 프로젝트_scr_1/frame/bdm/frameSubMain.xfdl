    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    샘플
*  @FileName 	frameSubMain.xfdl
*  @Creator 	정인혁
*  @CreateDate 	2022.10.31 
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.10.31     	정인혁 	        최초 생성 
*******************************************************************************
*/
include "lib::pam_script.xjs";
include "lib::bdm_script.xjs";
/************************************************************************************************
 * FORM 변수 선언 영역
************************************************************************************************/
var stateCd = [0,0,0,0,0,0];
var cddcUrl;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frameSubMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitForm(this);
	this.fv_param = this.smfGetFormParams();

	// 메인 페이지를 보여주기 위한 정보를 표시한다.
	var objMainForminfo = {
						  quickmenu : {
										  use : "N"                      
										, url : "frame::/bdm/frameQuickMenu.xfdl"   
									  }
						//@KBR  divNotice 사용여부
						, noticeband : {
										  use   : "N"                 
										, serviceurl : "/xxxxx.do"     
									 }
						//@KBR 전체화면
						, wildmode : "N"		
					  }	
	this.pamfSetMainPageInfo(objMainForminfo);

	//@KBR 위치 조절
	this.fnArrangeMiddlePos();
	
	//팝업 설정
 	this.popInfo = {};
 	this.popInfo.id = "commNoticeAll";
 	this.popInfo.pUrl = "frame::bdm/commNoticeAll.xfdl";
 	this.popInfo.callbackScope = this;
 	this.popInfo.callbackFunc = "fncommNoticeAll";
	
	this.dsCorpLogin.clearData();
	
	this.dsSearch.setColumn(0,"cddcCd", this.smfGetSessionValue("cddcCd"));
	this.dsSearch.setColumn(0,"orgCd", this.smfGetSessionValue("orgCd"));
	
	this.smfSearchService("selectNtcMteIndpQestn")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
				
		//팝업, 시도에따라 달라지는 함수
		if(this.smfGetCddcCode() != ""){
			if(this.dsListPopup.rowcount > 0){
				this.popInfo.dsListPopup =this.dsListPopup;
				this.smfDivPop(this.popInfo);
			}
			
			//시도명 바꾸는 로직 
			this.fnCddcNmChg()
			
			//다른 시도 선택 한 경우 체크 
			this.fnCddcLoginChk(this.smfGetSessionValue("orgCd"), this.smfGetCddcCode())
		}
		
		//로그인유지
		if(this.dsCorpLogin.rowcount > 0){
			this.smfSetSessionDataset(this.dsCorpLogin);
			this.getOwnerFrame().form.divTop.form.fnLoginAfter();
		}
		
		var corpCd = this.smfGetSessionValue("corpCd");

		if(this.smfIsNull(corpCd)) {
			this.div01.form.div03.form.div00.set_visible(false)
		}else{
			this.div01.form.div03.form.div00.set_visible(true)
			
			// 세션에서 법인코드 받아서 검색 파라미터 세팅
			this.dsSearch.setColumn(0,"corpCd", corpCd);
			this.dsSearch.setColumn(0,"cddcCd", this.smfGetSessionValue("cddcCd"));
			this.dsSearch.setColumn(0,"orgCd", this.smfGetSessionValue("orgCd"));
			
			this.smfSearchService("selectCorpMainInfo")
			.run()
			.callback(function(callbackParams){
				if(callbackParams.errors) return;
				
				var isSpm = false; // 보완여부
				var isRjct = false; // 반려여부
				var alertMsg = []; // 보완반려 알람메시지
				for(var i = 0; i < this.dsCorpMainCvlcpt.getRowCount(); i++){
					var cvlcptClfNo = this.dsCorpMainCvlcpt.getColumn(i, "cvlcptClfNo");
					var spmYn = this.dsCorpMainCvlcpt.getColumn(i, "spmYn");
					var rjctYn = this.dsCorpMainCvlcpt.getColumn(i, "rjctYn");
					if(cvlcptClfNo == "037AA01101"){
						stateCd[0] = this.dsCorpMainCvlcpt.getColumn(i, "state");
					}else if(cvlcptClfNo == "037AA01201"){
						stateCd[1] = this.dsCorpMainCvlcpt.getColumn(i, "state");
					}else if(cvlcptClfNo == "037AA01501"){
						stateCd[2] = this.dsCorpMainCvlcpt.getColumn(i, "state");
					}else if(cvlcptClfNo == "037AA01401"){
						stateCd[3] = this.dsCorpMainCvlcpt.getColumn(i, "state");
					}else if(cvlcptClfNo == "037AA01301"){
						stateCd[4] = this.dsCorpMainCvlcpt.getColumn(i, "state");
					}else if(cvlcptClfNo == "999ZZ99999"){
						stateCd[5] = this.dsCorpMainCvlcpt.getColumn(i, "state");
					}
					
					// (보완제출없는)보완요청이 한건이라도 있는지
					if (!isSpm && spmYn == 'Y') {isSpm = true;alertMsg.push("보완");}
					
					// 반려이 한건이라도 있는지
					if (!isRjct && rjctYn == 'Y') {isRjct = true;alertMsg.push("반려");}
				}
				
				this.div01.form.div03.form.div00.form.divTotal.form.btn00_00.click();
				
				// (보완제출없는)보완요청이 한건이라도 있으면 보완 글씨보여주기
				this.div01.form.div03.form.div00.form.staAlert.set_text(isSpm || isRjct ? alertMsg.join(", ") + " 건이 있습니다." : "");
							
			})
		}
			
	})
}; 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

}
/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){

};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fncommNoticeAll = function( pObj )
{
	if ( pObj instanceof nexacro.NormalDataset ){
		if(pObj.rowcount > 0){
			var vLnkTypCd = pObj.getColumn(0,"lnkTypCd");
			var vLnkUrl = pObj.getColumn(0,"lnkUrl");
			
			this.fnLinkPrcs(vLnkTypCd, vLnkUrl);
		}
	}
};
this.fnLinkPrcs = function(lnkTypCd, lnkUrl){
	if(lnkTypCd == 1){ //url 링크
		this.smfSetServiceLink(lnkUrl,"redirect");		//해당 url로 이동
		
	}else{		//게시물 링크
		var vBbsScCd = lnkUrl.substring(0,3);	//게시물 ID 앞 3자리가 게시판 코드
		var params = {pafrBbsId:lnkUrl};	
		
		switch(vBbsScCd)
		{
			case "NTC": // 공지사항 
				this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn00_m02.xfdl", "open", params);
				break;
			case "FAQ": // 자주묻는질문 TO-DO 목록으로 되어 있어서 어떻게 처리할지 고민 필요!!!
				this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn01_m01.xfdl");
				break;
			case "PUB": // 공모전
				this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn03_m03.xfdl", "open", params);
				break;
			case "EVT": // 이벤트
				this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn03_m02.xfdl", "open", params);
				break;
		}
	}
}

/**
 * @description 메인이미지, content 위치 조절
 */
this.fnArrangeMiddlePos = function()
{
	var nLeft,nWidth;
	// divAll center 정렬
	if(this.fv_isMobile)	//모바일일 경우
	{
		//this.divTop.setOffsetWidth(640);
		nWidth = 640;
		var nLeft = (this.width / 2) - (this.divAll.getOffsetWidth()/2);
		if(nLeft < 0) nLeft = 0;
	}
	else
	{	
		var bWildMode = false;
		
		var nAllWidth = this.width;  // 전체 form의 사이즈
		var nMaxWidth = 1200;
		
		if((nAllWidth >= nMaxWidth)&&(!bWildMode))	//1200 사용
		{
			nLeft = parseInt((nAllWidth - nMaxWidth) / 2);
			if(nLeft < 0) nLeft = 0;
			
			nWidth = nMaxWidth;
		}
		else
		{
			nLeft = 0;
			nWidth = nAllWidth;
		}
		
		// Top 배경이미지
		this.div01.form.div03.form.div04.set_left(nLeft);
		this.div01.form.div03.setOffsetRight(nLeft+nWidth);

		// content영역
		this.div01.form.div04.set_left(nLeft);
		
		this.div01.form.div03.form.resetScroll();
		this.div01.form.resetScroll();
	}
}

/**
 * @description 교육청바로가기 버튼 이름변경
 */
this.fnCddcNmChg = function()
{
	/*
	서울 : sen, 경기 : goe, 인천 : ice, 강원 : gwe, 충북 : cbe, 충남 : cne, 세종 : sje, 대전 : dje, 경북 : gbe
	경남 : gne, 대구 : dge, 울산 : use, 부산 : pen, 전북 : jbe, 광주 : gen, 전남 : jne, 제주 : jje
	*/
	var cddcNmArr = ["서울특별시교육청", "경기도교육청", "인천광역시교육청", "강원특별자치도교육청", "충청북도교육청", "충청남도교육청", "세종특별자치시교육청", "대전광역시교육청", "경상북도교육청", "경상남도교육청", "대구광역시교육청", "울산광역시교육청", "부산광역시교육청", "전라북도교육청", "광주광역시교육청", "전라남도교육청", "제주특별자치도교육청"]
	var cddcUrlCdAdrr = ["sen", "goe", "ice", "gwe", "cbe", "cne", "sje", "dje", "gbe", "gne", "dge", "use", "pen", "jbe", "gen", "jne", "jje"] 
	var cddcCdArr = ["B100000001", "J100000001", "E100000001", "K100000001", "M100000001", "N100000001", "I100000001", "G100000001", "R100000001", "S100000001", "D100000001", "H100000001", "C100000001", "P100000001", "F100000001", "Q100000001", "T100000001"]

	for(var i = 0 ; i < cddcCdArr.length ; i++){
		if(cddcCdArr[i] == this.smfGetCddcCode()){
			cddcUrl = "www."+cddcUrlCdAdrr[i]+".go.kr";
			this.div01.form.btnLink01.set_text(cddcNmArr[i] + " 바로가기");
		}
	}
}

/**
 * @description 다른시도 체크
 */
this.fnCddcLoginChk = function (orgCd, cddcCd)
{
	if(!this.smfIsNull(orgCd)) {
		var orgCdSc = orgCd.substr(0, 3)
		var cddcCdSc = cddcCd.substr(0, 3)
		
		if(orgCdSc != cddcCdSc){
			//PA041 : 해당 법인의 시도랑 다른 시도를 선택하여 자동 로그아웃 처리됩니다.
			this.bdmAlert("PA041", [], function ()
			{
				this.smfClearSessionDataset();
				this.smfSetSessionValue("cddcCd", cddcCd);
				
				this.getOwnerFrame().form.divTop.form.fnLogout();
			});
		}
	}
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 민원신청현황+버튼클릭
 */
this.div01_div03_div00_btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var params = {};
	this.smfSetWorkPage("pa_bdm_cas_as::bdm_casas00_m00.xfdl", params);
};

/**
 * @description 민원신청현황 가기
 */
