/**
 * @description 민원신청현황 선택 
 */
this.div01_div03_div00_btn00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.div01.form.div03.form.div00.form.divTotal.form.btn00_00.set_cssclass("btn_WF_Complain")
	this.div01.form.div03.form.div00.form.divTotal.form.btn00_01.set_cssclass("btn_WF_Complain")
	this.div01.form.div03.form.div00.form.divTotal.form.btn00_02.set_cssclass("btn_WF_Complain")
	this.div01.form.div03.form.div00.form.divTotal.form.btn00_03.set_cssclass("btn_WF_Complain")
	this.div01.form.div03.form.div00.form.divTotal.form.btn00_04.set_cssclass("btn_WF_Complain")
	this.div01.form.div03.form.div00.form.divTotal.form.btn00_05.set_cssclass("btn_WF_Complain")
	this.div01.form.div03.form.div00.form.sta02_00.set_cssclass("sta_WF_Txt15")
	this.div01.form.div03.form.div00.form.sta02_01.set_cssclass("sta_WF_Txt15")
	this.div01.form.div03.form.div00.form.sta02_02.set_cssclass("sta_WF_Txt15")
	this.div01.form.div03.form.div00.form.sta02_03.set_cssclass("sta_WF_Txt15")
	
	obj.set_cssclass("btn_WF_ComplainS")
	
	var btnId = obj.id.substr(7,7);
	
	if(stateCd[btnId] == 0){
		this.div01.form.div03.form.div00.form.sta01.set_cssclass("sta_WF_PrgrsBar00"); 
		this.div01.form.div03.form.div00.form.sta02_00.set_cssclass("sta_WF_Txt15B")
	}else if(stateCd[btnId] == 1){
		this.div01.form.div03.form.div00.form.sta01.set_cssclass("sta_WF_PrgrsBar01"); 
		this.div01.form.div03.form.div00.form.sta02_01.set_cssclass("sta_WF_Txt15B")
	}else if(stateCd[btnId] == 2){
		this.div01.form.div03.form.div00.form.sta01.set_cssclass("sta_WF_PrgrsBar02"); 
		this.div01.form.div03.form.div00.form.sta02_01.set_cssclass("sta_WF_Txt15B")
	}else if(stateCd[btnId] == 3){
		this.div01.form.div03.form.div00.form.sta01.set_cssclass("sta_WF_PrgrsBar03"); 
		this.div01.form.div03.form.div00.form.sta02_02.set_cssclass("sta_WF_Txt15B")
	}else if(stateCd[btnId] == 4){
		this.div01.form.div03.form.div00.form.sta01.set_cssclass("sta_WF_PrgrsBar04"); 
		this.div01.form.div03.form.div00.form.sta02_03.set_cssclass("sta_WF_Txt15B")
	}
	
};

/**
 * @description 공지사항 자주하는질문 + 버튼 선택 시 
 */
this.div01_div04_btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var btn01 = this.div01.form.div04.form.btn01.cssclass;
	var btn02 = this.div01.form.div04.form.btn02.cssclass;
	var params = {};
	
	if(btn01 == "btn_WF_Active02"){
		this.smfSetWorkPage("pa_bdm_bbs_nt::bdm_bbsnt00_m00.xfdl", params);
	}else{
		this.smfSetWorkPage("pa_bdm_bbs_fq::bdm_bbsfq00_m00.xfdl", params);
	}
};

/**
 * @description 공지사항 자주하는질문 버튼 선택 시 
 */
this.div01_div04_btn01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.div01.form.div04.form.btn01.set_cssclass("btn_WF_DeAct");
	this.div01.form.div04.form.btn02.set_cssclass("btn_WF_DeAct");
	
	obj.set_cssclass("btn_WF_Active02");
	
	var btnId = obj.id.substr(4,4);
	if(btnId == 1){
		this.div01.form.div04.form.grd00.set_visible(true)
		this.div01.form.div04.form.grd00_00.set_visible(false)
	}else{
		this.div01.form.div04.form.grd00.set_visible(false)
		this.div01.form.div04.form.grd00_00.set_visible(true)
	}
	
};

/**
 * @description 공지사항 선택 시
 */
this.div01_div04_grd00_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	// 클릭한 셀을 구한다
	var nRow = e.row;
	var nCell = e.cell;
	
	var titlNo = 1;
	if(this.smfIsMobile()){
		titlNo = 1;
	}
	if(nCell == titlNo){ // 제목
		var objDs = obj.getBindDataset();
		var sNtcMteId = objDs.getColumn(nRow,"ntcMteId");
		var params = {ntcMteId:sNtcMteId};
		this.smfSetWorkPage("pa_bdm_bbs_nt::bdm_bbsnt01_m00.xfdl", params);
	}
};

/**
 * @description 자주묻는질문 선택 시
 */
this.div01_div04_grd00_00_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	// 클릭한 셀을 구한다
	var nRow = e.row;
	var nCell = e.cell;
	
	var titlNo = 1;
	if(this.smfIsMobile()){
		titlNo = 1;
	}
	
	if(nCell == titlNo){ // 제목
		var objDs = obj.getBindDataset();
		var faqId = objDs.getColumn(nRow,"faqId");
		var params = {faqId:faqId};
		this.smfSetWorkPage("pa_bdm_bbs_fq::bdm_bbsfq00_m00.xfdl", params);
	}
	
};

this.frameMain_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnArrangeMiddlePos();	
};

this.partNo = 0;	//화면에 보이는 첫이미지
this.ePartNo = 6;	//이미지 갯수
this.divLeft = 0; 
this.divTop = 3;
this.divWidth = 120;
this.btnPrev_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.partNo == 0){	//이미지가 더이상 없으면 return
		return;
	}

	this.partNo--;
	
	this.div01.form.div03.form.div00.form.divTotal.form.components["btn00_0"+this.partNo].set_visible(true); //현재 첫 이미지 보여줌
		
	//이미지 한칸씩 뒤로 이동
	this.div01.form.div03.form.div00.form.divTotal.form.components["btn00_0"+this.partNo].move(this.divLeft,this.divTop);
	this.div01.form.div03.form.div00.form.divTotal.form.components["btn00_0"+(this.partNo+1)].move(this.divLeft+this.divWidth,this.divTop);
	this.div01.form.div03.form.div00.form.divTotal.form.components["btn00_0"+(this.partNo+2)].move(this.divLeft+(this.divWidth*2),this.divTop);
	this.div01.form.div03.form.div00.form.divTotal.form.components["btn00_0"+(this.partNo+3)].move(this.divLeft+(this.divWidth*3),this.divTop);
	
	this.div01.form.div03.form.div00.form.divTotal.form.components["btn00_0"+(this.partNo+4)].set_visible(false); //마지막 이미지 표시
};

this.btnNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.partNo + 4 == this.ePartNo){	//이미지가 더이상 없으면 return
		return;
	}
	
	this.partNo++;

	this.div01.form.div03.form.div00.form.divTotal.form.components["btn00_0"+(this.partNo-1)].set_visible(false); //현재 첫 이미지 숨김
		
	//이미지 한칸씩 앞으로 이동
	this.div01.form.div03.form.div00.form.divTotal.form.components["btn00_0"+this.partNo].move(this.divLeft,this.divTop);
	this.div01.form.div03.form.div00.form.divTotal.form.components["btn00_0"+(this.partNo+1)].move(this.divLeft+this.divWidth,this.divTop);
	this.div01.form.div03.form.div00.form.divTotal.form.components["btn00_0"+(this.partNo+2)].move(this.divLeft+(this.divWidth*2),this.divTop);
	this.div01.form.div03.form.div00.form.divTotal.form.components["btn00_0"+(this.partNo+3)].move(this.divLeft+(this.divWidth*3),this.divTop);
	
	this.div01.form.div03.form.div00.form.divTotal.form.components["btn00_0"+(this.partNo+3)].set_visible(true); //마지막 이미지 표시
};

/**
 * @description 국세청 바로가기
 */
this.div01_btnLink02_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	system.execBrowser("www.nts.go.kr");
};

/**
 * @description 인터넷등기소 바로가기
 */
this.div01_btnLink03_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	system.execBrowser("www.iros.go.kr");
};

/**
 * @description 교육청 바로가기
 */
this.div01_btnLink01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	system.execBrowser(cddcUrl);
};
