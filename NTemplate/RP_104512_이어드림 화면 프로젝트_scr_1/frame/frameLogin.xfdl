    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    TEMPLATE
*  @FileName 	frameLogin.xfdl
*  @Creator 	홍길동
*  @CreateDate 	2022.7.5
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.7.5     	홍길동 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

this.fv_nextFormUrl = "";  // 
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frameLogin_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 테스트를 위해 데이터 클리어
	this.dsLogin.clearData();
	var nAddRow = this.dsLogin.addRow();
	
	// 테스트를 위해 값을 세팅
	this.dsLogin.setColumn(nAddRow,"cddcCd",this.smfGetCddcCode());
	
	
	// 넘어온 파라미터를 보관한다.(없으면 서브포털화면)
	this.pv_params = this.smfGetFormParams();
	
	// 로그인 후 움직일 화면을 저장한다.
	this.fv_nextFormUrl = this.pv_params.resendUrl; 
	
}; 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnFindFirstWorkPageUrl = function(sSubSystemGb)
{
	var sUrl = "";
	
	var objTopFrameForm = this.getOwnerFrame().form.divTop.form;
	var objDs = objTopFrameForm.dsMenu;
	
	for(var i=0;i<objDs.rowcount;i++)
	{
		var sMenuUrl = objDs.getColumn(i,"menuUrl");
		var sIsShow = objDs.getColumn(i,"isShow");
		
		if((!this.smfIsNull(sMenuUrl)) && sIsShow!="N")
		{
			sUrl =  sMenuUrl;
			break;
		}
	}
	
	return sUrl;
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 
this.divAll_divWork_btnLogin_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
};


// [일반로그인] - [로그인]버튼 처리
this.tab00_Tabpage4_div00_btnLogin_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 로그인 없이 세션데이터만 세팅
	var sCddcCd   = this.dsLogin.getColumn(0,"cddcCd"  ); // 시도교육청코드
	var sKornFlnm = this.dsLogin.getColumn(0,"kornFlnm"); // 성명
	var sSxdsScCd = this.dsLogin.getColumn(0,"sxdsScCd"); // 성별
	var sMblTelno = this.dsLogin.getColumn(0,"mblTelno"); // 휴대폰번호
	var sTrprRrno = this.dsLogin.getColumn(0,"trprRrno"); // 주민등록번호
	//2022.07.15 법인 추가
	var sCorpCd = this.dsLogin.getColumn(0,"corpCd"); // 법인코드

	var sUserId       = this.dsLogin.getColumn(0,"userId"       ); // 사용자ID
	var sEMl_Addr     = this.dsLogin.getColumn(0,"eMl_Addr"     ); // 이메일주소
	var sBRdt         = this.dsLogin.getColumn(0,"bRdt"         ); // 생년월일
	var sFunrKornFlnm = this.dsLogin.getColumn(0,"funrKornFlnm" ); // 설립자한글성명
	var sFunrRrno     = this.dsLogin.getColumn(0,"funrRrno"     ); // 설립자주민등록번호
	var sBrno         = this.dsLogin.getColumn(0,"brno"         ); // 사업자등록번호
	var sUvstOrgCd    = this.dsLogin.getColumn(0,"uvstOrgCd"    ); // 대학조직코드

	
	var objSessionDs = nexacro.getApplication().gdsSession;
	
	objSessionDs.setColumn(0,"cddcCd"  ,sCddcCd  ); // 시도교육청코드
	objSessionDs.setColumn(0,"kornFlnm",sKornFlnm); // 성명
	objSessionDs.setColumn(0,"sxdsScCd",sSxdsScCd); // 성별
	objSessionDs.setColumn(0,"mblTelno",sMblTelno); // 휴대폰번호
	objSessionDs.setColumn(0,"trprRrno",sTrprRrno); // 주민등록번호
	
	//2022.07.15 법인코드 추가
	objSessionDs.setColumn(0,"corpCd",sCorpCd); // 법인코드	

	objSessionDs.setColumn(0,"userId"      ,sUserId      ); // 사용자ID
	objSessionDs.setColumn(0,"eMl_Addr"    ,sEMl_Addr    ); // 이메일주소
	objSessionDs.setColumn(0,"bRdt"        ,sBRdt        ); // 생년월일
	objSessionDs.setColumn(0,"funrKornFlnm",sFunrKornFlnm); // 설립자한글성명
	objSessionDs.setColumn(0,"funrRrno"    ,sFunrRrno    ); // 설립자주민등록번호
	objSessionDs.setColumn(0,"brno"        ,sBrno        ); // 사업자등록번호
	objSessionDs.setColumn(0,"uvstOrgCd"   ,sUvstOrgCd   ); // 대학조직코드


	// 혹시 시도교육청이 바뀌면 다른 화면에서도 변경을 한다.
	//   --  divTop , divHead
	
	
	// 창을 닫는다.
	//this.close(true);
	
	// 로그인 됐다고 판정
	this.smfSetLoginState(true);
	
	// Top영역을 변경
	var objTopFrameForm = this.getOwnerFrame().form.divTop.form;
	if(objTopFrameForm)	
	{
		objTopFrameForm.fnLoginAfter();
	}
	
	// 다음화면으로 이동
	var params = {};
	
	var sSubSystemGb = this.smfGetSubSystemGb();
	if(  (sSubSystemGb=="AFS")   // 업무지원(외부강사)
		  || (sSubSystemGb=="ECC")   // 업무지원(돌봄인력서비스)
		  || (sSubSystemGb=="IBM")   // 업무지원(교과용도서)
		  || (sSubSystemGb=="SEM")   // 업무지원(학교환경관리)
		  || (sSubSystemGb=="PHE")   // 업무지원(체육)
		  || (sSubSystemGb=="SML")   // 업무지원(급식)
		  || (sSubSystemGb=="SPR")   // 업무지원(교육복지)
		  )	
	{
		
		if(objTopFrameForm)		objTopFrameForm.fnRearrageTopComp(sSubSystemGb,"expand");
		// 메뉴의 첫번째화면으로 이동
		
		var sUrl = this.fnFindFirstWorkPageUrl(sSubSystemGb);
		var bShowHead = true;
		this.smfSetWorkPage(sUrl,params,bShowHead);
	}
	else 
	{	
		this.smfSetWorkPage(this.fv_nextFormUrl, params);
	}
	
	
};



this.tab00_Tabpage4_div00_btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objApp = nexacro.getApplication();
	
	trace(objApp.gdsSession.saveXML());
};
]]></Script>
    <Objects>
      <Dataset id="dsLogin">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256" description="시도교육청코드"/>
          <Column id="kornFlnm" type="STRING" size="256" description="성명"/>
          <Column id="sxdsScCd" type="STRING" size="256" description="성별"/>
          <Column id="mblTelno" type="STRING" size="256" description="휴대폰번호"/>
          <Column id="trprRrno" type="STRING" size="256" description="주민등록번호"/>
          <Column id="corpCd" type="STRING" size="256" description="법인코드"/>
          <Column id="userId" type="STRING" size="256" description="사용자ID"/>
          <Column id="eMl_Addr" type="STRING" size="256" description="이메일주소"/>
          <Column id="bRdt" type="STRING" size="256" description="생년월일"/>
          <Column id="funrKornFlnm" type="STRING" size="256" description="설립자한글성명"/>
          <Column id="funrRrno" type="STRING" size="256" description="설립자주민등록번호"/>
          <Column id="brno" type="STRING" size="256" description="사업자등록번호"/>
          <Column id="uvstOrgCd" type="STRING" size="256" description="대학조직코드"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsCddcList">
        <ColumnInfo>
          <Column id="cddcOrgCd" type="STRING" size="256"/>
          <Column id="cddcOrgNm" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="cddcOrgNm">-선택-</Col>
          </Row>
          <Row>
            <Col id="cddcOrgNm">서울특별시교육청</Col>
            <Col id="cddcOrgCd">B100000001</Col>
          </Row>
          <Row>
            <Col id="cddcOrgNm">부산광역시교육청</Col>
            <Col id="cddcOrgCd">C100000001</Col>
