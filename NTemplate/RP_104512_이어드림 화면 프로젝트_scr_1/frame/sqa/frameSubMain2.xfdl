    <Script type="xscript5.1"><![CDATA[/**
*  검정고시 대입전형자료제출
*  @MenuPath    frame > frameSubMain2
*  @FileName 	frameSubMain2.xfdl 
*  @Creator 	kmp
*  @CreateDate 	2021.12.27
*  @Desction    base가 되는 화면
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
*  2021.12.27     		kmp		 	  			최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::pam_script.xjs"; 


/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_workPageParams = {};	//화면전환시 넘길 parameter
this.fv_isMobile;	//모바일로 접속여부
this.fv_device;		//device 종류
var objMainForminfo;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 
/**
 * 화면 onload시 처리내역
*/
this.form1_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{	
	this.smfInitForm(this);

	this.fv_param = this.smfGetFormParams();

	// 메인 페이지를 보여주기 위한 정보를 표시한다.
	objMainForminfo = {
						  quickmenu : {
										  use : "N"                      //
										, url : "frame::/sqa/frameQuickMenu2.xfdl"   //
									  }
						, divBottomNotice : {
										  objdiv : this.divBottomNotice    //  
										, objds : this.dsListBottomNotice    //  
										, listredirecturl : "pa_sqa_uep_sc::sqa_uepsc02_m01.xfdl"    //  
									   }
						//@KBR 전체화면 Y
						, wildmode : "N"										   
					  }	
	
	this.pamfSetMainPageInfo(objMainForminfo);
	
	//@KBR 위치 조절
	this.fnArrangeMiddlePos();	
	
	//팝업 설정
 	this.popInfo = {};
 	this.popInfo.id = "commNoticeAll";
 	this.popInfo.pUrl = "frame::bdm/commNoticeAll.xfdl";
 	this.popInfo.callbackScope = this;
 	this.popInfo.callbackFunc = "fncommNoticeAll";
	
	// Form의 검색영역 초기화처리를 한다.
	this.fnFormInit();
};

this.fnFormInit = function()
{
	// Form의 검색영역 초기화처리를 한다.(바인딩된 것)
	this.dsSearch.setColumn(0,"cddcCd", this.smfGetCddcCode());
	this.divTelInfo.form.staAdviceTitle.set_text("<fc v='#7e4cfc'>"+ this.smfGetCddcName()+"</fc> 문의전화")
	this.smfResetScroll(this.divTelInfo.form) //div사이즈 최적화
	
	//전화번호 셋팅
	var cddcScCd = this.smfGetCddcCode().substr(0,3)


	if ( cddcScCd == "S10") { //경상남도
		this.divTelInfo.form.staQuestTime.set_text("(평일) 09:00~18:00\n(단, 점심시간 12:00~13:00 제외)");
	} else if (cddcScCd == "B10") { //서울
		this.divTelInfo.form.staQuestTime.set_text("(평일) 09:00~18:00\n<fc v='red'>※토·일·공휴일 미운영</fc>");
	} else if (cddcScCd == "F10"){ //광주
		this.divTelInfo.form.staQuestTime.set_text("(월,화,목) 09:00~18:00\n(수,금) 08:30~17:30");
	}else if ( cddcScCd == "G10") { //대전
		this.divTelInfo.form.staQuestTime.set_text("(월~목) 09:00~18:00\n(금) 08:30~17:30");
	}else {
		this.divTelInfo.form.staQuestTime.set_text("(평일) 09:00~18:00");
	}
	
	this.fnSearch();
}

this.fnSearch = function(){
	// 서비스 객체 생성
	this.smfSearchService("selectMainInfo") //메인 공지사항 조회

		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			//메인공지사항 날짜 셋팅
			for(var i = 0; i < this.dsListBottomNotice.rowcount; i++){
				this.dsListBottomNotice.setColumn(i, "aplcnBgngYmd", this.dsListBottomNotice.getColumn(i,"regDt"))			
			}

			//메인 화면 셋팅
			this.pamfSetMainPageInfo(objMainForminfo);
			
			
			if(!this.smfIsNull(this.dsTelno.getColumn(0,"cddcTelno"))){
				this.divTelInfo.form.staMeqTelno.set_text(this.dsTelno.getColumn(0,"cddcTelno"))
			}
			
				//메인 새로고침 시 세션 유지
			//if(this.dsSqaUepSession.rowcount > 0){
			//	this.smfSetSessionDataset(this.dsSqaUepSession);
			//}
			
			//로그인유지
			if(this.dsSqaUepSession.rowcount > 0){
				this.smfSetSessionDataset(this.dsSqaUepSession);
				this.getOwnerFrame().form.divTop.form.fnLoginAfter();
				
			}
				
			//팝업공지
			if(this.dsListPopup.rowcount > 0){
				this.popInfo.dsListPopup = this.dsListPopup;
				this.smfDivPop(this.popInfo);
			}
			
			
			
		});
}
this.form1_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnArrangeMiddlePos();		
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/ 
 this.fnTransCallback = function(svcid,errcd,errmsg)
{

}

/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){

};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnRefreshCddcInfo = function()
{
	var sCddcCd = this.smfNvl(this.smfGetCddcCode(),"");  // 교육청코드를 가져온다.(없으면,서울교육청)
	
	// 값이 없으면 처리를 중단(혹시나 해서...)
	if(this.smfIsNull(sCddcCd)) return;
	
	var sCddcName = this.smfGetCddcName();
	
	// 담당자정보를 가져온다.
	// Form의 검색영역 초기화처리를 한다.(바인딩된 것)
	this.dsSearch.setColumn(0,"cddcCd", this.smfGetCddcCode());  // sCddcCd
	
	//  페이지를 조회한다.
	//this.fnSearch();
};


/**
 * 하단의 링크에 의한 ㄷ이동처리를 한다 
 * @param : objDs - 정보를 가진 데이터셋 오브젝트
 */ 
this.fnRedirectFuncLink = function(obj)
{
	var url = "";
	
	switch(obj._linkNo)
	{
		case "100" :    // 안내사항
			url = "pa_sqa_uep_sc::sqa_uepsc01_m00.xfdl";
			break;
	
		case "200" :    /// 제출현황조회
			url = "pa_sqa_uep_sc::sqa_uepsc04_m00.xfdl";
			break;
			
		case "300" :    /// 수신대학이력조회
			url = "pa_sqa_uep_sc::sqa_uepsc05_m00.xfdl";
			break;
	}
	
	var params = {
	                
				 };
	this.smfSetWorkPage(url,params);  //자주묻는질문 세번째 탭으로 이동
	
}
this.fncommNoticeAll = function( pObj )
{
	trace("pObj", pObj);
	if ( pObj instanceof nexacro.NormalDataset ){
		trace("pObj", pObj.saveXML());
		if(pObj.rowcount > 0){
			var vLnkTypCd = pObj.getColumn(0,"lnkTypCd");
			var vLnkUrl = pObj.getColumn(0,"lnkUrl");
			
			this.fnLinkPrcs(vLnkTypCd, vLnkUrl);
		}
	}
};
this.fnLinkPrcs = function(lnkTypCd, lnkUrl){
	trace(lnkTypCd, lnkUrl);
	if(lnkTypCd == 1){ //url 링크
		this.smfSetServiceLink(lnkUrl,"redirect");		//해당 url로 이동
		
	}else{		//게시물 링크
		var vBbsScCd = lnkUrl.substring(0,3);	//게시물 ID 앞 3자리가 게시판 코드
		var params = {pafrBbsId:lnkUrl};	
		
		switch(vBbsScCd)
		{
			case "NTC": // 공지사항 
				this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn00_m02.xfdl", "open", params);
				break;
			case "FAQ": // 자주묻는질문 TO-DO 목록으로 되어 있어서 어떻게 처리할지 고민 필요!!!
				this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn01_m01.xfdl");
				break;
			case "PUB": // 공모전
				this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn03_m03.xfdl", "open", params);
				break;
			case "EVT": // 이벤트
				this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn03_m02.xfdl", "open", params);
				break;
		}
	}
}

/**
 * @description 메인이미지, content 위치 조절
 */
this.fnArrangeMiddlePos = function()
{
	var nLeft,nWidth;
	// divAll center 정렬
	if(this.fv_isMobile)	//모바일일 경우
	{
		//this.divTop.setOffsetWidth(640);
		nWidth = 640;
		var nLeft = (this.width / 2) - (this.divAll.getOffsetWidth()/2);
		if(nLeft < 0) nLeft = 0;
	}
	else
	{	
		var bWildMode = false;
		
		var nAllWidth = this.width;  // 전체 form의 사이즈
		var nMaxWidth = 1200;
		
		if((nAllWidth >= nMaxWidth)&&(!bWildMode))	//1200 사용
		{
			nLeft = parseInt((nAllWidth - nMaxWidth) / 2);
			if(nLeft < 0) nLeft = 0;
			
			nWidth = nMaxWidth;
		}
		else
		{
			nLeft = 0;
			nWidth = nAllWidth;
		}
		
		// Top 배경이미지
		this.divTopNotice.form.div04.set_left(nLeft);
		this.divTopNotice.setOffsetRight(nLeft+nWidth);

		// content영역
		this.divBottomNotice.set_left(nLeft);
		this.divLink1.set_left(nLeft);
		
		this.divTopNotice.form.resetScroll();
		this.resetScroll();
	}
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 사이즈 변경시 위치변경
*/
this.frameMain_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
