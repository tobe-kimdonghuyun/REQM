};

// 하단링크에 의한 이동처리를 한다.
this.btnLink_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnRedirectFuncLink(obj);
};


//검정고시 온라인접수로 이동
this.divRedirect_staLink_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	this.pamfRediectOtherSys("SQA","101")
};


//자료확인 및 신청 페이지로 이동
this.div03_div04_btn02_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	params={};
	this.smfSetWorkPage("pa_sqa_uep_sc::sqa_uepsc03_m00",params);  
};
]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">selectMainInfo</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsListBottomNotice=dsListBottomNotice dsListPopup=dsListPopup dsSqaUepSession=dsSqaUepSession dsTelno=dsTelno</Col>
            <Col id="url">sqa_uep_sc00_001.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true">
        <ColumnInfo>
          <Column id="pbancNtcScCd" type="STRING" size="256"/>
          <Column id="pbancNtcDtlCd" type="STRING" size="256"/>
