    <Script type="xscript5.1"><![CDATA[/**
*  검정고시 온라인원서접수
*  @MenuPath    frame > frameSubMain
*  @FileName 	frameSubMain.xfdl 
*  @Creator 	kmp
*  @CreateDate 	2021.12.27
*  @Desction    base가 되는 화면
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
*  2021.12.27     		kmp		 	  			최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::pam_script.xjs"; 


/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_workPageParams = {};	//화면전환시 넘길 parameter
this.fv_isMobile;	//모바일로 접속여부
this.fv_device;		//device 종류
var objMainForminfo;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 
/**
 * 화면 onload시 처리내역
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{	
	//10:공고 11:공지사항 12:정답조회 13:합격자조회, 14:작성요령
	this.smfInitForm(this);

	this.fv_param = this.smfGetFormParams();

	// 메인 페이지를 보여주기 위한 정보를 표시한다.
	objMainForminfo = {
						  quickmenu : {
										  use : "N"                      //
										, url : "frame::/sqa/frameQuickMenu.xfdl"   //
									  }
						, divTopNotice : {
										  objdiv : this.div03.form.divTopNotice    //  
										, objds : this.dsListTopNotice    //  
										, listredirecturl : "pa_sqa_noi_bi::sqa_noibi01_m00.xfdl"    //  
									   }
						, divBottomNotice : {
										  objdiv : this.divBottomNotice    //  
										, objds : this.dsListBottomNotice    //  
										, listredirecturl : "pa_sqa_noi_bi::sqa_noibi02_m01.xfdl"    //  
									   }
						//@KBR 전체화면 Y
						, wildmode : "N"	
					  }	
	this.pamfSetMainPageInfo(objMainForminfo);
	
	//@KBR 위치 조절
	this.fnArrangeMiddlePos();	
	
		//팝업 설정
 	this.popInfo = {};
 	this.popInfo.id = "commNoticeAll";
 	this.popInfo.pUrl = "frame::bdm/commNoticeAll.xfdl"; //bdm에서 관리하는 팝업공지를 따라감
 	this.popInfo.callbackScope = this;
 	this.popInfo.callbackFunc = "fncommNoticeAll";
	
	
	// Form의 검색영역 초기화처리를 한다.
	this.fnFormInit();
};

this.fnFormInit = function()
{

	this.dsSearch.setColumn(0,"cddcCd",  this.smfGetCddcCode());
	
	//  페이지를 조회한다.
	this.fnSearch();
}
this.form1_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnArrangeMiddlePos();		
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 this.fnSearch = function(obj, e)
{
	
	if(!this.smfIsNull(this.smfGetCddcCode())){
	
	this.dsSearch.setColumn(0,"cddcCd",  this.smfGetCddcCode());

	this.smfSearchService("selectMainList") 
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.smfGetCddcCode() != ""){
				if(this.dsListPopup.rowcount > 0){
					this.popInfo.dsListPopup =this.dsListPopup;
					this.smfDivPop(this.popInfo);
				}
			}
			
			//상담센터 데이터 셋팅
			
			this.divTelInfo.form.staAdviceTitle.set_text("<fc v='#7e4cfc'>"+this.smfGetCddcName()+"</fc> 상담센터");
			this.smfResetScroll(this.divTelInfo.form) //div사이즈 최적화
			this.divTelInfo.form.staMeqTelno.set_text(this.dsRprsTelno.getColumn(0, "rprsTelno"))
			this.divTelInfo.form.staHeqTelno.set_text(this.dsRprsTelno.getColumn(1, "rprsTelno"))
			this.divTelInfo.form.staHgqTelno.set_text(this.dsRprsTelno.getColumn(2, "rprsTelno"))
			
			//전화번호 셋팅 (대전만 변경)
			var cddcScCd = this.smfGetCddcCode().substr(0,3)

			if ( cddcScCd == "G10") { //대전
				this.divTelInfo.form.staQuestTime.set_text("월~목 09:00~18:00, 금 08:30~17:30\n점심시간 12:00~13:00");
			} 
			
			//TopNotice에 시도교육청명 표시
			this.div03.form.divTopNotice.form.staCddcNm.set_text(this.smfGetCddcName());
			
	
			//로그인유지
			if(this.dsSqaSession.rowcount > 0){
				this.smfSetSessionDataset(this.dsSqaSession);
				this.getOwnerFrame().form.divTop.form.fnLoginAfter();
				
			}
			
			//메인화면 문구 및 공지사항 셋팅
			this.fnSetData(); 
			
			
		});
	}
 	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/ 
 this.fnTransCallback = function(svcid,errcd,errmsg)
{

}


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnRefreshCddcInfo = function()
{
	var sCddcCd = this.smfNvl(this.smfGetCddcCode(),"");  // 교육청코드를 가져온다.(없으면,서울교육청)
	
	// 값이 없으면 처리를 중단(혹시나 해서...)
	if(this.smfIsNull(sCddcCd)) return;
	
	var sCddcName = this.smfGetCddcName();
	
	this.div03.form.divTopNotice.form.staCddcNm.set_text(sCddcName);
	
	// 담당자정보를 가져온다.
	// Form의 검색영역 초기화처리를 한다.(바인딩된 것)
	this.dsSearch.setColumn(0,"cddcCd",  this.smfGetCddcCode());  // sCddcCd
	
	//  페이지를 조회한다.
	this.fnSearch();	
};

this.fncommNoticeAll = function( pObj )
{
	if ( pObj instanceof nexacro.NormalDataset ){
		trace("pObj", pObj.saveXML());
		if(pObj.rowcount > 0){
			var vLnkTypCd = pObj.getColumn(0,"lnkTypCd");
			var vLnkUrl = pObj.getColumn(0,"lnkUrl");
			
			this.fnLinkPrcs(vLnkTypCd, vLnkUrl);
		}
	}
};
this.fnLinkPrcs = function(lnkTypCd, lnkUrl){
	trace(lnkTypCd, lnkUrl);
	if(lnkTypCd == 1){ //url 링크
		this.smfSetServiceLink(lnkUrl,"redirect");		//해당 url로 이동
		
	}else{		//게시물 링크
		var vBbsScCd = lnkUrl.substring(0,3);	//게시물 ID 앞 3자리가 게시판 코드
		var params = {pafrBbsId:lnkUrl};	
		
		switch(vBbsScCd)
		{
			case "NTC": // 공지사항 
				this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn00_m02.xfdl", "open", params);
				break;
			case "FAQ": // 자주묻는질문 TO-DO 목록으로 되어 있어서 어떻게 처리할지 고민 필요!!!
				this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn01_m01.xfdl");
				break;
			case "PUB": // 공모전
				this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn03_m03.xfdl", "open", params);
				break;
			case "EVT": // 이벤트
				this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn03_m02.xfdl", "open", params);
				break;
		}
	}
}
/**
 * 메인화면의 정보들을 셋팅한다
 * @param : objDs - 정보를 가진 데이터셋 오브젝트
 */ 
this.fnSetData = function(objDs)
{

	if(this.dsListTopNotice.rowcount == 0){
		this.dsListTopNotice.addRow();
	}
	
	 trace("공고일 : " + this.dsRcptInfo.getColumn(0,"pbancYmd"))
	 trace("원서 접수시작일 : " + this.dsRcptInfo.getColumn(0,"itnRcptBgngYmd"))
	 trace("원서 접수종료일 : " + this.dsRcptInfo.getColumn(0,"itnRcptEndYmd"))
	 trace("수험표출력 시작일 : " + this.dsRcptInfo.getColumn(0,"eiOtptBgngYmd"))
	  trace("수험표출력 시작일+1 : " + this.smfAddDate(this.dsRcptInfo.getColumn(0,"eiOtptBgngYmd"),1))
	 trace("수험표출력종료일 : " + this.dsRcptInfo.getColumn(0,"eiOtptEndYmd"))
	 trace("성적조회 시작일 : " + this.dsRcptInfo.getColumn(0,"screInqBgngYmd"))
	 trace("성적조회 종료일 : " + this.dsRcptInfo.getColumn(0,"screInqEndYmd"))
	 var enfcYr = this.dsRcptInfo.getColumn(0,"enfcYr")
	 var enfcTme = this.dsRcptInfo.getColumn(0,"enfcTme")
	 var txt = enfcYr +"년도 제"+enfcTme+"회 "
	 
	//공고일 ~  원서접수시작일 -1일
	if(this.smfToday() >= this.dsRcptInfo.getColumn(0,"pbancYmd") && this.smfToday() <= this.smfAddDate(this.dsRcptInfo.getColumn(0,"itnRcptBgngYmd"),-1)){
		this.dsListTopNotice.setColumn(0, "ntcMteTitlNm", txt+"초•중•고등학교 졸업학력 검정고시 공고")
		this.div03.form.divTopNotice.form.staNoticeSubTitle.set_text("온라인 접수기간")
		this.dsListTopNotice.setColumn(0, "itnRcptBgngYmd", this.dsRcptInfo.getColumn(0,"itnRcptBgngYmd"))
		this.dsListTopNotice.setColumn(0, "itnRcptEndYmd", this.dsRcptInfo.getColumn(0,"itnRcptEndYmd"))
		//공고자세히보기 버튼
	}
	//원서접수기간일때 (원서접수 시작일 ~ 원서접수 종료일)
	if(this.smfToday() >= this.dsRcptInfo.getColumn(0,"itnRcptBgngYmd") && this.smfToday() <= this.dsRcptInfo.getColumn(0,"itnRcptEndYmd")){
		this.dsListTopNotice.setColumn(0, "ntcMteTitlNm", txt+"초•중•고등학교 졸업학력 검정고시 공고")
		this.div03.form.divTopNotice.form.staNoticeSubTitle.set_text("온라인 접수기간")
		this.dsListTopNotice.setColumn(0, "itnRcptBgngYmd", this.dsRcptInfo.getColumn(0,"itnRcptBgngYmd"))
		this.dsListTopNotice.setColumn(0, "itnRcptEndYmd", this.dsRcptInfo.getColumn(0,"itnRcptEndYmd"))
		//공고자세히보기 버튼 + 온라인원서접수 이동버튼
	}
	// (원서접수 종료일 +1  ~ 수험표출력 시작일 -1)
	if(this.smfToday() >= this.smfAddDate(this.dsRcptInfo.getColumn(0,"itnRcptEndYmd"),1) && this.smfToday() <= this.smfAddDate(this.dsRcptInfo.getColumn(0,"eiOtptBgngYmd"),-1)){
		this.dsListTopNotice.setColumn(0, "ntcMteTitlNm", txt+"초•중•고등학교 졸업학력 검정고시 공고")
		this.div03.form.divTopNotice.form.staNoticeSubTitle.set_text("온라인 접수기간")
		this.dsListTopNotice.setColumn(0, "itnRcptBgngYmd", this.dsRcptInfo.getColumn(0,"itnRcptBgngYmd"))
		this.dsListTopNotice.setColumn(0, "itnRcptEndYmd", this.dsRcptInfo.getColumn(0,"itnRcptEndYmd"))
		//공고자세히보기 버튼
	}
	//수험표출력 시작일 ~ 수험표출력 종료일
	if(this.smfToday() >= this.dsRcptInfo.getColumn(0,"eiOtptBgngYmd") && this.smfToday() <= this.dsRcptInfo.getColumn(0,"eiOtptEndYmd")){
		this.dsListTopNotice.setColumn(0, "ntcMteTitlNm", txt+"초•중•고등학교 졸업학력 검정고시\n수험표출력")
		this.div03.form.divTopNotice.form.staNoticeSubTitle.set_text("수험표 출력기간")
		this.dsListTopNotice.setColumn(0, "itnRcptBgngYmd", this.dsRcptInfo.getColumn(0,"eiOtptBgngYmd"))
		this.dsListTopNotice.setColumn(0, "itnRcptEndYmd", this.dsRcptInfo.getColumn(0,"eiOtptEndYmd"))
		//수험표출력 이동 버튼
	}
	//수험표출력 종료일 +1 ~ 합격자발표일 -1
	if(this.smfToday() >= this.smfAddDate(this.dsRcptInfo.getColumn(0,"eiOtptEndYmd"),1) && this.smfToday() <=  this.smfAddDate(this.dsRcptInfo.getColumn(0,"sfcAnnYmd"),-1)){
		this.dsListTopNotice.setColumn(0, "ntcMteTitlNm", txt+"초•중•고등학교 졸업학력 검정고시\n합격자발표")
		this.div03.form.divTopNotice.form.staNoticeSubTitle.set_text("합격자발표일")
		this.dsListTopNotice.setColumn(0, "itnRcptBgngYmd",  this.dsRcptInfo.getColumn(0,"sfcAnnYmd") )
		this.dsListTopNotice.setColumn(0, "itnRcptEndYmd", "")
		//버튼없음
	}
	//합격자발표일 ~ 성적조회기간 종료일
	if(this.smfToday() >= this.dsRcptInfo.getColumn(0,"sfcAnnYmd") && this.smfToday() <= this.dsRcptInfo.getColumn(0,"screInqEndYmd")){
		this.dsListTopNotice.setColumn(0, "ntcMteTitlNm", txt+"초•중•고등학교 졸업학력 검정고시\n합격자발표")
		this.div03.form.divTopNotice.form.staNoticeSubTitle.set_text("합격자발표일")
		this.dsListTopNotice.setColumn(0, "itnRcptBgngYmd", this.dsRcptInfo.getColumn(0,"sfcAnnYmd"))
		this.dsListTopNotice.setColumn(0, "itnRcptEndYmd", "")
		//합격자조회 게시판이동버튼 + 성적조회 이동버튼
	}
	//성적조회기간 종료일 +1 ~ 다음회차 공고일 -1
	if(this.smfToday() < this.dsRcptInfo.getColumn(0,"pbancYmd") || this.smfToday() >= this.smfAddDate(this.dsRcptInfo.getColumn(0,"screInqEndYmd"),1)){
		this.div03.form.divTopNotice.set_visible(false)
		objMainForminfo.divTopNotice.objdiv = this.div03.form.divTopNotice01
		//this.div03.form.divTopNotice01.move(60,25,700,500)
		this.div03.form.divTopNotice01.set_visible(true)	
	}


	//공고,공지사항 데이터 셋팅
	this.pamfSetMainPageInfo(objMainForminfo);
	
	//TopNotice의 버튼(btnLink)컨트롤
	this.dsListTopNotice.setColumn(0,"menuId", "4000")
	
	//공고일 ~  원서접수시작일 -1일
	if(this.smfToday() >= this.dsRcptInfo.getColumn(0,"pbancYmd") && this.smfToday() <= this.smfAddDate(this.dsRcptInfo.getColumn(0,"itnRcptBgngYmd"),-1)){
		this.div03.form.divTopNotice.form.btnLink00.set_visible(true)
		this.div03.form.divTopNotice.form.btnLink00.redirecturl = "pa_sqa_noi_bi::sqa_noibi01_m00.xfdl"
		this.div03.form.divTopNotice.form.btnLink01.set_visible(false)
		//공고자세히보기 버튼
	}
	//원서접수기간일때 (원서접수 시작일 ~ 원서접수 종료일)
	if(this.smfToday() >= this.dsRcptInfo.getColumn(0,"itnRcptBgngYmd") && this.smfToday() <= this.dsRcptInfo.getColumn(0,"itnRcptEndYmd")){
		this.div03.form.divTopNotice.form.btnLink00.set_visible(true)
		this.div03.form.divTopNotice.form.btnLink00.redirecturl = "pa_sqa_noi_bi::sqa_noibi01_m00.xfdl"
		this.div03.form.divTopNotice.form.btnLink01.set_visible(true)
		//공고자세히보기 버튼 + 온라인원서접수 이동버튼
	}
	// (원서접수 종료일 +1  ~ 수험표출력 시작일 -1)
	if(this.smfToday() >= this.smfAddDate(this.dsRcptInfo.getColumn(0,"itnRcptEndYmd"),1) && this.smfToday() <= this.smfAddDate(this.dsRcptInfo.getColumn(0,"eiOtptBgngYmd"),-1)){
		this.div03.form.divTopNotice.form.btnLink00.set_visible(true)
		this.div03.form.divTopNotice.form.btnLink00.redirecturl = "pa_sqa_noi_bi::sqa_noibi01_m00.xfdl"
		this.div03.form.divTopNotice.form.btnLink01.set_visible(false)
		//공고자세히보기 버튼
	}
	//수험표출력 시작일 ~ 수험표출력 종료일
	if(this.smfToday() >= this.dsRcptInfo.getColumn(0,"eiOtptBgngYmd") && this.smfToday() <= this.dsRcptInfo.getColumn(0,"eiOtptEndYmd")){
		this.div03.form.divTopNotice.form.btnLink00.set_text("수험표 출력")
		this.dsListTopNotice.setColumn(0,"menuId", "6000")
		this.div03.form.divTopNotice.form.btnLink00.redirecturl = "pa_sqa_cmm_cm::sqa_cmmcm04_m00.xfdl"
		this.div03.form.divTopNotice.form.btnLink00.set_visible(true)
		this.div03.form.divTopNotice.form.btnLink01.set_visible(false)
		//수험표출력 이동 버튼
	}
	//수험표출력 종료일 +1 ~ 합격자발표일 -1
	if(this.smfToday() >= this.smfAddDate(this.dsRcptInfo.getColumn(0,"eiOtptEndYmd"),1) && this.smfToday() <=  this.smfAddDate(this.dsRcptInfo.getColumn(0,"sfcAnnYmd"),-1)){
		this.div03.form.divTopNotice.form.btnLink00.set_visible(false)
		this.div03.form.divTopNotice.form.btnLink01.set_visible(false)
		//버튼없음
	}
	//합격자발표일 ~ 성적조회기간 종료일
	if(this.smfToday() >= this.dsRcptInfo.getColumn(0,"sfcAnnYmd") && this.smfToday() <= this.dsRcptInfo.getColumn(0,"screInqEndYmd")){
		this.div03.form.divTopNotice.form.btnLink00.set_visible(false)
		this.div03.form.divTopNotice.form.btnLink01.set_visible(true)
		this.div03.form.divTopNotice.form.btnLink01.set_text("성적조회(합격확인)")
		this.div03.form.divTopNotice.form.btnLink01.set_textAlign("center")
		this.div03.form.divTopNotice.form.btnLink01.move(64,350)
		this.dsListTopNotice.setColumn(0,"menuId", "7000")
		this.div03.form.divTopNotice.form.btnLink01.redirecturl = "pa_sqa_cmm_cm::sqa_cmmcm04_m00.xfdl"
		//성적조회 이동버튼
	}
	//성적조회기간 종료일 +1 ~ 다음회차 공고일 -1
	if(this.smfToday() < this.dsRcptInfo.getColumn(0,"pbancYmd") || this.smfToday() >= this.smfAddDate(this.dsRcptInfo.getColumn(0,"screInqEndYmd"),1)){
		this.div03.form.divTopNotice.set_visible(false)
		objMainForminfo.divTopNotice.objdiv = this.divTopNotice
		//this.div03.form.divTopNotice01.move(60,25,700,500)
		this.div03.form.divTopNotice01.set_visible(true)	
	}
	
	this.div03.form.divTopNotice.form.divPage.form.btnPageLink0.set_visible(false)
	

}

/**
 * 하단의 링크에 의한 ㄷ이동처리를 한다 
 * @param : objDs - 정보를 가진 데이터셋 오브젝트
 */ 
this.fnRedirectFuncLink = function(obj)
{	
	var tabGubun;
	
	switch(obj._linkNo)
	{
		case "110" :    // 원서접수안내
			tabGubun = "10";
			break;
	
		case "112" :    /// 수험표출력안내
			tabGubun = "12";
			break;
			
		case "113" :    /// 합격자발표안내
			tabGubun = "13";
			break;
	}
	
	var params = {
					cddcCd        : this.smfGetCddcCode(),
					tabGubun	  : tabGubun
				 };
	this.smfSetWorkPage("pa_sqa_noi_bi::sqa_noibi06_m00.xfdl", params);  //자주묻는질문 세번째 탭으로 이동
	
}
/**
 * @description 메인이미지, content 위치 조절
 */
this.fnArrangeMiddlePos = function()
{
	var nLeft,nWidth;
	// divAll center 정렬
	if(this.fv_isMobile)	//모바일일 경우
	{
		//this.divTop.setOffsetWidth(640);
		nWidth = 640;
		var nLeft = (this.width / 2) - (this.divAll.getOffsetWidth()/2);
		if(nLeft < 0) nLeft = 0;
	}
	else
	{	
		var bWildMode = false;
		
		var nAllWidth = this.width;  // 전체 form의 사이즈
		var nMaxWidth = 1200;
		
		if((nAllWidth >= nMaxWidth)&&(!bWildMode))	//1200 사용
		{
			nLeft = parseInt((nAllWidth - nMaxWidth) / 2);
			if(nLeft < 0) nLeft = 0;
			
			nWidth = nMaxWidth;
		}
		else
		{
			nLeft = 0;
			nWidth = nAllWidth;
		}
		
		// Top 배경이미지
		this.div03.form.divTopNotice.set_left(nLeft);
		this.div03.form.divTopNotice01.set_left(nLeft);
		this.div03.setOffsetRight(nLeft+nWidth);

		// content영역
		this.divBottomNotice.set_left(nLeft);
		this.divLink.set_left(nLeft);
		
		this.div03.form.resetScroll();
		this.resetScroll();
	}
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 사이즈 변경시 위치변경
*/
this.frameMain_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{


};


// 하단링크에 의한 이동처리를 한다.
this.btnLink_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnRedirectFuncLink(obj);
};


//대입전형자료제출로 이동
this.divRedirect_sta00_00_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	this.pamfRediectOtherSys("SQA","102")
};



