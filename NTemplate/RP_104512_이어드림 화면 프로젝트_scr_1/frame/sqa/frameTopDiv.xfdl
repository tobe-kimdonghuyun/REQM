<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frameMain" width="290" height="43" onload="frameTopDiv_onload" scrollbartype="none none" scrolltype="none">
    <Layouts>
      <Layout height="43" width="290" screenid="ScreenDeskTop">
        <Button id="btn00" taborder="0" text="대입전형자료제출" left="116" top="7" width="169" height="30" initvalueid="ivBtnAccessibilityButton" cssclass="btn_TF_Send" visible="true" onclick="btn00_onclick"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 검정고시
*  @MenuPath    샘플
*  @FileName 	frameTopDiv.xfdl
*  @Creator 	TOBESOFT
*  @CreateDate 	2023.01.19
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  	2023.01.19     	TOBESOFT 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frameTopDiv_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

}; 

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd <= -1) return;
}

this.fnPopupCallback = function(context, responseParams, sender){
}
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnSetButton = function()
{
	// TEXT 세팅
	var sDetailGb = this.smfGetSubSystemDetailGb();
	
	if(sDetailGb=="101") // 원서접수
	{
		this.btn00.set_text("대입전형자료제출")
	}
	else if(sDetailGb=="102") // 대입전형자료제출
	{
		this.btn00.set_text("원서접수")	
	}
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// TEXT 세팅
	var sDetailGb = this.smfGetSubSystemDetailGb();
	var sTemp = "";
	if(sDetailGb=="101") sTemp = "102";
	else if(sDetailGb=="102") sTemp = "101";
	
	this.fnRediectOtherSys("SQA",sTemp)
};

this.fnRediectOtherSys = function(sSubSys,sdetailSubSys)
{
	var sSelVal1 = sdetailSubSys;  // 서브시스템
	var sSelVal2 = (sdetailSubSys=="101"?"원서접수":(sdetailSubSys=="102"?"대입전형자료제출":""));  // 서브시스템명
	var sSelVal3 = this.smfGetCddcCode() ;  // 교육청코드
	var sSelVal4 = this.smfGetCddcName();  // 교육청코드명

	if(this.smfGetSubSystemGb()!=sSubSys)
	{
		this.smfSetSubSystemGb(sSubSys);
	}

	var objTopForm = this.getOwnerFrame().form.divTop.form;

	objTopForm.fnSetPrivateProfile("CDDC_INFO",sSelVal1,sSelVal3,sSelVal4);
	
	// 교육청 변경 처리를 한다.
	objTopForm.fnChangeCddc(sSelVal1,sSelVal2,sSelVal3,sSelVal4);
	
	objTopForm.divDispArea.form.resetScroll();
	objTopForm.resetScroll();
}]]></Script>
