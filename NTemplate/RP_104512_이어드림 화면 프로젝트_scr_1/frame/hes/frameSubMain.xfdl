this.divAcaInstInfo_btnAca_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//학원 클릭 시 교습소 비활성화 처리
	if(this.smfIsMobile()){
		this.div00.form.divAcaInstInfo.form.btnAca.set_cssclass("btn_WF_SchTgS_M");
		this.div00.form.divAcaInstInfo.form.btnInst.set_cssclass("btn_WF_SchTg_M");
	}else{
		this.div00.form.divAcaInstInfo.form.btnAca.set_cssclass("btn_WF_SchTgS");
		this.div00.form.divAcaInstInfo.form.btnInst.set_cssclass("btn_WF_SchTg");
	}
	
	searchAcaInstiScCd = "1";
	this.div00.form.divAcaInstInfo.form.edtSearchAcaNm.set_displaynulltext("학원명을 입력하세요");
};

this.divAcaInstInfo_btnInst_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//교습소 클릭 시 학원 비활성화 처리
	if(this.smfIsMobile()){
		this.div00.form.divAcaInstInfo.form.btnAca.set_cssclass("btn_WF_SchTg_M");
		this.div00.form.divAcaInstInfo.form.btnInst.set_cssclass("btn_WF_SchTgS_M");
	}else{
		this.div00.form.divAcaInstInfo.form.btnAca.set_cssclass("btn_WF_SchTg");
		this.div00.form.divAcaInstInfo.form.btnInst.set_cssclass("btn_WF_SchTgS");
	}
	searchAcaInstiScCd = "2";
	this.div00.form.divAcaInstInfo.form.edtSearchAcaNm.set_displaynulltext("교습소명을 입력하세요");
};

this.divNtcMte_grdNtcMte_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	// 클릭한 셀을 구한다
	var nRow = e.row;
	var nCell = e.cell;
	
	if(nCell == 1){ // 제목클릭 시
		var objDs = obj.getBindDataset();
		var sNtcMteId = objDs.getColumn(nRow,"ntcMteId");
		var sUrl = "pa_hes_len_nt::hes_lennt01_m00.xfdl";

		var params = {"ntcMteId":sNtcMteId
					, "dsSearchParam":this.dsSearch.saveXML()
					, "dsPagingParam":this.dsPageInfo.saveXML()
					, _url : sUrl
			};
		this.smfSetWorkPage(sUrl, params);
	}
};

this.divFaq_grdFaq_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	// 클릭한 셀을 구한다
	var nRow = e.row;
	var nCell = e.cell;
	
	var titlNo = 1;
	if(this.smfIsMobile()){
		titlNo = 1;
	}
	
	if(nCell == titlNo){ // 제목
		var objDs = obj.getBindDataset();
		var faqId = objDs.getColumn(nRow,"faqId");
		var params = {faqId:faqId};
		this.smfSetWorkPage("pa_hes_qle_ql::hes_qleql00_m00.xfdl", params);
	}
};

this.div00_divBanner_divCvlcptAply_btnMoreCvlcpt_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sUrl = "pa_hes_mle_dc::hes_mledc00_m00.xfdl";
	var params = {
				_url : sUrl
		};
	this.smfSetWorkPage(sUrl, params);
};
