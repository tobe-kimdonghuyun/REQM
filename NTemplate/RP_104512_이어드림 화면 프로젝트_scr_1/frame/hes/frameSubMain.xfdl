this.divAcaInstInfo_btnAcaInstSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var searchAdtzoCd = this.div00.form.divAcaInstInfo.form.divDofdcCd.form.cboDofdcCd.value;
	var searchAcaNm = this.div00.form.divAcaInstInfo.form.edtSearchAcaNm.value;
	
	// 학원교습소정보조회화면으로 이동
	var sUrl = "pa_hes_ics_sl::hes_icssl00_m00.xfdl";
