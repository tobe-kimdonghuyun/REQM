	, ["C100000001", "평일(월~목) 09:00~18:00, (금) 08:00~17:00, 점심시간 12:00~13:00", "051-1396"]
	, ["D100000001", "평일(월~금) 09:00~18:00, 점심시간 12:00~13:00", "(동부교육지원청) 053-232-0184\n(서부교육지원청) 053-233-0176\n(남부교육지원청) 053-234-0142\n(달성교육지원청) 053-235-0181\n(군위교육지원청) 054-380-4243"]
	, ["E100000001", "평일(월,화,목) 09:00~18:00, (수, 금) 08:30~17:30, 점심시간 12:00~13:00", "(시교육청) 032-420-8432\n(남부교육지원청) 032-770-0132\n(북부교육지원청) 032-510-5474\n(동부교육지원청) 032-460-6074\n(서부교육지원청) 032-560-6717\n(강화교육지원청) 032-930-7812"]
	, ["F100000001", "평일(월~금) 09:00~18:00, 점심시간 12:00~13:00", "062-380-4817"]
	, ["G100000001", "평일(월~목) 09:00~18:00, (금) 08:30~17:30, 점심시간 12:00~13:00",  "(동부교육지원청) 042-229-1092~7\n(서부교육지원청) 042-530-1082~5, 1095"]
	, ["H100000001", "평일(월~금) 09:00~18:00, 점심시간 12:00~13:00", "(강북교육지원청) 052-219-5681~2\n(강남교육지원청) 052-228-6681~2"]
	, ["I100000001", "평일(월~금) 09:00~18:00, 점심시간 12:00~13:00", "044-320-3136"]
	, ["J100000001", "평일(월~금) 09:00~18:00, 점심시간 12:00~13:00", "1599-2578"]
