	, ["P100000001", "평일(월~금) 09:00~18:00, 점심시간 12:00~13:00", "063-1396"]
	, ["Q100000001", "평일(월~금) 09:00~18:00, 점심시간 12:00~13:00", "061-260-5641~3"]
	, ["R100000001", "평일(월~금) 09:00~18:00, 점심시간 12:00~13:00", "054-805-3423"]
	, ["S100000001", "평일(월~금) 09:00~18:00, 점심시간 12:00~13:00", "055-210-5197"]
	, ["T100000001", "평일(월~금) 09:00~18:00, 점심시간 12:00~13:00", "(제주시) 064-754-1381~5\n(서귀포시) 064-730-8231~4\n(도교육청) 064-710-0682"] //064-710-0740
]; 
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 
/**
 * 화면 onload시 처리내역
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{		
	this.smfInitForm(this);
	this.fv_param = this.smfGetFormParams();
	
	
	// 메인 페이지를 보여주기 위한 정보를 표시한다.
	objMainForminfo = {
						  quickmenu : {
										  use : "N"                      
										, url : "frame::/hes/frameQuickMenu.xfdl"   
									  }
						, divTopNotice : {
										  objdiv : this.div00.form.divBanner.form.divTopSvr    //  
										, objds : this.dsListTopSvr    //  
										, listredirecturl : "pa_hes_svr_sv::hes_svrsv00_m00.xfdl"    // 
										, redirectUrlColumn : "ntcMteCn"
									   }
						//@KBR  divNotice 사용여부
						, noticeband : {
										  use   : "N"                 
										, serviceurl : "/xxxxx.do"     
									 }
						//@KBR 전체화면
						, wildmode : "N"		
					  }	
	this.pamfSetMainPageInfo(objMainForminfo);


	//@KBR 위치 조절
	//this.fnArrangeMiddlePos();
	
	//팝업 설정
 	this.popInfo = {};
 	this.popInfo.id = "commNoticeAll";
 	this.popInfo.pUrl = "frame::bdm/commNoticeAll.xfdl"; //bdm에서 관리하는 팝업공지를 따라감
 	this.popInfo.callbackScope = this;
 	this.popInfo.callbackFunc = "fncommNoticeAll";
	
	
	this.fnSearch();
	
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/ 
this.fnTransCallback = function(svcid,errcd,errmsg)
{

};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 this.fnRefreshCddcInfo = function()
{
	var sCddcCd = this.smfNvl(this.smfGetCddcCode(),"");  // 교육청코드를 가져온다.(없으면,서울교육청)
	
	// 값이 없으면 처리를 중단(혹시나 해서...)
	if(this.smfIsNull(sCddcCd)) return;
	
	// 담당자정보를 가져온다.
	// Form의 검색영역 초기화처리를 한다.(바인딩된 것)
	this.dsSearch.setColumn(0,"cddcCd",  this.smfGetCddcCode());  // sCddcCd
	
	//  페이지를 조회한다.
	this.fnSearch();	
};

 /**
 * @description 메인이미지, content 위치 조절
 */
this.fnArrangeMiddlePos = function()
{	
	var bWildMode = false;
		
	var nAllWidth = this.width;  // 전체 form의 사이즈
	var nMaxWidth = 1200;
	
	if((nAllWidth >= nMaxWidth)&&(!bWildMode))	//1200 사용
	{
		nLeft = parseInt((nAllWidth - nMaxWidth) / 2);
		if(nLeft < 0) nLeft = 0;
		
		nWidth = nMaxWidth;
	}
	else
	{
		nLeft = 0;
		nWidth = nAllWidth;
	}
	
	
	// Top 배경이미지
	this.div00.form.divBanner.form.divTopSvr.set_left(nLeft);
	this.div00.form.divBanner.setOffsetRight(nLeft+nWidth);

	// content영역
	this.div00.form.divAcaInstInfo.set_left(nLeft);
	
	this.div00.form.divBanner.form.resetScroll();
	this.div00.form.resetScroll();
}

this.fnSearch = function(){
	
	//상담센터명 변경	
	var sCddcName = this.smfGetCddcName();
	var sCddcCd = this.smfGetCddcCode();
	var txt = "<fc v='#2a65f2'>"+sCddcName+"</fc> 상담센터";
	
	if(sCddcCd == "T100000001"){ //제주특별자치도교육청만 예외처리 (문의처 전화번호 여러줄)
		txt = "<fc v='#2a65f2'>학원서비스</fc>문의처";
		this.div00.form.divCddcDscsn.form.sta01_00.set_cssclass("sta_WF_Txt20B");
		this.div00.form.divCddcDscsn.form.sta01_00.set_height(110);
	}else if(sCddcCd == "G100000001" || sCddcCd == "H100000001"){
		this.div00.form.divCddcDscsn.form.sta01_00.set_cssclass("sta_WF_Txt20B");
		this.div00.form.divCddcDscsn.form.sta01_00.set_height(80);
	}else if(sCddcCd == "D100000001"){
		this.div00.form.divCddcDscsn.form.sta01_00.set_cssclass("sta_WF_Txt20B");
		this.div00.form.divCddcDscsn.form.sta01_00.set_height(120);
		this.div00.form.divCddcDscsn.form.sta01_00.set_top(85);
	}else if(sCddcCd == "N100000001" || sCddcCd == "E100000001"){
		this.div00.form.divCddcDscsn.form.sta01_00.set_visible(false);
		this.div00.form.divCddcDscsn.form.txt00.set_visible(true);
		this.div00.form.divCddcDscsn.form.txt00.set_height(100);
		this.div00.form.divCddcDscsn.form.txt00.set_top(100);
	}else{
		this.div00.form.divCddcDscsn.form.sta01_00.set_cssclass("sta_WF_Txt34B");
		this.div00.form.divCddcDscsn.form.sta01_00.set_height(40);
	}
	
	this.div00.form.divCddcDscsn.form.staCslcNm.set_text(txt);
	
	//교육청별 상담시간, 전화번호 변경
	for(var i=0; i < this.fv_dscsnCer.length; i++){
		if(this.fv_dscsnCer[i][0] == sCddcCd){
			this.div00.form.divCddcDscsn.form.sta01.set_text(this.fv_dscsnCer[i][1]);
			
			if(this.div00.form.divCddcDscsn.form.sta01_00.visible == true) {
				this.div00.form.divCddcDscsn.form.sta01_00.set_text(this.fv_dscsnCer[i][2]);
			}else if(this.div00.form.divCddcDscsn.form.txt00.visible == true){
				this.div00.form.divCddcDscsn.form.txt00.set_value(this.fv_dscsnCer[i][2]);
			}
		}
	}
	
	
	//로그인한 경우 민원목록 조회
	if(this.smfIsLogin()){
		this.div00.form.divBanner.form.divCvlcptAply.set_visible(true);
		this.fnSearchInstutInfo();
	}else{
		this.div00.form.divBanner.form.divCvlcptAply.set_visible(false);
	}
	
	// 시군구목록조회
	var cddcOrgCd = this.smfGetCddcCode().substring(0, 3);
	this.div00.form.divAcaInstInfo.form.divCddcOrgCd.form.cboCddcOrgCd.set_value(this.smfGetCddcCode());
	this.dsSearch.setColumn(0,"cddcOrgCd",cddcOrgCd);
	this.dsSearch.setColumn(0,"cddcCd",sCddcCd);
	
	this.smfSearchService("listZoneInfo")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
			//현재 교육청 정보 학원교습소 정보조회에 SET
			this.dsCddc.setColumn(0,"cddcCd",sCddcCd);
			this.dsCddc.setColumn(0,"cddcCdName",sCddcName);
			
			this.div00.form.divAcaInstInfo.form.divDofdcCd.form.cboDofdcCd.set_value(this.dsZoneCd.getColumn(0,"zoneCd"));
			
			//팝업조회
			this.fnSearchPop();
			
			//설문조사조회
			this.fnSearchSvr();
			
			//자주묻는질문조회
			this.fnSearchFaq();
			
	});
	
}

this.fncommNoticeAll = function( pObj )
{
	if ( pObj instanceof nexacro.NormalDataset ){
		trace("pObj", pObj.saveXML());
		if(pObj.rowcount > 0){
			var vLnkTypCd = pObj.getColumn(0,"lnkTypCd");
			var vLnkUrl = pObj.getColumn(0,"lnkUrl");
			
			this.fnLinkPrcs(vLnkTypCd, vLnkUrl);
		}
	}
};

//온라인민원명 dataset 생성
this.fnSetCvlcptNmDs = function(){
	var rowCount = this.dsCvlcptAplyCd.getRowCount();
	
	switch(this.hesGetAcaInstiScCd){
		case "1" : 
			// 학원
			for(var i = 0; i < this.fv_instutCd01.length; i++){
				this.dsCvlcptAplyCd.addRow();
				this.dsCvlcptAplyCd.setColumn(rowCount, 0, this.fv_instutCd01[i]);	// 민원신청명 코드
				this.dsCvlcptAplyCd.setColumn(rowCount, 1, this.fv_instutNm01[i]);	// 민원신청명 명칭
				rowCount++;
			}
		break;
		case "2" : 
			// 교습소
			for(var i = 0; i < this.fv_instutCd02.length; i++){
				this.dsCvlcptAplyCd.addRow();
				this.dsCvlcptAplyCd.setColumn(rowCount, 0, this.fv_instutCd02[i]);	// 민원신청명 코드
				this.dsCvlcptAplyCd.setColumn(rowCount, 1, this.fv_instutNm02[i]);	// 민원신청명 명칭
				rowCount++;
			}
		break;
		case "3" : 
			// 개인과외교습자
			for(var i = 0; i < this.fv_invlPrlsCd.length; i++){
				this.dsCvlcptAplyCd.addRow();
				this.dsCvlcptAplyCd.setColumn(rowCount, 0, this.fv_invlPrlsCd[i]);	// 민원신청명 코드
				this.dsCvlcptAplyCd.setColumn(rowCount, 1, this.fv_invlPrlsNm[i]);	// 민원신청명 명칭
				rowCount++;
			}
		break;
	}
}

// 학원정보 조회 함수
this.fnSearchInstutInfo = function (){
	// 학원조회조건	
	this.dsSearch.setColumn(0, "acaDsgnNo", this.hesGetAcaDsgnNo);	
	this.dsSearch.setColumn(0, "acaInstiScCd", this.hesGetAcaInstiScCd);
	this.dsSearch.setColumn(0, "atptOfcdcOrgCode",  this.hesGetAtptOfcdcOrgCode);
	this.dsSearch.setColumn(0, "invlDsgnNo", this.hesGetInvlDsgnNo);	
	
	//온라인민원명 코드 SET
	this.fnSetCvlcptNmDs();
	
	if(this.hesGetAcaInstiScCd == "3"){ //개인과외교습자일 경우 학원목록 조회 생략
		this.fnSearchChkDtlCvCmpltRpt();
	}else{
		//학원정보조회
		this.smfSearchService("listInstutInfo")
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors)return;
			
			//조회된 학원정보가 있을 경우 해당 민원 조회
			var dsRowCnt = this.dsInstutList.getRowCount();
			if(dsRowCnt > 0){
				var acaDsgnNoArr = [];
				for(var i=0; i<dsRowCnt; i++){
					acaDsgnNoArr[i] = this.dsInstutList.getColumn(i,"acaDsgnNo");
				}
				
				var acaDgsnNoList = acaDsgnNoArr.join(",");
				this.dsSearch.setColumn(0,"acaDgsnNoList",acaDgsnNoList);
				this.fnSearchChkDtlCvCmpltRpt();
			}
			
		});
	}
}

// 민원신고내역 조회 함수
this.fnSearchChkDtlCvCmpltRpt = function (){

	this.smfSearchService("listChkDtlCvCmpltRpt")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
	});
}

this.fnSearchPop = function(){
	//팝업조회
	this.smfSearchService("listPop")
	// 실행
	.run()
	// 콜백
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		if(this.smfGetCddcCode() != ""){
			if(this.dsListPopup.rowcount > 0){
				this.popInfo.dsListPopup =this.dsListPopup;
				this.smfDivPop(this.popInfo);
			}
		}
	});	
}

this.fnSearchSvr = function(){
	//설문조사조회
	this.dsSearch.setColumn(0,"cddcCd" ,  this.smfGetCddcCode()); //접속시도 가져오기
	this.dsSearch.setColumn(0,"ntcMteClfCd" , '42'); 	//42 : 설문조사
	
	//40:공지사항 41:작성방법 안내 자료 42:설문조사 게시 관리

	// 서비스 객체 생성
	this.smfSearchService("listNtcMte")
	// 실행
	.run()
	// 콜백
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		if(this.dsTmprList.getRowCount() > 0){
			//조회된 목록 설문 dataset으로 복사
			this.dsListTopSvr.copyData(this.dsTmprList);
		}		
	
		//설문조사 없는 경우 기본 문구가 보이도록
		if(this.dsListTopSvr.getRowCount() < 1){
			this.div00.form.divBanner.form.divTopTitle.set_visible(true);
			this.div00.form.divBanner.form.divTopSvr.set_visible(false);
		}else{
			this.div00.form.divBanner.form.divTopTitle.set_visible(false);
			this.div00.form.divBanner.form.divTopSvr.set_visible(true);
		}
		
		//임시 dataset 초기화
		this.dsTmprList.clearData();
		
		//공지사항조회
		this.fnSearchNtcMte();
		
		
		this.pamfSetMainPageInfo(objMainForminfo);
	});
	
}

this.fnSearchFaq = function(){
	//자주묻는질문조회
	this.smfSearchService("listFaq")
	// 실행
	.run()
	// 콜백
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
	});	
}

this.fnSearchNtcMte = function(){
	//공지사항조회
	this.dsSearch.setColumn(0,"cddcCd" ,  this.smfGetCddcCode()); //접속시도 가져오기
	this.dsSearch.setColumn(0,"ntcMteClfCd" , '40'); 	//40 : 공지사항

	// 서비스 객체 생성
	this.smfSearchService("listNtcMte")
	// 실행
	.run()
	// 콜백
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		if(this.dsTmprList.getRowCount() > 0){
			//조회된 목록 설문 dataset으로 복사
			this.dsNtcMteList.copyData(this.dsTmprList);
			
			for(var i = 0; i < this.dsNtcMteList.rowcount; i++){
				var row = this.fnGetNum(i)
				this.dsNtcMteList.setColumn(i,"rowNum",row)
			}
			
			
			//임시 dataset 초기화
			this.dsTmprList.clearData();
		}	
	});
	
}

this.setCvlcptNm = function(val){
	var idx = this.dsCvlcptAplyCd.findRow("id",val);
	return this.dsCvlcptAplyCd.getColumn(idx,"value");
}

this.fnDispLongTextGrid = function(comp,row,currow,longTextCol)
{
	var sFont = this.smfIsMobile()?'normal 400 28px/normal "Noto Sans KR","NotoSansKR-Regular"':'normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular"';  // 대국민 포털용
	var objFont = null;
	var nPadding = this.smfIsMobile()?80:40;  // default : 10
	
	return this.smfDispLongTextGrid(comp,row,currow,longTextCol, sFont, nPadding);
}
