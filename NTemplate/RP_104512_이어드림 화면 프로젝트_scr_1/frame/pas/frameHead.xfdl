    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    대국민포탈메인헤더
*  @FileName 	frameHead
*  @Creator 	투비소프트
*  @CreateDate 	2022.07.22
*  @Desction    대국민포탈
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.07.21     	TOBESOFT 	               최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/


/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
this.frameHead_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{	
	this.smfInitDiv(obj);	
	//0501 CF 일괄등록
};

// 상단의 TopFrame의 데이터셋을 가져온다.
this.fnSetHeadMenu = function()
{
	if(this.dsMenu.rowcount == 0)
	{
		this.dsMenu.copyData(this.getOwnerFrame().form.divTop.form.dsMenu);
		this.divMenuIndicator.form.cboMenuLevel1.set_index(-1);
		this.divMenuIndicator.form.cboMenuLevel2.set_index(-1);		
	}
};

/**
 * @description 레벨 0 콤보 선택 메뉴 이동 호출
 * frame::frameMainP.xfdl this.fnSetWorkpage 함수 호출함 
*/
this.fnSetMenu = function(sUrl,pParam)
{	
	this.objApp = nexacro.getApplication();
	// sUrl로 메뉴레벨별 메뉴아이디를 구한다.
	var nFindRow = this.dsMenu.findRow(this.objApp.gv_menuColumns.pageUrl,sUrl);
	//trace(" nFindRow : " + nFindRow);
	// 일치하는 URL이 없는 경우(클리어할 것인지 확인필요)
	if(nFindRow < 0)
	{
		return;
	}
	var nlvl = this.dsMenu.lookup(this.objApp.gv_menuColumns.pageUrl,sUrl,this.objApp.gv_menuColumns.menuLevel);
	//trace(" nlvl : " + nlvl );
	// 현재의 레벨을 구한다.
	var aMenuPathInfo,sMenuIdLevel0,sMenuIdLevel1;
	if ( pParam && pParam.menuLvl  == 1)
	{
		aMenuPathInfo = this.fnGetMenuPathInfo(nFindRow);	
		sMenuIdLevel0 = aMenuPathInfo[0];
		sMenuIdLevel1 = aMenuPathInfo[1];
	}else
	{
		if ( nlvl == 0 )
		{
			aMenuPathInfo = this.fnGetMenuPathInfoByTopDown(nFindRow);
			sMenuIdLevel0 = aMenuPathInfo[0];
			sMenuIdLevel1 = aMenuPathInfo[1];

		}else
		{
			aMenuPathInfo = this.fnGetMenuPathInfo(nFindRow);		
			sMenuIdLevel0 = aMenuPathInfo[0];
			sMenuIdLevel1 = aMenuPathInfo[1];		
		}
	}

	// 데이터셋을 가져간다.
	if ( this.dsMenuLevel1.rowcount == 0 )	this.dsMenuLevel1.copyData(this.dsMenu);
	if ( this.dsMenuLevel2.rowcount == 0 )	this.dsMenuLevel2.copyData(this.dsMenu);

	var sMenu, cboMenu;	//웹접근성- titletext를 변경하기 위한 값

	if ( !this.smfIsMobile() ) 
	{
		this.dsMenuLevel0.filter("menuLvl=='0'");
		var menuName = this.dsMenu.lookup("menuId",sMenuIdLevel0,"menuNm");
		this.divMenuIndicator.form.btnMenuLevel0.set_text(menuName);
		this.divMenuIndicator.form.btnMenuLevel0.set_visible(true);

		this.dsMenuLevel1.filter("menuLvl=='1'&&upMenuId=='"+sMenuIdLevel0+"'");
		if ( aMenuPathInfo.length == 1 )
		{
			this.divMenuIndicator.form.cboMenuLevel1.set_visible(false);		
			this.divMenuIndicator.form.staLine02.set_visible(false);
		}else if(aMenuPathInfo.length > 1 )
		{
			if(this.dsMenuLevel1.rowcount == 0 ){
				this.divMenuIndicator.form.cboMenuLevel1.set_visible(false);
				this.divMenuIndicator.form.staLine02.set_visible(false);			
			}else if(this.dsMenuLevel1.rowcount > 1){
				this.divMenuIndicator.form.cboMenuLevel1.set_visible(true);
				this.divMenuIndicator.form.staLine02.set_visible(true);			
			}
		}
		
		var nRow = this.dsMenuLevel1.findRow("menuId",sMenuIdLevel1);
		if ( nRow > -1 ) 
		{
			this.divMenuIndicator.form.cboMenuLevel1.set_index(nRow);
		}
		
		sMenu = this.divMenuIndicator.form.btnMenuLevel0.text;
		cboMenu = this.divMenuIndicator.form.cboMenuLevel1.text;
		if (!this.smfIsNull(this.divMenuIndicator.form.cboMenuLevel2.text)) {
			cboMenu = cboMenu +"|"+ this.divMenuIndicator.form.cboMenuLevel2.text;
		}
		
	}else
	{
		var menuName = this.dsMenu.lookup("menuId",sMenuIdLevel0,"menuNm");
		//trace( "@@ menuName1 : " + menuName );
		this.divMenuIndicator2.form.btnMenuLevel0.set_text(menuName);
		this.divMenuIndicator2.form.btnMenuLevel0.set_visible(true);
		
		var menuName = this.dsMenu.lookup("menuId",sMenuIdLevel1,"menuNm");		
		this.divMenuIndicator2.form.btnMenuLevel1.set_text(menuName);		
		this.divMenuIndicator2.form.btnMenuLevel1.set_visible(true);
		
		this.divMenuIndicator2.form.resetScroll();
		
		sMenu = this.divMenuIndicator2.form.btnMenuLevel0.text;
		cboMenu = this.divMenuIndicator2.form.btnMenuLevel1.text;
	}

	//웹접근성- MainFrame의 titletext를 변경
	if (!this.smfIsNull(cboMenu))	cboMenu = sMenu +"|"+ cboMenu;
	else cboMenu = sMenu;
	
	if (!this.smfIsNull(cboMenu)) {
		this.getOwnerFrame().form.fnChangeFrameTitle( cboMenu );
	}
};

/**
 * @description 상위 메뉴 ID 반환
 * @return 배열
*/
this.fnGetMenuPathInfo = function(nTargetRow)
{
	var aMenuPathInfo = [];
	
	var nCurLevel = parseInt(this.dsMenu.getColumn(nTargetRow,"menuLvl")); 
	var aMenuId = ["","",""];
	for(var i=nTargetRow;i>=0;i--)
	{
		var nLevel = parseInt(this.dsMenu.getColumn(i,"menuLvl")); 
		var sMenuId = this.dsMenu.getColumn(i,"menuId"); 

		if(nCurLevel>=nLevel)
		{	
			aMenuId[nCurLevel] =  sMenuId; 
			
			if(nCurLevel==0) break;
			
			nCurLevel--;
		}
	}	

	return aMenuId;
};

/**
 * @description 하위 메뉴 ID 반환
 * @return 배열
*/
this.fnGetMenuPathInfoByTopDown = function(nTargetRow)
{
	//해당 row 레벨 포함 하위 첫번째 메뉴 Id 반환
	var nMax = this.dsMenu.getMax("menuLvl");
	//trace(" Max : " + nMax );
	var sTargetMenuId = this.dsMenu.getColumn(nTargetRow,"menuId");
	var aMenuId = new Array();
	aMenuId[0] = sTargetMenuId;
	for( var i=1; i < nMax+2; i++)
	{
		if ( sTargetMenuId )
		{
			var menuId = this.dsMenu.lookup("upMenuId",sTargetMenuId,"menuId");
			var useYn = this.dsMenu.lookup("upMenuId",sTargetMenuId,"useYn");

			if ( menuId && useYn == "Y")
			{
				sTargetMenuId = menuId;
				aMenuId[i] = menuId;
			}
		}
	}

	return aMenuId;
};

/**
 * @description 메뉴 1 레벨 콤보 드랍다운
 * @return 배열
*/
this.divMenuIndicator_cboMenuLevel1_ondropdown = function(obj:nexacro.Combo,e:nexacro.EventInfo)
{
	//this.smfChangeDiv("W");	//@RHS - 2022.12.05 주석처리함
	obj.set_cssclass("cbo_LNB_F");	
};


this.divMenuIndicator_cboMenuLevel1_onkeyup = function(obj:nexacro.Combo,e:nexacro.KeyEventInfo)
{
	if (e.keycode==13) {
		var cIdx = this.divMenuIndicator.form.cboMenuLevel1.index;
		var sUrl = this[obj.innerdataset].getColumn(cIdx,"menuUrlAddr");	
	
		var params = {};
		params.menuLvl  = 1;
		if(!this.smfIsNull(sUrl))
		{	
			this.smfSetWorkPage(sUrl, params);	
		}
	}	
};

/**
 * @description 메뉴 조회(1 레벨) closeup
 * @return 
*/
this.divMenuIndicator_cboMenuLevel1_oncloseup = function(obj:nexacro.Combo,e:nexacro.ComboCloseUpEventInfo)
{
	obj.set_cssclass("cbo_LNB_N");

	/*
	var sUrl = this[obj.innerdataset].getColumn(e.postindex,"menuUrlAddr");	
	var params = {};
	params.menuLvl  = 1;
	if(!this.smfIsNull(sUrl))
	{	
		this.smfSetWorkPage(sUrl, params);	
	}*/
};

this.divMenuIndicator_cboMenuLevel1_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{		
	var sUrl = this[obj.innerdataset].getColumn(e.postindex,"menuUrlAddr");	
	
	var params = {};
	params.menuLvl  = 1;
	if(!this.smfIsNull(sUrl))
	{	
		this.smfSetWorkPage(sUrl, params);	
	}
};

/**
 * @description 메뉴 2 레벨 콤보 드랍다운
 * @return 배열
*/
this.divMenuIndicator_cboMenuLevel2_ondropdown = function(obj:nexacro.Combo,e:nexacro.EventInfo)
{
	//this.smfChangeDiv("W");	//@RHS - 2022.12.05 주석처리함
	obj.set_cssclass("cbo_LNB_F");	
};

this.divMenuIndicator_cboMenuLevel2_onkeyup = function(obj:nexacro.Combo,e:nexacro.KeyEventInfo)
{
	if (e.keycode==13) {
		var cIdx = this.divMenuIndicator.form.cboMenuLevel2.index;
		var sUrl = this[obj.innerdataset].getColumn(cIdx,"menuUrlAddr");	
	
		var params = {};
		if(!this.smfIsNull(sUrl))
		{	
			this.smfSetWorkPage(sUrl, params);	
		}		
	}
};	

/**
 * @description 메뉴 조회(2 레벨) closeup
 * @return 
*/
this.divMenuIndicator_cboMenuLevel2_oncloseup = function(obj:nexacro.Combo,e:nexacro.ComboCloseUpEventInfo)
{
	obj.set_cssclass("cbo_LNB_N");
	
	/*
	var sUrl = this[obj.innerdataset].getColumn(e.postindex,"menuUrlAddr");
	var params = {};
	if(!this.smfIsNull(sUrl))
	{	
		this.smfSetWorkPage(sUrl, params);	
	}
	*/
};

this.divMenuIndicator_cboMenuLevel2_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	var sUrl = this[obj.innerdataset].getColumn(e.postindex,"menuUrlAddr");
	var params = {};
	if(!this.smfIsNull(sUrl))
	{	
		this.smfSetWorkPage(sUrl, params);	
	}	
};

/**
 * @description 마우스enter
 * @return 
*/
this.obj_onmouseenter = function(obj:nexacro.Combo,e:nexacro.MouseEventInfo)
{
	obj.set_cssclass("cbo_LNB_O");		
};

/**
 * @description 마우스leave
 * @return 
*/
this.divMenuIndicator_cboMenuLevel_onmouseleave = function(obj:nexacro.Combo,e:nexacro.MouseEventInfo)
{
	obj.set_cssclass("cbo_LNB_N");
};

/**
 * @description 메뉴 초기화
 * @return 
*/
this.fnSetHeadReset = function()
{
	this.divMenuIndicator.form.btnMenuLevel0.set_text("");
	this.divMenuIndicator.form.btnMenuLevel0.set_visible(true);	
	
	this.divMenuIndicator.form.cboMenuLevel1.set_index(-1);
	this.divMenuIndicator.form.cboMenuLevel1.set_visible(true);	
	this.divMenuIndicator.form.cboMenuLevel2.set_index(-1);
	this.divMenuIndicator.form.cboMenuLevel2.set_visible(true);
};

// 처음으로 클릭
this.divMenuIndicator_btnHome_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var mainWidth = this.getOwnerFrame().form.width - this._getHScrollBarSize();
	
	this.getOwnerFrame().form.divAll.setOffsetTop(0);
	this.getOwnerFrame().form.divAll.form.divWork.setOffsetLeft(0);
	this.getOwnerFrame().form.divAll.form.divWork.setOffsetWidth(mainWidth);

	this.getOwnerFrame().form.fnFormInit();
	this.getOwnerFrame().form.divTop.form.fnTopMode("B");
	//this._smfAnimationDivDirect(0);

};

//처음으로(모바일)
this.divMenuIndicator2_btnHome_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if ( this.smfIsMobile() )
	{
		this.getOwnerFrame().form.divAll.form.divHead.form.fnSetHeadReset();
		this.getOwnerFrame().form.frameMain_onload();		
	}
};
]]></Script>
    <Objects>
      <Dataset id="dsMenu">
        <ColumnInfo>
          <Column id="pafrSysClfCd" type="string" size="256" description="대국민시스템분류코드"/>
          <Column id="menuId" type="STRING" size="256" description="메뉴ID"/>
          <Column id="scrinId" type="string" size="256" description="화면ID"/>
          <Column id="menuNm" type="STRING" size="256" description="메뉴명"/>
          <Column id="scrinNm" type="string" size="256" description="화면명"/>
          <Column id="menuLvl" type="string" size="256" description="메뉴레벨"/>
          <Column id="upMenuId" type="string" size="256" description="상위메뉴ID"/>
          <Column id="menuUrlAddr" type="string" size="256" description="메뉴URL주소"/>
          <Column id="comYn" type="STRING" size="256" description="공통(푸터)메뉴여부"/>
          <Column id="useYn" type="string" size="256" description="사용여부"/>
          <Column id="rgtrId" type="STRING" size="256" description="등록자ID"/>
          <Column id="regDt" type="STRING" size="256" description="등록일시"/>
          <Column id="mdfrId" type="STRING" size="256" description="수정자ID"/>
          <Column id="mdfcnDt" type="STRING" size="256" description="수정일시"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsMenuLevel1">
        <ColumnInfo>
          <Column id="pafrSysClfCd" type="string" size="256" description="대국민시스템분류코드"/>
          <Column id="menuId" type="STRING" size="256" description="메뉴ID"/>
          <Column id="scrinId" type="string" size="256" description="화면ID"/>
          <Column id="menuNm" type="STRING" size="256" description="메뉴명"/>
          <Column id="scrinNm" type="string" size="256" description="화면명"/>
          <Column id="menuLvl" type="string" size="256" description="메뉴레벨"/>
          <Column id="upMenuId" type="string" size="256" description="상위메뉴ID"/>
          <Column id="menuUrlAddr" type="string" size="256" description="메뉴URL주소"/>
          <Column id="comYn" type="STRING" size="256" description="공통(푸터)메뉴여부"/>
