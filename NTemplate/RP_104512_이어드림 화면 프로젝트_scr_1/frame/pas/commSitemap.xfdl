    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    frame/pas
*  @FileName 	commSitemap.xfdl
*  @Creator 	투비소프트
*  @CreateDate 	2022.07.29
*  @Desction    사이트 맵
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.07.21     	TOBESOFT 	               최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/


/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
this.commSitemap_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	var comp = this.divSitemap.form.getFirstAccessibilityComponent();
	comp.setFocus();
	this.commSitemapResize(obj,e);
	
};

/**
 * @description 팝업창 삭제
*/
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.getOwnerFrame().form.divTop.form.divSkip.set_visible(true);

	var objDiv = this.getOwnerFrame().form.removeChild("commSitemap"); 
	objDiv.destroy();
	objDiv = null;
};

/**
 * @description 메뉴 이동 & 화면 닫기
*/
this.fnMenu = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.nexacroFrame = nexacro.getApplication().mainframe.VFrameSet.frameMain.form;	

	this.nexacroFrame.divAll.form.vscrollbar.set_pos(0);
	
	// History 기능 적용시 주석처리 함 (메뉴화면이 계속 열려서 메뉴와 메뉴 사이에 메인 화면이 낌)
	//this.smfChangeDiv("B");


	//현재 준비중인 메뉴들(추후에 삭제)
	var objName = obj.name;
	
// 	switch(objName) {
// 	case "btnMenu9_3":
// 		this.smfAlert("서비스 준비중입니다");
// 		return;
// 		break;
// 	case "btnMenu9_8":
// 		this.smfAlert("서비스 준비중입니다");
// 		return;
// 		break;
// 	case "btnMenu9_7":
// 		this.smfAlert("4세대 나이스 전환을 위해 교육비원클릭신청시스템 서비스가 일시 중단됩니다. \n 이용에 불편을 드려 죄송합니다. \n보다 편리한 서비스를 제공할 수 있도록 노력하겠습니다. \n\n서비스 중단 기간 \n23.6.21.(수) 6:00 ~ 6.26(월) 6:00");
// 		return;
// 		break;	
// 	default:
// 	}

	//menuId = 5000
	//var sUrl = "pa_pas_mms_sp::pas_mmssp00_m02.xfdl";
	var sUrl = "";
	sUrl = this.getOwnerFrame().form.divTop.form.dsMenu.lookup("menuId",obj.menuId,"menuUrlAddr");
	if(!this.smfIsNull(sUrl))
	{
		var params = {};
		var upMenuId = obj.menuId.substr(0,1);
		var sServer = "local";
		var sType = "open";
		
		if(this.smfContainsStr(window.location.host, "local")){		//로컬인 경우
			sServer = "local";
		}else if (this.smfContainsStr(window.location.host, "dev")){	//개발인 경우
			sServer = "dev";
		}else if (this.smfContainsStr(window.location.host, "tst")){	//시험인 경우
			sServer = "test";
		}else if (!this.smfContainsStr(window.location.host, "local") && 
				  !this.smfContainsStr(window.location.host, "dev") &&
				  !this.smfContainsStr(window.location.host, "tst")){	//운영인 경우
			sServer = "prod";
		}
		
		if(upMenuId == "8"){ //서비스링크인 경우
			sType = "link";

			if(sUrl.length == 3){	//서비스 코드인 경우 url 받아오기
				sUrl = this._smfGoNexacro(sServer,sUrl);
			}
		}
		
		if(obj.menuId == "8001"){	//대국민포털 메인은 현재창에 열기
			sType="redirect";
		}
		
		if(obj.menuId == "8011"){  // 원격지원서비스인 경우 팝업으로 오픈
			params.options = "width=600,height=600,scrollbars=yes";
		}

		this.smfSetServiceLink(sUrl,sType,params);
	}
	this.getOwnerFrame().form.divTop.form.divSkip.set_visible(true);
	
	// 페이지 변경 시 마다 Focus 위치 초기화
	if (this.getOwnerFrame().form.divTop.form["btnFirstFocus"]) 
		this.getOwnerFrame().form.divTop.form.btnFirstFocus.setFocus();

	var objDiv = this.getOwnerFrame().form.removeChild("commSitemap"); 
	objDiv.destroy();
	objDiv = null;	
};

this.commSitemapResize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
//	if( e.cx > 1920)
//	{
//		this.setOffsetWidth(1920);
//		return;
//	}

	var nAllWidth = this.width;  // 전체 form의 사이즈
	var nMaxWidth = 1200;
	var nLeft;

	if(nAllWidth >= nMaxWidth)	//1280 사용
	{
		nLeft = parseInt((nAllWidth - nMaxWidth) / 2);
		if(nLeft < 0) nLeft = 40;
	}else
	{
		nLeft = 40;
	}

	// 가운데 정렬
	this.divSitemap.setOffsetLeft(nLeft);
	
	//사이트맵 높이 조절
	// 마지막 버튼 하단 여백 36px
	var nMaxHeight = this._smfGetMaxBottomPos(this.divSitemap.form) +36;
	this.divSitemap.setOffsetHeight(nMaxHeight);
	// 배경Static 높이 조절
	var nHeight = nMaxHeight + 200;
	// 브라우저 높이보다 작을 경우 브라우저 높이로 설정
	if(nHeight < window.innerHeight){
		nHeight = window.innerHeight;
	}
	this.staBG.setOffsetHeight(nHeight);
	this.divSitemap.form.resetScroll();
	this.resetScroll();

	//this.smfResetScroll(this.staBG);
};

this.commSitemap_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.commSitemapResize(obj,e);
};

this.btnClose_onkillfocus = function(obj:nexacro.Button,e:nexacro.KillFocusEventInfo)
{
	var comp = this.divSitemap.form.getFirstAccessibilityComponent();
	comp.setFocus();
};
]]></Script>
  </Form>
</FDL>
