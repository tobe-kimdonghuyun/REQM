/**
 * @description 메뉴버튼 마우스로 진입 시
*/ 
this.btn_onmouseenter = function(obj:nexacro.Button,e:nexacro.MouseEventInfo)
{
	this.pdvMenu.closePopup();
	this.dsMenu.filter("");
	this.dsMenu.filter("parentMenuId=="+obj.menuid+"&&isShow!='N'");
	this.dsMenuSub.copyData(this.dsMenu,true);
	this.dsMenuSub.set_rowposition(-1);
	if(this.dsMenuSub.getRowCount()  == 0) return;
	this.pdvMenu.setOffsetHeight(this.dsMenuSub.getRowCount() * 40 +4);
	this.pdvMenu.trackPopupByComponent(obj, 0, obj.getOffsetBottom() +1, 232, this.dsMenuSub.getRowCount() * 40 +4, "", false);
};

/**
 * @description 메뉴버튼 포커스가 들어올 때 
*/
this.Button_onsetfocus = function(obj:nexacro.Button,e:nexacro.SetFocusEventInfo)
{
	//포커스 가지고 있는 컴포넌트 저장
	this.objFocusComp = obj;

	this.pdvMenu.closePopup();
	this.dsMenu.filter("");
	this.dsMenu.filter("parentMenuId=="+obj.menuid+"&&isShow!='N'");
	this.dsMenuSub.copyData(this.dsMenu,true);
	this.dsMenuSub.set_rowposition(-1);
	if(this.dsMenuSub.getRowCount()  == 0) return;
	this.pdvMenu.setOffsetHeight(this.dsMenuSub.getRowCount() * 40 +4);
	this.pdvMenu.trackPopupByComponent(obj, 0, obj.getOffsetBottom() +1, 232, this.dsMenuSub.getRowCount() * 40 +4, "", false);	
};


/**
 * @description popupdiv 에서 벗어날때 닫기
*/ 
this.pdivMenu_grd00_onmouseleave = function(obj:nexacro.Grid,e:nexacro.MouseEventInfo)
{
	this.pdvMenu.closePopup();
};


/**
 * @description popupdiv 메뉴 클릭시
*/ 
this.pdivMenu_grd00_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{

	var sUrl    = this.dsMenuSub.getColumn(e.row, "menuUrl");
	var sMenuId = this.dsMenuSub.getColumn(e.row, "menuId" );
	
	var sParentMenuId = this.dsMenuSub.getColumn(e.row, "parentMenuId");
	var nRow =  this.dsMenu.findRowNF("menuId", sParentMenuId);
	var sParentName = this.dsMenu.getColumnNF( nRow, "menuName");
	var menuText = sParentName + "|" + this.dsMenuSub.getColumn(e.row, "menuName");
	
	if(!this.smfIsNull(sUrl))
	{		
		//@KBR  주석처리
		//this.fnChangeDiv("B");
		
		// 화면을 호출한다.
		var params = {menu : sMenuId,_url:sUrl};
		this.smfSetWorkPage(sUrl, params, null, menuText);
	}
	
	//this.getOwnerFrame().form.fnSetWorkpage();

	this.pdvMenu.closePopup();
};

// 로그인/로그아웃 버튼을 누른 경우의 처리
this.divDispArea_btnLogin_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//@KBR 로그인 여부
	if(!this.smfIsLogin())
	{
		// 다음 URL을 지정한다.(일반적으로 메인화면)
		var sMainUrl =  this.getOwnerFrame().form.fv_mainformUrl;
		
		// 로그인 화면을 구한다.
		var sUrl = "frame::frameLogin.xfdl";
		
		sUrl = this.fnGetLoginUrl();
		
		// 파라미터를 구한다.
		var params = {resendUrl: sMainUrl};
		
		//@KBR  주석처리
		//this.fnChangeDiv("B");
		
		// 로그인화면으로 이동한다.
		var bHead = false;
		
		var sMenuText = "로그인";
		this.smfSetWorkPage(sUrl, params,bHead, sMenuText);	
	}else
	{
		this.fnLogout();
	}	
};

// 교육청선택버튼
this.divDispArea_btnChangeCddcCd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sSubSystemGb = this.smfGetSubSystemGb();
	
	// 교육청선택팝업을 표시한다.
	// callback함수 : this.fnPopupCallback
	if(  (sSubSystemGb=="AFS")   // 업무지원(외부강사)
	  || (sSubSystemGb=="ECC")   // 업무지원(돌봄인력서비스)
	  || (sSubSystemGb=="IBM")   // 업무지원(교과용도서)
	  || (sSubSystemGb=="SEM")   // 업무지원(학교환경관리)
	  || (sSubSystemGb=="PHE")   // 업무지원(체육)
	  || (sSubSystemGb=="SML")   // 업무지원(급식)
	  || (sSubSystemGb=="SPR")   // 업무지원(교육복지)
	  )
	{
		// 로그인여부 체크해제(?)
		
		// 자기자신을 줄인다. 
		this.fnRearrageTopComp(sSubSystemGb,"collapse");
		
		//@KBR subSystemDetailGb 초기화
		this.smfSetSubSystemDetailGb("");
		
		// 메인화면으로 이동
		var objParams={};
		//var sUrl = "frame::afs/frameSubMain.xfdl";  // 메인 URL- framMain의 데이터셋에서 가져와야...
		//@KBR frameMain에서 메인 URL 가져오기
		var objMainForm = this.parent.parent;
		var sUrl = objMainForm.fnGetMainFormUrl();
		var bIsHeadShow = false;
		this.smfSetWorkPage(sUrl,objParams,bIsHeadShow)
	}
	else if(  (sSubSystemGb=="ORE")   // 온라인 교직원 채용(교원채용)
	       || (sSubSystemGb=="HRD")   // 온라인 교직원 채용(계약제교원인력풀)
	       )
	{
		this.fnCddcPopup(sSubSystemGb);
	}		
	else
	{
		this.fnCddcPopup(sSubSystemGb);
	}
};


//사이트맵 버튼 클릭
this.divDispArea_btnSitemap_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
 	if (  nexacro.getEnvironmentVariable("ev_isMobile") == "Y")
 	{	// 모바일 - 메뉴표시
	
		//@KBR css설정
		if ( obj.cssclass == "btn_Top_sitemap_M")
		{
			obj.set_cssclass("btn_Top_close_M");
		}else if( obj.cssclass == "btn_Top_close_M" )
		{
			obj.set_cssclass("btn_Top_sitemap_M");		
		}
		
		if( this.getOwnerFrame().form["commpop_menu"] ) 
		{
			var objDel = this.getOwnerFrame().form.removeChild("commpop_menu");
			objDel.destroy();
			objDel = null;
			return;
		}
		this.popInfo = {};
		this.popInfo.id     = "commpop_menu";
		this.popInfo.pUrl   = "comm::comp_mobileMenu.xfdl";		
		this.smfDivPop(this.popInfo,false);	
	
	}
	else
	{  // PC - 사이트맵
		// Create Object  
		var objFrameForm = this.getOwnerFrame().form;
		
		var sSitemapDivId = "frameSitemap";
		var objDiv = objFrameForm[sSitemapDivId];
		
		if(!objDiv)
		{
			objDiv = new Div();  
			objDiv.init("frameSitemap", 0, 0, null, null,0,0);
			objDiv.set_initvalueid("ivDivAccessibilityOn");
			objDiv.set_accessibilitylabel("사이트맵 팝업");
			
			// Add Object to Parent Form  
			this.getOwnerFrame().form.addChild("frameSitemap", objDiv); 
			objDiv.set_visible(false);
			// Show Object  
			objDiv.show(); 
			objDiv.set_url("frame::frameSitemap.xfdl");	
		}
		else
		{
			objDiv.set_left(0);
			objDiv.set_top(0);
			objDiv.set_right(0);
			objDiv.set_bottom(0);
		}

		objDiv.set_visible(true);
		objDiv.form.resetScroll();		
	}
};


/**
 * @description skip에서 포커스가 빠졌을때
*/
this.divSkip_onkillfocus = function(obj:nexacro.Div,e:nexacro.KillFocusEventInfo)
{
	this.divSkip.set_height(0);

	var elem = this.divSkip.getElement();
	if(elem)
	{ //겹쳐진 컴포넌트의 z-index 조절
		elem.setElementZIndex("");
	}	
};
/**
 * @description skip에서 포커스가 들어올때
*/
this.divSkip_onsetfocus = function(obj:nexacro.Div,e:nexacro.SetFocusEventInfo)
{
	this.divSkip.set_height(44);
	
	var elem = this.divSkip.getElement();
	if(elem)
	{ //겹쳐진 컴포넌트의 z-index 조절
		elem.setElementZIndex(1);
	}	
	
};

/**
 * @description 본문바로가기 버튼 클릭
*/
this.divSkip_btnGobody_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var divWork = this.getOwnerFrame().form.divAll.form.divWork;
	
	//divWork의 첫번째 컴포넌트로 setFocus();
	var comp = divWork.form.components;
	for(var i=0; i<comp.length; i++)
	{
		//접근성 enable true인 첫번째 컴포넌트
		if(comp[i].accessibilityenable==true)
		{
			comp[i].setFocus();
			break;
		}
	}
};





/****************** 로그인/로그아웃 START ******************/

//로그인 이후의 처리를 한다.
this.fnLoginAfter = function()
{
	var sSubSystemGb = this.smfGetSubSystemGb();	
	
	//글로벌 변수 로그인 여부 수정
	this.smfSetLoginState(true);
	
	//로그인btn text 수정
	this.divDispArea.form.btnLogin.set_text("로그아웃");
	
	//@KBR
	//학원민원  마이페이지 DIV
	if(sSubSystemGb == "HES") this.divDispArea.form.divHESLink.set_visible(true);
	
	// 메뉴변경
	if(sSubSystemGb == "EWS" || sSubSystemGb == "ORE")//JSF 20240705 for 관리자모드 
	{
		this.fnChangeMenu();
	}
	
	//로그인 잔여시간 셋팅
	//(해당하는 서브시스템에서만 동작)
	if(sSubSystemGb == "SQA"
	   || sSubSystemGb == "BDM"
	   || sSubSystemGb == "UDS"
	   || sSubSystemGb == "ORE"
	   || sSubSystemGb == "HRD"
	   || sSubSystemGb == "UDA")
	{
		this.fvUseRemainTime = true;
		//서버에서 타임아웃 시간 가져 옴
		this.fnGetTimeout();  
	}

};

//서버에서 로그인 잔여시간 정보 가져오기.
this.fnGetTimeout = function()
{
	this.smfSearchService("selectTimeout")		
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			//로그인한 시간 저장
			var objCurrTime = new Date();

			this.fvMaxTimeout = this.dsTimeOut.getColumn(0, "maxTimeout") * 60; // 초로 저장
			this.fvRemainTimeout = this.dsTimeOut.getColumn(0, "remainTimeout") * 60; //초로 저장
			this.fvLoginLocalTime = objCurrTime;

			//로그인 후 잔여시간 처리
			this.fnTimeoutLogin();
		});
};


//로그인 후 잔여시간 컴포넌트 처리
this.fnTimeoutLogin = function()
{
	var sSubSystemGb = this.smfGetSubSystemGb();	

	//ORE, HRD에서는 시간표시하지 않음.
	if(  sSubSystemGb != "ORE"
		&& sSubSystemGb != "HRD")
	{
		//시간표시obj visible true
		this.divDispArea.form.staRemainingTime.set_visible(true);
	}

	var sMaxOutTime = this.lpad(this.dsTimeOut.getColumn(0, "maxTimeout"), "0", 2); // "00"
	this.divDispArea.form.staRemainingTime.set_text( sMaxOutTime + "분 00초");
	
	//obj 위치 조절
	var nLeft = (this.divDispArea.getOffsetWidth() - this.divDispArea.form.staRemainingTime.getOffsetLeft()) + 20; 
	if(this.divDispArea.form.divSQALink.visible){
		this.divDispArea.form.divSQALink.set_right(nLeft);
	}
	if(this.divDispArea.form.divPARLink.visible){
		this.divDispArea.form.divPARLink.set_right(nLeft);
	}
	if(this.divDispArea.form.divHESLink.visible){
		this.divDispArea.form.divHESLink.set_right(nLeft);
	}		

	//timer on
	this.setTimer(this.fvTimerId, 1000);
};


//로그아웃 후 잔여시간 처리
this.fnTimeoutLogout = function()
{
	//시간표시obj visible false
	this.divDispArea.form.staRemainingTime.set_visible(false);
	this.divDispArea.form.staRemainingTime.set_text("");	
	
	//obj 위치 조절
	var nLeft = (this.divDispArea.getOffsetWidth() - this.divDispArea.form.btnLogin.getOffsetLeft()) + 20;
	if(this.divDispArea.form.divSQALink.visible){
		this.divDispArea.form.divSQALink.set_right(nLeft);
	}
	if(this.divDispArea.form.divPARLink.visible){
		this.divDispArea.form.divPARLink.set_right(nLeft);
	}
	if(this.divDispArea.form.divHESLink.visible){
		this.divDispArea.form.divHESLink.set_right(nLeft);
	}	
};


this.frameTop_ontimer = function(obj:nexacro.Form,e:nexacro.TimerEventInfo)
{
	//로그아웃 잔여시간 체크
	if (e.timerid == this.fvTimerId) 
	{
		//this.fvMaxTimeout 서버에서 가져온 잔여 총 시간 (초)
		//this.fvRemainTimeout 서버에서 가져온 연장 여부 체크시간 (초)
		//this.fvLoginLocalTime 로그인했을 때 로컬 시간(Date)
		
		var objCurrLocalTime = new Date(); //현재 로컬 시간

		//경과시간   현재시간-로그인시간 (.getTime() 밀리초값으로 반환.) 
		var nPassTime = Math.floor( (objCurrLocalTime.getTime() - this.fvLoginLocalTime.getTime())/1000 );
		//남은시간(잔여총시간(초) - 경과시간)
		var nDiffSec = this.fvMaxTimeout - nPassTime;
		
		var nLastMin = Math.floor(nDiffSec/60);
		var nLastSec = Math.floor(nDiffSec%60);

		//시간 text셋팅
		this.divDispArea.form.staRemainingTime.set_text( this.lpad(nLastMin,"0",2) + "분 "    //00분
														+  this.lpad(nLastSec, "0", 2)+"초"); //00초
		
		// 연장팝업 (남은시간<=연장체크시간) (초로 계산)
		if(nDiffSec <=  this.fvRemainTimeout)
		{
			this.fnRemainPopup();
			this.killTimer(this.fvTimerId);
		}

	}
};


//잔여시간obj 클릭
this.divDispArea_staRemainingTime_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.killTimer(this.fvTimerId);
	this.fnRemainPopup();
};


// 로그인시간 연장 팝업을 표시한다.
// callback함수 : this.fnRemainPopupCallback
this.fnRemainPopup = function()
{
	//팝업 열려있는지 확인
	var arrPopup = nexacro.getPopupFrames();
	if(arrPopup["comm::comp_login_extend.xfdl"])
	{
		return;
	}
	else
	{
		var sLastTime = this.divDispArea.form.staRemainingTime.text;//현재 남은 시간
		
		// 팝업을 동작에 필요한 파라메터 지정
		var popupParams = {
			callback: this.fnRemainPopupCallback, // 콜백함수 지정
			sender: obj, // sender 지정	

			// 팝업 전달 파라메터 지정
			params: {
				// 처리타입 지정
				procType: "notice"
				, sLastTime : sLastTime
				, fvMaxTimeout : this.fvMaxTimeout
				, objLoginLocalTime : this.fvLoginLocalTime
			},
			
			titlebar:false
		};

		// 모달팝업 실행
		this.smfDialog("_auto", "comm::comp_login_extend.xfdl", popupParams );	
	}
};

/*
 * 로그인 연장여부 팝업 콜백
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnRemainPopupCallback = function(e, sender)
{
	this.killTimer(this.fvTimerId);
	
	//로그아웃YN에 따라 분기처리(연장/종료)
	if(e.logoutYn){
	
		// 동일팝업 열려있는지 확인
		var arrPopup = nexacro.getPopupFrames();
		if(arrPopup["comm::comp_login_ending.xfdl"])
		{
			return;
		}
		else
		{
			//종료 alert 팝업 출력
			var popupParams = {
				callback: this.fnLogoutMsgCallback, // 콜백함수 지정
				internalCallback: this.fnLogoutMsgCallback, // 콜백함수 지정
				sender: obj, // sender 지정	
				popuptype : "modalsync",
				// 팝업 전달 파라메터 지정
				params: {
					// 처리타입 지정
					procType: "notice"
				},
				titlebar:false
			};

			// 모달팝업 실행
			this.smfDialog("_auto", "comm::comp_login_ending.xfdl", popupParams );	
			//this.smfLiteralAlert("정보보호를 위해 시스템을 종료합니다.", this.fnLogoutMsgCallback);	
		}

	}
	else{
		//로그인 시간 연장(세션 연장 서비스 호출)
		this.smfExecuteService("executeSessionRemain")	
		.showConfirm(false)
		//.requireModifredData()  데이터 변경 필수
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
					//잔여시간 연장
					this.fnRemainTime();
				});	
	}
};

//잔여시간 연장
this.fnRemainTime = function()
{
	//현재 시간 저장
	var objCurrTime = new Date();		
	this.fvLoginLocalTime = objCurrTime;
	
	//text 셋팅
	var sMaxOutTime = this.lpad(this.dsTimeOut.getColumn(0, "maxTimeout"), "0", 2); // "00"
	this.divDispArea.form.staRemainingTime.set_text( sMaxOutTime + "분 00초");

	//timer on
	this.setTimer(this.fvTimerId, 1000);
}


//로그인시간 만료 메시지 콜백
this.fnLogoutMsgCallback = function(e, sender)
{
	this.fnLogout();
};

//로그아웃
this.fnLogout = function()
{
	this.killTimer(this.fvTimerId);
	
	//로그아웃 서비스 호출
	this.smfExecuteService("executeLogout")		
	.showConfirm(false)
	.run()// 실행
	// 콜백
	.callback(function(callbackParams){
			this.fnLogoutAfter();
		});
};

//로그아웃 후 처리
this.fnLogoutAfter = function()
{
	var sSubSystemGb = this.smfGetSubSystemGb();	
	var sCddcCode = this.smfGetCddcCode();  // 교육청코드

	//gdsSession clearData addRow
	var objSessionDs = nexacro.getApplication().gdsSession;
	// 온라인 채용인 경우 일부 값을 그대로 유지
	var sAppoExamScCd = this.smfGetAppoExamScCd();
	
	objSessionDs.clearData();
	objSessionDs.addRow();
	
	// 일부 필요한 값을 디폴트 세팅
	this.smfSetCddcCode(sCddcCode);
	this.smfSetAppoExamScCd(sAppoExamScCd);  // 온라인 채용을 위해

	
	//글로벌 변수 로그인 여부 수정
	this.smfSetLoginState(false);
	
	//로그아웃btn text 수정
	this.divDispArea.form.btnLogin.set_text("로그인");
	
	//@KBR
	//학원민원 마이페이지 DIV
	if(sSubSystemGb == "HES") this.divDispArea.form.divHESLink.set_visible(false);	
		
	// 메뉴변경
	if(sSubSystemGb == "ORE") this.fnChangeMenu(); //JSF 20240717 for 관리자모드 

	//로그아웃 후 잔여시간 obj처리	
	if(this.fvUseRemainTime){
	    this.fvUseRemainTime = false;
		this.fnTimeoutLogout();
	}

	
	//열려있는 팝업 전부 닫기 [팝업 안닫힘]
	var arrPopup = nexacro.getPopupFrames();
	var nLength = arrPopup.length;
	if(nLength > 0){
		for(var i=nLength-1; i>=0; i--)
		{	
			if(arrPopup[i]){
				trace(arrPopup[i].name);
				arrPopup[i].form.close();
			}		
		}
	}	
	
	var objFrame = this.getOwnerFrame();
	if(objFrame.form.divAll)
	{
		var sSubSystemGb =  this.smfGetSubSystemGb();
		var sMainUrl = objFrame.form.fv_mainformUrl;
		
		//@KBR 대입전형 로그인 페이지로 이동, 그 외 메인화면으로 이동
		if(sSubSystemGb == "UDS")
		{
			var oParam = {};
			this.smfSetWorkPage("pa_uds_cmm_cm::uds_cmmcm00_m00.xfdl",oParam,false);
		}
		else if(sSubSystemGb == "PAR")
		{
			this.divDispArea.form.divPARLink.form.fnDeleteJwt();
		}
		else
		{
			// Top 에 값을 세팅		
			// 메인URL로 이동한다.
			if(!this.smfIsNull(sMainUrl))
			{
				//@KBR 채용/업무지원 Top영역 조절
				if(  (sSubSystemGb=="AFS")   // 업무지원(외부강사)
				  || (sSubSystemGb=="ECC")   // 업무지원(돌봄인력서비스)
				  || (sSubSystemGb=="IBM")   // 업무지원(교과용도서)
				  || (sSubSystemGb=="SEM")   // 업무지원(학교환경관리)
				  || (sSubSystemGb=="PHE")   // 업무지원(체육)
				  || (sSubSystemGb=="SML")   // 업무지원(급식)
				  || (sSubSystemGb=="SPR")   // 업무지원(교육복지)
				 // || (sSubSystemGb=="ORE")   // 온라인채용(교원임용)
				 // || (sSubSystemGb=="HRD")   // 온라인채용(계약제교원인력풀)	
				 )
				{
					this.fnRearrageTopComp(sSubSystemGb,"collapse");
				}			
				
				// 메인화면으로 이동한다.
				objFrame.form.fnSetMainpage(sMainUrl);	
				
			}
		}
	}			
}

/******************로그인/로그아웃  END******************/


this.divDispArea_divSelectCddc_staCddcLogo_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	// 현재 서브시스템을 구한다.
	var sSubSystemGb =  this.smfGetSubSystemGb();
	
	// 대상제외 시스템이면 처리를 중단(만약을 위한 처리)
	var arrExceptSubSysGB = [];  // 대상제외시스템("SQA","ORE" 등)
	if(arrExceptSubSysGB.indexOf(sSubSystemGb)>-1)
	{
		return;
	}

	//메인화면으로 이동
	var objFrame = this.getOwnerFrame();
	if(objFrame.form.divAll)
	{
		// Top 에 값을 세팅
		var sMainUrl = objFrame.form.fv_mainformUrl;
		
		// 메인URL로 이동한다.
		if(!this.smfIsNull(sMainUrl))
		{
			//@KBR 채용/업무지원 Top영역 조절
			if(  (sSubSystemGb=="AFS")   // 업무지원(외부강사)
			  || (sSubSystemGb=="ECC")   // 업무지원(돌봄인력서비스)
			  || (sSubSystemGb=="IBM")   // 업무지원(교과용도서)
			  || (sSubSystemGb=="SEM")   // 업무지원(학교환경관리)
			  || (sSubSystemGb=="PHE")   // 업무지원(체육)
			  || (sSubSystemGb=="SML")   // 업무지원(급식)
			  || (sSubSystemGb=="SPR")   // 업무지원(교육복지)
			 // || (sSubSystemGb=="ORE")   // 온라인채용(교원임용)
			 // || (sSubSystemGb=="HRD")   // 온라인채용(계약제교원인력풀)	
			 )
			{
				this.fnRearrageTopComp(sSubSystemGb,"collapse");
			}			
			
			// 메인화면으로 이동한다.
			objFrame.form.fnSetMainpage(sMainUrl);	
			
		}
	}
};


//ESC를 누르면 popupDiv닫힘. 기존 컴포넌트로 포커스 이동.
this.pdvMenu_grd00_onkeydown = function(obj:nexacro.Grid,e:nexacro.KeyEventInfo)
{
	//ESC누름
	if(e.keycode == 27)
	{
		this.pdvMenu.closePopup();
		this.objFocusComp.setFocus();
	}
};


this.divDispArea_divSelectCddc_btnChangeCddcCd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divDispArea.form.btnChangeCddcCd.click();
};
]]></Script>
  </Form>
</FDL>
