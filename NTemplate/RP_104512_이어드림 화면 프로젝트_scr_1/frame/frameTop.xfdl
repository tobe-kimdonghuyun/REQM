    <Script type="xscript5.1"><![CDATA[/**
*  컨설팅 표준화 작업
*  @MenuPath    frameSDI > frameTop
*  @FileName 	frameTop.xfdl 
*  @Creator 	consulting
*  @CreateDate 	2018.02.22
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
*  2018.02.22	     	consulting			    최초 생성
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

this.fv_TopBtnPrefix = "TOP_";
this.objApp = nexacro.getApplication();
this.fvSubSysGb = "";
this.fvLastLeft=0;

//로그인 잔여시간
this.fvMaxTimeout = 0; //총잔여시간
this.fvRemainTimeout = 0; //연장알림시간
this.fvLoginLocalTime; //로그인로컬시간
this.fvUseRemainTime = false; //잔여시간 사용여부
this.fvTimerId = 1001; //타이머 아이디

this.fv_MenuPostfixMobile = "";

// History처리를 위한 변수
this.fvHistoryInfo_type = "expand";  // "expand" , "collapse"
this.fvHistoryInfo_objOption = {};


this.objFocusComp ;//포커스를 가지고 있는 컴포넌트 저장
/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitDiv(obj); 
	
	if(this.smfIsMobile()){
		this.parent.setOffsetHeight(96);
	}
	
	this.divSkip.set_height(0);	
	
	var objMenuForm = this.divMenu.form;
	// 서브시스템코드를 가져온다.
	var sSubSystemGb = this.smfGetSubSystemGb();
	this.fvSubSysGb = sSubSystemGb;
	
	var sDetailSubSys = this.smfGetSubSystemDetailGb();
	
	// 교육청선택cssclass를 선택
	this.fnSetCddcSelCssclass();
	
	// 모바일인 경우 별도메뉴를 가진 것을 지정
	if(this.smfIsMobile())
	{
		if(  (sSubSystemGb=="AFS")   // 업무지원(대표서브시스템구분)
		  || (sSubSystemGb=="SML")   // 업무지원(급식)
		  || (sSubSystemGb=="HES")   // 학원민원
		  || (sSubSystemGb=="UDA")   // 대입전형자료온라인생성신청-대입전형자료(학교생활기록부)
		  )
		{
			this.fv_MenuPostfixMobile = "_m"
		}
	}

	// 메뉴 설정 - 일부는 추후에 세팅 변경
	if((sSubSystemGb=="SQA")&&(sDetailSubSys=="103"))
	{
		this.dsMenu.copyData(objMenuForm["dsMenu_"+sSubSystemGb.toLowerCase()+"_"+sDetailSubSys]);
	}else if(sSubSystemGb=="PAR" && (nexacro.getProjectPath().indexOf("localhost") > -1 || nexacro.getProjectPath().indexOf("dev.firstschool.neis.go.kr") > -1)){
		//유치원 학부모서비스 로컬, 개발서버는 "dsMenu_par_dev" 개발용 메뉴를 설정
		this.dsMenu.copyData(objMenuForm["dsMenu_" + sSubSystemGb.toLowerCase() + "_dev"]);
	}
	else
	{
		this.dsMenu.copyData(objMenuForm["dsMenu_"+sSubSystemGb.toLowerCase()+this.fv_MenuPostfixMobile]);
	}
	this.dsMenu.appendData(this.dsMenuBottom);
	
	//@KBR 서브시스템 별 로그인 버튼 색상 변경
	this.fnSetLoginColor(sSubSystemGb);

	var oPrivateData = this.fnGetPrivateProfile("CDDC_INFO");
	
	trace("oPrivateData="+JSON.stringify(oPrivateData));
	
	oPrivateData.cddcCd="";
	if(this.smfIsNull(oPrivateData.cddcCd))
	{
		// 메뉴를 로드(테스트를 위해)
		if(sSubSystemGb=="HES")   // 학원관련민원
		{
			// [학원민원-모바일]인 경우, 높이가 크다
			if(this.smfIsMobile())
			{
				this.divDispArea.form.divSelectCddc.set_visible(true);
				//this.divDispArea.form.btnChangeCddcCd.set_visible(true);
			
				// 높이를 지정
				var nDispHeight = 160;
				this.divDispArea.setOffsetHeight(nDispHeight);
				this.parent.setOffsetHeight(nDispHeight);
				
				// resetScroll을 실시
				this.divDispArea.form.resetScroll();
				this.resetScroll();
			}
			
			
			
			// 교육청선택(시스템선택포함)팝업을 표시한다.
			// callback함수 : this.fnPopupCallback
			this.fnCddcPopup(sSubSystemGb);
		}
		else if (sSubSystemGb=="BDM")   // 비영리법인민원
		{
			// 교육청선택(시스템선택포함)팝업을 표시한다.
			// callback함수 : this.fnPopupCallback
			if(this.smfIsMobile()) return;
			
			this.fnCddcPopup(sSubSystemGb);
		}
		else if(  (sSubSystemGb=="SQA")   // 검정고시
		  )
		{
			// 대입전형(검정고시)의 경우는 교육청 선택 필요 없음.
			
			if(sDetailSubSys=="103")
			{
				// 표시할 것을 조정한다.
				this.divDispArea.form.divTopBtn.set_left(0);
				this.divDispArea.form.divSelectCddc.set_visible(false);
				this.divDispArea.form.btnChangeCddcCd.set_visible(false);
				
				// 로고에 서브시스템명칭을 표시한다.(없으면 표시안함)
				this.fnDisplaySubSysTitle(this.fvSubSysGb);
				
				// TOP화면에 메뉴를 표시한다.
				this.fnRedrawTopMenu();			
			}
			else
			{
				// 교육청선택(시스템선택포함)팝업을 표시한다.
				// callback함수 : this.fnPopupCallback
				this.fnCddcPopup(sSubSystemGb);
 			}
		}
		else if(sSubSystemGb=="UDA")   // 대입전형자료온라인생성신청-대입전형자료(학교생활기록부)
		{
			// 표시할 것을 조정한다.
			this.divDispArea.form.divTopBtn.set_left(160);
			this.divDispArea.form.btnChangeCddcCd.set_visible(false);
			
			this.divDispArea.form.divSelectCddc.form.staCddcLogo.set_cssclass("sta_TF_MOE");
			this.divDispArea.form.divSelectCddc.form.staCddcLogo.set_text("교육부");
			if(this.smfIsMobile()){
				this.divDispArea.form.staRemainingTime.set_right(250);
				this.divDispArea.form.btnLogin.set_cssclass("btn_WF_Crud");
				this.divDispArea.form.btnLogin.set_width(150);
				this.divDispArea.form.btnLogin.set_height(45)
				this.divDispArea.form.btnLogin.set_right(90);
				this.divDispArea.form.btnLogin.set_visible(true);
			}
			
			// 로고에 서브시스템명칭을 표시한다.(없으면 표시안함)
			this.fnDisplaySubSysTitle(this.fvSubSysGb);
			
			// TOP화면에 메뉴를 표시한다.
			this.fnRedrawTopMenu();
		}
		else if(  (sSubSystemGb=="AFS")   // 업무지원(외부강사)
		  || (sSubSystemGb=="ECC")   // 업무지원(돌봄인력서비스)
		  || (sSubSystemGb=="IBM")   // 업무지원(교과용도서)
		  || (sSubSystemGb=="SEM")   // 업무지원(학교환경관리)
		  || (sSubSystemGb=="PHE")   // 업무지원(체육)
		  || (sSubSystemGb=="SML")   // 업무지원(급식)
		  || (sSubSystemGb=="SPR")   // 업무지원(교육복지)
		  )
		{
			this.fnRearrageTopComp(sSubSystemGb,"collapse");
		}
		else if(  (sSubSystemGb=="ORE")   // 온라인채용(교원임용)
		  || (sSubSystemGb=="HRD")   // 온라인채용(계약제교원인력풀)		  
		  )
		{
			this.fnRearrageTopComp(sSubSystemGb,"collapse");
		}
		else if(  (sSubSystemGb=="EDS")   // 교육설문
		  )
		{
			// TopFrame / Bottom Fram을 표시하지 않는다.
			var objTopFrame = this.getOwnerFrame().form.divTop;
			var objNoticeFrame = this.getOwnerFrame().form.divNotice;
			var objBottomFrame = this.getOwnerFrame().form.divAll.form.divBottom;
			var objBgImageFrame = this.getOwnerFrame().form.divAll.form.staBgImage;

			objTopFrame.set_visible(false);
			objTopFrame.setOffsetHeight(0);
			
			objNoticeFrame.set_visible(false);
			objNoticeFrame.setOffsetHeight(0);
			
			objBottomFrame.set_visible(false);
			objBottomFrame.setOffsetHeight(0);
			
			objBgImageFrame.set_visible(false);
			objBgImageFrame.setOffsetHeight(0);
			objBgImageFrame.useYn = "N";
			
			// 로고에 서브시스템명칭을 표시한다.(없으면 표시안함)
			this.fnDisplaySubSysTitle(this.fvSubSysGb);
		}
		else if(  (sSubSystemGb=="PAR")   // 유치원학부모서비스
		  )
		{
			var objProjParams = this.smfGetProjectParams();
			
			var sUserVrId  = objProjParams.userVrId   ;		// 사용자가상ID
			var sStuDtclNo = objProjParams.stuDtclNo  ;     // 자녀 고유 번호
			var sScrnId    = objProjParams.scrnId     ;     // 호출될 화면 ID
			var sScrnType  = objProjParams.scrnType   ;     // 업무단화면구분여부("Y":업무화면,"N":화면관리화면)
			
			if(sScrnType=="N")
			{   // 화면관리화면
				// TopFrame / Bottom Fram을 표시하지 않는다.
				var objTopFrame = this.getOwnerFrame().form.divTop;
				var objNoticeFrame = this.getOwnerFrame().form.divNotice;
				var objBottomFrame = this.getOwnerFrame().form.divAll.form.divBottom;
				var objBgImageFrame = this.getOwnerFrame().form.divAll.form.staBgImage;
				
				objTopFrame.set_visible(false);
				objTopFrame.setOffsetHeight(0);
				
				objNoticeFrame.set_visible(false);
				objNoticeFrame.setOffsetHeight(0);
				
				objBottomFrame.set_visible(false);
				objBottomFrame.setOffsetHeight(0);
				
				objBgImageFrame.set_visible(false);
				objBgImageFrame.setOffsetHeight(0);
				objBgImageFrame.useYn = "N";
			}
			else
			{ // 업무화면
				// 
				if(this.smfIsMobile())
				{	
					var nParLinkHeight = 60;
					
					this.divDispArea.form.divPARLink.set_visible(true);
					//this.divDispArea.form.divPARLink.setOffsetTop(40);
					this.divDispArea.form.divPARLink.setOffsetHeight(nParLinkHeight);
					this.divDispArea.form.resetScroll();					
					
					// Link위치로 이동
					this.divDispArea.form.divPARLink2.set_visible(true);
					
					// 높이를 지정
					var nDispHeight = this.divDispArea.getOffsetHeight() +nParLinkHeight;
					var nDispHeight = this.divDispArea.form.divPARLink.getOffsetTop() +nParLinkHeight;
					this.divDispArea.setOffsetHeight(nDispHeight);
					this.parent.setOffsetHeight(nDispHeight);
					
					// resetScroll을 실시
					this.divDispArea.form.resetScroll();
					this.resetScroll();
				}
				else
				{
					//  교육청 정보를 보여주지 않는다.
					this.divDispArea.form.divSelectCddc.set_visible(false);
					this.divDispArea.form.btnChangeCddcCd.set_visible(false);
					
					this.divDispArea.set_maxwidth(null);
					this.divDispArea.set_right("0");
					//-------------------------------------------
					// 상단 항목 이동 및 사이즈 조정
					var nFirstAreaTop = 6;
					this.divDispArea.form.staLogo.setOffsetTop        (nFirstAreaTop);
					this.divDispArea.form.staSubTitle.setOffsetTop    (nFirstAreaTop);
					this.divDispArea.form.btnChangeCddcCd.setOffsetTop(nFirstAreaTop);
					
					this.divDispArea.form.btnLogin.setOffsetTop   (nFirstAreaTop);
					this.divDispArea.form.divPARLink2.setOffsetTop(nFirstAreaTop-4);
					this.divDispArea.form.divPARLink2.setOffsetHeight(40-((nFirstAreaTop-4)*2));
					
					this.divDispArea.form.btnSitemap.setOffsetTop (nFirstAreaTop);
					
					// 로그인 버튼을 이동
					//this.divDispArea.form.btnLogin.set_right("134");  // 54->134  (width:80)
					// Link위치로 이동
					this.divDispArea.form.divPARLink2.set_visible(true);
					
					//-------------------------------------------
					// 중간 항목 이동 및 사이즈 조정
					var nParLinkHeight = 47;
					
					this.divDispArea.form.sta00.set_visible(false);  // 상단하부 경계선
					this.divDispArea.form.divPARLink.set_visible(true);
					this.divDispArea.form.divPARLink.setOffsetTop(40);
					this.divDispArea.form.divPARLink.setOffsetHeight(nParLinkHeight);
					this.divDispArea.form.resetScroll();					
					
					//-------------------------------------------
					// 하단 항목 이동 및 사이즈 조정
					// 메뉴의 위치를 0으로 이동한다.
					this.divDispArea.form.divTopBtn.setOffsetLeft(0);
					this.divDispArea.form.divTopBtn.set_top(40 + nParLinkHeight + 7);
					

					
					// 높이를 지정
					var nDispHeight = 40 + nParLinkHeight + 55;   
					this.divDispArea.setOffsetHeight(nDispHeight);
					this.parent.setOffsetHeight(nDispHeight);
					
					// resetScroll을 실시
					this.divDispArea.form.resetScroll();
					this.resetScroll();
				}
				
				
				
				
				// 로고에 서브시스템명칭을 표시한다.(없으면 표시안함)
				this.fnDisplaySubSysTitle(this.fvSubSysGb);
				
				// TOP화면에 메뉴를 표시한다.
				this.fnRedrawTopMenu();
			}
		}
		else if(  (sSubSystemGb=="EWS")  // 교육비 원클릭 
			   || (sSubSystemGb=="UDS")	 // 대입전형자료(일반)
		  )
		{
			// 로그인 버튼 안보이게
			if(sSubSystemGb=="EWS")
			{
				//var sIsAdmin = nexacro.getEnvironmentVariable("ev_isAdmin");
				var sIsAdmin = nexacro.getApplication().getVariable("gv_isAdmin");
				if(sIsAdmin!="Y")
				{
					this.divDispArea.form.btnLogin.set_visible(false);
				}
			}
		
			// 표시할 것을 조정한다.
			this.divDispArea.form.divTopBtn.set_left(0);
			this.divDispArea.form.divSelectCddc.set_visible(false);
			this.divDispArea.form.btnChangeCddcCd.set_visible(false);
			
			// 로고에 서브시스템명칭을 표시한다.(없으면 표시안함)
			this.fnDisplaySubSysTitle(this.fvSubSysGb);
			
			// TOP화면에 메뉴를 표시한다.
			this.fnRedrawTopMenu();
		}
		else
		{
			// 로고에 서브시스템명칭을 표시한다.(없으면 표시안함)
			this.fnDisplaySubSysTitle(this.fvSubSysGb);
			
			// TOP화면에 메뉴를 표시한다.
			this.fnRedrawTopMenu();
		}
	}
	else
	{
		this.fnChangeCddc(oPrivateData.selSubSysCd,oPrivateData.subTitle,oPrivateData.cddcCd,oPrivateData.cddcNm);
	}
	
	//@KBR btnFirstBtn 포커스
	this.fnFormInit();
};

this.fnFormInit = function()
{
	if( nexacro.getEnvironment().enableaccessibility && !this.smfIsMobile() ) {
		var sText = "Ctrl + Shift + F11 키를 동시에 눌러 스크린리더의 가상커서를 설정하신 후 이용하시기 바랍니다.";
		
		//[웹접근성] 전용브라우저인 경우
		if(this.fvSubSysGb == "UDS"){
			// sText = "<문서시작> " + sText;
			
			//hotKey설정을 위한 static visible = true [ctrl+home 단축키로 문서시작으로 이동]
			this.staHotkey.set_visible(true);
			this.staHotkey.set_text("<문서시작>");
			this.staHotkey.set_hotkey("CTRL+HOME");
		}
		//this.btnFirstFocus.set_text(sText);
		//this.btnFirstFocus.set_accessibilitylabel(sText);
	}
	this.btnFirstFocus.setFocus();
	
	if( this.smfIsMobile()){
		this.divSkip.set_visible(false);
	}
}

this.frameTop_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	var nMaxWidth = 1200;
	var nHScrollbarWidth = this.parent.parent.divAll.form.divWork._getHScrollBarSize(); //this._getHScrollBarSize();
	var nFormWidth = this.parent.getOffsetWidth() - nHScrollbarWidth;
	
	// 모바일에서 오른쪽에 안붙는 현상 해결
	if(this.smfIsMobile())
	{
		nFormWidth = this.parent.getOffsetWidth();
	}
	
	if(nFormWidth>nMaxWidth)
	{
		var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
		
		var sSubSysGb = this.smfGetSubSystemGb();
		
		if(nLeft<0) nLeft=0;
		
		//sSubSysGb = "SQA";
		// 
		if(sSubSysGb=="PAR")  // 학부모서비스 - 유치원
		{
			if(this.smfIsMobile())
			{
				this.divDispArea.setOffsetLeft(nLeft);
				this.divDispArea.setOffsetWidth(nMaxWidth);			
			}
			else
			{
				nLeft += 22;  // Main의
				
				this.divDispArea.set_left("0");
				this.divDispArea.set_right(nHScrollbarWidth+"");
				
				//--------------------------------------------
				// 상단 조정
				this.divDispArea.form.staLogo.setOffsetLeft(nLeft);
				this.divDispArea.form.btnLogin.setOffsetLeft(nLeft+nMaxWidth-230+22);
				this.divDispArea.form.divPARLink2.setOffsetLeft(nLeft+nMaxWidth-130+22);
				this.divDispArea.form.btnSitemap.setOffsetLeft(nLeft+nMaxWidth-(30+16)+22);
				
				//--------------------------------------------
				// 중단 조정				
				this.divDispArea.form.divPARLink.form.cboStuList.setOffsetLeft(nLeft);
				this.divDispArea.form.divPARLink.form.staSchNm.setOffsetLeft(nLeft+nMaxWidth-284);
				this.divDispArea.form.divPARLink.form.resetScroll();
				
				//--------------------------------------------
				// 하단 조정
				this.divDispArea.form.divTopBtn.setOffsetLeft(nLeft);
				this.divDispArea.form.divTopBtn.setOffsetWidth(nMaxWidth);
				
			}
			
		}
		else
		{
			this.divDispArea.setOffsetLeft(nLeft);
			this.divDispArea.setOffsetWidth(nMaxWidth);
		}
	}
	else
	{
		var nLeft = 0;

		this.divDispArea.setOffsetLeft(nLeft);
		this.divDispArea.setOffsetWidth(nFormWidth);
	}
	
	this.divDispArea.form.resetScroll();
	this.resetScroll();

};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 this.fnTransCallback = function(svcid,errcd,errmsg)
{

}

this.fnCheckSessionWhenAfterServiceCallback = function(svcid, errcd, errmsg, objForm)
{
	var arr = svcid.split("|");
	if(arr[0] == "executeSessionRemain" || arr[0] == "executeLogout") return; 
	
	//로그인 잔여시간 연장
	if(this.fvUseRemainTime){
		this.killTimer(this.fvTimerId);
		this.fnRemainTime();
	}
};


this.fnPopupCallback = function(e, sender){

	//
	var sSelVal1 =  e.selVal1;  // 
	var sSelVal2 =  e.selVal2;  // 
	var sSelVal3 =  e.selVal3;  // 
	var sSelVal4 =  e.selVal4;  // 
	
	this.fnSetPrivateProfile("CDDC_INFO",sSelVal1,sSelVal3,sSelVal4);
	
	// 교육청 변경 처리를 한다.
	this.fnChangeCddc(sSelVal1,sSelVal2,sSelVal3,sSelVal4);
	
	this.divDispArea.form.resetScroll();
	this.resetScroll();
	
};

/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnLoginPopupCallback = function(e, sender){
	// 업무콜백 처리
	trace(e.result);
};

// 교육청로고를 표시한다.
this.fnGetCddcCssClass = function(sCddcCd)
{
	var objApp = nexacro.getApplication();
	
	if(this.smfIsNull(sCddcCd))
	{
		sCddcCd = this.smfGetCddcCode();
	}
	var sCddcCssClass = objApp.gdsCddcList.lookup("cddcCd",sCddcCd,"cssclassId");
	return sCddcCssClass;
}

// 교육청정보에 따라 화면을 변경한다.
this.fnChangeCddc = function(sSelBtnCd,sSelSubTitle,sSelCddcCd,sSelCddcNm)
{
	if(!this.smfIsNull(sSelBtnCd))
	{
		this.smfSetSubSystemGb(this.fvSubSysGb);
		this.smfSetSubSystemDetailGb(this.lpad(sSelBtnCd,"0",3));
	
		var objMenuForm = this.divMenu.form;
		// 메뉴데이터셋 선택/카피
		switch(sSelBtnCd)
		{
			case "1"   :    // 온라인채용(유초등)
			case "001" :    // 온라인채용(유초등)
			case "2"   :    // 온라인채용(중등)
			case "002" :    // 온라인채용(중등)
			case "3"   :    // 온라인채용(지방공무원)
			case "003" :    // 온라인채용(지방공무원)
			case "4"   :    // 온라인채용(교육공무직)
			case "004" :    // 온라인채용(교육공무직)
				this.fvSubSysGb = "ORE";
				this.dsMenu.copyData(objMenuForm["dsMenu_"+this.fvSubSysGb.toLowerCase()+"_"+sSelBtnCd]);
				break;
			case "5"   :    // 온라인채용(계약제교원)
			case "005" :    // 온라인채용(계약제교원)
				this.fvSubSysGb = "HRD";
				this.dsMenu.copyData(objMenuForm["dsMenu_"+this.fvSubSysGb.toLowerCase()]);
				break;
			case "101" : // 검정고시(원서접수)
				this.fvSubSysGb = "SQA";
				this.dsMenu.copyData(objMenuForm["dsMenu_"+this.fvSubSysGb.toLowerCase()+"_"+sSelBtnCd]);
				this.divDispArea.form.divSQALink.set_visible(true);
				this.divDispArea.form.divSQALink.form.fnSetButton();
				break;
			case "102" : // 검정고시(대입전형자료제출)
				this.fvSubSysGb = "SQA";
				this.dsMenu.copyData(objMenuForm["dsMenu_"+this.fvSubSysGb.toLowerCase()+"_"+sSelBtnCd]);
				this.divDispArea.form.divSQALink.set_visible(true);
				this.divDispArea.form.divSQALink.form.fnSetButton();
				break;
			case "201" : // 대입전형(일반)
				this.fvSubSysGb = "UDS";
				this.dsMenu.copyData(objMenuForm["dsMenu_"+this.fvSubSysGb.toLowerCase()]);
				break;
			case "103" :  // 대입전형(검정고시)
				this.fvSubSysGb = "SQA";
				this.dsMenu.copyData(objMenuForm["dsMenu_"+this.fvSubSysGb.toLowerCase()+"_"+sSelBtnCd]);
				break;
		}
		this.dsMenu.appendData(this.dsMenuBottom);
	
		// 

	}
	
	if(!this.smfIsNull(sSelCddcCd))
	{
		this.smfSetCddcCode(sSelCddcCd); // 시도교육청
	}
	
	
	// 로고이미지의 타이틀을 세팅
	sSubSystemName = this.fnDisplaySubSysTitle(this.fvSubSysGb);
	if(this.smfIsNull(sSelSubTitle))
	{
		this.divDispArea.form.staSubTitle.set_visible(false);	
		this.divDispArea.form.staSubTitle.set_text("");	
	}
	else
	{
		this.divDispArea.form.staSubTitle.set_visible(true);	
		this.divDispArea.form.staSubTitle.set_text(sSelSubTitle+" ");	
	}

	this.parent.parent.divAll.form.divHead.form.dsMenu.copyData(this.dsMenu);
	
	
	var sCddcCssClass = this.fnGetCddcCssClass();
	this.divDispArea.form.divSelectCddc.form.staCddcLogo.set_cssclass(sCddcCssClass);
	this.divDispArea.form.divSelectCddc.form.staCddcLogo.set_text(sSelCddcNm);
	//@KBR width변경(width가 250보다 긴 text가 들어올 경우 글자 잘림), resetscroll
	this.divDispArea.form.divSelectCddc.form.resetScroll();
	var nWidth = this.divDispArea.form.divSelectCddc.form.staCddcLogo.getOffsetWidth() + 33;
	// 모바일일 경우(학원민원)
	if(this.smfIsMobile())
	{
		var objChangeCddcCd = this.divDispArea.form.divSelectCddc.form.btnChangeCddcCd;
		var nSelectCddcWidth = objChangeCddcCd.getOffsetWidth();
		
		objChangeCddcCd.move(nWidth-20,objChangeCddcCd.getOffsetTop());
		
		nWidth += nSelectCddcWidth;
	}	
	
	this.divDispArea.form.divSelectCddc.setOffsetWidth(nWidth);
	this.divDispArea.form.divSelectCddc.form.resetScroll();	
	
	this.parent.parent.divNotice.form.fnSetCddcInfo2(sSelCddcNm);
	
	// 메인화면인 경우, 교육청정보를 재설정한다.
	var objMainForm = this.parent.parent;
	var objWorkForm = objMainForm.divAll.form.divWork.form;
	
	if(objWorkForm.fnRefreshCddcInfo)
	{
		objWorkForm.fnRefreshCddcInfo.call(objWorkForm);
	}
		
	
	// 메인화면을 설정한다.
	if(objMainForm.fnSetMain)
	{
		objMainForm.fnSetMain.call(objMainForm);
	}
	
// 	// MainForm의 사이즈를 조정한다.
// 	if(objMainForm.fnResizeProc)
// 	{
// 		objMainForm.fnResizeProc.call(objMainForm,objMainForm);
// 	}	
	
	this.fnRedrawTopMenu();

}

this.fnGetPrivateProfile = function (sProfileName)
{
	var sCddcCd      = "";
	var sCddcNm      = "";
	var sSelSubSysCd = "";
	var sUrl         = "";
	
	// 프로파일로부터 값을 가져온다.
	var sProfile = nexacro.getPrivateProfile(sProfileName);
	
	// 
	if(!this.smfIsNull(sProfile))
	{
		var sCurUrl ="";
		
		if(system.navigatorname.indexOf("nexacro")>-1)
		{  // 전용브라우저
			sCurUrl = nexacro.getApplication().xadl;
		}
		else
		{
			sCurUrl = window.location.href;			
		}
		
		var oProfileJson = JSON.parse(sProfile);
		var aProfiles = oProfileJson.profile;
		
		for(var i=0;i<aProfiles.length;i++)
		{
			var aProfile = aProfiles[i];
			
			if(aProfile.url == sCurUrl)
			{
				sCddcCd      = aProfile.cddcCd;
				sCddcNm      = aProfile.cddcNm;
				sSelSubSysCd = aProfile.selSubSysCd;
				sUrl         = aProfile.url;
				
				break;
			}
		}
	}
	
	var oProfileInfo = {cddcCd:sCddcCd,cddcNm:sCddcNm,selSubSysCd:sSelSubSysCd,url:sUrl};
	
	return oProfileInfo;
}

this.fnSetPrivateProfile = function (sProfileName,sSelSubSysCd,sCddcCd,sCddcNm)
{
	// 프로파일로부터 값을 가져온다.
	var sProfile = nexacro.getPrivateProfile(sProfileName);
	var sProfileData = "";
	
	var sCurUrl ="";
	
	if(system.navigatorname.indexOf("nexacro")>-1)
	{  // 전용브라우저
		sCurUrl = nexacro.getApplication().xadl;
	}
	else
	{
		sCurUrl = window.location.href;			
	}	
	// 
	var bHit = false;
	if(!this.smfIsNull(sProfile))
	{
		var oProfileJson = JSON.parse(sProfile);
		var aProfiles = oProfileJson.profile;
		
		for(var i=0;i<aProfiles.length;i++)
		{
			var aProfile = aProfiles[i];
			
			if(aProfile.url == sCurUrl)
			{
				aProfile.cddcCd       = sCddcCd     ;
				aProfile.cddcNm       = sCddcNm     ;
				aProfile.selSubSysCd  = sSelSubSysCd;
				
				bHit = true;
				break;
			}
		}
		
		if(bHit)
		{
			oProfileJson.profile.push({cddcCd:sCddcCd,cddcNm:sCddcNm,selSubSysCd:sSelSubSysCd,url:sCurUrl})
		}
		
		sProfileData = JSON.stringify(oProfileJson);
		
	}
	else
	{
		var oProfileJsonNew = {profile:[]};
		
		oProfileJsonNew.profile.push({cddcCd:sCddcCd,cddcNm:sCddcNm,selSubSysCd:sSelSubSysCd,url:sCurUrl})
		sProfileData = JSON.stringify(oProfileJsonNew);
	}
	
	nexacro.setPrivateProfile(sProfileName,sProfileData);
}


// 각 업무별 특정 작업영역을 표시 비표시한다.
this.fnShowTopDiv = function(bShow,sSubSysGb)
{
	var sSubSystemGb = sSubSysGb;	
	if(this.smfIsNull(sSubSysGb)) 
	{
		sSubSystemGb = this.smfGetSubSystemGb();
	}
	
	// [업무지원]용
	if(  (sSubSystemGb=="AFS")   // 업무지원(외부강사)
	  || (sSubSystemGb=="ECC")   // 업무지원(돌봄인력서비스)
	  || (sSubSystemGb=="IBM")   // 업무지원(교과용도서)
	  || (sSubSystemGb=="SEM")   // 업무지원(학교환경관리)
	  || (sSubSystemGb=="PHE")   // 업무지원(체육)
	  || (sSubSystemGb=="SML")   // 업무지원(급식)
	  || (sSubSystemGb=="SPR")   // 업무지원(교육복지)
	  )
	{
		this.divDispArea.form.divAFSLink.set_visible(bShow);
	}
	else if(sSubSystemGb=="SQA") // 검정고시
	{
		this.divDispArea.form.divSQALink.set_visible(bShow);
	}
	else if(sSubSystemGb=="HES") // 학원민원
	{
		this.divDispArea.form.divHESLink.set_visible(bShow);
	}
}
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/**
@class fnRedrawTopMenu
@description topmenu를 dsMenu로 copy
@param N/A
@return N/A
*/ 
this.fnRedrawTopMenu = function ()
{
	if(this.smfIsMobile())
	{
		return;
	}
//return;	
	// 대분류만추출
	this.dsMenu.filter("lvl==0&&isShow!='N'");
	
	// 기존에 TopMenu가 있으면 삭제한다.
	this.fnDestroyTopMenu();
	
	// 메뉴를 재생성
	this.fnSetTopMenu();
	
	// 필터를 해제
	this.dsMenu.filter("");
	
};

/**
@class fnSetTopMenu
@description topmenu세팅
@param N/A
@return N/A
*/ 
this.fnDestroyTopMenu = function ()
{
	var oComps = this.divDispArea.form.divTopBtn.form.components;
	
	for (var i = oComps.length-1; i >=0; i--) 
	{
		var oComp = oComps[i];
		this.divDispArea.form.divTopBtn.removeChild(oComp.id);
		oComp.destroy();
	}	
	
	this.fvLastLeft = 0;
};

/**
@class fnSetTopMenu
@description topmenu세팅
@param N/A
@return N/A
*/ 
this.fnSetTopMenu = function ()
{
	var btnObj;
	var sSubSys = this.smfGetSubSystemGb();
	var nGapBtn = (sSubSys=="PAR")?74:24;
	var nHeight = (sSubSys=="PAR")?40:40;
	for (var i = 0; i < this.dsMenu.getRowCount(); i++) 
	{
		var strID   = this.dsMenu.getColumn(i, this.objApp.gv_menuColumns.menuId );  // 메뉴아이디
		//var strName = this.dsMenu.getColumn(i, this.objApp.gv_menuColumns.menuNm );  // 메뉴명
		var strName = this.dsMenu.getColumn(i, "menuName" );  // 메뉴명
		var strUrl = this.dsMenu.getColumn(i, this.objApp.gv_menuColumns.pageUrl);  // 메뉴URL
		this.fnCreateTopMenu(strID, strName, strUrl, i,nGapBtn,nHeight);
	}
};

/**
@class fnCreateTopMenu
@description Top menu creation
@param  필수 {String} strID - 버튼아이디
		필수 {String} strName - 버튼 text
		필수 {String} strUrl - 버튼 Url(없는 경우는 "")
		필수 {Number} index - 버튼 순번		
@return N/A
*/
this.fnCreateTopMenu = function (strID, strName, strUrl, index,nGapBtn,nHeight)
{
	// Creating page button
	var strFont = 'normal 700 18px/normal "NotoSansKR-Regular,Malgun Gothic,Arial,MS PGothic"'; // this.btn03._getCurrentStyleInheritValue("font").value;
	var nWidth = nexacro.getTextSize( strName, strFont).nx + nGapBtn;  // 40: padding
	
	
	var objBtn = new Button();
	objBtn.init(this.fv_TopBtnPrefix + strID, this.fvLastLeft, 0, nWidth, nHeight);
	this.fvLastLeft += nWidth;
	
	this.divDispArea.form.divTopBtn.addChild(objBtn.name, objBtn);
	objBtn.set_text(strName);
	objBtn.set_cssclass("btn_TF_Menu");
	objBtn.menuid = strID;
	//objBtn.set_cssclass("TF_menu");

	objBtn.setEventHandler("onclick", this.Button_onclick, this);
	objBtn.setEventHandler("onmouseenter", this.btn_onmouseenter, this);
	//@KBR PC웹접근성 키보드로 접근하기 위함
	objBtn.setEventHandler("onsetfocus", this.Button_onsetfocus, this);	
	objBtn.set_visible(true);
	
	//@KBR 서브메뉴가 있는 메뉴에 접근성설명 추가
	var nRow = this.dsMenu.findRowNF("parentMenuId", strID);
	if(nRow > -1) objBtn.set_accessibilityaction("알트+아래쪽 방향키를 이용해 하위 메뉴 목록으로 이동합니다. 알트+상하 방향키를 이용해 하위 메뉴를 확인합니다. 엔터 키를 이용하여 메뉴를 선택합니다. ESC키를 눌러 하위 메뉴 목록을 닫습니다.");

	objBtn.show();
	
	objBtn._pageUrl = strUrl;
	
};

// 교육청선택팝업을 표시한다.
// callback함수 : this.fnPopupCallback
this.fnCddcPopup = function()
{
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: this.fnPopupCallback, // 콜백함수 지정
		sender: obj, // sender 지정
		popuptype : "modalsync",

		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: "insert"
		},
		
		//@KBR  타이틀바를 표시하지 않음
		titlebar:false
	};

	// 모달팝업 실행
	var nLeft = 0;
	var nTop = 0;
	var nWidth = this.getOffsetWidth();
	var nHeight = this.parent.parent.divAll.getOffsetBottom();
	//nLeft, nTop, nWidth, nHeight
	this.smfDialog("_auto", "comm::comm_cddcList.xfdl", popupParams , nLeft, nTop, nWidth, nHeight);	
	
}

// 로고이미지에 시스템타이틀을 표시한다.
this.fnDisplaySubSysTitle = function(sSubSysCd)
{
	var objSubSystemName = {
	                         "PAS" : "대국민포털"
	                     ,   "SQA" : "검정고시"
	                     ,   "ORE" : "온라인 교직원 채용"  // 교원채용 
	                     ,   "HRD" : "온라인 교직원 채용"  // 계약제교원인력풀
	                     ,   "HES" : "학원서비스"
	                     ,   "BDM" : "비영리법인"
	                     ,   "PAR" : "학부모서비스"
	                     ,   "UDS" : "대입전형자료수신"     // 일반대입전형
	                     ,   "EDS" : "학생·학부모 참여 교육설문"
	                     ,   "AFS" : "업무지원"    // 방과후학교 
	                     ,   "ECC" : "업무지원"    // 초등돌봄교실 
	                     ,   "IBM" : "업무지원"    // 교과용도서 
	                     ,   "SEM" : "업무지원"    // 학교환경관리 
	                     ,   "PHE" : "업무지원"    // 체육 
	                     ,   "SML" : "업무지원"    // 급식 	
	                     ,   "SPR" : "업무지원"    // 교육복지 
	                     ,   "EWS" : "교육비 원클릭 신청시스템"    // 교육비 원클릭
						 ,   "UDA" : "대학지원용 학교생활기록부 신청 서비스"    // 대입전형자료온라인생성신청-대입전형자료(학교생활기록부)
	                     };
	var sSubSystemName = objSubSystemName[sSubSysCd];
	this.divDispArea.form.staLogo.set_text(sSubSystemName+" ");	
	
	if(sSubSysCd=="PAR") // 유치원인 경우
	{
		if(this.smfIsMobile())
		{
			this.divDispArea.form.staLogo.set_cssclass("sta_TF_NeisKinder_M");
		}
		else
		{
			this.divDispArea.form.staLogo.set_cssclass("sta_TF_NeisKinder");
		}
	} else if(sSubSysCd=="UDA"){
		if(this.smfIsMobile())
		{
			this.divDispArea.form.staLogo.set_top(13);
			this.divDispArea.form.staLogo.set_height(77);
			this.divDispArea.form.staLogo.set_text("대학지원용\n학교생활기록부 신청 서비스"+" ");
		}
	}
	
	//@KBR  mainframe titletext 변경
	nexacro.getApplication().mainframe.set_titletext(sSubSystemName);
	nexacro.getApplication().gv_appTtiletext = sSubSystemName;
	
	//@KBR resetScroll
	this.divDispArea.form.resetScroll();
}


// 서브시스템별로 콤포넌트 구성을 다시 한다.(업무지원/교육설문/온라인채용 위주)
this.fnRearrageTopComp = function(sSubSystemGb,sType,objOption)
{
	// history를 위해 상태를 저장
	this.fnSetHistoryInfo(sSubSystemGb,sType,objOption);


	if(  (sSubSystemGb=="AFS")   // 업무지원(외부강사)
	  || (sSubSystemGb=="ECC")   // 업무지원(돌봄인력서비스)
	  || (sSubSystemGb=="IBM")   // 업무지원(교과용도서)
	  || (sSubSystemGb=="SEM")   // 업무지원(학교환경관리)
	  || (sSubSystemGb=="PHE")   // 업무지원(체육)
	  || (sSubSystemGb=="SML")   // 업무지원(급식)
	  || (sSubSystemGb=="SPR")   // 업무지원(교육복지)
	  
	  || (sSubSystemGb=="ORE")   // 온라인채용(교원채용)
	  || (sSubSystemGb=="HRD")   // 온라인채용(계약제교원인력풀)
	  )
	{//Collapse Expand 
		if(sType=="collapse")
		{
			if(this.smfIsMobile())
			{
				// Top의 높이를 조정
				this.parent.setOffsetHeight(96);				
				this.resetScroll();
				this.parent.parent.resetScroll();
				
				//@KBR 필요없는 것 비표시.
				this.divDispArea.form.btnSitemap.set_visible(false);
				
				// 로고cssclass변경
				if(  (sSubSystemGb=="ORE")   // 온라인채용(교원채용)
				  || (sSubSystemGb=="HRD")   // 온라인채용(계약제교원인력풀)
				)
				{
					this.divDispArea.form.staLogo.set_cssclass("sta_WF_Txt30");
					
					// 로고에 서브시스템명칭을 표시한다.(없으면 표시안함)
					this.fnDisplaySubSysTitle(sSubSystemGb);
				}
				else
				{
					this.divDispArea.form.staLogo.set_cssclass("sta_WF_Txt30");
					// 로고에 서브시스템명칭을 표시한다.(없으면 표시안함)
					this.fnDisplaySubSysTitle(sSubSystemGb);
				}				
				
			}
			else
			{
				// Top의 높이를 조정
				this.parent.setOffsetHeight(44);			
				this.resetScroll();
				this.parent.parent.resetScroll();
				
				// 필요없는 것 비표시
				this.divDispArea.form.staSubTitle.set_visible(false);
				this.divDispArea.form.divSQALink.set_visible(false);
				this.divDispArea.form.btnLogin.set_visible(false);
				this.divDispArea.form.btnSitemap.set_visible(false);
				this.divDispArea.form.divTopBtn.set_visible(false);
				this.divDispArea.form.divSelectCddc.set_visible(false);
				this.divDispArea.form.btnChangeCddcCd.set_visible(false);
				
				// 로고cssclass변경
				if(  (sSubSystemGb=="ORE")   // 온라인채용(교원채용)
				  || (sSubSystemGb=="HRD")   // 온라인채용(계약제교원인력풀)
				)
				{
					this.divDispArea.form.staLogo.set_cssclass("sta_TF_Neis");
					
					// 로고에 서브시스템명칭을 표시한다.(없으면 표시안함)
					this.fnDisplaySubSysTitle(sSubSystemGb);
				}
				else
				{
					this.divDispArea.form.staLogo.set_cssclass("sta_TF_Neis");
					// 로고에 서브시스템명칭을 표시한다.(없으면 표시안함)
					this.fnDisplaySubSysTitle(sSubSystemGb);
				}
			}
		}
		else
		{
			if(this.smfIsMobile())
			{
				// Top의 높이를 조정
				this.parent.setOffsetHeight(96);	
				
				//@KBR 
				this.divDispArea.form.btnSitemap.set_visible(true);
			
			}
			else
			{
				// Top의 높이를 조정
				this.parent.setOffsetHeight(120);			
				this.resetScroll();
				this.parent.parent.resetScroll();
				
				// 필요없는 것 비표시
				this.divDispArea.form.staSubTitle.set_visible(true);
				this.divDispArea.form.divSQALink.set_visible(false);
				this.divDispArea.form.btnLogin.set_visible(true);
				this.divDispArea.form.btnSitemap.set_visible(true);
				this.divDispArea.form.divTopBtn.set_visible(true);
				this.divDispArea.form.divSelectCddc.set_visible(true);
				this.divDispArea.form.btnChangeCddcCd.set_visible(true);
				
				this.fvSubSysGb = sSubSystemGb;
				
				// 로고cssclass변경
				if(  (sSubSystemGb=="ORE")   // 온라인채용(교원채용)
				  || (sSubSystemGb=="HRD")   // 온라인채용(계약제교원인력풀)
				)
				{
					this.divDispArea.form.staLogo.set_cssclass("sta_TF_Neis");
					
					// 로고에 서브시스템명칭을 표시한다.(없으면 표시안함)
					this.fnDisplaySubSysTitle(this.fvSubSysGb);
					
					// 서브로고타이틀을 세팅한다.
					this.fnSetSubLogoTitle(objOption.appoExamScNm);
				}
				else
				{
					this.divDispArea.form.staLogo.set_cssclass("sta_TF_Neis");
					
					// 로고에 서브시스템명칭을 표시한다.(없으면 표시안함)
					this.fnDisplaySubSysTitle(this.fvSubSysGb);
				}
				
				
				// 로고에 서브시스템명칭을 표시한다.(없으면 표시안함)
				var sCddcCode = this.smfGetCddcCode();
				var sCddcCssClass = this.fnGetCddcCssClass(sCddcCode);
				var sfnGetCddcNm = this.smfGetCddcName(sCddcCode);
				this.divDispArea.form.divSelectCddc.form.staCddcLogo.set_cssclass(sCddcCssClass);
				this.divDispArea.form.divSelectCddc.form.staCddcLogo.set_text(sfnGetCddcNm);
				//@KBR text변경 후 width설정(staCddLogo + 새로고침 버튼), resetscroll 
				this.divDispArea.form.divSelectCddc.form.resetScroll();
				var nWidth = this.divDispArea.form.divSelectCddc.form.staCddcLogo.getOffsetWidth() + 33;
				
				// 모바일일 경우(학원민원)
				if(this.smfIsMobile())
				{
					var objChangeCddcCd = this.divDispArea.form.divSelectCddc.form.btnChangeCddcCd
					var nSelectCddcWidth = objChangeCddcCd.getOffsetWidth();
					
					objChangeCddcCd.move(nWidth-20,objChangeCddcCd.getOffsetTop());
					
					nWidth += nSelectCddcWidth;
				}
				this.divDispArea.form.divSelectCddc.setOffsetWidth(nWidth);
				this.divDispArea.form.divSelectCddc.form.resetScroll();
				
			
				// 메뉴데이터셋을 세팅한다.
				if(sSubSystemGb=="ORE")   // 온라인채용(교원채용)
				{
					var sSelBtnCd = this.smfGetAppoExamScCd();
					this.dsMenu.copyData(this.divMenu.form["dsMenu_"+this.fvSubSysGb.toLowerCase()+"_"+sSelBtnCd]);
				}
				else
				{
					this.dsMenu.copyData(this.divMenu.form["dsMenu_"+this.fvSubSysGb.toLowerCase()]);
				}
				
				//@KBR  head에 menuCopy
				this.dsMenu.appendData(this.dsMenuBottom);
				this.parent.parent.divAll.form.divHead.form.dsMenu.copyData(this.dsMenu);	
				
				// TOP화면에 메뉴를 표시한다.
				this.fnRedrawTopMenu();			
			}
		}
	}
	//else if(sSubSystemGb=="SQA")   // 온라인채용(교원채용)
	//{
	//	
	//}
	
	this.divDispArea.form.resetScroll();
	this.resetScroll();
}


// 서브로고타이틀을 세팅한다.
this.fnSetSubLogoTitle = function(sTitle)
{	
	
	if(this.smfIsNull(sTitle))
	{
		this.divDispArea.form.staSubTitle.set_text("");
		this.divDispArea.form.staSubTitle.set_visible(false);
	}
	else
	{
		this.divDispArea.form.staSubTitle.set_text(sTitle+" ");
		this.divDispArea.form.staSubTitle.set_visible(true);
	}
}

this.fnGetFormLogInfo = function(sMenuId,sUrl)
{
	//this.objApp.gv_menuColumns.menuId
	var objResult = {menu0:"",menu1:"",menu2:"",pafrSysClfCd:"",pafrSysSubCd:"",url:sUrl};
	var arrMenuId = [];
	
	// 메뉴아이디를 구한다
	// 레벨이 0일 때까지 찾음
	while(!this.smfIsNull(sMenuId))
	{
		var nFindRow = this.dsMenu.findRowNF("menuId",sMenuId); 
		
		if(nFindRow>-1)
		{
			var sLvl          = this.dsMenu.getColumnNF(nFindRow,"lvl"         );
			var sMenuId       = this.dsMenu.getColumnNF(nFindRow,"menuId"      );
			var sParentMenuId = this.dsMenu.getColumnNF(nFindRow,"parentMenuId");
			
			objResult["menu"+sLvl] = sMenuId;
			if(sLvl=="0")
			{
				break;
			}
			
			sMenuId = sParentMenuId;
			
		}
		else
		{
			break;
		}
	}
	
	// 레벨을 찾음.
	if(!this.smfIsNull(sUrl))
	{
		var arrUrl = sUrl.split("::");
		var sAppGroup = arrUrl[0];
		
		var arrAppGroup = sAppGroup.split("_");
		
		var sPafrSysClfCd = "";
		var sPafrSysSubCd = "";
		if(arrAppGroup.length==4) // 일반적인 형태(대국민)
		{
			sPafrSysClfCd = arrAppGroup[1];
			sPafrSysSubCd = arrAppGroup[2];
		
			objResult.pafrSysClfCd = sPafrSysClfCd.toUpperCase();
			objResult.pafrSysSubCd = sPafrSysSubCd.toUpperCase();
		}
		else if(arrAppGroup.length==4) // 일반적인 형태(디지털원패스)
		{
			sPafrSysClfCd = arrAppGroup[0];
			sPafrSysSubCd = arrAppGroup[1];
			
			objResult.pafrSysClfCd = sPafrSysClfCd.toUpperCase();
			objResult.pafrSysSubCd = sPafrSysSubCd.toUpperCase();
		}
	}
	return objResult;
}

this.fnGetLoginUrl = function()
{
	var sSubSys = this.smfGetSubSystemGb();
	var sSubSysDetail = this.smfGetSubSystemDetailGb();
	
	// 대입전형(검정고시)는 대입전형(일반)으로 처리
	if((sSubSys=="SQA")&&(sSubSysDetail=="103"))
	{
		sSubSys = "UDS";
	}
	else if( (sSubSys  == "ORE" || sSubSys  == "HRD")
	        && (nexacro.getProjectPath().indexOf("localhost")  > -1 
			|| (nexacro.getProjectPath().indexOf("10.200.127.167")  > -1 )
			|| nexacro.getProjectPath().indexOf("dev.edurecruit.go.kr/") > -1)
    )
	{
		sSubSys = "ORE_DEV";
	}
	else if( sSubSys  == "HES"
	        && (nexacro.getProjectPath().indexOf("localhost")  > -1 
			|| (nexacro.getProjectPath().indexOf("10.200.127.167")  > -1 )
			|| nexacro.getProjectPath().indexOf("dev.hakwon.neis.go.kr/") > -1)
    )
	{
		sSubSys = "HES_DEV";
	}	
	var sUrl = this.dsLoginUrl.lookup("subsys",sSubSys,"url") || "";

	return sUrl;
}


//@KBR  frameMain setWorkpage()함수에서 조절하고 있음. 추후 삭제 예정.
//메인 모드에서 메뉴 조회 모드로 전환하는 작업(화면 넓이 조절)
this.fnChangeDiv = function()
{
//return false;
	var ndivAllWTop        = 100;
	var ndivHeadWLeft      = 360;
	var ndivHeadWWidth     = 1200;	
	var ndivWorkWLeft      = 360;
	var ndivWorkWWidth     = 1200;
	var ndivTopWRight      = 0;
	
		nexacro.getApplication().mainframe.VFrameSet.frameMain.form.divAll.form.vscrollbar.set_pos(0);	
		//this.getOwnerFrame().form.divTop.form.fnTopMode("W");
		
		//메인 모드에서 메뉴 조회 모드로 전환.
		if ( this.smfIsMobile() ) {
			this.getOwnerFrame().form.divAll.setOffsetTop(0);
			this.getOwnerFrame().form.divAll.form.divHead.setOffsetLeft(0);
			this.getOwnerFrame().form.divAll.form.divWork.setOffsetLeft(0);
			this.getOwnerFrame().form.divTop.set_right(ndivTopWRight);		
		}else {
			var nLeft,nWidth;
			var nMaxWidth = 1200;
			var nAllWidth = this.width;	// 전체 form의 사이즈

			// 중앙정렬을 위해 divAll에 스크롤 사이즈만큼 빼준다.
			//nAllWidth = nAllWidth - this._getHScrollBarSize();

			if(nAllWidth >= nMaxWidth)	//1280 사용
			{
				nLeft = parseInt((nAllWidth - nMaxWidth) / 2);
				if(nLeft < 0) nLeft = 40;
				
				nWidth = nMaxWidth;	
			}else
			{
				nLeft = 40;
				nWidth = nAllWidth;
			}

			//this.getOwnerFrame().form.divAll.setOffsetTop(ndivAllWTop);
			this.getOwnerFrame().form.divAll.form.divHead.setOffsetLeft(nLeft);	//ndivHeadWLeft
			this.getOwnerFrame().form.divAll.form.divHead.setOffsetWidth(ndivHeadWWidth);
			this.getOwnerFrame().form.divAll.form.divWork.setOffsetLeft(nLeft);	//ndivWorkWLeft
			this.getOwnerFrame().form.divAll.form.divWork.setOffsetWidth(nWidth);//ndivWorkWWidth
			this.getOwnerFrame().form.divTop.set_right(ndivTopWRight);
		}
}

/**
* 로그인 버튼 색상 변경
*/
this.fnSetLoginColor = function(sSubSystemGb)
{
	var objBtn = this.divDispArea.form.btnLogin;
	var sColor = "";
	
	switch(sSubSystemGb) {
		case "HES" : //학원민원
				sColor = "#2a65f2";
				break;
		case "BDM" : //비영리법인
				sColor = "#2a65f2";
				this.divDispArea.form.staRemainingTime.set_cssclass("sta_TF_Session02");
				break;
		case "ORE": //교직원채용
		case "HRD": //교직원채용
				sColor = "#038667";
				break;
		case "SQA": //검정고시
				sColor = "#7e4cfc";
				objBtn.set_cssclass("btn_TF_Login02");
				this.divDispArea.form.staRemainingTime.set_cssclass("sta_TF_Session01");
				break;
		case "UDA": //대입전형자료온라인생성신청-대입전형자료(학교생활기록부)
				sColor = "#7e4cfc";
				objBtn.set_cssclass("btn_TF_Login02");
				this.divDispArea.form.staRemainingTime.set_cssclass("sta_TF_Session01");
				this.divDispArea.form.staRemainingTime.set_color("#7e4cfc");
				break;
		case "UDS": //대입전형
				sColor = "#7e4cfc";
				objBtn.set_cssclass("btn_TF_Login02");
				break;
		case "PAR": //유치원
				sColor = "#111111";
				objBtn.set_cssclass("btn_TF_Login03");
				break;
		default : break;
	}
	objBtn.set_background(sColor);
	
}


//frameMain - divAll 가로스크롤의 위치와 동일하게 이동하게 함
this.fnTopMenuOnhscroll = function(nPos)
{
	this.hscrollbar.set_pos(nPos);
}; 

this.fnChangeMenu = function()
{
	var sSubSys       = this.smfGetSubSystemGb();
	var sDetailSubSys = this.smfGetSubSystemDetailGb();
	var sMenuDsId = "";
	if(sSubSys=="EWS")
	{
		// 일반 고객용 메뉴를 세팅
		sMenuDsId = "dsMenu_" + sSubSys.toLowerCase();
		this.dsMenu.copyData(this.divMenu.form[sMenuDsId]);
		
		// 관리자용 메뉴를 세팅
		if(!this.smfIsNull(sDetailSubSys))
		{
			sMenuDsId = "dsMenu_" + sSubSys.toLowerCase() + "_" + this.lpad(sDetailSubSys,"0",3);
			this.dsMenu.appendData(this.divMenu.form[sMenuDsId]);
		}
	}
	//JSF 20240705 for 관리자모드 [[
	if(sSubSys=="ORE")
	{
		// 일반 고객용 메뉴를 세팅
		var sSelBtnCd = this.smfGetAppoExamScCd();//JSF_20240625
		this.dsMenu.copyData(this.divMenu.form["dsMenu_"+sSubSys.toLowerCase()+"_"+sSelBtnCd]);
		
		// 관리자용 메뉴를 세팅
		if(this.smfGetSessionValue('userScCd') == "07" || this.smfGetSessionValue('userScCd') == "06")
		{
			sMenuDsId = "dsMenu_"+sSubSys.toLowerCase()+"_"+sSelBtnCd+"99";
			this.dsMenu.appendData(this.divMenu.form[sMenuDsId]);
		}
	}	
	//JSF 20240705 for 관리자모드 ]]
	else
	{
		sMenuDsId = "dsMenu_" + sSubSys + (this.smfIsNull(sDetailSubSys)?"":("_"+this.lpad(sDetailSubSys,"0",3)));
		
		// 모바일 메뉴를 가진 것들은 "_m"을 붙여준다(업무지원/학원민원 등)
		sMenuDsId += this.fv_MenuPostfixMobile;
		
		this.dsMenu.copyData(this.divMenu.form[sMenuDsId]);
	}
	
	this.fnRedrawTopMenu();
}

this.fnSetCddcSelCssclass = function()
{
	var sCssClass = "";
	var sSubSysGb = this.smfGetSubSystemGb();
	
	if(sSubSysGb=="SQA")  // 검정고시
	{
		sCssClass = "btn_TF_SelectPurple";
	}
	else if(sSubSysGb=="UDA") // 대입전형자료온라인생성신청-대입전형자료(학교생활기록부)
	{
		sCssClass = "btn_TF_SelectPurple";  
	}
	else if(  (sSubSysGb=="ORE")   // 온라인채용(교원채용)
	       || (sSubSysGb=="HRD")   // 온라인채용(계약제교원인력풀)
		   )
	{
		sCssClass = "btn_TF_SelectGreen";  
	}
	else
	{
		sCssClass = "btn_TF_SelectBlue";
	}
	
	this.divDispArea.form.btnChangeCddcCd.set_cssclass(sCssClass);
	
}

// history를 위해 상태를 저장
this.fnSetHistoryInfo = function (sSubSystemGb,sType,objOption)
{
	this.fvHistoryInfo_type = sType;
	this.fvHistoryInfo_objOption = objOption;
}
