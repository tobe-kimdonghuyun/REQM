		oFrameMainForm.dsScrLgnSrch.setColumn(0, 'provider', 'kakao'); // 
		oFrameMainForm.dsScrLgnSrch.setColumn(0, 'ci', '7Fg1L214LzQB/OuQn/IgOrDIo4ilohmiUW5ronv0/OKJYH+gmR7Hu0WVGO6iopLpTteINnZzw+Qv15IIeXU5pA=='); //
		oFrameMainForm.dsScrLgnSrch.setColumn(0, 'userDtcNo', 'CSPP20240000149119'); //
		
