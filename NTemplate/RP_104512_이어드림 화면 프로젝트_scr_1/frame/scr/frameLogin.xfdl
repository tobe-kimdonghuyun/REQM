		break;
	default: this.close(); break;
	}

};

/* 입력로그인 클릭 */
this.btnLgn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	trace("=============================================================================================================");
	trace("::: this.edtLgn.value ::: "  + this.edtLgn.value );
	trace("=============================================================================================================");

	var oFrameMainForm = this.objApp.mainframe.VFrameSet.frameMain.form;
	oFrameMainForm.dsScrLgnSrch.setColumn(0, 'provider', 'kakao'); 
	oFrameMainForm.dsScrLgnSrch.setColumn(0, 'ci', this.edtLgn.value);
		
	oFrameMainForm.doScrLgn("LG005"); //간편인증

	this.close();
};
]]></Script>
  </Form>
</FDL>
