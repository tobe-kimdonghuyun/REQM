        <Button id="btnLogo02" taborder="14" width="165" height="50" right="1001" accessibilitylabel="17개 시도 교육청 바로가기" initvalueid="iv_Button" top="76" enable="true" cssclass="btn_BF_Logo02" accessibilityrole="none" color="black"/>
        <Button id="btnLogo03" taborder="15" width="116" height="50" right="864" accessibilitylabel="한국교육학술정보원 바로가기" cssclass="btn_BF_Logo03" initvalueid="iv_Button" top="76" text="" onclick="btnLogo03_onclick"/>
