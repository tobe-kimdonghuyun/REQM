    <Script type="xscript5.1"><![CDATA[/**
*  학부모소통시스템
*  @MenuPath    공통
*  @FileName 	frameBottom.xfdl
*  @Creator 	tobesoft
*  @CreateDate 	2025.03.17
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2025.03.17     	tobesoft 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::scr_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	//trace("Frame Bottom onload >>>>>>>");
};

//Form의 onlayoutchanged이벤트
this.form_onlayoutchanged = function(obj,e)
{
	obj.setTimer(900, 55);
};

//MLM 레이아웃 변경후 설정
this.fnAfter_onlayoutchanged = function(sLayoutId)
{
	this.getOwnerFrame().form.divAll.form.resetScroll();
};

//Form의 ontimer이벤트
this.form_ontimer = function(obj,e)
{
	if ( e.timerid == 900 ) {
		obj.killTimer(e.timerid);
		this.fnAfter_onlayoutchanged(this.getCurrentLayoutID());
	}
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
//관련사이트 실행
this.fnSiteMenuClick = function(sSelUrl)
{
	this.pdvSite.closePopup();
	
	var nSelRow = this.dsSite.rowposition;
	var sSelUrl = this.dsSite.getColumn(nSelRow, "siteUrl");
	
	system.execBrowser(sSelUrl);
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.divPolicy_btn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	switch(obj.id) {
	case "btnIndvInfo":
		var sUrl   = "frame::commom/framePolicyScr01.xfdl";
		var params = {menu : "B001",_url:sUrl};
		this.smfSetWorkPage(sUrl, params, null, obj.text);	
		
		break;
	case "btnLicense":
		var sUrl   = "frame::commom/framePolicyScr02.xfdl";
		var params = {menu : "B003",_url:sUrl};
		this.smfSetWorkPage(sUrl, params, null, obj.text);	
			
		break;
	case "btnAccessBility":
		var sUrl   = "frame::commom/framePolicyScr03.xfdl";
		var params = {menu : "B004",_url:sUrl};
		this.smfSetWorkPage(sUrl, params, null, obj.text);	
			
		break;
	case "btnUse":
		var sUrl   = "frame::commom/framePolicyScr04.xfdl";
		var params = {menu : "B002",_url:sUrl};
		this.smfSetWorkPage(sUrl, params, null, obj.text);	
			
		break;
	default:
	}
};

/* 교육부 링크 */
this.btnLogo01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sUrl = "https://www.moe.go.kr";
	system.execBrowser(sUrl);	
};


/* keris 링크 */
this.btnLogo03_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sUrl = "https://www.keris.or.kr";		
	system.execBrowser(sUrl);	
};




//관련사이트 버튼 클릭시
this.btnSite_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (this.divSite.visible) return;
	
	obj.set_accessibilitylabel("열림");
	
	var mainForm = nexacro.getApplication().mainframe.VFrameSet.frameMain.form;
	mainForm.divAll.form.divBottom.setOffsetTop("");
	mainForm.divAll.form.divBottom.setOffsetBottom(0);
	mainForm.divAll.form.divBottom.setOffsetHeight(441);
	mainForm.divAll.form.divBottom.setOffsetTop("divWork:-32");	
	mainForm.resetScroll();	

	this.fnAdjustCompOffset(122);
	
	this.divSite.set_visible(true);
};

this.fnCloseDivSite = function()
{
	this.divSite.set_visible(false);
	this.btnSite.set_accessibilitylabel("닫힘");
	
	var mainForm = nexacro.getApplication().mainframe.VFrameSet.frameMain.form;
	mainForm.divAll.form.divBottom.setOffsetTop("divWork:90");
	mainForm.divAll.form.divBottom.setOffsetHeight(mainForm.divAll.form.divBottom.getOffsetHeight() - 122);
	mainForm.resetScroll();	

	this.fnAdjustCompOffset(-122);
}

this.fnAdjustCompOffset = function(nHeight)
{
	var comps = this.components;
	for (var i = 0; i < comps.length; i++) {
		if (comps[i].id == "divSite") continue;
		comps[i].setOffsetTop(comps[i].getOffsetTop() + nHeight);
	}
}

this.divSite_grdSite_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	this.fnCloseDivSite();
	
	var nRow = this.dsSite.rowposition;
	system.execBrowser(this.dsSite.getColumn(nRow, "siteUrl"));	
};

this.divSite_grdSite_onkeydown = function(obj:nexacro.Grid,e:nexacro.KeyEventInfo)
{
	//ESC누름
	if(e.keycode == 27)
	{
		this.fnCloseDivSite();
	}	
};

this.divSite_onkillfocus = function(obj:nexacro.Div,e:nexacro.KillFocusEventInfo)
{
	this.fnCloseDivSite();
};

this.divSite_onmouseleave = function(obj:nexacro.Div,e:nexacro.MouseEventInfo)
{
	var bFlag = this.fnFindChildComponent(obj, e.fromreferenceobject);
	if(bFlag) {
		e.preventDefault();
		return true;
	}
	
	this.fnCloseDivSite();
};

this.fnFindChildComponent = function(oDiv, objTarget)
{
	if (!oDiv) return false;
	
	//자기 자신이면 true
	if (oDiv === objTarget) return oDiv;

	var comps = oDiv.form.components;
	for(var i = 0; i < comps.length; i++) {
		var comp = comps[i]
		
		if(comp instanceof Div) {
			//Div안의 Div체크
			var child = this.fnFindChildComponent(comps[i], objTarget);
			if (child) return child;
		} else {
			if(comp === objTarget) {
				return comp;
			}
		}
	}
	return false;
};]]></Script>
    <Objects>
      <Dataset id="dsSite">
        <ColumnInfo>
          <Column id="siteNm" type="STRING" size="256" description="사이트명"/>
          <Column id="siteUrl" type="STRING" size="256" description="사이트URL"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="siteUrl">https://www.moe.go.kr</Col>
            <Col id="siteNm">교육부</Col>
          </Row>
          <Row>
            <Col id="siteNm">학교알리미</Col>
            <Col id="siteUrl">https://www.schoolinfo.go.kr</Col>
          </Row>
          <Row>
            <Col id="siteNm">에듀넷</Col>
            <Col id="siteUrl">https://www.edunet.net</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
  </Form>
</FDL>
