/* 서비스별이용가이드 */
this.divGuide_btn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//trace("======================================================================================");
	//trace("obj.id ::: " +obj.id );			
	//trace("======================================================================================");
	
	var tabInfo = 0; 
	
	if("btnCrI" == obj.id){ // 상시상담안내
		tabInfo = 0;
	}else if("btnIrI" == obj.id){ // 집중상담안내
		tabInfo = 1;
	}else if("btnOrI" == obj.id){ // 온라인(서면)상담안내
		tabInfo = 2;
	}

	// 이동
	var sUrl   = "pa_scr_cmm_cm::scr_guide00.xfdl";
	var params = {menu : "B005", _url:sUrl, tabIndex:tabInfo};
	this.smfSetWorkPage(sUrl, params, null, obj.text);		
};

//폼사이즈 변경시 높이 수정
this.staFormHeightComp_onsize = function(obj:nexacro.Static,e:nexacro.SizeEventInfo)
{
	this.scrChangeWorkHeight(this);
};
this.divLogin_Static00_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	var sRunMode = nexacro.getEnvironmentVariable("ev_runMode");
	if ( sRunMode == "1" || sRunMode == "2" || sRunMode == "4" ) {
			this.smfDialog("_FormLoginScrP", "frame::/scr/frameLogin.xfdl", {
				noCallback: true,
				params: {
					procType: "none"
				},
				titlebar : false
			   }
			);
	}
};
