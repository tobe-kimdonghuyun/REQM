//이미지 변경을 위한 Form Timer 가동/중지 Toggle
this.btnStepPlay_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if ( obj.cssclass == "btn_MF_Stop" ) {
		obj.set_cssclass("btn_MF_Play");
		
		this.killTimer(1);	//Timer 중지
	}
	else {
		obj.set_cssclass("btn_MF_Stop");
		
		this.setTimer(1, 5000);	//5초	//Timer 가동
	}
};

//스텝버튼 클릭시 이벤트
this.btnStep_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var nStepIdx = parseInt(obj.name.substr(7,1));
	//trace("	nStepIdx === " + nStepIdx);
	var arrComp = [this.btnStep0, this.btnStep1, this.btnStep2];
	for ( var i=0; i<arrComp.length; i++ ) {
		if ( arrComp[i].name == obj.name ) {
			arrComp[i].set_cssclass("btn_MF_StepS");
		}
		else {
			arrComp[i].set_cssclass("btn_MF_Step");
		}
	}
	this.staStepIdx.set_text((nStepIdx + 1) + "/3");
	this.divImage.form.setStepIndex(nStepIdx);
};


/* 상시상담예약하기 버튼 클릭 */
