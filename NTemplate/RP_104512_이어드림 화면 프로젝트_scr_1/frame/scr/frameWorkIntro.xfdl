this.fnDisplayText = function(obj,nCell,nRow,sLongText)
{	
	//trace("=============================================================================================================");
	//trace("obj.get_id() ::: " + obj.id );
	//trace("sLongText ::: " + sLongText );
	//trace("sLongText.length ::: " + sLongText.length );
	//trace(" this.objApp.gv_appScreenType ::: " +  this.objApp.gv_appScreenType );
	//trace("=============================================================================================================");

	var objId = obj.id;
	var sSize;

	if ( this.objApp.gv_appScreenType == "M" ) { // 모바일
		sSize = 20;
	}else if ( this.objApp.gv_appScreenType == "T" ) { // 태블릿
		sSize = 15;
	}else {
		sSize = 20;
	}

	return this.scrDisplayText(sLongText, sSize);
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

/* 간편인증 */
this.divLogin_btnSimpleCet_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	trace("======================================================================================");
	trace("간편인증!!! ");
	trace("======================================================================================");
	
	// 오픈방식을 설정한다.
	var sOpenType   = "birth";  // [선택] Open방식 -  "birth"(default) : 생년월일 , "ssn" : 주민등록번호
	//var sActionType = "trans";  // [선택] 간편인증 동작방식 -  "trans" : 중계형(온라인채용/검정고시) , "instl" : 설치형(교육비원클릭/그외) // 미지정시 subSys를 체크하여 설정. 미지정을 권장
	var sActionType = "instl";  // [선택] 간편인증 동작방식 -  "trans" : 중계형(온라인채용/검정고시) , "instl" : 설치형(교육비원클릭/그외) // 미지정시 subSys를 체크하여 설정. 미지정을 권장
		
	this.dsSearch.setColumn(0, "actionType", sActionType);

	var objParam = {objForm:this, popupcallback :this.fnSimpleAuthPopupCallback , openType: sOpenType, actionType: sActionType };
	this.smfExecSimpleAuth(objParam);
};


/* 공동인증 */
this.divLogin_btnCoprCet_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	trace("======================================================================================");
	trace("공동 인증서!!! ");
	trace("======================================================================================");

	var sRrno = "";
	var sConnectBaseUrl = window.location.protocol + "//" + window.location.host;

	var sInitUrl  = sConnectBaseUrl + "/cmc_fcm_es01_003.do";
	var sLoginUrl = sConnectBaseUrl + "/cmc_fcm_es01_005.do";
	var userId = sRrno;
	
	var objLoginInfo = {
							initUrl  : sInitUrl    // init시 사용하는 서비스명(앞에 "/"을 붙일 것)
						,   loginUrl : sLoginUrl   // login시 사용하는 서비스명(앞에 "/"을 붙일 것)
						,	userId : userId
						,	useRrno : "N"
					   };   // 생략가능

	var objParam = {objForm:this, popupcallback :this.fnCooperationAuthPopupCallback, loginInfo:objLoginInfo};
	this.smfExecNpkiAuth(objParam);
	
};


/* 학부모 서비스 링크*/
this.divLogin_btnParentLink_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sUrl = "";
	var sRunMode = nexacro.getEnvironmentVariable("ev_runMode");
	
	//trace("======================================================================================");
	//trace("sRunMode ::: " + sRunMode );
	//trace("======================================================================================");
	
	if ("1" == sRunMode || "2" == sRunMode){ // 로컬, 개발인 경우
		sUrl = "http://parent.dev.neis.kr";
	} else if("4" == sRunMode){ // 시험인 경우
		sUrl = "http://parent.tst.neis.kr";
	}else if("3" == sRunMode){ // 운영인 경우
		sUrl = "https://parents.neis.go.kr";
	}

	system.execBrowser(sUrl);	
};


/* 시스템 공지 상세 */
this.grdSysbtbNt_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	//trace("======================================================================================");
	//trace("obj ::: " + obj );
	//trace("e ::: " + e );
	//trace("======================================================================================");

	// 클릭한 셀을 구한다
	var nRow = e.row;
	var nCell = e.cell;
	
	// 제목 cell 설정
	var titlNo = 0;
	// 제목 클릭했을 때만 동작
	if(nCell == titlNo){
		// 상세화면으로 전달할 데이터 SET
		var objDs = obj.getBindDataset();
		var sNtcMteId = objDs.getColumn(nRow,"ntcMteId");
		
		var params = {
			tabIndex:this.tabIndex,
			ntcMteId:sNtcMteId
		};
		
		// 상세화면 호출
		this.smfSetWorkPage("pa_scr_btb_nt::scr_btbnt00_m04.xfdl", params);
	}
};


/* 시스템공지 더보기 */
this.btnSysbtbNt_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sMenuId = "4000";
