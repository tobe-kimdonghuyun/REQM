    <Script type="xscript5.1"><![CDATA[/**
*  학부모소통시스템
*  @MenuPath    공통
*  @FileName 	frameWorkIntro.xfdl
*  @Creator 	tobesoft
*  @CreateDate 	2025.03.17
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2025.03.17     	tobesoft 	        최초 생성     
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::scr_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.objApp = nexacro.getApplication();
this.tabIndex = 0; // 탭 번호

/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	//trace("frameWorkIntro onload >>>>>>>");
	this.scrInitForm(obj);	//필수(화면초기화)

	// 화면 초기설정
	this.fnInitForm();
	
	//이미지 변경을 위한 Form Timer
	this.setTimer(1, 5000);	//5초
	
	//this.doBtbSysNt(); // 시스템공지 조회
	//this.doBtnSysFaq(); // 시스템FQA 조회
	
	this.dsNt.set_rowposition(-1);
	this.dsFaq.set_rowposition(-1);

};

//화면 초기설정
this.fnInitForm = function()
{
	//trace("=============================================================================================================");
	//trace("this.smfIsLogin() ::: " + this.smfIsLogin() );	
	//trace("this.objApp.gv_appScreenType::: " + this.objApp.gv_appScreenType );	
	//trace("=============================================================================================================");
	
	if ( this.objApp.gv_appScreenType == "T" ) {
		this.divLogin.form.btnCoprCet.set_visible(false);
		this.divLogin.setOffsetHeight(344);
	}else if ( this.objApp.gv_appScreenType == "M" ) {
		this.divLogin.form.btnCoprCet.set_visible(false);
		this.divLogin.setOffsetHeight(344);
	}else{
		this.divLogin.form.btnCoprCet.set_visible(true);
		this.divLogin.setOffsetHeight(394);
	}
	
	this.resetScroll();
};

/* 화면 사이즈 변경 */
this.fnAfter_onlayoutchanged = function (sLayoutID)
{
	//trace("=============================================================================================================");
	//trace("sLayoutID ::: " + sLayoutID );	
	//trace("=============================================================================================================");

	if ( sLayoutID == "mobile") {
		this.divLogin.form.btnCoprCet.set_visible(false);
		this.divLogin.setOffsetHeight(344);
		
		this.divImage.form.setStepIndex(0);
		this.btnStepPlay.set_cssclass("btn_MF_Play");
		this.killTimer(1);	//Timer 중지
	} else {
		this.divImage.form.setStepIndex(0);
		this.btnStepPlay.set_cssclass("btn_MF_Stop");
		this.setTimer(1, 5000);	//5초	//Timer 가동
		
		if ( sLayoutID == "tablet") {
			this.divLogin.form.btnCoprCet.set_visible(false);
			this.divLogin.setOffsetHeight(344);
		} else { // default
			this.divLogin.form.btnCoprCet.set_visible(true);
			this.divLogin.setOffsetHeight(394);
		}
	}
	
	this.resetScroll();
};

// Form Timer이벤트
this.frameWorkIntro_ontimer = function(obj:nexacro.Form,e:nexacro.TimerEventInfo)
{
	//이미지 변경을 위한 Form Timer
	if ( e.timerid == 1 ) {
		var sLayout = this.divImage.form.getCurrentLayoutID();
		//trace("	sLayout === " + sLayout);
		if ( sLayout == "mobile" ) {
			this.divImage.form.setStepIndex(0);
			this.btnStepPlay.set_cssclass("btn_MF_Play");
			this.killTimer(1);	//Timer 중지
			return;
		}

		var nStepIdx = this.divImage.form.getStepIndex();
		//trace("	nStepIdx === " + nStepIdx);
		var arrComp = [this.btnStep0, this.btnStep1, this.btnStep2];
		if ( nStepIdx == 2 ) {
			arrComp[2].set_cssclass("btn_MF_Step");
			arrComp[1].set_cssclass("btn_MF_Step");
			
			arrComp[0].set_cssclass("btn_MF_StepS");
			this.staStepIdx.set_text("1/3");
			this.divImage.form.setStepIndex(0);
		}
		else {
			if ( nStepIdx == 0 ) {
				arrComp[0].set_cssclass("btn_MF_Step");
				arrComp[2].set_cssclass("btn_MF_Step");
			}
			else if ( nStepIdx == 1 ) {
				arrComp[0].set_cssclass("btn_MF_Step");
				arrComp[1].set_cssclass("btn_MF_Step");
			}
			
			arrComp[nStepIdx + 1].set_cssclass("btn_MF_StepS");
			this.staStepIdx.set_text((nStepIdx + 2) + "/3");
			this.divImage.form.setStepIndex(nStepIdx + 1);
		}
	}
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 /* 기본 트랙잭션 콜백 */
 this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};


/* 간편인증 CALLBACK */
this.fnSimpleAuthPopupCallback = function(e, sender){

	trace("==================================================================");
	trace("간편인증 CALLBACK>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>");
	trace("e.result ::: " + e.result );
	trace("==================================================================");

	var sLog 		= "";
	var loginTyp 	= "simpleLogin";
	
	if(e.result){
	
		var sData = JSON.parse(e.data);
//		trace("==================================================================");
//		trace("성공");
//		trace("sData.userNm ::: " + sData.userNm );
//		trace("sData.ssn ::: " +sData.ssn );
//		trace("sData.ci ::: " + sData.ci );
//		trace("==================================================================");

		if(this.smfIsNull(e.data)){
		
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+e.data+"]";
			console.log(sLog);
			this.scrAlert("본인 인증 인증에 실패 하였습니다..");
			return;
			
		}

		sLog += "처리결과 : [성공]\n";

		// 데이터 SET
		this.dsSearch.setColumn(0, "jwt", e.data);
	
		/***********************************************************************************************************************
		* 서비스 객체 생성 시작
		************************************************************************************************************************/
		this.smfSearchService("listsimpleAuthParse")
		.run() // 실행			
		.callback(function(callbackParams){ // 콜백
			if(callbackParams.errors) return;

			////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
			// 처리 시작
			////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
			var oFrameMainForm = this.objApp.mainframe.VFrameSet.frameMain.form;

			// 데이터 SET
			oFrameMainForm.dsScrLgnSrch.setColumn(0, 'provider', this.dsResult.getColumn(0, "provider")  ); 
			oFrameMainForm.dsScrLgnSrch.setColumn(0, 'ci', this.dsResult.getColumn(0, "ci") );

			// 로그인처리[간편인증]			
			oFrameMainForm.doScrLgn("LG005"); //간편인증
			////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
			// 처리 종료
			////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
				
		});
		/***********************************************************************************************************************
		* 서비스 객체 생성 시작
		************************************************************************************************************************/
			
	}
	
};


/* 공동인증서 CALLBACK */
this.fnCooperationAuthPopupCallback = function(e, sender){

	trace("==================================================================");
	trace("공동인증서 CALLBACK>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>");
	trace("e.result ::: " + e.result );
	trace("==================================================================");
	
	var sLog = "";
//	var obj = sender.divLoginFrm.form;


	if(e.result){
	
		var sData = JSON.parse(e.data);

		trace("==================================================================");
		trace("공동인증서 결과[sData] ::: " + sData );
		trace(" sData.subjectDn ::: " + sData.subjectDn );
		trace("공동인증서 결과[sData] ::: {} ", sData );
		trace("==================================================================");
		
		// 데이터 SET
		//this.dsSearch.setColumn(0, "jwt", e.data);
		
		this.dsSearch.setColumn(0, "issuerDn", sData.subjectDn );
		
		// 로그인처리[공동인증서]
		this.doLogin("2");
		
		//this.doLogin(sData.subjectDn, "LG001"); // 로그인 유형코드 LG001:EPKI/GPKI
		
	}else{
	
		var sData = e.data;
		var arrData = sData.split(":");
		
		if(arrData[0].trim()=='{"visible"'){  // 유저가 팝업을 강제 종료한 경우
		
			sLog += "처리결과 : [에러(유저강제종료)]\n";
			sLog += "data : ["+sData+"]";
			
			trace("==================================================================");
			trace("에러(유저강제종료) ::: " + sData);	
			trace("==================================================================");

		}else{ // 에러인 경우
		
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+sData+"]";
			
			trace("==================================================================");
			trace("에러인 경우 ::: " + sLog);	
			trace("==================================================================");

			if("취소되었습니다." != sData){
				this.scrAlert(sData);
			}

			return;
			
		}
		
	}
	
};
