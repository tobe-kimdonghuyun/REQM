        <Static id="staMascot" taborder="14" height="90" right="543" width="66" accessibilityenable="false" cssclass="sta_BF_Mascot" top="152"/>
        <Button id="btnLogo01" taborder="15" width="130" height="50" right="1170" accessibilitylabel="교육부 바로가기" cssclass="btn_BF_Logo01" initvalueid="iv_Button" top="76" onclick="btnLogo01_onclick" color="black" text=""/>
