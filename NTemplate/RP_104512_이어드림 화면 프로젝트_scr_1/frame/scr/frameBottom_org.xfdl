    <Script type="xscript5.1"><![CDATA[/**
*  학부모소통시스템
*  @MenuPath    공통
*  @FileName 	frameBottom.xfdl
*  @Creator 	tobesoft
*  @CreateDate 	2025.03.17
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2025.03.17     	tobesoft 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::scr_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	//trace("Frame Bottom onload >>>>>>>");
};

//Form의 onlayoutchanged이벤트
this.form_onlayoutchanged = function(obj,e)
{
	obj.setTimer(900, 55);
};

//MLM 레이아웃 변경후 설정
this.fnAfter_onlayoutchanged = function(sLayoutId)
{
	this.getOwnerFrame().form.divAll.form.resetScroll();
};

//Form의 ontimer이벤트
this.form_ontimer = function(obj,e)
{
	if ( e.timerid == 900 ) {
		obj.killTimer(e.timerid);
		this.fnAfter_onlayoutchanged(this.getCurrentLayoutID());
	}
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
//관련사이트 실행
this.fnSiteMenuClick = function(sSelUrl)
{
	this.pdvSite.closePopup();
	
	var nSelRow = this.dsSite.rowposition;
	var sSelUrl = this.dsSite.getColumn(nSelRow, "siteUrl");
	
	system.execBrowser(sSelUrl);
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.divPolicy_btn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	switch(obj.id) {
	case "btnIndvInfo":
		var sUrl   = "frame::commom/framePolicyScr01.xfdl";
		var params = {menu : "B001",_url:sUrl};
		this.smfSetWorkPage(sUrl, params, null, obj.text);	
		
		break;
	case "btnLicense":
		var sUrl   = "frame::commom/framePolicyScr02.xfdl";
		var params = {menu : "B003",_url:sUrl};
		this.smfSetWorkPage(sUrl, params, null, obj.text);	
			
		break;
	case "btnAccessBility":
		var sUrl   = "frame::commom/framePolicyScr03.xfdl";
		var params = {menu : "B004",_url:sUrl};
		this.smfSetWorkPage(sUrl, params, null, obj.text);	
			
		break;
	case "btnUse":
		var sUrl   = "frame::commom/framePolicyScr04.xfdl";
		var params = {menu : "B002",_url:sUrl};
		this.smfSetWorkPage(sUrl, params, null, obj.text);	
			
		break;
	default:
	}
};

//관련사이트 버튼 클릭시
this.btnSite_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if ( this.pdvSite.isPopup() ) this.pdvSite.closePopup();
	
	if(this.dsSite.getRowCount()  == 0) return;

	var nWidth  = this.pdvSite.getOffsetWidth();
	var nHeight = this.dsSite.getRowCount() * 36;
	var nLeft   = 0;
	var nTop    = obj.getOffsetTop() - nHeight + 1;
	
	this.pdvSite.trackPopupByComponent(obj, nLeft, nTop, nWidth, nHeight, "", false);
};

//관련사이트 선택시
this.pdvSite_lstSite_onitemclick = function(obj:nexacro.ListBox,e:nexacro.ItemClickEventInfo)
{
	this.pdvSite.closePopup();

	system.execBrowser(e.itemvalue);
};

//관련사이트 ESC를 누르면 popupDiv닫힘. 기존 컴포넌트로 포커스 이동.
this.pdvSite_lstSite_onkeydown = function(obj:nexacro.ListBox,e:nexacro.KeyEventInfo)
{
	//ESC누름
	if(e.keycode == 27)
	{
		this.pdvSite.closePopup();
	}
	else if(e.keycode == 13 || e.keycode == 32)	//엔터키 or 스페이스키
	{
		this.pdvSite.closePopup();
		
		system.execBrowser(obj.value);
	}	
};


/* 교육부 링크 */
this.btnLogo01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sUrl = "https://www.moe.go.kr";
	system.execBrowser(sUrl);	
};


/* keris 링크 */
this.btnLogo03_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sUrl = "https://www.keris.or.kr";		
	system.execBrowser(sUrl);	
};
]]></Script>
    <Objects>
      <Dataset id="dsSite">
        <ColumnInfo>
          <Column id="siteNm" type="STRING" size="256" description="사이트명"/>
          <Column id="siteUrl" type="STRING" size="256" description="사이트URL"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="siteUrl">https://www.moe.go.kr</Col>
            <Col id="siteNm">교육부</Col>
          </Row>
          <Row>
            <Col id="siteNm">학교알리미</Col>
            <Col id="siteUrl">https://www.schoolinfo.go.kr</Col>
          </Row>
          <Row>
            <Col id="siteNm">에듀넷</Col>
            <Col id="siteUrl">https://www.edunet.net</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
  </Form>
</FDL>
