<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frameMain" width="1430" height="1020" titletext="학부모소통시스템(frameMain)" onload="form_onload" scrollbartype="none none" scrollindicatorsize="10" nHeight="30" scrolltype="none" onsize="form_onsize" onlayoutchanged="form_onlayoutchanged" ontimer="form_ontimer">
    <Layouts>
      <Layout height="1020" mobileorientation="landscape" width="1430" screenid="desktopScr">
        <Static id="staTopGuide" taborder="5" left="0" top="0" right="0" cssclass="sta_TF_Bg" height="128" accessibilityenable="false"/>
        <Div id="divTop" taborder="0" left="0" top="0" async="false" url="frame::scr/frameTop.xfdl" height="130" text="" initvalueid="ivDivAccessibilityOn" formscrollbartype="none none" formscrolltype="none" accessibilitylabel="Top영역" minwidth="" formscrollbarsize="20" right="0" accessibilityenable="false"/>
        <Div id="divAll" taborder="1" left="0" top="divTop:0" text="" accessibilityenable="false" accessibilityrole="none" bottom="0" initvalueid="ivDivAccessibilityOff" minwidth="" url="frame::scr/frameAll.xfdl" right="0" formscrolltype="vertical" formscrollbartype="none fixed"/>
        <Div id="divMenu" taborder="2" text="divMenu" left="1500" top="65" width="200" height="150" url="frame::scr/frameTopMenu.xfdl" minwidth=""/>
        <Div id="divSearch" taborder="3" text="divSearch" left="1500" top="295" width="200" height="150" url="frame::scr/frameTopSearch.xfdl" minwidth=""/>
      </Layout>
      <Layout height="1147" mobileorientation="Landscape" name="tablet" type="default" width="800" screenid="tabletScr,desktopScr">
        <Div id="divTop"/>
      </Layout>
      <Layout height="1040" mobileorientation="Landscape" name="mobile" type="default" width="480" screenid="mobileScr,desktopScr">
        <Static id="staTopGuide" height="76" left="0" top="0" right="0"/>
        <Div id="divTop" height="76" left="0" top="0" right="0" accessibilityenable="false"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  학부모소통시스템
*  @MenuPath    공통
*  @FileName 	frameMain.xfdl
*  @Creator 	tobesoft
*  @CreateDate 	2025.03.17
*  @Desction    
************** 소스 수정 이력 ***********************************************
