            <Col id="useGrade">N</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[



/**
*  학부모소통시스템
*  @MenuPath    공통
*  @FileName 	frameTop.xfdl
*  @Creator 	tobesoft
*  @CreateDate 	2025.03.17
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2025.03.17     	tobesoft 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::scr_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.objApp = nexacro.getApplication();
this.fv_WorkFormWidth;

this.fv_TopBtnPrefix = "TOP_";
this.fvSubSysGb = "";
this.fvLastLeft=0;

//로그인 잔여시간
this.fvMaxTimeout = 0; //총잔여시간
this.fvRemainTimeout = 0; //연장알림시간
this.fvLoginLocalTime; //로그인로컬시간
this.fvUseRemainTime = false; //잔여시간 사용여부
this.fvTimerId = 1001; //타이머 아이디

// History처리를 위한 변수
this.fvHistoryInfo_type = "expand";  // "expand" , "collapse"
this.fvHistoryInfo_objOption = {};

this.objFocusComp ;//포커스를 가지고 있는 컴포넌트 저장

this.fvUserInfo = {};


this.fvTest;
/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	//this.scrInitForm(obj);	//Frame화면은 사용안함
	//trace("formsize===" + this.getOffsetWidth()+"::::layout==="+ this.getCurrentLayoutID());
	//trace("Frame Top onload >>>>>>>");
	this.fv_WorkFormWidth = nexacro.toNumber(this.divDispArea.maxwidth) + 90 + 6;
	
	//웹접근성 안내
	this.divSkip.set_height(0);	
	
	//서브시스템코드를 가져온다.
	this.fvSubSysGb = this.smfGetSubSystemGb();

	//TOP화면에 메뉴를 표시한다.
	this.fnRedrawTopMenu();
	
	//메시지(gdsMessage) 가져오기
	//this.smfLoadMessage();

	//초기설정(추가)
	this.fnFormInit();
	
	//공지팝업 호출
	//this.fnNoticePopup();
	
	
	this.fnScrFrameTopInfoChg(this);

};

this.fnFormInit = function()
{
	this.setTimer(900, 200);
	
// 	if( nexacro.getEnvironment().enableaccessibility && !this.smfIsMobile() ) {
// 		var sText = "Ctrl + Shift + F11 키를 동시에 눌러 스크린리더의 가상커서를 설정하신 후 이용하시기 바랍니다.";
// 		
// 		//[웹접근성] 전용브라우저인 경우
// 		if(this.fvSubSysGb == "UDS"){
// 			// sText = "<문서시작> " + sText;
// 			
// 			//hotKey설정을 위한 static visible = true [ctrl+home 단축키로 문서시작으로 이동]
// 			this.staHotkey.set_visible(true);
// 			this.staHotkey.set_text("<문서시작>");
// 			this.staHotkey.set_hotkey("CTRL+HOME");
// 		}
// 		//this.btnFirstFocus.set_text(sText);
// 		//this.btnFirstFocus.set_accessibilitylabel(sText);
// 	}
// 	this.btnFirstFocus.setFocus();
// 	
// 	if( this.smfIsMobile()){
// 		this.divSkip.set_visible(false);
// 	}
};

/**
 * @description 화면 사이즈 변경시
*/
this.form_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	var nMainFrameWidth = this.objApp.mainframe.getOffsetWidth();

	var nLeft = 0;
	if ( nMainFrameWidth > this.fv_WorkFormWidth ) {
		nLeft = (nMainFrameWidth / 2) - (this.fv_WorkFormWidth / 2);
	}

    this.divDispArea.setOffsetLeft(nLeft);
	if ( this.divDispArea.form.divTopBtn.getOffsetWidth() > 603) {
		this.divDispArea.form.divTopBtn.set_visible(true);
	}
	else {
		this.divDispArea.form.divTopBtn.set_visible(false);
	}
	this.resetScroll();
};

//Form의 onlayoutchanged이벤트 추가
this.form_onlayoutchanged = function(obj,e)
{
	//trace("work form_onlayoutchanged >>>>" + e.newlayout);
	obj.setTimer(900, 55);
};

//form의 onkeydown이벤트
this.form_onkeydown = function(obj,e)
{
	var sRunMode = nexacro.getEnvironmentVariable("ev_runMode");
	if ( sRunMode == "1" || sRunMode == "2" || sRunMode == "4" ) {
		if(e.ctrlkey && e.altkey && e.keycode == 68 ){		//ctrl + alt + D
			this.smfOpen("FormSpy" + Math.random() + Math.random() + Math.random(), "comm::form_spy.xfdl", {
				noCallback: true,
				params: {
					procType: "none",
				},
			});
		}
		else if(e.ctrlkey && e.altkey && e.keycode == 76 ){		//ctrl + alt + L
			this.smfDialog("FormLogin" + Math.random() + Math.random() + Math.random(), "frame::/scr/frameLogin.xfdl", {
				noCallback: true,
				params: {
					procType: "none"
				},
				titlebar : false
			   }
			);
		}
	}
};

//MLM 레이아웃 변경후 설정
this.fnAfter_onlayoutchanged = function(sLayoutId)
{
	//var isLogin = this.smfIsLogin();
	if ( this.getFocus() == this.divSkip.form.btnGobody ) {
		this.divSkip.set_height(22);
	}
	else {
		this.divSkip.set_height(0);
	}
	
	if (sLayoutId == "mobile" ) {
		this.divDispArea.form.divUser.set_visible(true);
		this.divDispArea.form.btnUserM.set_visible(true);
	}
	else if ( sLayoutId == "tablet" ) {
		this.divDispArea.form.divUser.set_visible(true);
		this.divDispArea.form.btnUserM.set_visible(true);
	} 
	else {
		this.divDispArea.form.divUser.set_visible(true);
		this.divDispArea.form.btnUserM.set_visible(true);
	}
};

/* Form의 ontimer이벤트 추가 */
this.form_ontimer = function(obj,e)
{
	if ( e.timerid == 900 ) {
		obj.killTimer(e.timerid);
		this.fnAfter_onlayoutchanged(this.getCurrentLayoutID());
	}	
	//로그아웃 잔여시간 체크
	else if (e.timerid == this.fvTimerId) 
	{
		//this.fvMaxTimeout 서버에서 가져온 잔여 총 시간 (초)
		//this.fvRemainTimeout 서버에서 가져온 연장 여부 체크시간 (초)
		//this.fvLoginLocalTime 로그인했을 때 로컬 시간(Date)
		
		var objCurrLocalTime = new Date(); //현재 로컬 시간

		//경과시간   현재시간-로그인시간 (.getTime() 밀리초값으로 반환.) 
		var nPassTime = Math.floor( (objCurrLocalTime.getTime() - this.fvLoginLocalTime.getTime())/1000 );
		//남은시간(잔여총시간(초) - 경과시간)
		var nDiffSec = this.fvMaxTimeout - nPassTime;
		
		var nLastMin = Math.floor(nDiffSec/60);
		var nLastSec = Math.floor(nDiffSec%60);

		//시간 text셋팅
		this.divDispArea.form.staRemainingTime.set_text( this.lpad(nLastMin,"0",2) + "분 "    //00분
														+  this.lpad(nLastSec, "0", 2)+"초"); //00초
		
		// 연장팝업 (남은시간<=연장체크시간) (초로 계산)
		if(nDiffSec <=  this.fvRemainTimeout)
		{
			this.fnRemainPopup();
			this.killTimer(this.fvTimerId);
		}

	}
	else if (e.timerid == 700) {	//팝업close
		this.killTimer(e.timerid);
		
		this.pdvMenu.closePopup();
	}
	else if (e.timerid == 701) {	//팝업close
		this.killTimer(e.timerid);
		
		this.pdvUser.closePopup();
	}
	else if (e.timerid == 702) {	//팝업close
		this.killTimer(e.timerid);
		
		this.pdvStudent.closePopup();
	}
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	//trace("svcid==="+svcid + "::::errcd==="+errcd + "::::errmsg==="+errmsg);
	if(errcd == -1) return;
	
};


/* 로그인 연장여부 팝업 콜백 */
this.fnRemainPopupCallback = function(e, sender)
{
	this.killTimer(this.fvTimerId);
	
	//this.trace("frameTop:::::::::::::::::::::::::::::::::::::: e.logoutYn ::: " + e.logoutYn );
	
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// 로그아웃YN에 따라 분기처리(연장/종료) 시작
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	if(e.logoutYn){
	
		//팝업 열려있는지 확인
		var scrLgnCommEnd = this.smfGetPopupFrame("_ScrLgnCommEnd");

		//trace("======================================================================================");
		//trace("scrLgnCommEnd ::: " + scrLgnCommEnd );			
		//trace("======================================================================================");
	
		if(scrLgnCommEnd) { // 동일팝업 열려있는지 확인
			return;
		}else{
		
			var scrLgnCommExtend = this.smfGetPopupFrame("_ScrLgnCommExtend") ;

			//trace("======================================================================================");
			//trace("scrLgnCommEnd ::: " + scrLgnCommEnd );			
			//trace("======================================================================================");
		
			if(scrLgnCommExtend){ // 연장팝업이 열여있는 경우
				this.smfGetPopupFrame("_ScrLgnCommExtend").form.close();
			}
			
			//종료 alert 팝업 출력
			var popupParams = {
				callback: this.fnLogoutMsgCallback, // 콜백함수 지정
				//internalCallback: this.fnLogoutMsgCallback, // 콜백함수 지정
				sender: obj, // sender 지정	
				popuptype : "modalsync",
				// 팝업 전달 파라메터 지정
				params: {
					// 처리타입 지정
					procType: "notice"
				},
				titlebar:false
			};

			// 모달팝업 실행
			this.smfDialog("_ScrLgnCommEnd", "pa_scr_cmm_cm::scr_comm_ending.xfdl", popupParams );	

		}
	}else{
		//로그인 시간 연장(세션 연장 서비스 호출)
		this.smfExecuteService("executeSessionRemain")	
		.showConfirm(false)
		//.requireModifredData()  데이터 변경 필수
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
					//잔여시간 연장
					this.fnRemainTime();
				});	
	}
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// 로그아웃YN에 따라 분기처리(연장/종료) 종료
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
};


/* 로그인시간 만료 메시지 콜백 */
this.fnLogoutMsgCallback = function(e, sender)
{
	this.fnLogout();
};


/* 로그인 잔여시간 연장 */
this.fnCheckSessionWhenAfterServiceCallback = function(svcid, errcd, errmsg, objForm)
{	
	// 로그인 잔여시간 연장
	if(this.fvUseRemainTime){
		this.killTimer(this.fvTimerId);
		this.fnRemainTime();
	}
};

// 공지팝업 콜백
this.fnNoticePopupCallback = function( pObj )
{
	if ( pObj instanceof nexacro.NormalDataset ){

		if(pObj.rowcount > 0){
			var vLnkTypCd = pObj.getColumn(0,"lnkTypCd");
			var vLnkUrl = pObj.getColumn(0,"lnkUrl");
			
			this.fnLinkPrcs(vLnkTypCd, vLnkUrl);
		}
	}
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/



//서브메뉴 팝업에서 onkeydown이벤트
this.pdvMenu_divMenu_onkeydown = function(obj:nexacro.Div,e:nexacro.KeyEventInfo)
{
	if(e.keycode == 27)
	{
		//this.pdvMenu.closePopup();
	}	
};

//서브메뉴 팝업에서 onsetfocus이벤트
this.pdvMenu_divMenu_onsetfocus = function(obj:nexacro.Div,e:nexacro.SetFocusEventInfo)
{
	if ( e.oldcomponent.name == "divMenu" ) {
		
		this.setTimer(700, 100);
	}
};

//메뉴 팝업 표시될때 발생하는 이벤트
this.pdvMenu_onpopup = function(obj:nexacro.PopupDiv,e:nexacro.EventInfo)
{
	this.pdvMenu.form.divMenu.form.setFocus();
};

//공지팝업
this.fnNoticePopup = function()
{
	//팝업 설정
	this.popInfo = {};
	this.popInfo.id = "commNoticeAll";
	this.popInfo.pUrl = "pa_scr_cmm_cm::commNoticeAll.xfdl";
	
	//콜백 함수 설정
	this.popInfo.callbackScope = this;
	this.popInfo.callbackFunc = "fnNoticePopupCallback";
	
	this.smfSearchService("selectPopupInfo")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			// 팝업 호출
			if(this.dsListPopup.getRowCount() > 0){
				this.popInfo.dsListPopup =this.dsListPopup;
				this.smfDivPop(this.popInfo);
			}
		});
};

// 팝업 링크 이동
this.fnLinkPrcs = function(lnkTypCd, lnkUrl){
	if(lnkTypCd == 1){ //url 링크
		this.smfSetServiceLink(lnkUrl,"redirect");		//해당 url로 이동
	}
};


/* 잔여시간 연장 */
this.fnRemainTime = function()
{
	//현재 시간 저장
	var objCurrTime = new Date();		
	this.fvLoginLocalTime = objCurrTime;
	
	//text 셋팅
	var sMaxOutTime = this.lpad(this.dsTimeOut.getColumn(0, "maxTimeout"), "0", 2); // "00"
	this.divDispArea.form.staRemainingTime.set_text( sMaxOutTime + "분 00초");

	//timer on
	this.setTimer(this.fvTimerId, 1000);
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
//프로그램 종료
this.btnExit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.objApp.exit();
};





//검색 버튼 클릭
this.divDispArea_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.getOwnerFrame().form.fnShowPopDiv("search");
};

//전체메뉴 버튼 클릭
this.divDispArea_btnSitemap_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.getOwnerFrame().form.fnShowPopDiv("menu");
};

//이용가이드 버튼 클릭
this.divDispArea_btnGuide_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
    var objEnv  = nexacro.getEnvironment();
	var sUrl    = objEnv.services["baseUrl"].url + "/doc/edu/pa/scr/학부모소통(이어드림) 사용자매뉴얼.pdf";
	system.execBrowser(sUrl);
};

/* 로그아웃 버튼 클릭 */
this.fnLogout_onclick = function(obj, e)
{
	this.killTimer(this.fvTimerId);
	this.fnLogout();
};


/********************************************************************************************************************************************************/
/********************************************************************************************************************************************************/
/* 로그인/로그아웃 START */
/********************************************************************************************************************************************************/
/********************************************************************************************************************************************************/

/* 로그인 이후의 처리를 한다. */
this.fnScrFrameTopInfoChg = function(objForm)
{
	//var sSubSystemGb = objForm.smfGetSubSystemGb();	
	//var isLogin = objForm.smfIsLogin();

	 // 로그인정보 영역
	objForm.divDispArea.form.divUser.set_visible(true);
	objForm.divDispArea.form.btnUserM.set_visible(true);

	this.divDispArea.form.divUser.form.divBtnUserWrap.form.btnUser.destroy();
    var objBtn = new Button("btnUser", 0, 0, null, null, 0, 0);
	this.divDispArea.form.divUser.form.divBtnUserWrap.form.addChild("btnUser", objBtn);
	this.divDispArea.form.divUser.form.divBtnUserWrap.form.btnUser.set_cssclass("btn_TF_My");
	this.divDispArea.form.divUser.form.divBtnUserWrap.form.btnUser.setEventHandler("onclick", this.divDispArea_divUser_btnUser_onclick, this);
	this.divDispArea.form.divUser.form.divBtnUserWrap.form.btnUser.set_accessibilitydesclevel("all");
	this.divDispArea.form.divUser.form.divBtnUserWrap.form.btnUser.set_accessibilityenable("true");
	this.divDispArea.form.divUser.form.divBtnUserWrap.form.btnUser.set_accessibilitylabel("학부모정보");
	this.divDispArea.form.divUser.form.divBtnUserWrap.form.btnUser.set_accessibilityrole("button");
	
	if (this.objApp.gv_appScreenType == "M") {
		this.divDispArea.form.divUser.form.divBtnUserWrap.form.btnUser.set_tabstop(false);
	} else {
		this.divDispArea.form.divUser.form.divBtnUserWrap.form.btnUser.set_tabstop(true);
	}

	objForm.divDispArea.form.divUser.form.divBtnUserWrap.form.btnUser.set_text("학부모님");
	objBtn.show();

	this.divDispArea.form.divUser.form.divBtnStudentWrap.form.btnStudent.destroy();
	var btnStudent = new Button();
	if (this.objApp.gv_appScreenType == "M") {
		btnStudent.init("btnStudent", 0, 0, null, null, 0, 0);
	} else {
		btnStudent.init("btnStudent", 0, 0, null, null, 0, 0);
	}	
	this.divDispArea.form.divUser.form.divBtnStudentWrap.form.addChild("btnStudent", btnStudent);
	this.divDispArea.form.divUser.form.divBtnStudentWrap.form.btnStudent.set_cssclass("btn_TF_Student");
	this.divDispArea.form.divUser.form.divBtnStudentWrap.form.btnStudent.setEventHandler("onclick", this.divDispArea_divUser_btnStudent_onclick, this);
	this.divDispArea.form.divUser.form.divBtnStudentWrap.form.btnStudent.set_accessibilitydesclevel("all");
	this.divDispArea.form.divUser.form.divBtnStudentWrap.form.btnStudent.set_accessibilityenable("true");
	this.divDispArea.form.divUser.form.divBtnStudentWrap.form.btnStudent.set_accessibilitylabel("자녀선택");	
	
	this.divDispArea.form.divUser.form.divBtnStudentWrap.form.btnStudent.set_text("학생명");
	btnStudent.show();

	//this.divDispArea.form.divUser.form.resetScroll();

	//서버에서 타임아웃 시간 가져 옴
	//this.fvUseRemainTime = true;
	//this.fnGetTimeout();  
};

/* 서버에서 로그인 잔여시간 정보 가져오기 */
this.fnGetTimeout = function()
{
	this.smfSearchService("selectTimeout")		
		.run()// 실행
		.callback(function(callbackParams){ // 콜백
			//로그인한 시간 저장
			var objCurrTime = new Date();

			this.fvMaxTimeout = this.dsTimeOut.getColumn(0, "maxTimeout") * 60; // 초로 저장
			this.fvRemainTimeout = this.dsTimeOut.getColumn(0, "remainTimeout") * 60; //초로 저장
			this.fvLoginLocalTime = objCurrTime;

//this.fvRemainTimeout = "1770";

			//trace("======================================================================================");
			//trace("fvMaxTimeout ::: " + this.fvMaxTimeout );
			//trace("fvRemainTimeout ::: " + this.fvRemainTimeout );
			//trace("fvLoginLocalTime ::: " + this.fvLoginLocalTime );
			//trace("======================================================================================");
			
			//로그인 후 잔여시간 처리
			this.fnTimeoutLogin();
		});
};

/* 로그인 후 잔여시간 컴포넌트 처리 */
this.fnTimeoutLogin = function()
{
	var sSubSystemGb = this.smfGetSubSystemGb();	
	var sMaxOutTime = this.lpad(this.dsTimeOut.getColumn(0, "maxTimeout"), "0", 2); // "00"
	
	this.divDispArea.form.staRemainingTime.set_text( sMaxOutTime + "분 00초");
	//timer on
	this.setTimer(this.fvTimerId, 1000);
};


/* 로그인시간 연장 팝업을 표시한다 */
this.fnRemainPopup = function()
{
	//팝업 열려있는지 확인
	var scrLgnCommExtend = this.smfGetPopupFrame("_ScrLgnCommExtend") ;

	//trace("======================================================================================");
	//trace("scrLgnCommExtend ::: " + scrLgnCommExtend );			
	//trace("======================================================================================");

	if(scrLgnCommExtend){
		return;
	}else{
		var sLastTime = this.divDispArea.form.staRemainingTime.text;//현재 남은 시간
		
		// 팝업을 동작에 필요한 파라메터 지정
		var popupParams = {
			callback: this.fnRemainPopupCallback, // 콜백함수 지정
			sender: obj, // sender 지정	

			// 팝업 전달 파라메터 지정
			params: {
				// 처리타입 지정
				procType: "notice"
				, sLastTime : sLastTime
				, fvMaxTimeout : this.fvMaxTimeout
				, objLoginLocalTime : this.fvLoginLocalTime
			},
			
			titlebar:false
		};
		
		// 모달팝업 실행
		this.smfDialog("_ScrLgnCommExtend", "pa_scr_cmm_cm::scr_comm_extend.xfdl", popupParams );	
	}
};


/* 로그아웃 */
this.fnLogout = function()
{
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// 로그아웃 서비스 호출
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	this.smfExecuteService("executeLogout")		
	.showConfirm(false)
	.run()// 실행
	// 콜백
	.callback(function(callbackParams){
			this.fnLogoutAfter();
	});
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// 로그아웃 서비스 호출
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
};


//로그아웃 후 처리
this.fnLogoutAfter = function()
{
	//글로벌 변수 로그인 여부 수정
	this.smfSetLoginState(false);
	this.divDispArea.form.divUser.form.divBtnUserWrap.form.btnUser.set_text("");
	this.divDispArea.form.divUser.set_visible(false); // 로그인정보 영역
	this.divDispArea.form.btnUserM.set_visible(false);

	//로그아웃 후 잔여시간 obj처리	
	if(this.fvUseRemainTime){
	    this.fvUseRemainTime = false;
	}

	// 메인화면을 호출한다.
	var sUrl   = "frame::scr/frameWorkMain.xfdl";
	var params = {menu : "MAIN",_url:sUrl};
	this.smfSetWorkPage(sUrl, params, null, "HOME");	
};

/********************************************************************************************************************************************************/
/********************************************************************************************************************************************************/
/* 로그인/로그아웃 END */
/********************************************************************************************************************************************************/
/********************************************************************************************************************************************************/






