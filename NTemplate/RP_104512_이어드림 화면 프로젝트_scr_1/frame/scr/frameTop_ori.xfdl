            <Col id="lvl">1</Col>
            <Col id="parentMenuId">9000</Col>
            <Col id="menuId">9053</Col>
            <Col id="menuName">연계 테스트</Col>
            <Col id="menuUrl">pa_scr_ctr_oc::testsample.xfdl</Col>
            <Col id="useGrade">N</Col>
            <Col id="isShow">Y</Col>
            <Col id="isNeedLogin">N</Col>
            <Col id="useHead">Y</Col>
          </Row>
          <Row>
            <Col id="lvl">1</Col>
            <Col id="parentMenuId">9000</Col>
            <Col id="menuId">9060</Col>
            <Col id="menuName">상담 테스트</Col>
            <Col id="menuUrl">pa_scr_mri_cl::scr_mricl99_m99.xfdl</Col>
            <Col id="isNeedLogin">N</Col>
            <Col id="useHead">Y</Col>
