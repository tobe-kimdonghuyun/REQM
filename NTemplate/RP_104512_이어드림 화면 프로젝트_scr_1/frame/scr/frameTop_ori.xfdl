/*******************************************메뉴**********************************************/
/**
@class fnSetTopMenu
@description topmenu세팅
@param N/A
@return N/A
*/ 
this.fnRedrawTopMenu = function ()
{
	// 기존에 TopMenu 초기화
	this.divDispArea.form.divTopBtn.reload();
	this.divDispArea.form.divTopBtn.form.set_scrolltype("none");
	this.divDispArea.form.divTopBtn.form.set_scrollbartype("none none");	

	//시스템 메뉴 가져오기
	//var objMenuForm = this.divMenu.form;
	//this.dsMenu.copyData(objMenuForm["dsMenu_" + this.fvSubSysGb.toLowerCase()]);
	this.dsMenu.copyData(this.dsMenu_scr);
	this.dsMenu.appendData(this.dsMenuExpand);
	var sRunMode = nexacro.getEnvironmentVariable("ev_runMode");
	if ( sRunMode == "1" ) {	//Local실행시 샘플메뉴 추가
		this.dsMenu.appendData(this.dsMenuTemp);
	}	

	// 대분류만추출
	this.dsMenu.filter("lvl==0&&isShow!='N'");

	var btnObj;
	var nGapBtn = 48;
	var nHeight = 72;
	var strID = "", strName = "", strUrl = "", strGroup = "";
	for (var i = 0; i < this.dsMenu.getRowCount(); i++) 
	{
		strID   = this.dsMenu.getColumn(i, "menuId" );  // 메뉴아이디
		strName = this.dsMenu.getColumn(i, "menuName" );  // 메뉴명
		strUrl  = this.dsMenu.getColumn(i, "menuUrl");  // 메뉴URL
		strGroup = this.dsMenu.getColumn(i, "isGroup");  // 그룹메뉴 여부
		this.fnCreateTopMenu(strID, strName, strUrl, i, nGapBtn,nHeight, strGroup);
	}
	
	// 필터를 해제
	this.dsMenu.filter("");	
};

/**
@class fnCreateTopMenu
@description Top menu creation
@param  필수 {String} strID - 버튼아이디
		필수 {String} strName - 버튼 text
		필수 {String} strUrl - 버튼 Url(없는 경우는 "")
		필수 {Number} index - 버튼 순번		
@return N/A
*/
this.fnCreateTopMenu = function (strID, strName, strUrl, index, nGapBtn, nHeight, strGroup)
{
	//trace("strName==="+strName + "::::strGroup==="+strGroup);
	// Creating page button
	var strFont = '500 24px "pre","Pretendard-Medium"'; // this.btn03._getCurrentStyleInheritValue("font").value;
	var nGroupGap = 0;
	if ( strGroup == "Y" ) {
		nGroupGap = 16;
	}
	var nWidth = nexacro.getTextSize( strName, strFont).nx + nGapBtn + nGroupGap;  // 40: padding
	
	var objBtn = new Button();
	objBtn.init(this.fv_TopBtnPrefix + strID, this.fvLastLeft, 0, nWidth, nHeight);
	this.divDispArea.form.divTopBtn.addChild(objBtn.name, objBtn);
	objBtn.set_initvalueid("iv_Button");
	objBtn.menuid = strID;
	objBtn._pageUrl = strUrl;
	objBtn.show();	
	
	objBtn.set_text(strName);
	if ( strGroup == "Y" ) {
		objBtn.set_cssclass("btn_TF_Mnu02");
		this.fnCreateSubMenuDiv(objBtn.menuid, this.fvLastLeft);
		objBtn.set_accessibilitylabel("닫힘 폴다운");
	} else {
		objBtn.set_cssclass("btn_TF_Mnu01");
		objBtn.set_accessibilitylabel("링크");
	}
	
	objBtn.orgcssclass = objBtn.cssclass;
	objBtn.setEventHandler("onclick", this.btnMenuButton_onclick, this);
	
	this.fvLastLeft += nWidth;
};


//서브메뉴 Div 만들기
this.fnCreateSubMenuDiv = function(sMenuId, nLeft)
{
	var objDiv = new Div();
	objDiv.init("divSubMenu_" + sMenuId, nLeft, 72, 226, 331);
	this.divDispArea.form.divTopBtn.form.addChild(objDiv.name, objDiv);
	objDiv.show();
	objDiv.set_visible(false);
	objDiv.set_accessibilityenable(true);
	//objDiv.set_accessibilityenable(false);
	objDiv.set_border("1px solid black");
	
	// test
	//objDiv.set_accessibilitylabel("test accesslabel");
	
	objDiv.setEventHandler("onkillfocus", this.divSubMenu_onkillfocus, this);	
	objDiv.setEventHandler("onmouseleave", this.divSubMenu_onmouseleave, this);	
}

/**
@class fnSetStyleTopMenu
@description 선택된 메뉴ID cssclass적용
@param  필수 {String} sMenuId - 메뉴ID
@return N/A
*/
this.fnSetStyleTopMenu = function (sMenuId)
{
	var objBtn;
	var objDs = this.dsMenu;
	var sTopMenuId = this.fnGetTopMenu(objDs, sMenuId);
	if ( this.smfIsNull(sTopMenuId) ) {
		sTopMenuId = sMenuId;
	}
	//trace("top menu === " + this.fnGetTopMenu(objDs, sMenuId));
	//trace("fnSetStyleTopMenu==="+sMenuId + "::::sTopMenuId==="+sTopMenuId);
	var arrComp = this.divDispArea.form.divTopBtn.form.components;
	for ( var i=0; i<arrComp.length; i++) {
		objBtn = arrComp[i];
		if ( objBtn.menuid == sTopMenuId ) {
			objBtn.set_cssclass( objBtn.orgcssclass + "S");
		}
		else {
			objBtn.set_cssclass(objBtn.orgcssclass);
		}
	}
};

this.fnGetTopMenu = function (objDs, sMenuId)
{
	var sPrtMenu = objDs.lookupNF("menuId", sMenuId, "parentMenuId");

	if ( this.smfIsNull(sPrtMenu) ) {
		return sMenuId;
	}
	else {
		return this.fnGetTopMenu(objDs, sPrtMenu);
	}
};



/**
@class fnCreateBtnList
@description 메뉴 or Student 버튼 creation
@param  필수 {String} strID - 버튼아이디
		필수 {String} strName - 버튼 text
		필수 {Number} nTop - 버튼 Top
		필수 {Number} nHeight - 버튼 Height
		필수 {String} sCss - 버튼 cssclass
		필수 {String} sType - 학생리스트 or 메뉴리스트 (MENU, STUDENT)
@return N/A
*/
this.fnCreateBtnList = function (strID, strName, nTop, nHeight, nGap, sCss, sType, objParentDiv)
{
	this.fvTest = objParentDiv;
	
	//trace("strID==="+strID + "::::::strName==="+strName);
	var objBtn = null;
	objBtn = new nexacro.Button();

	objBtn.init("btn_" + strID, 2, nTop, null, nHeight, 2, null);
	nTop = nTop + objBtn.getOffsetHeight() + nGap;
	
	if ( sType == "MENU" ) {
		objParentDiv.addChild(objBtn.name, objBtn);
	} else {
		objParentDiv.addChild(objBtn.name, objBtn);
	}
	objBtn.set_text(strName);	
	objBtn.set_cssclass(sCss);
	objBtn.set_initvalueid("iv_Button");
	if ( sType == "MENU" ) {
		objBtn.setEventHandler("onclick", this.btnSubMenuButton_onclick, this);
	} else {
		objBtn.setEventHandler("onclick", this.btnStudentButton_onclick, this);
	}
		
	objBtn.userdata_id = strID;
	objBtn.userdata_nm = strName;

	objBtn.show();
	//trace("objBtn==="+objBtn.name + ":::::::::nTop==="+nTop);
	return nTop;
};

/************************************************서브메뉴***********************************************/
/**
 * @description 메뉴버튼 클릭시
*/ 
this.btnMenuButton_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sUrl  = obj._pageUrl;
	var sMenuId = obj.menuid;

	//서브메뉴, 사용자정보, 학생리스트 div 닫기
	this.fnCloseDivs(["ALL"]);

//trace("sMenuId===="+sMenuId + "::::sUrl===="+sUrl);
	if(!this.smfIsNull(sUrl))
	{
		var params = {menu : sMenuId,_url : sUrl};
		this.smfSetWorkPage(sUrl, params, null, String(obj.text));
	}
	else {		
		this.fnCreateSubMenu(obj);
		obj.set_accessibilitylabel("열림 폴다운");
	}
};

/**
@class fnCreateSubMenu
@description Top메뉴 > 하위메뉴 생성
@param  필수 {String} strID - 버튼아이디
@return N/A
*/
this.fnCreateSubMenu = function (obj)
{
	this.dsMenu.filter("");
	this.dsMenu.filter("parentMenuId=="+obj.menuid+"&&isShow!='N'");
	this.dsMenuSub.copyData(this.dsMenu,true);
	
	if(this.dsMenuSub.getRowCount()  == 0) return;
	
	var objParentDiv = this.divDispArea.form.divTopBtn.form.components["divSubMenu_"+obj.menuid];
	
	
	this.fnInitBtnMenu(objParentDiv);

	var nTop = obj.getOffsetBottom() - 13;
 	var nHeight = this.dsMenuSub.getRowCount() * 56 + 20;
	objParentDiv.setOffsetTop(nTop);
	objParentDiv.setOffsetHeight(nHeight);
	objParentDiv.set_visible(true);
	
	this.divDispArea.form.divTopBtn.setOffsetHeight(72 + objParentDiv.getOffsetHeight());

	//top 높이 조절
	this.fnResetTopArea(58 + this.divDispArea.form.divTopBtn.getOffsetHeight(), this.objApp.mainframe.VFrameSet.frameMain.form.divAll.getOffsetTop());
	
	//Z-Index 조절
	this.fnSetZIndex(objParentDiv, true);		
};

//서브메뉴 버튼 만들기
this.fnInitBtnMenu = function(objParentDiv)
{
	var objDs = this.dsMenuSub;
	var sMenuId = "", sMenuNm = "", sCss = "", sType = "";
	var nTop = 17, nHeight = 40, nGap = 16;
	var sType = "MENU";
	
	
	for ( i=0; i<objDs.rowcount; i++) {
		sMenuId = objDs.getColumn(i,"menuId");
		sMenuNm = objDs.getColumn(i, "menuName");
		
		sCss = "btn_TF_2Mnu";

		nTop = this.fnCreateBtnList(sMenuId, sMenuNm, nTop, nHeight, nGap, sCss, sType, objParentDiv);
	}
	//this.pdvMenu.form.divMenu.form.setFocus();	
};

//메뉴실행 버튼 onclick 이벤트
this.btnSubMenuButton_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//this.pdvMenu.closePopup();
	//선택메뉴
	var sMenuId = obj.userdata_id;	
	var nSelRow = this.dsMenuSub.findRowNF("menuId", sMenuId);
	var sUrl    = this.dsMenuSub.getColumn(nSelRow, "menuUrl");
	//상위메뉴	
	var sParentMenuId = this.dsMenuSub.getColumn(nSelRow, "parentMenuId");
	var nRow =  this.dsMenu.findRowNF("menuId", sParentMenuId);
	var sParentName = this.dsMenu.getColumnNF( nRow, "menuName");
	var menuText = sParentName + "|" + this.dsMenuSub.getColumn(nSelRow, "menuName");
	
	if(!this.smfIsNull(sUrl))
	{		
		// 화면을 호출한다.
		var params = {menu : sMenuId,_url:sUrl};
		this.smfSetWorkPage(sUrl, params, null, menuText);
	}
};

//서브메뉴 Div 닫기
this.divSubMenu_onkillfocus = function(obj, e)
{
	this.fnCloseSubMenuDiv(obj);
}
this.divSubMenu_onmouseleave = function(obj, e)
{
	//서브Div 내에서 mouseleave는 취소함.
	var bFlag = this.fnFindChildComponent(obj, e.fromreferenceobject);
	if(bFlag) {
		e.preventDefault();
		return true;
	}
	
	this.fnCloseSubMenuDiv(obj);
};

this.fnFindChildComponent = function(oDiv, objTarget)
{
	if (!oDiv) return false;
	
	//자기 자신이면 true
	if (oDiv === objTarget) return oDiv;

	var comps = oDiv.form.components;
	for(var i = 0; i < comps.length; i++) {
		var comp = comps[i]
		
		if(comp instanceof Div) {
			//Div안의 Div체크
			var child = this.fnFindChildComponent(comps[i], objTarget);
			if (child) return child;
		} else {
			if(comp === objTarget) {
				return comp;
			}
		}
	}
	
	return false;
};

this.fnCloseSubMenuDiv = function(objDiv)
{
	objDiv.set_visible(false);

	//버튼 대체텍스트 변경
	var btnId = objDiv.id.replace("divSubMenu","TOP");
	var objBtn = this.divDispArea.form.divTopBtn.form.components[btnId];
	objBtn.set_accessibilitylabel("닫힘 폴다운");

	//SubMenuBtn 삭제
	this.fnRemoveChildComponents(objDiv);
	
	this.divDispArea.form.divTopBtn.setOffsetHeight(72);
	//top 높이 조절
	this.fnResetTopArea(58 + this.divDispArea.form.divTopBtn.getOffsetHeight(), "divTop:0");

	//Z-Index 조절
	this.fnSetZIndex(objDiv, false);	
};

/*********************************************학부모 정보**********************************************/
//내정보
this.divDispArea_divUser_btnUser_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divDispArea.form.divUser.form.divBtnUserWrap.form.btnUser.set_accessibilitylabel("열림 학부모정보");
	this.divDispArea.form.btnUserM.set_accessibilitylabel("열림");

	var divUserInfo = this.divDispArea.form.divUser.form.divUserInfo;
	
	//서브메뉴, 학생리스트 div 닫기
	this.fnCloseDivs(["MENU","STUDENT"]);

	var nLeft  = this.divDispArea.form.divUser.form.divBtnUserWrap.getOffsetLeft() - 100;
	var nHeight = 185;
	
	var objDs = this.objApp.gdsScrLgnChildList;		//자녀정보
	if ( objDs.rowcount > 1 ) {
		nHeight = nHeight + ((objDs.rowcount - 1) * 24);
	}

	//위치 조절
	divUserInfo.setOffsetHeight(nHeight);	
	divUserInfo.setOffsetLeft(nLeft);
	
	divUserInfo.form.fnInitMyInfo();		//팝업 설정
	
	divUserInfo.set_visible(true);
	
	this.divDispArea.form.divUser.setOffsetHeight(25 + divUserInfo.getOffsetHeight());
	
	//top 높이 조절
	this.fnResetTopArea(23 + this.divDispArea.form.divUser.getOffsetHeight(), this.objApp.mainframe.VFrameSet.frameMain.form.divAll.getOffsetTop());
	
	//Z-Index 조절
	this.fnSetZIndex(this.divDispArea.form.divUser, true);	
};

this.fnCloseUserDiv = function()
{
	if (!this.divDispArea.form.divUser.form.divUserInfo.visible) return;

	this.divDispArea.form.divUser.form.divBtnUserWrap.form.btnUser.set_accessibilitylabel("닫힘 학부모정보");
	this.divDispArea.form.btnUserM.set_accessibilitylabel("닫힘");
	this.divDispArea.form.divUser.form.divUserInfo.set_visible(false);
	this.divDispArea.form.divUser.setOffsetHeight(25);
	
	//top 높이 조절
	this.fnResetTopArea(130, "divTop:0");
	
	//Z-Index 조절
	this.fnSetZIndex(this.divDispArea.form.divUser, false);	
}

this.divDispArea_divUser_divUserInfo_onmouseleave = function(obj:nexacro.Div,e:nexacro.MouseEventInfo)
{
	//서브Div 내에서 mouseleave는 취소함. (TopMyInfo 내의 divStudent에서 마우스 빠졌을 때 꺼지지 않도록 함)
	if(this.fnFindChildComponent(obj, e.fromreferenceobject) ||
	   (e.fromreferenceobject.parent.id === "divStudent")) {
		e.preventDefault();
		return true;
	}
	
	this.fnCloseUserDiv();	
};

this.divDispArea_divUser_divUserInfo_onkillfocus = function(obj:nexacro.Div,e:nexacro.KillFocusEventInfo)
{
	this.fnCloseUserDiv();	
};


/**********************************************자녀 리스트*********************************************/
//자녀 리스트 버튼 클릭시
this.divDispArea_divUser_btnStudent_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	obj.set_accessibilitylabel("열림 자녀목록");
	
	var objDiv = this.divDispArea.form.divUser.form.divStudentInfo;
	
	//자녀정보 삭제
	this.fnRemoveChildComponents(objDiv);
	
	//서브메뉴, 사용자정보 div 닫기
	this.fnCloseDivs(["MENU","USER"]);
	
	var objDs = this.dsStudent;
	objDs.copyData(this.objApp.gdsScrLgnChildList);
	
	if(objDs.getRowCount()  == 0) return;
	
	this.fnInitBtnStudent(this.divDispArea.form.divUser.form.divStudentInfo);
	
	var nHeight = objDs.getRowCount() * 30 + 20;
	objDiv.setOffsetHeight(nHeight);
	objDiv.set_visible(true);
	
	this.divDispArea.form.divUser.setOffsetHeight(25 + objDiv.getOffsetHeight());

	//top 높이 조절
	this.fnResetTopArea(23 + this.divDispArea.form.divUser.getOffsetHeight(), this.objApp.mainframe.VFrameSet.frameMain.form.divAll.getOffsetTop());
	
	//Z-Index 조절
	this.fnSetZIndex(this.divDispArea.form.divUser, true);	
};

this.fnInitBtnStudent = function(objParentDiv)
{
	//자녀정보
	var objDs = this.dsStudent;
	var sChildNo = "", sChildNames = "", sCss = "", sType = "";
	var nTop = 18, nHeight = 28, nGap = 2;
	var sType = "STUDENT";
	
	var nFindRow = objDs.findRow("chcYn","Y");
	for ( i=0; i<objDs.rowcount; i++) {
		sChildNo    = objDs.getColumn(i,"chldNo");
		sChildNames = objDs.getColumn(i, "stdntNm");
		
		if ( i == nFindRow ) {
			sCss = "btn_TF_Stu_S";
		} else {
			sCss = "btn_TF_Stu_";
		}
		
		nTop = this.fnCreateBtnList(sChildNo, sChildNames, nTop, nHeight, nGap, sCss, sType, objParentDiv);
	}	
};

this.divDispArea_divUser_divStudentInfo_onmouseleave = function(obj:nexacro.Div,e:nexacro.MouseEventInfo)
{
	//서브Div 내에서 mouseleave는 취소함.
	if(this.fnFindChildComponent(obj, e.fromreferenceobject)) {
		e.preventDefault();
		return true;
	}
	
	this.fnCloseStudentDiv();		
};

this.divDispArea_divUser_divStudentInfo_onkillfocus = function(obj:nexacro.Div,e:nexacro.KillFocusEventInfo)
{
	
	this.fnCloseStudentDiv();			
};


this.fnCloseStudentDiv = function()
{
	if (!this.divDispArea.form.divUser.form.divStudentInfo.visible) return;

	this.divDispArea.form.divUser.form.divBtnStudentWrap.form.btnStudent.set_accessibilitylabel("닫힘 자녀목록");
	this.divDispArea.form.divUser.form.divStudentInfo.set_visible(false);
	this.divDispArea.form.divUser.setOffsetHeight(25);
	
	//top 높이 조절
	this.fnResetTopArea(130, "divTop:0");
	
	//Z-Index 조절
	this.fnSetZIndex(this.divDispArea.form.divUser, false);
};



//자녀리스트 버튼 onclick 이벤트
this.btnStudentButton_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnChangeChild(obj.userdata_id, obj.userdata_nm);
};


//자녀정보 변경
this.fnChangeChild = function(sValue, sText)
{
	trace("--------------------------------------------------------------------");
	trace("자녀변경 ::: ");
	trace("text ::: " + sText );
	trace("value ::: " + sValue );
	trace("--------------------------------------------------------------------");
	
	// 자녀 변경
	if ( sValue == this.fvUserInfo["childNo"] ) {
		trace("선택된 자녀입니다. ");
		return;
	}
	this.getOwnerFrame().form.doScrChldChg(sValue); //간편인증
};


/**
 * 팝업(div) 닫기
 * @param options {Array} ["ALL"] | ["MENU","USER","STUDENT"]
 */
this.fnCloseDivs = function(options)
{
	if (this.smfIsNull(options)) options = ["ALL"];
	
	//서브메뉴 닫기
	if (options.includes("ALL") || options.includes("MENU")) {
		var comp = this.divDispArea.form.divTopBtn.form.components;
		for (var i = 0; i< comp.length; i++) {
			if(comp[i] instanceof Div && comp[i].visible) this.fnCloseSubMenuDiv(comp[i]);
		}		
	}

	//사용자/학생리스트 닫기
	if (options.includes("ALL")  || options.includes("USER")) {
		this.fnCloseUserDiv();
	}
	if (options.includes("ALL") || options.includes("STUDENT")) {
		this.fnCloseStudentDiv();
	}
};

//동적 생성된 버튼 삭제
this.fnRemoveChildComponents = function(objDiv)
{
	var objComps = objDiv.form.components;
	var objCompsLen = objComps.length -1;

	for ( var i = objCompsLen; i >= 0; i--) {
		var objRtn = objDiv.removeChild(objComps[i].name);
		objRtn.destroy();
		objRtn = null;
	}		
};


//Top영역 높이 조절
this.fnResetTopArea = function(nHeight, nTop)
{
	var mainForm = this.objApp.mainframe.VFrameSet.frameMain.form;
	mainForm.divTop.setOffsetHeight(nHeight);
	mainForm.divAll.setOffsetTop(nTop);
	mainForm.resetScroll();
};

//Zindex조절
this.fnSetZIndex = function(divObj, bFront)
{
	var elemDiv = divObj.getElement();
	var elemTop = this.objApp.mainframe.VFrameSet.frameMain.form.divTop.getElement();
	
	if(elemDiv && elemTop) {
		if (bFront) {
			elemDiv.setElementZIndex(1);
			elemTop.setElementZIndex(1);
		} else {
			elemDiv.setElementZIndex("");
			elemTop.setElementZIndex("");
		}
	}
};

this.divDispArea_divTopBtn_onmouseleave = function(obj:nexacro.Div,e:nexacro.MouseEventInfo)
{
	if(this.smfIsNull(this.fvTest)) return false;
	trace(e.canvasy);
	
	if (e.canvasy >= 59) return false;
	
	trace("fvTest:: " + this.fvTest.id);
	
	this.fnCloseSubMenuDiv(this.fvTest);
	return true;
};
]]></Script>
  </Form>
</FDL>
