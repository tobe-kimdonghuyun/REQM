    <Script type="xscript5.1"><![CDATA[/**
*  학부모소통시스템
*  @MenuPath    공통
*  @FileName 	frameTopMenu.xfdl
*  @Creator 	tobesoft
*  @CreateDate 	2025.03.17
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2025.03.17     	tobesoft 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::scr_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.objApp = nexacro.getApplication();

/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	//trace("frameTopMenu onload >>>>>>>");
	this.fnSetMenuDs();
};


/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/* 메뉴 접근 가능 여부 */
this.fnMenuLgnChk = function(sUrl){
	return true;
	//trace("======================================================================================");
	//trace("sUrl ::: " + sUrl );
	//trace("smfIsLogin ::: " + this.smfIsLogin() );
	//trace("======================================================================================");

	if("pa_scr_ctr_cr::scr_ctrcr00_m00.xfdl" == sUrl || "pa_scr_ctr_ir::scr_ctrir00_m00.xfdl" == sUrl 
		|| "pa_scr_ctr_oc::scr_ctroc00_m00.xfdl" == sUrl || "pa_scr_mri_cl::scr_mricl02_m02.xfdl" == sUrl
		|| "pa_scr_mri_cl::scr_mricl00_m00.xfdl" == sUrl || "pa_scr_mri_cl::scr_mricl01_m00.xfdl" == sUrl
		|| "pa_scr_mri_cl::scr_mricl02_m00.xfdl" == sUrl){
	
		if(this.smfIsLogin() ){
			return true;
		}else{
			return false;
		}	
	}else{
		return true;
	}

}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.fnSetMenuDs = function()
{
	//if ( this.dsMenu.rowcount > 0 ) return;
	
	//this.dsMenu.copyData(this.parent.parent.divTop.form.dsMenu);
	this.dsMenu.appendData(this.dsMenuExpand);
	this.dsMenu.filter("isShow!='N'");
};

//닫기버튼
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
// 	// 메인화면을 호출한다.
// 	var sUrl   = "frame::scr/frameWorkMain.xfdl";
// 	var params = {menu : "MAIN",_url:sUrl};
// 	this.smfSetWorkPage(sUrl, params, null, "HOME");
// 	
	this.parent.parent.fnHidePopDiv("menu");
};

//메뉴버튼 클릭시
this.btnMenu_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sMenuLinkUrl = obj.menuLinkUrl;	
	if ( this.smfIsNull(sMenuLinkUrl) ) return;
	
	if(this.fnMenuLgnChk(sMenuLinkUrl)){

		//trace("======================================================================================");
		//trace("sMenuLinkUrl::: " +sMenuLinkUrl );			
		//trace("======================================================================================");
	
		if("btnCrI" == sMenuLinkUrl || "btnIrI" == sMenuLinkUrl || "btnOrI" == sMenuLinkUrl ){ // 이용가이드인 경우
			var tabInfo = 0; 
			
			if("btnCrI" == sMenuLinkUrl){ // 상시상담안내
				tabInfo = 0;
			}else if("btnIrI" == sMenuLinkUrl){ // 집중상담안내
				tabInfo = 1;
			}else if("btnOrI" == sMenuLinkUrl){ // 온라인(서면)상담안내
				tabInfo = 2;
			}

			// 이동
			var sUrl   = "pa_scr_cmm_cm::scr_guide00.xfdl";
			var params = {menu : "B005", _url:sUrl, tabIndex:tabInfo};
			this.smfSetWorkPage(sUrl, params, null, obj.text);	
			
			this.getOwnerFrame().form.fnHidePopDiv("menu");
		}else{

			////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
			//  집중상담기간이 아닌 경우 메뉴 진입 불가 처리 시작
			////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
			if("pa_scr_ctr_ir::scr_ctrir00_m00.xfdl" ==  sMenuLinkUrl){ // 메뉴 ::: 집중상담예약
				var cnctrDscsnPrdYn = nexacro.getApplication().gdsScrLgnChildList.lookup("chcYn", "Y", "cnctrDscsnPrdYn"); // 집중상담기간여부
				
				//trace("=============================================================================================================");
				//trace("frameTopMenu ::: cnctrDscsnPrdYn ::: " + cnctrDscsnPrdYn );	
				//trace("=============================================================================================================");

				if("N" == cnctrDscsnPrdYn){				
					////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
					// 알럿
					////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
					this.scrAlert("집중상담기간이 아닙니다.", null, function (result){ // 집중상담기간이 아닙니다.
					
						// 메인화면을 호출한다.
						//this.fnStartMainForm();
						return;
						
					});
					////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
					// 알럿
					////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
				
					return;					
				}

			}	
			////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
			//  집중상담기간이 아닌 경우 메뉴 진입 불가 처리 종료
			////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

			var sUrl   = sMenuLinkUrl;
			var params = {menu : "",_url:sUrl};
			this.smfSetWorkPage(sUrl, params, null, obj.text);
			
			this.getOwnerFrame().form.fnHidePopDiv("menu");		
		}
	}else{
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		// 알럿
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		//this.scrAlert("CP001", null, function (result){ //사용자 로그인이 필요합니다.
		this.scrAlert("로그인이 필요한 서비스입니다.", null, function (result){ // 로그인이 필요한 서비스입니다.
			return false;
		});
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		// 알럿
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	}
};

//그리드 메뉴 클릭시
this.divMenuM_grdMenu_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var oBindDs = obj.getBindDataset();
	var sMenuLinkUrl = oBindDs.getColumn(e.row, "menuUrl");
	if ( this.smfIsNull(sMenuLinkUrl) ) return;
	
	if(this.fnMenuLgnChk(sMenuLinkUrl)){
	
		if("btnCrI" == sMenuLinkUrl || "btnIrI" == sMenuLinkUrl || "btnOrI" == sMenuLinkUrl ){ // 이용가이드인 경우
			var tabInfo = 0; 
			
			if("btnCrI" == sMenuLinkUrl){ // 상시상담안내
				tabInfo = 0;
			}else if("btnIrI" == sMenuLinkUrl){ // 집중상담안내
				tabInfo = 1;
			}else if("btnOrI" == sMenuLinkUrl){ // 온라인(서면)상담안내
				tabInfo = 2;
			}

			// 이동
			var sUrl   = "pa_scr_cmm_cm::scr_guide00.xfdl";
			var params = {menu : "B005", _url:sUrl, tabIndex:tabInfo};
			this.smfSetWorkPage(sUrl, params, null, obj.text);	
			
			this.getOwnerFrame().form.fnHidePopDiv("menu");
		}else{
		
			////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
			//  집중상담기간이 아닌 경우 메뉴 진입 불가 처리 시작
			////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
			if("pa_scr_ctr_ir::scr_ctrir00_m00.xfdl" ==  sMenuLinkUrl){ // 메뉴 ::: 집중상담예약
				var cnctrDscsnPrdYn = nexacro.getApplication().gdsScrLgnChildList.lookup("chcYn", "Y", "cnctrDscsnPrdYn"); // 집중상담기간여부
				
				//trace("=============================================================================================================");
				//trace("frameTopMenu ::: cnctrDscsnPrdYn ::: " + cnctrDscsnPrdYn );	
				//trace("=============================================================================================================");

				if("N" == cnctrDscsnPrdYn){				
					////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
					// 알럿
					////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
					this.scrAlert("집중상담기간이 아닙니다.", null, function (result){ // 집중상담기간이 아닙니다.
					
						// 메인화면을 호출한다.
						//this.fnStartMainForm();
						return;
						
					});
					////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
					// 알럿
					////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
				
					return;					
				}

			}	
			////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
			//  집중상담기간이 아닌 경우 메뉴 진입 불가 처리 종료
			////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		
			var sUrl   = sMenuLinkUrl;
			var params = {menu : "",_url:sUrl};
			this.smfSetWorkPage(sUrl, params, null, obj.text);
			
			this.getOwnerFrame().form.fnHidePopDiv("menu");		
		}
	}else{
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		// 알럿
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		//this.scrAlert("CP001", null, function (result){ //사용자 로그인이 필요합니다.
		this.scrAlert("로그인이 필요한 서비스입니다.", null, function (result){ // 로그인이 필요한 서비스입니다.
			return false;
		});
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		// 알럿
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////	
	}
};
this.divMenuM_btnGuide_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objEnv  = nexacro.getEnvironment();
	var sUrl    = objEnv.services["baseUrl"].url + "/doc/edu/pa/scr/학부모소통(이어드림) 사용자매뉴얼.pdf";
	system.execBrowser(sUrl);
};
]]></Script>
  </Form>
</FDL>
