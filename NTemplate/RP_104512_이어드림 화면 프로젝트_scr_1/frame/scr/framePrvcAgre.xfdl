    </Layouts>
    <Objects>
      <Dataset id="ds_data01">
        <ColumnInfo>
          <Column id="제공받는자" type="STRING" size="256"/>
          <Column id="제공목적" type="STRING" size="256"/>
          <Column id="제공항목" type="STRING" size="256"/>
          <Column id="보유이용기간" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="제공받는자">시도교육청</Col>
            <Col id="제공목적">상담 신청 처리</Col>
            <Col id="제공항목">신청자 정보 및 신청녀액</Col>
            <Col id="보유이용기간">3년</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">savePrvcAgreInfo</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResult=dsResult</Col>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp"/>
            <Col id="url">/scr_cmm_cm00_002.do</Col>
            <Col id="bindingControls"/>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="esntlPrvcGthAgreYn" type="STRING" size="256" description="필수개인정보수집동의여부"/>
          <Column id="chcPrvcGthAgreYn" type="STRING" size="256" description="선택개인정보수집동의여부"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsResult" useclientlayout="true">
        <ColumnInfo>
          <Column id="code" type="STRING" size="256" description="연계상태값"/>
          <Column id="message" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  학부모소통시스템
*  @MenuPath    공통
*  @FileName 	framePrvcAgre.xfdl
*  @Creator 	tobesoft
*  @CreateDate 	2025.04.30
*  @Desction    개인정보동의
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2025.04.30     	tobesoft 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::scr_script.xjs";	//SCR공통라이브러리(필수)

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.beMenuUrl = "";	


/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{	
	this.scrInitForm(obj);	//화면초기화 공통함수(필수)
	
	//trace("=============================================================================================================");
	//trace("prvcAgreUrl ::: " +nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'prvcAgreUrl')  );	
	//trace("=============================================================================================================");
 
	this.beMenuUrl = nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'prvcAgreUrl') ;
	
	nexacro.getApplication().gdsScrLgnInfo.setColumn(0,"prvcAgreUrl", "");	

	//trace("=============================================================================================================");
	//trace("this.beMenuUrl ::: " + this.beMenuUrl );	
	//trace("bePrvcAgreUrl ::: " + nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'prvcAgreUrl')  );	
	//trace("=============================================================================================================");
	
};


/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 /* 기본 트랙잭션 콜백 */
 this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/


/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

/* 무두 동의 클릭 */
this.checkBoxAll_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	trace("=============================================================================================================");
	trace("this.checkBoxAll.isChecked() ::: " + this.checkBoxAll.isChecked() );	
	trace("=============================================================================================================");
	
	if(this.checkBoxAll.isChecked()){ // 체크
		this.checkBoxPrvc01.set_value(true);
		this.checkBoxPrvc02.set_value(true);
		this.checkBoxPrvc03.set_value(true);
	}else{ // 미체크
		this.checkBoxPrvc01.set_value(false);
		this.checkBoxPrvc02.set_value(false);
		this.checkBoxPrvc03.set_value(false);	
	}	
	
};


/* 취소버튼 */
this.Button20_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 메인화면 이동
	var sUrl   =  "frame::scr/frameWorkMain.xfdl";
	var params = {menu : "",_url:sUrl};
	this.smfSetWorkPage(sUrl, params, null, obj.text);
};

	
/* 확인버튼 */
this.Button12_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		// 개인정보수집 동의여부 체크 시작
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		if(!this.checkBoxPrvc01.isChecked()){ // 개인정보 수집동의

			this.scrAlert("개인정보 수집동의는 필수항목입니다.", null, function (result){ // 개인정보 수집동의는 필수항목입니다.
			
				this.checkBoxPrvc01.setFocus();
			
				return false;
			});

			return false;
			
		}
		
		if(!this.checkBoxPrvc02.isChecked()){ // 민감정보 수집동의

			this.scrAlert("민감정보 수집동의는 필수항목입니다.", null, function (result){ // 민감정보 수집동의는 필수항목입니다.
			
				this.checkBoxPrvc02.setFocus();
			
				return false;
			});

			return false;
			
		}
		
		if(!this.checkBoxPrvc03.isChecked()){ // 민감정보 수집동의

			this.scrAlert("개인정보 제3자 제공동의는 필수항목입니다.", null, function (result){ // 개인정보 제3자 제공동의는 필수항목입니다.
			
				this.checkBoxPrvc03.setFocus();
			
				return false;
			});

			return false;
			
		}
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		// 개인정보수집 동의여부 체크 종료
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		// 처리 시작
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		this.scrConfirm("PA060", ["개인정보 수집·이용 동의"], function (result){
		
			if(result.confirmResult){
								
				this.dsSearch.setColumn(0, "esntlPrvcGthAgreYn", "Y"); // 필수개인정보수집동의여부 SET
				this.dsSearch.setColumn(0, "chcPrvcGthAgreYn", "N"); // 선택개인정보수집동의여부 SET

				// 서비스 객체 생성
				this.smfSaveService("savePrvcAgreInfo")
					.showConfirm(false)
					.run()// 실행
					// 콜백
					.callback(function(callbackParams){
						if(callbackParams.errors) return;
						
						trace("=============================================================================================================");
						trace("::: 성공 ::: ");
						trace("=============================================================================================================");

						// 개인정보 동의여부 글로벌변수 변경
						nexacro.getApplication().gdsScrLgnInfo.setColumn(0,"mnrDsgnYn", "Y");	

						// 해당화면 이동
						var sUrl   = this.beMenuUrl;
						var params = {menu : "",_url:sUrl};
						this.smfSetWorkPage(sUrl, params, null, obj.text);
						
					});	

			}
		});
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		// 처리 종료
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
};



this.Static00_00_00_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	
};
]]></Script>
  </Form>
</FDL>
