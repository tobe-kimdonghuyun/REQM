<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="scr_site01" width="1340" height="953" titletext="개인정보동의" onload="form_onload">
    <Layouts>
      <Layout height="953" width="1340" screenid="desktopScr">
        <Static id="Static09" taborder="0" text="개인정보 수집·이용 동의" left="20" top="0" height="95" cssclass="sta_WF_Title" accessibilityrole="heading" right="0" onclick="Static09_onclick"/>
        <CheckBox id="checkBoxPrvc01" taborder="1" width="32" height="34" value="false" top="Static09:-5" onclick="Div01_CheckBox03_onclick" initvalueid="iv_CheckBox" padding="3px" left="20" accessibilitylabel="개인정보 수집동의 (필수)"/>
        <Static id="Static01" taborder="2" text="개인정보 수집동의 &lt;fc v='#c43636'&gt;(필수)&lt;/fc&gt;" left="checkBoxPrvc01:5" top="Static09:0" height="24" cssclass="sta_WF_Txt18M" usedecorate="true" right="0"/>
        <Static id="Static00" taborder="3" text="가. 개인정보의 수집 및 이용목적&#13;&#10;     · 상담 신청자에 대한 신청 내용 확인, 방문 예약 승인 및 답변 처리&#13;&#10;나. 수집하는 개인정보의 항목&#13;&#10;     · 신청자 수집정보: &lt;b v='true'&gt;(필수) &lt;fc v='#c43636'&gt;학부모 성명, 학부모 연락처&lt;/fc&gt;&lt;/b&gt;&#13;&#10;다. 개인정보의 보유 및 이용기간: &lt;b v='true'&gt;&lt;fc v='#c43636'&gt;3년&lt;/b&gt;&lt;/fc&gt;" left="20" top="Static01:15" height="117" fittocontents="height" cssclass="sta_WF_SiteTxtBox" right="0" usedecorate="true"/>
        <CheckBox id="checkBoxPrvc02" taborder="4" width="32" height="34" value="false" top="Static00:35" onclick="Div01_CheckBox03_onclick" initvalueid="iv_CheckBox" padding="3px" left="20" accessibilitylabel="민감정보 수집동의 (필수)"/>
        <Static id="Static01_00" taborder="5" text="민감정보 수집동의 &lt;fc v='#c43636'&gt;(필수)&lt;/fc&gt;" left="checkBoxPrvc02:5" top="Static00:40" height="24" right="0" cssclass="sta_WF_Txt18M" usedecorate="true"/>
        <Static id="Static00_00" taborder="6" text="가. 민감정보의 수집 및 이용목적&#13;&#10;     · 온라인 학부모 소통 서비스 운영&#13;&#10;나. 수집하는 민감정보의 항목: &lt;b v='true'&gt;(필수) &lt;fc v='#c43636'&gt;상담 신청내역(제목, 내용, 첨부파일)&lt;/fc&gt;&lt;/b&gt;&#13;&#10;다. 민감정보의 보유 및 이용기간: &lt;b v='true'&gt;&lt;fc v='#c43636'&gt;3년&lt;/b&gt;&lt;/fc&gt;" left="20" top="Static01_00:15" height="101" fittocontents="height" cssclass="sta_WF_SiteTxtBox" right="0" usedecorate="true"/>
        <CheckBox id="checkBoxPrvc03" taborder="7" width="32" height="34" value="false" top="Static00_00:35" onclick="Div01_CheckBox03_onclick" initvalueid="iv_CheckBox" padding="3px" left="20" accessibilitylabel="개인정보 제3자 제공동의 (필수)"/>
        <Static id="Static01_00_00" taborder="8" text="개인정보 제3자 제공동의 &lt;fc v='#c43636'&gt;(필수)&lt;/fc&gt;" left="checkBoxPrvc03:5" top="Static00_00:40" height="24" right="0" cssclass="sta_WF_Txt18M" usedecorate="true"/>
        <Grid id="Grid00" taborder="9" left="20" top="Static01_00_00:15" height="108" right="0" binddataset="ds_data01" selecttype="cell" cssclass="grd_WF_Site" showselection="true" showcellselection="true" initvalueid="iv_Grid0_TabstopF" autofittype="col" scrollbartype="auto none">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="100"/>
                <Column size="105"/>
                <Column size="136"/>
                <Column size="110"/>
              </Columns>
              <Rows>
                <Row size="47" band="head"/>
                <Row size="60"/>
              </Rows>
              <Band id="head">
                <Cell text="제공받는 자"/>
                <Cell col="1" text="제공 목적"/>
                <Cell col="2" text="제공 항목"/>
                <Cell col="3" text="보유·이용기간"/>
              </Band>
              <Band id="body">
                <Cell text="bind:제공받는자" displaytype="text"/>
                <Cell col="1" text="bind:제공목적" displaytype="text"/>
                <Cell col="2" text="bind:제공항목" displaytype="text"/>
                <Cell col="3" text="bind:보유이용기간" displaytype="text" cssclass="cell_WF_End"/>
              </Band>
            </Format>
            <Format id="format00">
              <Columns>
                <Column size="48"/>
                <Column size="48"/>
                <Column size="48"/>
                <Column size="48"/>
                <Column size="48"/>
              </Columns>
              <Rows>
                <Row size="47" band="head"/>
                <Row size="120"/>
              </Rows>
              <Band id="head">
                <Cell text="서비스명"/>
                <Cell col="1" text="개인정보파일"/>
                <Cell col="2" text="보유기간"/>
                <Cell col="3" text="홈페이지"/>
                <Cell col="4" text="수집항목"/>
              </Band>
              <Band id="body">
                <Cell text="bind:서비스명" displaytype="text"/>
                <Cell col="1" text="bind:개인정보파일" displaytype="text"/>
                <Cell col="2" text="bind:보유기간" displaytype="text"/>
                <Cell col="3" text="bind:홈페이지" displaytype="text"/>
                <Cell col="4" cssclass="cell_WF_End" text="bind:수집항목" displaytype="text"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="Static01_00_00_00" taborder="10" text="동의를 거부할 권리 등 동의 거부에 따른 안내" left="20" top="Grid00:40" height="24" right="0" cssclass="sta_WF_SiteTitle01" usedecorate="true"/>
        <Static id="Static00_00_00" taborder="11" text="· 사용자는 본 안내에 따른 제 3자 제공에 대하여 거부하실 수 있는 권리가 있습니다.&#13;&#10;본 개인정보 제3자 제공을 거부하는 경우 상담 신청이 진행되지 않습니다." left="20" top="Static01_00_00_00:15" height="68" fittocontents="height" cssclass="sta_WF_SiteTxtBox" right="0" usedecorate="true" onclick="Static00_00_00_onclick"/>
        <CheckBox id="checkBoxAll" taborder="12" text="모두 동의합니다." width="174" height="35" value="false" top="Static00_00_00:40" initvalueid="iv_CheckBox" padding="5px" left="20" onclick="checkBoxAll_onclick"/>
        <Static id="Static03_01" taborder="13" left="20" top="checkBoxAll:40" height="46" right="0" cssclass="sta_WF_SiteTitle02"/>
        <Button id="Button12_00" taborder="14" text="확인" top="checkBoxAll:73" height="40" width="72" initvalueid="iv_Button" right="35" cssclass="btn_WF_Crud04" onclick="Button12_00_onclick"/>
        <Button id="Button20" taborder="15" text="취소" top="checkBoxAll:73" height="40" width="74" left="55" cssclass="btn_WF_Crud01" initvalueid="iv_Button" onclick="Button20_onclick"/>
      </Layout>
      <Layout height="953" mobileorientation="Portrait" name="tablet" type="default" width="800" screenid="desktopScr,tabletScr">
        <Grid id="Grid00" left="20" top="Static01_00_00:15" height="108" right="0"/>
        <Button id="Button20" left="55" top="checkBoxAll:73" width="74" height="40"/>
        <Button id="Button12_00" top="checkBoxAll:73" width="72" height="40" right="35"/>
        <CheckBox id="checkBoxPrvc03" top="Static00_00:35" left="20" width="32" height="34"/>
      </Layout>
      <Layout height="1019" mobileorientation="Portrait" name="mobile" type="default" width="480" screenid="desktopScr,mobieScr">
        <Static id="Static09" left="15" top="0" height="60" right="15" cssclass="sta_WF_TitleM"/>
        <Static id="Static01" left="checkBoxPrvc01:5" top="Static09:26" height="24" right="0"/>
        <Static id="Static01_00" right="0" left="checkBoxPrvc02:5" top="Static00:40" height="24"/>
        <Static id="Static01_00_00" right="0" left="checkBoxPrvc03:5" top="Static00_00:40" height="24"/>
        <Grid id="Grid00" autofittype="none" scrollbartype="autoindicator none" left="15" top="Static01_00_00:15" height="108" right="15"/>
        <CheckBox id="checkBoxPrvc01" left="15" top="Static09:21" height="34" width="32" text=""/>
        <Static id="Static00" left="15" top="Static01:15" height="112" right="15"/>
        <CheckBox id="checkBoxPrvc02" left="15" top="Static00:35" height="34" width="32"/>
        <Static id="Static00_00" left="15" top="Static01_00:15" height="112" right="15"/>
        <CheckBox id="checkBoxPrvc03" left="15" top="Static00_00:35" height="34" width="32"/>
        <Static id="Static01_00_00_00" left="15" top="Grid00:40" height="24" right="15"/>
        <Static id="Static00_00_00" left="15" top="Static01_00_00_00:15" height="80" right="15"/>
        <CheckBox id="checkBoxAll" left="15" top="Static00_00_00:40" height="35" width="174"/>
