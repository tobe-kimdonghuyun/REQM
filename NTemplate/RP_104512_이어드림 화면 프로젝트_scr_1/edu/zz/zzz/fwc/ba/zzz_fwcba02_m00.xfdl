              <Combo id="cboBusnScCd" taborder="5" left="staBusnScCd:0" top="11" width="150" height="30" innerdataset="dsBunsCd" codecolumn="businessCode" onitemchanged="divSearch_cboBusnScCd_onitemchanged" datacolumn="businessNm"/>
              <Button id="btnSearch" top="11" width="74" height="30" taborder="10" text="조회" tooltiptext="조회" onclick="divSearch_btnSearch_onclick" cssclass="btn_WF_Search03" right="20"/>
              <Static id="staBusnScCd00" taborder="6" text="실행일자" left="670" top="11" height="30" cssclass="sta_WF_Searchtxt01" width="85"/>
