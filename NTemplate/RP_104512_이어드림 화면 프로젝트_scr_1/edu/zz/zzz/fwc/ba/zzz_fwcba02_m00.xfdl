              <Static id="staTxt21" taborder="11" text="FILTER COUNT" left="433" top="123" width="154" height="42" cssclass="sta_WF_Input01"/>
              <Static id="staTxt24" taborder="13" text="COMMIT COUNT" left="0" top="164" width="154" height="42" cssclass="sta_WF_Input01"/>
              <Static id="staTxt27" taborder="15" text="ROLLBACK COUNT" left="433" top="164" width="154" height="42" cssclass="sta_WF_Input01"/>
              <Static id="staTxt30" taborder="17" left="0" top="205" width="154" height="127" cssclass="sta_WF_Input01" text="종료메시지"/>
              <TextArea id="txtExitMessage" taborder="18" left="159" top="211" width="673" height="115" readonly="true"/>
