      </Dataset>
      <Dataset id="dsSearchStepParam">
        <ColumnInfo>
          <Column id="jobExecutionId" type="STRING" size="256" description="JobId"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsStep" useclientlayout="true" preload="true">
        <ColumnInfo>
          <Column id="stepName" type="STRING" size="256"/>
          <Column id="stepExecutionId" type="STRING" size="256"/>
          <Column id="createTime" type="STRING" size="256"/>
          <Column id="startTime" type="STRING" size="256"/>
          <Column id="endTime" type="STRING" size="256"/>
          <Column id="readCount" type="STRING" size="256"/>
          <Column id="writeCount" type="STRING" size="256"/>
          <Column id="commitCount" type="STRING" size="256"/>
          <Column id="rollbackCount" type="STRING" size="256"/>
          <Column id="filterCount" type="STRING" size="256"/>
          <Column id="readSkipCount" type="STRING" size="256"/>
          <Column id="writeSkipCount" type="STRING" size="256"/>
          <Column id="processSkipCount" type="STRING" size="256"/>
          <Column id="status" type="STRING" size="256"/>
          <Column id="exitCode" type="STRING" size="256"/>
          <Column id="exitMessage" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.edtJobName" propid="value" datasetid="dsSearch" columnid="jobName"/>
      <BindItem id="item1" compid="divSearch.form.edtJobKorName" propid="value" datasetid="dsSearch" columnid="jobKorName"/>
      <BindItem id="item2" compid="divSearch.form.calFrom" propid="value" datasetid="dsSearch" columnid="startTime"/>
      <BindItem id="item3" compid="divSearch.form.calTo" propid="value" datasetid="dsSearch" columnid="endTime"/>
      <BindItem id="item4" compid="divStepDetail.form.edtStepId" propid="value" datasetid="dsStepDetail" columnid="stepExecutionId"/>
      <BindItem id="item5" compid="divStepDetail.form.edtStatus" propid="value" datasetid="dsStepDetail" columnid="status"/>
      <BindItem id="item9" compid="divStepDetail.form.edtReadCount" propid="value" datasetid="dsUserInfoSave" columnid="userNm"/>
      <BindItem id="item10" compid="divStepDetail.form.edtWriteCount" propid="value" datasetid="dsUserInfoSave" columnid="userNm"/>
      <BindItem id="item11" compid="divStepDetail.form.edtFilterCount" propid="value" datasetid="dsUserInfoSave" columnid="userNm"/>
      <BindItem id="item12" compid="divStepDetail.form.edtCommitCount" propid="value" datasetid="dsUserInfoSave" columnid="userNm"/>
      <BindItem id="item13" compid="divStepDetail.form.edtRollbackCount" propid="value" datasetid="dsUserInfoSave" columnid="userNm"/>
    </Bind>
  </Form>
</FDL>
