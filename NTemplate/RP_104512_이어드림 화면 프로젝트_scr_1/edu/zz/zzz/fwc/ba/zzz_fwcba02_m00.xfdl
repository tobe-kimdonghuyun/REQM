        <Grid id="grdBatchJobList" taborder="2" left="0" top="142" width="650" binddataset="dsMain" autoenter="select" cellcombopopuptype="none" oncellclick="grdBatchJobList_oncellclick" onheadclick="grdBatchJobList_onheadclick" autofittype="col" bottom="10" cellsizingtype="col">
