                <Cell col="2" displaytype="combotext" edittype="none" comboautoselect="false" combocodecol="businessCode" combodatacol="businessNm" combodataset="dsBunsCd" text="bind:businessCode" textAlign="center"/>
                <Cell col="3" text="bind:status" edittype="none" textAlign="center"/>
