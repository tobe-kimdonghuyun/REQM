        </Div>
        <Static id="staStep" taborder="3" text="Step실행결과" left="680" top="102" height="30" cssclass="sta_WF_Tit18" font="normal 14pt/normal &quot;Arial&quot;" width="128"/>
        <Static id="staStepDetail" taborder="5" text="Step실행상세결과" left="680" top="372" height="30" cssclass="sta_WF_Tit18" font="normal 14pt/normal &quot;Arial&quot;" width="302"/>
        <Static id="Static99_00_00_00_00" taborder="7" left="0" top="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
        <Static id="Static99_00_00_00_00_00" taborder="8" left="0" top="82" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
        <Static id="Static99_00_00_00_00_00_00" taborder="9" left="0" top="132" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
        <Static id="Static99_00_00_00_00_00_00_01" taborder="10" left="650" top="142" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="0"/>
        <Static id="Static99_00_00_00_00_00_00_00" taborder="11" left="680" top="402" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
        <Static id="Static99_00_00_00_00_00_00_00_00" taborder="12" left="680" top="352" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
        <Static id="Static99_00_00_00_00_00_00_00_01" taborder="13" left="0" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" height="10" bottom="0"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    배치관리
*  @FileName 	zzz_fwcba00_m00.xfdl 
*  @Creator 	이준우
*  @CreateDate 	2022.01.02
*  @Desction    form CRUD 샘플
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.01.02     	   이준우 	                최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::cm_script.xjs" 

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);
	this.divSearch.form.cboBusnScCd.set_index(0);
	//날짜셋팅 함수확인후 재작업 필요
	var objDate = new Date();
	sToday  = objDate.getFullYear().toString();
	sToday += this.smfRight("0" + (objDate.getMonth() + 1), 2);
	sToday += this.smfRight("0" + objDate.getDate(), 2);
	this.divSearch.form.calFrom.set_value(objDate);
	this.divSearch.form.calTo.set_value(objDate);
	// 조회 입력값 엔터키입력시 조회수행 이벤트 설정
	this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 조회
*/
this.fnSearch = function ()
{ 
 	// 서비스 객체 생성
	this.smfSearchService("listBatchJobMonitoring")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});
};

/**
 * @description 조회
*/
this.fnSearchStepList = function (pos)
{ 
	this.dsSearchStepParam.setColumn(0, "jobExecutionId", this.dsMain.getColumn(pos, "jobExecutionId"));
 	// 서비스 객체 생성
	this.smfSearchService("listBatchStepMonitoring")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});
};

/**
 * @description 상세조회셋팅
*/
this.fnSetStepDetailList = function (pos)
{ 
	//필터 초기화
	this.divStepDetail.form.edtStepId.set_value(this.dsStep.getColumn(pos, "stepName"));
	this.divStepDetail.form.edtStatus.set_value(this.dsStep.getColumn(pos, "status"));
	this.divStepDetail.form.calCreateDate.set_value(this.dsStep.getColumn(pos, "createTime"));
	this.divStepDetail.form.calStartTime.set_value(this.dsStep.getColumn(pos, "startTime"));
	this.divStepDetail.form.calEndTime.set_value(this.dsStep.getColumn(pos, "endTime"));
	this.divStepDetail.form.edtReadCount.set_value(this.dsStep.getColumn(pos, "readCount"));
	this.divStepDetail.form.edtWriteCount.set_value(this.dsStep.getColumn(pos, "writeCount"));
	this.divStepDetail.form.edtFilterCount.set_value(this.dsStep.getColumn(pos, "filterCount"));
	this.divStepDetail.form.edtCommitCount.set_value(this.dsStep.getColumn(pos, "commitCount"));
	this.divStepDetail.form.edtRollbackCount.set_value(this.dsStep.getColumn(pos, "rollbackCount"));
	this.divStepDetail.form.txtExitMessage.set_value(this.dsStep.getColumn(pos, "exitMessage"));
};


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
*/

this.fnTransCallback = function(svcid,errcd, errmsg){

	if(errcd == -1) return;
	
	if(svcid == "listBatchJobMonitoring"){
		//Job실행결과가 있을경우에만 Step실행결과조회
		if(this.dsMain.rowcount > 0){
			this.dsMain.set_rowposition(0);
			this.grdBatchJobList.setFocus(true, true);
			this.dsSearchStepParam.setColumn(0, "jobExecutionId", this.dsMain.getColumn(0, "jobExecutionId"));
			// 서비스 객체 생성
			this.smfSearchService("listBatchStepMonitoring")
				// 실행
				.run()
				// 콜백
				.callback(function(callbackParams){
					if(callbackParams.errors) return;
			});
		}
		
	}else if(svcid == "listBatchStepMonitoring"){
		this.fnSetStepDetailList(0);
	}
};

/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	// 업무콜백 처리
	this.dsMain.setColumn(this.dsMain.rowposition, "jobName", e.result.jobName );
	this.dsMain.setColumn(this.dsMain.rowposition, "jobKorName", e.result.jobKorName );
	this.dsMain.setColumn(this.dsMain.rowposition, "businessCode", e.result.businessCode );
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

/**
 * @description 조회버튼
*/
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 검색조건 세팅
	this.dsSearch.setColumn(0, "jobName", this.divSearch.form.edtJobName.value);
	this.dsSearch.setColumn(0, "jobKorName", this.divSearch.form.edtJobKorName.value);
	this.dsSearch.setColumn(0, "businessCode", this.divSearch.form.cboBusnScCd.value);
	
	this.dsMain.clearData();
	this.dsStep.clearData();
	this.fnSetStepDetailList(0);

	this.fnSearch();
};

/**
 * @description Job실행관리 셀클릭
**/
this.grdBatchJobList_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	this.fnSearchStepList(e.row);
};


/**
* @description Step실행관리 셀클릭
**/
this.grdBatchStepList_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	this.fnSetStepDetailList(e.row);
};

/**
 * @description 조회조건 엔터키 이벤트
*/
this.divSearch_edtJobName_onkeyup = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode == "13"){
		this.divSearch_btnSearch_onclick();
	}
};


/**
 * @description 조회조건 엔터키 이벤트
*/
this.divSearch_edtJobKorName_onkeyup = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode == "13"){
		this.divSearch_btnSearch_onclick();
	}
};
]]></Script>
    <Objects>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="jobName" type="STRING" size="256" description="배치JOBID"/>
          <Column id="jobKorName" type="STRING" size="256" description="배치명"/>
          <Column id="businessCode" type="STRING" size="256" description="업무구분"/>
          <Column id="startTime" type="STRING" size="256" description="실행시작일자"/>
          <Column id="endTime" type="STRING" size="256" description="실행종료일자"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true" preload="true">
        <ColumnInfo>
          <Column id="jobName" type="STRING" size="256"/>
          <Column id="jobKorName" type="STRING" size="256"/>
          <Column id="businessCode" type="STRING" size="256"/>
          <Column id="jobInstanceId" type="STRING" size="256"/>
          <Column id="jobExecutionId" type="STRING" size="256"/>
          <Column id="createTime" type="STRING" size="256"/>
          <Column id="startTime" type="STRING" size="256"/>
          <Column id="endTime" type="STRING" size="256"/>
          <Column id="status" type="STRING" size="256"/>
          <Column id="exitCode" type="STRING" size="256"/>
          <Column id="exitMessage" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listBatchJobMonitoring</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsSearch=dsSearch dsMain=dsMain</Col>
            <Col id="url">/zzz_fwc_ba02_000.do</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="id">listBatchStepMonitoring</Col>
            <Col id="inDatasets">dsSearchStepParam=dsSearchStepParam</Col>
            <Col id="outDatasets">dsStep=dsStep</Col>
            <Col id="url">/zzz_fwc_ba02_001.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsBunsCd">
        <ColumnInfo>
          <Column id="businessCode" type="STRING" size="256" description="업무구분코드"/>
          <Column id="businessNm" type="STRING" size="256" description="업무구분이름"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="businessCode"/>
            <Col id="businessNm">선택</Col>
          </Row>
          <Row>
            <Col id="businessCode">SM</Col>
            <Col id="businessNm">시스템관리</Col>
          </Row>
          <Row>
            <Col id="businessCode">CM</Col>
            <Col id="businessNm">공통관리</Col>
          </Row>
          <Row>
            <Col id="businessCode">GA</Col>
            <Col id="businessNm">일반행정</Col>
          </Row>
          <Row>
            <Col id="businessCode">SA</Col>
            <Col id="businessNm">학교행정</Col>
          </Row>
          <Row>
            <Col id="businessCode">SW</Col>
            <Col id="businessNm">교무업무</Col>
