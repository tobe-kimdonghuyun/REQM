        </Grid>
        <Static id="staJobId" taborder="1" text="Job실행결과" left="0" top="102" height="30" cssclass="sta_WF_Tit18" font="normal 14pt/normal &quot;Arial&quot;" width="119"/>
        <Grid id="grdBatchStepList" taborder="4" left="680" top="142" height="210" binddataset="dsStep" autofittype="col" oncellclick="grdBatchStepList_oncellclick" right="0" cellsizingtype="col">
