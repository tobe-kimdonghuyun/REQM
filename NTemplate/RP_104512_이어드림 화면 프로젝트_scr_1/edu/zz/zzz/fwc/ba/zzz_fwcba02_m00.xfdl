              <Calendar id="calCreateDate" taborder="19" left="159" top="47" width="240" height="30" headformat="yyyy.MM.dd ddd HH:mm:ss" dateformat="yyyy.MM.dd ddd HH:mm:ss" readonly="true" editformat="yyyy.MM.dd ddd HH:mm:ss" onchanged="divStepDetail_calCreateDate_onchanged" rtl="false"/>
              <Calendar id="calStartTime" taborder="20" left="592" top="47" width="240" height="30" headformat="yyyy.MM.dd.HH.mm.ss" dateformat="yyyy.MM.dd ddd HH:mm:ss" readonly="true" editformat="yyyy.MM.dd ddd HH:mm:ss"/>
              <Calendar id="calEndTime" taborder="21" left="159" top="88" width="240" height="30" headformat="yyyy.MM.dd.HH.mm.ss" dateformat="yyyy.MM.dd ddd HH:mm:ss" readonly="true" editformat="yyyy.MM.dd ddd HH:mm:ss"/>
            </Layout>
