              <Static id="staTxt09" taborder="5" text="시작일시" left="433" top="41" width="154" height="42" cssclass="sta_WF_Input01"/>
              <Static id="staTxt12" taborder="6" text="종료일시" left="0" top="82" width="154" height="42" cssclass="sta_WF_Input01"/>
