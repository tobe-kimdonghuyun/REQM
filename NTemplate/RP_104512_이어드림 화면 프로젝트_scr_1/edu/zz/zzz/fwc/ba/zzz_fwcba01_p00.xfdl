<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="zzz_fwcba01_p00" width="850" height="520" titletext="배치관리팝업" onload="form_onload" position="absolute">
    <Layouts>
      <Layout width="850" height="520">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divSearch" taborder="1" left="20" top="20" height="52" cssclass="div_WF_Search" right="20">
          <Layouts>
            <Layout>
              <Button id="btnSearch" top="11" height="30" taborder="0" text="조회" tooltiptext="조회" onclick="divSearch_btnSearch_onclick" cssclass="btn_WF_Search03" right="20" width="74"/>
              <Combo id="cboBusnScCd" taborder="1" left="520" top="11" width="130" height="30" innerdataset="dsBunsCd" codecolumn="businessCode" onitemchanged="divSearch_cboBusnScCd_onitemchanged" datacolumn="businessNm"/>
              <Static id="staBusnScCd" taborder="2" text="업무구분" left="435" top="11" height="30" cssclass="sta_WF_Searchtxt01" onclick="divSearch_staJobId00_onclick" width="85"/>
              <Edit id="edtJobKorName" taborder="3" left="295" top="11" width="140" height="30" onkeyup="divSearch_edtJobKorName_onkeyup"/>
              <Static id="staJobNm" taborder="4" text="배치명" left="224" top="11" height="30" cssclass="sta_WF_Searchtxt01" onclick="divSearch_staJobId00_onclick" width="71"/>
              <Edit id="edtJobName" taborder="5" left="94" top="11" width="130" height="30" enable="true" onkeyup="divSearch_edtJobName_onkeyup"/>
              <Static id="staJobId" taborder="6" text="배치JobId" left="0" top="11" height="30" cssclass="sta_WF_Searchtxt01" width="94"/>
            </Layout>
          </Layouts>
        </Div>
        <Grid id="grdBatchJobList" taborder="2" left="20" top="92" height="358" binddataset="dsMain" autoenter="none" cellcombopopuptype="center" oncellclick="grdBatchJobList_oncellclick" onheadclick="grdBatchJobList_onheadclick" autofittype="col" right="20" cellsizingtype="col">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="50"/>
                <Column size="250"/>
                <Column size="250"/>
                <Column size="300"/>
              </Columns>
              <Rows>
                <Row size="40" band="head"/>
                <Row size="34"/>
              </Rows>
              <Band id="head">
                <Cell displaytype="checkboxcontrol" edittype="checkbox"/>
                <Cell col="1" text="배치JobId"/>
                <Cell col="2" text="배치명"/>
                <Cell col="3" text="업무구분"/>
              </Band>
              <Band id="body">
                <Cell displaytype="checkboxcontrol" edittype="checkbox" text="bind:_chk"/>
                <Cell col="1" text="bind:jobName" edittype="none"/>
                <Cell col="2" text="bind:jobKorName" edittype="none"/>
                <Cell col="3" displaytype="combotext" edittype="none" comboautoselect="false" combocodecol="businessCode" combodatacol="businessNm" combodataset="dsBunsCd" text="bind:businessCode"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="btnConfirm" taborder="3" text="확인" left="368" width="50" height="30" cssclass="btn_WF_Crud" accessibilitylabel="팝업닫기" onclick="btnConfirm_onclick" bottom="20"/>
        <Static id="Static99_00_00_00_00" taborder="4" left="0" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
        <Static id="Static99_00_00_00_00_00_01_00" taborder="5" left="0" top="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0"/>
        <Static id="Static99_00_00_00_00_00_01_00_00" taborder="6" top="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" right="0"/>
        <Static id="Static99_00_00_00_00_00" taborder="7" left="0" top="72" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
        <Static id="Static99_00_00_00_00_00_00" taborder="8" left="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" bottom="0"/>
        <Button id="btnRtncn" taborder="9" text="취소" top="470" height="30" width="50" left="428" fittocontents="width" cssclass="btn_WF_Custom" visible="true" onclick="btnRtncn_onclick"/>
        <Static id="Static99_00_00_00_00_00_00_00" taborder="10" left="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" bottom="50"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    배치관리
*  @FileName 	zzz_fwcba01_p00.xfdl 
*  @Creator 	이준우
*  @CreateDate 	2022.01.02
*  @Desction    form CRUD 샘플
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.01.02     	   이준우 	                최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::cm_script.xjs" 

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitPopup(obj);
	this.divSearch.form.cboBusnScCd.set_index(0);
	
	// 조회 입력값 엔터키입력시 조회수행 이벤트 설정
	this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 조회
*/
this.fnSearch = function ()
{ 
 	// 서비스 객체 생성
	this.smfSearchService("select")
		// 데이터 검증
		.validateForm(this.divSearch)
		// 데이터가 변경되었으면 확인메시지
		.confirmIfModifiedDataset(this.dsMain)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});
};	

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
*/

this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

/**
 * @description 조회버튼
*/
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 검색조건 세팅
	this.dsSearch.setColumn(0, "jobName", this.divSearch.form.edtJobName.value);
	this.dsSearch.setColumn(0, "jobKorName", this.divSearch.form.edtJobKorName.value);
	this.dsSearch.setColumn(0, "businessCode", this.divSearch.form.cboBusnScCd.value);
	
	this.dsMain.clearData();

	this.fnSearch();
};

this.grdBatchJobList_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
    if( e.cell == 0){
		//checkbox를 radio처럼 하나만 check되게
		this.smfCheckColumnAsRadio(this.dsMain)
	}
};


this.btnConfirm_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.dsMain.findRow("_chk", "1") == -1){

		this.smfAlert("그리드에 체크된 데이터가 없습니다. 데이터를 체크하세요.");
		
		return false;

	}else{
		//응답을 전달한다.
		this.smfSendResponseToOpener({
			"result": this.smfRowToObject(this.dsMain)
		});
		
		this.close(true);
	}
	
};

/**
 * @description 조회조건 엔터키 이벤트
*/
this.divSearch_edtJobName_onkeyup = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode == "13"){
		this.divSearch_btnSearch_onclick();
	}
};

/**
 * @description 조회조건 엔터키 이벤트
*/
this.divSearch_edtJobKorName_onkeyup = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode == "13"){
		this.divSearch_btnSearch_onclick();
	}
};

/**
 * @description 취소버튼클릭
*/
this.btnRtncn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};
]]></Script>
    <Objects>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="jobName" type="STRING" size="256" description="배치JOBID"/>
          <Column id="jobKorName" type="STRING" size="256"/>
          <Column id="businessCode" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true" preload="true">
        <ColumnInfo>
          <Column id="_chk" type="STRING" size="256"/>
          <Column id="jobName" type="STRING" size="256" description="배치Job ID"/>
          <Column id="jobKorName" type="STRING" size="256" description="배치명"/>
          <Column id="businessCode" type="STRING" size="256" description="업무구분"/>
          <Column id="jobParams" type="STRING" size="256"/>
          <Column id="jobDesc" type="STRING" size="256"/>
          <Column id="batchExcute" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">select</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsSearch=dsSearch dsMain=dsMain</Col>
            <Col id="url">/zzz_fwc_ba00_000.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsBunsCd">
        <ColumnInfo>
          <Column id="businessCode" type="STRING" size="256" description="업무구분코드"/>
          <Column id="businessNm" type="STRING" size="256" description="업무구분이름"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="businessCode"/>
            <Col id="businessNm">선택</Col>
          </Row>
          <Row>
            <Col id="businessCode">CM</Col>
            <Col id="businessNm">공통관리</Col>
          </Row>
          <Row>
            <Col id="businessCode">SM</Col>
            <Col id="businessNm">시스템관리</Col>
          </Row>
          <Row>
            <Col id="businessCode">GA</Col>
            <Col id="businessNm">일반행정</Col>
          </Row>
          <Row>
            <Col id="businessCode">SA</Col>
            <Col id="businessNm">학교행정</Col>
          </Row>
          <Row>
            <Col id="businessCode">SW</Col>
            <Col id="businessNm">교무업무</Col>
          </Row>
          <Row>
            <Col id="businessCode">OP</Col>
            <Col id="businessNm">정보개방</Col>
          </Row>
          <Row>
            <Col id="businessCode">EP</Col>
            <Col id="businessNm">업무포털</Col>
          </Row>
          <Row>
            <Col id="businessCode">PA</Col>
            <Col id="businessNm">대국민</Col>
          </Row>
          <Row>
            <Col id="businessCode">CP</Col>
            <Col id="businessNm">학교수업</Col>
          </Row>
          <Row>
            <Col id="businessCode">US</Col>
            <Col id="businessNm">사용자지원</Col>
          </Row>
          <Row>
            <Col id="businessCode">PM</Col>
            <Col id="businessNm">프로젝트관리</Col>
          </Row>
          <Row>
            <Col id="businessCode">NS</Col>
            <Col id="businessNm">일반설문</Col>
          </Row>
          <Row>
            <Col id="businessCode">EO</Col>
            <Col id="businessNm">교육디지털원패</Col>
          </Row>
          <Row>
            <Col id="businessCode">LI</Col>
            <Col id="businessNm">소재정보</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item2" compid="divSearch.form.edtJobKorName" propid="value" datasetid="dsSearch" columnid="jobKorName"/>
      <BindItem id="item3" compid="divSearch.form.edtJobName" propid="value" datasetid="dsSearch" columnid="jobName"/>
    </Bind>
  </Form>
</FDL>
