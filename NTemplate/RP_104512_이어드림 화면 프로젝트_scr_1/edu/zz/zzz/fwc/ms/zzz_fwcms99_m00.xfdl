/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::cm_script.xjs" 

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);
	
	this.Tab00.Tabpage1.set_url("zzz_fwcms00_m00.xfdl.js");
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.Tab00_onchanged = function(obj:nexacro.Tab,e:nexacro.TabIndexChangeEventInfo)
{
	switch(e.postindex) {
		case 0:
			this.Tab00.Tabpage1.set_url("zz_zzz_fwc_ms::zzz_fwcms00_m00.xfdl.js");
			break;
		case 1:
			this.Tab00.Tabpage2.set_url("zz_zzz_fwc_ms::zzz_fwcms01_m00.xfdl.js");
			break;
		case 2:
			this.Tab00.Tabpage3.set_url("zz_zzz_fwc_ms::zzz_fwcms02_m00.xfdl.js");
			break;
		case 3:
			this.Tab00.Tabpage4.set_url("zz_zzz_fwc_ba::zzz_fwcba00_m00.xfdl.js");
			break;
		case 4:
			this.Tab00.Tabpage5.set_url("zz_zzz_fwc_ba::zzz_fwcba01_m00.xfdl.js");
			break;
		case 5:
			this.Tab00.Tabpage6.set_url("zz_zzz_fwc_ba::zzz_fwcba02_m00.xfdl.js");
			break;
		default:
			this.Tab00.Tabpage1.set_url("zz_zzz_fwc_ms::zzz_fwcms00_m00.xfdl.js");
	}
};
]]></Script>
