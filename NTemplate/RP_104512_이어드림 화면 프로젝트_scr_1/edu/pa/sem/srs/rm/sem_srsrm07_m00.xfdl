      <Layout height="745" width="1200" screenid="ScreenDeskTop">
        <Static id="sta00" taborder="5" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Div id="divTitle" taborder="0" left="0" top="sta00:0" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="공기질점검장소관리" left="0" top="0" height="44" cssclass="img_WF_SubTit01" width="600" initvalueid="ivTitleAccessibilityOn" onclick="divTitle_imgTitle_onclick"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta01" taborder="1" left="0" top="divTitle:0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Div id="divSearch" taborder="2" left="0" top="sta01:0" height="70" cssclass="div_WF_Search" right="0" accessibilityenable="false" accessibilityrole="none" text="">
          <Layouts>
            <Layout initvalueid="ivDivAccessibilityOff">
              <Button id="btnSearch" taborder="6" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="20" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="조회" onclick="divSearch_btnSearch_onclick"/>
              <Static id="staBizNm" taborder="0" text="사업명" left="0" top="20" height="30" cssclass="sta_WF_Essential01" initvalueid="ivStcAccessibilityOff" width="77"/>
              <Combo id="cboBizNm" taborder="1" left="staBizNm:0" height="30" innerdataset="dsBizList" codecolumn="bizSn" datacolumn="bizNm" index="0" top="20" value="" initvalueid="ivCmbEssential" accessibilitylabel="사업명" text="" width="200" onitemchanged="divSearch_cboBizNm_onitemchanged" accessibilityaction="알트 + 아래쪽 방향키로 리스트 아이템 목록을 활성화하여 가상커서를 해제한 후 컨트롤 + 상하 방향키로 아이템을 이동합니다. 엔터 키를 이용하여 아이템을 선택합니다. 탭 키 로 다음으로 이동합니다."/>
              <Static id="staByr" taborder="2" text="년도" left="cboBizNm:0" top="20" height="30" cssclass="sta_WF_Essential01" initvalueid="ivStcAccessibilityOff" width="63"/>
              <Combo id="cboAyr" taborder="3" left="staByr:0" width="120" height="30" innerdataset="dsAyrList" codecolumn="ayr" datacolumn="ayr" index="0" top="20" initvalueid="ivCmbEssential" accessibilitylabel="년도" text="" accessibilityaction="알트 + 아래쪽 방향키로 리스트 아이템 목록을 활성화하여 가상커서를 해제한 후 컨트롤 + 상하 방향키로 아이템을 이동합니다. 엔터 키를 이용하여 아이템을 선택합니다. 탭 키 로 다음으로 이동합니다."/>
              <Static id="staShlNm" taborder="4" text="학교명" left="467" top="20" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOff" width="71"/>
              <Combo id="cboShlNm" taborder="5" left="staShlNm:0" width="200" height="30" top="20" initvalueid="ivCmbNormal" text="" innerdataset="dsBizSnShlCdList" datacolumn="shlNm" codecolumn="shlCd" index="-1" accessibilitylabel="학교명" onitemchanged="divSearch_cboShlNm_onitemchanged"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta02" taborder="3" left="0" top="divSearch:0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta02_00" taborder="4" left="0" top="264" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Grid id="grdMain" taborder="6" left="0" top="sta02_00:0" height="480" autofittype="col" right="0" binddataset="dsMain" selecttype="cell" initvalueid="ivGrdAccessibilityOn" oncellclick="grdMain_oncellclick" accessibilitylabel="공기질정기점검결과목록(발주기관명,점검항목,검사대상학교,검사년도,반기,작성여부)">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="50"/>
                <Column size="100"/>
                <Column size="180"/>
                <Column size="100"/>
                <Column size="200"/>
                <Column size="100"/>
                <Column size="130"/>
                <Column size="250"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="순번"/>
                <Cell col="1" text="점검년도"/>
                <Cell col="2" text="교육지원청"/>
                <Cell col="3" text="학교구분"/>
                <Cell col="4" text="학교명"/>
                <Cell col="5" text="점검구분"/>
                <Cell col="6" text="점검구분상세"/>
                <Cell col="7" text="점검장소"/>
              </Band>
              <Band id="body">
                <Cell textAlign="center" text="expr:currow +1"/>
                <Cell col="1" text="bind:ayr" textAlign="center"/>
                <Cell col="2" text="bind:cteOrgNm"/>
                <Cell col="3" text="bind:shlKndScNm" textAlign="center"/>
                <Cell col="4" text="bind:shlNm" textAlign="left"/>
                <Cell col="5" text="bind:chckPlaceScNm" textAlign="center"/>
                <Cell col="6" text="bind:gubun" textAlign="center" cssclass="cell_WF_underline,cell_WF_Pointer,cell_WF_BlueB"/>
                <Cell col="7" textAlign="left" text="bind:list"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="sta04" taborder="8" left="0" top="grdMain:0" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" height="30"/>
        <Button id="btnAdd" taborder="7" text="등록" top="sta02:0" fittocontents="width" visible="true" height="30" initvalueid="ivBtnAccessibilityButton" width="60" right="0" onclick="btnAdd_onclick" accessibilitylabel="등록"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    학교환경관리 > 공기질점검장소관리
*  @FileName 	sem_srsrm07_m00.xfdl 
*  @Creator 	whkim
*  @CreateDate 	2025.02.17
*  @Desction    공기질정기점검관리
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2025.02.17            whkim                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_cddcCd;  // 시도교육청 코드
this.fv_brno; 	 //사업자등록번호

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
    //시도교육청 세팅
	this.fv_cddcCd = this.smfGetCddcCode();
	this.dsSearch.setColumn(0, "cddcCd", this.fv_cddcCd);
	
	//사업자등록번호 세팅
	this.fv_brno = this.smfGetBrno();
	this.dsSearch.setColumn(0, "brno", this.fv_brno);
	
	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
			url : "/sem_srs_rm07_000.do",
		})
		.mappingRulesetToForm(this.divSearch, "search")
		.callback(function(callbackParams) {
		})
		.run()
	;

	// 공통코드의 코드구분
	this.smfCodeList("code", [this.dsHyCd])
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		})
	;
	
	//조회조건 조회
	this.fnSearchInqCondCn(); 
	
	//조회조건(년도) 세팅
	this.yearCmbSet();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 팝업의 콜백함수
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	this.fnSearchList();
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 조회조건 조회
 * @param : N/A
 * @param : N/A
 */
 this.fnSearchInqCondCn = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("listInqCondCn")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'prcsRltCd') == 'SUCC'){
				this.divSearch.form.cboBizNm.set_index(0);
				this.divSearch.form.cboAyr.set_index(0);
				this.fnComboShlSet();
			}else{
				if (this.smfIsNull(this.dsApiResponseList.getColumn(0, 'errCn'))){
					this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')], this.fnMessageCallback);
				}else{
					this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'errCn')], this.fnMessageCallback);
				}
			}
		});
};

/**
 * 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchList = function()
{
    //indRwdatInptYn 파라미터 넘기기
    var indRwdatInptYn = this.dsBizList.getColumn(0, "indRwdatInptYn");
	this.dsSearch.setColumn(0, "indRwdatInptYn", indRwdatInptYn);
 	// 서비스 객체 생성
	this.smfSearchService("list")
		// 데이터 검증
		.validateForm(this.divSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'prcsRltCd') == 'SUCC'){
			}else{
				if (this.smfIsNull(this.dsApiResponseList.getColumn(0, 'errCn'))){
					this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')], this.fnMessageCallback);
				}else{ 
					this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'errCn')], this.fnMessageCallback);
				}
			}
		});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * 조회조건 년도 세팅 : 현재년도 ~  현재년도-2
 * @param  : cmb			- combo 컴포넌트
 * @return : N/A
 */
this.yearCmbSet = function(){
	var today = new nexacro.Date();
	var year = today.getFullYear();
	
	for(var i = 0; i < 3; i++){
		var yearVal = year - i;
		this.dsAyrList.addRow();
		this.dsAyrList.setColumn(i, 'ayr', yearVal);
	}
};

/**
 * 학교명 콤보박스 세팅
 * @param  : N/A
 * @return : N/A
 */
this.fnComboShlSet = function(){
	this.dsBizSnShlCdList.filter("bizSn == " + this.dsSearch.getColumn(0, "bizSn"));
	this.dsBizSnShlCdList.setColumn(this.dsBizSnShlCdList.insertRow(0), 'shlNm', '- 전체 -');
	this.divSearch.form.cboShlNm.set_index(0);

	//사업명 가져오기
	this.dsSearch.setColumn(0, 'bizNm', this.divSearch.form.cboBizNm.text);
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 조회 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearchList();
};

/**
 * 등록버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//팝업에 전달할 데이터셋에 값 세팅
	var sBrno = this.dsSearch.getColumn(0, "brno");
	var sBizSn = this.dsSearch.getColumn(0, "bizSn");
	var sAyr = this.dsSearch.getColumn(0, "ayr");
	
	var popupParams = {
						callback: this.fnPopupCallback,
						internalCallback : this.fnPopupCallback,
						sender: obj, // sender 지정
						params: {
								// 처리타입 지정
								procType : 'insert'
								,addTitle : ' 등록'
								,ayr : sAyr
								,brno : sBrno
								,bizSn : sBizSn
								,shlList : this.dsBizSnShlCdList.saveXML()
								},
					};

		this.smfDialog("_auto", "pa_sem_srs_rm::sem_srsrm07_p00.xfdl", popupParams);
};

/**
 * 그리드 셀 클릭 시
 * @param  : obj			- [object]Grid
 * @param  : e				- [string]GridClickEventInfo
 * @return : N/A
 */
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{	
	var sBrno = this.dsSearch.getColumn(0, "brno");
	this.dsGrdChcRow.copyRow(0, this.dsMain, e.row);
	var sBizSn = this.dsSearch.getColumn(0, "bizSn");
	var sBizNm = this.dsSearch.getColumn(0, "bizNm");
	
	if (e.col == 6){
		// 팝업을 동작에 필요한 파라메터 지정
		var popupParams = {
			callback: this.fnPopupCallback,
			internalCallback : this.fnPopupCallback,
			sender: obj, // sender 지정
			params: {
				// 처리타입 지정
				procType : 'update'
				,addTitle : ' 수정'
				,brno : sBrno
				,bizSn : sBizSn
				,bizNm : sBizNm
				,dataset : this.dsGrdChcRow.saveXML()
				,shlList : this.dsBizSnShlCdList.saveXML()
			},
		};

		this.smfDialog("_auto", "pa_sem_srs_rm::sem_srsrm07_p00.xfdl", popupParams);
	}
};

/**
 * 콤보 아이템 변경 시
 * @param  : obj			- [object]Combo
 * @param  : e				- [string]ItemChangeEventInfo
 * @return : N/A
 */
this.divSearch_cboBizNm_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.fnComboShlSet();
};

]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listInqCondCn</Col>
            <Col id="url">/sem_srs_rm07_001.do</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsBizList=dsBizList dsBizSnShlCdList=dsBizSnShlCdList dsApiResponseList=dsApiResponseList</Col>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">R</Col>
            <Col id="bindingControls"/>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
          <Row>
            <Col id="id">list</Col>
            <Col id="url">/sem_srs_rm07_002.do</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsMain=dsMain dsApiResponseList=dsApiResponseList</Col>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">R</Col>
            <Col id="bindingControls"/>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="brno" type="STRING" size="256" description="사업자등록번호"/>
          <Column id="bizSn" type="STRING" size="256" description="사업일련번호"/>
          <Column id="bizNm" type="STRING" size="256" description="사업명"/>
          <Column id="ayr" type="STRING" size="256" description="학년도"/>
          <Column id="shlCd" type="STRING" size="256" description="학교코드"/>
          <Column id="shlNm" type="STRING" size="256" description="학교명"/>
          <Column id="cddcCd" type="STRING" size="256" description="시도교육청코드"/>
          <Column id="hyCd" type="STRING" size="256" description="반기코드"/>
          <Column id="cteOrgCd" type="STRING" size="0"/>
          <Column id="cddcOrgCd" type="STRING" size="0"/>
          <Column id="shlKndScCd" type="STRING" size="0" sumtext="" description="학교급"/>
          <Column id="indRwdatInptYn" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true">
        <ColumnInfo>
          <Column id="shlNm" type="STRING" size="256" sumtext="" description="학교명"/>
          <Column id="chckPlaceScNm" type="STRING" size="256" sumtext="" description="점검장소구분코드명"/>
          <Column id="gubun" type="STRING" size="256" sumtext="" description="구분"/>
