/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 /**
 * 조회조건 년도 세팅 : 현재년도 ~  현재년도-2
 * @param  : cmb			- combo 컴포넌트
 * @return : N/A
 */
this.yearCmbSet = function(){
	var today = new nexacro.Date();
	var year = today.getFullYear();
	
	for(var i = 0; i < 3; i++){
		var yearVal = year - i;
		this.dsAyrList.addRow();
		this.dsAyrList.setColumn(i, 'ayr', yearVal);
	}
};


/**
 * 저장 체크
 * @param : N/A
 * @return : true : 저장 적합, false : 저장 부적합
 */
this.fnSaveCheck = function(){

	var vsShlNm = this.dsSearch.getColumn(0, "shlNm");						//학교
	var vsShlCd = this.dsSearch.getColumn(0, "shlCd");						
	var vsAyr = this.dsSearch.getColumn(0, "ayr");							//년도
	var vsChckPlaceScCd = this.dsSearch.getColumn(0, "chckPlaceScCd");		//점검구분
	var vsHy = this.dsSearch.getColumn(0, "hyCd");						  	//반기
	var vsSpecl = this.dsSearch.getColumn(0, "speclChckRsnCd");				//특별점검
	var vsNwcc = this.dsSearch.getColumn(0, "nwccChckRsnCd");				//신축점검
	var vsDgr = this.divInfo.form.cboDgr.value;							//차수
	var addDgr = this.divInfo.form.btnAddDgr.enable;
	
	if (vsChckPlaceScCd == 10){
		var vsChckPlaceMngNo = String(vsChckPlaceScCd + vsHy + 1);
	}else if(vsChckPlaceScCd == 20){
		var vsChckPlaceMngNo = this.dsSearch.getColumn(0, "chckPlaceMngNo");
	}else if(vsChckPlaceScCd == 30){
		var vsChckPlaceMngNo =  String(vsChckPlaceScCd + vsNwcc + 1);
	}

	if(this.isNil(vsAyr)){
		this.smfAlert('CM006', ['년도']);
		return false;
	}
	
	if(this.isNil(vsChckPlaceScCd)){
		this.smfAlert('PA058', ['점검구분을 체크']);
		return false;
	}
	
	if(vsChckPlaceScCd == 10 && this.isNil(vsHy)){
		this.smfAlert('PA058', ['반기구분을 체크']);
		return false;
	}
	
	if(vsChckPlaceScCd == 20 && this.isNil(vsSpecl)){
		this.smfAlert('PA058', ['특별점검구분을 체크']);
		return false;
	}
	
	if(vsChckPlaceScCd == 30 && this.isNil(vsNwcc)){
		this.smfAlert('PA058', ['신축점검구분을 체크']);
		return false; 
	}
	if(addDgr == true){
		this.smfAlert('PA058', ['차수 추가를 체크']);
		return false;
	}
	
	var vsRowCnt = this.dsListSub.getRowCount();
	if(vsRowCnt == 0){
		this.smfAlert('PA058', ['점검대상장소를 입력']);
		return false;
	}
	
	var vsShlBuYm = this.dsMain.getColumn(0, "shlBuYm");  //학교건축연월
	var getYear = this.smfToday();
	
	for (var i=0; i<vsRowCnt; i++){
		var vsRetFaScCd = this.dsListSub.getColumn(i, "retFaScCd");
		var vsChckFaNm = this.dsListSub.getColumn(i, "chckFaNm");
		var vsFaBuYm = this.dsListSub.getColumn(i, "faBuYm");

		if(this.isNil(vsRetFaScCd)){
			this.smfAlert('PA058', ['점검장소를 입력']);
			return false;
		}
		if(this.isNil(vsChckFaNm)){
			this.smfAlert('PA058', ['측정장소를 입력']);
			return false;
		}
		
		if(this.isNotNil(vsShlBuYm)){
			// 현재일자 > 학교건축연월
			if(vsShlBuYm > getYear){
			this.smfAlert('PA003', ['학교건축연월은 현재보다 미래일을 지정하실수 ']);
			return false;
			}
		}

		if(this.smfLength(vsChckFaNm, 3) > 100){
			this.smfAlert('CM155', ['측정장소가 100Bytes를 초과하였습니다. 다시 등록하시기 바랍니다.']);
			return;
		}
	
		this.dsListSub.setColumn(i, "shlCd", vsShlCd);
		this.dsListSub.setColumn(i, "ayr", vsAyr);
		this.dsListSub.setColumn(i, "chckPlaceScCd", vsChckPlaceScCd);
		this.dsListSub.setColumn(i, "chckPlaceMngNo", vsChckPlaceMngNo);
		if(this.isNil(vsFaBuYm)){
			this.dsListSub.setColumn(i, 'faBuYm', '');
		} else {
			this.dsListSub.setColumn(i, 'faBuYm', vsFaBuYm.substr(0, 6));
		}
		
	}
	

	return true;
};


/**
 * 마감체크
 */
this.fnSetDdln = function(listCheck){
	//마감확인
	var qltaDdlnMngNm = this.dsMain.getColumn(0, 'qltaDdlnMngNm');
	
	//마감됨
	if(this.isNotNil(qltaDdlnMngNm)){

		this.staDdlnMngNo.set_visible(true);					// 마감문구 보이기
		
		this.btnCopy.set_enable(false);							// 이전내역 가져오기 
		this.btnSave.set_enable(false);							// 저장
		this.btnDelete.set_enable(false);						// 삭제
		this.divInfo.form.cboShlNm.set_enable(false);			// 학교
		this.divInfo.form.cboAyr.set_enable(false);				// 년도
		this.divInfo.form.rdoChckPlaceScCd.set_enable(false);	// 점검구분
		this.divInfo.form.rdoHy.set_enable(false);				// 반기
		this.divInfo.form.rdoNwcc.set_enable(false);			// 신축점검구분
		this.divInfo.form.rdoSpecl.set_enable(false);			// 특별점검구분
		this.divInfo.form.cboDgr.set_enable(false);				// 차수
		this.divInfo.form.btnAddDgr.set_enable(false);			// 차수등록
		
		this.btnRowAdd.set_enable(false);						// 행추가 버튼
		this.btnRowDelete.set_enable(false);					// 행삭제 버튼
		this.btnDownload.set_enable(false);						// 양식 내려받기
		this.btnUpload.set_enable(false);						// 파일 올리기
	
		
	// 미 마감	
	}else{
		this.staDdlnMngNo.set_visible(false);					// 마감문구 숨기기
		//등록
		if(fv_procType == "insert") {
			this.btnCopy.set_enable(true);							// 이전내역 가져오기 
			this.btnSave.set_enable(true);							// 저장
			this.btnDelete.set_enable(true);						// 삭제
			this.divInfo.form.cboShlNm.set_enable(true);			// 학교 
			this.divInfo.form.cboAyr.set_enable(true);				// 년도 
			this.divInfo.form.rdoChckPlaceScCd.set_enable(true);	// 점검구분 
			
			this.btnRowAdd.set_enable(true);						// 행추가 버튼
			this.btnRowDelete.set_enable(true);						// 행삭제 버튼
			this.btnDownload.set_enable(true);						// 양식 내려받기
			this.btnUpload.set_enable(true);						// 파일 올리기
			
			var vsRdoChckPlaceScCd = this.divInfo.form.rdoChckPlaceScCd.value;
			if(vsRdoChckPlaceScCd == 20 && fv_addDgrYn){
				this.divInfo.form.btnAddDgr.set_enable(true);			// 차수등록 가능
			}
			
			//등록된 자료가 있을시 이전내역가져오기,저장,삭제,행추가,행삭제 버튼 활성화
			//메인에서 수정으로 들어와야 키값들이 매핑 됨.
			if(listCheck == null){
				this.btnSave.set_enable(true);							// 저장가능
				this.btnRowAdd.set_enable(true);						// 행추가 버튼
				this.btnRowDelete.set_enable(true);						// 행삭제 버튼
			} else{
				this.btnCopy.set_enable(false);							// 이전내역 가져오기 
				this.btnSave.set_enable(false);							// 저장
				this.btnDelete.set_enable(false);						// 삭제
				
				this.btnRowAdd.set_enable(false);						// 행추가 버튼
				this.btnRowDelete.set_enable(false);					// 행삭제 버튼
				this.btnDownload.set_enable(false);						// 양식 내려받기
				this.btnUpload.set_enable(false);						// 파일 올리기
			}
			
		}
			
		//수정
		if(fv_procType == "update"){
			this.btnCopy.set_enable(false);							// 이전내역 가져오기
			this.btnSave.set_enable(true);							// 저장
			this.btnDelete.set_enable(true);						// 삭제
			this.divInfo.form.cboShlNm.set_enable(false);			// 학교
			this.divInfo.form.cboAyr.set_enable(false);				// 년도
			this.divInfo.form.rdoChckPlaceScCd.set_enable(false);	// 점검구분
			this.divInfo.form.rdoHy.set_enable(false);				// 반기구분
			this.divInfo.form.rdoNwcc.set_enable(false);			// 신축점검구분
			this.divInfo.form.rdoSpecl.set_enable(false);			// 특별점검구분
			this.divInfo.form.cboDgr.set_enable(false);				// 차수
			this.divInfo.form.btnAddDgr.set_enable(false);			// 차수등록
		}
	}
	
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 양식 내려받기 버튼 클릭 시
 * @param  : obj			- [object]Grid
 * @param  : e				- [string]GridClickEventInfo
 * @return : N/A
 */
this.btnDownload_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objOption = {
						objGrid : this.grdExcelExport
					,   sheetname : "Sheet1"
					,   filename : "공기질점검장소_업로드양식" + this.smfTodayTime()
					};
	this.smfExcelExport(objOption);
};

/**
 * 파일 올리기 버튼 클릭 시
 * @param  : obj			- [object]Grid
 * @param  : e				- [string]GridClickEventInfo
 * @return : N/A
 */
this.btnUpload_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objOption = {
						datasetname : "dsExcelImport"
					,   sheetname   : "Sheet1"
					,   startcell   : "A2"
					,   callback    : "fnImportCallback"
					,   importId    : "import"
					,   objForm     : this
					};
	this.smfExcelImport(objOption);
};

/**
 * 저장 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (!this.fnSaveCheck()) return;
	// 최소 1건은 입력해야함
	if (this.dsListSub.rowcount < 1){
		this.smfConfirm("점검대상 장소를 등록해 주시기 바랍니다.");
		return false;
	}

	var vsAyr = this.dsSearch.getColumn(0, "ayr"); // 년도
	var vsShlCd = this.dsSearch.getColumn(0, "shlCd");
	var vsShlNm = this.dsSearch.getColumn(0, "shlNm");
	var vsChckPlaceScCd = this.dsSearch.getColumn(0, "chckPlaceScCd"); // 점검구분코드 
	var vsHyCd = this.dsSearch.getColumn(0, "hyCd"); // 반기점검코드
	var vsSpecl = this.dsSearch.getColumn(0, "speclChckRsnCd");//특별점검코드
	var vsNwcc = this.dsSearch.getColumn(0, "nwccChckRsnCd"); //신축점검코드
	var vsShlBuYm = this.dsMain.getColumn(0, "shlBuYm");
	var speclChckDgr = this.dsSearch.getColumn(0, "chckPlaceMngNo");
	
	var mngNo =this.dsListSub.getColumn(0, "chckPlaceMngNo");
	
	this.dsSave.setColumn(0, "ayr", vsAyr);
	this.dsSave.setColumn(0, "shlCd", vsShlCd);
	this.dsSave.setColumn(0, "shlNm", vsShlNm);
	this.dsSave.setColumn(0, "cddcCd", this.dsSearch.getColumn(0, "cddcCd"));
	this.dsSave.setColumn(0, "dstrtOfcdcCd", this.dsSearch.getColumn(0, "cteOrgCd"));
	this.dsSave.setColumn(0, "chckPlaceScCd", vsChckPlaceScCd);
	this.dsSave.setColumn(0, "chckPlaceMngNo", mngNo);
	this.dsSave.setColumn(0, "hyCd", vsHyCd);
	this.dsSave.setColumn(0, "speclChckRsnCd", vsSpecl);
	this.dsSave.setColumn(0, "nwccChckRsnCd", vsNwcc);
	if (this.isNotNil(vsShlBuYm))
	{
		this.dsSave.setColumn(0, "shlBuYm", vsShlBuYm.substr(0,6));
	}else{
		this.dsSave.setColumn(0, "shlBuYm", vsShlBuYm);
	}
	this.dsSave.setColumn(0, "procType", fv_procType);
	
	for(var i=0; i<this.dsBizSn.getRowCount(); i++){
		if(fv_bizSn == this.dsBizSn.getColumn(i, 'bizSn')){
			this.dsSave.setColumn(0, "qltaChckComyNm", this.dsBizSn.getColumn(i, 'inspComyNm'));
			this.dsSave.setColumn(0, "qltaChckYmd", this.dsBizSn.getColumn(i, 'inspComyDsgnYmd'));
			
			break;
		}
	}
	
	
	this.dsSave.setColumn(0, "bizSn", fv_bizSn);
	
	if (this.isNotNil(speclChckDgr))
	{
		this.dsSave.setColumn(0, "speclChckDgr", speclChckDgr.substring(4,3));
	}else{
		this.dsSave.setColumn(0, "speclChckDgr", speclChckDgr);
	}
				
	if(rltDelYn){
		this.smfConfirm("[행삭제]된 건 중 측정(검사)결과가 등록되어 있습니다.\n[점검대상 장소]의 내용이 삭제된 경우 측정(검사)결과도 함께 삭제됩니다.\n\n저장하시겠습니까?", function(result){
			if(result.confirmResult){
				//저장
				this.fnNoConfirmSave();
			}
		});
	}else{
		//저장
		this.fnSave();
	}
	
	
};

/**
 * 닫기 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close();
};

/**
 * 행추가 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnRowAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	var shlNm = this.dsSearch.getColumn(0, "shlNm");						//학교
	var vsAyr = this.dsSearch.getColumn(0, "ayr");							//년도
	var vsChckPlaceScCd = this.dsSearch.getColumn(0, "chckPlaceScCd");		//점검구분
	var vsHy = this.dsSearch.getColumn(0, "hyCd");						  	//반기
	var vsSpecl = this.dsSearch.getColumn(0, "speclChckRsnCd");				//특별점검
	var vsNwcc = this.dsSearch.getColumn(0, "nwccChckRsnCd");				//신축점검
	var cboDgr = this.divInfo.form.cboDgr.value;							//차수
	var addDgr = this.divInfo.form.btnAddDgr.enable;

	if(this.isNil(vsAyr)){
		this.smfAlert('CM006', ['년도']);
		return false;
	}
	
	if(this.isNil(vsChckPlaceScCd)){
		this.smfAlert('PA058', ['점검구분을 체크']);
		return false;
	}
	
	if(vsChckPlaceScCd == 10 && this.isNil(vsHy)){
		this.smfAlert('PA058', ['반기구분을 체크']);
		return false;
	}
	
	if(vsChckPlaceScCd == 20 && this.isNil(vsSpecl)){
		this.smfAlert('PA058', ['특별점검구분을 체크']);
		return false;
	}
	
	if(vsChckPlaceScCd == 30 && this.isNil(vsNwcc)){
		this.smfAlert('PA058', ['신축점검구분을 체크']);
		return false; 
	}
	if(addDgr == true){
		this.smfAlert('PA058', ['차수 추가를 먼저']);
		return false;
	}

	var nRow = this.dsListSub.addRow();

};

/**
 * 행삭제 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnRowDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//체크박스 선택 여부 확인
	var arrChk = this.dsListSub.extractRows('chk == 1');
	if(arrChk == '-1' || arrChk.length < 1){
		//선택된 {0}이(가) 없습니다. {0}을(를) 선택하여 주십시오.
		this.smfAlert('CM013', ['행']);	  
		return;
	}	
	// 삭제 시 검사결과가 있는지 체크
	var qltaInspRltYn = "";
    var qltaInspRltChk = false;
	
    for(var i = 0; i < arrChk.length; i++){
    	qltaInspRltYn = this.dsListSub.getColumn(arrChk[i], 'qltaInspRltYn');
		
    	if(qltaInspRltYn == "Y"){
    		qltaInspRltChk = true;
    	}
    }
	
	if(qltaInspRltChk){
	    this.smfConfirm("측정(검사)결과가 입력되어 있습니다.\n[행삭제]시 측정(검사)결과도 함께 삭제됩니다.\n\n삭제하시겠습니까?",
		function(result){
			if(result.confirmResult){	//YES
				rltDelYn = true; 
				for(var i=arrChk.length - 1; i >= 0 ; i--){
					
					if(this.dsListSub.getColumn(arrChk[i], 'chckRetFaSn')){
						var row = this.dsDelList.addRow();
						this.dsDelList.copyRow(row, this.dsListSub, arrChk[i]);
					}
					this.dsListSub.deleteRow(arrChk[i]);
				}
			}
	    });
    } else {
		for(var i = arrChk.length - 1; i >= 0 ; i--){
			
			if(this.dsListSub.getColumn(arrChk[i], 'chckRetFaSn')){
				var row = this.dsDelList.addRow();
				this.dsDelList.copyRow(row, this.dsListSub, arrChk[i]);
			}
			this.dsListSub.deleteRow(arrChk[i]);
		}
	}
};

/**
 * 닫기 버튼 클릭 시
 * @param  : N/A
 * @return : N/A
 */
this.btn_close_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};

/**
 * @description 학교선택시 호출
*/
this.divInfo_cboShlNm_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	//학교가 선택되어있으면
	if(this.isNotNil(this.dsSearch.getColumn(0, "shlCd"))){
		//조회 함
		this.fnSearch();
	}
};

/**
 * @description 특별점검구분 라디오 버튼 클릭시 변경사항
*/
this.divInfo_rdoSpecl_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{	
	if(this.isNil(this.dsSearch.getColumn(0, "shlCd"))){
		this.smfAlert('PA058', ['학교를 선택 ']);
		this.divInfo.form.rdoSpecl.set_value("-1");
		return false;
	}

	
	this.divInfo.form.cboDgr.set_enable(true);				//차수 콤보박스
	this.divInfo.form.btnAddDgr.set_enable(true);			//차수 추가버튼
	
	//this.fnSearch();
	if(fv_procType == "insert"){
		this.fnDgrSearch();
	}
};

/**
 * @description 점검구분 라디오 버튼 클릭시 변경사항
*/
this.divInfo_rdoChckPlaceScCd_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	if(this.isNil(this.dsSearch.getColumn(0, "shlCd"))){
		this.smfAlert('PA058', ["학교를 선택 "]);
		this.divInfo.form.rdoChckPlaceScCd.set_value('-1');
		return false;
	}

	var vsRdoChckPlaceScCd = this.divInfo.form.rdoChckPlaceScCd.value;

	this.divInfo.form.rdoHy.set_enable(false);				// 반기 변경불가
	this.divInfo.form.rdoNwcc.set_enable(false);			// 신축점검구분 변경불가
	this.divInfo.form.rdoSpecl.set_enable(false);			// 특별점검구분 변경불가
	this.divInfo.form.cboDgr.set_enable(false);				// 차수 변경불가
	this.divInfo.form.btnAddDgr.set_enable(false);			// 차수등록 불가
	
	this.divInfo.form.rdoHy.set_value("");					// 
	this.divInfo.form.rdoNwcc.set_value("");				// 
	this.divInfo.form.rdoSpecl.set_value("");				//
	this.divInfo.form.cboDgr.set_value("");					//
		
 	this.dsMain.reset();
 	this.dsListSub.reset();
	
	if(vsRdoChckPlaceScCd == 10){				//정기점검
	
		this.divInfo.form.rdoHy.set_enable(true);				// 반기 변경가능
		this.divInfo.form.rdoNwcc.set_enable(false);			// 신축점검구분 변경불가
		this.divInfo.form.rdoSpecl.set_enable(false);			// 특별점검구분 변경불가
		this.divInfo.form.cboDgr.set_enable(false);				// 차수 변경불가
		this.divInfo.form.btnAddDgr.set_enable(false);			// 차수등록 불가
		
		this.divInfo.form.rdoNwcc.set_value("");				// 
		this.divInfo.form.rdoSpecl.set_value("");				//
		this.divInfo.form.cboDgr.set_value("");					//
		
	}else if (vsRdoChckPlaceScCd == 20){		//특별점검
		
		this.divInfo.form.rdoHy.set_enable(false);				// 반기 변경불가
		this.divInfo.form.rdoNwcc.set_enable(false);			// 신축점검구분 변경불가
		this.divInfo.form.rdoSpecl.set_enable(true);			// 특별점검구분 변경가능
		
		this.divInfo.form.rdoHy.set_value("");					//
		this.divInfo.form.rdoNwcc.set_value("");				//
		
	}else if (vsRdoChckPlaceScCd == 30){		//신축학교점검
	
		this.divInfo.form.rdoHy.set_enable(false);				// 반기 변경불가
		this.divInfo.form.rdoNwcc.set_enable(true);				// 신축점검구분 변경가능
		this.divInfo.form.rdoSpecl.set_enable(false);			// 특별점검구분 변경불가
		this.divInfo.form.cboDgr.set_enable(false);				// 차수 변경불가
		this.divInfo.form.btnAddDgr.set_enable(false);			// 차수등록 불가
		
		this.divInfo.form.rdoHy.set_value("");					// 
		this.divInfo.form.rdoSpecl.set_value("");				//
		this.divInfo.form.cboDgr.set_value("");					//
		
	}
};


/**
 * @description 차수추가 버튼 클릭시 
*/
this.divInfo_btnAddDgr_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var maxIndex = this.dsDgrList.getRowCount() - 1;
	var temp = 0;
	if(this.isNil(this.dsDgrList.getColumn(maxIndex, "cdcValue"))){
		temp = 0
	}else{
		temp = Number(this.dsDgrList.getColumn(maxIndex, "cdcValue"));
	}
	
	var addCdcValue = String(Number(temp + 1));

	if(addCdcValue.substring(3) == "10"){
		this.smfAlert('PA061', ['차수추가는 9차수까지 ']);
		return false;
	}
	
	if (addCdcValue == "1") {
		addCdcValue = String("20" +  this.divInfo.form.rdoSpecl.value + "1");
		
		var rowcnt = this.dsDgrList.addRow();
		this.dsDgrList.setColumn(rowcnt, 'cdcValue', addCdcValue);
		this.dsDgrList.setColumn(rowcnt, 'cdcValueNm', addCdcValue.substring(3));
	  
	} else {
		var rowcnt = this.dsDgrList.addRow();
		this.dsDgrList.setColumn(rowcnt, 'cdcValue', addCdcValue);
		this.dsDgrList.setColumn(rowcnt, 'cdcValueNm', addCdcValue.substring(3));
	}
	
    this.divInfo.form.btnAddDgr.set_enable(false);
    fv_addDgrYn = false;
	
	//콤보박스 set
	this.divInfo.form.cboDgr.set_index(this.dsDgrList.getRowCount()-1);
	
	this.divInfo_cboDgr_onitemchanged();
};

/**
 * @description 이전내역 가져오기 버튼 클릭시 
*/
this.btnCopy_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 콤보박스값 가져오기
	var vsShlNm = this.dsSearch.getColumn(0, "shlNm");						//학교
	var vsShlCd = this.dsSearch.getColumn(0, "shlCd");						
	var vsAyr = this.dsSearch.getColumn(0, "ayr");							//년도
	var vsChckPlaceScCd = this.dsSearch.getColumn(0, "chckPlaceScCd");		//점검구분
	var vsHy = this.dsSearch.getColumn(0, "hyCd");						  	//반기
	var vsSpecl = this.dsSearch.getColumn(0, "speclChckRsnCd");				//특별점검
	var vsNwcc = this.dsSearch.getColumn(0, "nwccChckRsnCd");				//신축점검
	var vsDgr = this.divInfo.form.cboDgr.value;							//차수
	var addDgr = this.divInfo.form.btnAddDgr.enable;
	
	if(this.isNil(vsShlCd)){
		this.smfAlert('PA058', ['학교를 선택 ']);
		return false;
	}

	if(this.isNil(vsAyr)){
		this.smfAlert('CM006', ['년도']);
		return false;
	}
	
	if(this.isNil(vsChckPlaceScCd)){
		this.smfAlert('PA058', ['점검구분을 체크']);
		return false;
	}
	
	if(vsChckPlaceScCd == 10 && this.isNil(vsHy)){
		this.smfAlert('PA058', ['반기구분을 체크']);
		return false;
	}
	
	if(vsChckPlaceScCd == 20 && this.isNil(vsSpecl)){
		this.smfAlert('PA058', ['특별점검구분을 체크']);
		return false;
	}
	
	if(vsChckPlaceScCd == 30 && this.isNil(vsNwcc)){
		this.smfAlert('PA058', ['신축점검구분을 체크']);
		return false; 
	}
	if(addDgr == true){
		this.smfAlert('PA058', ['차수 추가를 체크']);
		return false;
	}
	
//check
	this.smfSearchService("check")
		// 실행
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
   
			if(this.dsApiResponseList.getColumn(0, 'prcsRltCd') == 'SUCC'){
				var msg = "";
				var msgAyr = this.dsSearchSub.getColumn(0, 'ayr');
				var gubun = this.dsSearchSub.getColumn(0, 'gubun');
				
				if(this.isNotNil(msgAyr) && this.isNotNil(gubun)){
					msg = "가장 최근에 등록된 자료가 " + msgAyr + "년 " + gubun + "입니다 . \n해당내역을 가져오시겠습니까?";
				}
				
				if(msg.length > 0){
					this.smfConfirm(msg, function(result){
						if(result.confirmResult){
							this.fnCopy();
						}
					});
				} else {
					this.smfAlert('CM155', ['이전내역이 없습니다.']);
					return;
				}
			}	  	  
		});
		
};

/**
 * @description 반기 라디오 버튼 클릭시 
*/
this.divInfo_rdoHy_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	if(this.isNil(this.dsSearch.getColumn(0, "shlCd"))){
		this.smfAlert('PA058', ['학교를 선택 ']);
		this.divInfo.form.rdoHy.set_value("-1");
		return false;
	}

	var rdoHyCd = this.divInfo.form.rdoHy.value;
	if(rdoHyCd == 1)		//상반기
	{
		this.dsSearch.setColumn(0, "chckPlaceMngNo", "1011");
	}
	else if(rdoHyCd == 2)		//하반기
	{
		this.dsSearch.setColumn(0, "chckPlaceMngNo", "1021");
	}

	//등록된 자료가 있을시 이전내역가져오기 비활성화, 저장, 삭제버튼 활성화
	 // 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'prcsRltCd') == 'SUCC'){
				var listCheck = this.dsListSub.getColumn(0, "shlCd");
				this.fnSetDdln(listCheck);
			}
	});
};

this.grdMain_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	//체크박스 전체 선택 
	this.smfToggleChkHeader(obj, e);
};


this.divInfo_calShlBuYm_onchanged = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{
	var dateVal = obj.value;
	if (dateVal.length === 8){
		var dateYm = dateVal.substr(0, 6);
		obj.set_value(dateYm);
		this.dsMain.setColumn(0, "shlBuYm", dateYm);
	}
	
	if(this.isNotNil(this.dsMain.getColumn(0, 'shlBuYm'))){
		for(var i=0; i<this.dsListSub.getRowCount(); i++){
			if(this.dsMain.getColumn(0, 'shlBuYm') == this.dsListSub.getColumn(i, 'faBuYm')){
				this.dsListSub.setColumn(i, 'checkYn', true);
			}	
		}
	}
};

/**
 * @description 차수 콤보박스 선택
*/
this.divInfo_cboDgr_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	// 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'prcsRltCd') == 'SUCC'){
				var listCheck = this.dsListSub.getColumn(0, 'shlCd');
				this.fnSetDdln(listCheck);
				
			}else{
				if (this.smfIsNull(this.dsApiResponseList.getColumn(0, 'errCn'))){
					this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')], this.fnMessageCallback);
				}else{
					this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'errCn')], this.fnMessageCallback);
				}
		}
	});
};

/**
 * @description 년도 콤보박스 선택
*/
this.divInfo_cboAyr_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	if(this.isNil(this.dsSearch.getColumn(0, "shlCd"))){
		this.smfAlert('PA058', ['학교를 선택 ']);
		return false;
	}
	
	this.divInfo.form.rdoHy.set_enable(false);
	this.divInfo.form.rdoSpecl.set_enable(false);
	this.divInfo.form.rdoNwcc.set_enable(false);
	this.divInfo.form.cboDgr.set_enable(false);
	this.divInfo.form.btnAddDgr.set_enable(false);
	
	this.divInfo.form.rdoChckPlaceScCd.set_value('');
	this.divInfo.form.rdoHy.set_value('');
	this.divInfo.form.rdoSpecl.set_value('');
	this.divInfo.form.rdoNwcc.set_value('');
	this.divInfo.form.cboDgr.set_value('');
	
	this.dsList.clearData();
	this.dsListSub.clearData();
};

/**
 * @description 삭제 버튼 클릭
*/
this.btnDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 검사결과가 있는지 체크
    var qltaInspRltYn = false;
	
	for(var i=0; i<this.dsListSub.getRowCount(); i++){
		if(this.dsList.getColumn(i, 'qltaInspRltYn') == "Y"){
			qltaInspRltYn = true;
			break;
		}
	}
	
	if(rltDelYn || qltaInspRltYn){
		this.smfConfirm("측정(검사)결과가 입력되어 있습니다.\n측정(검사)결과도 모두 삭제됩니다.\n\n삭제하시겠습니까?", function(result){
			if(result.confirmResult){
				// 삭제
				this.fnNoConfirmDelete();
			}
		});
	}else{
		this.fnDelete();
	}
};

/**
 * @description 그리드 건축연월 클릭 시
*/
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var rowCnt = e.row;
	var checkYn = this.dsListSub.getColumn(rowCnt, "checkYn");
	var dtiShlBuYm = this.divInfo.form.calShlBuYm.value;
	
	if (e.col == 3 || e.col == 4){
		if(this.divInfo.form.rdoSpecl.value != 1){
			this.smfAlert('CM000', ["신축3년이내 구분에서만 가능합니다. "]);
			//this.dsListSub.setColumn(rowCnt, 'faBuYm', '');
			//this.dsListSub.setColumn(rowCnt, "checkYn", false);
			return false;
		}else {
			if (checkYn == 1){
				this.dsListSub.setColumn(rowCnt, "faBuYm", dtiShlBuYm);
				
			}else {
				this.dsListSub.setColumn(rowCnt, "faBuYm", "");
			}
		}
	}
	
};

this.divInfo_rdoNwcc_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	var rdbNwcc = this.dsSearch.getColumn(0, 'nwccChckRsnCd');
	
	if(rdbNwcc == 1)
	{
		this.dsSearch.setColumn(0, "chckPlaceMngNo", "3011");
	}
	else if(rdbNwcc == 2)
	{
		this.dsSearch.setColumn(0, "chckPlaceMngNo", "3021");
	}
		
	//등록된 자료가 있을시 이전내역가져오기 비활성화, 저장, 삭제버튼 활성화
	 // 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'prcsRltCd') == 'SUCC'){
				var listCheck = this.dsListSub.getColumn(0, "shlCd");
				this.fnSetDdln(listCheck);
			}
		});
};

/**
 * @description 탭으로 접근해서 입력하는것 방지(건축년월)
*/
this.grdMain_oninput = function(obj:nexacro.Grid,e:nexacro.GridInputEventInfo)
{
	var rowCnt = e.row;
	
	if (e.col == 3){
		if(this.divInfo.form.rdoSpecl.value != 1){
			this.smfAlert('CM000', ["신축3년이내 구분에서만 가능합니다. "]);
			this.dsListSub.setColumn(rowCnt, 'faBuYm', '');
			//this.dsListSub.setColumn(rowCnt, "checkYn", false);
			return false;
		}
	}
};

/**
 * @description 탭으로 접근해서 입력하는것 방지(체크박스)
*/
this.dsListSub_oncolumnchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	var rowCnt = e.row;
	
	if(e.columnid == 'checkYn'){
		if(this.divInfo.form.rdoSpecl.value != 1){
			this.smfAlert('CM000', ["신축3년이내 구분에서만 가능합니다. "]);
			//this.dsListSub.setColumn(rowCnt, 'faBuYm', '');
			this.dsListSub.setColumn(rowCnt, "checkYn", false);
			return false;
		}
	}
};
]]></Script>
