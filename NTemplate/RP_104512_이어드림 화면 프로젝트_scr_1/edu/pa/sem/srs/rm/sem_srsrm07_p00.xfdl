    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    학교환경관리 > 공기질점검장소 등록/수정
*  @FileName 	sem_srsrm07_p00.xfdl 
*  @Creator 	whkim
*  @CreateDate 	2025.02.20
*  @Desction    먹는물점검장소 등록/수정
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2025.02.20            whkim                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::sem_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_param;	// 파라메터 세팅
this.fv_cddcCd;	// 시도교육청 코드
this.fv_brno;	// 사업자등록번호
this.fv_bizSn;	// 사업일련번호
this.fv_bizNm;  // 사업명
this.fv_shlBuYm;  // 학교건축연월

this.fv_procType;	//등록,수정구분
this.FrstInspCnt;

this.fv_addDgrYn;		//차수추가 여부
this.rltDelYn; 		// 점검결과가 있는데 "행삭제" 되었는지 여부
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	fv_addDgrYn = true;
	
	// 전달받은 파라메터 설정
	fv_param = this.smfGetPopupParams();
		
	//팝업명 수정
	var text = this.divTitle.form.imgTitle.text;
	var addText = fv_param.addTitle;
	this.divTitle.form.imgTitle.set_text(text + addText);
	
	//사업자등록번호
	fv_brno = fv_param.brno;
	fv_bizSn = fv_param.bizSn;
	
	//등록,수정 구분
	fv_procType = fv_param.procType;
	
	// 행삭제 여부 초기화
	rltDelYn = false;
	
	//학교코드 세팅
	this.dsShlList.loadXML(fv_param.shlList);
	this.dsShlList.filter("bizSn == " + fv_bizSn);
	
	//검사년도 기본 세팅
	this.yearCmbSet();

	if(fv_procType == "insert"){
		//삭제버튼 비활성화
		this.btnDelete.enable = false;
		
		this.staDdlnMngNo.set_visible(false);					// 마감문구 숨기기
		
		fv_cddcCd = this.smfGetCddcCode();
		this.dsSearch.setColumn(0, "cddcCd", fv_cddcCd);		//시도교육청
		
		var paramAyr = fv_param.ayr;
		this.dsSearch.setColumn(0, "ayr", paramAyr);				//검사년도
		
 		this.divInfo.form.rdoHy.set_enable(false);				// 반기 
 		this.divInfo.form.rdoNwcc.set_enable(false);			// 신축점검구분 
 		this.divInfo.form.rdoSpecl.set_enable(false);			// 특별점검구분 
 		this.divInfo.form.cboDgr.set_enable(false);				// 차수 
 		this.divInfo.form.btnAddDgr.set_enable(false);			// 차수등록 
		
	} else if(fv_procType == "update"){
	
		//부모창에서 받아온 파라미터로 조회조건 세팅
		this.dsSearch.loadXML(fv_param.dataset);
		
		//시도교육청
 		fv_cddcCd = this.smfGetCddcCode();
 		this.dsSearch.setColumn(0, "cddcCd", fv_cddcCd);	
		
		//목록 조회
		if("20" == this.dsSearch.getColumn(0, 'chckPlaceScCd')){
			this.fnDgrSearch();
		} else {
			this.fnSearch();
		}
	}
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 엑셀파일 import 콜백함수
 * @param : sImportId		- import ID
 * @param : bResult			- 결과값(true, false)
 * @return : N/A
 */
this.fnImportCallback = function(sImportId,bResult)
{
	if(bResult){
		var rowCnt = this.dsExcelImport.getRowCount();
		
		if(rowCnt < 1)return;
						
		var vsChckPlaceScCd = this.dsSearch.getColumn(0, "chckPlaceScCd");		//점검구분
		if(this.isNil(vsChckPlaceScCd)){
			this.smfAlert('PA058', ['점검구분을 체크']);
			return false;
		}
		
		// 점검장소 검증
		for(var i=0; i<rowCnt; i++){
			var rowChckFaNm = this.dsExcelImport.getColumn(i, 'chckFaNm');		// 측정장소
			if(this.smfLength(rowChckFaNm, 3) > 40){
				this.smfAlert('CM155', ['측정장소가 40Bytes를 초과하였습니다. 다시 등록하시기 바랍니다.']);
				return;
			}
			
			var vsRetFaScCd = this.smfNvl(this.dsExcelImport.getColumn(i, "retFaScCd"), "");	//점검장소
			var vsFaBuYm = this.smfNvl(this.dsExcelImport.getColumn(i, "faBuYm"), "");			//건축연월
			var vsChckPlaceScCd = this.dsSearch.getColumn(0, "chckPlaceScCd");				//점검구분
			var vsSpecl = this.divInfo.form.rdoSpecl.value;									//특별점검구분
			
			if(this.isNotNil(vsRetFaScCd) || this.isNotNil(vsFaBuYm) || this.isNotNil(rowChckFaNm)){
				var rowNum = this.dsListSub.addRow();
				
				if(this.isNotNil(vsRetFaScCd)){
					if(this.smfTrim(vsRetFaScCd) == "교실"){
						this.dsListSub.setColumn(rowNum, "retFaScCd", "110");
					}else if(this.smfTrim(vsRetFaScCd) == "특별교실"){
						this.dsListSub.setColumn(rowNum, "retFaScCd", "120");
					}else if(this.smfTrim(vsRetFaScCd) == "급식시설"){
						this.dsListSub.setColumn(rowNum, "retFaScCd", "130");
					}else if(this.smfTrim(vsRetFaScCd) == "기숙사"){
						this.dsListSub.setColumn(rowNum, "retFaScCd", "140");
					}else if(this.smfTrim(vsRetFaScCd) == "체육관"){
						this.dsListSub.setColumn(rowNum, "retFaScCd", "150");
					}else if(this.smfTrim(vsRetFaScCd) == "강당"){
						this.dsListSub.setColumn(rowNum, "retFaScCd", "160");
					}else if(this.smfTrim(vsRetFaScCd) == "보건실"){
						this.dsListSub.setColumn(rowNum, "retFaScCd", "170");
					}else if(this.smfTrim(vsRetFaScCd) == "교무실"){
						this.dsListSub.setColumn(rowNum, "retFaScCd", "180");
					}else if(this.smfTrim(vsRetFaScCd) == "행정실"){
						this.dsListSub.setColumn(rowNum, "retFaScCd", "190");
					}else if(this.smfTrim(vsRetFaScCd) == "컴퓨터실"){
						this.dsListSub.setColumn(rowNum, "retFaScCd", "191");
					} else {
						this.dsListSub.setColumn(rowNum, "retFaScCd", "");
					}
				}
				
				if(this.isNotNil(vsFaBuYm) && vsFaBuYm != ""){
					if (vsChckPlaceScCd == 20 && vsSpecl == 1){
						this.dsListSub.setColumn(rowNum, "faBuYm", vsFaBuYm);
					}else{
						this.dsListSub.setColumn(rowNum, "faBuYm", "");
					}
				}
				
				this.dsListSub.setColumn(rowNum, "chckFaNm", rowChckFaNm);
			}
			
		}
	}
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearch = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'prcsRltCd') == 'SUCC'){
				this.fnSetDdln();
				//this.fnDgrSearch();
				if(this.isNotNil(this.dsMain.getColumn(0, 'shlBuYm'))){
					for(var i=0; i<this.dsListSub.getRowCount(); i++){
						if(this.dsMain.getColumn(0, 'shlBuYm') == this.dsListSub.getColumn(i, 'faBuYm')){
							this.dsListSub.setColumn(i, 'checkYn', true);
						}
					}
				}
				
			}else{
				if (this.smfIsNull(this.dsApiResponseList.getColumn(0, 'errCn'))){
					this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')], this.fnMessageCallback);
				}else{
					this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'errCn')], this.fnMessageCallback);
				}
		}
	});
};

/**
 * 저장서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSave = function()
{
	// 서비스 객체 생성
	this.smfSaveService("save")
		// (권장) 데이터 존재 필수
		.requireExistsData(this.dsSearch)
		// 데이터 변경 필수
		.requireModifredData([this.dsSave, this.dsListSub])
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'prcsRltCd') == 'SUCC'){
				this.smfAlert('CM002', []); // 저장이 완료되었습니다.
				this.close();				// 저장 후 팝업 닫음
			}else{
				if (this.smfIsNull(this.dsApiResponseList.getColumn(0, 'errCn'))){
					this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')], this.fnMessageCallback);
				}else{
					this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'errCn')], this.fnMessageCallback);
				}
			}
		});
};

/**
 * 저장서비스
 * @param : N/A
 * @param : N/A
 */
this.fnNoConfirmSave = function()
{
	// 서비스 객체 생성
	this.smfSaveService("save")
		.showConfirm(false)
		// (권장) 데이터 존재 필수
		.requireExistsData(this.dsSearch)
		// 데이터 변경 필수
		.requireModifredData([this.dsSave, this.dsListSub])
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'prcsRltCd') == 'SUCC'){
				this.smfAlert('CM002', []); // 저장이 완료되었습니다.
				this.close();				// 저장 후 팝업 닫음
			}else{
				if (this.smfIsNull(this.dsApiResponseList.getColumn(0, 'errCn'))){
					this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')], this.fnMessageCallback);
				}else{
					this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'errCn')], this.fnMessageCallback);
				}
			}
		});
};

/**
 * 특별점검 차수조회 서비스
 */
this.fnDgrSearch = function ()
{
	this.dsDgrList.clearData();
	
	this.smfSearchService("listDgr")
	.requireExistsData(this.dsSearch)
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
					
		if (this.dsApiResponseList.getColumn(0, 'prcsRltCd') == 'SUCC'){
			
			//콤보박스 set
			if(fv_procType == "insert"){
				this.divInfo.form.cboDgr.set_index(0);
			}
			
			//등록된 자료가 있을시 이전내역가져오기 비활성화, 저장, 삭제버튼 활성화
			// 서비스 객체 생성
			this.smfSearchService("list")
				// 실행
				.run()
				.callback(function(callbackParams){
					if(callbackParams.errors) return;
					
					if (this.dsApiResponseList.getColumn(0, 'prcsRltCd') == 'SUCC'){
						var listCheck = this.dsListSub.getColumn(0, "shlCd");
						this.fnSetDdln(listCheck);
						
						if(this.isNotNil(this.dsMain.getColumn(0, 'shlBuYm'))){
							for(var i=0; i<this.dsListSub.getRowCount(); i++){
								if(this.dsMain.getColumn(0, 'shlBuYm') == this.dsListSub.getColumn(i, 'faBuYm')){
									this.dsListSub.setColumn(i, 'checkYn', true);
								}	
							}
						}
					}
					
	});
		}else{
			if (this.smfIsNull(this.dsApiResponseList.getColumn(0, 'errCn'))){
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')], this.fnMessageCallback);
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'errCn')], this.fnMessageCallback);
			}
		}
	});
};

/**
 * 이전내역 가져오기 서비스
 */
this.fnCopy = function ()
{
	this.smfSearchService("listCopy")
	.requireExistsData(this.dsSearch)
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		if (this.dsApiResponseList.getColumn(0, 'prcsRltCd') == 'SUCC'){

			// 불러온 데이터 복사
			this.dsMain.copyData(this.dsMainPre);
			this.dsListSub.copyData(this.dsListSubPre);
			
			for(var i=0; i<this.dsListSub.getRowCount(); i++){
				this.dsListSub.setColumn(i, 'chckRetFaSn', '');
			}

		}else{
			if (this.smfIsNull(this.dsApiResponseList.getColumn(0, 'errCn'))){
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')], this.fnMessageCallback);
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'errCn')], this.fnMessageCallback);
			}
		}
	});
};

/**
 * @description 삭제 Transaction
 */
this.fnDelete = function()
{	
 	// 서비스 객체 생성
	this.smfDeleteService("delete")
		// (권장) 데이터 존재 필수
		.requireExistsData(this.dsSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'prcsRltCd') == 'SUCC'){
				this.smfAlert('PA020');	// 삭제가 완료되었습니다.
				// 창 닫기
				this.close();
			}else{
				this.smfAlert('CM000', [this.dsApiResponseList.getColumn(0, 'errCn')]);
			}
		});
};

