                <Cell col="7" displaytype="calendarcontrol" edittype="date" text="bind:qltaLastInspYmd" calendardateformat="yyyy.MM.dd" calendareditformat="yyyy.MM.dd" calendardisplaynulltype="nullmask" tooltiptext="bind:qltaLastInspYmd"/>
                <Cell col="8" displaytype="editcontrol" edittype="text" text="bind:qltaLastInspComyNm" textAlign="left" tooltiptext="bind:qltaLastInspComyNm" editmaxlength="30" editautoselect="true"/>
