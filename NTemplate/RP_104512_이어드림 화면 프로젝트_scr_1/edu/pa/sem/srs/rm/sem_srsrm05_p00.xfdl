                <Cell col="1" text="점검시설"/>
                <Cell col="2" text="점검장소명"/>
                <Cell col="3" text="점검항목"/>
                <Cell col="4" text="1차점검결과"/>
                <Cell col="5" text="조치사항"/>
                <Cell col="6" text="최종점검결과"/>
