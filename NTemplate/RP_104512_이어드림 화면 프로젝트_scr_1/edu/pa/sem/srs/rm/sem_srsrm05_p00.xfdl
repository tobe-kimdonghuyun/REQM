    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    환경관리 > 공기질특별점검 수정
*  @FileName 	sem_srsrm05_p00.xfdl 
*  @Creator 	김민성
*  @CreateDate 	2022.09.26
*  @Desction    공기질특별점검 수정
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.09.26            김민성                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::sem_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.FrstInspCnt;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	
	// 파라메터 세팅
	var pv_params = this.smfGetPopupParams();
	this.dsSearch.set_updatecontrol(false);
	this.dsSearch.loadXML(pv_params.dataset);
	var qltwtInspYmd = this.dsSearch.getColumn(0, 'speclChckYmd');
	this.dsSearch.setColumn(0, "cddcCd", this.smfGetCddcCode());
	this.dsSearch.setColumn(0, "brno", this.smfGetBrno());
	this.dsSearch.set_updatecontrol(true);
	
	this.divTitle.form.imgTitle.set_text(this.divTitle.form.imgTitle.text + (this.dsSearch.getColumn(0, 'wrtYn') == 'Y' ? " 수정" : " 등록"));
	
	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
		url : "/sem_srs_rm05_000.do",
		})
		.mappingRulesetToDataset(this.dsMainValid, "save")
		.callback(function(callbackParams) {
		})
		.run()
	;

	// 공통코드의 코드구분
	this.smfCodeList("code", [this.dsSpeclChckRsnCd])
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		})
	;

	//=======================================
	// 업로드관련 초기설정을 한다.
	//=======================================
	// 업로드시 저장위치등을 판별할 정보 세팅(대문자 : 시스템코드(2)+"."+서브시스템코드(3)+"."+대분류코드(3))
	this.div01.form.divFileUpload.UPLOAD_CreateComplete = this.fnEventUploadCreateComplete;  // 필요한 경우만 세팅
	this.div01.form.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;        // 필요한 경우만 세팅(세팅권장)
	this.div01.form.divFileUpload.UPLOAD_OnError        = this.fnEventUploadError;           // 필요한 경우만 세팅(세팅권장)
	this.div01.form.divFileUpload.UPLOAD_AfterAddFile   = this.fnEventUploadAfterAddFile;
 	this.div01.form.divFileUpload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)
	this.div01.form.divFileUpload.form.RaonkUpload.addEventHandler("RAONKUPLOAD_AfterDeleteFile", this.fnEventUploadAfterDeleteFile, false);
	
	this.fnSearchSelect();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
}

/**
 * 엑셀파일 import 콜백함수
 * @param : sImportId		- import ID
 * @param : bResult			- 결과값(true, false)
 * @return : N/A
 */
this.fnImportCallback = function(sImportId,bResult)
{
	if(bResult){
		// 비교 컬럼 리스트
		var voKey = new Array();
		voKey.push("speclChckInspItmNm");    // 공기질검사항목명
		voKey.push("retFaScNm");        // 보유시설명
		voKey.push("chckFaNm");         // 점검시설명
		this.fnGridUpload(this.grdMain, this.dsExcelImport, voKey);
	}
}

/**
 * raonkupload가 화면을 생성된 이후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @return : N/A
 */
this.fnEventUploadCreateComplete = function(obj,paramObj)
{
}

/**
 * raonkupload가 파일을upload한 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @param : objResultDataset
 * @return : N/A
 */
this.fnEventUploadComplete = function(obj,paramObj,objResultDataset)
{
	// 업로드 성공 후, newfile에 있는 파일들을 webfile로 옮긴다.
	this.div01.form.divFileUpload.form.fnSetUploadCompleteState(obj,paramObj);
	if(objResultDataset != null){
		this.dsSearch.setColumn(0, "speclChckFileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
		for(var i = 0; i < objResultDataset.getRowCount(); i++){
			var row = this.dsOutFileinfo.addRow();
			this.dsOutFileinfo.copyRow(row, objResultDataset, i);
		}
	}
	
	if (this.FrstInspCnt != 0 && (this.dsOutFileinfo.getRowCount() == 0 || this.dsOutFileinfo.extractRows("useYn == 'N'").length == this.dsOutFileinfo.getRowCount())){
		this.smfAlert('PA061', ['첨부파일은 필수']);
		return;
	}
	
	this.fnSave();
}

/**
 * raonkupload가 파일을upload실패 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @return : N/A
 */
this.fnEventUploadError = function(obj,paramObj)
{
}

/**
 * raonkupload가 파일을 추가 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @param : sCustomValue
 * @param : sFileName
 * @param : nFileSize
 * @return : N/A
 */
this.fnEventUploadAfterAddFile = function(obj,paramObj,sCustomValue,sFileName,nFileSize)
{
}

/**
 * raonkupload가 파일을 삭제 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @param : sCustomValue
 * @param : sFileName
 * @param : nFileSize
 * @return : N/A
 */
this.fnEventUploadAfterDeleteFile = function(obj, paramObj)
{
 	var fileNm = paramObj.userdata.strKey;
 	var formThis = this.parent.parent.parent.parent.parent;

	var row = formThis.dsOutFileinfo.findRow('atchFileGuid', fileNm);
	if (row != -1){
		formThis.dsOutFileinfo.setColumn(row, 'useYn', 'N');
	}
}
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchSelect = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("select")
		// 데이터가 변경되었으면 확인메시지
		//.confirmIfModifiedGrid(this.grdPaging)
		// 데이터 검증
		//.validateForm(this.divSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'prcsRltCd') == 'SUCC'){
				if (!this.smfIsNull(this.dsSearch.getColumn(0, 'speclChckFileRefrnId'))){
					this.fnListFileInfo();
				}
			}else{
				if (this.smfIsNull(this.dsApiResponseList.getColumn(0, 'errCn'))){
					this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')], this.fnMessageCallback);
				}else{
					this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'errCn')], this.fnMessageCallback);
				}
			}
		});
};

/**
 * 저장서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSave = function()
{
	// 서비스 객체 생성
	this.smfSaveService("save")
		// (권장) 데이터 존재 필수
		.requireExistsData(this.dsSearch)
		// 데이터 변경 필수
		.requireModifredData([this.dsSearch, this.dsMain, this.dsOutFileinfo])
		// 데이터 검증
		//.validateGrid(this.grdMain, this.dsMainValid)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'prcsRltCd') == 'SUCC'){
				this.smfAlert('CM002', [], this.fnMessageCallback); // 저장이 완료되었습니다.
				this.fnSearchSelect();
			}else{
				if (this.smfIsNull(this.dsApiResponseList.getColumn(0, 'errCn'))){
					this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')], this.fnMessageCallback);
				}else{
					this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'errCn')], this.fnMessageCallback);
				}
			}
		});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * KUpload를 생성시 지정할 property값을 지정
 * @param  : N/A
 * @return : N/A
 */
this.fnSetRaonProp = function()
{
	// 설정할 property
	var objAddRaonProps = {
							MaxOneFileSize			: '10MB'									// 파일당 최대 사이즈
							,ExtensionAllowOrLimit	: '1'										// 설정값이 "0" 이면 설정한 파일 확장자명만 "제한"으로 설정되며, "1"로 설정시 "허용"으로 설정
							,ExtensionArr           : 'pdf,png,jpg,jpeg,PDF,PNG,JPG,JPEG'		// 제한 또는 허용할 확장자 (,)로 구분
							,DisableAlertMessage	: {
								DisableDeleteConfirm: "1" 										// "1"로 설정시 파일 삭제시 confirm창 비활성.
							}
							,ButtonBarEdit			: "add,remove,remove_all,download,download_all"
							,UseDbclickOpen			: '1'										// 더블클릭으로 파일열기 0: 사용안함 1:사용
							};
	return objAddRaonProps;
}

/**
 * 파일 조회
 * @param : N/A
 * @param : N/A
 */
this.fnListFileInfo = function(){
	// 업로드 초기화
	this.div01.form.divFileUpload.form.fnResetUpload();
	
	for (var i = 0; i < this.dsOutFileinfo.getRowCount(); i++) {
		var handlerCode       = "PA.SEM.SRS";
		var atchFileSn        = this.dsOutFileinfo.getColumn(i, "fileRefrnId");
		var fileSize          = this.dsOutFileinfo.getColumn(i, "atchFileMg"); 
		var backendFilename   = this.dsOutFileinfo.getColumn(i, "atchFileGuid");
		var frontendFilename  = this.dsOutFileinfo.getColumn(i, "atchFileNm");
		var fileId            = this.dsOutFileinfo.getColumn(i, "fileId");
		if(this.isNotNil(atchFileSn)){
			this.div01.form.divFileUpload.form.fnAddUploadedFile(handlerCode, atchFileSn, fileSize, backendFilename, frontendFilename, fileId);
		}
	}
};

/**
 * 저장 체크
 * @param : N/A
 * @return : true : 저장 적합, false : 저장 부적합
 */
this.fnSaveChk = function(){
	var cntObj = {};
	var cntArray = new Array();
	var ymdChk = "";
	
	this.FrstInspCnt = this.dsMain.getCaseCount("qltaFrstChckRltNmvl != null && qltaFrstChckRltNmvl != ''");
	if (this.FrstInspCnt != 0 && this.smfIsNull(this.dsSearch.getColumn(0, 'speclChckYmd'))){
		this.smfAlert('LI155', ['1차점검일자를 입력하세요.']);
		return false;
	}
	
	for(var i = 0; i < this.dsMain.rowcount; i++){
		if (!this.smfIsNull(this.dsMain.getColumn(i, 'qltaLastChckRltNmvl'))
			&& this.smfIsNull(this.dsMain.getColumn(i, 'qltaFrstChckRltNmvl'))){
			cntObj["msg0"] = '항목의 1차점검결과를 입력하세요.';
			cntArray.push("cntList0");
			this.smfIsNull(cntObj["cntList0"]) ? (cntObj["cntList0"] = [(i + 1) + "번째"]) : (cntObj["cntList0"].push((i + 1) + "번째"));
		}
		
		if ((!this.smfIsNull(this.dsMain.getColumn(i, 'qltaLastChckRltNmvl'))
			&& this.smfIsNull(this.dsMain.getColumn(i, 'qltaFrstActnMteCn')))
			|| (!this.smfIsNull(this.dsMain.getColumn(i, 'qltaLastChckRltNmvl'))
			&& this.smfIsNull(this.dsMain.getColumn(i, 'qltaLastInspYmd')))
			|| (!this.smfIsNull(this.dsMain.getColumn(i, 'qltaLastChckRltNmvl'))
			&& this.smfIsNull(this.dsMain.getColumn(i, 'qltaLastInspComyNm')))){
			cntObj["msg1"] = '항목을 입력해주세요. \n 최종점검결과 입력시(조치사항, 최종점검일자, 최종점검업체)는 필수사항입니다.';
			cntArray.push("cntList1");
			this.smfIsNull(cntObj["cntList1"]) ? (cntObj["cntList1"] = [(i + 1) + "번째"]) : (cntObj["cntList1"].push((i + 1) + "번째"));
		}
	
		
		if (this.dsMain.getColumn(i, 'qltaLastInspYmd') > this.smfToday()){
			ymdChk = 'qltaLastInspYmd'
			this.dsMain.setColumn(i, 'qltaLastInspYmd', this.smfToday());
			
		}else if (this.dsMain.getColumn(i, 'qltaLastInspYmd') < this.dsSearch.getColumn(0, 'speclChckYmd')){
			ymdChk = 'speclChckYmd'
			this.dsMain.setColumn(i, 'qltaLastInspYmd', this.dsSearch.getColumn(0, 'speclChckYmd'));	
		}
		
	}
		if(ymdChk == 'qltaLastInspYmd'){
			this.smfAlert('CM020', ['최종점검일자', '오늘']);
			return;
		}else if(ymdChk == 'speclChckYmd'){
			this.smfAlert('CM021', ['최종점검일자', '1차점검일자']);
			return;
		}
	
	
	if (!this.smfIsNull(cntObj[cntArray[0]])){
		this.smfAlert('LI155', ["(" + cntObj[cntArray[0]].join(', ') + ")" + cntObj["msg" + cntArray[0].substr(7)]]);
		return false;
	}
	
	return true;
};



/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 양식다운로드 버튼 클릭 시
 * @param  : obj			- [object]Grid
 * @param  : e				- [string]GridClickEventInfo
 * @return : N/A
 */
this.btnDownload_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objOption = {
						objGrid : this.grdExcelExport
					,   sheetname : "Sheet1"
					,   filename : "공기질특별점검_" + this.smfTodayTime()
					};
	this.smfExcelExport(objOption);
};

/**
 * 결과업로드 버튼 클릭 시
 * @param  : obj			- [object]Grid
 * @param  : e				- [string]GridClickEventInfo
 * @return : N/A
 */
this.btnUpload_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objOption = {
						datasetname : "dsExcelImport"
					,   sheetname   : "Sheet1"
					,   startcell   : "A2"
					,   callback    : "fnImportCallback"
					,   importId    : "import"
					,   objForm     : this
					};
	this.smfExcelImport(objOption);
};

/**
 * 저장 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (!this.fnSaveChk()) return;

	this.div01.form.divFileUpload.form.fnFileUpload();
	
};

/**
 * 닫기 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close();
};

/**
 * 캘랜더 값 변경 시
 * @param  : obj			- [object]Calendar
 * @param  : e				- [string]ChangeEventInfo
 * @return : N/A
 */
this.div00_calChckYmd_onchanged = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{
	if (e.postvalue > this.smfToday()){
		this.smfAlert('CM020', ['1차점검일자', '오늘']);
		obj.set_value(this.smfToday());
		return;
	}
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="div00.form.edtShlNm" propid="value" datasetid="dsSearch" columnid="shlNm"/>
      <BindItem id="item1" compid="div00.form.edtChckYr" propid="value" datasetid="dsSearch" columnid="ayr"/>
      <BindItem id="item3" compid="div00.form.edtChckDgr" propid="value" datasetid="dsSearch" columnid="speclChckDgr"/>
      <BindItem id="item4" compid="div00.form.edtEtcRsn" propid="value" datasetid="dsSearch" columnid="speclChckRsnEtcCn"/>
      <BindItem id="item6" compid="div00.form.edtChckComy" propid="value" datasetid="dsSearch" columnid="speclChckComyNm"/>
      <BindItem id="item2" compid="div00.form.rdoChckRsn" propid="value" datasetid="dsSearch" columnid="speclChckRsnCd"/>
      <BindItem id="item5" compid="div00.form.calChckYmd" propid="value" datasetid="dsSearch" columnid="speclChckYmd"/>
    </Bind>
  </Form>
</FDL>
