        <Div id="divSearch" taborder="1" left="0" top="sta01:0" height="70" cssclass="div_WF_Search" right="0" accessibilityenable="false" accessibilityrole="none" text="">
          <Layouts>
            <Layout initvalueid="ivDivAccessibilityOff">
              <Button id="btnSearch" taborder="8" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="20" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="조회" onclick="divSearch_btnSearch_onclick"/>
              <Static id="staBizNm" taborder="0" text="사업명" left="0" top="20" height="30" cssclass="sta_WF_Essential01" initvalueid="ivStcAccessibilityOff" width="77"/>
              <Combo id="cboBizNm" taborder="1" left="staBizNm:0" height="30" innerdataset="dsBizList" codecolumn="bizSn" datacolumn="bizNm" index="0" top="20" value="" initvalueid="ivCmbReadOnly" accessibilitylabel="사업명" text="" width="200" onitemchanged="divSearch_cboBizNm_onitemchanged"/>
              <Static id="staByr" taborder="2" text="년도" left="cboBizNm:0" top="20" height="30" cssclass="sta_WF_Essential01" initvalueid="ivStcAccessibilityOff" width="63"/>
              <Combo id="cboAyr" taborder="3" left="staByr:0" width="120" height="30" innerdataset="dsAyr" codecolumn="ayr" datacolumn="ayrNm" index="0" top="20" initvalueid="ivCmbReadOnly" accessibilitylabel="년도" text=""/>
              <Static id="staHy" taborder="4" text="반기" left="cboAyr:0" top="20" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOff" width="57"/>
              <Combo id="cboHy" taborder="5" left="staHy:0" width="120" height="30" innerdataset="dsHyCd" codecolumn="unyCdValue" datacolumn="unyCdValueNm" index="0" top="20" initvalueid="ivCmbReadOnly" accessibilitylabel="반기" text=""/>
              <Static id="staShlNm" taborder="6" text="학교명" left="cboHy:0" top="20" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOff" width="71"/>
              <Combo id="cboShlNm" taborder="7" left="staShlNm:0" width="200" height="30" top="20" initvalueid="ivCmbNormal" text="" innerdataset="dsBizSnShlCdList" datacolumn="shlNm" codecolumn="shlCd" index="-1" accessibilitylabel="학교명"/>
            </Layout>
