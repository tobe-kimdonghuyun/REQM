        <Static id="sta02" taborder="5" left="0" top="divSearch:0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Grid id="grdMain" taborder="2" left="0" top="sta02:0" height="480" autofittype="col" right="0" binddataset="dsMain" selecttype="cell" initvalueid="ivGrdAccessibilityOn" oncellclick="grdMain_oncellclick" accessibilitylabel="지하수수질검사결과표(발주기관명,검사대상학교,검사년도,분기,전체검사여부,작성여부)">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="129"/>
                <Column size="193"/>
                <Column size="109"/>
                <Column size="113"/>
                <Column size="143"/>
                <Column size="92"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="발주기관명"/>
                <Cell col="1" text="검사대상학교" cssclass="LineNo"/>
