        </Div>
        <Static id="sta01" taborder="4" left="0" top="divTitle:0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Div id="divSearch" taborder="1" left="0" top="sta01:0" height="70" cssclass="div_WF_Search" right="0" accessibilityenable="false" accessibilityrole="none" text="">
          <Layouts>
            <Layout initvalueid="ivDivAccessibilityOff">
              <Button id="btnSearch" taborder="8" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="20" onclick="divSearch_btnSearch_onclick" initvalueid="ivBtnAccessibilityButton"/>
              <Static id="staBizNm" taborder="0" text="사업명" left="0" top="20" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOff" width="77"/>
              <Combo id="cboBizNm" taborder="1" left="staBizNm:0" height="30" innerdataset="dsBizList" codecolumn="bizSn" datacolumn="bizNm" index="0" readonly="false" top="20" value="" initvalueid="ivCmbReadOnly" accessibilitylabel="사업명" onclick="Common_onclick" text="" width="200" onitemchanged="divSearch_cboBizNm_onitemchanged" displaynulltext="- 선택 -"/>
              <Static id="staAyr" taborder="2" text="년도" left="cboBizNm:0" top="20" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOff" width="63"/>
              <Combo id="cboAyr" taborder="3" left="staAyr:0" width="120" height="30" innerdataset="dsAyrList" codecolumn="ayr" datacolumn="ayr" index="0" readonly="false" top="20" initvalueid="ivCmbReadOnly" accessibilitylabel="년도" text="" displaynulltext="- 선택 -"/>
              <Static id="staQtrScCd" taborder="4" text="분기" left="cboAyr:0" top="20" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOff" width="63"/>
              <Combo id="cboQtrScCd" taborder="5" left="staQtrScCd:0" width="120" height="30" innerdataset="dsQtrScCd" codecolumn="unyCdValue" datacolumn="unyCdValueNm" index="0" readonly="false" top="20" initvalueid="ivCmbReadOnly" accessibilitylabel="분기" text=""/>
              <Static id="staShlNm" taborder="6" text="학교명" left="cboQtrScCd:0" top="20" height="30" initvalueid="ivStcAccessibilityOff" width="77" cssclass="sta_WF_Searchtxt01"/>
              <Combo id="cboShlNm" taborder="7" left="staShlNm:0" width="200" height="30" innerdataset="dsShlList" codecolumn="shlCd" datacolumn="shlNm" index="0" readonly="false" top="20" initvalueid="ivCmbReadOnly" accessibilitylabel="학교명" text="" value=""/>
            </Layout>
