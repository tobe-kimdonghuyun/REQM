    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    먹는물점검장소 등록/수정
*  @FileName 	sem_srsrm08_p00.xfdl 
*  @Creator 	dylee
*  @CreateDate 	2025.02.19
*  @Desction    먹는물점검장소 등록/수정
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2025.02.19            dylee                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::sem_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_param;	// 파라메터 세팅
this.fv_cddcCd;	// 시도교육청 코드

this.fv_brno;				// 사업자등록번호
this.fv_bizSn;				// 사업일련번호
this.fv_inspComyNm;			//수질검사업체명
this.fv_inspComyDsgnYmd;	//검사업체지정일자

this.fv_procType;	//등록,수정구분
this.FrstInspCnt;

this.rltDelYn; 		// 점검결과가 있는데 "행삭제" 되었는지 여부
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	
	// 전달받은 파라메터 설정
	fv_param = this.smfGetPopupParams();
	
	//팝업명 수정
	var text = this.divTitle.form.imgTitle.text;
	var addText = fv_param.addTitle;
	this.divTitle.form.imgTitle.set_text(text+addText);
	
	//사업자등록번호
	fv_brno = fv_param.brno;
	fv_bizSn = fv_param.bizSn;
	fv_inspComyNm = fv_param.comyNm;
	fv_inspComyDsgnYmd = fv_param.comyYmd;
	
	//시도교육청코드
	fv_cddcCd = this.smfGetCddcCode();
	
	//등록,수정 구분
	fv_procType = fv_param.procType;
	
	// 행삭제 여부 초기화
	rltDelYn = false;
	
	//학교코드 세팅
	this.dsShlList.loadXML(fv_param.shlList);
	this.dsShlList.filter("bizSn == " + fv_bizSn);
	
	//검사년도 기본 세팅
	this.yearCmbSet();
	
	if(fv_procType == "insert"){
		this.dsSearch.setColumn(0, "cddcCd", fv_cddcCd);			// 시도교육청
		
		var paramAyr = fv_param.ayr;
		var paramQtrScCd = fv_param.qtrScCd;
		
		this.dsSearch.setColumn(0, "ayr", paramAyr);				// 검사년도
		
		if(this.isNotNil(paramQtrScCd)){							// 분기
			this.dsSearch.setColumn(0, "qtrScCd", paramQtrScCd);
		}else{
			this.dsSearch.setColumn(0, "qtrScCd", 1);
		}
		
		this.btnDelete.set_enable(false);							// 삭제불가
		
	} else if(fv_procType == "update"){
		//부모창에서 받아온 파라미터로 조회조건 세팅
		this.dsSearch.loadXML(fv_param.dataset);
		
		this.dsSearch.setColumn(0, "cddcCd", fv_cddcCd);	// 시도교육청
		
		this.btnCopy.set_enable(false);						// 전분기내역가져오기 불가
		this.btnDelete.set_enable(true);					// 삭제가능
		this.div00.form.cboShlNm.set_enable(false); 		// 학교명
		this.div00.form.cboAyr.set_enable(false);			// 검사년도
		this.div00.form.rdoQtrSc.set_enable(false);			// 분기
		this.div00.form.cboWrteSpl.set_enable(false);		// 공급구분
		
		//목록 조회
		this.fnSearch();
	}
	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * @description Import callback
 */ 
this.fnImportCallback = function(sImportId,bResult)
{	
	if(bResult){
		var rowcnt = this.dsExcelImport.getRowCount();
		
		if(rowcnt < 1)return;
		
		// 입력 값 검증
		for(var i=0; i<rowcnt; i++){
			var wrprMngNo = this.dsExcelImport.getColumn(i, 'wrprMngNo');				// 관리번호
			var wrprPstnRmkCn = this.dsExcelImport.getColumn(i, 'wrprPstnRmkCn');		// 설치위치
			
			if(this.smfLength(wrprMngNo, 3) > 40){
				this.smfAlert('CM155', ['관리번호가 40Bytes를 초과하였습니다. 다시 등록하시기 바랍니다.']);
				return;
			}
			if(this.smfLength(wrprPstnRmkCn, 3) > 100){
				this.smfAlert('CM155', ['설치위치가 100Bytes를 초과하였습니다. 다시 등록하시기 바랍니다.']);
				return;
			}
		}
		
		for(var i=0; i<rowcnt; i++){
			var wrprScNm = this.dsExcelImport.getColumn(i, 'wrprScNm');					// 구분
			var wrprSplScNm = this.dsExcelImport.getColumn(i, 'wrprSplScNm');			// 공급구분
			var wrprMngNo = this.dsExcelImport.getColumn(i, 'wrprMngNo');				// 관리번호
			var wrprPstnRmkCn = this.dsExcelImport.getColumn(i, 'wrprPstnRmkCn');		// 설치위치
		
			if(this.isNotNil(wrprScNm) || this.isNotNil(wrprSplScNm) || this.isNotNil(wrprMngNo) || this.isNotNil(wrprPstnRmkCn)){
				var rownum = this.dsList.addRow();
			
				// 구분
				if(wrprScNm == "정수기"){
					this.dsList.setColumn(rownum, 'wrprScCd', 1);
				}else if(wrprScNm == "냉온수기"){
					this.dsList.setColumn(rownum, 'wrprScCd', 2);
				}else {
					this.dsList.setColumn(rownum, 'wrprScCd', '');
				}
				
				// 공급구분
				if(wrprSplScNm == "상수도"){
					this.dsList.setColumn(rownum, 'wrprSplScCd', 1);
				}else if(wrprSplScNm == "지하수"){
					this.dsList.setColumn(rownum, 'wrprSplScCd', 2);
				}else {
					this.dsList.setColumn(rownum, 'wrprSplScCd', '');
				}
				
				this.dsList.setColumn(rownum, 'wrprMngNo' , wrprMngNo)					// 관리번호
				this.dsList.setColumn(rownum, 'wrprPstnRmkCn' , wrprPstnRmkCn)			// 설치위치
			}
			
		}
	}
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 목록 조회 Transaction
 */

this.fnSearch = function()
{
	//조회 전 공급구분, 전체 저수조수, 먹는물이용 저수조수 값 초기화
	this.dsData.clearData();
	this.dsData.addRow();
	
 	// 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'prcsRltCd') == 'SUCC'){
			
				//마감체크
				var wrteDdlnMngNo = this.dsData.getColumn(0, 'wrteDdlnMngNo');	//먹는물마감관리번호
				
				// 지역교육청마감여부, 지역교육청제출여부
				var dstrtOfcdcDdlnYn  = this.dsData.getColumn(0, 'dstrtOfcdcDdlnYn');
				var dstrtOfcdcSbmsnYn = this.dsData.getColumn(0, 'dstrtOfcdcSbmsnYn');
				
				// 시도교육청마감여부, 시도교육청제출여부
				var cddcDdlnYn  = this.dsData.getColumn(0, 'cddcDdlnYn');
				var cddcSbmsnYn = this.dsData.getColumn(0, 'cddcSbmsnYn');
				
				// 마감됨
				if(this.isNotNil(wrteDdlnMngNo)){
					this.sta03_00.set_visible(true);		// 마감문구 보이기
					
					this.btnCopy.set_enable(false);			// 전분기내역 가져오기
					this.btnSave.set_enable(false);			// 저장 버튼
					this.btnDelete.set_enable(false);		// 삭제 버튼
					
					this.btnRowAdd.set_enable(false);		// 행추가 버튼
					this.btnRowDelete.set_enable(false);	// 행삭제 버튼
					this.btnDownload.set_enable(false);		// 양식 내려받기
					this.btnUpload.set_enable(false);		// 파일 올리기
					
					this.div00.form.cboAyr.enable(false);	// 년도
					
					if(fv_procType != "insert"){
						this.div00.form.rdoQtrSc.set_enable(false);		// 분기
					}
					this.div00.form.cboWrteSpl.set_enable(false);		// 공급구분
					
				// 마감안됨
				}else{
					this.sta03_00.set_visible(false);		// 마감문구 숨기기
					
					// 등록
					if(fv_procType == "insert"){
						this.btnDelete.set_enable(false);						// 삭제불가
						
						if(this.dsList.getRowCount() < 1){						// 기존 데이터 없을 경우
							this.btnCopy.set_enable(true);							// 전분기내역 가져오기 가능
							this.btnSave.set_enable(true);							// 저장가능
							this.btnDelete.set_enable(false);						// 삭제불가
							this.div00.form.cboAyr.set_enable(true)					// 년도 변경가능
							this.div00.form.cboWrteSpl.set_enable(true)				// 공급구분 변경가능
						}
						else{														// 기존 데이터 있을 경우
							this.btnCopy.set_enable(false);							// 전분기내역 가져오기 불가
							this.btnSave.set_enable(true);							// 저장가능
							this.btnDelete.set_enable(true);						// 삭제가능
							this.div00.form.cboAyr.set_enable(false)				// 년도 변경불가
							this.div00.form.cboWrteSpl.set_enable(false)			// 공급구분 변경불가
						}
					}
					// 정수기 및 냉온수기 버튼
					this.btnRowAdd.set_enable(true);		// 행추가 버튼
					this.btnRowDelete.set_enable(true);	// 행삭제 버튼
					this.btnDownload.set_enable(true);		// 양식 내려받기
					this.btnUpload.set_enable(true);		// 파일 올리기
				}
				
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'errCn')]);
			}
		});
};


/**
 * @description 목록 저장 Transaction
 */
this.fnSave = function()
{	
	//저장 전 업체명, 사업일련번호, 검사업체지정일자 추가
	this.dsData.setColumn(0, 'bizSn', fv_bizSn);
	this.dsData.setColumn(0, 'qltwtInspComyNm', fv_inspComyNm);
	this.dsData.setColumn(0, 'qltwtInspYmd', fv_inspComyDsgnYmd);
	
	for(var i=0; i<this.dsList.getRowCount(); i++){
		this.dsList.setColumn(i, 'bizSn', fv_bizSn);
		this.dsList.setColumn(i, 'qltwtInspComyNm', fv_inspComyNm);
		this.dsList.setColumn(i, 'qltwtInspYmd', fv_inspComyDsgnYmd);
	}

 	// 서비스 객체 생성
	this.smfSaveService("save")
		// (권장) 데이터 존재 필수
		.requireExistsData(this.dsSearch)
		// 데이터 변경 필수
		.requireModifredData([this.dsSearch, this.dsData, this.dsList])
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'prcsRltCd') == 'SUCC'){
				this.smfAlert('CM002', []); // 저장이 완료되었습니다.
				this.close();				// 저장 후 팝업 닫음
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'errCn')]);
			}
		});
};

