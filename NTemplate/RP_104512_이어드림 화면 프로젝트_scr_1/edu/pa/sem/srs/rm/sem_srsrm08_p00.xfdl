/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/**
 * @description 조회조건 년도 세팅 : 현재년도 ~  현재년도-2
*/
this.yearCmbSet = function(){
	var today = new nexacro.Date();
	var year = today.getFullYear();
	
	for(var i = 0; i < 3; i++){
		var yearVal = year - i;
		this.dsAyrList.addRow();
		this.dsAyrList.setColumn(i, 'ayr', yearVal);
	}
};

/**
 * 저장 체크
 * @param : N/A
 * @return : true : 저장 적합, false : 저장 부적합
 */
this.fnSaveChk = function(){
	var valShlCd = this.dsSearch.getColumn(0, "shlCd");				// 학교코드
	var valAyr = this.dsSearch.getColumn(0, "ayr");					// 학년도
	var valQtrScCd = this.dsSearch.getColumn(0, "qtrScCd");			// 분기구분코드
	var valWrteSplScCd = this.dsData.getColumn(0, "wrteSplScCd");	// 먹는물공급구분코드
	var valWrtkCnt = this.dsData.getColumn(0, "wrtkCnt");			// 전체저수조수
	var valWrteWrtkCnt = this.dsData.getColumn(0, "wrteWrtkCnt");	// 먹는물저수조수
	
	if(this.isNil(valShlCd)){
		this.smfAlert('CM006', ['학교명']);
		return false;
	}
	if(this.isNil(valAyr)){
		this.smfAlert('CM006', ['검사년도']);
		return false;
	}
	if(this.isNil(valQtrScCd)){
		this.smfAlert('CM006', ['분기']);
		return false;
	}
	if(this.isNil(valWrteSplScCd)){
		this.smfAlert('CM006', ['공급구분']);
		return false;
	}
	if(valWrtkCnt < valWrteWrtkCnt){
		this.smfAlert('CM020', ['먹는물이용 저수조수', '전체 저수조수']);
		return false;
	}
	
	for(var i=0; i<this.dsList.getRowCount(); i++){
		var rowWrprScCd = this.dsList.getColumn(i, "wrprScCd");				// 구분
		var rowWrprSplScCd = this.dsList.getColumn(i, "wrprSplScCd");		// 공급구분
		var rowWrprMngNo = this.dsList.getColumn(i, "wrprMngNo");			// 관리번호
		var rowWrprPstnRmkCn = this.dsList.getColumn(i, "wrprPstnRmkCn");	// 설치위치
		
		var msg = (i+1)+"번째 행의 ";
		
		if(this.isNil(rowWrprScCd)){
			msg += "구분을 입력해주세요";
			this.smfAlert('CM155', [msg]);
			return false;
		}
		if(this.isNil(rowWrprSplScCd)){
			msg += "공급구분을 입력해주세요";
			this.smfAlert('CM155', [msg]);
			return false;
		}
		if(this.isNil(rowWrprMngNo)){
			msg += "관리번호를 입력해주세요";
			this.smfAlert('CM155', [msg]);
			return false;
		}
		if(this.isNil(rowWrprPstnRmkCn)){
			msg += "설치위치를 입력해주세요";
			this.smfAlert('CM155', [msg]);
			return false;
		}
		
		if(this.smfLength(rowWrprMngNo, 3) > 40){
			msg += "관리번호가 40Bytes를 초과하였습니다.\n다시 등록하시기 바랍니다.";
			this.smfAlert('CM155', [msg]);
			return;
		}
		if(this.smfLength(rowWrprPstnRmkCn, 3) > 100){
			msg += "설치위치가 100Bytes를 초과하였습니다.\n다시 등록하시기 바랍니다.";
			this.smfAlert('CM155', [msg]);
			return;
		}
		
		//관리번호 중복체크
		if(this.dsList.getRowCount() > 1){
			for(var j=0; j<i; j++){
				var rowWrprMngNo2 = this.dsList.getColumn(j, "wrprMngNo");
				
				//관리번호중복
				if(rowWrprMngNo2 == rowWrprMngNo){
					this.smfAlert('CM155', ['관리번호가 중복입니다.']);
					return false;
				}
			}
		}
		
		//해당 없으면 학교코드, 학년도, 공급구분값 세팅
		this.dsList.setColumn(i, "shlCd", valShlCd);
		this.dsList.setColumn(i, "ayr", valAyr);
		this.dsList.setColumn(i, "qtrScCd", valQtrScCd);
	}
	
	return true;
};

/**
 * 전분기내역 복사
 * @param : N/A
 */
this.fnCopy = function(){
	// 서비스 객체 생성
	this.smfSearchService("listCopy")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.dsApiResponseList.getColumn(0, 'prcsRltCd') == 'SUCC'){
				// dsListPre의 데이터 중 분기일련번호 제거하여 신규상태로 변경
				for(var i=0; i<this.dsListPre.getRowCount(); i++){
					this.dsListPre.setColumn(i, 'qtrSn', '');
				}
				// 불러온 데이터 복사
				this.dsData.copyData(this.dsDataPre);
				this.dsList.copyData(this.dsListPre);
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'errCn')]);
			}
		});
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 전분기내역 가져오기 버튼 클릭
*/
this.btnCopy_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var chkShlCd = this.dsSearch.getColumn(0, 'shlCd');
	var chkAyr = this.dsSearch.getColumn(0, 'ayr');
	var chkQtrScCd = this.dsSearch.getColumn(0, 'qtrScCd');
	
	if(this.isNil(chkShlCd)){
		this.smfAlert('CM006', ['학교명']);
		return false;
	}
	if(this.isNil(chkAyr)){
		this.smfAlert('CM006', ['검사년도']);
		return false;
	}
	if(this.isNil(chkQtrScCd)){
		this.smfAlert('CM006', ['분기']);
		return false;
	}
	
	// 서비스 객체 생성
	this.smfSearchService("check")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.dsApiResponseList.getColumn(0, 'prcsRltCd') == 'SUCC'){
				var msg = "";
				var msgAyr = this.dsSearch2.getColumn(0, 'ayr');
				var msgQtrScCd = this.dsSearch2.getColumn(0, 'qtrScCd');
				
				if(this.isNotNil(msgAyr) && this.isNotNil(msgQtrScCd)){
					msg = "가장 최근에 등록된 자료가 " + msgAyr + "년 " + msgQtrScCd + "분기입니다.\n해당내역을 가져오시겠습니까?";
				}
				
				if(msg.length > 0){
					this.smfConfirm(msg, function(result){
						if(result.confirmResult){
							this.fnCopy();
						}
					});
				} else {
					this.smfAlert('CM155', ['이전내역이 없습니다.']);
					return;
				}
				
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'errCn')]);
			}
		});
};

/**
 * @description 저장 버튼 클릭
*/
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	if (!this.fnSaveChk()) return;
	
	this.dsData.setColumn(0, 'shlCd', this.dsSearch.getColumn(0, 'shlCd'));			// 학교코드
	this.dsData.setColumn(0, 'ayr', this.dsSearch.getColumn(0, 'ayr'));				// 검사년도
	this.dsData.setColumn(0, 'qtrScCd', this.dsSearch.getColumn(0, 'qtrScCd'));		// 분기구분코드
	
	if(rltDelYn){
		this.smfConfirm("[행삭제]된 건 중 정수기수질검사결과가 입력된 건이 있습니다.\n[정수기 및 냉온수기]의 내용이 삭제된 경우 검사결과도 함께 삭제됩니다.\n\n저장하시겠습니까?", function(result){
			if(result.confirmResult){
				//저장
				this.fnNoConfirmSave();
			}
		});
	}else{
		//저장
		this.fnSave();
	}
};

/**
 * @description 저장 버튼 클릭
*/
this.btnDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 검사결과가 있는지 체크
    var qltwtInspRltYn = false;
	
	for(var i=0; i<this.dsList.getRowCount(); i++){
		if(this.dsList.getColumn(i, 'qltwtInspRltYn') == "Y"){
			qltwtInspRltYn = true;
			break;
		}
	}
	
	if(rltDelYn || qltwtInspRltYn){
		this.smfConfirm("정수기수질검사결과가 입력되어 있습니다.\n검사결과도 모두 삭제됩니다.\n\n삭제하시겠습니까?", function(result){
			if(result.confirmResult){
				// 삭제
				this.fnNoConfirmDelete();
			}
		});
	}else{
		this.fnDelete();
	}
};

/**
 * @description 양식다운로드 버튼 클릭
*/
this.btnDownload_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objOption = {
					objGrid : this.grdExcelExport
				,   sheetname : "Sheet1" 
				,   filename : "먹는물점검장소_업로드양식_"+this.smfToday()
				};
	this.smfExcelExport(objOption);
};

/**
 * @description 결과업로드 버튼 클릭
*/
this.btnUpload_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objOption = {
						datasetname : "dsExcelImport"
					,   sheetname   : "Sheet1"
					,   startcell   : "A2"
					,   callback    : "fnImportCallback"
					,   importId    : "import"
					,   objForm     : this
					};
	this.smfExcelImport(objOption);
};

/**
 * @description 닫기 버튼 클릭
*/
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};

/**
 * @description 행추가 버튼 클릭
*/
this.btnRowAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var wrprSplScCd = this.dsData.getColumn(0, 'wrteSplScCd');
	var rowCount = 0;
	
	if(wrprSplScCd == '1' || wrprSplScCd == '2'){
		rowCount = this.dsList.addRow();
		this.dsList.setColumn(rowCount, 'wrprSplScCd', wrprSplScCd);
	}else if(wrprSplScCd == '3'){
		rowCount = this.dsList.addRow();
		this.dsList.setColumn(rowCount, 'wrprSplScCd', '1');
	}else{
		rowCount = this.dsList.addRow();
	}
	
};

/**
 * @description 행삭제 버튼 클릭
*/
this.btnRowDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//체크박스 선택 여부 확인
	var arrChk = this.dsList.extractRows('chk==1');	//체크된 rowNum 리턴
	
	if(arrChk == '-1' || arrChk.length < 1){
		//선택된 {0}이(가) 없습니다. {0}을(를) 선택하여 주십시오.
		this.smfAlert('CM013', ['행']);	  
		return;
	}
	
	// 삭제 시 검사결과가 있는지 체크
    var qltwtInspRltYn = "";
    var qltwtInspRltChk = false;
	
	for(var i=0; i<arrChk.length; i++){
		qltwtInspRltYn = this.dsList.getColumn(arrChk[i], 'qltwtInspRltYn');
		
		if(qltwtInspRltYn == "Y"){
			qltwtInspRltChk = true;
		}
	}
	
	// 수질 검사결과가 있을 때
	if(qltwtInspRltChk){
		this.smfConfirm("정수기수질검사결과가 입력되어 있습니다.\n[행삭제]시 검사결과도 함께 삭제됩니다.\n\n삭제하시겠습니까?",
		function(result){
			if(result.confirmResult){	//YES
				rltDelYn = true;
				for(var i=arrChk.length-1; i>=0 ; i--){
					// 분기일련번호가 있는 값 : DB에 저장된 값이므로 삭제 리스트에 복사
					if(this.dsList.getColumn(arrChk[i], 'qtrSn')){
						var row = this.dsDelList.addRow();
						this.dsDelList.copyRow(row, this.dsList, arrChk[i]);
					}
					this.dsList.deleteRow(arrChk[i]);
				}
			}
		});
		
	}else{
		for(var i=arrChk.length-1; i>=0 ; i--){
			// 분기일련번호가 있는 값 : DB에 저장된 값이므로 삭제 리스트에 복사
			if(this.dsList.getColumn(arrChk[i], 'qtrSn')){
				var row = this.dsDelList.addRow();
				this.dsDelList.copyRow(row, this.dsList, arrChk[i]);
			}
			this.dsList.deleteRow(arrChk[i]);
		}
	}
};

/**
 * @description 학교선택시 호출
*/
this.div00_cboShlNm_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	//학교가 선택되어있으면
	if(this.isNotNil(this.dsSearch.getColumn(0, "shlCd"))){
		//조회 함
		this.fnSearch();
	}
};

/**
 * @description 분기 선택시 호출
*/
this.div00_rdoQtrSc_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	//학교가 선택되어있으면
	if(this.isNotNil(this.dsSearch.getColumn(0, "shlCd"))){
		//조회 함
		this.fnSearch();
	}
};

this.grdMain_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	//체크박스 전체 선택 
	this.smfToggleChkHeader(obj, e);
};
]]></Script>
