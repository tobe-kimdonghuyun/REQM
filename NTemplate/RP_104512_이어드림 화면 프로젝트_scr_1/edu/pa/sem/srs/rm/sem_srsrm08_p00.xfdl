        <Grid id="grdMain" taborder="13" left="20" top="368" binddataset="dsList" autofittype="col" right="20" initvalueid="ivGrdAccessibilityOn" selecttype="cell" height="236" autosizingtype="none" scrolltype="both" autoenter="select" accessibilitylabel="정수기 및 냉온수기 등록내역(체크박스, 구분, 공급구분, 관리번호, 설치위치)" onheadclick="grdMain_onheadclick">
