            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">R</Col>
            <Col id="bindingControls"/>
            <Col id="url">/sem_srs_rm00_004.do</Col>
            <Col id="callback">fnTransCallback</Col>
