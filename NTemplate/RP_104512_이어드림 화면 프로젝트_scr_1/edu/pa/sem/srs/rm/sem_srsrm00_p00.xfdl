      <Dataset id="dsInspRltList" useclientlayout="true">
        <ColumnInfo>
          <Column id="shlCd" type="STRING" size="256" description="학교코드"/>
          <Column id="ayr" type="STRING" size="256" description="검사년도"/>
          <Column id="qtrScCd" type="STRING" size="256" description="분기코드"/>
          <Column id="wrprSn" type="STRING" size="256" description="정수기일련번호"/>
          <Column id="wrprMngNo" type="STRING" size="256" description="정수기관리번호"/>
          <Column id="wrprPstnRmkCn" type="STRING" size="256" description="정수기위치"/>
          <Column id="qltwtInspItmCd" type="STRING" size="256" description="검사항목코드"/>
          <Column id="qltwtInspItmNm" type="STRING" size="256" description="검사항목명"/>
          <Column id="inspCtrValueNm" type="STRING" size="256" description="검사기준값"/>
          <Column id="inspCtrMinValueNm" type="STRING" size="256" description="검사기준최소값"/>
          <Column id="inspCtrMaxValueNm" type="STRING" size="256" description="검사기준최대값"/>
          <Column id="qltwtFrstInspRltNmvl" type="STRING" size="256" description="수질최초검사결과수치"/>
          <Column id="qltwtFrstActnMteCn" type="STRING" size="256" description="수질최초조치사항"/>
          <Column id="qltwtLastInspRltNmvl" type="STRING" size="256" description="수질최종검사결과수치"/>
          <Column id="qltwtLastActnMteCn" type="STRING" size="256" description="수질최종조치사항"/>
          <Column id="qltwtLastInspComyNm" type="STRING" size="256" description="수질최종검사업체명"/>
          <Column id="qltwtLastInspYmd" type="STRING" size="256" description="수질최종검사일자"/>
          <Column id="qltwtInspRltCd" type="STRING" size="256" description="수질검사결과코드"/>
          <Column id="regId" type="STRING" size="256" description="등록자ID"/>
          <Column id="modId" type="STRING" size="256" description="수정자ID"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsInspRltValid" useclientlayout="true">
        <ColumnInfo>
          <Column id="bizSn" type="STRING" size="256" description="사업일련번호"/>
          <Column id="qltwtInspItmNm" type="STRING" size="256" description="수질검사항목명"/>
          <Column id="inspCtrValueNm" type="STRING" size="256" description="기준치"/>
          <Column id="qltwtFrstInspRltNmvl" type="STRING" size="256" description="수질최초검사결과수치"/>
          <Column id="qltwtFrstActnMteCn" type="STRING" size="256" description="수질최초조치사항내용"/>
          <Column id="qltwtLastInspRltNmvl" type="STRING" size="256" description="수질최종검사결과수치"/>
          <Column id="qltwtLastInspYmd" type="STRING" size="256" description="수질최종검사일자"/>
          <Column id="qltwtLastInspComyNm" type="STRING" size="256" description="수질최종검사업체명"/>
          <Column id="qltwtLastActnMteCn" type="STRING" size="256" description="수질최종조치사항내용"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsApiResponseList" useclientlayout="true">
        <ColumnInfo>
          <Column id="code" type="STRING" size="256" description="연계상태값"/>
          <Column id="prcsRltCd" type="STRING" size="256" description="연계결과코드"/>
          <Column id="errCn" type="STRING" size="256" description="연계결과내용"/>
          <Column id="message" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsExcelImport" useclientlayout="true">
        <ColumnInfo>
          <Column id="wrprMngNo" type="STRING" size="256" description="정수기관리번호"/>
          <Column id="wrprPstnRmkCn" type="STRING" size="256" description="정수기위치"/>
          <Column id="qltwtInspItmNm" type="STRING" size="256" description="검사항목명"/>
          <Column id="qltwtFrstInspRltNmvl" type="STRING" size="256" description="수질최초검사결과수치"/>
          <Column id="qltwtFrstActnMteCn" type="STRING" size="256" description="수질최초조치사항"/>
          <Column id="qltwtLastInspRltNmvl" type="STRING" size="256" description="수질최종검사결과수치"/>
          <Column id="qltwtLastInspYmd" type="STRING" size="256" description="수질최종검사일자"/>
          <Column id="qltwtLastInspComyNm" type="STRING" size="256" description="수질최종검사업체"/>
          <Column id="qltwtLastActnMteCn" type="STRING" size="256" description="수질최종조치사항"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsOutFileinfo" useclientlayout="true">
        <ColumnInfo>
          <Column id="fileRefrnId" type="string" size="256"/>
          <Column id="fileId" type="string" size="256"/>
          <Column id="suc" type="string" size="256"/>
          <Column id="atchFileNm" type="string" size="256"/>
          <Column id="atchFileGuid" type="string" size="256"/>
          <Column id="atchFileMg" type="string" size="256"/>
          <Column id="fileExtsnNm" type="string" size="256"/>
          <Column id="minTypeNm" type="string" size="256"/>
          <Column id="fileCoursNm" type="string" size="256"/>
          <Column id="fileObjKey" type="string" size="256"/>
          <Column id="fileEncryptYn" type="string" size="256"/>
          <Column id="fileSaveStg" type="string" size="256"/>
          <Column id="chk" type="int" size="1"/>
          <Column id="fileGubunCd" type="string" size="32"/>
          <Column id="useYn" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    위생점검등록서비스 > 정수기수질검사결과 수정
*  @FileName 	sem_srsrm00_p00.xfdl 
*  @Creator 	Kangchaeyoon
*  @CreateDate 	2022.10.19
*  @Desction    위생점검등록서비스 > 정수기수질검사결과 수정
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.10.19            Kangchaeyoon                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::sem_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_param;	// 파라메터 세팅
this.fv_cddcCd;	// 시도교육청 코드
this.FrstInspCnt;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	
	// 전달받은 파라메터 설정
	this.fv_param = this.smfGetPopupParams();
	this.dsSearch.loadXML(this.fv_param.dataset);
	
	//시도교육청 코드 세팅
	this.fv_cddcCd = this.smfGetCddcCode();
	this.dsSearch.setColumn(0, "cddcCd", this.fv_cddcCd);
	
	//팝업명 수정
	var text = this.divTitle.form.imgTitle.text;
	var addText = this.fv_param.addTitle;
	this.divTitle.form.imgTitle.set_text(text+addText);
	
	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
			url : "/sem_srs_rm00_000.do",
		})
		.mappingRulesetToDataset(this.dsInspRltValid, "save")
		.callback(function(callbackParams) {
		})
		.run()
	;

	//=======================================
	// 업로드관련 초기설정을 한다.
	//=======================================
	// 업로드시 저장위치등을 판별할 정보 세팅(대문자 : 시스템코드(2)+"."+서브시스템코드(3)+"."+대분류코드(3))
	this.div01.form.divFileUpload.UPLOAD_CreateComplete = this.fnEventUploadCreateComplete;  // 필요한 경우만 세팅
	this.div01.form.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;        // 필요한 경우만 세팅(세팅권장)
	this.div01.form.divFileUpload.UPLOAD_OnError        = this.fnEventUploadError;           // 필요한 경우만 세팅(세팅권장)
	this.div01.form.divFileUpload.UPLOAD_AfterAddFile   = this.fnEventUploadAfterAddFile;
 	this.div01.form.divFileUpload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)
	this.div01.form.divFileUpload.form.RaonkUpload.addEventHandler("RAONKUPLOAD_AfterDeleteFile", this.fnEventUploadAfterDeleteFile, false);

	//목록 조회
	this.fnSearch();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * @description Import callback
 */ 
this.fnImportCallback = function(sImportId,bResult)
{
	if(bResult){
		// 비교 컬럼 리스트
		var voKey = new Array();
		voKey.push("wrprMngNo");        // 정수기관리번호
		voKey.push("wrprPstnRmkCn");	// 정수기위치
		voKey.push("qltwtInspItmNm"); 	// 검사항목명
		this.fnGridUpload(this.grdMain, this.dsExcelImport, voKey);
	}
}

/**
 * raonkupload가 화면을 생성된 이후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @return : N/A
 */
this.fnEventUploadCreateComplete = function(obj,paramObj)
{
}

/**
 * raonkupload가 파일을upload한 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @param : objResultDataset
 * @return : N/A
 */
this.fnEventUploadComplete = function(obj,paramObj,objResultDataset)
{
	// 업로드 성공 후, newfile에 있는 파일들을 webfile로 옮긴다.
	this.div01.form.divFileUpload.form.fnSetUploadCompleteState(obj,paramObj);
	if(objResultDataset != null){
		this.dsSearch.setColumn(0, "qltwtInspFileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
		for(var i = 0; i < objResultDataset.getRowCount(); i++){
			var row = this.dsOutFileinfo.addRow();
			this.dsOutFileinfo.copyRow(row, objResultDataset, i);
		}
	}
	
	if (this.FrstInspCnt != 0 && (this.dsOutFileinfo.getRowCount() == 0 || this.dsOutFileinfo.extractRows("useYn == 'N'").length == this.dsOutFileinfo.getRowCount())){
		this.smfAlert('PA061', ['첨부파일은 필수']);
		return;
	}
	
	this.fnSave();
}

/**
 * raonkupload가 파일을upload실패 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @return : N/A
 */
this.fnEventUploadError = function(obj,paramObj)
{
}

/**
 * raonkupload가 파일을 추가 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @param : sCustomValue
 * @param : sFileName
 * @param : nFileSize
 * @return : N/A
 */
this.fnEventUploadAfterAddFile = function(obj,paramObj,sCustomValue,sFileName,nFileSize)
{
}

/**
 * raonkupload가 파일을 삭제 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @param : sCustomValue
 * @param : sFileName
 * @param : nFileSize
 * @return : N/A
 */
this.fnEventUploadAfterDeleteFile = function(obj, paramObj)
{
 	var fileNm = paramObj.userdata.strKey;
 	var formThis = this.parent.parent.parent.parent.parent;

	var row = formThis.dsOutFileinfo.findRow('atchFileGuid', fileNm);
	if (row != -1){
		formThis.dsOutFileinfo.setColumn(row, 'useYn', 'N');
	}
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 목록 조회 Transaction
 */
this.fnSearch = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'prcsRltCd') == 'SUCC'){
				if (!this.smfIsNull(this.dsSearch.getColumn(0, 'qltwtInspFileRefrnId'))){
					this.fnListFileInfo();
				}
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'errCn')]);
			}
		});
};

/**
 * @description 목록 저장 Transaction
 */
this.fnSave = function()
{
 	// 서비스 객체 생성
	this.smfSaveService("save")
		// (권장) 데이터 존재 필수
		.requireExistsData(this.dsSearch)
		// 데이터 변경 필수
		.requireModifredData([this.dsSearch, this.dsInspRltList, this.dsOutFileinfo])
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'prcsRltCd') == 'SUCC'){
				this.smfAlert('CM002', []); // 저장이 완료되었습니다.
				//목록 조회
				this.fnSearch();
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'errCn')]);
			}
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * KUpload를 생성시 지정할 property값을 지정
 * @param  : N/A
 * @return : N/A
 */
this.fnSetRaonProp = function()
{
	// 설정할 property
	var objAddRaonProps = {
							MaxOneFileSize			: '10MB'									// 파일당 최대 사이즈
							,ExtensionAllowOrLimit	: '1'										// 설정값이 "0" 이면 설정한 파일 확장자명만 "제한"으로 설정되며, "1"로 설정시 "허용"으로 설정
							,ExtensionArr           : 'pdf,png,jpg,jpeg,PDF,PNG,JPG,JPEG'		// 제한 또는 허용할 확장자 (,)로 구분
							,DisableAlertMessage	: {
								DisableDeleteConfirm: "1" 										// "1"로 설정시 파일 삭제시 confirm창 비활성.
							}
							,ButtonBarEdit			: "add,remove,remove_all,download,download_all"
							,UseDbclickOpen			: '1'										// 더블클릭으로 파일열기 0: 사용안함 1:사용
							};
	return objAddRaonProps;
}

/**
 * 파일 조회
 * @param : N/A
 * @param : N/A
 */
this.fnListFileInfo = function(){
	// 업로드 초기화
	this.div01.form.divFileUpload.form.fnResetUpload();
	
	for (var i = 0; i < this.dsOutFileinfo.getRowCount(); i++) {
		var handlerCode       = "PA.SEM.SRS";
		var atchFileSn        = this.dsOutFileinfo.getColumn(i, "fileRefrnId");
		var fileSize          = this.dsOutFileinfo.getColumn(i, "atchFileMg"); 
		var backendFilename   = this.dsOutFileinfo.getColumn(i, "atchFileGuid");
		var frontendFilename  = this.dsOutFileinfo.getColumn(i, "atchFileNm");
		var fileId            = this.dsOutFileinfo.getColumn(i, "fileId");
		if(this.isNotNil(atchFileSn)){
			this.div01.form.divFileUpload.form.fnAddUploadedFile(handlerCode, atchFileSn, fileSize, backendFilename, frontendFilename, fileId);
		}
	}
};

/**
 * 저장 체크
 * @param : N/A
 * @return : true : 저장 적합, false : 저장 부적합
 */
this.fnSaveChk = function(){
	var cntObj = {};
	var cntArray = new Array();
	var ymdChk = "";
	
	this.FrstInspCnt = this.dsInspRltList.getCaseCount("qltwtFrstInspRltNmvl != null && qltwtFrstInspRltNmvl != ''");
	if (this.FrstInspCnt != 0 && this.smfIsNull(this.dsSearch.getColumn(0, 'qltwtInspYmd'))){
		this.smfAlert('LI155', ['1차검사일자를 입력하세요.']);
		return false;
	}
	
	for(var i = 0; i < this.dsInspRltList.rowcount; i++){
		if (!this.smfIsNull(this.dsInspRltList.getColumn(i, 'qltwtLastInspRltNmvl'))
			&& this.smfIsNull(this.dsInspRltList.getColumn(i, 'qltwtFrstInspRltNmvl'))){
			cntObj["msg0"] = '항목의 1차검사결과를 입력하세요.';
			cntArray.push("cntList0");
			this.smfIsNull(cntObj["cntList0"]) ? (cntObj["cntList0"] = [(i + 1) + "번째"]) : (cntObj["cntList0"].push((i + 1) + "번째"));
		}
		
		if ((!this.smfIsNull(this.dsInspRltList.getColumn(i, 'qltwtLastInspRltNmvl'))
			&& this.smfIsNull(this.dsInspRltList.getColumn(i, 'qltwtFrstActnMteCn')))
			|| (!this.smfIsNull(this.dsInspRltList.getColumn(i, 'qltwtLastInspRltNmvl'))
			&& this.smfIsNull(this.dsInspRltList.getColumn(i, 'qltwtLastInspYmd')))
			|| (!this.smfIsNull(this.dsInspRltList.getColumn(i, 'qltwtLastInspRltNmvl'))
			&& this.smfIsNull(this.dsInspRltList.getColumn(i, 'qltwtLastInspComyNm')))){
			cntObj["msg1"] = '항목을 입력해주세요. \n 최종검사결과 입력시(조치사항, 최종검사일자, 최종검사업체)는 필수사항입니다.';
			cntArray.push("cntList1");
			this.smfIsNull(cntObj["cntList1"]) ? (cntObj["cntList1"] = [(i + 1) + "번째"]) : (cntObj["cntList1"].push((i + 1) + "번째"));
		}
		
		if (this.dsInspRltList.getColumn(i, 'qltwtLastInspYmd') > this.smfToday()){
			ymdChk = 'qltwtLastInspYmd'
			this.dsInspRltList.setColumn(i, 'qltwtLastInspYmd', this.smfToday());
			
		}else if (this.dsInspRltList.getColumn(i, 'qltwtLastInspYmd') < this.dsSearch.getColumn(0, 'qltwtInspYmd')){
			ymdChk = 'qltwtInspYmd'
			this.dsInspRltList.setColumn(i, 'qltwtLastInspYmd', this.dsSearch.getColumn(0, 'qltwtInspYmd'));	
		}
	}
	
	if(ymdChk == 'qltwtLastInspYmd'){
			this.smfAlert('CM020', ['최종점검일자', '오늘']);
			return;
		}else if(ymdChk == 'qltwtInspYmd'){
			this.smfAlert('CM021', ['최종점검일자', '1차점검일자']);
			return;
		}
	
	if (!this.smfIsNull(cntObj[cntArray[0]])){
		this.smfAlert('LI155', ["(" + cntObj[cntArray[0]].join(', ') + ")" + cntObj["msg" + cntArray[0].substr(7)]]);
		return false;
	}
	
	return true;
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 저장 버튼 클릭
*/
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (!this.fnSaveChk()) return;
	
	this.div01.form.divFileUpload.form.fnFileUpload();
};

/**
 * @description 양식다운로드 버튼 클릭
*/
this.btnDownload_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objOption = {
					objGrid : this.grdExcelExport
				,   sheetname : "Sheet1" 
				,   filename : "정수기수질검사결과_"+this.smfTodayTime()
				};
	this.smfExcelExport(objOption);
};

/**
 * @description 결과업로드 버튼 클릭
*/
this.btnUpload_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objOption = {
						datasetname : "dsExcelImport"
					,   sheetname   : "Sheet1"
					,   startcell   : "A2"
					,   callback    : "fnImportCallback"
					,   importId    : "import"
					,   objForm     : this
					};
	this.smfExcelImport(objOption);
};

/**
 * @description 캘린더 날짜 조건 세팅
*/
this.div00_calChckYmd_onchanged = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{
	var today = this.smfToday();
	if(e.postvalue > today){
		this.smfAlert('CM020', ['1차점검일자', '오늘']);
		obj.set_value(today);
		return false;
	}
};

/**
 * @description 닫기 버튼 클릭
*/
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};]]></Script>
    <Bind>
      <BindItem id="item0" compid="div00.form.edtShlNm" propid="value" datasetid="dsSearch" columnid="shlNm"/>
