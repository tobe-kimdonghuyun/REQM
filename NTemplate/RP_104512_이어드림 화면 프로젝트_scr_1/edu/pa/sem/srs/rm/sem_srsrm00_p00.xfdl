        <Grid id="grdMain" taborder="6" left="20" top="278" binddataset="dsInspRltList" autofittype="col" right="20" initvalueid="ivGrdAccessibilityOn" selecttype="cell" height="236" autosizingtype="none" scrollbartype="none" scrolltype="both" autoenter="select" accessibilitylabel="정수기측정결과표(순번,정수기관리번호,정수기위치,검사항목,1차검사결과,조치사항,최종검사결과,최종검사일자,최종검사업체,최종조치사항)">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="50"/>
                <Column size="80"/>
                <Column size="90"/>
                <Column size="130"/>
                <Column size="80"/>
                <Column size="150"/>
                <Column size="80"/>
                <Column size="100"/>
                <Column size="150"/>
                <Column size="150"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="순번"/>
                <Cell col="1" text="정수기관리번호"/>
                <Cell col="2" text="정수기위치"/>
                <Cell col="3" text="검사항목"/>
                <Cell col="4" text="1차검사결과"/>
                <Cell col="5" text="조치사항"/>
                <Cell col="6" text="최종검사결과"/>
                <Cell col="7" text="최종검사일자"/>
                <Cell col="8" text="최종검사업체"/>
                <Cell col="9" text="최종조치사항"/>
              </Band>
              <Band id="body">
                <Cell text="expr:currow +1" textAlign="center"/>
                <Cell col="1" text="bind:wrprMngNo" textAlign="center" suppress="1" suppressalign="middle" tooltiptext="bind:wrprMngNo" tooltiptype="default"/>
                <Cell col="2" suppress="1" text="bind:wrprPstnRmkCn" tooltiptext="bind:wrprPstnRmkCn" suppressalign="middle"/>
                <Cell col="3" text="bind:qltwtInspItmNm" textAlign="left" tooltiptext="bind:qltwtInspItmNm" wordWrap="english"/>
                <Cell col="4" text="bind:qltwtFrstInspRltNmvl" textAlign="right" displaytype="maskeditcontrol" edittype="text" editinputtype="dot,digit" cssclass="expr:(+qltwtFrstInspRltNmvl &gt;= +inspCtrMinValueNm &amp;&amp; +qltwtFrstInspRltNmvl &lt;= +inspCtrMaxValueNm) ? '' : 'cell_WF_MaskERed'" editmaxlength="5" tooltiptext="bind:qltwtFrstInspRltNmvl" editautoselect="true"/>
                <Cell col="5" text="bind:qltwtFrstActnMteCn" textAlign="left" displaytype="editcontrol" edittype="text" editmaxlength="30" tooltiptext="bind:qltwtFrstActnMteCn" editautoselect="true"/>
                <Cell col="6" text="bind:qltwtLastInspRltNmvl" displaytype="maskeditcontrol" edittype="text" calendardateformat="yyyy.MM.dd" editinputtype="digit,dot" cssclass="expr:(+qltwtLastInspRltNmvl &gt;= +inspCtrMinValueNm &amp;&amp; +qltwtLastInspRltNmvl &lt;= +inspCtrMaxValueNm) ? '' : 'cell_WF_MaskERed'" textAlign="right" editmaxlength="5" tooltiptext="bind:qltwtLastInspRltNmvl" editautoselect="true"/>
                <Cell col="7" text="bind:qltwtLastInspYmd" edittype="date" displaytype="calendarcontrol" tooltiptext="bind:qltwtLastInspYmd" calendardateformat="yyyy.MM.dd" calendareditformat="yyyy.MM.dd" calendardisplaynulltype="nullmask"/>
                <Cell col="8" displaytype="editcontrol" edittype="text" text="bind:qltwtLastInspComyNm" editmaxlength="30" tooltiptext="bind:qltwtLastInspComyNm" editautoselect="true"/>
                <Cell col="9" text="bind:qltwtLastActnMteCn" textAlign="left" displaytype="editcontrol" edittype="text" editmaxlength="30" tooltiptext="bind:qltwtLastActnMteCn" editautoselect="true"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
      </Layout>
