    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-지방공무원-지원서작성-한국산업인력공단 가산점 추가 팝업
*  @MenuPath    pa_ore_oew_ar
*  @FileName 	pa_ore_oewar21_p02.xfdl
*  @Creator 	최재형
*  @CreateDate 	2022.11.24
*  @Desction    기관검증을 통한 데이터 등록 가산점 팝업 
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.11.24  	최재형 	        최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.pv_params;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

	// default 초기처리를 한다.
	this.smfInitPopup(obj);
	
	this.pv_params = this.smfGetPopupParams();
	
	// opener dataset 복사
	var adtnParam = this.pv_params.dsResultJbgdAdtn;
	this.dsResultJbgdAdtn.clearData();
	this.dsResultJbgdAdtn.loadJSON(adtnParam);
	
	var myQlflCnt = this.pv_params.myQlflCnt;
	if(myQlflCnt <1){
		this.smfAlert('한국산업인력공단 취득 자격 정보가 없습니다.');
		this.divMain.form.staTltIQlfl.set_enable(false);
		this.divMain.form.cboQlfl.set_enable(false);
		this.divMain.form.staQlfl.set_enable(false);
		this.btnRegist.set_enable(false);
	}else{
		// 마이데이터 산업인력공단 내자격증 SET
		var myQlflParam = this.pv_params.dsResultMyDataQlfl;
		this.dsResultMyDataQlfl.clearData();
		this.dsResultMyDataQlfl.loadJSON(myQlflParam);
	}
	
// 	this.dsResultQlfl.clearData();
// 	this.dsResultQlfl.setColumn(0, 'qlflNo' , this.dsResultMyDataQlfl.getColumn(0, 'qlflNo')); // 자격번호
// 	this.dsResultQlfl.setColumn(0, 'qlflNm' , this.dsResultMyDataQlfl.getColumn(0, 'itemNm')); //자격명
// 	this.dsResultQlfl.setColumn(0, 'issuYmd' , this.dsResultMyDataQlfl.getColumn(0, 'qlflAcqsDt')); // 자격취득일
// 	this.dsResultQlfl.setColumn(0, 'issuInstNm' , '한국산업인력공단');
// 	this.dsResultQlfl.setColumn(0, 'instVrfcScsYn' , 'Y');
// 	this.dsResultQlfl.setColumn(0, 'vrfcRltCn' , '공공마이데이터검증');


	// 가산특별규칙구분코드 = 4번  (한국산업인력공단(국가기술자격)분야) 모드 여부
	var isQlflMode = this.pv_params.qlflModeYn;
	// 콤보 필터링
	this.fnCreateAdtnComboData(isQlflMode)
	
	// POPUP TITLE
	this.smfUpdatePopupTitle("한국산업인력공단 자격 가산점 추가");
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 /**
 * 가산점 관련 콤보 데이터 초기 SET
 * 가산점 전체 데이터에서 그룹별 필터링 분류
 **/
this.fnCreateAdtnComboData= function(isQlflMode){
	
	// 가산특별규칙 필터
	var adtnSpeclRuleScCdFilter;
	
	// 한국산업인력공단 검증 추가 모드의경우
	if(isQlflMode ==="Y"){
		// 가산특별규칙코드 필터  = 4 :한국산업인력공단 
		adtnSpeclRuleScCdFilter = "adtnSpeclRuleScCd == '4'";
		// 기본값 SET
		this.divMain.form.edtIssuInstNm.set_value("한국산업인력공단");
		this.divMain.form.edtIssuInstNm.set_readonly(true);
	}else{
		// 가산특별규칙코드 필터 =1:직급별가산, 2:취업지원대상자 및 의사상자, 3: 공통가산
		adtnSpeclRuleScCdFilter = "adtnSpeclRuleScCd != '4'";
	}
	
	//console.log("====시작 전체 DATA " + this.dsResultJbgdAdtn.getRowCount()+"건");
	//console.log(this.dsResultJbgdAdtn.saveJSON());
	
	/** 대분류: 가산특별규칙 그룹화 **/
	// 필터링 초기화
	this.dsResultJbgdAdtn.filter("");
	// 대분류 - (가산특별규칙코드 그룹화 AND 지정 가산특별규칙코드) 필터
	var depth1GrpExpr = "adtnSpeclRuleScCd=='\"+adtnSpeclRuleScCd+\"'"+"&&"+ adtnSpeclRuleScCdFilter;
	var depth1FilterExpr = "rowidx==dataset.findRowExpr(\""+depth1GrpExpr+"\")";
	// 전체데이터 필터링
	this.dsResultJbgdAdtn.filter(depth1FilterExpr);
	// 그룹화 필터링된 데이터를 가산특별규칙 콤보에 복사
	this.dsCboJbgdAdtn1.clearData();
	this.dsCboJbgdAdtn1.copyData(this.dsResultJbgdAdtn, true);
	//console.log("====대분류 가산특별규칙코드 그룹 DATA " + this.dsResultJbgdAdtn.getCaseCount(depth1FilterExpr)+"건");
	//console.log(this.dsCboJbgdAdtn1.saveJSON());
	
	/** 중분류: 가산분야 그룹화 **/
	// 전체데이터 필터링 초기화
	this.dsResultJbgdAdtn.filter("");
	// 중분류 - (가산분야코드 그룹화  AND 지정 가산특별규칙코드) 필터
	var depth2GrpExpr = "adtnClfCd=='\"+adtnClfCd+\"'"+"&&"+ adtnSpeclRuleScCdFilter;
	var depth2FilterExpr = "rowidx==dataset.findRowExpr(\""+depth2GrpExpr+"\")";
	// 전체데이터 필터링
	this.dsResultJbgdAdtn.filter(depth2FilterExpr);
	// 그룹화 필터링된 데이터를 가산분류 콤보에 복사
	this.dsCboJbgdAdtn2.clearData();
	this.dsCboJbgdAdtn2.copyData(this.dsResultJbgdAdtn, true);
	//console.log("====중분류 가산분류코드 그룹 DATA " + this.dsResultJbgdAdtn.getCaseCount(depth2FilterExpr)+"건");
	//console.log(this.dsCboJbgdAdtn2.saveJSON());

 }
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 확인버튼 클릭	
 */
this.btnRegist_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	if(this.smfIsNull(this.divMain.form.cboAdtnClf.value)){
		this.divMain.form.cboAdtnClf.setFocus();
		this.smfAlert('CM006', ["가산분야"], this.fnMessageCallback ); 
		return;	
	}
	if(this.smfIsNull(this.divMain.form.cboGrtTrgtCn.value)){
		this.divMain.form.cboGrtTrgtCn.setFocus();
		this.smfAlert('CM006', ["가산점부여내역"], this.fnMessageCallback ); 
		return;	
	}
	
	if(this.smfIsNull(this.divMain.form.cboQlfl.value)){
		this.divMain.form.cboQlfl.setFocus();
		this.smfAlert('CM006', ["자격증"], this.fnMessageCallback ); 
		return;	
	}
	
	
	// 화면 입력값 SET
	this.dsMain.setColumn(0, "qlflNo", this.divMain.form.edtQlflNo.value); // 자격증번호
	this.dsMain.setColumn(0, "issuInstNm",this. divMain.form.edtIssuInstNm.value); //발급기관
	this.dsMain.setColumn(0, "issuYmd", this.divMain.form.calIssuYmd.value); //발급일
	this.dsMain.setColumn(0, "fileRefrnId", ""); //첨부파일 참조아이디
	this.dsMain.setColumn(0, "fileNm",""); // 첨부파일명
	this.dsMain.setColumn(0, "instVrfcScsYn", "Y"); // 기관검증여부
	this.dsMain.setColumn(0, "vrfcRltCn", this.divMain.form.cboQlfl.text); // 기관검증내용
	
	// 입력값 부모창 전달
	this.smfSendResponseToOpener({
		"row": this.smfRowToObject(this.dsMain)
	});
	this.close(true);
};

/**
 * 취소버튼 클릭
 */
this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};

/**
 * 가산분야 콤보 선택
 * 가산분야 콤보 선택시 가산점부여내역 콤보 데이터 동적 생성
 */
this.cboAdtnClf_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	// 선택 인덱스
	var idx = e.postindex;
	// 선택한 가산분류코드
	var sAdtnClfCd = this.dsCboJbgdAdtn2.getColumn(idx, "adtnClfCd");
	// 선택한 가산특별규칙코드
	var sAdtnSpeclRuleScCd = this.dsCboJbgdAdtn2.getColumn(idx, "adtnSpeclRuleScCd");
	
	//  가산점부여내역 (가산특별규칙코드 AND 가산분류)  콤보 필터
	var comboFilters = "adtnClfCd=='"+sAdtnClfCd+"'"+" && adtnSpeclRuleScCd=='"+sAdtnSpeclRuleScCd+"'";	
	// 전체데이터에서  필터
	this.dsResultJbgdAdtn.filter("");
	this.dsResultJbgdAdtn.filter(comboFilters);
	// 가산점부여내역 콤보 데이터 초기화
	this.dsCboJbgdAdtn3.clearData();
	// 필터링된 데이터를 가산점부여내역 콤보에 복사
	this.dsCboJbgdAdtn3.copyData(this.dsResultJbgdAdtn, true);
};

/**
 * 가산내역 콤보 선택 
 */
this.cboGrtTrgtCn_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	// 선택 인덱스
	var idx = e.postindex;

	// 가산방식코드
	var adtnMetCd =this.dsCboJbgdAdtn3.getColumn(idx, "adtnMetCd");
	// 가산비율
	var adtnRto =this.dsCboJbgdAdtn3.getColumn(idx, "adtnRto");
	// 임용시험가산점수
	var appoExamAdtnScr = this.dsCboJbgdAdtn3.getColumn(idx, "appoExamAdtnScr");
	
	// 가산점(비율)
	var adtnScoreTxt = "0";
	// 비율
	if(adtnMetCd === "1"){
		adtnScoreTxt = adtnRto+"%";
	}
	// 점수
	if(adtnMetCd === "2"){
		adtnScoreTxt = appoExamAdtnScr+"점";
	}
	
	// 화면에 점수 SET
	this.divMain.form.edtAdtnScore.set_value(adtnScoreTxt);
	
	// 부모창 콜백 데이터에 기본정보 SET
	this.dsMain.clearData();
	this.dsMain.addRow();
	this.dsMain.setColumn(0, "adtnCd", this.dsCboJbgdAdtn3.getColumn(idx, "adtnCd"));
	this.dsMain.setColumn(0, "adtnSpeclRuleScCd", this.dsCboJbgdAdtn3.getColumn(idx, "adtnSpeclRuleScCd"));
	this.dsMain.setColumn(0, "adtnSpeclRuleScNm", this.dsCboJbgdAdtn3.getColumn(idx, "adtnSpeclRuleScNm"));
	this.dsMain.setColumn(0, "adtnClfCd", this.dsCboJbgdAdtn3.getColumn(idx, "adtnClfCd"));
	this.dsMain.setColumn(0, "adtnClfNm", this.dsCboJbgdAdtn3.getColumn(idx, "adtnClfNm"));
	this.dsMain.setColumn(0, "grtTrgtCn", this.dsCboJbgdAdtn3.getColumn(idx, "grtTrgtCn"));
	this.dsMain.setColumn(0, "adtnMetCd", this.dsCboJbgdAdtn3.getColumn(idx, "adtnMetCd"));
	this.dsMain.setColumn(0, "adtnRto", this.dsCboJbgdAdtn3.getColumn(idx, "adtnRto"));
	this.dsMain.setColumn(0, "appoExamAdtnScr", this.dsCboJbgdAdtn3.getColumn(idx, "appoExamAdtnScr"));
	this.dsMain.setColumn(0, "adtnScoreTxt", this.divMain.form.edtAdtnScore.value);
	
};

/**
 * 공공마이데이터 자격증선택 콤보 선택 
 */
this.cboQlfl_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	// 선택 인덱스
	var idx = e.postindex;
	
	// 자격번호
	var qlflNo =this.dsResultMyDataQlfl.getColumn(idx, "qlflNo");
	// 자격명
	var qlflNm = this.dsResultMyDataQlfl.getColumn(idx, "itemNm");
	// 발급일
	var issuYmd = this.dsResultMyDataQlfl.getColumn(idx, "qlflAcqsDt");
	
	// 화면에 자격번호 SET
	this.divMain.form.edtQlflNo.set_value(qlflNo);
	// 화면에 발급일 SET
	this.divMain.form.calIssuYmd.set_value(issuYmd);
};
]]></Script>
  </Form>
</FDL>
