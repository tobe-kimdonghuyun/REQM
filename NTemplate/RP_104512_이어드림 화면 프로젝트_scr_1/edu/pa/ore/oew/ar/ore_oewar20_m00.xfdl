        <Static id="staGd13_00" taborder="10" left="450" top="2580" height="50" cssclass="sta_GD_Size" text="50" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="300" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-지방공무원-지원서 작성 동의서
*  @MenuPath    pa_ore_oew_ar
*  @FileName 	pa_ore_oewar20_m00.xfdl
*  @Creator 	최재형
*  @CreateDate 	2022.07.29
*  @Desction    온라인통합채용-지방공무원-지원서 작성 동의서
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.07.29    	최재형	 	        최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.applpRrno;
this.applpFlnm;
this.applpBrdt;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 로그인 체크 세션 없을경우 로그인 페이지로 이동
	//this.isOreLogin();
	
	//  본인인증 세션취득
	this.applpRrno = nexacro.base64Decode(this.smfGetSessionValue('userRrno'));
	this.applpFlnm = this.smfGetSessionValue('userNm');
	this.applpBrdt = this.applpRrno.slice(0,6);
	
	
	// Form의 default 초기처리를 한다.
	this.smfInitForm(this);
	
	//현재 일자 설정
	this.fnSearchDate();
	
	//  개요 목록  조회
	this.fnSearchAppoExamList();	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid, errcd, errmsg){

}

// 지방공무원-지원서 작성 동의서 상세 팝업1 콜백
this.fnDetail00Callback = function(e, sender){
	// popup Modal에서 선택한 동의 여부set
	this.divContent00.form.rdoYn00.set_value(e.ynValue);
};

// 지방공무원-지원서 작성 동의서 상세 팝업2 콜백
this.fnDetail01Callback = function(e, sender){
	// popup Modal에서 선택한 동의 여부set
	this.divContent00.form.rdoYn01.set_value(e.ynValue);
};

// 지방공무원-지원서 작성 동의서 상세 팝업3 콜백
this.fnDetail02Callback = function(e, sender){
	// popup Modal에서 선택한 동의 여부set
	this.divContent00.form.rdoYn02.set_value(e.ynValue);
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
//현재 일자 검색
this.fnSearchDate = function(obj, e)
{
	// 서비스 객체 생성
	this.smfSearchService("selectDate")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;

			// 시간을 표시한다.
			var sCurDate = this.dsDateTime.getColumn(0, "yyyymmdd");
			// 보기 좋게 표시하기 위해 formatting
			sCurDate = sCurDate.dateFormat("yyyy년 MM월 dd일");
			
			// 서버에서 가져온 시간을 표시한다.
			this.divContent00.form.staDate00.set_text(sCurDate);
		});
}
/**
 * 개요 목록 검색
 */
this.fnSearchAppoExamList = function(obj, e)
{
	// 시도 교육청 코드 SET
	this.dsSearch.setColumn(0, 'cddcCd', this.smfGetCddcCode());
	
	// 개요조회
	this.smfSearchService('selectAppoExamList') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
	});
	
	// 직렬 콤보 데이터 초기화
	this.divContent04.form.cboAppoJbln.set_value(null);
	this.dsResultJbln.filter("appoExamId=='9999999999'");
	// 계급 콤보 데이터 초기화
	this.divContent04.form.cboAppoRks.set_value(null);
	this.dsResultRks.filter("appoExamId=='9999999999'");

};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// 지방공무원-지원서 작성 동의서 상세 팝업1
this.btnDetail00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	var popupParams = {
		callback: this.fnDetail00Callback, // 콜백함수 지정
		sender: obj, // sender 지정
		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: 'none',
			ynValue: this.divContent00.form.rdoYn00.value,
		},
	};
	// 모달팝업 실행
	this.smfDialog("_auto", "pa_ore_oew_ar::ore_oewar20_p00.xfdl", popupParams);
};

// 지방공무원-지원서 작성 동의서 상세 팝업2
this.btnDetail01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var popupParams = {
		callback: this.fnDetail01Callback, // 콜백함수 지정
		sender: obj, // sender 지정
		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: 'none',
			ynValue: this.divContent00.form.rdoYn01.value,
		},
	};
	// 모달팝업 실행
	this.smfDialog("_auto", "pa_ore_oew_ar::ore_oewar20_p01.xfdl", popupParams);
};

// 지방공무원-지원서 작성 동의서 상세 팝업3
this.btnDetail02_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var popupParams = {
		callback: this.fnDetail02Callback, // 콜백함수 지정
		sender: obj, // sender 지정
		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: 'none',
			ynValue: this.divContent00.form.rdoYn02.value,
		},
	};
	// 모달팝업 실행
	this.smfDialog("_auto", "pa_ore_oew_ar::ore_oewar20_p02.xfdl", popupParams);
};

/**
 * 전체동의
 */
this.divContent00_chkVal_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	// 인터넷서약
	this.divContent00.form.chkVal01.set_value(obj.value);
	// 개인정보동의 1. 개인정보 수집 및 이용에 대한 동의
	this.divContent00.form.chkVal02.set_value(obj.value);
	// 개인정보동의 3. 민감정보 수집 동의
	this.divContent00.form.chkVal04.set_value(obj.value);
	// 개인정보동의 4. 개인정보 제3자 제공에 관한 동의
	this.divContent00.form.chkVal05.set_value(obj.value);
	// 행정정보 공동이용 사전동의
	this.divContent00.form.chkVal06.set_value(obj.value);
};

// 다음 버튼 클릭
this.btnNext00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	// 인터넷접수 서약서 동의
	if( !this.divContent00.form.chkVal01.value ) {
		this.divContent00.form.staTlt00.setFocus();
		this.divContent00.form.chkVal01.setFocus();
		this.smfAlert('인터넷 접수 서약에 동의 후 진행 가능 합니다.');
		return false;
	}
	// 개인정보 수집 및 이용에 대한 동의
	if( !this.divContent00.form.chkVal02.value ) {
		this.divContent00.form.staTltSub01.setFocus();
		this.divContent00.form.chkVal02.setFocus();
		this.smfAlert('개인정보 수집 및 이용에 대한 동의 후 진행 가능 합니다.');
		return false;
	}
	// 민감정보 수집 동의
	if( !this.divContent00.form.chkVal04.value ) {
		this.divContent00.form.staTltSub03.setFocus();
		this.divContent00.form.chkVal04.setFocus();
		this.smfAlert('민감정보 수집 동의 후 진행 가능 합니다.');
		return false;
	}
	// 개인정보 제3자 제공에 관한 동의
	if( !this.divContent00.form.chkVal05.value ) {
		this.divContent00.form.staTltSub04.setFocus();
		this.divContent00.form.chkVal05.setFocus();
		this.smfAlert('개인정보 제3자 제공에 관한 동의 후 진행 가능 합니다.');
		return false;
	}
	
	// 행정정보공동이용 사전 동의
	if( !this.divContent00.form.chkVal06.value ) {
		this.divContent00.form.staTlt02.setFocus();
		this.divContent00.form.chkVal06.setFocus();
		this.smfAlert('행정정보공동이용 사전 동의 후 진행 가능 합니다.');
		return false;
	}
	
	// 개요 선택여부
	if( !this.divContent04.form.cboAppoExam.value ) {
		this.divContent04.form.cboAppoExam.setFocus();
		this.smfAlert('임용시험을 선택 해주세요.');
		return false;
	}
	// 직렬 선택여부
	if( !this.divContent04.form.cboAppoJbln.value ) {
		this.divContent04.form.cboAppoJbln.setFocus();
		this.smfAlert('직렬을 선택 해주세요.');
		return false;
	}
	// 계급 선택여부
	if( !this.divContent04.form.cboAppoRks.value ) {
		this.divContent04.form.cboAppoRks.setFocus();
		this.smfAlert('계급을 선택 해주세요.');
		return false;
	}
	
	// 임용시험 콤보 선택 INDEX
	var examCboIdx = this.divContent04.form.cboAppoExam.index;
	var sAppoExamId = this.dsResultAppoExam.getColumn(examCboIdx, "appoExamId");
	var sAppoExamNm = this.dsResultAppoExam.getColumn(examCboIdx, "appoExamNm");
	var sAppoExamMastrIdfId = this.dsResultAppoExam.getColumn(examCboIdx, "appoExamMastrIdfId");
	
	// 직렬 콤보 선택 INDEX
	var jblnCboIdx = this.divContent04.form.cboAppoJbln.index;
	// 직류
	var sOcptyCd = this.dsResultJbln.getColumn(jblnCboIdx, "ocptyCd");
	var sOcptyNm = this.dsResultJbln.getColumn(jblnCboIdx, "ocptyNm");
	//직렬
	var sJblnCd = this.dsResultJbln.getColumn(jblnCboIdx, "jblnCd");
	var sJblnNm = this.dsResultJbln.getColumn(jblnCboIdx, "jblnNm");
	
	// 계급 콤보 선택 INDEX
	var rksCboIdx = this.divContent04.form.cboAppoRks.index;
	// 직급
	var sJbgdCd = this.dsResultRks.getColumn(rksCboIdx, "jbgdCd");
	var sJbgdNm = this.dsResultRks.getColumn(rksCboIdx, "jbgdNm");
	// 계급
	var sRksCd = this.dsResultRks.getColumn(rksCboIdx, "rksCd");
	var sRksNm = this.dsResultRks.getColumn(rksCboIdx, "rksNm");
	
	var cddcCeckMsg = "현재 접속하신 교육청은 ["+this.smfGetCddcName()+"] 입니다.\n원서 접수를 진행 하시겠습니까?"
	this.smfConfirm(cddcCeckMsg, function(result){
		if(result.confirmResult){
			//this.dsResultAdf.clearData();
			// TODO 조회조건 - 주민번호 세션 취득
			this.dsSearch.setColumn(0, 'applpRrno'  , this.applpRrno);
			this.dsSearch.setColumn(0, 'appoExamId'  ,sAppoExamId);
			this.dsSearch.setColumn(0, 'appoExamMastrIdfId'  ,sAppoExamMastrIdfId);
			
			this.dsSearch.setColumn(0, 'ocptyCd'  ,sOcptyCd);
			this.dsSearch.setColumn(0, 'jblnCd'  ,sJblnCd);
			this.dsSearch.setColumn(0, 'jbgdCd'  ,sJbgdCd);
			this.dsSearch.setColumn(0, 'rksCd'  ,sRksCd);
			
			//  지원서 가능 여부 체크 데이터- 비동기 = false
			this.smfSearchService('selectCheckData') 
				.run()
				// 콜백
				.callback(function(callbackParams){
					if(callbackParams.errors){
						return;
					}
			});

			// 기타 API 등 데이터 취득에러
			var applpImYn = this.dsResultCheck.getColumn(0, 'applpImYn');
			if(applpImYn === 'Y'){
				this.smfAlert("접수가 불가능 합니다. ");
				return;
			}
			// 무효시험(삭제,마감)
			var unaExamYn = this.dsResultCheck.getColumn(0, 'unaExamYn');
			if(unaExamYn === 'Y'){
				this.smfAlert("진행중인 임용시험이 아닙니다.");
				return;
			}
			// 접수불가기간
			var rcptImDtYn = this.dsResultCheck.getColumn(0, 'rcptImDtYn');
			if(rcptImDtYn === 'Y'){
				this.smfAlert("원서 접수 기간이 아닙니다.");
				return;
			}

			// 제한연령여부
			var lmttAgeYn = this.dsResultCheck.getColumn(0, 'lmttAgeYn');
			if(lmttAgeYn === 'Y'){
				this.smfAlert("본 임용시험의 지원연령에 해당하지 않습니다.\n 임용공고를 확인 해주세요.");
				return;
			}
			
			// 결격자(부정행위)여부
			var disquYn = this.dsResultCheck.getColumn(0, 'disquYn');
			if(disquYn === 'Y'){
				this.smfAlert("결격자로서 응시자격이 제한됩니다.");
				return;
			}

			// 동일임용시험 중복지원여부
			var dpcnYn = this.dsResultCheck.getColumn(0, 'dpcnYn');
			if(dpcnYn === 'Y'){
				this.smfAlert("본 임용시험에 이미 등록된 주민등록번호 내용이 있습니다.");
				return;
			}
			
			// PARAM
			var params = {
				rcptNo : "", // 접수번호
				viewMode : "new", //처리타입 new(신규) / modify(수정)
				appoExamId:sAppoExamId, //임용시험ID
				appoExamNm:sAppoExamNm, //임용시험명
				appoExamMastrIdfId:sAppoExamMastrIdfId,//임용시험마스터식별ID
				ocptyCd:sOcptyCd, //직류코드
				ocptyNm:sOcptyNm, //직류명
				jblnCd:sJblnCd, //직렬코드
				jblnNm:sJblnNm, //직렬명
				jbgdCd:sJbgdCd, //직급코드
				jbgdNm:sJbgdNm, //직급명
				rksCd:sRksCd, //계급코드
				rksNm:sRksNm //계급명
			};
			
			// 중복지원여부
			var dpcnYn2 = this.dsResultCheck.getColumn(0, 'dpcnYn2');
			if(dpcnYn2 === 'Y'){
				this.smfAlert("현재 귀하는 해당 시도교육청에 이미 접수완료(결제완료)한 지원자로 확인됩니다.\n\n동일 시도교육청 내 중복 접수는 불가하므로, 계속 접수를 진행하기 위해서는\n\n기존에 접수한 원서를 '접수취소' 한 후 재시도해 주시기 바랍니다.\n\n※ 기존 접수원서는 [마이페이지]-[원서접수내역]에서 확인 및 접수취소 가능"); 
				return;
			}
			
			// 전체 시도 중복지원여부
			var totalDpcnYn = this.dsResultCheck.getColumn(0, 'totalDpcnYn');
			/*
			if(totalDpcnYn === 'Y'){
				// 타시도 또는 타임용시험에 접수 정보가 있을 경우, aptpwl vytl gn wlsgod
				this.smfAlert("이미 접수 완료한 시험이 있습니다.\n\n본 시험에 응시하려면 기존에 접수한 시험을 취소 후\n본 시험을 응시하시기 바랍니다.");
			}*/
			if(totalDpcnYn === 'Y') {
				this.smfConfirm("현재 귀하는 다른 시도교육청 임용시험에 지원한 것으로 확인됩니다.\n위 내용 확인 후에도 계속 진행 하시겠습니까?", function(result){
					if(result.confirmResult){
						this.smfSetWorkPage("pa_ore_oew_ar::ore_oewar21_m00.xfdl", params);
					}
				});
			} else {
				this.smfSetWorkPage("pa_ore_oew_ar::ore_oewar21_m00.xfdl", params);
			}
		}
	});
};

/**
 * 개요 셀렉트박스 선택 : 해당 개요의 직렬 콤보 생성
 */
this.divContent04_cboAppoExam_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	// 선택 아아디
	var selIdx = e.postindex;
	// 선택한 개요아이디
	var selAppoExamId = this.dsResultAppoExam.getColumn(selIdx, "appoExamId");
	// 선택한 개요명
	var selAppoExamNm = this.dsResultAppoExam.getColumn(selIdx, "appoExamNm");
	// 직렬 콤보 데이터 clear
	//this.dsJbln.clearData();
	// 계급 콤보 데이터 clear
	//this.dsRks.clearData();
	// 직렬 콤보 데이터 필터
	this.divContent04.form.cboAppoJbln.set_value(null);
	this.dsResultJbln.filter("appoExamId=='"+selAppoExamId+"'");
	
	// 계급 콤보 데이터 초기화
	this.divContent04.form.cboAppoRks.set_value(null);
	this.dsResultRks.filter("appoExamId=='99999999'");
};

/**
 * 직렬 셀렉트박스 선택 : 직렬의 계급 콤보 생성
 */
this.divContent04_cboAppoJbln_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
 	var selIdx = e.postindex;
 	// 선택한 직렬의 임용시험아이디
 	var selAppoExamId = this.dsResultJbln.getColumn(selIdx, "appoExamId");
 	// 선택한 직렬의 직렬코드
 	var selOcptyCd = this.dsResultJbln.getColumn(selIdx, "ocptyCd");
	// 계급 콤보 초기화
	this.divContent04.form.cboAppoRks.set_value(null);
	// 계급 콤보 데이터 필터
	this.dsResultRks.filter("appoExamId=='"+selAppoExamId+"'"+" && ocptyCd=='"+selOcptyCd+"'");
};



]]></Script>
    <Objects>
      <Dataset id="dsDateTime" useclientlayout="true">
        <ColumnInfo>
          <Column id="mm" type="STRING" size="256"/>
          <Column id="dd" type="STRING" size="256"/>
          <Column id="hhmmss" type="STRING" size="256"/>
          <Column id="yyyymmdd" type="STRING" size="256"/>
          <Column id="yyyy" type="STRING" size="256"/>
          <Column id="hhmmsssss" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">selectDate</Col>
            <Col id="inDatasets"/>
            <Col id="outDatasets">dsDateTime=dsDateTime</Col>
            <Col id="url">cmc_fcm_dt01_001.do</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="id">selectAppoExamList</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResultAppoExam=dsResultAppoExam dsResultJbln=dsResultJbln dsResultRks=dsResultRks</Col>
            <Col id="url">ore_oew_ar20_m00_001.do</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="id">selectCheckData</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResultCheck=dsResultCheck</Col>
            <Col id="url">ore_oew_ar20_m00_002.do</Col>
            <Col id="asynctp">false</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsResultAppoExam" useclientlayout="true">
        <ColumnInfo>
          <Column id="appoExamId" type="string" size="256" description="임용시험아이디"/>
          <Column id="appoExamNm" type="string" size="256" description="임용시험명"/>
          <Column id="appoExamMastrIdfId" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsResultJbln" useclientlayout="true">
        <ColumnInfo>
          <Column id="appoExamId" type="string" size="256" description="임용시험ID"/>
          <Column id="appoExamNm" type="STRING" size="256" description="임용시험명"/>
          <Column id="ocptyCd" type="STRING" size="256" description="직류코드"/>
          <Column id="ocptyNm" type="STRING" size="256" description="직류명"/>
          <Column id="jblnCd" type="STRING" size="256" description="직렬명"/>
          <Column id="jblnNm" type="STRING" size="256" description="직렬코드"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsResultRks" useclientlayout="true">
        <ColumnInfo>
          <Column id="appoExamId" type="string" size="256" description="임용시험ID"/>
          <Column id="appoExamNm" type="STRING" size="256" description="임용시험명"/>
          <Column id="ocptyCd" type="STRING" size="256" description="직류코드"/>
          <Column id="ocptyNm" type="STRING" size="256" description="직류명"/>
          <Column id="jbgdCd" type="STRING" size="256" description="직급코드"/>
          <Column id="jbgdNm" type="STRING" size="256" description="직급명"/>
          <Column id="rksCd" type="STRING" size="256" description="계급코드"/>
          <Column id="rksNm" type="STRING" size="256" description="계급명"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsJbln" useclientlayout="true">
        <ColumnInfo>
          <Column id="appoExamId" type="string" size="256" description="임용시험ID"/>
          <Column id="appoExamNm" type="STRING" size="256" description="임용시험명"/>
          <Column id="ocptyCd" type="STRING" size="256" description="직류코드"/>
          <Column id="ocptyNm" type="STRING" size="256" description="직류명"/>
          <Column id="jblnCd" type="STRING" size="256" description="직렬명"/>
          <Column id="jblnNm" type="STRING" size="256" description="직렬코드"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsRks" useclientlayout="true">
        <ColumnInfo>
          <Column id="appoExamId" type="string" size="256" description="임용시험ID"/>
          <Column id="appoExamNm" type="STRING" size="256" description="임용시험명"/>
          <Column id="ocptyCd" type="STRING" size="256" description="직류코드"/>
          <Column id="ocptyNm" type="STRING" size="256" description="직류명"/>
          <Column id="jbgdCd" type="STRING" size="256" description="직급코드"/>
          <Column id="jbgdNm" type="STRING" size="256" description="직급명"/>
          <Column id="jblnCd" type="STRING" size="256" description="직렬명"/>
          <Column id="jblnNm" type="STRING" size="256" description="직렬코드"/>
          <Column id="rksCd" type="STRING" size="256" description="계급코드"/>
          <Column id="rksNm" type="STRING" size="256" description="계급명"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="false" updatecontrol="false">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256" description="접속시도교육청 구분코드"/>
          <Column id="applpRrno" type="STRING" size="256" description="응시자주민번호"/>
          <Column id="appoExamId" type="STRING" size="256" description="임용시험아아디"/>
          <Column id="ocptyCd" type="STRING" size="256" description="직류코드"/>
          <Column id="jblnCd" type="STRING" size="256" description="직렬코드"/>
          <Column id="jbgdCd" type="STRING" size="256" description="직급코드"/>
          <Column id="rksCd" type="STRING" size="256" description="계급코드"/>
          <Column id="appoExamMastrIdfId" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="cddcCd"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsResultCheck" useclientlayout="true" updatecontrol="true">
        <ColumnInfo>
          <Column id="applpImYn" type="STRING" size="1" description="기타 지원불가"/>
          <Column id="disquYn" type="STRING" size="1" description="결격자(부정행위)여부"/>
          <Column id="unaExamYn" type="STRING" size="1" description="무효시험(삭제,마감)여부"/>
          <Column id="rcptImDtYn" type="STRING" size="1" description="접수불가기간여부"/>
          <Column id="dpcnYn" type="STRING" size="1" description="중복지원여부"/>
          <Column id="totalDpcnYn" type="STRING" size="1"/>
          <Column id="lmttAgeYn" type="STRING" size="1" description="연령제한여부"/>
          <Column id="dpcnYn2" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="disquYn">N</Col>
            <Col id="unaExamYn">N</Col>
            <Col id="rcptImDtYn">N</Col>
            <Col id="dpcnYn">N</Col>
            <Col id="lmttAgeYn">N</Col>
            <Col id="applpImYn">N</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
  </Form>
</FDL>
