<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="formMain" width="1200" height="2630" titletext="지방공무원-지원서 작성 동의서" onload="formMain_onload">
    <Layouts>
      <Layout height="2630" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle00" taborder="0" left="0" top="70" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle00" taborder="0" text="지원서작성 동의서" left="0" top="0" height="44" cssclass="img_WF_SubTit01" width="276" initvalueid="ivTitleAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divContent00" taborder="1" left="0" height="2186" right="0" top="144" text="" initvalueid="ivDivAccessibilityOff" cssclass="div_WF_InfoBOX">
          <Layouts>
            <Layout>
              <Static id="staTlt00" taborder="0" left="30" top="24" height="36" text="인터넷접수 서약서" wordWrap="char" width="289" cssclass="sta_WF_WorkTit" initvalueid="ivStcAccessibilityOn" accessibilitylabel="교육부, 시도교육청내 자료 활용 동의서"/>
              <Div id="divContent01" taborder="1" left="30" height="150" cssclass="div_WF_InfoBOX" top="65" text="" right="30" initvalueid="ivDivAccessibilityOff">
                <Layouts>
                  <Layout>
                    <Static id="staContents" taborder="0" left="30" top="20" height="107" text="※ 아래의 내용을 읽으시고 동의하셔야 인터넷 접수가 가능합니다.&#13;&#10;    본 시스템으로 제출하는 응시원서 기재사항은 사실과 틀림없으며 허위 사실을 기재하였을 때에는 관계법령에 의거 당해 시험이 정지되거나 &#13;&#10;    합격결정이 취소되고, 그 처분이 있는 날로부터 5년간 응시자격이 정지되어도 이의를 제기하지 않겠으며, 시험과 관련한 사실관계확인을 위하여 &#13;&#10;    관계 기관으로부터 관련정보를 제공받고 제공하는 것에 동의하며, 만약 본 시스템의 응시원서 기재사항과 불일치할 경우 본인의 당해시험 &#13;&#10;    무효처리 및 최종합격 취소처리 자격정지 되어도 아무런 이의를 제기하지 않겠습니다." wordWrap="char" width="1078" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" onclick="divContent00_divContent01_staContent01_onclick"/>
                    <Static id="staGd03" taborder="1" left="0" top="-7" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="-1" text="30" initvalueid="ivStcAccessibilityOff"/>
                    <Static id="staGd04" taborder="2" left="1110" top="-3" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="-7" text="30" initvalueid="ivStcAccessibilityOff"/>
                  </Layout>
                </Layouts>
              </Div>
              <CheckBox id="chkVal01" taborder="2" text="서약에 동의합니다.  " left="1002" top="221" width="150" height="25" initvalueid="ivChkNormal" textAlign="right"/>
              <Static id="staTlt01" taborder="3" left="30" top="263" height="32" text="개인정보 수집 및 이용에 대한 동의" wordWrap="char" width="359" cssclass="sta_WF_WorkTit" initvalueid="ivStcAccessibilityOn" accessibilitylabel="교육부, 시도교육청내 자료 활용 동의서"/>
              <Static id="staTltSub01" taborder="4" left="41" top="311" height="23" text="1. 개인정보 수집 및 이용에 대한 동의" wordWrap="char" width="289" cssclass="sta_WF_InfoTit02" initvalueid="ivStcAccessibilityOn" accessibilitylabel="교육부, 시도교육청내 자료 활용 동의서"/>
              <Div id="divContentSub01" taborder="5" left="31" height="337" cssclass="div_WF_InfoBOX" top="342" text="" right="30" initvalueid="ivDivAccessibilityOff">
                <Layouts>
                  <Layout>
                    <Static id="staContents" taborder="0" left="30" top="16" height="300" text="가. 개인정보의 수집 및 이용 목적&#13;&#10;  지방공무원 임용시험에 응시한 사람을 신규채용절차에 따라 응시자격 및 결격사유 등을 확인하고, 시험의 합격자를 선발하기 위함&#13;&#10;  응시료 결제 시 본인확인 및 인증&#13;&#10;나. 수집하려는 개인정보의 항목&#13;&#10;  임용시험 원서 접수 시 응시자의 응시자격, 가산점 및 가점 확인, 시험 진행, 시험성적의 처리를 위해 아래와 같은 개인정보를 수집하고 있습니다.&#13;&#10;  성명, &lt;b v='true'&gt;&lt;fs v='12'&gt;주민등록번호, 주민등록표 등본, 가족관계증명서&lt;/fs&gt;&lt;/b&gt;, 연락처, 사진, 장애관련사항 등 합격자 선발을 위한 가(산)점 확인 사항, 이 외에 원서 접수 시 입력하는 사항&#13;&#10;  원서접수 내용 외 응시원서 접수사이트 로그인 시 사용하는 비밀번호&#13;&#10;  응시수수료 납부과정에서의 결제 정보들은 전자지불업체의 개인정보처리방침을 참고하시기 바랍니다.&#13;&#10;  ※ 주민등록번호는 「지방공무원임용령」  제77조(민감정보 및 고유식별정보의 처리)에 근거하여 처리합니다.&#13;&#10;  ※ 미성년자 두 자녀 이상의 경우 응시료 면제가 가능하므로 주민등록표 등본에서 가족 구성원 확인이 필요합니다.&#13;&#10;&lt;b v='true'&gt;&lt;fs v='12'&gt;다. 개인정보의 보유 기간 &#13;&#10;  수집한 개인정보는 공공기록물 관리에 관한 법률에 의해 정해진 기간 동안 보유&lt;/fs&gt;&lt;/b&gt;&#13;&#10;라. 동의를 거부할 권리 및 동의 거부에 따른 제약사항 &#13;&#10;  위 사항에 대하여 동의를 거부할 권리가 있으며 동의 거부 시에는 본 사이트에서 제공하는 원서접수, 합격 및 성적조회 서비스 등을 이용할 수 없습니다." wordWrap="char" width="1077" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" onclick="divContent00_divContent01_staContent01_onclick" usedecorate="true"/>
                    <Static id="staGd01" taborder="1" left="0" top="-7" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="-20" text="30" initvalueid="ivStcAccessibilityOff"/>
                    <Static id="staGd04_00" taborder="2" left="1110" top="-7" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="-1" text="30" initvalueid="ivStcAccessibilityOff"/>
                    <Static id="staGd02" taborder="3" left="21" top="-4" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="-23" initvalueid="ivStcAccessibilityOff"/>
                    <Static id="staGd04" taborder="4" left="31" top="318" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="27" initvalueid="ivStcAccessibilityOff"/>
                  </Layout>
                </Layouts>
              </Div>
              <CheckBox id="chkVal02" taborder="6" text="동의합니다.  " left="1044" top="680" width="101" height="27" initvalueid="ivChkNormal" textAlign="right"/>
              <Static id="staTltSub03" taborder="7" left="41" top="717" height="23" text="2. 민감정보 수집 동의" wordWrap="char" width="289" cssclass="sta_WF_InfoTit02" initvalueid="ivStcAccessibilityOn" accessibilitylabel="교육부, 시도교육청내 자료 활용 동의서"/>
              <Div id="divContentSub03" taborder="8" left="32" height="375" cssclass="div_WF_InfoBOX" top="750" text="" right="29" initvalueid="ivDivAccessibilityOff">
                <Layouts>
                  <Layout>
                    <Static id="staContents" taborder="0" left="32" top="8" height="357" text="&lt;b v='true'&gt;&lt;fs v='12'&gt;가. 고유식별번호 및 민감정보 수집 내역&lt;/fs&gt;&lt;/b&gt; &#13;&#10;  주민등록번호&#13;&#10;  취업지원대상자&#13;&#10;  의사상자 등 가점 대상자&#13;&#10;  장애관련 사항(장애구분, 장애등급)&#13;&#10;  사회취약계층대상자(국민기초생활수급자, 한부모가족, 차상위계층)&#13;&#10;  장애인연금법상 수급정보&#13;&#10;  가족관계 정보&#13;&#10;&lt;b v='true'&gt;&lt;fs v='12'&gt;나. 고유식별번호, 민감정보 수집 및 이용 목적&lt;/fs&gt;&lt;/b&gt;&#13;&#10;  지방공무원 임용시험에 응시한 사람을 신규채용절차에 따라 응시자격 및 결격사유 등을 확인하고, 시험의 합격자를 선발하기 위함&#13;&#10;  시험 시행을 위한 응시자 확인&#13;&#10;  응시수수료 면제 대상자 사실관계 확인&#13;&#10;  합격 및 성적조회 서비스 등 응시생 편의를 위해 이용&#13;&#10;다. 동의를 거부할 권리 및 거부에 따른 제약사항 &#13;&#10;  위 사항에 대하여 동의를 거부할 권리가 있으며 동의 거부 시에는 본 사이트에서 제공하는 원서접수, 합격 및 성적조회 서비스를 이용할 수 없습니다." wordWrap="char" width="1067" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" onclick="divContent00_divContent01_staContent01_onclick" usedecorate="true"/>
                    <Static id="staGd04" taborder="1" left="0" top="-7" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="-1" text="30" initvalueid="ivStcAccessibilityOff"/>
                    <Static id="staGd01" taborder="2" left="1105" top="1" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="-9" text="30" initvalueid="ivStcAccessibilityOff"/>
                    <Static id="staGd00" taborder="3" left="31" top="-1" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="31" initvalueid="ivStcAccessibilityOff"/>
                    <Static id="staGd02" taborder="4" left="29" top="355" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="29" initvalueid="ivStcAccessibilityOff"/>
                  </Layout>
                </Layouts>
              </Div>
              <CheckBox id="chkVal04" taborder="9" text="동의합니다.  " left="1044" top="1133" width="101" height="27" initvalueid="ivChkNormal" textAlign="right"/>
              <Static id="staTltSub04" taborder="10" left="41" top="1198" height="23" text="3. 개인정보 제3자 제공에 관한 동의" wordWrap="char" width="289" cssclass="sta_WF_InfoTit02" initvalueid="ivStcAccessibilityOn" accessibilitylabel="교육부, 시도교육청내 자료 활용 동의서"/>
              <Div id="divContentSub04" taborder="11" left="32" height="396" cssclass="div_WF_InfoBOX" top="1229" text="" right="29" initvalueid="ivDivAccessibilityOff">
                <Layouts>
                  <Layout>
                    <Static id="staContent" taborder="0" left="30" top="6" height="359" text="&lt;b v='true'&gt;&lt;fs v='12'&gt;가. 개인정보 제3자 제공내역 &#13;&#10;  국가보훈부 : 취업지원 가점 대상자 확인 목적&#13;&#10;  보건복지부 : 의사상자, 국민기초생활수급자, 차상위계층 등 확인 목적&#13;&#10;  여성가족부 : 한부모가족 확인 목적&#13;&#10;  교육부 : 인터넷 응시원서 접수 확인 목적&#13;&#10;  지방자치단체(시,군,구,읍,면,동) : 장애인 여부, 신원조회 확인 목적&#13;&#10;  경찰서 : 성범죄경력 여부 확인 목적&#13;&#10;  경찰청 : 신원조사 확인 목적&#13;&#10;  행정안전부 : 비위면직자 확인 목적&#13;&#10;  각종 자격증 발급기관 : 가산점 확인 및 취득여부 확인&#13;&#10;  인사혁신처 : 공무원시험 부정행위 이력조회 목적&lt;/fs&gt;&lt;/b&gt; &#13;&#10;&lt;b v='true'&gt;&lt;fs v='12'&gt;나. 해당기관에서 관련 법령의 규정에 의하여 일정기간 보유 하여야 할 필요가 있을 경우에는 그 기간 동안 보유합니다.&lt;/fs&gt;&lt;/b&gt;&#13;&#10;다. 동의를 거부할 권리 및 거부에 따른 제약사항 &#13;&#10;  위 사항에 대하여 동의를 거부할 권리가 있으며 동의 거부 시에는 본 사이트에서 제공하는 원서접수, 합격 및 성적조회, 임용후보자 등록 등 서비스 이용할 수 없습니다." wordWrap="char" width="1065" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" onclick="divContent00_divContent01_staContent01_onclick" usedecorate="true"/>
                    <Static id="staGd04" taborder="1" left="0" top="-7" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="-1" text="30" initvalueid="ivStcAccessibilityOff"/>
                    <Static id="staGd04_01" taborder="2" left="1109" top="1" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="-9" text="30" initvalueid="ivStcAccessibilityOff"/>
                    <Static id="staGd03_00_01" taborder="3" left="31" top="-1" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="31" initvalueid="ivStcAccessibilityOff"/>
                    <Static id="staGd03_00_01_00" taborder="4" left="29" top="374" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="29" initvalueid="ivStcAccessibilityOff"/>
                  </Layout>
                </Layouts>
              </Div>
              <CheckBox id="chkVal05" taborder="12" text="동의합니다.  " left="1044" top="1633" width="101" height="27" initvalueid="ivChkNormal" textAlign="right" onclick="divContent00_chkVal05_onclick"/>
              <CheckBox id="chkAll" taborder="13" text="위 내용에 전체 동의합니다." left="39.40%" top="2066" width="196" height="33" initvalueid="ivChkNormal" onclick="divContent00_chkVal_onclick"/>
              <Static id="staDate00" taborder="14" left="40.82%" top="2123" height="21" text="2022년 5월 20일" wordWrap="char" font="bold 16px/1.5 &quot;NotoSansKR-Regular,Malgun Gothic,Arial,MS PGothic&quot;" width="157" cssclass="sta_WF_InfoTit01" textAlign="center" initvalueid="ivStcAccessibilityOn"/>
