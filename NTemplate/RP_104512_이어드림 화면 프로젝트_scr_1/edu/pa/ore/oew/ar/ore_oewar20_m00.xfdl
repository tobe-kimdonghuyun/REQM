              <Static id="staGd19" taborder="25" left="491" top="2032" height="40" cssclass="sta_GD_Size" text="40" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="488" initvalueid="ivStcAccessibilityOff"/>
