        <Static id="staGd00" taborder="5" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd01" taborder="6" left="31" top="114" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="879" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd15" taborder="7" left="456" top="2510" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="454" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd14" taborder="8" left="0" top="2404" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="910" initvalueid="ivStcAccessibilityOff"/>
