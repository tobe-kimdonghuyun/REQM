/**
 * [버튼클릭] 가산점 삭제
 */
this.divAdtnInfo_btnAdtnDel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 데이터 없을경우
	if(this.dsMainAdtn.rowcount < 1){
		this.smfAlert("삭제 대상 가산점이 없습니다.");
		return;
	}
	// 체크박스 ON ARRAY 
	var chkIdxArray = this.dsMainAdtn.extractRows("_chk ==1");
	
	if(this.isNil(chkIdxArray)){ 
		this.smfAlert("삭제 대상 가산점을 선택 해주세요. ");
		return;
	}
	
	// 확인 메시지 출력
	this.smfConfirm("삭제 하시겠습니까?", function(result){
		if(result.confirmResult){
			// 데이터삭제
			this.dsMainAdtn.deleteMultiRows(chkIdxArray);
		}
	});
};

