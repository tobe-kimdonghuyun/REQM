/**
* 응시료 면제 체크박스 처리
*/
this.divAechgInfo_chkAechg_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	// 응시료면제구분
	var rlesScCd = this.divAechgInfo.form.rdoRlesScCd.value;
		
	if(obj.value === 'Y'){
		this.divAechgInfo.form.staContent00.set_enable(true);
		// 응시료면제구분 라디오 활성
		this.divAechgInfo.form.rdoRlesScCd.set_enable(true);
		this.divAechgInfo.form.divContent03.set_enable(true);
	}else{
		this.divAechgInfo.form.staContent00.set_enable(false);
		// 응시료면제구분 라디오 비활성화
		this.divAechgInfo.form.rdoRlesScCd.set_enable(false);
		this.divAechgInfo.form.divContent03.set_enable(false);
	}
};


// 응시료 면제자 구분 탭 변경
this.divAechgInfoTabChange = function()
{
	var rlesScCd = this.divAechgInfo.form.rdoRlesScCd.value;

	this.divAechgInfo.form.divContent03.set_enable(true); // 환불정보 활성
	this.dsMainDtl.setColumn(0 ,'rlesVrfcScsYn', 'N' ); //검증결과
	this.dsMainDtl.setColumn(0 ,'rlesRegNo', ''); //검증번호
	this.dsMainDtl.setColumn(0 ,'rlesVrfcCn', '');  //검증내용
	this.dsMainStatus.setColumn(0 ,'rlesYn', 'N'); //응시료 면제 여부
};

/**
* 응시료 면제 구분코드 변경
*/
this.divAechgInfo_rdoRlesScCd_canitemchange = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	// 이전 면제구분코드
	var beforeRdoVal = e.prevalue;
	// 선택 면제구분코드
	var afterRdoVal = e.postvalue;

	// 응시료 면제 검증 여부
	var rlesVrfcScsYn = this.dsMainDtl.getColumn(0, 'rlesVrfcScsYn');
	if(rlesVrfcScsYn === 'Y'){
		this.smfConfirm("이미 검증된 정보가 있을 경우 이전 검증 정보는 초기화됩니다. \n응시료면제 구분을 변경 하시겠습니까?", function(result){
			if(result.confirmResult){
				// 선택 면제구분코드 SET
				this.divAechgInfo.form.rdoRlesScCd.set_value(afterRdoVal)
				// 클릭한 면제구분 코드 탭이동
				this.divAechgInfoTabChange();
				return true;
			}else{
				// 이전 면제구분코드 SET 탭이동 없음
				this.divAechgInfo.form.rdoRlesScCd.set_value(beforeRdoVal);
				return false;
			}
		});
	}else{
		// 선택 면제구분코드 SET
		this.divAechgInfo.form.rdoRlesScCd.set_value(afterRdoVal);
		// 클릭한 면제구분 코드 탭이동
		this.divAechgInfoTabChange();
	}
};

/**
* [버튼클릭] 저장
*/
this.divSubmitInfo_btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 개요정보 존재여부
	var useApplpYn = this.dsResultAppoExamCeck.getColumn(0, "useApplpYn");
	if(useApplpYn != 'Y' ){
		this.smfAlert("원서 접수가 불가능합니다.");
		return;
	}
	
	// 임용시험유효여부
	var useExamYn = this.dsResultAppoExamCeck.getColumn(0, "useExamYn");
	if(useExamYn === 'N'){
		this.smfAlert("진행중인 임용 시험이 아닙니다.");
		return;
	}
	
	// 인터넷 접수기간
	var itnRcptYn = this.dsResultAppoExamCeck.getColumn(0, "itnRcptYn");
	// 가산점 수정기간
	var adpnRcptRtrcnYn = this.dsResultAppoExamCeck.getColumn(0, "adpnRcptRtrcnYn");

	if(itnRcptYn != 'Y' && adpnRcptRtrcnYn != 'Y'){
		this.smfAlert("원서접수 기간이 아닙니다.");
		return;
	}
	
	// 지원서 기본정보 등록용 부가 정보  SET
	this.fnSetSaveMainBaseInfo();
	
	// 제한자격증 등록용 부가 정보  SET
	//JSF_20250210
	if(this.lmttQlflDetail)
	{
		// 초기화
		this.dsMainLmttQlfl.clearData();	
		var checkedIdx = 0;
		for(var i=0;i<this.dsResultLmttQlfl.rowcount;i++){
			if(this.dsResultLmttQlfl.getColumn(i,"_chk") == "1")
			{
				this.dsMainLmttQlfl.addRow();
				/*if(this.smfIsNull(this.dsResultLmttQlfl.getColumn(i,"qlflNo")))
				{
					this.smfAlert(this.dsResultLmttQlfl.getColumn(i,"qlflIdfValue") + " 에 대한 자격번호가 입력되지 않았습니다.\n입력후 저장해 주세요");
					return false;	
				}
				if(this.smfIsNull(this.dsResultLmttQlfl.getColumn(i,"issuInstNm")))
				{
					this.smfAlert(this.dsResultLmttQlfl.getColumn(i,"qlflIdfValue") + " 에 대한 발급기관이 입력되지 않았습니다.\n입력후 저장해 주세요");
					return false;	
				} 자격번호, 발급기관은 입력안해도 되도록 수정(SR00253177 04.14)*/
				if(this.smfIsNull(this.dsResultLmttQlfl.getColumn(i,"issuYmd")))
				{
					this.smfAlert(this.dsResultLmttQlfl.getColumn(i,"qlflIdfValue") + " 에 대한 취득일이 입력되지 않았습니다.\n입력후 저장해 주세요");
					return false;	
				}
				this.dsMainLmttQlfl.setColumn(checkedIdx,"qlflIdfCd"	,this.dsResultLmttQlfl.getColumn(i,"qlflIdfCd").trim());
				this.dsMainLmttQlfl.setColumn(checkedIdx,"qlflIdfValue"	,this.dsResultLmttQlfl.getColumn(i,"qlflIdfValue"));
				this.dsMainLmttQlfl.setColumn(checkedIdx,"qlflIdfNm"	,this.dsResultLmttQlfl.getColumn(i,"qlflIdfNm"));			
				this.dsMainLmttQlfl.setColumn(checkedIdx,"qlflNo"		,this.dsResultLmttQlfl.getColumn(i,"qlflNo"));
				this.dsMainLmttQlfl.setColumn(checkedIdx,"issuInstNm"	,this.dsResultLmttQlfl.getColumn(i,"issuInstNm"));
				this.dsMainLmttQlfl.setColumn(checkedIdx,"issuYmd"		,this.dsResultLmttQlfl.getColumn(i,"issuYmd"));
				checkedIdx++;
			}
		}
	}
	else
	{
		this.fnSetSaveMainLmttQlflInfo();
	}
	
	// 원서접수 문자발송정보 SET
	this.fnSetSaveRcptSmsInfo();
	
	//사진필수여부
	var photoEsntlYn = this.dsResultAppoExamBasic.getColumn(0, 'photoEsntlYn'); 
	if(photoEsntlYn === 'Y'){
		// 기본정보 validate  
		this.smfUpdateValidateToComponent("required",this.divBaseInfo.form.imgPicture); //사진
	}
	/*
	자동완성 기능 미지원으로 인한
	휴대전화 비상연락처 이메일 validate 체크 방식 변경
	2024.4.15
	this.smfUpdateValidateToComponent("required",this.divBaseInfo.form.edtMblTelno00); //휴대전화1
	this.smfUpdateValidateToComponent("required",this.divBaseInfo.form.edtMblTelno01); //휴대전화2
	this.smfUpdateValidateToComponent("required",this.divBaseInfo.form.edtMblTelno02); //휴대전화3
	this.smfUpdateValidateToComponent("required",this.divBaseInfo.form.edtPhoneNo00); //비상연락처1
	this.smfUpdateValidateToComponent("required",this.divBaseInfo.form.edtPhoneNo01); //비상연락처2
	this.smfUpdateValidateToComponent("required",this.divBaseInfo.form.edtPhoneNo02); //비상연락처3
	//this.smfUpdateValidateToComponent("required,email",this.divBaseInfo.form.edtEmail); //이메일
	this.smfUpdateValidateToComponent("required",this.divBaseInfo.form.edtEmail1);
	this.smfUpdateValidateToComponent("required",this.divBaseInfo.form.edtEmail3);
	*/
	
	// 휴대전화
	if(this.smfIsNull(this.dsMainBase.getColumn(0,"mblTelno1"))){
		this.divBaseInfo.form.edtMblTelno00.setFocus();
		this.smfAlert("휴대전화 이(가) 입력되어 있지 않습니다.\n※ 자동완성 기능으로 입력하신 경우 이를 지우고 키보드로 직접 다시 입력해 주세요.");
		return false;	
	}
	if(this.smfIsNull(this.dsMainBase.getColumn(0,"mblTelno2"))){
		this.divBaseInfo.form.edtMblTelno01.setFocus();
		this.smfAlert("휴대전화 이(가) 입력되어 있지 않습니다.\n※ 자동완성 기능으로 입력하신 경우 이를 지우고 키보드로 직접 다시 입력해 주세요.");
		return false;	
	}
	if(this.smfIsNull(this.dsMainBase.getColumn(0,"mblTelno3"))){
		this.divBaseInfo.form.edtMblTelno02.setFocus();
		this.smfAlert("휴대전화 이(가) 입력되어 있지 않습니다.\n※ 자동완성 기능으로 입력하신 경우 이를 지우고 키보드로 직접 다시 입력해 주세요.");
		return false;	
	}
	// 비상시 연락처
	if(this.smfIsNull(this.dsMainBase.getColumn(0,"emgCnctTelno1"))){
		this.divBaseInfo.form.edtPhoneNo00.setFocus();
		this.smfAlert("비상시 연락처 이(가) 입력되어 있지 않습니다.\n※ 자동완성 기능으로 입력하신 경우 이를 지우고 키보드로 직접 다시 입력해 주세요.");
		return false;	
	}
	if(this.smfIsNull(this.dsMainBase.getColumn(0,"emgCnctTelno2"))){
		this.divBaseInfo.form.edtPhoneNo01.setFocus();
		this.smfAlert("비상시 연락처 이(가) 입력되어 있지 않습니다.\n※ 자동완성 기능으로 입력하신 경우 이를 지우고 키보드로 직접 다시 입력해 주세요.");
		return false;	
	}
	if(this.smfIsNull(this.dsMainBase.getColumn(0,"emgCnctTelno3"))){
		this.divBaseInfo.form.edtPhoneNo02.setFocus();
		this.smfAlert("비상시 연락처 이(가) 입력되어 있지 않습니다.\n※ 자동완성 기능으로 입력하신 경우 이를 지우고 키보드로 직접 다시 입력해 주세요.");
		return false;	
	}
	// E-MAIL
	if(this.smfIsNull(this.dsMainBase.getColumn(0,"emlAddr1"))){
		this.divBaseInfo.form.edtEmail1.setFocus();
		this.smfAlert("이메일 이(가) 입력되어 있지 않습니다.\n※ 자동완성 기능으로 입력하신 경우 이를 지우고 키보드로 직접 다시 입력해 주세요.");
		return false;	
	}
	if(this.smfIsNull(this.dsMainBase.getColumn(0,"emlAddr3"))){
		this.divBaseInfo.form.cboEmlAddr2.setFocus();
		this.smfAlert("이메일 이(가) 입력되어 있지 않습니다.\n※ 자동완성 기능으로 입력하신 경우 이를 지우고 키보드로 직접 다시 입력해 주세요.");
		return false;	
	}
	
	
	this.smfUpdateValidateToComponent("required",this.divBaseInfo.form.edtPostCode);  //우편번호
	this.smfUpdateValidateToComponent("required",this.divBaseInfo.form.edtAddr);  //주소
	this.smfUpdateValidateToComponent("required",this.divBaseInfo.form.edtAddrDtl);  //주소상세
	// 최종학력 validate
	this.smfUpdateValidateToComponent("required",this.divAcbgInfo.form.cboAcbg); // 최종학력
	
	// 가산점 수정기간에는 시험장 필수처리 X
	// 원서접수기간 일 때만 시험장 [필수]처리
	if(itnRcptYn == 'Y'){
		// 시험장 있을경우
		if(this.dsResultExmr.getRowCount() >  0){
			// 시험장지역명 validate
			this.smfUpdateValidateToComponent("required", this.divExmrInfo.form.cboExmr); // 시험장지역명
		}
	}

	// 휴대전화번호
	var mblTelno =this.dsMainBase.getColumn(0, "mblTelno");
	// 비상연락처
	var emgCnctTelno = this.dsMainBase.getColumn(0, "emgCnctTelno");	
	if((mblTelno != '' && emgCnctTelno != '') && (mblTelno === emgCnctTelno)){
		this.divBaseInfo.form.edtPhoneNo00.setFocus();
		this.smfAlert("비상시 연락처는 휴대전화와 같은 번호로 등록 할 수 없습니다.");
		return;
	}
	
	// 이메일 
	if(!this.smfIsNull(this.dsMainBase.getColumn(0,"emlAddr"))){
		if(!this.smfIsEmail(this.dsMainBase.getColumn(0,"emlAddr"))){
			this.divBaseInfo.form.edtEmail1.setFocus();
			this.smfAlert('이메일의 형식이 잘못되었습니다.');
			return;
		}
	}
	
	// 제한자격 validate
	var lmttQlflCnt = this.dsResultLmttQlfl.getRowCount();
	// 제한자격이 있을경우
	if(lmttQlflCnt >  0){
		// 제한자격 선택 체크
		var chkLmttQlflCnt = this.dsMainLmttQlfl.getRowCount();
		if(chkLmttQlflCnt <1){
			this.divLmttQlflInfo.form.imgTitleLmttQlfl.setFocus();
			this.smfAlert("필요자격증이 존재할 경우, 필요자격증을 1개 이상 선택해야만 접수가 가능합니다.");
			return;
		}
	}
	
	// 장애시험여부
	var dltYn = this.dsResultAppoExam.getColumn(0, "dltYn");
	if('Y' === dltYn){
		// 장애구분
		var dltScCd = this.divApplpScInfo.form.cboDltScCd.value;
		if('0' === dltScCd){ // 장애아님 선택시
			this.divApplpScInfo.form.cboDltScCd.setFocus();
			this.smfAlert("장애인 구분은 필수입니다.");
			return;
		}
		// 장애등급
		var dltClaCd = this.divApplpScInfo.form.cboDltClaCd.value;
		if('09' === dltClaCd){ // 장애아님 선택시
			this.divApplpScInfo.form.cboDltClaCd.setFocus();
			this.smfAlert("장애인 등급은 필수입니다.");
			return;
		}
		// 중증구분코드
		var dltSedScCd = this.divApplpScInfo.form.cboSedScCd.value;
		if('0' === dltSedScCd){ // 해당없음 선택시
			this.divApplpScInfo.form.cboSedScCd.setFocus();
			this.smfAlert("중증/중증외는 필수입니다.");
			return;
		}
	}
	
	// 응시료 면제 체크 여부
	var isAechgChk = this.divAechgInfo.form.chkAechg.value;
	if(isAechgChk === 'Y'){
		var sRlesScCd = this.divAechgInfo.form.rdoRlesScCd.value; // 선택 응시료 면제 구분코드
		var rlesVrfcScsYn = this.dsMainDtl.getColumn(0 ,'rlesVrfcScsYn' ); //응시료면제 검증여부
		// 면제자 설정값이 있을 경우 화면 처리
		if(sRlesScCd != "00"){
			if(rlesVrfcScsYn != 'Y'){
				var bankCd = this.divAechgInfo.form.divContent03.form.cboBankCd.value;// 환불은행
				var bankActno = this.divAechgInfo.form.divContent03.form.edtBankActno.value; // 환불계좌
				var refndAccDpstrNm = this.divAechgInfo.form.divContent03.form.edtRefndAccDpstrNm.value;// 예금주
				if(this.smfIsNull(bankCd) || this.smfIsNull(bankActno)  || this.smfIsNull(refndAccDpstrNm) ){
					this.divAechgInfo.form.divContent03.form.cboBankCd.setFocus();
					this.smfAlert("응시료 환불 정보를 입력해 주세요.\n※ 추후 담당자 확인 후 입력된 정보로 환불 진행 됩니다.");
					return;
				}
			}
		}
	}else{
		// 환불정보 초기화
		this.divAechgInfo.form.divContent03.form.cboBankCd.set_value("");
		this.divAechgInfo.form.divContent03.form.edtBankActno.set_value("");
		this.divAechgInfo.form.divContent03.form.edtRefndAccDpstrNm.set_value("");
	}
	
	// 가산점 validate : 동일 가산분야 등록 불가
	for(var i=0 ; i<this.dsMainAdtn.rowcount ; i++){
		// 가산 분류코드
		var adtnClfCd = this.dsMainAdtn.getColumn(i, 'adtnClfCd');
		// 중복 수
		var adtnDupleCnt  = this.dsMainAdtn.getCaseCount("adtnClfCd=='"+adtnClfCd+"'");
		if(adtnDupleCnt >1){
			this.divAdtnInfo.form.imgTitleApdn.setFocus();
			this.smfAlert("동일한 가산분야는 저장할 수 없습니다.");
			return;
		}
	}
	
	// 가산점 validate : 취업지원 대상자(08) 등록수
	var adtnClfCd08Cnt = this.dsMainAdtn.getCaseCount("adtnClfCd=='08'");
	// 가산점 validate : 의사상자 대상자(17) 등록수
	var adtnClfCd17Cnt = this.dsMainAdtn.getCaseCount("adtnClfCd=='17'");
	// 취업 지원 대상 + 의사상자 동시 불가
	if(adtnClfCd08Cnt > 0  && adtnClfCd17Cnt > 0 ){
		this.divAdtnInfo.form.imgTitleApdn.setFocus();
		this.smfAlert("의사상자와 취업지원대상자 가산점중 하나만 선택해야 합니다.");
		return;
	}
	//console.log(this.divBaseInfo.form.imgPicture._image);
// 	if(this.divBaseInfo.form.imgPicture._image){
// 		// 사진
// 		var objImg = this.divBaseInfo.form.imgPicture._image
// 		// canvas에 이미지를 옮긴다.
// 		var canvas = document.createElement('canvas');
// 		var ctx = canvas.getContext('2d');
// 		canvas.width = objImg._orgwidth;
// 		canvas.height = objImg._orgheight;
// 		ctx.drawImage(objImg._img_elem.handle,0,0);
// 		// base64데이터를 추출한다.
// 		var base64 = canvas.toDataURL('image/*');	
// 		// base64데이터만 추출("data:image/png,base64,"를 삭제한 순수한 base64부분)
// 		var strOnlyBase64 = base64.replace(/^data:image\/[a-z]+;base64,/,"");
// 		// 사진파일
// 		this.dsMainBase.setColumn(0, 'apstPhotoFileCn', strOnlyBase64 );
// 	}
	
	// 저장
	this.smfSaveService("saveAppoExamAply")
		.validateForm(this.divBaseInfo)
		.validateForm(this.divAcbgInfo)
		.validateForm(this.divExmrInfo)
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors){
				return;
			}
			// 저장이 완료되었습니다.
			this.smfAlert('CM002', [], function(){
				// 응시료 면제  체크 없을경우 초기화
				if(isAechgChk != 'Y'){
					this.dsMainDtl.setColumn(0 ,'rlesVrfcScsYn', 'N' );
					this.dsMainDtl.setColumn(0 ,'rlesRegNo', '');
					this.dsMainDtl.setColumn(0 ,'rlesVrfcCn', ''); 
					this.dsMainStatus.setColumn(0 ,'rlesYn', 'N');
				}
			});
	});	
};

/**
* [버튼클릭] 다음 
* 응시료 면제 여부에따라 접수완료 또는 응시료 결제 페이지로 이동 
*/
this.divSubmitInfo_btnNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	// 개요정보 존재여부
	var useApplpYn = this.dsResultAppoExamCeck.getColumn(0, "useApplpYn");
	if(useApplpYn === 'N' ){
		this.smfAlert("원서 접수가 불가능합니다.");
		return;
	}
	
	// 임용시험유효여부
	var useExamYn = this.dsResultAppoExamCeck.getColumn(0, "useExamYn");
	if(useExamYn === 'N'){
		this.smfAlert("진행중인 임용 시험이 아닙니다.");
		return;
	}

	// 저장여부
	var saveYn  = this.dsMainStatus.getColumn(0, 'saveYn');
	
	// 페이지 타입  new(신규) / modify(수정)
	var viewMode = this.dsMainStatus.getColumn(0, 'viewMode');

	//  등록 모드
	if(viewMode === "new" && saveYn === 'N'){
		this.smfAlert("지원서 저장 후 다음 단계로 이동 가능 합니다. ");
		return;
	}

	// 응시료 면제여부
	var rlesYn = this.dsMainStatus.getColumn(0, "rlesYn");
	// 저소득시험여부
	var smliYn =  this.dsMainBase.getColumn(0, 'smliYn');
	// 결제여부
	var stlmYn =  this.dsMainBase.getColumn(0, 'stlmYn');
	
	if(stlmYn === 'Y'){
		// 응시료 SET
		this.dsMainStatus.setColumn(0, 'aplemAmt', this.dsMainBase.getColumn(0, 'stlmAmt'));
		if(rlesYn ==="Y" ||  smliYn ==="Y"){
				this.dsMainStatus.setColumn(0, 'aplemAmt', "0");
		}
	}
	// 인터넷 접수기간
	var itnRcptYn = this.dsResultAppoExamCeck.getColumn(0, "itnRcptYn");
						
	// PARAM
  	var params = {
  		"dsMainBase" : this.dsMainBase.saveJSON(), // 기본정보
		"dsMainStatus" : this.dsMainStatus.saveJSON(), // 상태
		"dsResultAppoExamCeck" :  this.dsResultAppoExamCeck.saveJSON(), // 임용시험체크
		"rcptQustTelNo" : this.dsResultAppoExamBasic.getColumn(0, 'rcptQustTelNo') // 접수문의번호
		,"rcptQustHrValue" : this.dsResultAppoExamBasic.getColumn(0, 'rcptQustHrValue') // 접수문의시간
  	};
	
	// 수정 모드
	if(viewMode === "modify"  && saveYn === 'N'){
		this.smfConfirm("저장하지 않은 정보는 변경되지 않습니다. \n다음 단계로 이동 하시겠습니까?", function(result){
			if(result.confirmResult){
				if(rlesYn === "Y" || stlmYn === 'Y'){
						// 접수 완료 PAGE
						this.smfSetWorkPage("pa_ore_oew_ar::ore_oewar21_m02.xfdl", params);
				}else{
						// 응시료 결제 PAGE
						this.smfSetWorkPage("pa_ore_oew_ar::ore_oewar21_m01.xfdl", params);
				}
			}
		});
	}else{
			if(rlesYn === "Y" || stlmYn === 'Y'){
					// 접수 완료 PAGE
					this.smfSetWorkPage("pa_ore_oew_ar::ore_oewar21_m02.xfdl", params);
			}else{
					// 응시료 결제 PAGE
					this.smfSetWorkPage("pa_ore_oew_ar::ore_oewar21_m01.xfdl", params);
					return;
			}
	}
};

//이메일 변경시 
this.divBaseInfo_cboEmail2_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	if(e.postvalue == "") {
		//직접입력일경우 
		this.divBaseInfo.form.edtEmail3.set_readonly(false);
		this.divBaseInfo.form.edtEmail3.set_value("");
	}else{
		this.divBaseInfo.form.edtEmail3.set_readonly(true);
		this.divBaseInfo.form.edtEmail3.set_value(e.postvalue);
	}
};

/**
 * 사진업로드 raonk 옵션
 */
this.fnSetRaonPropImg = function()
{
	var objAddRaonProps = {
		ExtensionAllowOrLimit	: "1"        // 업로드 할 파일 확장자를 허용 또는 제한 설정("0":지정된 확장자를 제한(선택 금지) , "1":지정된 확장자만 허용(선택가능))
		, ExtensionArr          : "gif,jpg,png,jpeg" 
		, MaxTotalFileCount 	: "1"	//업로드 할 최대 파일 개수 제한값을 설정합니다.
		, MaxOneFileSize 		: "1024KB"	//업로드할 때 파일당 용량제한을 설정합니다.
	};						  
	return objAddRaonProps;
};

/**
 * 장애인구분 옵션 변경시 후처리 2024. 4. 11. SR00163825
 */
this.divApplpScInfo_cboDltScCd_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	if(obj.value == '0')
	{
		this.divApplpScInfo.form.cboDltClaCd.set_enable(false);
		this.divApplpScInfo.form.cboSedScCd.set_enable(false);
		this.divApplpScInfo.form.cboCnvAply.set_enable(false);
		this.divApplpScInfo.form.edtEtcCnvPvsn.set_enable(false);		
	}
	else
	{
		this.divApplpScInfo.form.cboDltClaCd.set_enable(true);
		this.divApplpScInfo.form.cboSedScCd.set_enable(true);
		this.divApplpScInfo.form.cboCnvAply.set_enable(true);
		this.divApplpScInfo.form.edtEtcCnvPvsn.set_enable(true);			
	}
};

this.divLmttQlflInfo_grdLmttQlfl_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
//	if(e.col == 0)
//	{
//		this.dsResultLmttQlfl.getColumn(e.row,"_chk");
//	}

};
]]></Script>
