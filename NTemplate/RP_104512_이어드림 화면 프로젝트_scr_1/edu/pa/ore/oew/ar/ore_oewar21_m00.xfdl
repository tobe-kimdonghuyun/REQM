    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-지방공무원-지원서 작성-원서 정보 등록
*  @MenuPath    pa_ore_oew_ar
*  @FileName 	pa_ore_oewar21_m00.xfdl
*  @Creator 	최재형
*  @CreateDate 	2022.08.01
*  @Desction    온라인통합채용-지방공무원-지원서 작성-원서 정보 등록
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.08.01    	shhan	 	        최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
// 파라메터 세팅
this.pv_params;

this.m_applpRrno;
this.m_applpFlnm;
this.m_mblTelno;

//2023.08.30 파일업로드 성공시에만 이미지 변경되도록 수정
this.sImageType       = "";
this.sImageFileName   = "";   // 선택된 파일이름
this.sImageDataBase64 = "";
this.sImageDataBase64Reduce = "";
this.lmttQlflDetail = true;//JSF_20250210

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{	
	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);
	
	// 본인인증 세션취득
	this.m_applpRrno = nexacro.base64Decode(this.smfGetSessionValue('userRrno'));
	this.m_applpFlnm = this.smfGetSessionValue('userNm');
	this.m_mblTelno = this.smfGetSessionValue('mblTelNo');

	// parameters
	this.pv_params = this.smfGetFormParams();
	
	// 공통코드 조회
	// dsComAcbgCd:학력코드, dsComDltScCd:장애코드, dsComDltClaCd:장애정도, dComsDltClaCd:중증도, dsComCnvAplyCd:편의사항, dsComRlesScCd : 응시료면제구분
	this.smfCodeList("code", [this.dsComAcbgCd, this.dsComDltScCd, this.dsComDltClaCd, this.dsComSedScCd, this.dsComCnvAplyCd, this.dsComRlesScCd, this.dsComBankCd])
		.callback(function(callbackParams){
			if(callbackParams.errors){
				return;
			}

			// 페이지 타입  new(신규) / modify(수정)
			var viewMode = this.pv_params.viewMode;
			// 초기화
			this.dsMainStatus.clearData();
			this.dsMainStatus.addRow();
			// 처리모드 SET
			this.dsMainStatus.setColumn(0,'viewMode', viewMode);
			// 저장여부 SET
			this.dsMainStatus.setColumn(0,'saveYn', 'N');
			// 면제여부 SET
			this.dsMainStatus.setColumn(0,'rlesYn', 'N');
			// 응시료 SET
			this.dsMainStatus.setColumn(0, 'aplemAmt', "0");

			
			// 수정 모드
			if(viewMode === "modify" ){
				// 접수번호
				var rcptNo = this.pv_params.rcptNo;
				// 접수번호 SET
				this.dsMainStatus.setColumn(0,'rcptNo', rcptNo);
				// 수정모드 데이터
				this.fnInitModifyModeData();		

			// 등록 모드 
			}else{
				// 등록모드 기본 데이터 SET
				this.fnInitNewModeData();
			}
		}).run();
		
	// 파일 업로드 -- 지원자 사진파일
	this.divFileUpload.UPLOAD_UploadComplete  = this.fnEventUploadComplete;
	this.divFileUpload.UPLOAD_OnError         = this.fnEventUploadError;
	this.divFileUpload.UPLOAD_AfterAddFile    = this.fnEventUploadAfterAddFile;     
	this.divFileUpload.UPLOAD_Form            = this;
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 
// 콜백
this.fnTransCallback = function(svcid, errcd, errmsg){
}

/**
* 사진 업로드 콜백
**/
this.fnPopupCallback = function(e, sender){
	// TODO  사진  처리 START
	// 업무콜백 처리
	//this.smfAlert("응답결과 ==>"+e.row.Column0+", "+e.row.Column1+", "+e.row.Column2+", "+e.row.Column3);
	// TODO  증명사진  처리 END
	
	//trace("====>fnPopupCallback");
	//2023.08.30 파일업로드 성공시에만 이미지 변경되도록 수정
	sImageType       = "";
	sImageFileName   = "";   // 선택된 파일이름
	sImageDataBase64 = "";
	sImageDataBase64Reduce = "";
	
	if(e.imageInfo)
	{
		sImageType       = e.imageInfo.imageType;   // 이미지 타입(image/png)
		sImageFileName   = e.imageInfo.imageFileName;   // 파일이름(test.png)
		// 사진파일 특수 문자 확인 
		var fileExtension = sImageFileName.substring(sImageFileName.lastIndexOf(".")); // 파일 확장자 
		var fileName = sImageFileName.split(fileExtension); // 파일명. 확장자 분리 
		/*var fileName = sImageFileName.split(/.png|.PNG|.jpg|.JPG|.JPEG|.jpeg|.bmp|.BMP/);*/
		var sMatch = fileName[0].match(/[\.\/\,\~\!\@\#\$\%\^\&\(\)\+\-\']/); // 파일명 특수문자 확인
		if ( sMatch != null)
		{
			this.smfAlert("사진 파일 이름에 특수 문자가 있습니다.");
			return;
		}
		sImageDataBase64 = e.imageInfo.imageDataBase64;  // BASE64의 이미지 파일
		sImageDataBase64Reduce = 	e.imageInfo.imageDataBase64Reduce; // BASE64의 이미지 파일(품질축소)
		
//2023.08.30 파일업로드 성공시에만 이미지 변경되도록 수정
// 		if(!this.smfIsNull(sImageDataBase64))
// 		{
// 			this.divBaseInfo.form.imgPicture._imagetype = sImageType; 
// 			this.divBaseInfo.form.imgPicture._imagename = sImageFileName; 
// 			// 이미지 용량 작은 데이터 SET
// 			if(sImageDataBase64.length > sImageDataBase64Reduce.length){
// 				this.divBaseInfo.form.imgPicture.set_image(sImageDataBase64Reduce);
// 			}else{
// 				this.divBaseInfo.form.imgPicture.set_image(sImageDataBase64);
// 			}
// 			this.divBaseInfo.form.imgPicture.set_text("");
// 		}
	}
	
//2023.08.30 파일업로드 성공시에만 이미지 변경되도록 수정
// 	var sBase64Data = this.divBaseInfo.form.imgPicture.image;
// 	this.divFileUpload.form.fnResetUpload();
// 	this.divFileUpload.form.fnFileUploadWithBase64(sBase64Data, sImageFileName);
	this.divFileUpload.form.fnResetUpload();
	// 이미지 용량 작은 데이터 SET
	if(sImageDataBase64.length > sImageDataBase64Reduce.length){
		this.divFileUpload.form.fnFileUploadWithBase64(sImageDataBase64Reduce, sImageFileName);
	}else{
		this.divFileUpload.form.fnFileUploadWithBase64(sImageDataBase64, sImageFileName);
	}
	
};

/**
* 파일 업로드 성공 콜백(사진)
**/
this.fnEventUploadComplete = function(obj, paramObj, objResultDataset)
{
	//2023.08.30 파일업로드 성공시에만 이미지 변경되도록 수정
	if(!this.smfIsNull(sImageDataBase64))
	{
		this.divBaseInfo.form.imgPicture._imagetype = sImageType; 
		this.divBaseInfo.form.imgPicture._imagename = sImageFileName; 
		// 이미지 용량 작은 데이터 SET
		if(sImageDataBase64.length > sImageDataBase64Reduce.length){
			this.divBaseInfo.form.imgPicture.set_image(sImageDataBase64Reduce);
		}else{
			this.divBaseInfo.form.imgPicture.set_image(sImageDataBase64);
		}
		this.divBaseInfo.form.imgPicture.set_text("");
	}

	this.divFileUpload.form.fnSetUploadCompleteState(obj,paramObj);
	this.dsMainBase.setColumn(0, "photoRefrnId", objResultDataset.getColumn(0, "fileRefrnId"));
	this.dsMainBase.setColumn(0, "apstPhotoFileNm", objResultDataset.getColumn(0, "atchFileNm"));
}

 /**
 * 주소찾기 콜백
 */
this.fnCommpopRdnZip = function(e, sender){
	// 우편번호
	var zipCd = e.zipCd;
	// 도로명주소
	var roadNmAddr = e.roadNmAddr;
	// 구주소
	var lotnoAddr = e.lotnoAddr
	// 주소상세
	var roadNmDtl = e.roadNmDtl;
	
	
	// 우편번호 정보 
	if(zipCd === ""){
		zipCd = "00000";
	}
	
	// 우편번호 SET
	this.divBaseInfo.form.edtPostCode.set_value(zipCd);
	// 주소 SET
	this.divBaseInfo.form.edtAddr.set_value(roadNmAddr);
	// 주소상세 SET
	this.divBaseInfo.form.edtAddrDtl.set_value(e.roadNmDtl);
	
	// 제한지역 체크
	this.fnCeckLmttDsTrt();
};

/**
 * 가산점 추가 팝업 콜백
 */
this.fnAdtnAddModalCallback = function(e, sender){	
	// 팝업 콜백 결과
	var adtn = e.row;
	// 그리드 ROW ADD
	var idx = this.dsMainAdtn.addRow();
 	this.dsMainAdtn.setColumn(idx, 'adtnCd', adtn.adtnCd); // 가산코드
 	this.dsMainAdtn.setColumn(idx, 'adtnSpeclRuleScCd', adtn.adtnSpeclRuleScCd); // 가산특별규칙구분코드
 	this.dsMainAdtn.setColumn(idx, 'adtnSpeclRuleScNm', adtn.adtnSpeclRuleScNm); // 가산특별규칙구분명
 	this.dsMainAdtn.setColumn(idx, 'adtnClfCd', adtn.adtnClfCd); // 가산분류코드
 	this.dsMainAdtn.setColumn(idx, 'adtnClfNm', adtn.adtnClfNm); // 가산분류명
 	this.dsMainAdtn.setColumn(idx, 'grtTrgtCn', adtn.grtTrgtCn); // 부여대상내용
 	this.dsMainAdtn.setColumn(idx, 'adtnMetCd', adtn.adtnMetCd); // 가산방식코드
 	this.dsMainAdtn.setColumn(idx, 'adtnRto', adtn.adtnRto); // 가산비율
	this.dsMainAdtn.setColumn(idx, 'appoExamAdtnScr', adtn.appoExamAdtnScr); // 가산비율
 	this.dsMainAdtn.setColumn(idx, 'adtnScoreTxt', adtn.adtnScoreTxt); // 가산비율
 	this.dsMainAdtn.setColumn(idx, 'qlflNo', adtn.qlflNo); // 자격번호
 	this.dsMainAdtn.setColumn(idx, 'issuInstNm', adtn.issuInstNm); // 발급기관
 	this.dsMainAdtn.setColumn(idx, 'issuYmd', adtn.issuYmd); // 발급일
 	this.dsMainAdtn.setColumn(idx, 'fileRefrnId', adtn.fileRefrnId); // 파일참조아이디
 	this.dsMainAdtn.setColumn(idx, 'fileRefrnNm', adtn.fileRefrnNm); // 파일명일
 	this.dsMainAdtn.setColumn(idx, 'instVrfcScsYn', adtn.instVrfcScsYn); // 검증결과여부
 	this.dsMainAdtn.setColumn(idx, 'vrfcRltCn', adtn.vrfcRltCn); // 검증결과내용
	
	//console.log("====가산점 추가 결과===");
	//console.log(this.dsMainAdtn.saveJSON());

};


/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 개요 상세 검색
 */
this.fnSearchAppoExamDetail = function(obj, e)
{
	/** 조회조건**/
	// 시도코드
	this.dsSearch.setColumn(0, 'cddcCd', this.smfGetCddcCode());
	// 임용시험ID
	this.dsSearch.setColumn(0, 'appoExamId', this.dsMainBase.getColumn(0, 'appoExamId'));
	// 직류코드
	this.dsSearch.setColumn(0, 'ocptyCd', this.dsMainBase.getColumn(0, 'ocptyCd'));
	// 직급코드
	this.dsSearch.setColumn(0, 'jbgdCd', this.dsMainBase.getColumn(0, 'jbgdCd'));
	
	// 개요 상세 조회
	this.smfSearchService('selectAppoExamDetail') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) {
				return;
			}
			//20240419 - 원인불명 아래 두 데이터셋은 필수적으로 내용이 존재해야만 하는 데이터셋이다.
			if(this.dsResultAppoExam.getRowCount() == 0 || this.dsResultAppoExamBasic.getRowCount() == 0)
			{
				window.location.reload();
				return; 
			}

			// 서브 타이틀 동적 SET
			this.fnInitSubTitle();
			
			// 원서접수 기간에 따른 DIV CHECK처리
			this.fnInitDivCeck();
			
			// 접수문의 영역 초기화
			this.fnInitInquiryData();
			
			// DIV 처리
			this.fnInitDiv();
			
			// 제한자격 체크박스 동적 생성
			this.fnInitLmttQlflCheckbox();
			
			//JSF_20250210
			//아래 소스 확인 필요
			if(this.lmttQlflDetail)
			{	
				this.divLmttQlflInfo.form.staTltLmttQlfl.set_visible(false);
				this.divLmttQlflInfo.form.sdivLmttQlfl.set_visible(false);
				this.divLmttQlflInfo.form.grdLmttQlfl.set_visible(true);	
			}
			else
			{
				this.divLmttQlflInfo.form.staTltLmttQlfl.set_visible(true);
				this.divLmttQlflInfo.form.sdivLmttQlfl.set_visible(true);
				this.divLmttQlflInfo.form.grdLmttQlfl.set_visible(false);
			}
			
			// 응시료 면제영역 초기화
			this.fnInitDivAechg();
			
			this.divApplpScInfo_cboDltScCd_onitemchanged(this.divApplpScInfo.form.cboDltScCd,null);//2024. 4. 11. SR00163825
			// 페이지 타입  new(신규) / modify(수정)
			if(this.pv_params.viewMode === 'modify'){
				// 제한지역 체크
				this.fnCeckLmttDsTrt();
			}
	});
};

/**
 * 지원서 정보 조회 : 수정 모드에서만 호출(viewMode ='modif')
 */
this.fnSearchAdfInfo = function(obj, e)
{
	/** 조회조건**/
	this.dsSearch.setColumn(0, 'rcptNo', this.dsMainStatus.getColumn(0, 'rcptNo')); // 접수번호
	
	// 지원서 정보 조회
	this.smfSearchService('selectApf') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) {
				return;
			}
			//이메일
			var emlAddr = this.dsMainBase.getColumn(0,"emlAddr").split("@");
			this.dsMainBase.setColumn(0, "emlAddr1", emlAddr[0]);	
			this.dsMainBase.setColumn(0, "emlAddr2", emlAddr[1]);	
			this.dsMainBase.setColumn(0, "emlAddr3", emlAddr[1]);	
			if(this.divBaseInfo.form.cboEmail2.index == -1){
				this.dsMainBase.setColumn(0, "emlAddr2", "");	 //직접입력
			}
			
			// 사진 set (413 error : request entity too large 해결 )
			if(!this.smfIsNull(this.dsMainBase.getColumn(0,"apstPhotoFileCn"))){
				this.divBaseInfo.form.imgPicture.set_image(this.dsMainBase.getColumn(0, "apstPhotoFileCn"));
				this.divBaseInfo.form.imgPicture.set_stretch('fit');
				this.divBaseInfo.form.imgPicture.set_text('');
				this.dsMainBase.setColumn(0, "apstPhotoFileCn", "");
			}else{
				this.divBaseInfo.form.imgPicture.set_image("");
			}
			// 개요상세 API 조회
			this.fnSearchAppoExamDetail();
	});
};

/**
* SCI 실명인증정보 취득
*/
this.fnSearchSciCert = function(obj, e)
{

	this.dsSearch.setColumn(0, 'applpRrno' , this.dsMainBase.getColumn(0, 'applpRrno'));
	this.dsSearch.setColumn(0, 'applpFlnm' , this.dsMainBase.getColumn(0, 'applpFlnm'));
	// 실명인증정보 취득
	this.smfSearchService('selectSciCert') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) {
				return;
			}
	});
}

/**
* 실명인증 +공공마이데이터 취득
*/
this.fnSearchMyData = function(type)
{	
	this.dsSearch.setColumn(0, 'applpRrno' , this.dsMainBase.getColumn(0, 'applpRrno'));// 주민번호
	this.dsSearch.setColumn(0, 'applpFlnm' , this.dsMainBase.getColumn(0, 'applpFlnm')); //이름
	// 실명인증 정보가 없을 경우 실명 인증후 마이데이터 취득
	var sicCnt = this.dsResultSciCert.getRowCount();
	if(sicCnt <1 ){
		// 실명인증정보 취득
		this.smfSearchService('selectSciCert') 
			.run()
			// 콜백
			.callback(function(callbackParams){
				if(callbackParams.errors) {
					return;
				}
				// SCI실명인증-결과 코드 (정상 000)
				var sciCode = this.dsResultSciCert.getColumn(0, 'sciCode')
				// SCI실명인증-결과 메세지 (정상 1)
				var sciMsg = this.dsResultSciCert.getColumn(0, 'sciMsg')
				if(sciCode === '000' && sciMsg === '1'){
					// CID
					 this.dsSearch.setColumn(0, 'userCid' , this.dsResultSciCert.getColumn(0, 'userCid'));
				}
				// 마이데이터 조회
				this.fnSearchBundleMyData(type);
		});
	}else{
		
		// 마이데이터 묶음정보가 없으면
		if(this.dsResultMyDataVrfc.getRowCount() < 1 ){
			// CID
			this.dsSearch.setColumn(0, 'userCid' , this.dsResultSciCert.getColumn(0, 'userCid'));
			// 조회
			this.fnSearchBundleMyData(type);
		}else{
			// 한부모 가정은 번호 입력, 미검증시 재조회
			var sptFamYn = this.dsResultMyDataVrfc.getColumn(0,'sptFamYn');
			if(type === 'sptFam' && sptFamYn ==='N' ){
				// CID
				this.dsSearch.setColumn(0, 'userCid' , this.dsResultSciCert.getColumn(0, 'userCid'));
				// 조회
				this.fnSearchBundleMyData(type);
			}else{
				// 결과
				this.fnResultMyData(type);
			}
		}
	}
}
/**
* 공공마이데이터 묶음정보 취득
*/
this.fnSearchBundleMyData = function(type)
{	
	// 공공마이데이터 묶음정보 조회
	this.smfSearchService('selectMyData') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) {
				return;
			}
			//console.log(this.dsResultMyDataQlfl.saveJSON());
			// 검증결과
			this.fnResultMyData(type);
	});
}

/**
* 공공마이데이터 묶음정보 검증 결과
*/
this.fnResultMyData = function(type)
{	
	// 검증여부
	var isVrfc = false;
	// 검증번호
	var rlesRegNo="";
		
	// 한국산업인역공단 취득 자격 검증 결과
	if(type === 'qlfl' ){	
		var qlflYn = this.dsResultMyDataVrfc.getColumn(0,'qlflYn');
		if(qlflYn != 'Y'){
			//this.smfAlert('한국산업인력공단 취득 자격 정보가 없습니다.');
			//return;
		}
	
		// popup param
		var popupParams = {
			callback: this.fnAdtnAddModalCallback, // 콜백함수 지정
			sender: obj, // sender 지정
				params: {
					procType: 'none', // 처리타입 지정
					qlflModeYn: 'Y', // 가산특별규칙구분코드 =4 ( 한국산업인력공단(국가기술자격)분야) 모드
					dsResultJbgdAdtn: this.dsResultJbgdAdtn.saveJSON(),
					dsResultMyDataQlfl: this.dsResultMyDataQlfl.saveJSON(),
					myQlflCnt: this.dsResultMyDataQlfl.rowcount
				},
		};
		//  공공 마이데이터  한국산업인력공단(국가기술자격)분야 검증 전용 모달팝업 실행
		this.smfDialog("_auto", "pa_ore_oew_ar::ore_oewar21_p02.xfdl", popupParams);
	}
}


