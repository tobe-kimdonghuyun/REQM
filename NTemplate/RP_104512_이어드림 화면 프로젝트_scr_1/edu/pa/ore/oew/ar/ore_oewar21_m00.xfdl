/**
 * 등록모드 기본 데이터
 **/
 this.fnInitNewModeData = function(){
 	// 시도교육청코드
	var cddcCd = this.smfGetCddcCode();
	this.dsMainBase.clearData();
	this.dsMainBase.addRow();
							
	// 이미지
	this.divBaseInfo.form.imgPicture.set_text('사진규격 \n 3.6cm*4.6cm');
	//  본인인증 정보 START
	this.dsMainBase.setColumn(0, 'applpFlnm', this.m_applpFlnm); //응시자성명
	this.dsMainBase.setColumn(0, 'applpRrno', this.m_applpRrno); //응시자주민등록번호
	// 휴대전화를 이용한 본인인증의경우
	if(!this.smfIsNull(this.m_mblTelno)){
		var mblTelnoArr= this.m_mblTelno.split('-');
		this.dsMainBase.setColumn(0, 'mblTelno', this.m_mblTelno); //휴대전화번호
		this.dsMainBase.setColumn(0, 'mblTelno1', mblTelnoArr[0]); //휴대전화번호1
		this.dsMainBase.setColumn(0, 'mblTelno2', mblTelnoArr[1]); //휴대전화번호2
		this.dsMainBase.setColumn(0, 'mblTelno3', mblTelnoArr[2]); //휴대전화번호3
	}
	//  본인인증 정보 END
		
	this.dsMainBase.setColumn(0, 'cddcScCd', cddcCd.slice(0,3)); // 시도교육청코드
	this.dsMainBase.setColumn(0, 'onlEmpmnExamScCd', 3); //온라인채용시험구분코드 3 지방공무원
	this.dsMainBase.setColumn(0, 'appoExamId', this.pv_params.appoExamId); //임용시험ID
	this.dsMainBase.setColumn(0, 'appoExamNm', this.pv_params.appoExamNm); //임용시험명
	this.dsMainBase.setColumn(0, 'ocptyCd', this.pv_params.ocptyCd);//직류코드
	this.dsMainBase.setColumn(0, 'ocptyNm', this.pv_params.ocptyNm); //직류명
	this.dsMainBase.setColumn(0, 'jblnCd', this.pv_params.jblnCd); //직렬코드
	this.dsMainBase.setColumn(0, 'jblnNm', this.pv_params.jblnNm); //직렬명
	this.dsMainBase.setColumn(0, 'jbgdCd', this.pv_params.jbgdCd); //직급코드
	this.dsMainBase.setColumn(0, 'jbgdNm', this.pv_params.jbgdNm); //직급명
	this.dsMainBase.setColumn(0, 'rksCd', this.pv_params.rksCd); //계급코드
	this.dsMainBase.setColumn(0, 'rksNm', this.pv_params.rksNm); //계급명
		
	// 장애인구분 콤보 디폴트값  : 장애아님
	this.divApplpScInfo.form.cboDltScCd.set_value('0');
	// 장애인등급 콤보 디폴트값 : 장애아님
	this.divApplpScInfo.form.cboDltClaCd.set_value('09');
	// 중증외 콤보 디폴트값 : 해당없음
	this.divApplpScInfo.form.cboSedScCd.set_value('0');
	
	// 개요상세 API 조회
	this.fnSearchAppoExamDetail();
	
 }
 
/**
 * 수정모드 기본 데이터
 **/
 this.fnInitModifyModeData = function(){

 	// 지원서 상세 조회
	this.fnSearchAdfInfo();

 }
 
 /**
 * 조건별 영역 비표시  가변 처리
 **/
 this.fnInitDiv = function(){
  
	// 저소득 시험 메세지 영역
 	var smliYn = this.dsResultAppoExam.getColumn(0 , 'smliYn');
	this.dsMainBase.setColumn(0, 'smliYn', smliYn);
	this.dsMainStatus.setColumn(0 ,'smliYn', smliYn);
	if(smliYn === "Y"){
		// 저소득 시험 메세지 표시
		this.divBaseInfo.form.staSmliMsg.set_visible(true);
		// 결제여부
		var stlmYn =  this.dsMainBase.setColumn(0, 'stlmYn', 'Y');
		// 응시료 면제 영역 숨김
		this.divAechgInfo.setOffsetHeight(0);
		// 응시료 면제 영역 비표시
		this.divAechgInfo.set_visible(false);
	}
 
	// 제한 자격 DIV 영역 체크
	var lmttQlflCnt = this.dsResultLmttQlfl.getRowCount();
	//console.log("제한자격건수 : " + lmttQlflCnt);
	// 제한자격이 없을경우
	if(lmttQlflCnt === 0){
		// 제한자격영역 숨김
		this.divLmttQlflInfo.setOffsetHeight(0);
		// 제한자격영역 비표시
		this.divLmttQlflInfo.set_visible(false);
	}

	// 시험장  DIV 영역 체크
	var exmrCnt = this.dsResultExmr.getRowCount();
	// 시험장이 없을경우
	if(exmrCnt === 0 ){
		// 시험장영역 숨김
		this.divExmrInfo.setOffsetHeight(0);
		// 시험장영역 비표시
		this.divExmrInfo.set_visible(false);
	}
	// 가산점 수정기간일 경우 시험장 영역 숨김
	var adpnRcptRtrcnYn = this.dsResultAppoExamCeck.getColumn(0,"adpnRcptRtrcnYn");
	// 가산점 수정기간일 경우
	if(adpnRcptRtrcnYn === 'Y'){
		// 시험장영역 숨김
		this.divExmrInfo.setOffsetHeight(0);
		// 시험장영역 비표시
		this.divExmrInfo.set_visible(false);
	}
	
	// 가산점 영역 DVI 사용여부 체크
	var adpnUseYn = this.dsResultAppoExamBasic.getColumn(0, "adpnUseYn");
	// 가산점 설정값
	var adpnCnt =  this.dsResultJbgdAdtn.getRowCount();
	//console.log("가산점사용여부 : " + adpnUseYn)
	// 가산점 사용 설정이 아니거나 가산점 세팅이 없을경우
	if(adpnUseYn != "Y"  ||  adpnCnt < 1){
		// 가산점영역 숨김
		this.divAdtnInfo.setOffsetHeight(0);
		// 가산점영역 비표시
		this.divAdtnInfo.set_visible(false);
	}else{
		
		// 가산점 추가 버튼 표시,비표시 처리
		// 한국산업인력공단 자격 외  (adtnSpeclRuleScCd !=4) Count
		var glflAdtnIgnoreCnt = this.dsResultJbgdAdtn.getCaseCount("adtnSpeclRuleScCd != '4'")
		if(glflAdtnIgnoreCnt > 0){
			this.divAdtnInfo.form.btnAdtnAdd.set_visible(true);
		}else{
			this.divAdtnInfo.form.btnAdtnAdd.set_visible(false);
		}
		// 한국산업인력공단 자격 버튼 표시,비표시
		var glflAdtnCnt = this.dsResultJbgdAdtn.getCaseCount("adtnSpeclRuleScCd == '4'")
		if(glflAdtnCnt > 0){
			this.divAdtnInfo.form.btnQlflAdd.set_visible(true);
		}else{
			this.divAdtnInfo.form.btnQlflAdd.set_visible(false);
		}
	}
	
	
	// 전체영역  RESET
	this.smfResetScroll(this);
 }

this.fnInitDivCeck = function(){

	// 사진필수여부에 따른 필수 표시
	var photoEsntlYn = this.dsResultAppoExamBasic.getColumn(0, 'photoEsntlYn'); 
	if(photoEsntlYn === 'Y'){
		this.divBaseInfo.form.btnPicture.set_cssclass('btn_WF_FunctionRed');
	}else{
		this.divBaseInfo.form.btnPicture.set_cssclass('btn_WF_Function');
	}

	// 개요정보 존재여부
	var useApplpYn = this.dsResultAppoExamCeck.getColumn(0, "useApplpYn");
	// 임용시험유효여부
	var useExamYn = this.dsResultAppoExamCeck.getColumn(0, "useExamYn");
	if(useApplpYn != 'Y' || useExamYn != 'Y'){
		// 기본정보 영역
		this.divBaseInfo.set_enable(false);
		// 학력정보 영역
		this.divAcbgInfo.set_enable(false);
		// 제한자격 영역
		this.divLmttQlflInfo.set_enable(false);
		// 응시자구분 영역
		this.divApplpScInfo.set_enable(false);
		// 시험장 영역
		this.divExmrInfo.set_enable(false);
		// 응시료면제 영역
		this.divAechgInfo.set_enable(false);
		// 가산점 영역
		this.divAdtnInfo.set_enable(false);
	}else{
		 // 인터넷 접수기간
		var itnRcptYn = this.dsResultAppoExamCeck.getColumn(0, "itnRcptYn");
		if(itnRcptYn != 'Y' ){
			// 기본정보 영역
			this.divBaseInfo.set_enable(false);
			// 학력정보 영역
			this.divAcbgInfo.set_enable(false);
			// 제한자격 영역
			this.divLmttQlflInfo.set_enable(false);
			// 응시자구분 영역
			this.divApplpScInfo.set_enable(false);
			// 시험장 영역
			this.divExmrInfo.set_enable(false);
			// 응시료면제 영역
			this.divAechgInfo.set_enable(false);
			
			// 가산점 수정기간
			var adpnRcptRtrcnYn = this.dsResultAppoExamCeck.getColumn(0, "adpnRcptRtrcnYn");
			// 가산점 사용 + 가산점 수정 기간일 경우
			if(adpnRcptRtrcnYn === 'Y' ){
				this.divAdtnInfo.set_enable(true);
			}else{
				// 가산점 영역
				this.divAdtnInfo.set_enable(false);
			}
		}
	}
}
 /**
 * 서브타이틀 SET  개요/ 직렬/계급
 **/
 this.fnInitSubTitle = function(){
 	// 동의화면에서 선택한 시험명, 직렬, 계급 SET
 	this.divSubTitle.form.staSubTlite00.set_text(this.dsMainBase.getColumn(0, 'appoExamNm'));
	this.divSubTitle.form.staSubTlite01.set_text(this.dsMainBase.getColumn(0, 'jblnNm'));
	this.divSubTitle.form.staSubTlite02.set_text(this.dsMainBase.getColumn(0, 'rksNm'));
 }
 
 /**
 * 응시료면제  영역 초기화
 **/
 this.fnInitDivAechg = function(){
 
	this.divAechgInfo.form.staContent00.set_enable(false); // 응시료면제 라디오 타이틀
	this.divAechgInfo.form.rdoRlesScCd.set_enable(false); // 응시료 면제 라디오 비활성
		
	//  면제 확인 후 환불영역 비활성
	this.divAechgInfo.form.divContent03.set_enable(false);
	
	//  모드 new(신규) / modify(수정)
	var viewMode = this.dsMainStatus.getColumn(0, 'viewMode');
	// 신규
	if(viewMode === 'new'){
		// 응시료 면제 라디오 기본값 : 기초생활수급법상  수급자 -> 미선택으로 (SR00158516)
		this.divAechgInfo.form.rdoRlesScCd.set_index(-1);
	}
	
	// 응시료 면제 검증 여부
	var rlesVrfcScsYn = this.dsMainDtl.getColumn(0, 'rlesVrfcScsYn');
	if(rlesVrfcScsYn === 'Y'){
		this.dsMainStatus.setColumn(0 ,'rlesYn', 'Y');
	}else{
		this.dsMainStatus.setColumn(0 ,'rlesYn', 'N');
	}

	// 수정
	if(viewMode === 'modify'){
		// 응시료 면제 구분코드
		var rlesScCd = this.dsMainDtl.getColumn(0, 'rlesScCd');
		// 면제자 설정값이 있을 경우 화면 처리
		if(rlesScCd != "00"){
			this.divAechgInfo.form.chkAechg.set_value("Y"); // 응시료 면제 체크박스 ON
			this.divAechgInfo.form.rdoRlesScCd.set_enable(true); // 응시료 면제 라디오활성
			this.divAechgInfo.form.staContent00.set_enable(true); // 응시료면제 라디오 타이틀
			this.divAechgInfo.form.divContent03.set_enable(true); // 환불정보 활성
		}
		else
		{
			this.divAechgInfo.form.divContent03.set_enable(false); // 환불정보 활성
		}
	}
	
	// 결제 완료 일경우
	var stlmYn =  this.dsMainBase.getColumn(0, 'stlmYn');
	if(stlmYn === 'Y'){
		// 응시료면제 전체 영역 비활성
		this.divAechgInfo.set_enable(false);
	}
 }
 
/**
 * 제한지역(응시가능지역) 체크
 **/
 this.fnCeckLmttDsTrt = function(){
	// 개요에 설정된 제한지역 설정 건수
	var lmttCnt = this.dsResultLmttDsTrt.getRowCount();
	// 제한지역 설정이 없을경우
	if(lmttCnt < 1){
		// 응시제한지역 메세지 비표시
		this.divBaseInfo.form.staLmttDsTrsMsg.set_visible(false);
	}else{
		// 선택 우편번호
		var sPostCd = this.divBaseInfo.form.edtPostCode.value;
		// 선택 우편번호 앞 3자리
		var sLmttZipCd = sPostCd.slice(0,3);
		// 제한지역 (응시가능지역) 
		for(var i=0;i<this.dsResultLmttDsTrt.getRowCount();i++){
			// 개요 설정 제한지역
			var lmttZipCd    = this.dsResultLmttDsTrt.getColumn(i,"zipCode"); 
			// 선택 우편번호가 제한지역에 포함된 지역일 경우
			if(sLmttZipCd === lmttZipCd){
				// 응시제한지역 메세지 비표시
				this.divBaseInfo.form.staLmttDsTrsMsg.set_visible(false);
				return;
			}
		}
		// 응시제한지역 메세지 표시
		//20240401 -  불필요문구 this.divBaseInfo.form.staLmttDsTrsMsg.set_visible(true);
	}
}

 
/**
 * 제한자격증 체크박스 동적 생성
 **/
 this.fnInitLmttQlflCheckbox = function(){
 	
	// 제한 자격증 체크박스 동적 생성
	var objOption = {
		blockcount : 4  // 몇개의 block으로 나눌지 같은폭으로 생성
		, blockgap : 1  // 블럭사이의 Gap(pixel)
		, height : 35
		, leftgap : 5
		, heightgap : 5
	};
	this.fnCreateCheckbox(this.divLmttQlflInfo.form.divLmttQlfl,this.dsResultLmttQlfl,objOption);
	// 동적 생성후 해당 Div 스크롤 Reset
	this.divLmttQlflInfo.form.divLmttQlfl.form.resetScroll();
 }
 
 /**
 * 체크박스 동적 생성
 */
 this.fnCreateCheckbox = function(divComp:nexacro.Div,dsList:nexacro.NormalDataset,objOption)
{
	// 나중을 위해 설정 값 저장
	divComp._option = objOption;

	var sCheckboxIdPrefix = "chkQlflIdf_";
	var sCheckboxId="";
	var oCheckbox=null;
	
	// 기본 설정
	var nBlockCount = this.smfNvl(objOption.blockcount,1 );  // 지정이 없으면 1
	var nBlockGap   = this.smfNvl(objOption.blockgap  ,10);  // 지정이 없으면 10
	var nLeftGap    = this.smfNvl(objOption.leftgap   ,10);  // 지정이 없으면 10
	var nHeight     = this.smfNvl(objOption.height    ,30);  // 지정이 없으면 30
	var nHeightGap  = this.smfNvl(objOption.heightgap ,10);  // 지정이 없으면 10
	var nWidth = parseInt((divComp.getOffsetWidth()
			   - ((nBlockCount-1)*nBlockGap) - nLeftGap)/nBlockCount);
	for(var i=0;i<dsList.rowcount;i++)
	{
		// Text값을 데이터셋에서 가져옴.
		var sQlflIdfCd    = dsList.getColumn(i,"qlflIdfCd");  // 자격증식별코드
		var sQlflIdfValue = dsList.getColumn(i,"qlflIdfValue");  // 자격증식별값
		
		// 해당오브젝트를 구한다.
		sCheckboxId = sCheckboxIdPrefix+i;
		oCheckbox = divComp[sCheckboxId];
		
		// 위치를 계산
		var nBlockIdx = i%nBlockCount;
		var nLeft = nLeftGap + (nBlockIdx*nWidth) + (nBlockIdx*nBlockGap);
		var nTop = parseInt(i/nBlockCount) * nHeight;
		
		if(!oCheckbox)
		{
			oCheckbox = new CheckBox(sCheckboxId,nLeft,nTop,nWidth,nHeight);
			divComp.addChild(sCheckboxId,oCheckbox);
			oCheckbox.show();
		}
		else
		{
			// 이미 만들어져 있는 경우 
			oCheckbox.move(nLeft,nTop,nWidth,nHeight);			
			oCheckbox.set_visible(true);
		}
		oCheckbox.set_value(false);
		oCheckbox._qlflIdfCd = sQlflIdfCd;
		oCheckbox.set_text(sQlflIdfValue);
	}	
	
	//  모드 new(신규) / modify(수정)
	var viewMode = this.dsMainStatus.getColumn(0, 'viewMode');
	
	// 수정 모드의 경우 체크 박스 체크 처리
	if(viewMode === 'modify'){
		//JSF_20250210
		if(this.lmttQlflDetail)
		{
			for(var j=0;j<this.dsMainLmttQlfl.rowcount;j++){
				for(var i=0;i<this.dsResultLmttQlfl.rowcount;i++){
					if(this.dsResultLmttQlfl.getColumn(i,"qlflIdfCd").trim() == this.dsMainLmttQlfl.getColumn(j,"qlflIdfCd" ))
					{
						this.dsResultLmttQlfl.setColumn(i,"_chk"         ,"1");
						this.dsResultLmttQlfl.setColumn(i,"qlflNo"       ,this.dsMainLmttQlfl.getColumn(j,"qlflNo"));
						this.dsResultLmttQlfl.setColumn(i,"issuInstNm"   ,this.dsMainLmttQlfl.getColumn(j,"issuInstNm"));
						this.dsResultLmttQlfl.setColumn(i,"issuYmd"      ,this.dsMainLmttQlfl.getColumn(j,"issuYmd"));
					}
				}
			}
		}
		else
		{
			// 선택한 자격증 식별 코드 LOOP
			for(var j=0;j<this.dsMainLmttQlfl.rowcount;j++){
				// 동적 생성된 체크박스 컴포넌트
				var arrComps = this.divLmttQlflInfo.form.divLmttQlfl.form.components;
				// 전체 체크박스 LOOP
				for(var i=0;i<arrComps.length;i++){
					var objComp = arrComps[i];
					// 선택 자격증식별코드
					var myQlflIdfCd   = this.dsMainLmttQlfl.getColumn(j,"qlflIdfCd" );
					// 전체 자격증식별코드
					var allQlflIdfCd   = objComp._qlflIdfCd.trim();
					// 선택된 자격증 식별코드를 전체 체크박스의 해당하는 항목에 체크처리
					if(allQlflIdfCd=== myQlflIdfCd){
						// 체크처리
						objComp.set_value(true);
						break;
					}
				}
			}
		}
	}
}

/**
 * 문의 데이터
 **/
 this.fnInitInquiryData = function(){
	
	// 접수문의 전화번호
	var rcptQustTelNo = this.dsResultAppoExamBasic.getColumn(0, 'rcptQustTelNo');
	var rcptQustHrValue = this.dsResultAppoExamBasic.getColumn(0, 'rcptQustHrValue');
	
	// ORE 공통 스크립트에서 정보 취득
	this.lcltyRcptInquiryInfo(rcptQustTelNo,rcptQustHrValue);
 }
 
 /**
 * 지원서 기본정보 등록 데이터 SET
 * 
 **/
 this.fnSetSaveMainBaseInfo = function(){
	// 주민번호
	var applpRrno =  this.dsMainBase.getColumn(0, "applpRrno")
	// 성별 :  default 여
	var sxdsCd = "2";
	// 주민번호 뒷자리 [남성] 1,3,5(외국인),7(외국인) [여성] 2,4,6(외국인),8(외국인)
	var sxdsNo = applpRrno.slice(6,7);
	if(sxdsNo === "1" || sxdsNo === "3" || sxdsNo === "5" || sxdsNo === "7"){
		sxdsCd = "1";
	}
	
	// 출생년도 앞 2자리 처리
	var applpBrdtYY = "19";
	// 주민번호 뒷자리 3,4,7(외국인),8(외국인)  = 2000년대 출생
	if(sxdsNo === "3" || sxdsNo === "4" || sxdsNo === "7" || sxdsNo === "8"){
		applpBrdtYY ="20";
	}
	var applpBrdt = applpBrdtYY+applpRrno.slice(0,6);
	
	// 휴대전화번호
	var mblTelno1 = this.dsMainBase.getColumn(0, "mblTelno1");	
	var mblTelno2 = this.dsMainBase.getColumn(0, "mblTelno2");	
	var mblTelno3 = this.dsMainBase.getColumn(0, "mblTelno3");
	var mblTelno = [mblTelno1, mblTelno2, mblTelno3].join("-"); 
	if ( mblTelno == "--" ){
		mblTelno = "";
	}

	// 비상연락처
	var emgCnctTelno1 = this.dsMainBase.getColumn(0, "emgCnctTelno1");	
	var emgCnctTelno2 = this.dsMainBase.getColumn(0, "emgCnctTelno2");	
	var emgCnctTelno3 = this.dsMainBase.getColumn(0, "emgCnctTelno3");
	var emgCnctTelno = [emgCnctTelno1, emgCnctTelno2, emgCnctTelno3].join("-"); 
	if ( emgCnctTelno == "--" ){
		emgCnctTelno = "";
	}
	
	// 이메일
	var emlAddr1 = this.dsMainBase.getColumn(0,"emlAddr1");
	var emlAddr3 = this.dsMainBase.getColumn(0,"emlAddr3");
	var emlAddr = [emlAddr1, emlAddr3].join("@"); 
	if ( emlAddr == "@" ){
		emlAddr = "";
	}
	// 임용시험 마스터ID
	this.dsMainBase.setColumn(0, 'appoExamMastrIdfId',  this.dsResultAppoExamBasic.getColumn(0, "appoExamMastrIdfId"));
	// 임용시험년도
	this.dsMainBase.setColumn(0 ,'appoExamYr', this.dsResultAppoExam.getColumn(0, "appoExamYr"));
	// 성별
	this.dsMainBase.setColumn(0 ,'sxdsCd', sxdsCd);
	// 생년월일
	this.dsMainBase.setColumn(0 ,'applpBrdt', applpBrdt);
	// 휴대전화
	this.dsMainBase.setColumn(0, 'mblTelno', mblTelno );
	// 비상연락처
	this.dsMainBase.setColumn(0, 'emgCnctTelno', emgCnctTelno );
	// 이메일
	this.dsMainBase.setColumn(0, 'emlAddr', emlAddr );
 }
 
 /**
 * 제한자격증 등록 데이터 SET
 * 가변 생성 체크박스 정보 추출
 **/
 this.fnSetSaveMainLmttQlflInfo = function(sCheckPrefix)
 {
 	// 초기화
	this.dsMainLmttQlfl.clearData();
	var arrComps = this.divLmttQlflInfo.form.divLmttQlfl.form.components;
	sCheckPrefix = this.smfNvl(sCheckPrefix,"chkQlflIdf_");	
	var checkedIdx = 0;
	for(var i=0;i<arrComps.length;i++){
		var objComp = arrComps[i];
		if(objComp.id.indexOf(sCheckPrefix)==0){
			if(objComp.value){
				// 제한자격정보 ADD
				this.dsMainLmttQlfl.addRow();
				this.dsMainLmttQlfl.setColumn(checkedIdx, 'qlflIdfCd', objComp._qlflIdfCd.trim());
				this.dsMainLmttQlfl.setColumn(checkedIdx,'qlflIdfValue', objComp.text);
				this.dsMainLmttQlfl.setColumn(checkedIdx,'qlflIdfNm', objComp.text);	// 연계시 자격증명 변수 추가
				
				checkedIdx++;
			}
		}		
	}
}

 /**
 * 원서접수 문자발송정보 SET
 * 
 **/
 this.fnSetSaveRcptSmsInfo = function(){
	// 초기화
	this.dsRcptSms.clearData();
	this.dsRcptSms.addRow();
	this.dsRcptSms.setColumn(0, 'appoExamScCd' , this.smfGetAppoExamScCd()); //임용시험구분코드
	this.dsRcptSms.setColumn(0, 'cddcScCd' ,this.smfGetCddcCode().slice(0,3)); //시도교육청구분코드
	this.dsRcptSms.setColumn(0, 'cddcNm' , this.smfGetCddcName()); //시도교육청명
	this.dsRcptSms.setColumn(0, 'rcptQustTelNo' , this.dsResultAppoExamBasic.getColumn(0, 'rcptQustTelNo')); //발신번호
	this.dsRcptSms.setColumn(0, 'mblTelno' , this.dsMainBase.getColumn(0, 'mblTelno')); //수신번호
 }

