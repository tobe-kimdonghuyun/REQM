          <Column id="applpImYn" type="STRING" size="1" description="기타 지원불가"/>
          <Column id="unaExamYn" type="STRING" size="1" description="무효시험(삭제,마감)여부"/>
          <Column id="rcptImDtYn" type="STRING" size="1" description="접수불가기간여부"/>
          <Column id="dpcnYn" type="STRING" size="1" description="중복지원여부"/>
          <Column id="lmttAgeYn" type="STRING" size="1" description="연령제한여부"/>
          <Column id="basicDdlnYn" type="STRING" size="256"/>
          <Column id="ddlnYn" type="STRING" size="256"/>
          <Column id="delYn" type="STRING" size="256"/>
          <Column id="itnRcptBgngDt" type="STRING" size="256"/>
          <Column id="itnRcptEndDt" type="STRING" size="256"/>
          <Column id="ady24HrCeckYn" type="STRING" size="256"/>
          <Column id="aplemUltBrdt" type="STRING" size="256"/>
          <Column id="aplemLwltBrdt" type="STRING" size="256"/>
