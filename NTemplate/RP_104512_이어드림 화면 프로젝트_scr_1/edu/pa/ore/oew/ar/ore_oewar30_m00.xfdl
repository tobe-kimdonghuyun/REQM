          <Column id="eduPubsvCtpvOcptCd" type="STRING" size="256" description="채용직종코드"/>
          <Column id="dstrtCd" type="STRING" size="256" description="채용지역코드"/>
          <Column id="dstrtNm" type="STRING" size="256" description="채용지역명"/>
