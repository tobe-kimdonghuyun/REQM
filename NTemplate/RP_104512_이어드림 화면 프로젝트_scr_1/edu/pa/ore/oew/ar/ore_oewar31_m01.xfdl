    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-교육공무직-지원서 작성-접수완료
*  @MenuPath    pa_ore_oew_ar
*  @FileName 	pa_ore_oewar31_m02.xfdl
*  @Creator 	
*  @CreateDate 	2022.09.01
*  @Desction    온라인통합채용-교육공무직-지원서 작성-접수완료
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.09.01    		 	        최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs"
include "lib::ore_script.xjs";
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.rcptQustTelNo = "";
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);
	
	// 파라메터 세팅
 	this.pv_params = this.smfGetFormParams();
 	this.divCont.form.staExamNm.set_text(this.pv_params.appoExamNm); // 시험명
	this.divCont.form.staOccup.set_text(this.pv_params.occupNm); // 직종
	this.divCont.form.staDist.set_text(this.pv_params.distNm); // 지역
	this.divCont.form.staNm.set_text(this.smfGetSessionValue('userNm'));
	this.dsRtpNo.setColumn(0,"rcptNo", this.pv_params.rcptNo); //접수번호 
	
	//접수증 내역
	this.dsReport.setColumn(0,"staExamNm",this.pv_params.appoExamNm);
	this.dsReport.setColumn(0,"occupNm",this.pv_params.occupNm);
	this.dsReport.setColumn(0,"distNm",this.pv_params.distNm);
	this.dsReport.setColumn(0,"applpFlnm",this.pv_params.applpFlnm);
	this.dsReport.setColumn(0,"applpBrdt",this.pv_params.applpBrdt);
	this.dsReport.setColumn(0,"rcptNo",this.pv_params.rcptNo);
	this.dsReport.setColumn(0,"chorDutyNm", this.pv_params.chorDutyNm); //기관장명칭
	
	//삭제 가능 여부 확인 
	var sCddcCd = this.smfGetCddcCode();
	this.dsSearch.setColumn(0, "cddcScCd", sCddcCd.slice(0,3));
	this.dsSearch.setColumn(0, "cddcCd", sCddcCd);
	this.dsSearch.setColumn(0, "empmnExamId", this.pv_params.appoExamId);
	this.dsSearch.setColumn(0, "orgCd", sCddcCd);
	this.dsSearch.setColumn(0, "eduPubsvCtpvOcptCd", this.pv_params.occupCd);
	this.dsSearch.setColumn(0, "dstrtCd", this.pv_params.distCd);

	this.rcptQustTelNo = this.pv_params.rcptQustTelNo;
	var inquiry = this.elvRcptInquiryInfo(this.rcptQustTelNo);
	this.divInqInfo.form.staContent01.set_text(inquiry);
					
	var rcptDt = this.pv_params.rcptDt;
	if(this.smfIsNull(rcptDt)){ 
		// 서버시간 조회
		this.fnSearchDate();
	}else{
		this.divCont.form.staApplDt.set_text(rcptDt);
		rcptDt = rcptDt.dateFormat("yyyy-MM-dd");
		this.dsReport.setColumn(0,"rcptDt",this.pv_params.rcptDt);
	}
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid, errcd, errmsg){

};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
// 현재 일자 검색
this.fnSearchDate = function(obj, e)
{	
	// 서비스 객체 생성
	this.smfSearchService("selectDate")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;

			// 년월일시분초
			var sCurYmdHms = this.dsDateTime.getColumn(0, "yyyymmdd") + this.dsDateTime.getColumn(0, "hhmmss");
	
			// formatting
			sCurYmdHms = sCurYmdHms.dateFormat("yyyy-MM-dd hh:mm:ss");
			// 서버에서 가져온 시간을 표시한다.
			this.divCont.form.staApplDt.set_text(sCurYmdHms);
			
			var sCurYmd = this.dsDateTime.getColumn(0, "yyyymmdd");
			sCurYmd = sCurYmd.dateFormat("yyyy-MM-dd");
			this.dsReport.setColumn(0,"rcptDt",sCurYmd);
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 /**
 * 원서접수 문자발송정보 SET
 * 
 **/
 this.fnSetSaveRcptSmsInfo = function(){
	// 초기화
	this.dsRcptSms.clearData();
	this.dsRcptSms.addRow();
	this.dsRcptSms.setColumn(0, 'appoExamScCd' , this.smfGetAppoExamScCd()); //임용시험구분코드
	this.dsRcptSms.setColumn(0, 'cddcScCd' ,this.smfGetCddcCode().slice(0,3)); //시도교육청구분코드
	this.dsRcptSms.setColumn(0, 'cddcNm' , this.smfGetCddcName()); //시도교육청명
	this.dsRcptSms.setColumn(0, 'rcptQustTelNo' , this.pv_params.rcptQustTelNo); // 온라인마스터 문의번호 : 발신번호
	this.dsRcptSms.setColumn(0, 'mblTelno' , this.smfGetSessionValue('mblTelNo')); // 세션: 수신번호
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

// 이전 버튼 클릭
this.divActionBtn_btnPrev_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
 	var params = {
			appoExamId:this.pv_params.appoExamId,
			appoExamNm: this.pv_params.appoExamNm,
			occupCd:this.pv_params.occupCd,
			occupNm:this.pv_params.occupNm,
			distCd:this.pv_params.distCd,
			distNm:this.pv_params.distNm,
			rcptNo:this.pv_params.rcptNo,
			appoExamYr:this.pv_params.appoExamYr
 	};
	this.smfSetWorkPage("pa_ore_oew_ar::ore_oewar31_m00.xfdl", params);	
	
};

// 접수증출력 버튼 클릭
this.divActionBtn_btnPrint_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{ 

	// 버튼표시여부
	var objButton = {
		"toolbar.save" : "false"    // 저장 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)           
		, "toolbar.addmemo" : "false"    // 메모 추가 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
		, "toolbar.savedm" : "false"    // 데이터 모듈 저장 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
		, "toolbar.etc" : "false"    // 다른 메뉴 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
	}
	
	// 리포트를 생성하기 위한 옵션을 설정한다.
	var oOzOption = {
					    reports : [	
							{	
								  displayname  : "접수증"         
								, reportname : "/edu/pa/ore/oew/ar/ore_oewrm31_r01.ozr"                                
								, jsonDs     : [this.dsReport]     
								, jsonDsName : ["dsReport"]          
								// 추가/보안옵션
								, security     : "N"     // [선택] 위변조방지 삽입   ("Y"(default):표시,"N":비표시)
								, voiceBarcode : "N"     // [선택] 보이스바코드 삽입 ("Y"(default):표시,"N":비표시)
								, brailleCode  : "N"    // [선택] 점자문서 생성     ("Y":생성,"N"(default):미생성)
								, showStatus : false   // [선택] 하단 상태값 표시
							}						
						]
						, button : objButton    // [선택] 버튼의 표시 비표시를 통제
	                };
					
	//리포트를 그린다
	this.smfReportView(this,"popup",oOzOption,this.fnReportCallback);           // Div로 표시
};

this.fnReportCallback = function(context, responseParams, sender){
	
}

// 접수취소 버튼 클릭
this.divActionBtn_btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 원서접수 문자발송정보 SET
	this.fnSetSaveRcptSmsInfo();
	
	// 서비스 객체 생성
	this.smfConfirm("원서접수 취소시 처음단계부터 재작성 해주셔야 합니다 \n원서접수를 취소하시겠습니까?", function(result){
		if(result.confirmResult){
			//취소전 체크 
			this.smfSearchService('selectCheckData') 
						.showConfirm(false)
				.run()
				// 콜백
				.callback(function(callbackParams){
					
					if(callbackParams.errors){
						return;
					}
					// 접수불가기간
					var rcptImDtYn = this.dsResultCheck.getColumn(0, 'rcptImDtYn');
					if(rcptImDtYn === 'Y'){
						this.smfAlert("원서 취소 기간이 아닙니다.");
						return;
					}	
					this.fnSaveRcptCancel();
				});
		}
	});			
};

//접수취소
this.fnSaveRcptCancel = function(obj, e)
{	
	this.smfSaveService("saveApf")
	.showConfirm(false)
	// 실행
	.run()
	// 콜백
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		this.smfAlert("원서 접수 취소가 완료 되었습니다.", this.fnCancelMessageCallback);
		var params = {};
		this.smfSetWorkPage("pa_ore_oew_rm::ore_oewrm30_m00.xfdl", params);
	});	
};]]></Script>
    <Objects>
      <Dataset id="dsDateTime" useclientlayout="true">
        <ColumnInfo>
          <Column id="mm" type="STRING" size="256"/>
          <Column id="dd" type="STRING" size="256"/>
          <Column id="hhmmss" type="STRING" size="256"/>
          <Column id="yyyymmdd" type="STRING" size="256"/>
          <Column id="yyyy" type="STRING" size="256"/>
          <Column id="hhmmsssss" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
