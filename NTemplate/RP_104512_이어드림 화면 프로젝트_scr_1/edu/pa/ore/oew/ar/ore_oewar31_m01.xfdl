              <Button id="btnPrint" taborder="1" text="접수증 출력" top="50" height="50" cssclass="btn_WF_Action" enable="true" initvalueid="ivBtnAccessibilityLink" left="btnPrev:20" right="532" onclick="divActionBtn_btnPrint_onclick"/>
