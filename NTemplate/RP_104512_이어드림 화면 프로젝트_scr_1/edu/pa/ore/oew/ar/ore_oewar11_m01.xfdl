          <Column id="stlmNo" type="STRING" size="256" description="결제번호(INICIS상점코드)"/>
          <Column id="octpRcptYn" type="STRING" size="256" description="타시도접수여부"/>
          <Column id="applpRrno" type="STRING" size="256" description="응시자주민등록번호"/>
          <Column id="onlEmpmnExamScCd" type="STRING" size="256" description="온라인채용시험구분코드"/>
          <Column id="appoExamId" type="STRING" size="256" description="임용시험ID"/>
          <Column id="cddcScCd" type="STRING" size="256"/>
