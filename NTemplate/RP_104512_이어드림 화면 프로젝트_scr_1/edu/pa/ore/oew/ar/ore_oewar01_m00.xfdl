// 학력정보 - 교원자격증 검증 가능, 불가 탭 변경
this.divContent05_chkTchQlfVrfcPassvYn_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	/*초등 협의회 요청
	확인이 안되는 경우 안내 문구 추가
	*/
	if(obj.value)
	{
		this.smfAlert("※ 증빙자료 : 학력정보가 확인이 안되는 졸업예정자의 경우, 교원자격증 취득 예정증명서를 성명-파일명으로 첨부\n(예) 홍길동-교원자격증 취득 예정증명서"); 
		
		this.dsMain.setColumn(0, "qlflNo", "");//자격번호
		this.dsMain.setColumn(0, "tchQlfAsortScNmY", "");//교원자격종별
		this.dsMain.setColumn(0, "tchQlfAsortScCdY", "");//교원자격종별
		
		this.dsMain.setColumn(0, "lsgByScNmY", "");//교원자격증급별
		this.dsMain.setColumn(0, "lsgByScCdY", "");//교원자격증급별
		
		this.dsMain.setColumn(0, "tchQlfInstNmY", "");//발급기관명
		this.dsMain.setColumn(0, "tchQlfInstCdY", "");//발급기관명
		
		this.dsMain.setColumn(0, "tchQlfAsortScCdN", "");//교원자격종별
		this.dsMain.setColumn(0, "lsgByScCdN", "");//교원자격증급별
		this.dsMain.setColumn(0, "tchQlfInstNmN", "");//발급기관명
		
		this.divContent05.form.divContent01.form.divTchQlfFileRefrnFile.form.fnResetUpload(); //초기화
		this.dsMain.setColumn(0, "tchQlfFileRefrnId", "");
		
		this.fnAcbgTabChange(obj.value);
	}else{
		//입력 내용 초기화
		this.smfConfirm("입력한 교원자격증종별, 교원자격증급별, 발급기관명, 증빙자료가 초기화 됩니다. 계속 진행하시겠습니까?", function(result){
			
			if(result.confirmResult){
			
				this.dsMain.setColumn(0, "qlflNo", "");//자격번호
				this.dsMain.setColumn(0, "tchQlfAsortScNmY", "");//교원자격종별
				this.dsMain.setColumn(0, "tchQlfAsortScCdY", "");//교원자격종별
				
				this.dsMain.setColumn(0, "lsgByScNmY", "");//교원자격증급별
				this.dsMain.setColumn(0, "lsgByScCdY", "");//교원자격증급별
				
				this.dsMain.setColumn(0, "tchQlfInstNmY", "");//발급기관명
				this.dsMain.setColumn(0, "tchQlfInstCdY", "");//발급기관명
				
				this.dsMain.setColumn(0, "tchQlfAsortScCdN", "");//교원자격종별
				this.dsMain.setColumn(0, "lsgByScCdN", "");//교원자격증급별
				this.dsMain.setColumn(0, "tchQlfInstNmN", "");//발급기관명
				
				this.divContent05.form.divContent01.form.divTchQlfFileRefrnFile.form.fnResetUpload(); //초기화
				this.dsMain.setColumn(0, "tchQlfFileRefrnId", "");
				

				this.fnAcbgTabChange(obj.value);
			}else{
			
				this.divContent05.form.chkTchQlfVrfcPassvYn.set_value(!obj.value);
			}
		
		});
		
		
	}
	
};

// 응시료 면제자 구분 탭 변경
this.divContent14_rdoContent00_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{

	//자격확인요청 후 응시료 면제 구분을 변경시 안내 메세지 출력 및 초기화
	var rlesVrfcScsYn = this.dsMain.getColumn(0, "rlesVrfcScsYn");
	if(rlesVrfcScsYn === "Y"){
		var returnValue = this.smfConfirm("응시료 면제구분 변경시 자격확인요청을 다시 실행해야 합니다. 계속 진행하시겠습니까", function(result){
		
			if(result.confirmResult){
			
				this.dsMain.setColumn(0,"pvsnPrcusAgreYn", "");
				this.dsMain.setColumn(0,"rlesVrfcScsYn", "N");
				this.fnRlesCheck(obj.value);
				
			}else{
				this.dsMain.setColumn(0, "aplemFeeExmpTrgtScCd", e.prevalue);
				
			}
		
		});
		
		
	}else{
		var rlesVrfcFileRefrnId = this.dsMain.getColumn(0, "rlesVrfcFileRefrnId");
		
		if(!this.smfIsNull(rlesVrfcFileRefrnId)){
			var returnValue = this.smfConfirm("응시료 면제구분 변경시 응시료 면제 증빙자료가 초기화 됩니다. 계속 진행하시겠습니까?", function(result){
		
				if(result.confirmResult){
					this.dsMain.setColumn(0,"pvsnPrcusAgreYn", "");
					this.fnRlesCheck(obj.value);
				}else{
					this.dsMain.setColumn(0, "aplemFeeExmpTrgtScCd", e.prevalue);
					
				}
			
			});
		}else{
			this.dsMain.setColumn(0,"pvsnPrcusAgreYn", "");
			this.fnRlesCheck(obj.value);
		}
		
	}
	
	
};

// 다음 단계
this.divContent15_btnContent01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	
	var rcptNo = this.dsMain.getColumn(0,"rcptNo");
	// 수정일 경우 데이터 조회 
	if(!this.smfIsNull(rcptNo)){
		
		//수정
		if( this.dsMain.getRowType(0) == "4" ){ //마이페이지>원서접수내역에서 들어와 바로 다음버튼 눌렀을 경우, 무조건 4임.
			/*
				면제자인데 결재 처리가 되지 않은 경우 다음 버튼 클릭 방지. 저장 후 다음.
				면제자의 경우 저장시 자동 결재 처리가 되는데 결재 취소를 하는 경우 다시 저장 버튼을 누르지 
				않으면 결재 처리 되지 않음. 이 상태에서 다음버튼을 클릭 할 경우 결재완료 된것처럼 보이지만
				실제로는 결재 정보가 존재하지 않아 접수 완료 처리가 안됨.
			*/
			var rlesYn  = this.dsMain.getColumn(0, "rlesYn");//면제유무
			var stlmYn = this.dsMain.getColumn(0, "stlmYn");//결재유무
			if(rlesYn == "Y" && stlmYn != "Y"){
				this.smfAlert("응시료 면제(결재) 처리를 위해 지원서 저장 후 다음 단계로 이동 가능 합니다. ");
				return;
			}
			
			/*
				응시료면제자가 자격확인요청 및 저장 후 결재 취소를 한 후
				응시료 면제자 체크 박스를 풀고 다음 버튼 클릭시 결재정보는 없으나
				접수 완료 화면으로 전환되는 오류를 방지하기 위하여
				저장(결재정보 생성)후 다음 버튼 클릭하도록 안내메세지 출력
			*/
			var oldRlesVrfcScsYn = this.dsMain.getColumn(0, "oldRlesVrfcScsYn");
			if(oldRlesVrfcScsYn == "Y" && stlmYn != "Y"){
				
				this.smfAlert("응시료 면제 정보가 변경된 경우 지원서 저장 후 다음 단계로 이동 가능 합니다. ");
				return;
			}
			if(this.gotoPay =="Y"){
				this.fnAechgPayScrinMvmn('Y'); //응시료납부화면이동
			}
			else	
			{
				this.smfConfirm("저장하지 않은 정보는 변경되지 않습니다. \n다음 단계로 이동 하시겠습니까?", function(result){
					if(result.confirmResult){
						this.fnAechgPayScrinMvmn('Y'); //응시료납부화면이동
					}
				});
			}
			
		}else{
			this.fnAechgPayScrinMvmn('N'); //응시료납부화면이동
		}
	}else{
		//신규
		this.smfAlert("지원서 저장 후 다음 단계로 이동 가능 합니다. ");
		return;
	}
};

