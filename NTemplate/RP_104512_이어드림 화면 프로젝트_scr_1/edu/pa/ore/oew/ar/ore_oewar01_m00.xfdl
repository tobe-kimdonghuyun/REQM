// 장애인 응시자 처리
this.fnDltCheck = function(isChecked)
{
	// 화면처리
	this.divContent08.form.cboDltScCd.set_enable(isChecked);
	this.divContent08.form.cboSedScCd.set_enable(isChecked);
	this.divContent08.form.cboCnvPvsnDmndYn.set_enable(isChecked);
	this.divContent08.form.divDltCnvFile.set_enable(isChecked);
	this.divContent08.form.btnAtchFileDel02.set_enable(isChecked); //증빙자료 삭제버튼
		
	if( isChecked ) {
		// validate 추가
		this.smfUpdateValidateToComponent("title:장애인구분,required", this.divContent08.form.cboDltScCd);
		this.smfUpdateValidateToComponent("title:장애인구분,required", this.divContent08.form.cboSedScCd);
		// 장애아님 filter처리 
		this.dsDltScCd.filter("unyCdValue != '2' && unyCdValue != '22' && unyCdUseYn != 'N' && unyCdValue != '0'");
		this.dsSedScCd.filter("unyCdValue > '09'");
	} else {
		// validate 제거
		this.smfClearRulesetToComponent(this.divContent08.form.cboDltScCd);
		this.smfClearRulesetToComponent(this.divContent08.form.cboSedScCd);
		this.dsDltScCd.filter("unyCdValue != '2' && unyCdValue != '22' && unyCdUseYn != 'N'");
		this.dsSedScCd.filter("unyCdValue >= '09'");
	}
};


