        <Static id="staPicNoti00" taborder="19" text="&lt;b v='true'&gt;★★ 교직원온라인채용 포털은 자동완성 기능을 지원하지 않습니다. 반드시 키보드로 직접 입력하시길 바랍니다.&lt;/b&gt;" left="10" top="356" height="27" cssclass="sta_WF_Black14" onclick="sta00_00_00_00_onclick" right="375" initvalueid="ivStcAccessibilityOn" verticalAlign="top" usedecorate="true" color="red"/>
      </Layout>
