	}
	this.fnCheckSprtMet(obj.value, "", "");
};

// 졸업여부 변경시
this.divContent05_cboGrdtnScCd_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	//정상졸업
	if(obj.value == '1'){
		
		this.divContent05.form.chkTchQlfVrfcPassvYn.set_enable(true);
		
		if(this.divContent05.form.chkTchQlfVrfcPassvYn.value){
			this.divContent05.form.btnContent00.set_enable(false);
		}else{
			this.divContent05.form.btnContent00.set_enable(true);
		}
		
		this.fnAcbgTabChange(this.divContent05.form.chkTchQlfVrfcPassvYn.value);
	}else if( obj.value == '6' ){ //졸업예정이면 졸업년월을 내년 2월로 설정
		if(!this.smfIsNull(this.dsMain.getColumn(0, "qlflNo"))){
			
			//입력 내용 초기화
			this.smfConfirm("졸업예정으로 변경시 교원자격조회한 내용이 초기화 됩니다. 계속 진행하시겠습니까?", function(result){
				
				if(result.confirmResult){
					
					this.dsMain.setColumn(0, "qlflNo", "");//자격번호
					this.dsMain.setColumn(0, "tchQlfAsortScNmY", "");//교원자격종별
					this.dsMain.setColumn(0, "tchQlfAsortScCdY", "");//교원자격종별
					
					this.dsMain.setColumn(0, "lsgByScNmY", "");//교원자격증급별
					this.dsMain.setColumn(0, "lsgByScCdY", "");//교원자격증급별
					
					this.dsMain.setColumn(0, "tchQlfInstNmY", "");//발급기관명
					this.dsMain.setColumn(0, "tchQlfInstCdY", "");//발급기관명
					
					
					var result = this.smfTodayTime();
					result = this.smfAddMonth(result.substring(0, 4)+'0101', 13);
					this.dsMain.setColumn(0, 'grdtnYm', result);
					this.divContent05.form.btnContent00.set_enable(false);
					//입학년월이 내년2월로 되어있는 상태서 졸업여부를 졸업예정으로 하면 입학년월 제거
					//this.fnCheckGrdtnYm(0);
					this.divContent05.form.chkTchQlfVrfcPassvYn.set_value(true);
					this.divContent05.form.chkTchQlfVrfcPassvYn.set_enable(false);
					this.fnAcbgTabChange(this.divContent05.form.chkTchQlfVrfcPassvYn.value);
				}else{
				
					
					//입학년월이 내년2월로 되어있는 상태서 졸업여부를 졸업예정으로 하면 입학년월 제거
					this.divContent05.form.cboGrdtnScCd.set_value("1");
				}
			
			});
		}else{
			var result = this.smfTodayTime();
			result = this.smfAddMonth(result.substring(0, 4)+'0101', 13);
			this.dsMain.setColumn(0, 'grdtnYm', result);
			this.divContent05.form.chkTchQlfVrfcPassvYn.set_value(true);
			this.divContent05.form.chkTchQlfVrfcPassvYn.set_enable(false);
			this.fnAcbgTabChange(true);
			
		}
	}else{
	
		//입력 내용 초기화
		this.smfConfirm("입력한 정보가 초기화 됩니다. 계속 진행하시겠습니까?", function(result){
			if(result.confirmResult){
				this.dsMain.setColumn(0, "qlflNo", "");//자격번호
				this.dsMain.setColumn(0, "tchQlfAsortScNmY", "");//교원자격종별
				this.dsMain.setColumn(0, "tchQlfAsortScCdY", "");//교원자격종별
				
				this.dsMain.setColumn(0, "lsgByScNmY", "");//교원자격증급별
				this.dsMain.setColumn(0, "lsgByScCdY", "");//교원자격증급별
				
				this.dsMain.setColumn(0, "tchQlfInstNmY", "");//발급기관명
				this.dsMain.setColumn(0, "tchQlfInstCdY", "");//발급기관명
				
				this.dsMain.setColumn(0, "mlvAppoCurrCdY", "");//교원자격증 표시과목
				
				
				this.dsMain.setColumn(0, "tchQlfAsortScNmN", "");//교원자격종별
				this.dsMain.setColumn(0, "tchQlfAsortScCdN", "");//교원자격종별
				
				this.dsMain.setColumn(0, "lsgByScNmN", "");//교원자격증급별
				this.dsMain.setColumn(0, "lsgByScCdN", "");//교원자격증급별
				
				this.dsMain.setColumn(0, "tchQlfInstNmN", "");//발급기관명
				this.dsMain.setColumn(0, "tchQlfInstCdN", "");//발급기관명
				
				this.dsMain.setColumn(0, "mlvAppoCurrCdY", "");//교원자격증 표시과목
				this.dsMain.setColumn(0, "mlvAppoCurrCdN", "");//교원자격증 표시과목
				
				this.divContent05.form.divContent01.form.divTchQlfFileRefrnFile.form.fnResetUpload(); //초기화
				this.dsMain.setColumn(0, "tchQlfFileRefrnId", "");//증빙자료
				
				this.divContent05.form.chkTchQlfVrfcPassvYn.set_enable(false);//조회가 안되는 경우
				this.divContent05.form.chkTchQlfVrfcPassvYn.set_value(false);//조회가 안되는 경우
				this.divContent05.form.btnContent00.set_enable(false);//교원자격조회
				this.fnAcbgTabChange(false);
			}else{
			
				this.divContent05.form.cboGrdtnScCd.set_value(e.prevalue);
			}
		});
	}
	
	
	
};

//응시료 면제자 클릭시 이벤트 
this.divContent14_chkContent01_onchanged = function(obj:nexacro.CheckBox,e:nexacro.CheckBoxChangedEventInfo)
{
	if(e.postvalue){
		
		this.dsMain.setColumn(0,"aplemFeeExmpTrgtScCd","1");
		this.fnRlesCheck(this.dsMain.getColumn(0,"aplemFeeExmpTrgtScCd"));
		this.divContent14.form.staContent01.set_visible(true);//안내
		this.divContent14.form.divContent00.set_visible(true);//국민기초생활수급자
		this.divContent14.form.divContent01.set_visible(false);//한부모가족보호대상자
		this.divContent14.form.divContent03.set_visible(true);//증빙자료
		
		
		
	}else{
	
		
		var rlesVrfcScsYn = this.dsMain.getColumn(0, "rlesVrfcScsYn");//검증여부
		var rlesVrfcFileRefrnId = this.dsMain.getColumn(0, "rlesVrfcFileRefrnId");
		
		if(rlesVrfcScsYn === "Y" || !this.smfIsNull(rlesVrfcFileRefrnId)){
			
			this.smfConfirm("자격확인 검증정보 및 응시료 면제 증빙자료가 초기화 됩니다. 계속 진행하시겠습니까?", function(result){
				if(result.confirmResult){
					this.dsMain.setColumn(0,"aplemFeeExmpTrgtScCd","0");
					this.dsMain.setColumn(0,"pvsnPrcusAgreYn","");
					this.fnRlesCheck(this.dsMain.getColumn(0,"aplemFeeExmpTrgtScCd"));
							
					
				}else{
					this.divContent14.form.chkContent01.set_value(e.prevalue);
				}
			});
		
		}else{
		
			this.dsMain.setColumn(0,"aplemFeeExmpTrgtScCd","0");
			this.dsMain.setColumn(0,"pvsnPrcusAgreYn","");
			//화면 조정
			
			this.fnRlesCheck(this.dsMain.getColumn(0,"aplemFeeExmpTrgtScCd"));
			
			
		}
		
	}
	
};

//자격번호(교원자격) 검증
this.divContent05_btnContent00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 주민번호
	var applpRrno =  this.dsMain.getColumn(0, "applpRrno");
	var currCd    =  this.pv_params.appoFieldCd;//응시분야
	///var applpBrdt = applpRrno.slice(0,6);
	var popupParams = {
		callback: this.fnAdd00Callback, // 콜백함수 지정
		sender: obj, // sender 지정
		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType : 'none',
			flNm : this.dsMain.getColumn(0,"applpFlnm"),
			applpRrno : applpRrno,
			currCd : currCd
		},
	};
	// 모달팝업 실행
	this.smfDialog("_auto", "pa_ore_oew_ar::ore_oewar01_p00.xfdl", popupParams);
};

//회차변경시 일자 세팅 
this.divContent07_cboKrhisRcgnTmeN_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	var krhisRcgnTme = e.postvalue;
	var krhisRcgnCetYmd = this.dsKrhisRcgnCetYmdList.lookup("krhisRcgnTme",krhisRcgnTme,"krhisRcgnCetYmd");
	this.dsMain.setColumn(0,"krhisRcgnCetYmdN", krhisRcgnCetYmd);
};

this.divContent07_btnContent00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//회차
	if(this.smfIsNull(this.dsMain.getColumn(0,"krhisRcgnTmeN"))){
		this.divContent07.form.cboKrhisRcgnTmeN.setFocus();
		this.smfAlert('회차를 선택해주세요.'); 
		return false;	
	}
	//인증번호
	if(this.smfIsNull(this.dsMain.getColumn(0,"krhisRcgnCetNo2"))){
		this.divContent07.form.edtKrhisRcgnCetNo2.setFocus();
		this.smfAlert('인증번호를 입력해주세요.'); 
		return false;	
	}
		
	// 파라메터 셋
	this.dsKrhisVrfc.setColumn(0, "applpRrno", nexacro.base64Decode(this.smfGetSessionValue('userRrno')));
	this.dsKrhisVrfc.setColumn(0, "applpFlnm", this.smfGetSessionValue('userNm'));
	this.dsKrhisVrfc.setColumn(0, "krhisRcgnCetNo", this.divContent07.form.edtKrhisRcgnCetNo1.value +'-'+this.divContent07.form.edtKrhisRcgnCetNo2.value);

	this.smfSearchService('selectKrhisApi') 
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		// 한국사 검증여부 성공시
		if ("Y" == this.dsResultKrhisVrfc.getColumn(0, "krhisVrfcYn")) {
			// 3급 미만의 한국사능력검정
			if (this.dsResultKrhisVrfc.getColumn(0, "testlevel") > 3)
			{
				// 한국사능력검증성공여부
				this.dsMain.setColumn(0,"krhisAbtVrfcScsYn", "N");
				this.smfAlert("한국사능력취득은 확인되었으나 한국사능력검정 3급이상이 아닙니다.");
				return;
			}
			this.dsMain.setColumn(0, "krhisRcgnClaValue", this.dsResultKrhisVrfc.getColumn(0, "testlevel"));
			this.dsMain.setColumn(0, "krhisRcgnCetNo", this.dsKrhisVrfc.getColumn(0, "krhisRcgnCetNo"));
			// 한국사능력검증성공여부
			this.dsMain.setColumn(0,"krhisAbtVrfcScsYn", "Y");
			this.smfAlert("한국사능력검정 인증번호 확인이 완료되었습니다.");
			//응시원서기관검증이력(성공했을때만)
			var iFindRow = this.dsOthinVrfc.findRow("othinVrfcScCd" , "HCH");    
			if(iFindRow == -1 ){
				iFindRow = this.dsOthinVrfc.addRow();
				this.dsOthinVrfc.setColumn(iFindRow, "othinVrfcScCd" , "HCH");   // 국사편찬위원회
			}
		} else {
			this.smfAlert("한국사능력검정 인증번호가 존재하지 않습니다.");
		}
	});	
};

//응시료면제 요청
this.divContent14_divContent00_btnContent00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var rlesScCd    = this.dsMain.getColumn(0,"aplemFeeExmpTrgtScCd"); // 응시료면제구분 
	var rlesRegNo10 = this.dsMain.getColumn(0,"rlesRegNo10");          // 기초
	var rlesRegNo20 = this.dsMain.getColumn(0,"rlesRegNo20");          // 한부모 
	var agreeYn     = "N"; // 동의 여부  
	
	// 검증결과 초기화
	this.divContent14.form.divContent00.form.staResult.set_text("[미검증]");
	this.divContent14.form.divContent01.form.staResult.set_text("[미검증]");

	if(rlesScCd == "1"){
		// 동의여부
		agreeYn = this.divContent14.form.divContent00.form.rdoContent00.value;
	}else{
		// 동의여부
		agreeYn = this.divContent14.form.divContent01.form.rdoContent00.value;
		
		if(this.smfIsNull(rlesRegNo20)){
			this.divContent14.form.divContent01.form.edtRlesRegNo20.setFocus();
			this.smfAlert('CM006', ["등록번호"], this.fnMessageCallback ); 
			return false;	
		}
		this.dsSearchMyData.setColumn(0,"sptRegNo",rlesRegNo20);
	}
	
	if(agreeYn != 'Y'){
		this.smfAlert('정보 제공을 요구하지 않을시 검증할 수 없습니다.');
		return;
	}
		
	this.dsSearchMyData.setColumn(0,"userCid","");
	this.dsSearchMyData.setColumn(0,"applpRrno",this.dsMain.getColumn(0,"applpRrno"));
	this.dsSearchMyData.setColumn(0,"applpFlnm",this.dsMain.getColumn(0,"applpFlnm"));

	this.smfSearchService('selectMyData') 
	.run()
	// 콜백
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
					
			// 기초수급 대상자 검증 결과
			var rcbfYn = this.dsResultMyVrfc.getColumn(0,"rcbfYn");
			var sptFamYn = this.dsResultMyVrfc.getColumn(0,"sptFamYn");
			
			if( rcbfYn == 'Y' || sptFamYn == 'Y'){
				this.dsMain.setColumn(0 , "rlesVrfcScsYn", 'Y' );
				this.dsMain.setColumn(0 , "rlesVrfcCn", '공공마이데이터검증');
				this.dsMain.setColumn(0 , 'rlesYn', 'Y'); // 응시료 면제
				this.divContent14.form.divContent03.set_enable(false); //환불정보 비활성
			//	this.divContent14.form.divContent03.form.cboBankCd.set_value(""); // 환불 은행 초기화
			//	this.divContent14.form.divContent03.form.edtBankActno.set_value("");// 환불 계좌 초기화
			//	this.divContent14.form.divContent03.form.edtRefndAccDpstrNm.set_value("");// 환불 예금주 초기화
			}else{
				this.dsMain.setColumn(0 , "rlesVrfcScsYn", 'N' );
				this.dsMain.setColumn(0 , "rlesVrfcCn", '');
				this.dsMain.setColumn(0 ,"rlesRegNo20", '');
				this.dsMain.setColumn(0 ,'rlesYn', 'N'); // 응시료 면제
				this.divContent14.form.divContent03.set_enable(true);         //환불정보 활성
				//this.divContent14.form.divContent03.form.cboBankCd.setFocus();
			}
			
			if(rlesScCd == "1" ){
				if(rcbfYn == 'Y'){
					var rlesRegNo = this.dsResultMyVrfc.getColumn(0, "rcbfNo");
					this.dsMain.setColumn(0 , "rlesRegNo10", rlesRegNo);
					this.divContent14.form.divContent00.form.staResult.set_text("[검증완료]"); 
					this.smfAlert('국민기초보장법상 수급 대상자 검증이 완료 되었습니다.');

					//응시원서기관검증이력
					var iFindRow = this.dsOthinVrfc.findRow("othinVrfcScCd" , "PVH");
					if(iFindRow == -1 ){
						iFindRow = this.dsOthinVrfc.addRow();
						this.dsOthinVrfc.setColumn(iFindRow, "othinVrfcScCd" , "PVH"); // 국가보훈처 
					}
				}else{
					this.divContent14.form.divContent00.form.rdoContent00.set_value('N'); // 요구하지않음 SET
					this.divContent14.form.divContent00.form.staResult.set_text("[검증불가]");
					this.divContent14.form.divContent00.form.btnContent00.set_enable(false);
					//this.smfAlert('국민기초보장법상 수급 대상자 정보가 없습니다.\n자격확인요청이 되지 않는 경우(또는 검증불가인 경우) 응시수수료 면제 증빙자료를 첨부하시기 바랍니다.');
					this.smfAlert('국민기초보장법상 수급 대상자 정보가 없습니다.\n자격확인요청이 되지 않는 경우(또는 검증불가인 경우)\n응시수수료 면제 증빙자료를 첨부하시기 바랍니다.\n또한 응시수수료 결제를 완료해야 원서가 접수되며\n추후 대상자 확정 시 환불처리 됩니다.\n※ 증빙자료 : 자격확인요청을 통해 검증이 되지 않거나,\n자격확인요청을 요구하지 않는 경우, 응시수수료 면제 신청서와 면제대상 증명서류를 하나의 파일로 압축하여 성명-파일명으로 첨부\n(예) 홍길동-응시수수료면제증빙서류');
				}
			}else{
				if(sptFamYn == 'Y'){
					var rlesRegNo = this.dsResultMyVrfc.getColumn(0, "sptFamNo");
					this.dsMain.setColumn(0 ,"rlesRegNo20", rlesRegNo);
					this.divContent14.form.divContent01.form.staResult.set_text("[검증완료]"); 
					this.smfAlert('한부모가족 지원자 검증이 완료 되었습니다.');
					
					//응시원서기관검증이력
					var iFindRow = this.dsOthinVrfc.findRow("othinVrfcScCd" , "GEH");
					if(iFindRow == -1 ){
						iFindRow = this.dsOthinVrfc.addRow();
						this.dsOthinVrfc.setColumn(iFindRow, "othinVrfcScCd" , "GEH");   // 여성가족부
					}
				}else{
					this.divContent14.form.divContent01.form.rdoContent00.set_value('N'); // 요구하지않음 SET
					this.divContent14.form.divContent01.form.staResult.set_text("[검증불가]");
					this.divContent14.form.divContent01.form.btnContent00.set_enable(false);
					//this.smfAlert('한부모가족 대상자 정보가 없습니다.\n자격확인요청이 되지 않는 경우(또는 검증불가인 경우) 응시수수료 면제 증빙자료를 첨부하시기 바랍니다.');
					this.smfAlert('한부모가족 대상자 정보가 없습니다.\n자격확인요청이 되지 않는 경우(또는 검증불가인 경우)\n응시수수료 면제 증빙자료를 첨부하시기 바랍니다.\n또한 응시수수료 결제를 완료해야 원서가 접수되며\n추후 대상자 확정 시환불처리 됩니다.\n※ 증빙자료 : 자격확인요청을 통해 검증이 되지 않거나,\n자격확인요청을 요구하지 않는 경우, 응시수수료 면제 신청서와 면제대상 증명서류를\n하나의 파일로 압축하여 성명-파일명으로 첨부\n(예) 홍길동-응시수수료면제증빙서류');
				}
			}	
	});	
};

//사진등록
this.divContent03_btnContent01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	var sBase64ImageData = "";

	var objParam = {
						type : "file"             // [필수] 이미지 전달 방식 ("data": base64형태의 데이터롤 이미지 전달, "file":팝업에서 파일선택)
					, 	data : sBase64ImageData   // [선택] (type="data"인 경우는 필수) 팝업에 전달할 이미지 데이터
				    ,   senderObj : obj
				   };

	var sPopupId = "popupImageCrop";
	this.smfImgCropPopup(objParam,sPopupId);
	
};

//응시료 면제자 동의여부
this.divContent14_divContent01_rdoContent00_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	var rlesVrfcScsYn = this.dsMain.getColumn(0, "rlesVrfcScsYn");//검증여부
	var aplemFeeExmpTrgtScCd = this.dsMain.getColumn(0, "aplemFeeExmpTrgtScCd");//응시료 면제 구분
	// 요구함 선택, 검증버튼 활성
	if( obj.value === 'Y' ) {
		
		
		if(!this.smfIsNull(this.dsMain.getColumn(0, "rlesVrfcFileRefrnId"))){
			var returnValue = this.smfConfirm("응시료 면제 증빙자료가 삭제 됩니다. 계속 진행하시겠스니까?", function(result){
				if(result.confirmResult){
				
					this.divContent14.form.divContent03.form.divRlesVrfcFile.form.fnResetUpload(); //초기화
					this.dsMain.setColumn(0, "rlesVrfcFileRefrnId", '');
					if(aplemFeeExmpTrgtScCd == "1"){
					
						this.divContent14.form.divContent00.form.btnContent00.set_enable(true);
					}else{
						this.divContent14.form.divContent01.form.btnContent00.set_enable(true);
						this.divContent14.form.divContent01.form.edtRlesRegNo20.set_enable(true); //한부모가정 번호 활성
					}
					
					
					this.divContent14.form.divContent03.set_enable(false); //응시료면제증빙자료
				}else{
					this.dsMain.setColumn(0, "pvsnPrcusAgreYn", e.prevalue);
				}
				
			});
			
		}else{
			if(aplemFeeExmpTrgtScCd == "1"){
					
				this.divContent14.form.divContent00.form.btnContent00.set_enable(true);
			}else{
				this.divContent14.form.divContent01.form.btnContent00.set_enable(true);
				this.divContent14.form.divContent01.form.edtRlesRegNo20.set_enable(true); //한부모가정 번호 활성
			}
			this.divContent14.form.divContent03.set_enable(false); //응시료면제증빙자료
		}
		
	}else{
	
		
		if(rlesVrfcScsYn === "Y"){
			var returnValue = this.smfConfirm("자격확인요청 내용이 초기화 됩니다. 계속 진행하시겠습니까?", function(result){
			
				if(result.confirmResult){
				
					//응시료 면제구분값이 변경되면 데이터 초기화
					this.divContent14.form.divContent00.form.staResult.set_text("[미검증]");
					this.divContent14.form.divContent01.form.staResult.set_text("[미검증]"); 
					this.dsMain.setColumn(0, "rlesVrfcScsYn", "N");
					this.dsMain.setColumn(0, "rlesVrfcCn", "");
					this.dsMain.setColumn(0 ,"rlesYn", "N");
					this.dsMain.setColumn(0 ,"rlesRegNo10", "");
					this.dsMain.setColumn(0 ,"rlesRegNo20", "");
					this.divContent14.form.divContent00.form.btnContent00.set_enable(false);
					this.divContent14.form.divContent01.form.btnContent00.set_enable(false);
					this.divContent14.form.divContent01.form.edtRlesRegNo20.set_enable(false); //한부모가정번호 비활성
					this.divContent14.form.divContent03.set_enable(true); //응시료면제증빙자료
				}else{
					this.dsMain.setColumn(0, "pvsnPrcusAgreYn", e.prevalue);
				}
			});
			
		}else{
			if(aplemFeeExmpTrgtScCd == "1"){
				this.divContent14.form.divContent00.form.btnContent00.set_enable(false);
			}else{
				this.divContent14.form.divContent01.form.edtRlesRegNo20.set_enable(false); //한부모가정번호 비활성
				this.divContent14.form.divContent01.form.btnContent00.set_enable(false);
			}
			
			this.divContent14.form.divContent03.set_enable(true); //응시료면제증빙자료
		}
		
	}
};

//E-MAIL 변경시 
this.divContent03_cboEmlAddr2_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	if(e.postvalue == "") {
		//직접입력일경우 
		this.divContent03.form.edtEmlAddr3.set_readonly(false);
		this.divContent03.form.edtEmlAddr3.set_value("");
	}else{
		this.divContent03.form.edtEmlAddr3.set_readonly(true);
		this.divContent03.form.edtEmlAddr3.set_value(e.postvalue);
	}	
};

//교원 경력 유무 변경시 
this.divContent13_rdoAdpnTrgtCarrYn_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	if(e.postvalue == "Y"){
		//경력이 존재했을 경우 지역가산점 입력 못함 
		this.dsMain.setColumn(0,"dstrtAdpnValue","");
		this.dsMain.setColumn(0, "dstrtAdpnFileRefrnId", "");
		//this.divContent13.form.divDstrtAdpnFile.form.edtFile.set_value("");
		this.divContent13.form.cboDstrtAdpn.set_enable(false);
		//this.divContent13.form.divDstrtAdpnFile.set_enable(false);
		
		//this.smfClearRulesetToComponent(this.divContent13.form.cboDstrtAdpn);
	}else{
		this.divContent13.form.cboDstrtAdpn.set_enable(true);
		//this.divContent13.form.divDstrtAdpnFile.set_enable(true);
		
		//this.smfUpdateValidateToComponent("title:지역가산점,required", this.divContent13.form.cboDstrtAdpn);
	}
};

// 임신부 편의요청선택
this.divContent09_cboPgnwCnvPvsnDmndYn_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	if(obj.value === 'Y'){
		/*초등 협의회 요청
	     확인이 안되는 경우 안내 문구 추가
	    */
		this.smfAlert("※ 증빙자료 : 편의제공을 요청한 경우, 편의제공 신청서, 의사진단(소견서)를 하나의 파일로 압축하여 성명-파일명으로 첨부\n(예) 홍길동-편의제공증빙서류"); 
		this.divContent09.form.divPgnwCnvFile.set_enable(true);
		this.divContent09.form.btnAtchFileDel03.set_enable(true); //증빙자료 삭제버튼
	}else{
		this.divContent09.form.divPgnwCnvFile.set_enable(false);
		this.divContent09.form.btnAtchFileDel03.set_enable(false); //증빙자료 삭제버튼
	}
	
};

