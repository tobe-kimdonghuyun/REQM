/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 this.fnMainSetting = function(chk)
{
	//미반영 선택 시 석차, 총원 빈값으로 표기
	if(this.divContent06.form.rdoUvstScreRfltScCd.index==3 || this.divContent06.form.rdoUvstScreRfltScCd.index==4)
	{
		this.divContent06.form.edtUvstScreRank.set_value("");
		this.divContent06.form.edtUvstScreWhprCnt.set_value("");
	}
	
	// 주민번호
	var applpRrno =  this.dsMain.getColumn(0, "applpRrno");
	// 성별 :  default 여
	var sxdsCd = "2";
	// 주민번호 뒷자리 [남성] 1,3,5(외국인),7(외국인) [여성] 2,4,6(외국인),8(외국인)
	var sxdsNo = applpRrno.slice(6, 7);
	if(sxdsNo === "1" || sxdsNo === "3" || sxdsNo === "5" || sxdsNo === "7"){
		sxdsCd = "1";
	}
	// 성별코드 Set
	this.dsMain.setColumn(0, 'sxdsCd', sxdsCd);
	
	// 출생년도 앞 2자리 처리
	var applpBrdtYY = "19";
	// 주민번호 뒷자리 3,4,7(외국인),8(외국인)  = 2000년대 출생
	if(sxdsNo === "3" || sxdsNo === "4" || sxdsNo === "7" || sxdsNo === "8"){
		applpBrdtYY ="20";
	}
	var applpBrdt = applpBrdtYY+applpRrno.slice(0, 6);
	// 생년월일 Set
	this.dsMain.setColumn(0, 'applpBrdt', applpBrdt);
	
	// 휴대전화
	if(!this.smfIsNull(this.dsMain.getColumn(0, "mblTelno"))){
		var mblTelno = this.dsMain.getColumn(0, "mblTelno").split("-");
		this.dsMain.setColumn(0, "mblTelno1", mblTelno[0]);	
		this.dsMain.setColumn(0, "mblTelno2", mblTelno[1]);	
		this.dsMain.setColumn(0, "mblTelno3", mblTelno[2]);	
	}

	// 비상연락처
	var emgCnctTelno = this.dsMain.getColumn(0, "emgCnctTelno").split("-");
	this.dsMain.setColumn(0, "emgCnctTelno1", emgCnctTelno[0]);	
	this.dsMain.setColumn(0, "emgCnctTelno2", emgCnctTelno[1]);	
	this.dsMain.setColumn(0, "emgCnctTelno3", emgCnctTelno[2]);	


	//응시교과가 초등교사, 유치원, 특수유치원, 특수초등학교인 경우 자동설정
	if(this.pv_params.appoFieldCd == "001"){//초등교사
		this.dsTchQlfAsortScCd.filter("unyCdValue == '' || unyCdValue == '" + "002'");
	}else if(this.pv_params.appoFieldCd == "003"){//유치원교사
		this.dsTchQlfAsortScCd.filter("unyCdValue == '' || unyCdValue == '" + "005'");
	}else if(this.pv_params.appoFieldCd == "005"){//특수(유치원)교사
		this.dsTchQlfAsortScCd.filter("unyCdValue == '' || unyCdValue == '" + "022'");
	}else if(this.pv_params.appoFieldCd == "006"){//특수(초등)교사
		this.dsTchQlfAsortScCd.filter("unyCdValue == '' || unyCdValue == '" + "023'");
	}
	
	// 학력정보 탭 처리
	var grdtnScCd = this.dsMain.getColumn(0, "grdtnScCd");//졸업여부
	var tchQlfVrfcPassvYn = this.dsMain.getColumn(0, "tchQlfVrfcPassvYn");//조회가 안되는 경우
	
	//졸업여부를 선택하지 않은 경우
	if(grdtnScCd == "1"){
		this.divContent05.form.chkTchQlfVrfcPassvYn.set_enable(true);
		//this.divContent05.form.btnContent00.set_enable(true);
		
	}else if(grdtnScCd == "6"){
		
		this.divContent05.form.chkTchQlfVrfcPassvYn.set_enable(false);
		//this.divContent05.form.btnContent00.set_enable(false);
	
	}
	this.divContent05.form.chkTchQlfVrfcPassvYn.set_value(tchQlfVrfcPassvYn == "Y" ? true : false);
	this.fnAcbgTabChange(tchQlfVrfcPassvYn == "Y" ? true : false);
	

	

	// 학교별 채용 체크
	this.fnSchoolCheck();

	// 한국사 취득/예정자 처리
	if( this.dsMain.getColumn(0, "krhisAcqsParngYn") == 'Y' ) {
		this.fnKrhisYnChange(true);
	} else {
		this.fnKrhisYnChange(false);
	}

	// 장애인 응시자 체크
	if( this.dsMain.getColumn(0, "dltScCd") != '0' ) {
		this.fnDltCheck(true);
		this.divContent08.form.chkContent01.set_value(true);
	} else {
		this.fnDltCheck(false);
		this.divContent08.form.chkContent01.set_value(false);
	}
	
	// 임신부 응시자 체크
	/*if( sxdsCd == '1' ) { //남자면 임신부 관련 비활성
		this.divContent09.set_enable(false);
	} else if( this.dsMain.getColumn(0, "pgnwCnvPvsnDmndYn") == 'Y' ) {
		this.fnPgnwCnvCheck(true);
		this.divContent09.form.chkContent01.set_value(true);
	} else {
		this.fnPgnwCnvCheck(false);
		this.divContent09.form.chkContent01.set_value(false);
	}*/	
	
	 if(this.dsMain.getColumn(0, "pgnwCnvPvsnDmndYn") === 'Y' ){
		this.divContent09.form.divPgnwCnvFile.set_enable(true);
		this.divContent09.form.btnAtchFileDel03.set_enable(true);
	 }else{
		this.divContent09.form.divPgnwCnvFile.set_enable(false);
		this.divContent09.form.btnAtchFileDel03.set_enable(false);
	 }

	// 병력구분 체크
	if( sxdsCd == '2' ) { //여자면 병력 관련 비활성
		this.divContent10.set_enable(false);
	}

	// 취업지원대상자 체크
	if( !this.smfIsNull(this.dsMain.getColumn(0, "soctyFrgltSclsrCd")) || 
		!this.smfIsNull(this.dsMain.getColumn(0, "emploSprtAdpnValue")) || 
		!this.smfIsNull(this.dsMain.getColumn(0, "emploSprtFileRefrnId")) ) {
		this.fnEmploSprtCheck(true);
		this.divContent11.form.chkContent01.set_value(true);
	} else {
		this.fnEmploSprtCheck(false);
		this.divContent11.form.chkContent01.set_value(false);
	}

	// 의사상자 체크
	if( !this.smfIsNull(this.dsMain.getColumn(0, "mertNo")) || 
		!this.smfIsNull(this.dsMain.getColumn(0, "mertAdpnValue")) || 
		!this.smfIsNull(this.dsMain.getColumn(0, "mertFileRefrnId")) ) {
		this.fnTmeMertCheck(true);
		this.divContent12.form.chkContent01.set_value(true);
	} else {
		this.fnTmeMertCheck(false);
		this.divContent12.form.chkContent01.set_value(false);
	}

	this.fnDstrtCheck(true,chk);
	
	// 지역가산점 체크
	/*
	if( this.dsMain.getColumn(0, "adpnTrgtCarrYn") == 'Y' || 
		!this.smfIsNull(this.dsMain.getColumn(0, "dstrtAdpnValue")) ) {
		this.fnDstrtCheck(true);
		this.divContent13.form.chkContent01.set_value(true);
	} else {
		this.fnDstrtCheck(false);
		this.divContent13.form.chkContent01.set_value(false);
	}*/
	
	if(this.dsMain.getColumn(0,"aplemFeeExmpTrgtScCd") != "0"){
		this.divContent14.form.chkContent01.enableevent = false;
		this.divContent14.form.chkContent01.set_value(true);
		this.divContent14.form.chkContent01.enableevent = true;
	}
	// 응시료면제 체크
	this.fnRlesCheck( this.dsMain.getColumn(0, "aplemFeeExmpTrgtScCd") );

	// 업로드 초기설정 - 대학성적증명자료
	//this.divContent06.form.divUvstScreFile.UPLOAD_UploadComplete = this.fnFileUploadCompleteCallback;
	//this.divContent06.form.divUvstScreFile.UPLOAD_OnError        = this.fnFileUploadErrorCallback;
	//this.divContent06.form.divUvstScreFile.UPLOAD_AfterAddFile   = this.fnFileUploadChangeCallback;     
	//this.divContent06.form.divUvstScreFile.UPLOAD_Form           = this;

	// 업로드 초기설정 - 취업지원대상자
	//this.divContent11.form.divEmploSprtFile.UPLOAD_UploadComplete = this.fnFileUploadCompleteCallback;
	//this.divContent11.form.divEmploSprtFile.UPLOAD_OnError        = this.fnFileUploadErrorCallback;
	//this.divContent11.form.divEmploSprtFile.UPLOAD_AfterAddFile   = this.fnFileUploadChangeCallback;     
	//this.divContent11.form.divEmploSprtFile.UPLOAD_Form           = this;

	// 업로드 초기설정 - 의사상자
	//this.divContent12.form.divMertFile.UPLOAD_UploadComplete = this.fnFileUploadCompleteCallback;
	//this.divContent12.form.divMertFile.UPLOAD_OnError        = this.fnFileUploadErrorCallback;
	//this.divContent12.form.divMertFile.UPLOAD_AfterAddFile   = this.fnFileUploadChangeCallback;     
	//this.divContent12.form.divMertFile.UPLOAD_Form           = this;
	
	// 업로드 초기설정 - 응시료면제자
	this.divContent14.form.divContent03.form.divRlesVrfcFile.UPLOAD_UploadComplete = this.fnFileUploadCompleteCallback;
	this.divContent14.form.divContent03.form.divRlesVrfcFile.UPLOAD_OnError        = this.fnFileUploadErrorCallback;
	this.divContent14.form.divContent03.form.divRlesVrfcFile.UPLOAD_AfterAddFile   = this.fnFileUploadChangeCallback;     
	this.divContent14.form.divContent03.form.divRlesVrfcFile.UPLOAD_Form           = this;
	
	// 업로드 초기설정 - 2023.03.30 추가 
	this.divContent05.form.divContent01.form.divTchQlfFileRefrnFile.UPLOAD_UploadComplete = this.fnFileUploadCompleteCallback;
	this.divContent05.form.divContent01.form.divTchQlfFileRefrnFile.UPLOAD_OnError        = this.fnFileUploadErrorCallback;
	this.divContent05.form.divContent01.form.divTchQlfFileRefrnFile.UPLOAD_AfterAddFile   = this.fnFileUploadChangeCallback;     
	this.divContent05.form.divContent01.form.divTchQlfFileRefrnFile.UPLOAD_Form           = this;
	this.divContent07.form.divKrhisCetFileRefrnFile.UPLOAD_UploadComplete = this.fnFileUploadCompleteCallback;
	this.divContent07.form.divKrhisCetFileRefrnFile.UPLOAD_OnError        = this.fnFileUploadErrorCallback;
	this.divContent07.form.divKrhisCetFileRefrnFile.UPLOAD_AfterAddFile   = this.fnFileUploadChangeCallback;     
	this.divContent07.form.divKrhisCetFileRefrnFile.UPLOAD_Form           = this;
	this.divContent08.form.divDltCnvFile.UPLOAD_UploadComplete = this.fnFileUploadCompleteCallback;
	this.divContent08.form.divDltCnvFile.UPLOAD_OnError        = this.fnFileUploadErrorCallback;
	this.divContent08.form.divDltCnvFile.UPLOAD_AfterAddFile   = this.fnFileUploadChangeCallback;     
	this.divContent08.form.divDltCnvFile.UPLOAD_Form           = this;
	this.divContent09.form.divPgnwCnvFile.UPLOAD_UploadComplete = this.fnFileUploadCompleteCallback;
	this.divContent09.form.divPgnwCnvFile.UPLOAD_OnError        = this.fnFileUploadErrorCallback;
	this.divContent09.form.divPgnwCnvFile.UPLOAD_AfterAddFile   = this.fnFileUploadChangeCallback;     
	this.divContent09.form.divPgnwCnvFile.UPLOAD_Form           = this;
	//this.divContent10.form.div09.form.divMtrscFlflFile.UPLOAD_UploadComplete = this.fnFileUploadCompleteCallback;
	//this.divContent10.form.div09.form.divMtrscFlflFile.UPLOAD_OnError        = this.fnFileUploadErrorCallback;
	//this.divContent10.form.div09.form.divMtrscFlflFile.UPLOAD_AfterAddFile   = this.fnFileUploadChangeCallback;     
	//this.divContent10.form.div09.form.divMtrscFlflFile.UPLOAD_Form           = this;
	// 2023.04.18 추가 
	//this.divContent13.form.divDstrtAdpnFile.UPLOAD_UploadComplete = this.fnFileUploadCompleteCallback;
	//this.divContent13.form.divDstrtAdpnFile.UPLOAD_OnError        = this.fnFileUploadErrorCallback;
	//this.divContent13.form.divDstrtAdpnFile.UPLOAD_AfterAddFile   = this.fnFileUploadChangeCallback;     
	//this.divContent13.form.divDstrtAdpnFile.UPLOAD_Form           = this;
	
	this.dsMain.set_updatecontrol(false);
	this.dsMain.setRowType(0,Dataset.ROWTYPE_NORMAL);
	this.dsMain.set_updatecontrol(true);
};

 // 개요 검색
this.fnSearch = function(rcptNo)
{
	// 서비스 객체 생성
	this.smfSearchService('selectAppoExam') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			// 접수문의번호
			var rcptQustTelNo = this.dsAppoOnlEmpmnMng.getColumn(0, 'rcptQustTelNo');
			var inquiry = this.elvRcptInquiryInfo(rcptQustTelNo);
			this.divContent16.form.staContent01.set_text(inquiry);
			
			
			// 개요 상세 정보 set
			if(this.smfIsNull(this.dsMain.getColumn(0, "appoExamMastrIdfId"))){
				this.dsMain.setColumn(0, 'appoExamMastrIdfId', this.dsAppoOnlEmpmnMng.getColumn(0, 'appoExamMastrIdfId')); // 임용시험마스터식별ID
			}			
			this.dsMain.setColumn(0, 'appoExamYr', this.dsAppoExam.getColumn(0, 'appoExamYr')); // 임용시험연도
			
			if(this.dsSprtMetList.getRowCount() > 0){
				var natnYn = this.dsSprtMetList.getColumn(0, "natnYn");
					
				if(natnYn == "Y"){
					//지원방법 임용시험개요가 공립/국립 여부에 따라 텍스트 변경
					this.dsPrivShlListTmp.setColumn(0, "privShlNm", "국립");
				}
			}
			
			

			// 지원방법 [선택] 항목 추가
			this.dsSprtMetList.insertRow(0);
			this.dsSprtMetList.setColumn(0, "prapShlSprtMthCd", "");
			this.dsSprtMetList.setColumn(0, "prapShlSprtMthNm", "- 선택 -");
			this.dsMain.setColumn(0, "prapShlSprtMthCd", "");

			
			

			//가산점
			//08: 국가유공자 , 17: 의사상자 , 09: 지역가산점 
			this.dsAdtnList.filter("adtnRealmCd == '08'");
			this.dsAdtnList08.copyData(this.dsAdtnList, true);
			this.dsAdtnList.filter("adtnRealmCd == '17'");
			this.dsAdtnList17.copyData(this.dsAdtnList, true);
			this.dsAdtnList.filter("adtnRealmCd == '09'");
			this.dsAdtnList09.copyData(this.dsAdtnList, true);
			
			if(this.dsAdtnList08.rowcount == 0 ){
				this.divContent11.form.chkContent01.set_enable(false);
			}
			if(this.dsAdtnList17.rowcount == 0 ){
				this.divContent12.form.chkContent01.set_enable(false);
			}
			if(this.dsAdtnList09.rowcount == 0 ){
				this.divContent13.form.chkContent01.set_enable(false);
			}
			
			if(this.dsKrhisRcgnCetYmdList.rowcount > 0){
				// 수정 2023.07.07 max값 칼럼 krhisRcgnTme에서 examYmd 변경, 소트 수정을 위해
				var examYmd = this.dsKrhisRcgnCetYmdList.getMax("examYmd");
				// 수정 2023.07.07 시험일자 칼럼examYmd의 가장 큰 날짜 smaxKrhisRcgnTme와 일치하는 시험일자examYmd  
				var dt = this.dsKrhisRcgnCetYmdList.lookup("examYmd", examYmd , "examYmd");
				var tme = this.dsKrhisRcgnCetYmdList.lookup("examYmd", examYmd , "krhisRcgnTme");
			
				if( !this.smfIsNull(dt) ){
				
					var arrDfk = ["일", "월", "화", "수", "목", "금", "토"];
					var rtnDft = 0;
					var year  = dt.substring(0, 4);
					var month = parseInt(dt.substring(4, 6))-1;
					var day   = dt.substring(6, 8);
					var tmpDt = new nexacro.Date(year, month, day);
					var rtnDft  = tmpDt.getDay();
					//* 시험종류 심화 (2020. 10. 24(토) 한국사능력검증 [심화과정] 시험접수자
					var txt = "* 제 " + tme + "회("+year+"년 "+dt.substring(4, 6)+"월 "+day+"일까지) 한국사 능력검증시험[심화과정] 접수자";
					this.divContent07.form.staContent08.set_text(txt);
				}
				// 수정 2023.07.07 findrow 칼럼 회차krhisRcgnTme 에서 시험일자examYmd 변경, maxrow 삭제 (취득예정자의 회차 날짜는 삭제)
				var maxRow = this.dsKrhisRcgnCetYmdList.findRow("examYmd", examYmd );
				this.dsKrhisRcgnCetYmdList.deleteRow(maxRow);
			}
			
			//2023.04.25 개요가 장애구분여부가 Y일경우 장애인 응시자 무조건 필수!
			if( this.dsAppoExam.getColumn(0, 'dltExamYn') == "Y" ){
				this.dsDltScCd.filter("unyCdValue != '0' && unyCdValue != '2' && unyCdValue != '22' && unyCdUseYn != 'N'");
				this.dsSedScCd.filter("unyCdValue >= '10' ");
			}
			
			//기술지원 2024.03.15
			// 시험장  DIV 영역 체크
			var exmrCnt = this.dsResultExmr.getRowCount();
			
			
			// 시험장이 없을경우
			if(exmrCnt === 0 ){
				
				// 시험장영역 숨김
				this.divExmrInfo.setOffsetHeight(0);
				
				// 시험장영역 비표시
				this.divExmrInfo.set_visible(false);
				
				// 전체영역  RESET
				this.smfResetScroll(this);	
			}else{
			
				// 시험장 [선택] 항목 추가
				this.dsResultExmr.insertRow(0);
				this.dsResultExmr.setColumn(0, "exmrDstrtNm", "- 선택 -");
				 
			}
			
			//수정일 경우 데이터 조회 
			if(!this.smfIsNull(rcptNo)){
				this.dsMain.clearData();
				this.dsSearch.setColumn(0,"rcptNo",rcptNo);
				
				/* 20240626 
				    selectlistApf, selectCheckData 를 비동기로 확인해도 되나,
					selectlistApf 동작후 selectCheckData하도록 변경
				*/
				this.smfSearchService('selectlistApf') 
				.run()
				// 콜백
				.callback(function(callbackParams){
							if(callbackParams.errors) return;			
				});

					this.fnMainSetting("1");
					this.dsMain.set_updatecontrol(false);
					this.fnCheckSprtMet( this.dsMain.getColumn(0,"prapShlSprtMthCd"), this.dsMain.getColumn(0,"sprt1RnkPrivShlCd"), this.dsMain.getColumn(0,"sprt2RnkPrivShlCd")); //1. 지원방법
					this.dsMain.set_updatecontrol(true);
					// 취업지원 가점 대상자 ON
					if(this.divContent11.form.chkContent01.value){
						this.divContent11.form.divEmploSprtFile.form.edtFile.set_value(this.dsMain.getColumn(0,"emploSprtFileRefrnNm"));
					}
					// 의사상자 가점 대상자 ON
					if(this.divContent12.form.chkContent01.value){
						this.divContent12.form.divMertFile.form.edtFile.set_value(this.dsMain.getColumn(0,"mertFileRefrnNm"));
					}
					//this.divContent06.form.divUvstScreFile.form.edtFile.set_value(this.dsMain.getColumn(0,"uvstScreFileRefrnNm"));
					//this.divContent11.form.divEmploSprtFile.form.edtFile.set_value(this.dsMain.getColumn(0,"emploSprtFileRefrnNm"));
					//this.divContent12.form.divMertFile.form.edtFile.set_value(this.dsMain.getColumn(0,"mertFileRefrnNm"));
					this.divContent14.form.divContent03.form.divRlesVrfcFile.form.edtFile.set_value(this.dsMain.getColumn(0,"rlesVrfcFileRefrnNm"));
					//2023.03.30 추가 
					this.divContent05.form.divContent01.form.divTchQlfFileRefrnFile.form.edtFile.set_value(this.dsMain.getColumn(0,"tchQlfFileRefrnNm"));
					// 한국사 취득자
					if(this.divContent07.form.chkContent01.value){
						this.divContent07.form.divKrhisCetFileRefrnFile.form.edtFile.set_value(this.dsMain.getColumn(0,"krhisCetFileRefrnNm"));
					}
					// 장애인 응시자 ON
					if(this.divContent08.form.chkContent01.value ){
						this.divContent08.form.divDltCnvFile.form.edtFile.set_value(this.dsMain.getColumn(0,"dltCnvFileRefrnNm"));
					}
					//임산부 편의 :있음
					//if('Y' === this.divContent09.form.cboPgnwCnvPvsnDmndYn.value){
						this.divContent09.form.divPgnwCnvFile.form.edtFile.set_value(this.dsMain.getColumn(0,"pgnwCnvFileRefrnNm"));
					//}
					//this.divContent10.form.div09.form.divMtrscFlflFile.form.edtFile.set_value(this.dsMain.getColumn(0,"mtrscFlflFileRefrnNm"));
					//2023.04.18 추가
					//this.divContent13.form.divDstrtAdpnFile.form.edtFile.set_value(this.dsMain.getColumn(0,"dstrtAdpnFileRefrnNm"));
					
					//E-MAIL
					var emlAddr = this.dsMain.getColumn(0,"emlAddr").split("@");
					this.dsMain.setColumn(0, "emlAddr1", emlAddr[0]);	
					this.dsMain.setColumn(0, "emlAddr2", emlAddr[1]);	
					this.dsMain.setColumn(0, "emlAddr3", emlAddr[1]);	
					if(this.divContent03.form.cboEmlAddr2.index == -1){
						this.dsMain.setColumn(0, "emlAddr2", "");	 //직접입력
					}
					
					//2023.04.25 개요가 장애구분여부가 Y일경우 장애인 응시자 무조건 필수!
					if( this.dsAppoExam.getColumn(0, 'dltExamYn') == "Y" ){
						this.fnDltCheck(true);
						this.divContent08.form.chkContent01.set_value(true);
						this.divContent08.form.chkContent01.set_enable(false);
					}
					
					// 사진 set (413 error : request entity too large 해결 )
					if(!this.smfIsNull(this.dsMain.getColumn(0,"apstPhotoFileCn"))){
						this.divContent03.form.imgCrop.set_stretch('fit');
						this.divContent03.form.imgCrop.set_text('');
						this.divContent03.form.imgCrop.set_image(this.dsMain.getColumn(0, "apstPhotoFileCn"));
						this.dsMain.setColumn(0, "apstPhotoFileCn", "");
					}else{
						this.divContent03.form.imgCrop.set_image("");
					}
			}else{
				this.fnMainSetting("2");
				
				//2023.04.25 개요가 장애구분여부가 Y일경우 장애인 응시자 무조건 필수!
				if( this.dsAppoExam.getColumn(0, 'dltExamYn') == "Y" ){
					this.fnDltCheck(true);
					this.dsMain.setColumn(0,"dltScCd","");
					this.dsMain.setColumn(0,"dltClaCd","");
					this.divContent08.form.chkContent01.set_value(true);
					this.divContent08.form.chkContent01.set_enable(false);
				}
				
				//사진 set
				this.divContent03.form.imgCrop.set_image("");
			}
			
			//수정여부 
			//  지원서 가능 여부 체크 데이터- 비동기 = false
			this.smfSearchService('selectCheckData') 
				.run()
				// 콜백
				.callback(function(callbackParams){
					if(callbackParams.errors){
					
						this.fnComponentDisable();
						return;
					}
					
					if(this.gotoPay =="Y"){
						this.divContent15_btnContent01_onclick();
						this.gotoPay = "N";
					}
					
					
			});

			
			
			
	});
	
	
};

/**
 * 원서접수 문자발송정보 SET
 **/
this.fnSetSaveRcptSmsInfo = function(){
	// 초기화
	this.dsRcptSms.clearData();
	this.dsRcptSms.addRow();
	this.dsRcptSms.setColumn(0, 'appoExamScCd' , this.smfGetAppoExamScCd()); //임용시험구분코드
	this.dsRcptSms.setColumn(0, 'cddcScCd' ,this.smfGetCddcCode().slice(0,3)); //시도교육청구분코드
	this.dsRcptSms.setColumn(0, 'cddcNm' , this.smfGetCddcName()); //시도교육청명
	this.dsRcptSms.setColumn(0, 'rcptQustTelNo' , this.dsAppoOnlEmpmnMng.getColumn(0, 'rcptQustTelNo')); //발신번호
	this.dsRcptSms.setColumn(0, 'mblTelno' , this.dsMain.getColumn(0, "mblTelno")); //수신번호
};

// 저장전 데이터 처리
this.fnBeforeSave = function() 
{
	// 휴대전화 조합
	var mblTelno1 = this.dsMain.getColumn(0, "mblTelno1");	
	var mblTelno2 = this.dsMain.getColumn(0, "mblTelno2");	
	var mblTelno3 = this.dsMain.getColumn(0, "mblTelno3");
	var mblTelno = [mblTelno1, mblTelno2, mblTelno3].join("-"); 
	if ( mblTelno == "--" ) mblTelno = "";
	this.dsMain.setColumn(0, "mblTelno", mblTelno);
	
	// 비상연락처 조합
	var emgCnctTelno1 = this.dsMain.getColumn(0, "emgCnctTelno1");	
	var emgCnctTelno2 = this.dsMain.getColumn(0, "emgCnctTelno2");	
	var emgCnctTelno3 = this.dsMain.getColumn(0, "emgCnctTelno3");
	var emgCnctTelno = [emgCnctTelno1, emgCnctTelno2, emgCnctTelno3].join("-"); 
	if ( emgCnctTelno == "--" ) emgCnctTelno = "";
	this.dsMain.setColumn(0, "emgCnctTelno", emgCnctTelno);
};

// 저장후 데이터 처리
this.fnAfterSave = function()
{
	// 접수번호가 없으면 생성된 접수번호 셋팅
	if( !this.dsMain.getColumn(0, "rcptNo") ) {
		this.dsMain.setColumn(0, "rcptNo", this.dsResult.getColumn(0, "rcptNo"));
	}
};

// 학력정보 검증 탭 처리
this.fnAcbgTabChange = function(isChecked)
{
	//학력정보 수동검증 플래그 업데이트
	this.dsMain.setColumn(0, "tchQlfVrfcPassvYn", isChecked ? "Y" : "N");
	// visible 변경
	this.divContent05.form.divContent00.set_visible(!isChecked); //검증탭
	this.divContent05.form.divContent01.set_visible(isChecked); //미검증탭
	
	
	//수동검증
	if(isChecked){
		// 검증탭 validate 제거
		this.smfClearRulesetToComponent(this.divContent05.form.edtTchQlflCtrCd);
		this.divContent05.form.edtTchQlflCtrCd.set_enable(false);
		this.divContent05.form.btnContent00.set_enable(false);
		// 미검증탭 validate 추가
		this.smfUpdateValidateToComponent("title:교원자격증종별,required", this.divContent05.form.divContent01.form.cboTchQlfAsortScCdN);
		this.smfUpdateValidateToComponent("title:교원자격증급별,required", this.divContent05.form.divContent01.form.cboLsgByScNmN);
		this.smfUpdateValidateToComponent("title:발급기관명,required", this.divContent05.form.divContent01.form.edtTchQlfInstNmN);
	
	}else{
	
		var grdtnScCd = this.dsMain.getColumn(0, "grdtnScCd");//졸업여부
		//졸업여부를 선택하지 않은 경우
		if(grdtnScCd == ""){
			this.divContent05.form.edtTchQlflCtrCd.set_enable(false);//자격번호
			this.divContent05.form.btnContent00.set_enable(false);//교원자격조회버튼
		
		}else{
			// 자격번호, 검증버튼 사용여부 처리
			this.divContent05.form.edtTchQlflCtrCd.set_enable(true);//자격번호
			this.divContent05.form.btnContent00.set_enable(true);//교원자격조회버튼
			
			// 검증탭 validate 추가
			this.smfUpdateValidateToComponent("title:자격번호,required,maxlengthB:10", this.divContent05.form.edtTchQlflCtrCd);
			
			// 미검증탭 validate 제거
			this.smfClearRulesetToComponent(this.divContent05.form.divContent01.form.cboTchQlfAsortScCdN);
			this.smfClearRulesetToComponent(this.divContent05.form.divContent01.form.cboLsgByScNmN);
			this.smfClearRulesetToComponent(this.divContent05.form.divContent01.form.edtTchQlfInstNmN);
		}
		
		
	
	}
	
}

// 학교별 채용 체크
this.fnSchoolCheck = function()
{
	if( this.dsMain.getColumn(0, 'currCd') == '001' ) { //초등일 경우 추가
		this.smfUpdateValidateToComponent("title:대학성적반영구분,required", this.divContent06.form.rdoUvstScreRfltScCd);
		this.smfUpdateValidateToComponent("title:석차,required,decimal:4", this.divContent06.form.edtUvstScreRank);
		this.smfUpdateValidateToComponent("title:총원,required,decimal:4", this.divContent06.form.edtUvstScreWhprCnt);
		this.smfUpdateValidateToComponent("title:대학성적미발급사유,required", this.divContent06.form.rdoUvstScreNsbmtReasoSbmsnYn);
		//this.smfUpdateValidateToComponent("title:대학성적증빙자료,required", this.divContent06.form.divUvstScreFile);
		//this.smfUpdateValidateToComponent("title:대학성적증빙자료,required", this.divContent06.form.divUvstScreFile.form.edtFile);
	} else { //초등이 아닐경우 제거
		
		this.divContent06.set_enable(false);
		this.smfClearRulesetToComponent(this.divContent06.form.rdoUvstScreRfltScCd);
		this.smfClearRulesetToComponent(this.divContent06.form.edtUvstScreRank);
		this.smfClearRulesetToComponent(this.divContent06.form.edtUvstScreWhprCnt);
		this.smfClearRulesetToComponent(this.divContent06.form.rdoUvstScreNsbmtReasoSbmsnYn);
		//this.smfClearRulesetToComponent(this.divContent06.form.divUvstScreFile);
		//this.smfClearRulesetToComponent(this.divContent06.form.divUvstScreFile.form.edtFile);
		
		// 지역가산점영역 숨김
		this.divContent06.setOffsetHeight(0);
		
		// 지역가산점영역 비표시
		this.divContent06.set_visible(false);
		
		// 전체영역  RESET
		this.smfResetScroll(this);	
	}
}

// 한국사 취득 예정 처리
this.fnKrhisYnChange = function(isChecked)
{	
	//한국사 취득 예정 플래그 업데이트
	this.dsMain.setColumn(0, "krhisAcqsParngYn", isChecked ? "Y" : "N");

	this.divContent07.form.chkContent01.set_value(!isChecked);
	this.divContent07.form.chkContent02.set_value(isChecked);

	// 한국사 취득자 처리
	this.divContent07.form.cboKrhisRcgnTmeN.set_enable(!isChecked);
	this.divContent07.form.edtKrhisRcgnCetNo2.set_enable(!isChecked);
	this.divContent07.form.chkContent00.set_enable(!isChecked);
	this.divContent07.form.cboKrhisAplemClaScCdN.set_enable(!isChecked);
	this.divContent07.form.divKrhisCetFileRefrnFile.set_enable(!isChecked);
	this.divContent07.form.btnAtchFileDel01.set_enable(!isChecked); //증빙자료 삭제버튼
	this.divContent07.form.btnContent00.set_enable(!isChecked);

	// 한국사 취득 예정자 처리
	this.divContent07.form.cboKrhisAplemClaScCdP.set_enable(isChecked);
	this.divContent07.form.edtKrhisExmtNo.set_enable(isChecked);
	
	// 한국사 검증 탭 처리
	if( !isChecked ) {
		// 한국사 수동 검증 처리
		if( this.dsMain.getColumn(0, "krhisVrfcPassvYn") == 'Y' ) {
			this.divContent07.form.chkContent00.set_value(true);
			this.fnKrhisTabChange(true);
		} else {
			this.divContent07.form.chkContent00.set_value(false);
			this.fnKrhisTabChange(false);
		}
		
		// 한국사 취득 예정자 validate 제거
		this.smfClearRulesetToComponent(this.divContent07.form.cboKrhisAplemClaScCdP);
		this.smfClearRulesetToComponent(this.divContent07.form.edtKrhisExmtNo);
	} else {
		// 한국사 취득자 validate 제거
		this.smfClearRulesetToComponent(this.divContent07.form.cboKrhisRcgnTmeN);
		this.smfClearRulesetToComponent(this.divContent07.form.edtKrhisRcgnCetYmdN);
		this.smfClearRulesetToComponent(this.divContent07.form.edtKrhisRcgnCetNo1);
		this.smfClearRulesetToComponent(this.divContent07.form.edtKrhisRcgnCetNo2);
		this.smfClearRulesetToComponent(this.divContent07.form.cboKrhisAplemClaScCdN);
		
		// 한국사 취득 예정자 validate 추가
		this.smfUpdateValidateToComponent("title:시험종류,required", this.divContent07.form.cboKrhisAplemClaScCdP);
		this.smfUpdateValidateToComponent("title:접수번호,required,maxlengthB:10", this.divContent07.form.edtKrhisExmtNo);
	}
}

// 한국사 수동 검증 탭 처리
this.fnKrhisTabChange = function(isChecked)
{
	//한국사 수동검증 플래그 업데이트
	this.dsMain.setColumn(0, "krhisVrfcPassvYn", isChecked ? "Y" : "N");
	
	this.divContent07.form.cboKrhisAplemClaScCdN.set_enable(isChecked);      //합격등급 
	this.divContent07.form.divKrhisCetFileRefrnFile.set_enable(isChecked);   //증명자료
	this.divContent07.form.btnAtchFileDel01.set_enable(isChecked); //증빙자료 삭제 버튼
	
	if( isChecked ) {
		// 한국사 인증 validate 제거
		this.smfClearRulesetToComponent(this.divContent07.form.cboKrhisRcgnTmeN);
		this.smfClearRulesetToComponent(this.divContent07.form.edtKrhisRcgnCetYmdN);
		this.smfClearRulesetToComponent(this.divContent07.form.edtKrhisRcgnCetNo1);
		this.smfClearRulesetToComponent(this.divContent07.form.edtKrhisRcgnCetNo2);

		// 한국사 미인증 validate 추가
		this.smfUpdateValidateToComponent("title:합격등급,required", this.divContent07.form.cboKrhisAplemClaScCdN);
		
		
		
	} else {
		
		// 한국사 미인증 validate 제거
		this.smfClearRulesetToComponent(this.divContent07.form.cboKrhisAplemClaScCdN);
		
		
		// 한국사 인증 validate 추가
		this.smfUpdateValidateToComponent("title:회차,required", this.divContent07.form.cboKrhisRcgnTmeN);
		this.smfUpdateValidateToComponent("title:일자,required", this.divContent07.form.edtKrhisRcgnCetYmdN);
		this.smfUpdateValidateToComponent("title:인증번호,required", this.divContent07.form.edtKrhisRcgnCetNo1);
