              <Static id="staGd01" taborder="9" left="0" top="50" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staContent01" taborder="10" text="&lt;fs v='12'&gt;관련 법에 따른 면제자격 확인을 요구하여, 검증되면 응시수수료가 결제되지 않습니다.&lt;/fs&gt;" left="0" top="113" width="1199" height="39" cssclass="sta_WF_Lable" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
