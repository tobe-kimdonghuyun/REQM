// 지원방법 변경시
this.divContent04_cboContent00_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	/*결제완료 시 지원방법 변경 못하게 2023.9.12
	this.smfAlert("원래 꺼"+e.preindex);*/
	if('Y' ==this.dsMain.getColumn(0, 'stlmYn'))
	{
		this.smfAlert("지원자가 선택한 지원방법(공립(국립), 사립 등)이 접수완료된 지원방법과 다릅니다.\n해당 내용을 수정하기 위해서는 마이페이지-원서접수내역에서 '결제취소'를 먼저 진행해주시기 바랍니다.");
		obj.set_index(e.preindex);
		//this.smfAlert(this.dsMain.getColumn(0, 'stlmYn'));
