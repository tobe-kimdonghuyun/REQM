// 지역가산점 처리
this.fnDstrtCheck = function(isChecked, chk)
{

	
	if( this.dsMain.getColumn(0, 'currCd') == '001') { //초등일 경우 추가
		this.divContent13.form.chkContent01.set_value(true);
		if( isChecked ) {
			// validate 추가
			this.smfUpdateValidateToComponent("title:교원경력유무,required", this.divContent13.form.rdoAdpnTrgtCarrYn);

			// 화면처리
			this.divContent13.form.rdoAdpnTrgtCarrYn.set_enable(true);
			if(chk == "2") //수정이 아닐 경우
			{
				this.divContent13.form.rdoAdpnTrgtCarrYn.index = -1;
				this.divContent13.form.rdoAdpnTrgtCarrYn.set_value( "" );
			}	

			if(this.divContent13.form.rdoAdpnTrgtCarrYn.value == "N"){
				this.divContent13.form.cboDstrtAdpn.set_enable(true);
				//this.divContent13.form.divDstrtAdpnFile.set_enable(true);
			}else{
				this.divContent13.form.cboDstrtAdpn.set_enable(false);
				//this.divContent13.form.divDstrtAdpnFile.set_enable(false);
			}
		} else {
			// validate 제거
			this.smfClearRulesetToComponent(this.divContent13.form.rdoAdpnTrgtCarrYn);
			
			// 화면처리
			this.divContent13.form.rdoAdpnTrgtCarrYn.set_enable(false);
			this.divContent13.form.cboDstrtAdpn.set_enable(false);
			//this.divContent13.form.divDstrtAdpnFile.set_enable(false);

			// 초기화
			this.dsMain.setColumn(0, "adpnTrgtCarrYn", "N"); 
			this.dsMain.setColumn(0, "dstrtAdpnValue", "");
			this.dsMain.setColumn(0, "dstrtAdpnFileRefrnId", "");
			//this.divContent13.form.divDstrtAdpnFile.form.edtFile.set_value("");
		}
	}else{
		
		this.smfClearRulesetToComponent(this.divContent13.form.rdoAdpnTrgtCarrYn);
		this.smfClearRulesetToComponent(this.divContent13.form.cboDstrtAdpn);
		
		// 지역가산점영역 숨김
		this.divContent13.setOffsetHeight(0);
		
		// 지역가산점영역 비표시
		this.divContent13.set_visible(false);
		
		// 전체영역  RESET
		this.smfResetScroll(this);	
		
		
		
	}
};

// 응시료면제 처리
this.fnRlesCheck = function(v)
{
	this.divContent14.form.divContent00.set_visible(false);
	this.divContent14.form.divContent00.set_enable(true);
	this.divContent14.form.divContent01.set_visible(false);
	this.divContent14.form.rdoRlesScCd.set_enable(true);

	// validate 제거
	this.smfClearRulesetToComponent(this.divContent14.form.divContent01.form.edtRlesRegNo20);
	this.smfClearRulesetToComponent(this.divContent14.form.divContent03.form.divRlesVrfcFile);
	this.smfClearRulesetToComponent(this.divContent14.form.divContent03.form.divRlesVrfcFile.form.edtFile);

	
	//증빙자료 위치 조정
	this.divContent14.form.divContent03.set_top('358');
	
    if( v == '0' ){ //응시료 면제자 미체크
		//해당없음
		this.divContent14.form.divContent00.set_visible(true);
		this.divContent14.form.divContent00.set_enable(false);
		this.divContent14.form.rdoRlesScCd.set_enable(false);
		this.dsMain.setColumn(0,"aplemFeeExmpTrgtScCd","0");
		this.divContent14.form.divContent03.set_enable(false);	
		
		this.divContent14.form.staContent01.set_visible(false);//안내
		this.divContent14.form.divContent00.set_visible(false);//국민기초생활수급자
		this.divContent14.form.divContent01.set_visible(false);//한부모가족보호대상자
		this.divContent14.form.divContent03.set_visible(false);//증빙자료
		this.divContent14.set_height(120);
		// 전체영역  RESET
		this.smfResetScroll(this);
		
		
		
		
		//응시료 면제자 관련 정보 초기화
		this.divContent14.form.divContent00.form.staResult.set_text("[미검증]");
		this.divContent14.form.divContent00.form.btnContent00.set_enable(false);
		this.divContent14.form.divContent01.form.staResult.set_text("[미검증]");
		this.divContent14.form.divContent01.form.btnContent00.set_enable(false);
		this.dsMain.setColumn(0, "rlesVrfcScsYn", "N");
		this.dsMain.setColumn(0, "rlesVrfcCn", "");
		this.dsMain.setColumn(0 ,"rlesYn", "N");
		this.dsMain.setColumn(0 ,"rlesRegNo10", "");
		this.dsMain.setColumn(0 ,"rlesRegNo20", "");
		this.dsMain.setColumn(0, "pvsnPrcusAgreYn", "");
		this.divContent14.form.divContent03.form.divRlesVrfcFile.form.fnResetUpload(); //초기화
		this.dsMain.setColumn(0, "rlesVrfcFileRefrnId", '');
		
		
	}else{
		// 응시료 면제 검증 여부
		var rlesVrfcScsYn = this.dsMain.getColumn(0, 'rlesVrfcScsYn');
		

		if(rlesVrfcScsYn == 'Y'){
			this.dsMain.setColumn(0 ,'rlesYn', 'Y');
		}else{
			this.dsMain.setColumn(0 ,'rlesYn', 'N');
		}
		
		//증빙자료 위치 조정
		this.divContent14.form.divContent03.set_top('380');
		this.divContent14.form.divContent00.form.btnContent00.set_enable(false);
		this.divContent14.form.divContent01.form.btnContent00.set_enable(false);
		this.divContent14.form.divContent03.set_enable(false);	
	
		if( v === '1' ) { //응시료 면제 구분 = 국민기초생활수급자
			// 화면처리
			this.divContent14.form.divContent00.set_visible(true);//국민기초생활수급자
			this.divContent14.form.divContent01.set_visible(false);//한부모가족보호대상자
			this.divContent14.form.staContent01.set_visible(true);//안내
			
			this.divContent14.set_height(455);
			
			// 전체영역  RESET
			this.smfResetScroll(this);
			// 검증완료의경우
			if(rlesVrfcScsYn === 'Y'){
				this.divContent14.form.divContent00.form.staResult.set_text("[검증완료]");
				this.divContent14.form.divContent00.form.btnContent00.set_enable(true);//자격확인요청(국민기초생활수급자)
				this.divContent14.form.divContent03.set_enable(false);	
			}else{
				this.divContent14.form.divContent00.form.staResult.set_text("[미검증]");
				this.divContent14.form.divContent00.set_enable(true); // 탭 활성
				var pvsnPrcusAgreYn = this.dsMain.getColumn(0,"pvsnPrcusAgreYn"); //동의여부 
				if(pvsnPrcusAgreYn == "N"){
					this.divContent14.form.divContent00.form.btnContent00.set_enable(false);//자격확인요청(국민기초생활수급자)
					this.divContent14.form.divContent03.set_enable(true);	
				}else if(pvsnPrcusAgreYn == "Y"){
					this.divContent14.form.divContent00.form.btnContent00.set_enable(true);//자격확인요청(국민기초생활수급자)
					this.divContent14.form.divContent03.set_enable(false);	
				}else{

					this.divContent14.form.divContent03.form.divRlesVrfcFile.form.fnResetUpload(); //초기화
					this.dsMain.setColumn(0, "rlesVrfcFileRefrnId", '');
				}
			}
		} else if( v === '2' ) { //응시료 면제 구분 = 한부모가족보호대상자
			// validate 추가
			this.smfUpdateValidateToComponent("title:등록번호,required,maxlengthB:30", this.divContent14.form.divContent01.form.edtRlesRegNo20);
			// 화면처리
			this.divContent14.form.divContent00.set_visible(false);//국민기초생활수급자
			this.divContent14.form.divContent01.set_visible(true);//한부모가족보호대상자
			this.divContent14.form.staContent01.set_visible(true);//안내
			
			this.divContent14.set_height(455);
			// 전체영역  RESET
			this.smfResetScroll(this);
			// 검증완료의경우
			if(rlesVrfcScsYn === 'Y'){
				this.divContent14.form.divContent01.form.staResult.set_text("[검증완료]");
				this.divContent14.form.divContent01.form.btnContent00.set_enable(true);//자격확인요청(한부모가족)
				this.divContent14.form.divContent03.set_enable(false);	
			}else{
				this.divContent14.form.divContent01.form.staResult.set_text("[미검증]");
				this.divContent14.form.divContent01.set_enable(true); // 탭 활성
				var pvsnPrcusAgreYn = this.dsMain.getColumn(0,"pvsnPrcusAgreYn"); //동의여부 
				if(pvsnPrcusAgreYn == "N"){
					this.divContent14.form.divContent01.form.btnContent00.set_enable(false);//자격확인요청(한부모가족)
					this.divContent14.form.divContent01.form.edtRlesRegNo20.set_enable(false);
					this.divContent14.form.divContent03.set_enable(true);	
				}else if(pvsnPrcusAgreYn == "Y"){
					this.divContent14.form.divContent01.form.btnContent00.set_enable(true);//자격확인요청(한부모가족)
					this.divContent14.form.divContent01.form.edtRlesRegNo20.set_enable(true);
					this.divContent14.form.divContent03.set_enable(false);	
				}else{
					this.divContent14.form.divContent01.form.edtRlesRegNo20.set_enable(false);
					this.divContent14.form.divContent03.form.divRlesVrfcFile.form.fnResetUpload(); //초기화
					this.dsMain.setColumn(0, "rlesVrfcFileRefrnId", '');
				}
			}
		} else if( v === '3' ) { //응시료 면제 구분 = 기타대상자
		
			this.divContent14.form.divContent00.set_visible(false); //국민기초생활수급자 부분
			this.divContent14.form.divContent01.set_visible(false); //한부모가족보호대상자 부분 
			this.divContent14.form.divContent03.set_enable(true); //응시료 면제 증빙자료
			this.divContent14.form.staContent01.set_visible(false);//안내
			
			var pvsnPrcusAgreYn = this.dsMain.getColumn(0,"pvsnPrcusAgreYn"); //동의여부 
			if(this.smfIsNull(pvsnPrcusAgreYn)){
				this.divContent14.form.divContent03.form.divRlesVrfcFile.form.fnResetUpload(); //초기화
				this.dsMain.setColumn(0, "rlesVrfcFileRefrnId", '');
			}
			//증빙자료 위치 조정
			this.divContent14.form.divContent03.set_top(100);
			this.divContent14.set_height(200);
			// 전체영역  RESET
			this.smfResetScroll(this);
			// 응시료 면제 검증 여부
			//this.divContent14.form.divContent01.form.rdoContent00.set_value('N');
			this.dsMain.setColumn(0 ,'rlesYn', 'N'); //응시료면제여부
			this.dsMain.setColumn(0 ,'rlesVrfcScsYn', 'N'); //면제자검증성공여부
		}

		
	}
	
	// 결제 완료 일경우
	var stlmYn =  this.dsMain.getColumn(0, 'stlmYn');
	if(stlmYn == 'Y'){
		// 응시료면제 전체 영역 비활성
		this.divContent14.form.set_enable(false);
	}
	
};

// 파일업로드 라온환경설정
this.fnSetRaonProp = function()
{
	var objAddRaonProps = {
        ExtensionAllowOrLimit	: '1',									// 설정값이 "0" 이면 설정한 파일 확장자명만 "제한"으로 설정되며, "1"로 설정시 "허용"으로 설정
		ExtensionArr           : 'pdf,png,jpg,jpeg,gif,zip',	// 제한 또는 허용할 확장자 (,)로 구분					
		AllowedZeroFileSize   : "1"        // 0byte 파일의 업로드를 허용 할지 설정합니다.(기본값은 "0" 허용안함이고, "1"로 설정시 허용입니다.)
	};
						  
	return objAddRaonProps;
};

/**
 * 사진업로드 raonk 옵션
 */
this.fnSetRaonPropImg = function()
{
	var objAddRaonProps = {
		ExtensionAllowOrLimit	: "1"        // 업로드 할 파일 확장자를 허용 또는 제한 설정("0":지정된 확장자를 제한(선택 금지) , "1":지정된 확장자만 허용(선택가능))
		, ExtensionArr          : "gif,jpg,png,jpeg" 
		, MaxTotalFileCount 	: "1"	//업로드 할 최대 파일 개수 제한값을 설정합니다.
		, MaxOneFileSize 		: "1024KB"	//업로드할 때 파일당 용량제한을 설정합니다.
	};						  
	return objAddRaonProps;
};

// 졸업년도 체크
this.fnCheckGrdtnYm = function(v)
{
	/*
	var calEtrcYm = this.divContent05.form.calEtrcYm.value; // 입학년도
	var calGrdtnYm = this.divContent05.form.calGrdtnYm.value; // 졸업년도
	if( calEtrcYm && calGrdtnYm ) {
		var result = this.smfDiffMonth(calEtrcYm, calGrdtnYm);
		if( result <= 0 ) {
			this.smfAlert('입학년월이 졸업년월보다 이전이여야 합니다.');
			if( v == 0 ){
				this.divContent05.form.calEtrcYm.set_value('');
			}else{
				this.divContent05.form.calGrdtnYm.set_value('');
			}
			
		}
	}
	*/
};

// 지원방법 체크
this.fnCheckSprtMet = function(v, sprt1RnkPrivShlCd , sprt2RnkPrivShlCd  )
{
	switch(v){
		case '' :
			//1순위 미사용, 2순위 미사용
			this.divContent04.form.cboContent01.set_enable(false);
			this.divContent04.form.cboContent02.set_enable(false);
			
			//1순위 모두 제거
			this.dsPrivShlList1.clear();
			this.dsMain.setColumn(0, "sprt1RnkPrivShlCd", "");
			
			//2순위 모두 제거
			this.dsPrivShlList2.clear();
			this.dsMain.setColumn(0, "sprt2RnkPrivShlCd", "");
		break;
		// 공립
		case '1' : 
			//1순위 사용, 2순위 미사용
			this.divContent04.form.cboContent01.set_enable(true);
			this.divContent04.form.cboContent02.set_enable(false);
			
			//1순위 모두 제거 후 공립 셋팅
			this.dsPrivShlList1.clear();
			this.dsPrivShlList1.copyData(this.dsPrivShlListTmp);
			this.dsMain.setColumn(0, "sprt1RnkPrivShlCd", "1");
			
			//2순위 모두 제거
			this.dsPrivShlList2.clear();
			this.dsMain.setColumn(0, "sprt2RnkPrivShlCd", "");
		break;
		// 공립+사립
		case '2' : 
			//1순위 사용, 2순위 사용
			this.divContent04.form.cboContent01.set_enable(true);
			this.divContent04.form.cboContent02.set_enable(true);
			
			//1순위 모두 제거 후 공립 셋팅
			this.dsPrivShlList1.clear();
			this.dsPrivShlList1.copyData(this.dsPrivShlListTmp);
			this.dsMain.setColumn(0, "sprt1RnkPrivShlCd", "1");
			
			//2순위 모두 제거 후 사립 셋팅
			this.dsPrivShlList2.clear();
			this.dsPrivShlList2.copyData(this.dsPrivShlList);
			this.dsMain.setColumn(0, "sprt2RnkPrivShlCd", sprt2RnkPrivShlCd);
		break;
		// 사립
		case '3' : 
			//1순위 사용, 2순위 미사용
			this.divContent04.form.cboContent01.set_enable(true);
			this.divContent04.form.cboContent02.set_enable(false);
			
			//1순위 모두 제거 후 사립 셋팅
			this.dsPrivShlList1.clear();
			this.dsPrivShlList1.copyData(this.dsPrivShlList);
			this.dsMain.setColumn(0, "sprt1RnkPrivShlCd", sprt1RnkPrivShlCd);
			
			//2순위 모두 제거
			this.dsPrivShlList2.clear();
			this.dsMain.setColumn(0, "sprt2RnkPrivShlCd", "");
		break;
		// 사립+공립
		case '4' : 
			//1순위 사용, 2순위 사용
			this.divContent04.form.cboContent01.set_enable(true);
			this.divContent04.form.cboContent02.set_enable(true);
			
			//1순위 모두 제거 후 사립 셋팅
			this.dsPrivShlList1.clear();
			this.dsPrivShlList1.copyData(this.dsPrivShlList);
			this.dsMain.setColumn(0, "sprt1RnkPrivShlCd", sprt1RnkPrivShlCd);
			
			//2순위 모두 제거 후 공립 셋팅
			this.dsPrivShlList2.clear();
			this.dsPrivShlList2.copyData(this.dsPrivShlListTmp);
			this.dsMain.setColumn(0, "sprt2RnkPrivShlCd", "1");
		break;
		// 사립+사립
		case '5' : 
			//1순위 사용, 2순위 사용
			this.divContent04.form.cboContent01.set_enable(true);
			this.divContent04.form.cboContent02.set_enable(true);
			
			//1순위 모두 제거 후 사립 셋팅
			this.dsPrivShlList1.clear();
			this.dsPrivShlList1.copyData(this.dsPrivShlList);
			this.dsMain.setColumn(0, "sprt1RnkPrivShlCd", sprt1RnkPrivShlCd);
			
			//2순위 모두 제거 후 사립 셋팅
			this.dsPrivShlList2.clear();
			this.dsPrivShlList2.copyData(this.dsPrivShlList);
			this.dsMain.setColumn(0, "sprt2RnkPrivShlCd", sprt2RnkPrivShlCd);
		break;
	}
};

// 저장처리
this.fnSave = function(v)
{
	// 저장 전 처리
	this.fnBeforeSave();	

	//**********************필수체크 시작**********************************************  
	//사진
	//2023.09.06 알림메시지 수정
	if(this.smfIsNull(this.dsMain.getColumn(0,"apstPhotoFileNm"))){
		this.divContent03.form.btnContent01.setFocus();
		this.smfAlert('CM006', ["기본정보의 사진"], this.fnMessageCallback ); 
		return false;	
	}
	// 휴대전화
	if(this.smfIsNull(this.dsMain.getColumn(0,"mblTelno1"))){
		this.divContent03.form.edtMblTelno1.setFocus();
		this.smfAlert('CM006', ["휴대전화"]); 
		return false;	
	}
	if(this.smfIsNull(this.dsMain.getColumn(0,"mblTelno2"))){
		this.divContent03.form.edtMblTelno2.setFocus();
		this.smfAlert('CM006', ["휴대전화"] ); 
		return false;	
	}
	if(this.smfIsNull(this.dsMain.getColumn(0,"mblTelno3"))){
		this.divContent03.form.edtMblTelno3.setFocus();
		this.smfAlert('CM006', ["휴대전화"] ); 
		return false;	
	}
	// 비상시 연락처
	if(this.smfIsNull(this.dsMain.getColumn(0,"emgCnctTelno1"))){
		this.divContent03.form.edtEmgCnctTelno1.setFocus();
		this.smfAlert('CM006', ["연락처"]); 
		return false;	
	}
	if(this.smfIsNull(this.dsMain.getColumn(0,"emgCnctTelno2"))){
		this.divContent03.form.edtEmgCnctTelno2.setFocus();
		this.smfAlert('CM006', ["연락처"] ); 
		return false;	
	}
	if(this.smfIsNull(this.dsMain.getColumn(0,"emgCnctTelno3"))){
		this.divContent03.form.edtEmgCnctTelno3.setFocus();
		this.smfAlert('CM006', ["연락처"] ); 
		return false;	
	}	
	// 휴대전화번호
	var mblTelno =this.dsMain.getColumn(0, "mblTelno");
	// 비상연락처
	var emgCnctTelno = this.dsMain.getColumn(0, "emgCnctTelno");	
	if((mblTelno != '' && emgCnctTelno != '') && (mblTelno === emgCnctTelno)){
		this.divContent03.form.edtEmgCnctTelno1.setFocus();
		this.smfAlert("비상시 연락처는 휴대 전화와 같은 번호로 등록 할 수 없습니다.");
		return;
	}
	// E-MAIL
	if(this.smfIsNull(this.dsMain.getColumn(0,"emlAddr1"))){
		this.divContent03.form.edtEmlAddr1.setFocus();
		this.smfAlert('CM006', ["이메일"] ); 
		return false;	
	}
	if(this.smfIsNull(this.dsMain.getColumn(0,"emlAddr3"))){
		this.divContent03.form.cboEmlAddr2.setFocus();
		this.smfAlert('CM006', ["이메일"] ); 
		return false;	
	}
	var emlAddr1 = this.dsMain.getColumn(0,"emlAddr1");
	var emlAddr3 = this.dsMain.getColumn(0,"emlAddr3");
	this.dsMain.setColumn(0,"emlAddr", emlAddr1 + "@" + emlAddr3);
	
	if(!this.smfIsEmail(this.dsMain.getColumn(0,"emlAddr"))){
		this.divContent03.form.edtEmlAddr3.setFocus();
		this.smfAlert('이메일의 형식이 잘못되었습니다.');
		return;
	}
	// 주소
	if(this.smfIsNull(this.dsMain.getColumn(0,"dmclZipAddr"))){
		this.divContent03.form.btnContent00.setFocus();
		this.smfAlert('CM006', ["주소"] ); 
		return false;	
	}
	if(this.smfIsNull(this.dsMain.getColumn(0,"dmclZipDaddr"))){
		this.divContent03.form.edtDmclZipDaddr.setFocus();
		this.smfAlert('CM006', ["상세주소"] ); 
		return false;	
	}
	// 지원방법
	if(this.smfIsNull(this.dsMain.getColumn(0,"prapShlSprtMthCd"))){
		this.divContent04.form.cboContent00.setFocus();
		this.smfAlert('CM006', ["지원방법"] ); 
		return false;	
	}
	// 1순위
	if(this.smfIsNull(this.dsMain.getColumn(0,"sprt1RnkPrivShlCd"))){
		this.divContent04.form.cboContent01.setFocus();
		this.smfAlert('CM006', ["1순위"] ); 
		return false;	
	}
	// 지원 방법에 2순위가 있을경우 2순위 필수 
	var prapShlSprtMthCd = this.dsMain.getColumn(0,"prapShlSprtMthCd");
	// 공립+사립(2) , 사립+공립(4) , 사립+사립(5)
	if('2' === prapShlSprtMthCd || '4' === prapShlSprtMthCd || '5' === prapShlSprtMthCd){
		//2순위
		if(this.smfIsNull(this.dsMain.getColumn(0,"sprt2RnkPrivShlCd"))){
			this.divContent04.form.cboContent02.setFocus();
			this.smfAlert('CM006', ["2순위"] ); 
			return false;	
		}
	}
	// 졸업여부
	if(this.smfIsNull(this.dsMain.getColumn(0,"grdtnScCd"))){
		this.divContent05.form.cboGrdtnScCd.setFocus();
		this.smfAlert('CM006', ["졸업여부"] ); 
		return false;	
	}
	
	//저장 전 검증
	if(!this.divContent05.form.chkTchQlfVrfcPassvYn.value){
		if(this.smfIsNull(this.dsMain.getColumn(0,"tchQlfAsortScCdY"))){
			this.divContent05.form.edtTchQlflCtrCd.setFocus();
			this.smfAlert("자격번호(교원자격) 검증은 필수입니다."); 
			return false;	
		}
	}else{
		//교원자격증종별
		if(this.smfIsNull(this.dsMain.getColumn(0,"tchQlfAsortScCdN"))){
			this.divContent05.form.divContent01.form.cboTchQlfAsortScCdN.setFocus();
			this.smfAlert('CM006', ["교원자격증종별"] ); 
			return false;	
		}	
		//교원자격증급별
		if(this.smfIsNull(this.dsMain.getColumn(0,"lsgByScCdN"))){
			this.divContent05.form.divContent01.form.cboLsgByScNmN.setFocus();
			this.smfAlert('CM006', ["교원자격증급별"] ); 
			return false;	
		}
		//발급기관명
		if(this.smfIsNull(this.dsMain.getColumn(0,"tchQlfInstNmN"))){
			this.divContent05.form.divContent01.form.edtTchQlfInstNmN.setFocus();
			this.smfAlert('CM006', ["발급기관명"] ); 
			return false;	
		}
		//증빙자료
		//2023.09.06 알림메시지 수정
		if(this.smfIsNull(this.dsMain.getColumn(0,"tchQlfFileRefrnId"))){
			this.divContent05.form.divContent01.form.divTchQlfFileRefrnFile.setFocus();
			this.smfAlert('CM006', ["학력정보의 증빙자료"] ); 
			return false;	
		}
	}
	
	
	// 입학년월 
	/*
	if(this.smfIsNull(this.dsMain.getColumn(0,"etrcYm"))){
		this.divContent05.form.calEtrcYm.setFocus();
		this.smfAlert('CM006', ["입학년월"] ); 
		return false;	
	}
	*/
	// 졸업년월 
	if(this.smfIsNull(this.dsMain.getColumn(0,"grdtnYm"))){
		this.divContent05.form.calGrdtnYm.setFocus();
		this.smfAlert('CM006', ["졸업년월"] ); 
		return false;	
	}

	//2023.09.08 추가 : 입학년월, 졸업년월 체크
	var v_appoExamYr = this.dsAppoExam.getColumn(0, "appoExamYr"); //임용시험연도
	var v_grdtnScCd = this.divContent05.form.cboGrdtnScCd.value; //졸업여부 : 1=정상졸업, 6=졸업예정
	//var v_etrcYm = this.divContent05.form.calEtrcYm.value; //입학년월(yyyymmdd로 들어옴)
	//var v_etrcYr = this.divContent05.form.calEtrcYm.value.substr(0,4); //입학년도
	var v_grdtnYm = this.divContent05.form.calGrdtnYm.value; //졸업(예정)년월(yyyymmdd로 들어옴)
	var v_grdtnYr = this.divContent05.form.calGrdtnYm.value.substr(0,4); //졸업(예정)년도
	
	/*
	if(v_etrcYm > v_grdtnYm) {
		this.divContent05.form.calEtrcYm.setFocus();
		this.smfAlert('CM020', ["입학년월", "졸업(예정)년도"] ); //CM020 : {0} 은(는) {1} 보다 작아야 합니다.
		return false;
	}
	
	if(v_etrcYr > v_appoExamYr) {
		this.divContent05.form.calEtrcYm.setFocus();
		this.smfAlert('CM020', ["입학년월", "임용시험연도("+v_appoExamYr+")"] ); //CM020 : {0} 은(는) {1} 보다 작아야 합니다.
		return false;
	}
	*/
	if(v_grdtnScCd == '1') { //정상졸업인 경우
		if(v_grdtnYr > v_appoExamYr) {
			this.divContent05.form.calGrdtnYm.setFocus();
			this.smfAlert('CM020', ["정상졸업인 경우 졸업(예정)년월", "임용시험연도("+v_appoExamYr+")"] ); //CM020 : {0} 은(는) {1} 보다 작아야 합니다.
			return false;
		}
	}

	// 한국사능력검정
	if(this.divContent07.form.chkContent01.value){
		//회차
		if(this.smfIsNull(this.dsMain.getColumn(0,"krhisRcgnTmeN"))){
			this.divContent07.form.cboKrhisRcgnTmeN.setFocus();
			this.smfAlert('CM006', ["회차"] ); 
			return false;	
		}
		//인증번호
		if(this.smfIsNull(this.dsMain.getColumn(0,"krhisRcgnCetNo2"))){
			this.divContent07.form.edtKrhisRcgnCetNo2.setFocus();
			this.smfAlert('CM006', ["인증번호"] ); 
			return false;	
		}
		
		if(!this.divContent07.form.chkContent00.value){
			if(this.dsMain.getColumn(0,"krhisAbtVrfcScsYn") != "Y"){
				this.divContent07.form.btnContent00.setFocus();
				this.smfAlert("한국사 능력 검정 인증은 필수입니다."); 
				return false;	
			}
		}else{
			//합격등급
			if(this.smfIsNull(this.dsMain.getColumn(0,"krhisRcgnClaValue"))){
				this.divContent07.form.cboKrhisAplemClaScCdN.setFocus();
				this.smfAlert('CM006', ["합격등급"] ); 
				return false;	
			}
			
			//증빙자료
			//2024.03.19 알림메시지 수정
			if(this.smfIsNull(this.dsMain.getColumn(0,"krhisCetFileRefrnId"))){
				this.divContent07.form.divKrhisCetFileRefrnFile.setFocus();
				this.smfAlert('CM006', ["한국사능력검정시험의 증빙자료"] ); 
				return false;	
			}
			
			this.dsMain.setColumn(0,"krhisRcgnCetNo", this.divContent07.form.edtKrhisRcgnCetNo1.value +'-'+this.divContent07.form.edtKrhisRcgnCetNo2.value);
		}
	}else{
		//시험종류
		if(this.smfIsNull(this.dsMain.getColumn(0,"krhisAplemClaScCd"))){
			this.divContent07.form.cboKrhisAplemClaScCdP.setFocus();
			this.smfAlert('CM006', ["시험종류"] ); 
			return false;	
		}
		//접수번호
		if(this.smfIsNull(this.dsMain.getColumn(0,"krhisExmtNo"))){
			this.divContent07.form.edtKrhisExmtNo.setFocus();
			this.smfAlert('CM006', ["접수번호"] ); 
			return false;	
		}
	}
	
	//장애인 응시자 
	if(this.divContent08.form.chkContent01.value){
	
	
		var dltScCd = this.dsMain.getColumn(0,"dltScCd");
		
		//장애유형
		if(this.smfIsNull(dltScCd) || dltScCd == "0"){
			this.divContent08.form.cboDltScCd.setFocus();
			this.smfAlert('CM006', ["장애유형"] ); 
			return false;	
		}
		var dltClaCd = this.dsMain.getColumn(0,"dltClaCd");
		//장애정도
		if(this.smfIsNull(dltClaCd) || dltClaCd == "09"){
			this.divContent08.form.cboSedScCd.setFocus();
			this.smfAlert('CM006', ["장애정도"] ); 
			return false;	
		}
	}
	
	// 취업지원대상자 
	if(this.divContent11.form.chkContent01.value){
		//보훈번호
		if(this.smfIsNull(this.dsMain.getColumn(0,"soctyFrgltSclsrCd1"))){
			this.divContent11.form.edtSoctyFrgltSclsrCd1.setFocus();
			this.smfAlert('CM006', ["보훈번호"] ); 
			return false;	
		}
		if(this.smfIsNull(this.dsMain.getColumn(0,"soctyFrgltSclsrCd2"))){
			this.divContent11.form.edtSoctyFrgltSclsrCd2.setFocus();
			this.smfAlert('CM006', ["보훈번호"] ); 
			return false;	
		}
		//보훈번호 앞자리 2자리 체크
		if(this.dsMain.getColumn(0,"soctyFrgltSclsrCd1").length < 2){
			this.divContent07.form.edtSoctyFrgltSclsrCd1.setFocus();
			this.smfAlert("보훈번호 앞자리는 2자리를 입력하셔야 합니다."); 
			return false;	
		}
		//보훈번호 뒷자리 6자리 체크
		if(this.dsMain.getColumn(0,"soctyFrgltSclsrCd2").length < 6){
			this.divContent07.form.edtSoctyFrgltSclsrCd2.setFocus();
			this.smfAlert("보훈번호 뒷자리는 6자리를 입력하셔야 합니다."); 
			return false;	
		}
		//취업지원대상자 가점
		if(this.smfIsNull(this.dsMain.getColumn(0,"emploSprtAdpnValue"))){
			this.divContent11.form.cboEmploSprtAdpn.setFocus();
			this.smfAlert('CM006', ["취업지원대상자 가점"] ); 
			return false;	
		}
		//증빙서류
		if(this.smfIsNull(this.dsMain.getColumn(0,"emploSprtFileRefrnId"))){
			this.divContent11.form.divEmploSprtFile.setFocus();
			this.smfAlert('CM006', ["취업지원대상자 가점대상자의 증빙자료"] ); 
			return false;	
		}
	}
	//병역구분
	//남자인 경우 해당 없음 선택 불가
	var sxdsCd = this.dsMain.getColumn(0, 'sxdsCd');
	if(sxdsCd == "1"){
		if(this.divContent10.form.div09.form.cboContent00.value == "1"){
			this.divContent10.form.div09.form.cboContent00.setFocus();
			this.smfAlert("의무복무대상(남성)의 경우 해당없음을 선택할수 없습니다."); 
			return false;	
		}
	}
	
	// 의사상자
	if(this.divContent12.form.chkContent01.value){
		//의사상자번호
		if(this.smfIsNull(this.dsMain.getColumn(0,"mertNo1"))){
			this.divContent12.form.edtMertNo1.setFocus();
			this.smfAlert('CM006', ["의사상자번호"] ); 
			return false;	
		}
		//if(this.smfIsNull(this.dsMain.getColumn(0,"mertNo2"))){
		//	this.divContent12.form.edtMertNo2.setFocus();
		//	this.smfAlert('CM006', ["의사상자번호"] ); 
		//	return false;	
		//}
		//의사상자 등 가점
		if(this.smfIsNull(this.dsMain.getColumn(0,"mertAdpnValue"))){
			this.divContent12.form.cboExam1TmeMertAdpn.setFocus();
			this.smfAlert('CM006', ["의사상자 등 가점"] ); 
			return false;	
		}
		//증빙서류
		if(this.smfIsNull(this.dsMain.getColumn(0,"mertFileRefrnId"))){
			this.divContent12.form.divMertFile.setFocus();
			this.smfAlert('CM006', ["의사상자 등 가점대상자의 증빙자료"] ); 
			return false;	
		}
	}
	if(this.divContent13.form.chkContent01.value){
	
		// 지역가산점
		if(this.divContent13.form.rdoAdpnTrgtCarrYn.value =="")
		{
			this.divContent13.form.rdoAdpnTrgtCarrYn.setFocus();
			this.smfAlert('CM006', ["교원경력유무"] ); 
			return false;	
		}
		if(this.divContent13.form.chkContent01.value){
			//교원 경력이 없을경우만 지역가산점 입력가능!!!!!
			if( this.dsMain.getColumn(0,"adpnTrgtCarrYn") == "N" ){
				if(this.smfIsNull(this.dsMain.getColumn(0,"dstrtAdpnValue"))){
					this.divContent13.form.cboDstrtAdpn.setFocus();
					this.smfAlert('CM006', ["지역가산점"] ); 
					return false;	
				}
			}
		}
	}
	
	// 시험장 있을경우
	if(this.dsResultExmr.getRowCount() >  0){
		if(this.smfIsNull(this.dsMain.getColumn(0,"exmrDstrtNm")) || this.dsMain.getColumn(0,"exmrDstrtNm") == "- 선택 -"){
			this.divExmrInfo.form.cboExmr.setFocus();
			this.smfAlert('CM006', ["시험장"] ); 
			return false;	
		}
	}
	
	//응시료면제자
	if(this.divContent14.form.chkContent01.value){
	
		//응시료 면제 구분
		if(this.smfIsNull(this.dsMain.getColumn(0,"aplemFeeExmpTrgtScCd"))){
			
			this.divContent14.form.rdoRlesScCd.setFocus();
			this.smfAlert('CM006', ["응시료 면제 구분"] ); 
			return false;	
			
		}
		if( this.dsMain.getColumn(0,"aplemFeeExmpTrgtScCd") == "1" || this.dsMain.getColumn(0,"aplemFeeExmpTrgtScCd") == "2"){
		
					
			//응시료면제 동의 여부
			if(this.smfIsNull(this.dsMain.getColumn(0,"pvsnPrcusAgreYn"))){
				this.divContent14.form.divContent01.form.rdoContent00.setFocus();
					this.smfAlert('CM006', ["응시료 면제 동의여부"] ); 
					return false;	
			}
		
			// 요구면서 검증이 안됐을 경우
			if(this.divContent14.form.divContent01.form.rdoContent00.value == "Y"){
				if(this.dsMain.getColumn(0,"rlesVrfcScsYn") != "Y" ){
					this.smfAlert("응시료 면제자 검증은 필수입니다."); 
					return false;	
				}
			}else{ 
			
				//증빙자료 필수체크 
				if(this.smfIsNull(this.dsMain.getColumn(0,"rlesVrfcFileRefrnId"))){
					this.divContent14.form.divContent03.form.divRlesVrfcFile.setFocus();
					this.smfAlert('CM006', ["응시료 면제 증빙자료"] ); 
					return false;	
				}
				//var bankCd = this.dsMain.getColumn(0,"bankCd"); // 환불은행
				//var bankActno =  this.dsMain.getColumn(0,"bankActno"); // 환불계좌
				//var refndAccDpstrNm =  this.dsMain.getColumn(0,"refndAccDpstrNm"); // 예금주
				
				//if(this.smfIsNull(bankCd) || this.smfIsNull(bankActno)  || this.smfIsNull(refndAccDpstrNm) ){
				//	this.divContent14.form.divContent03.form.cboBankCd.setFocus();
				//	this.smfAlert("응시료 면제 검증을 요구하지 않거나 검증이 불가능 할 경우,\n 환불 정보를 정확히 입력 해주세요.  ");
				//	return;
				//}
			}
		}else{
		
			//증빙자료 필수체크 
			if(this.smfIsNull(this.dsMain.getColumn(0,"rlesVrfcFileRefrnId"))){
				this.divContent14.form.divContent03.form.divRlesVrfcFile.setFocus();
				this.smfAlert('CM006', ["응시료 면제 증빙자료"] ); 
				return false;	
			}
		
		}
	}
	/*대학성적 0 체크*/
	if( this.dsMain.getColumn(0, 'currCd') == '001' ) { //초등일 경우 추가
		if(this.divContent06.form.edtUvstScreRank.value==0)
		{
			this.divContent06.form.edtUvstScreRank.setFocus();
			this.smfAlert("대학성적 - 석차에는 숫자 0을 입력하실 수 없습니다."); 
			return false;
		}
		if(this.divContent06.form.edtUvstScreWhprCnt.value==0)
		{
			this.divContent06.form.edtUvstScreWhprCnt.setFocus();
			this.smfAlert("대학성적 - 총원에는 숫자 0을 입력하실 수 없습니다."); 
			return false;
		}
	}
	//**********************필수체크 끝********************************************** 
	
	// 교원응시지원서 지원방법내역
	this.dsShlSprtMth.clearData();
	if( this.dsMain.getColumn(0,"prapShlSprtMthCd") == "2" ){
		//2: 공립 + 사립
		var nRow = this.dsShlSprtMth.addRow();
		this.dsShlSprtMth.setColumn(nRow, "prapShlSprtMthCd"  , this.dsMain.getColumn(0,"prapShlSprtMthCd") );
		this.dsShlSprtMth.setColumn(nRow, "priorRnk"          , "2" );
		this.dsShlSprtMth.setColumn(nRow, "sprt1RnkPrivShlCd" , this.dsMain.getColumn(0,"sprt2RnkPrivShlCd") );
		this.dsShlSprtMth.setColumn(nRow, "privShlNm"         , this.divContent04.form.cboContent02.text );
	}else if( this.dsMain.getColumn(0,"prapShlSprtMthCd") == "3" || this.dsMain.getColumn(0,"prapShlSprtMthCd") == "4" ){
		//3: 사립 or 4: 사립 + 공립
		var nRow = this.dsShlSprtMth.addRow();
		this.dsShlSprtMth.setColumn(nRow, "prapShlSprtMthCd"  , this.dsMain.getColumn(0,"prapShlSprtMthCd") );
		this.dsShlSprtMth.setColumn(nRow, "priorRnk"          , "1" );
		this.dsShlSprtMth.setColumn(nRow, "sprt1RnkPrivShlCd" , this.dsMain.getColumn(0,"sprt1RnkPrivShlCd") );
		this.dsShlSprtMth.setColumn(nRow, "privShlNm"         , this.divContent04.form.cboContent01.text );
	}else if( this.dsMain.getColumn(0,"prapShlSprtMthCd") == "5" ){
		//5: 사립 + 사립 
		var nRow = this.dsShlSprtMth.addRow();
		this.dsShlSprtMth.setColumn(nRow, "prapShlSprtMthCd"  , this.dsMain.getColumn(0,"prapShlSprtMthCd") );
		this.dsShlSprtMth.setColumn(nRow, "priorRnk"          , "1" );
		this.dsShlSprtMth.setColumn(nRow, "sprt1RnkPrivShlCd" , this.dsMain.getColumn(0,"sprt1RnkPrivShlCd") );
		this.dsShlSprtMth.setColumn(nRow, "privShlNm"         , this.divContent04.form.cboContent01.text );
		
		nRow = this.dsShlSprtMth.addRow();
		this.dsShlSprtMth.setColumn(nRow, "prapShlSprtMthCd"  , this.dsMain.getColumn(0,"prapShlSprtMthCd") );
		this.dsShlSprtMth.setColumn(nRow, "priorRnk"          , "2" );
		this.dsShlSprtMth.setColumn(nRow, "sprt1RnkPrivShlCd" , this.dsMain.getColumn(0,"sprt2RnkPrivShlCd") );
		this.dsShlSprtMth.setColumn(nRow, "privShlNm"         , this.divContent04.form.cboContent02.text );
	}
	
	// 원서접수 문자발송정보 SET
	this.fnSetSaveRcptSmsInfo();
	
	this.smfConfirm("저장 하시겠습니까?", function(result){
		if(result.confirmResult){
			// 취업지원 가점 대상자 체크박스 ON/OFF 처리
			if(!this.divContent11.form.chkContent01.value){
				// OFF 
				this.divContent11.form.edtSoctyFrgltSclsrCd1.set_value("");
				this.divContent11.form.edtSoctyFrgltSclsrCd2.set_value("");
				this.divContent11.form.cboEmploSprtAdpn.set_value("");
				this.dsMain.setColumn(0, "soctyFrgltSclsrCd", "");
				this.dsMain.setColumn(0, "soctyFrgltSclsrCd1", "");
				this.dsMain.setColumn(0, "soctyFrgltSclsrCd2", "");
				this.dsMain.setColumn(0, "emploSprtFileRefrnId", "");
				this.dsMain.setColumn(0, "emploSprtAdpnValue", "");

			}else{
				//보훈번호 조합
				var soctyFrgltSclsrCd1 = this.dsMain.getColumn(0, "soctyFrgltSclsrCd1");	
				var soctyFrgltSclsrCd2 = this.dsMain.getColumn(0, "soctyFrgltSclsrCd2");	
				var soctyFrgltSclsrCd = [soctyFrgltSclsrCd1, soctyFrgltSclsrCd2].join(""); 
				this.dsMain.setColumn(0, "soctyFrgltSclsrCd", soctyFrgltSclsrCd);
			}
			
			// 의사상자 가점 대상자 체크박스 ON/OFF 처리
			if(!this.divContent12.form.chkContent01.value){
				///OFF
				this.divContent12.form.edtMertNo1.set_value("");
				this.divContent12.form.edtMertNo2.set_value("");
				this.divContent12.form.cboExam1TmeMertAdpn.set_value("");
				this.dsMain.setColumn(0, "mertNo", "");
				this.dsMain.setColumn(0, "mertNo1", "");
				this.dsMain.setColumn(0, "mertNo2", "");
				this.dsMain.setColumn(0, "mertFileRefrnId", "");
				this.dsMain.setColumn(0, "mertAdpnValue", "");
			}else{
				//의사상자번호 조합
				var mertNo1 = this.dsMain.getColumn(0, "mertNo1");
				//var mertNo2 = this.dsMain.getColumn(0, "mertNo2");	
				//var mertNo = [mertNo1, mertNo2].join(""); 
				var mertNo = mertNo1.replace("-", "");
				if (mertNo.length > 6) mertNo = mertNo.substr(0,6);
				this.dsMain.setColumn(0, "mertNo", mertNo);
			}
			
			// 한국사 취득자 OFF
			if(!this.divContent07.form.chkContent01.value){
				this.dsMain.setColumn(0,"krhisRcgnTmeN",'');
				this.dsMain.setColumn(0,"krhisRcgnCetYmdN",'');
				this.dsMain.setColumn(0,"krhisRcgnCetNo2",'');
				this.dsMain.setColumn(0,"krhisRcgnClaValue",'');
				this.dsMain.setColumn(0,"krhisCetFileRefrnId", '');
				this.divContent07.form.divKrhisCetFileRefrnFile.form.edtFile.set_value('');
			}else{
				this.dsMain.setColumn(0,"krhisAplemClaScCd",'');
				this.dsMain.setColumn(0,"krhisExmtNo",'');
			}
			
			// 장애인 응시자 OFF
			if(!this.divContent08.form.chkContent01.value ){
				this.dsMain.setColumn(0,"dltCnvFileRefrnId", '');
				this.dsMain.setColumn(0,"cnvPvsnDmndYn", 'N');
				this.divContent08.form.divDltCnvFile.form.edtFile.set_value('');
			}
			/*
			// 임산부 편의 : 해당없음
			if('Y' != this.divContent09.form.cboPgnwCnvPvsnDmndYn.value){
				this.dsMain.setColumn(0,"pgnwCnvFileRefrnId", '');
				this.divContent09.form.divPgnwCnvFile.form.edtFile.set_value('');
			}
			*/
		
			// 저장
			this.smfSaveService("saveAppo")
				.showConfirm(false)
				.run()
				.callback(function(callbackParams){
					if(callbackParams.errors) return;
					
					var dupYn = this.dsResult.getColumn(0, "dupYn");
					
					if(dupYn == "Y"){
					
						var ocptStlmYn = this.dsResult.getColumn(0, "ocptStlmYn"); 
						var sameCddcStlmYn = this.dsResult.getColumn(0, "sameCddcStlmYn"); 
						var chcCurrYn = this.dsResult.getColumn(0, "chcCurrYn"); 
						
						if(ocptStlmYn === "Y"){
							this.smfAlert("타시도교육청에 임용시험 결재내역이 존재합니다. 결재 취소 후 다시 시도해주세요.");
							return;
						}else if(sameCddcStlmYn === "Y"){
							this.smfAlert("해당 시도교육청 임용시험에 이미 접수완료(결제완료)된 주민등록번호가 있습니다.\n해당 임용시험 결재 취소 후 다시 시도해주세요.");
							return;
						}else if(chcCurrYn === "Y"){
							this.smfAlert("이미 결제완료된 정보가 존재합니다.");
							return;
						}else{
							this.smfAlert("응시료 면제 결재 처리 도중 오류가 발생하였습니다.");
							return;
						}
					
					}
					
					// 저장 후 처리
					this.fnAfterSave();
					// 저장이 완료되었습니다.
					this.smfAlert('CM002');
					this.dsMain.set_updatecontrol(false);
					this.dsMain.setRowType(0,Dataset.ROWTYPE_NORMAL);
					this.dsMain.set_updatecontrol(true);
					this.dsOthinVrfc.clearData();
					
				});
		}
	});
	
};

// 교원 자격번호 추가 
this.fnAdd00Callback = function(e, sender){
	this.dsMain.setColumn(0,"tchQlfAsortScCdY", e.tchQlfAsortScCd); //교원자격증종별코드
	this.dsMain.setColumn(0,"tchQlfAsortScNmY", e.tchQlfAsortScNm); //교원자격증종별명칭
	this.dsMain.setColumn(0,"lsgByScCdY", e.lsgByScCd);   //교원자격증급별코드
	this.dsMain.setColumn(0,"lsgByScNmY", e.lsgByScNm);   //교원자격증급별명칭
	this.dsMain.setColumn(0,"tchQlfInstCdY", e.tchQlfInstCd);   //발급기관명코드
	this.dsMain.setColumn(0,"tchQlfInstNmY", e.tchQlfInstCdNm); //발급기관명명칭
	this.dsMain.setColumn(0,"qlflNo" , e.tchQlflCtrNo);
	this.dsMain.setColumn(0,"tchQlfVrfcYmd" , e.issuYmd); //발급일자
	this.dsMain.setColumn(0,"tchQlfVrfcScsYn" , "Y");
	
	//발급일자 = 졸업년월로 세팅
	var today = this.smfToday();
	if(today < e.issuYmd){
		this.dsMain.setColumn(0,"grdtnScCd" , "6"); //졸업예정  
	}else{
		this.dsMain.setColumn(0,"grdtnScCd" , "1");
	}
	this.dsMain.setColumn(0,"grdtnYm" , e.issuYmd.substr(0,6)); //발급일자
	
	//응시원서기관검증이력
	var iFindRow = this.dsOthinVrfc.findRow("othinVrfcScCd" , "TEQ");
	if(iFindRow == -1 ){
		iFindRow = this.dsOthinVrfc.addRow();
		this.dsOthinVrfc.setColumn(iFindRow, "othinVrfcScCd" , "TEQ"); // 교원자격 
	}
};

//응시료납부화면이동
this.fnAechgPayScrinMvmn = function(pDsResetYn){
	

	if(pDsResetYn == 'Y'){ //reset했을 때의 영향도를 몰라 구분값 넣어서 처리함.
		this.dsMain.reset(); //저장하지 않은 변경된 데이터가 파라미터로 넘어가 응시료납부화면에서 문제가 발생함. 이에 reset 해줌.
	}
	//결재여부
	var stlmYn = this.dsMain.getColumn(0,"stlmYn") == "Y" ? "Y" : "N"; // 결제여부 
	var rcptNo = this.dsMain.getColumn(0,"rcptNo");
	// 공사립학교지원방법코드
	var prapShlSprtMthCd =  this.dsMain.getColumn(0, "prapShlSprtMthCd"); 
	
	var params = {
		appoExamCd  : this.dsMain.getColumn(0, "appoExamId"),
		appoExamNm  : this.dsMain.getColumn(0, "appoExamNm"),
		appoFieldCd : this.dsMain.getColumn(0, "currCd"),
		appoFieldNm : this.dsMain.getColumn(0, "currNm"),
		applpFlnm : this.dsMain.getColumn(0, "applpFlnm"),
		mblTelno : this.dsMain.getColumn(0, "mblTelno"),
		emlAddr : this.dsMain.getColumn(0, "emlAddr"),
		rlesYn : this.dsMain.getColumn(0, "rlesYn"), // 응시료면제여부
		stlmYn:  this.dsMain.getColumn(0,"stlmYn"), //결제여부
		stlmAmt: this.dsMain.getColumn(0, "stlmAmt"), //결제완료금액
		prapShlSprtMthCd : prapShlSprtMthCd, // 공사립학교지원방법코드
		aplemAmt : this.dsAppoExam.getColumn(0, "aplemAmt"), // 공립응시금액
		privAplemAmt : this.dsAppoExam.getColumn(0, "privAplemAmt"), //사립응시금액
		rcptQustTelNo :  this.dsAppoOnlEmpmnMng.getColumn(0, 'rcptQustTelNo'), // 접수문의
		rcptNo : rcptNo,
		updateYn : this.updateYn,
		applpRrno : this.dsMain.getColumn(0, "applpRrno"), //2023.09.13 응시자주민등록번호 추가
		onlEmpmnExamScCd : this.smfGetAppoExamScCd(), //2023.09.13 온라인채용시험구분코드 추가
		appoExamId : this.dsMain.getColumn(0, "appoExamId"), //2023.09.13 임용시험ID 추가
		appoExamYr : this.dsMain.getColumn(0, "appoExamYr"), //2024.05.08 임용시험년도 추가
		cddcScCd : this.dsMain.getColumn(0, "cddcScCd") //2024.05.08 시도교육청코드 추가
	};
	
	/*
	// 결제필요여부
	var isPay = 'Y';
	// 응시료 사용여부
	var aplemAmtUseYn = 'TRUE';
	// 공립(국립) , 공립(1순위) + 사립(2순위), 사립(1순위) + 공립(2순위)
	if(prapShlSprtMthCd  === '1' || prapShlSprtMthCd  === '2' || prapShlSprtMthCd  === '4' ){
		// 공립응시료  사용 여부
		aplemAmtUseYn = this.dsAppoExam.getColumn(0, "aplemAmtUseYn");
	}
	// 사립, 사립(1순위)+사립(2순위) 
	if(prapShlSprtMthCd  === '3' || prapShlSprtMthCd  === '5' ){
		// 사립응시료  사용 여부
		aplemAmtUseYn = this.dsAppoExam.getColumn(0, "privAplemAmtUseYn");
	}
	// 응시료 사용 여부 = N :  응시료 없음
	if(aplemAmtUseYn === 'FALSE' ){
		isPay ='N';
	}
	*/
	
	// 응시료 면제여부
	var rlesYn = this.dsMain.getColumn(0, "rlesYn");
	
	
	if(stlmYn === 'Y' || rlesYn == 'Y'){ // TODO  응시료 rdoRlesScCd 면제여부 체크 추가
		// 접수 완료 PAGE
		this.smfSetWorkPage("pa_ore_oew_ar::ore_oewar01_m02.xfdl", params);
		return;
		
	}else{
	
		if(this.updateYn == "Y"){ //원서접수 내역에서 넘어왔을경우만 
			this.smfSearchService('selectCheckData') 
				.run()
				// 콜백
				.callback(function(callbackParams){
					if(callbackParams.errors){
						this.fnComponentDisable();
						return;
					}
					
					// 응시료 결제 PAGE
					this.smfSetWorkPage("pa_ore_oew_ar::ore_oewar01_m01.xfdl", params);
					return;	
					
					
			});
			
		}else{
			// 응시료 결제 PAGE
			this.smfSetWorkPage("pa_ore_oew_ar::ore_oewar01_m01.xfdl", params);
			return;	
		}
		
	}
};

