    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-교원임용(초등)-지원서 작성-원서 정보 등록
*  @MenuPath    pa_ore_oew_ar
*  @FileName 	pa_ore_oewar01_m00.xfdl
*  @Creator 	shhan
*  @CreateDate 	2022.08.30
*  @Desction    온라인통합채용-교원임용(초등)-지원서 작성-원서 정보 등록
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.08.30    	shhan	 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.updateYn = "N";
this.gotoPay = "N"; //마이페이지에서 결제하기 누르면 Y : 결제화면으로 다이렉트 이동
//2023.08.30 파일업로드 성공시에만 이미지 변경되도록 수정
this.sImageType       = "";
this.sImageFileName   = "";   // 선택된 파일이름
this.sImageDataBase64 = "";
this.sImageDataBase64Reduce = "";

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(this);

	// parameter set
	this.pv_params = this.smfGetFormParams();
	this.dsMain.setColumn(0, 'appoExamId', this.pv_params.appoExamCd); // 임용시험ID
	this.dsMain.setColumn(0, 'appoExamNm', this.pv_params.appoExamNm); // 임용시험명
	this.dsMain.setColumn(0, 'appoExamMastrIdfId', this.pv_params.appoExamMastrIdfId); // 임용시험마스터
	this.dsMain.setColumn(0, 'currCd', this.pv_params.appoFieldCd); // 교과(분야)코드
	this.dsMain.setColumn(0, 'currNm', this.pv_params.appoFieldNm); // 교과(분야)명
	this.dsMain.setColumn(0, 'cddcScCd', this.smfGetCddcCode().slice(0, 3)); // 시도코드 set
	//  본인인증
	this.dsMain.setColumn(0,"applpFlnm", this.smfGetSessionValue('userNm'));
	this.dsMain.setColumn(0,"applpRrno", nexacro.base64Decode(this.smfGetSessionValue('userRrno')));
	this.dsMain.setColumn(0,"mblTelno" , this.smfGetSessionValue('mblTelNo'));

	this.divContent02.form.staContent00.set_text(this.pv_params.appoExamNm);
	this.divContent02.form.staContent01.set_text("분야 : "+this.pv_params.appoFieldNm);
	
	this.updateYn = this.pv_params.updateYn; //N: 지원서 작성 / Y: 원서접수내역
	this.gotoPay = this.pv_params.gotoPay;//Y : 결제화면으로 다이렉트 이동
	//수정여부체크
	this.dsSearch.setColumn(0,"cddcCd", this.smfGetCddcCode().slice(0, 3));
	this.dsSearch.setColumn(0,"appoExamId", this.pv_params.appoExamCd);
	this.dsSearch.setColumn(0,"onlEmpmnExamScCd", this.smfGetAppoExamScCd());
	this.dsSearch.setColumn(0,"currCd", this.pv_params.appoFieldCd);
	this.dsSearch.setColumn(0,"applpRrno", nexacro.base64Decode(this.smfGetSessionValue('userRrno')));
	
	// 공통코드
	// dsGrdtnScCd : 졸업구분코드, dsTchQlfAsortScCd : 교원자격종별구분코드
	// dsQlfAsortCd : 자격종별코드, dsUvstScreRfltScCd : 대학성적반영구분코드
	// dsKrhisAplemClaScCd : 한국사응시등급구분코드, dsDltScCd : 장애구분코드
	// dsSedScCd : 중증구분코드, dsMtrscScCd : 병역구분코드, dsRlesScCd : 면제자구분코드
	// dsBankCd : 은행코드
	this.smfCodeList("code", [this.dsGrdtnScCd, this.dsTchQlfAsortScCd, this.dsQlfAsortCd
					, this.dsUvstScreRfltScCd, this.dsKrhisAplemClaScCd, this.dsKrhisAplemClaScCd2
					, this.dsDltScCd, this.dsSedScCd, this.dsMtrscScCd, this.dsRlesScCd
					, this.dsBankCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
				this.fnSearch(this.pv_params.rcptNo);
		})
		.run();

	// 업로드 초기설정 - 지원자 사진 파일
	this.divFileUpload.UPLOAD_UploadComplete  = this.fnFileUploadCompleteCallback;
	this.divFileUpload.UPLOAD_OnError         = this.fnFileUploadErrorCallback;
	this.divFileUpload.UPLOAD_AfterAddFile    = this.fnFileUploadChangeCallback;     
	this.divFileUpload.UPLOAD_Form            = this;
	
	// 업로드 초기설정 - 취업지원대상자
	this.divContent11.form.divEmploSprtFile.UPLOAD_UploadComplete = this.fnFileUploadCompleteCallback;
	this.divContent11.form.divEmploSprtFile.UPLOAD_OnError        = this.fnFileUploadErrorCallback;
	this.divContent11.form.divEmploSprtFile.UPLOAD_AfterAddFile   = this.fnFileUploadChangeCallback;     
	this.divContent11.form.divEmploSprtFile.UPLOAD_Form           = this;

	// 업로드 초기설정 - 의사상자
	this.divContent12.form.divMertFile.UPLOAD_UploadComplete = this.fnFileUploadCompleteCallback;
	this.divContent12.form.divMertFile.UPLOAD_OnError        = this.fnFileUploadErrorCallback;
	this.divContent12.form.divMertFile.UPLOAD_AfterAddFile   = this.fnFileUploadChangeCallback;     
	this.divContent12.form.divMertFile.UPLOAD_Form           = this;
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid, errcd, errmsg)
{

};

//이미지 콜백
this.fnPopupCallback = function(e, sender){

	//2023.08.30 파일업로드 성공시에만 이미지 변경되도록 수정
	sImageType       = "";
	sImageFileName   = "";   // 선택된 파일이름
	sImageDataBase64 = "";
	sImageDataBase64Reduce = "";
	
	if(e.imageInfo)
	{
		sImageType       = e.imageInfo.imageType;   // 이미지 타입(image/png)
		sImageFileName   = e.imageInfo.imageFileName;   // 파일이름(test.png)
		// 사진파일 특수 문자 확인 
		var fileExtension = sImageFileName.substring(sImageFileName.lastIndexOf(".")); // 파일 확장자 
		var fileName = sImageFileName.split(fileExtension); // 파일명. 확장자 분리 
		/*var fileName = sImageFileName.split(/.png|.PNG|.jpg|.JPG|.JPEG|.jpeg|.bmp|.BMP/);*/
		var sMatch = fileName[0].match(/[\.\/\,\~\!\@\#\$\%\^\&\(\)\+\-\']/); // 파일명 특수문자 확인
		if ( sMatch != null)
		{
			this.smfAlert("사진 파일 이름에 특수 문자가 있습니다.");
			return;
		}
		sImageDataBase64 = e.imageInfo.imageDataBase64;  // BASE64의 이미지 파일
		sImageDataBase64Reduce = 	e.imageInfo.imageDataBase64Reduce; // BASE64의 이미지 파일(품질축소)
		
// 2023.08.30 파일업로드 성공시에만 이미지 변경되도록 수정
// 		if(!this.smfIsNull(sImageDataBase64))
// 		{
// 			this.divContent03.form.imgCrop._imagetype = sImageType; 
// 			this.divContent03.form.imgCrop._imagename = sImageFileName; 
// 			// 이미지 용량 작은 데이터 SET
// 			if(sImageDataBase64.length > sImageDataBase64Reduce.length){
// 				this.divContent03.form.imgCrop.set_image(sImageDataBase64Reduce);
// 			}else{
// 				this.divContent03.form.imgCrop.set_image(sImageDataBase64);
// 			}
// 			this.divContent03.form.imgCrop.set_text("");
// 		}
 	}
	
// 2023.08.30 파일업로드 성공시에만 이미지 변경되도록 수정	
// 	var sBase64Data = this.divContent03.form.imgCrop.image;
// 	this.divFileUpload.form.fnResetUpload();
// 	this.divFileUpload.form.fnFileUploadWithBase64(sBase64Data, sImageFileName);
	this.divFileUpload.form.fnResetUpload();
	// 이미지 용량 작은 데이터 SET
	if(sImageDataBase64.length > sImageDataBase64Reduce.length){
		this.divFileUpload.form.fnFileUploadWithBase64(sImageDataBase64Reduce, sImageFileName);
	}else{
		this.divFileUpload.form.fnFileUploadWithBase64(sImageDataBase64, sImageFileName);
	}
	
};

// 우편번호검색 콜백
this.fnCommpopRdnZipCallback = function(e)
{
	this.dsMain.setColumn(0, "dmclZip",  e.zipCd);
	this.dsMain.setColumn(0, "dmclZipAddr", e.roadNmAddr);
	this.dsMain.setColumn(0, "dmclZipDaddr", e.roadNmDtl);
};

// 발급기관명 찾기 콜백
this.fnCommpopTchQlfInstCallback = function(e)
{
	this.dsMain.setColumn(0, "tchQlfInstCdN", e.row.unyCdValue);
	this.dsMain.setColumn(0, "tchQlfInstNmN", e.row.unyCdValueNm);
};

// 파일 업로드 성공 콜백
this.fnFileUploadCompleteCallback = function(obj, paramObj, objResultDataset)
{
	var target = obj.parent.parent.id;
	switch(target){
		// 지원자 사진 파일
		case 'divFileUpload' : 
			//2023.08.30 파일업로드 성공시에만 이미지 변경되도록 수정
			if(!this.smfIsNull(sImageDataBase64))
			{
				this.divContent03.form.imgCrop._imagetype = sImageType; 
				this.divContent03.form.imgCrop._imagename = sImageFileName; 
				// 이미지 용량 작은 데이터 SET
				if(sImageDataBase64.length > sImageDataBase64Reduce.length){
					this.divContent03.form.imgCrop.set_image(sImageDataBase64Reduce);
				}else{
					this.divContent03.form.imgCrop.set_image(sImageDataBase64);
				}
				this.divContent03.form.imgCrop.set_text("");
			}
		
			this.divFileUpload.form.fnSetUploadCompleteState(obj,paramObj);
			this.dsMain.setColumn(0, "photoRefrnId", objResultDataset.getColumn(0, "fileRefrnId"));
			this.dsMain.setColumn(0, "apstPhotoFileNm", objResultDataset.getColumn(0, "atchFileNm"));
		break;
		
		// 대학성적증명자료
		//case 'divUvstScreFile' : 
		//	this.divContent06.form.divUvstScreFile.form.fnSetUploadCompleteState(obj,paramObj);
		//	this.dsMain.setColumn(0, "uvstScreFileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
		//break;
		// 취업지원대상자
		case 'divEmploSprtFile' : 
			this.divContent11.form.divEmploSprtFile.form.fnSetUploadCompleteState(obj,paramObj);
			this.dsMain.setColumn(0, "emploSprtFileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
