			this.dsMain.setColumn(0, "rlesVrfcFileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
		break;
		// 교원자격검증
		case 'divTchQlfFileRefrnFile' : 
			this.divContent05.form.divContent01.form.divTchQlfFileRefrnFile.form.fnSetUploadCompleteState(obj,paramObj);
			this.dsMain.setColumn(0, "tchQlfFileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
		break;		
		// 한국사 검증
		case 'divKrhisCetFileRefrnFile' : 
			this.divContent07.form.divKrhisCetFileRefrnFile.form.fnSetUploadCompleteState(obj,paramObj);
			this.dsMain.setColumn(0, "krhisCetFileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
		break;		
		// 장애인검증
		case 'divDltCnvFile' : 
			this.divContent08.form.divDltCnvFile.form.fnSetUploadCompleteState(obj,paramObj);
			this.dsMain.setColumn(0, "dltCnvFileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
		break;		
		// 임신부검증 
		case 'divPgnwCnvFile' : 
			this.divContent09.form.divPgnwCnvFile.form.fnSetUploadCompleteState(obj,paramObj);
			this.dsMain.setColumn(0, "pgnwCnvFileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
		break;	
		
		// 병역검증 
		//case 'divMtrscFlflFile' : 
