<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="popupForm" width="800" height="450" titletext="지방공무원-지원서작성-한국산업인력공단 정보제공동의팝업" onload="form_onload" canlayoutchange="btnCancel_onclick">
    <Layouts>
      <Layout height="450" width="800" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divMain" taborder="1" left="20" height="350" top="20" text="" cssclass="div_WF_Detail" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="한국산업인력공단 정보제공동의" left="0" top="-1" width="250" height="28" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn" onclick="divMain_imgTitle00_onclick" accessibilitylabel="정보제공동의"/>
              <Static id="staContent02" taborder="1" left="0" top="42" height="248" cssclass="sta_WF_InfoTop" right="0" text="&#13;&#10;본인에 관한 행정 정보의 제공에 대한 전자정부법 제43조의 2에 따라 아래의 사항 등을 동의하여야만&#13;&#10;국가기술자격(한국산업인력공단) 정보제공이 가능합니다. &#13;&#10;&#13;&#10; ● 제공 요구를 받는 기관: 한국산업인력공단&#13;&#10; ● 제공 요구하는 본인 정보: 국가기술자격정보&#13;&#10; ● 본인 정보를 제공받는 자: 교육부(17개 시도교육청)&#13;&#10; ● 행정정보 제공 요구 데이터 항목 : &lt;fc v='#1E5DF2'&gt;기관명, 성명, 종목명, 자격증번호, 등급코드, 자격취득일자, 자격취득상태 &lt;/fc&gt;&#13;&#10; ● 본인정보제공 주기: 일회적 제공&#13;&#10;&#13;&#10; ※ 위의 행정정보는전자정부법시행령 제90조(민간정보및 고유식별정보의  처리)에 따라 수집ㆍ이용되며, &#13;&#10;    이에 대한 요구를 거부할 권리가 있습니다. &lt;fc v='#d32850'&gt;다만 요구를 거부할 경우 서류 제출을 요구할 수 있습니다.&lt;/fc&gt;&#13;&#10;" initvalueid="ivStcAccessibilityOn" usedecorate="true" accessibilitylabel="제보제공동의내용"/>
              <Radio id="rdoAgree" taborder="2" left="10" top="301" width="185" height="30" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" rowcount="-1" text="요구하지 않음" index="1" initvalueid="ivRdoEssential" cssclass="essential" columncount="-1" enable="true" value="N" accessibilitylabel="요구/요구하지않음 선택">
                <Dataset id="innerdataset">
                  <ColumnInfo>
                    <Column id="codecolumn" size="256"/>
                    <Column id="datacolumn" size="256"/>
                  </ColumnInfo>
                  <Rows>
                    <Row>
                      <Col id="codecolumn">Y</Col>
                      <Col id="datacolumn">요구</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">N</Col>
                      <Col id="datacolumn">요구하지 않음</Col>
                    </Row>
                  </Rows>
                </Dataset>
              </Radio>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnCancel" taborder="2" text="취소" height="30" width="50" left="43.25%" cssclass="btn_WF_Custom" initvalueid="ivBtnAccessibilityButton" top="380" onclick="btnCancel_onclick" accessibilitylabel="취소"/>
        <Button id="btnNext" taborder="3" text="확인" height="30" width="50" left="btnCancel:8" initvalueid="ivBtnAccessibilityButton" top="380" onclick="btnNext_onclick" accessibilitylabel="확인"/>
        <Static id="staGd00" taborder="4" left="20" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd04" taborder="5" left="20" cssclass="sta_GD_Size" text="40" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" height="40" bottom="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd01" taborder="6" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd02" taborder="7" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd03" taborder="8" left="20" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" bottom="70" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd00_00" taborder="9" left="20" top="42" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsMain" useclientlayout="true">
        <ColumnInfo>
          <Column id="agreeYn" type="STRING" size="256" description="가산코드(자체코드)"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-지방공무원-지원서작성-한국산업인력공단 가산점 동의 팝업
*  @MenuPath    pa_ore_oew_ar
*  @FileName 	pa_ore_oewar21_p01.xfdl
*  @Creator 	최재형
*  @CreateDate 	2022.11.25
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.11.25    	최재형 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// default 초기처리를 한다.
	this.smfInitPopup(obj);
	// POPUP TITLE
	this.smfUpdatePopupTitle("정보제공동의");
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 다음버튼 클릭	
 */
this.btnNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 정보수집 요구 여부
	var agree =this.divMain.form.rdoAgree.value;
	if(agree === 'N'){
		this.divMain.form.rdoAgree.setFocus();
		this.smfAlert('정보 제공 요구에 동의 하지 않을 경우 이용이 불가능 합니다.'); 
		return;	
	}
	// 동의여부 부모창 전달 : 부모창에서 동의여부에따라 가산점 팝업 분기
	this.smfSendResponseToOpener({
		"agree": this.divMain.form.rdoAgree.value
	});
	this.close(true);
};

/**
 * 취소버튼 클릭
 */
this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};

]]></Script>
  </Form>
</FDL>
