//우편번호 검색 
this.divBasicInfo_btnPostCode_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: this.fnCommpopRdnZip, // 콜백함수 지정
		sender: obj, // sender 지정

		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: 'search'
		},
	};
	// 모달팝업 실행
	this.smfDialog("_auto", "commpop::commpop_rdn_zip.xfdl", popupParams);
};
 
//저장 버튼 클릭
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 기본정보 SET
	this.fnSetSaveMain();
	
	// 원서접수 문자발송정보 SET
	this.fnSetSaveRcptSmsInfo();
	
	var fileRefrnId = this.dsCtrItmList.lookup("ctrItmCd", "18" , "fileRefrnId");
	this.fnSetSaveCtrItm(fileRefrnId);

	var photoEsntlYn = 	this.dsResultEmpmn.getColumn(0,"photoEsntlYn");

	if(this.dsResultEmpmn.getColumn(0,"photoEsntlYn") == "Y"){
		if(this.smfIsNull(this.dsMain.getColumn(0,"apstPhotoFileNm")) || this.dsMain.getColumn(0,"apstPhotoFileNm") == "NODATA"){
			this.divBasicInfo.form.btnPicture.setFocus();
			this.smfAlert('CM006', ["사진"] ); 
			return false;	
		}
	}else{
		if(this.smfIsNull(this.dsMain.getColumn(0,"apstPhotoFileNm")) && this.smfIsNull(this.dsMain.getColumn(0,"apstPhotoFileCn"))){	// 사진 파일 없을 땐, 'NODATA'값 넣음
			this.dsMain.setColumn(0, "apstPhotoFileNm", "NODATA");
			this.dsMain.setColumn(0, "apstPhotoFileCn", "NODATA");
		}
	}	

	if(this.smfIsNull(this.dsMain.getColumn(0,"sxdsCd"))){
		this.divBasicInfo.form.rdoSxdsCd.setFocus();
		this.smfAlert('CM006', ["성별"] ); 
		return false;	
	}

	var emlAddr1 = this.dsMain.getColumn(0,"emlAddr1");
	var emlAddr3 = this.dsMain.getColumn(0,"emlAddr3");
	this.dsMain.setColumn(0,"emlAddr", emlAddr1 + "@" + emlAddr3);
	
	if(this.dsResultEmpmn.getColumn(0,"emlEsntlYn") == "Y"){ // 이메일필수여부
		if(this.smfIsNull(this.dsMain.getColumn(0,"emlAddr1"))){
			this.divBasicInfo.form.edtEmlAddr1.setFocus();	
			this.smfAlert("이메일 이(가) 입력되어 있지 않습니다.\n※ 자동완성 기능으로 입력하신 경우 이를 지우고 키보드로 직접 다시 입력해 주세요.");
			return false;	
		}
		if(this.dsMain.getColumn(0,"emlAddr3") == "" || this.dsMain.getColumn(0,"emlAddr3") == undefined){
			this.divBasicInfo.form.edtEmlAddr1.setFocus();
			this.smfAlert('이메일의 형식이 잘못되었습니다.\n※ 자동완성 기능으로 입력하신 경우 이를 지우고 키보드로 직접 다시 입력해 주세요.');
			return;
		}
	}else{
		if(!this.smfIsNull(this.divBasicInfo.form.edtEmlAddr1.value)){ 
			if(this.dsMain.getColumn(0,"emlAddr3") == "" || this.dsMain.getColumn(0,"emlAddr3") == undefined){
				this.divBasicInfo.form.edtEmlAddr1.setFocus();
				this.smfAlert('이메일의 형식이 잘못되었습니다.\n※ 자동완성 기능으로 입력하신 경우 이를 지우고 키보드로 직접 다시 입력해 주세요.');
				return;
			}
		}else{
			this.dsMain.setColumn(0,"emlAddr", "");
		}
	}
	
	//연락처 
	if(this.smfIsNull(this.dsMain.getColumn(0,"emgCnctTelno1"))){
		this.divBasicInfo.form.edtEmgCnctTelno1.setFocus();
		//this.smfAlert("비상시 연락처 이(가) 입력되어 있지 않습니다.\n※ 자동완성 기능으로 입력하신 경우 이를 지우고 키보드로 직접 다시 입력해 주세요.");this.smfAlert('CM006', ["연락처"]); 
		this.smfAlert("비상연락처 이(가) 입력되어 있지 않습니다.\n※ 자동완성 기능으로 입력하신 경우 이를 지우고 키보드로 직접 다시 입력해 주세요.");
		return false;	
	}
	if(this.smfIsNull(this.dsMain.getColumn(0,"emgCnctTelno2"))){
		this.divBasicInfo.form.edtEmgCnctTelno2.setFocus();
