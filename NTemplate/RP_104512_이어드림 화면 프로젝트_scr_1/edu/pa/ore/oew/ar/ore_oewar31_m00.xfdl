    var objAddRaonProps = {						 
	                           ExtensionAllowOrLimit	: '1'									// 설정값이 "0" 이면 설정한 파일 확장자명만 "제한"으로 설정되며, "1"로 설정시 "허용"으로 설정
							 , ExtensionArr           : 'pdf,png,jpg,jpeg,gif'		// 제한 또는 허용할 확장자 (,)로 구분
							 , DisableAlertMessage	: {
								DisableDeleteConfirm: "1" 										// "1"로 설정시 파일 삭제시 confirm창 비활성.
							 }
							};
	return objAddRaonProps;
};

// 자기소개서 한글파일도 가능 
this.fnSetRaonPropMy = function()
{
    var objAddRaonProps = {						 
	                           ExtensionAllowOrLimit	: '1'									// 설정값이 "0" 이면 설정한 파일 확장자명만 "제한"으로 설정되며, "1"로 설정시 "허용"으로 설정
							 , ExtensionArr           : 'pdf,png,jpg,jpeg,gif,hwp'		// 제한 또는 허용할 확장자 (,)로 구분
							 , DisableAlertMessage	: {
								DisableDeleteConfirm: "1" 										// "1"로 설정시 파일 삭제시 confirm창 비활성.
							 }
							};
	return objAddRaonProps;
};

