/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 // 교육공무직 지원서 정보 조회
this.fnSelectApf = function()
{
			this.smfSearchService("selectApf") 
			.run()
			// 콜백
			.callback(function(callbackParams){
				if(callbackParams.errors) {
					return;
				}
				//응시원서내역
				this.dsCtrItm.clearData();
				this.dsCtrItm.addRow();
				
				for(var i=0; i < this.dsCtrItmList.rowcount; i++){
					if(this.dsCtrItmList.getColumn(i,"ctrItmCd") == "01"){	// 최종학력
						this.dsCtrItm.setColumn(0,"rcognAcbgScCd", this.dsCtrItmList.getColumn(i,"rcognAcbgScCd") );
						this.dsCtrItm.setColumn(0,"grdtnScCd", this.dsCtrItmList.getColumn(i,"grdtnScCd") );
						this.dsCtrItm.setColumn(0,"fileRefrnId1", this.dsCtrItmList.getColumn(i,"fileRefrnId") );
						this.divCtrItm01.form.divAttach01.form.edtFile.set_value(this.dsCtrItmList.getColumn(i,"attachFl"));
					}else if(this.dsCtrItmList.getColumn(i,"ctrItmCd") == "02"){	// 취업지원대상자 가점
						this.dsCtrItm.setColumn(0,"emploSprtAdpn", this.dsCtrItmList.getColumn(i,"emploSprtAdpn") );
						if(this.dsCtrItmList.getColumn(i,"emploSprtAdpn") != 0 && this.isNotNil(this.dsCtrItmList.getColumn(i,"emploSprtAdpn"))){
							this.divCtrItm02.form.divAttach02.set_enable(true);
							this.divCtrItm02.form.divAttach02.set_enable(true);
						}
						this.dsCtrItm.setColumn(0,"fileRefrnId2", this.dsCtrItmList.getColumn(i,"fileRefrnId") );
						this.divCtrItm02.form.divAttach02.form.edtFile.set_value(this.dsCtrItmList.getColumn(i,"attachFl"));
					}else if(this.dsCtrItmList.getColumn(i,"ctrItmCd") == "03"){	// 의사상자 가점
						this.dsCtrItm.setColumn(0,"exam1TmeMertAdpn", this.dsCtrItmList.getColumn(i,"exam1TmeMertAdpn") );
						if(this.dsCtrItmList.getColumn(i,"exam1TmeMertAdpn") != 0 && this.isNotNil(this.dsCtrItmList.getColumn(i,"exam1TmeMertAdpn"))){
							this.divCtrItm03.form.divAttach03.set_enable(true);
							this.divCtrItm03.form.btnAtchFileDel03.set_enable(true);
						}
						this.dsCtrItm.setColumn(0,"fileRefrnId3", this.dsCtrItmList.getColumn(i,"fileRefrnId") );
						this.divCtrItm03.form.divAttach03.form.edtFile.set_value(this.dsCtrItmList.getColumn(i,"attachFl"));
					}else if(this.dsCtrItmList.getColumn(i,"ctrItmCd") == "04"){	//	주민등록 전입일자
						this.dsCtrItm.setColumn(0,"itmRlvtYn1", this.dsCtrItmList.getColumn(i,"itmRlvtYn") );
						this.dsCtrItm.setColumn(0,"mvinYmd", this.dsCtrItmList.getColumn(i,"mvinYmd") );
						if( this.dsCtrItmList.getColumn(i,"itmRlvtYn") != "N" ){
							this.divCtrItm04.form.calIdAddr.set_enable(true);
							this.divCtrItm04.form.divAttach04.set_enable(true);
							this.divCtrItm04.form.btnAtchFileDel04.set_enable(true);
						}
						this.dsCtrItm.setColumn(0,"fileRefrnId4", this.dsCtrItmList.getColumn(i,"fileRefrnId") );
						this.divCtrItm04.form.divAttach04.form.edtFile.set_value(this.dsCtrItmList.getColumn(i,"attachFl"));
					}else if(this.dsCtrItmList.getColumn(i,"ctrItmCd") == "05"){	// 다자녀여부
						this.dsCtrItm.setColumn(0,"itmRlvtYn2", this.dsCtrItmList.getColumn(i,"itmRlvtYn") );
						if(this.dsCtrItmList.getColumn(i,"itmRlvtYn") != "N"){
							this.divCtrItm05.form.divAttach05.set_enable(true);
							this.divCtrItm05.form.btnAtchFileDel05.set_enable(true);
						}
						this.dsCtrItm.setColumn(0,"fileRefrnId5", this.dsCtrItmList.getColumn(i,"fileRefrnId") );
						this.divCtrItm05.form.divAttach05.form.edtFile.set_value(this.dsCtrItmList.getColumn(i,"attachFl"));
					}else if(this.dsCtrItmList.getColumn(i,"ctrItmCd") == "06"){	//	고교졸업자 모집
						this.dsCtrItm.setColumn(0,"itmRlvtYn3", this.dsCtrItmList.getColumn(i,"itmRlvtYn") );
						if(this.dsCtrItmList.getColumn(i,"itmRlvtYn") != "N"){
							this.divCtrItm06.form.divAttach06.set_enable(true);
							this.divCtrItm06.form.btnAtchFileDel06.set_enable(true);
						}
						this.dsCtrItm.setColumn(0,"fileRefrnId6", this.dsCtrItmList.getColumn(i,"fileRefrnId") );
						this.divCtrItm06.form.divAttach06.form.edtFile.set_value(this.dsCtrItmList.getColumn(i,"attachFl"));
					}else if(this.dsCtrItmList.getColumn(i,"ctrItmCd") == "07"){	// 특수교육대상 학부모
						this.dsCtrItm.setColumn(0,"itmRlvtYn4", this.dsCtrItmList.getColumn(i,"itmRlvtYn") );
						if(this.dsCtrItmList.getColumn(i,"itmRlvtYn") != "N"){
							this.divCtrItm07.form.divAttach07.set_enable(true);
							this.divCtrItm07.form.btnAtchFileDel07.set_enable(true);
						}
						this.dsCtrItm.setColumn(0,"fileRefrnId7", this.dsCtrItmList.getColumn(i,"fileRefrnId") );
						this.divCtrItm07.form.divAttach07.form.edtFile.set_value(this.dsCtrItmList.getColumn(i,"attachFl"));
					}else if(this.dsCtrItmList.getColumn(i,"ctrItmCd") == "08"){	// 저소득층 여부
						this.dsCtrItm.setColumn(0,"itmRlvtYn5", this.dsCtrItmList.getColumn(i,"itmRlvtYn") );
						if(this.dsCtrItmList.getColumn(i,"itmRlvtYn") != "N"){
							this.divCtrItm08.form.divAttach08.set_enable(true);
							this.divCtrItm08.form.btnAtchFileDel08.set_enable(true);
						}
						this.dsCtrItm.setColumn(0,"fileRefrnId8", this.dsCtrItmList.getColumn(i,"fileRefrnId") );
						this.divCtrItm08.form.divAttach08.form.edtFile.set_value(this.dsCtrItmList.getColumn(i,"attachFl"));
					}else if(this.dsCtrItmList.getColumn(i,"ctrItmCd") == "09"){	// 장애인 여부
						this.dsCtrItm.setColumn(0,"itmRlvtYn6", this.dsCtrItmList.getColumn(i,"itmRlvtYn") );
						this.dsCtrItm.setColumn(0,"dltClaCd", this.dsCtrItmList.getColumn(i,"dltClaCd") );
						if( this.dsCtrItmList.getColumn(i,"itmRlvtYn") != "N" ){
							this.divCtrItm09.form.cboDisPer.set_enable(true);
							this.divCtrItm09.form.divAttach09.set_enable(true);
							this.divCtrItm09.form.btnAtchFileDel09.set_enable(true);
						}	
						this.dsCtrItm.setColumn(0,"fileRefrnId9", this.dsCtrItmList.getColumn(i,"fileRefrnId") );
						this.divCtrItm09.form.divAttach09.form.edtFile.set_value(this.dsCtrItmList.getColumn(i,"attachFl"));
					}else if(this.dsCtrItmList.getColumn(i,"ctrItmCd") == "10"){	// 장애인임산부편의지원
						this.dsCtrItm.setColumn(0,"itmRlvtYn7", this.dsCtrItmList.getColumn(i,"itmRlvtYn") );
						if( this.dsCtrItmList.getColumn(i,"itmRlvtYn") != "N" ){
							this.divCtrItm10.form.divAttach10.set_enable(true);
							this.divCtrItm10.form.btnAtchFileDel10.set_enable(true);
						}
						this.dsCtrItm.setColumn(0,"fileRefrnId10", this.dsCtrItmList.getColumn(i,"fileRefrnId") );
						this.divCtrItm10.form.divAttach10.form.edtFile.set_value(this.dsCtrItmList.getColumn(i,"attachFl"));
					}else if(this.dsCtrItmList.getColumn(i,"ctrItmCd") == "11"){
						this.dsCtrItm.setColumn(0,"fileRefrnId11", this.dsCtrItmList.getColumn(i,"fileRefrnId") );
						this.divCtrItm11.form.divAttach11.form.edtFile.set_value(this.dsCtrItmList.getColumn(i,"attachFl"));
					}else if(this.dsCtrItmList.getColumn(i,"ctrItmCd") == "12"){
						this.dsCtrItm.setColumn(0,"rcognAcbgScCd2", this.dsCtrItmList.getColumn(i,"rcognAcbgScCd") );
						this.dsCtrItm.setColumn(0,"grdtnYmd"      , this.dsCtrItmList.getColumn(i,"grdtnYmd") );
						this.dsCtrItm.setColumn(0,"shlNm"         , this.dsCtrItmList.getColumn(i,"shlNm") );
						this.dsCtrItm.setColumn(0,"dddepNm"       , this.dsCtrItmList.getColumn(i,"dddepNm") );
						this.dsCtrItm.setColumn(0,"fileRefrnId12", this.dsCtrItmList.getColumn(i,"fileRefrnId") );
						this.divCtrItm12.form.divAttach12.form.edtFile.set_value(this.dsCtrItmList.getColumn(i,"attachFl"));
					}else if(this.dsCtrItmList.getColumn(i,"ctrItmCd") == "18"){
							//처음 한번만 파일 정보 조회 
							if ( this.sFileinfoR ){
								this.sFileinfoR = false;
								var sFileSn = this.dsCtrItmList.getColumn(i,"fileRefrnId") ;
								if(!this.smfIsNull(sFileSn)){
									this.divCtrItm18.form.divAttach18.form.fnResetUpload();  // 업로드 초기화
									this.transaction("fn_filesearch" // serviceId
												,"baseUrl::/cm_cmc_file_upload_001.do" // url
												,"" // inDataset
												,"dsFileinfo=atchFileinfo" // outDataset
												,"fileRefrnId='"+sFileSn+"'"
												,"" // callbackFunction
												,false );
												
									for (var j = 0; j < this.dsFileinfo.rowcount; j++) {
											var responseCustomValue = "";
											var sDownloadUrl       = "";   // 
											var sPrivInfoFiltYn    = "";   // 항목 관리안함
											var sFileInfSaveYn     = "Y";  // 업무에 맞게 개발자가 세팅(Y/N)
											var sHandlerCode       = "PA.ORE.OEW"; 
											var sFileSn            = this.dsFileinfo.getColumn(j,"fileRefrnId"   );
											var sFileSeq           = this.dsFileinfo.getColumn(j,"fileId"        );
											var sFileSize          = this.dsFileinfo.getColumn(j,"atchFileMg"    );
											var sBackendFilename   = this.dsFileinfo.getColumn(j,"atchFileGuid"  );
											var sForntendFilename  = this.dsFileinfo.getColumn(j,"atchFileNm"    );
											var sFileEncryptYn     = this.dsFileinfo.getColumn(j,"fileEncryptYn" );
											var sFileSaveStg       = this.dsFileinfo.getColumn(j,"fileSaveStg"   );

											this.divCtrItm18.form.divAttach18.form.fnAddUploadedFile(sHandlerCode
											                                                       , sFileSn
																								   , sFileSize
																								   , sBackendFilename
																								   , sForntendFilename
																								   , sFileSeq
																								   , sDownloadUrl
																								   , sFileEncryptYn
																								   , sPrivInfoFiltYn
																								   , sFileSaveStg
																								   , sFileInfSaveYn );			
									}
							  } 
						 }
					}
				}
				
				//응시원서항목상세
				if(this.dsDtl.rowcount > 0){
					this.dsDtl.filter("ctrItmCd == '13'");
					this.dsGridEssenLicence.copyData(this.dsDtl, true);
					this.dsDtl.filter("ctrItmCd == '14'");
					this.dsGridLicence.copyData(this.dsDtl, true);
					this.dsDtl.filter("ctrItmCd == '15'");
					this.dsGridEssenCareer.copyData(this.dsDtl, true);
					this.dsDtl.filter("ctrItmCd == '16'");
					this.dsGridCareer.copyData(this.dsDtl, true);
					this.dsDtl.filter("ctrItmCd == '17'");
					this.dsGridAwards.copyData(this.dsDtl, true);
					this.dsDtl.filter("ctrItmCd == '19'");
					this.dsGridEtc.copyData(this.dsDtl, true);
				}

				// 사진 
				if(!this.smfIsNull(this.dsMain.getColumn(0,"apstPhotoFileCn"))){
					this.divBasicInfo.form.imgPicture.set_stretch('fit');
					this.divBasicInfo.form.imgPicture.set_text('');
					this.divBasicInfo.form.imgPicture.set_image(this.dsMain.getColumn(0,"apstPhotoFileCn"));
					this.dsMain.setColumn(0,"apstPhotoFileCn","");
				}else{
					this.divBasicInfo.form.imgPicture.set_image("");
				}
				
				// 비상연락처
				var emgCnctTelno = this.dsMain.getColumn(0, "emgCnctTelno").split("-");
				this.dsMain.setColumn(0, "emgCnctTelno1", emgCnctTelno[0]);	
				this.dsMain.setColumn(0, "emgCnctTelno2", emgCnctTelno[1]);	
				this.dsMain.setColumn(0, "emgCnctTelno3", emgCnctTelno[2]);	
				
				//E-MAIL
				var emlAddr = this.dsMain.getColumn(0,"emlAddr").split("@");
				this.dsMain.setColumn(0, "emlAddr1", emlAddr[0]);	
				this.dsMain.setColumn(0, "emlAddr2", emlAddr[1]);	
				this.dsMain.setColumn(0, "emlAddr3", emlAddr[1]);	
				if(this.divBasicInfo.form.cboEmlAddr2.index == -1){
					this.dsMain.setColumn(0, "emlAddr2", "");	 //직접입력
				}
				//  지원서 가능 여부 체크 데이터- 비동기 = false
				this.smfSearchService('selectCheckData') 
					.run()
					// 콜백
					.callback(function(callbackParams){
						if(callbackParams.errors){
							return;
						}
				});

				// 기타 API 등 데이터 취득에러
				var applpImYn = this.dsResultCheck.getColumn(0, 'applpImYn');
				// 무효시험(삭제,마감)
				var unaExamYn = this.dsResultCheck.getColumn(0, 'unaExamYn');
				// 접수불가기간
				var rcptImDtYn = this.dsResultCheck.getColumn(0, 'rcptImDtYn');
				
				if(applpImYn === 'Y' || unaExamYn === 'Y' || rcptImDtYn === 'Y'){
					var errMsg;
					if(applpImYn === 'Y'){
						errMsg = "접수가 불가능 합니다.";
					}else if(unaExamYn === 'Y'){
						errMsg = "진행중인 채용시험이 아닙니다.";
					}else{
						errMsg = "원서 접수 기간이 아닙니다.";
					}
					this.smfAlert(errMsg);
					this.divBasicInfo.set_enable(false);
					this.divCtrItm01.set_enable(false);
					this.divCtrItm02.set_enable(false);
					this.divCtrItm03.set_enable(false);
					this.divCtrItm04.set_enable(false);
					this.divCtrItm05.set_enable(false);
					this.divCtrItm06.set_enable(false);
					this.divCtrItm07.set_enable(false);
					this.divCtrItm08.set_enable(false);
					this.divCtrItm09.set_enable(false);
					this.divCtrItm10.set_enable(false);
					this.divCtrItm11.set_enable(false);
					this.divCtrItm12.set_enable(false);
					this.divCtrItm12.set_enable(false);
					this.divCtrItm13.set_enable(false);
					this.divCtrItm14.set_enable(false);
					this.divCtrItm15.set_enable(false);
					this.divCtrItm16.set_enable(false);
					this.divCtrItm17.set_enable(false);
					this.divCtrItm18.set_enable(false);
					this.divCtrItm19.set_enable(false);
					this.divActionBtn.set_enable(false);
					return;
				}	
		});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 미사용 컴포넌트 화면제어 
this.fnDiableComponent = function()
{
	var iHeight = 703; 

	/*
	-- 단일 첨부파일 
	01최종학력, 02취업지원대상자, 03의사상자, 04주민등록전입여부, 05다자녀여부
    06고교졸업자 모집, 07특수교육대상 학부모 모집, 08저소득층 여부, 09장애인여부
    10장애인임산부편의지원,11	자기소개서,12필수학력사항
    -- 그리드 첨부파일
    13필수자격(면허)사항,14자격면허사항,15필수경력사항,16경력사항,17수상내역,19	기타사항
    -- 다중 첨부파일 
	18	서류첨부
    */
	for(var i=0; i < this.dsCtrItmCd.rowcount; i++){
		var name = "divCtrItm"+this.dsCtrItmCd.getColumn(i,"ctrItmCd");
		if(this.dsCtrItmCd.getColumn(i,"useYn") == "N"){
			//기준관리 사용여부가 N일경우 화면에서 보이지않게
			this.components[name].set_visible(false);
		}else{
			this.components[name].set_visible(true);
			this.components[name].set_top(iHeight);
			if(i == 10){ 
				iHeight = iHeight+30; 
			}
			iHeight = iHeight + nexacro.toNumber(this.components[name].height) -1;  
			
			// 그리드 상단에 필수문구 세팅 
			if( i > 10 ){
				var staWdsTxt = "staIapWdsCn"+this.dsCtrItmCd.getColumn(i,"ctrItmCd");
				if(!this.smfIsNull(this.dsCtrItmCd.getColumn(i,"iapWdsCn"))){
					this.components[name].form.components[staWdsTxt].set_text( " - "+this.dsCtrItmCd.getColumn(i,"iapWdsCn") );
				}
			}
			
			//파일 업로드 세팅 
			if ( i < 12 || i == 17 ){ 
				// i < 12 : 상단 파일(단일) i == 17 : 서류첨부 (다중)
				var filename = "divAttach"+this.dsCtrItmCd.getColumn(i,"ctrItmCd");
				var btnname = "btnAtchFileDel"+this.dsCtrItmCd.getColumn(i,"ctrItmCd");

				if(i == 17){
					this.dsCtrItmCd.setColumn(i,"atchFileUseYn","Y"); 
				}
				if(this.dsCtrItmCd.getColumn(i,"atchFileUseYn") == "N"){
					if( i == 11){
						this.divCtrItm12.form.staTltEduAttach.set_visible(false);
					}
					this.components[name].form.components[filename].set_visible(false);
					this.components[name].form.components[btnname].set_visible(false);
				}else{
					this.components[name].form.components[filename].set_visible(true);
					this.components[name].form.components[filename].UPLOAD_UploadComplete = this.fnFileUploadCompleteCallback;
					this.components[name].form.components[filename].UPLOAD_OnError        = this.fnFileUploadErrorCallback;
					this.components[name].form.components[filename].UPLOAD_AfterAddFile   = this.fnFileUploadChangeCallback;     
					this.components[name].form.components[filename].UPLOAD_Form           = this;
				}
			}else{
				// 그리드 첨부파일 보이고 안보이고 세팅 
				var grdName = "grd"+this.dsCtrItmCd.getColumn(i,"ctrItmCd");
				if(this.dsCtrItmCd.getColumn(i,"atchFileUseYn") == "N"){
					this.components[name].form.components[grdName].setRealColSize( "body", this.components[name].form.components[grdName].fileCol , 0 );
					this.components[name].form.components[grdName].fileYn = "N";
				}
			}
		}
	}

	this.divActionBtn.set_top(iHeight+60);	
	this.parent.parent.scrollTo(0,0);
	this.smfResetScroll(this);
	
	//접수번호 존재할 경우 재조회
	var rcptNo = this.pv_params.rcptNo;
	if(!this.smfIsNull(rcptNo)){
	
		this.divActionBtn.form.btnNext.set_text("다음");
		this.dsResult.clearData();
		this.dsResult.addRow();
		this.dsResult.setColumn(0, "rcptNo" , rcptNo ); // 접수번호
		this.fnSelectApf();
		
	}
};

//기본정보
this.fnSetSaveMain = function()
{
	//임용시험 정보 
	this.dsMain.setColumn(0, "appoExamId", this.pv_params.appoExamId); // 임용시험ID
	this.dsMain.setColumn(0, "appoExamNm", this.pv_params.appoExamNm); // 임용시험명
	this.dsMain.setColumn(0, "eduPubsvCtpvOcptCd", this.pv_params.occupCd);
	this.dsMain.setColumn(0, "eduPubsvCtpvOcptNm", this.pv_params.occupNm);
	this.dsMain.setColumn(0, "dofdcCd", this.pv_params.distCd);
	this.dsMain.setColumn(0, "dofdcNm", this.pv_params.distNm);
	
	// 시도교육청코드
	var cddcCd = this.smfGetCddcCode();
	this.dsMain.setColumn(0, "cddcScCd", cddcCd.slice(0,3));
	// 임용시험년도
	this.dsMain.setColumn(0 ,"appoExamYr", this.pv_params.appoExamYr);

	// 비상연락처
	var emgCnctTelno1 = this.dsMain.getColumn(0, "emgCnctTelno1");	
	var emgCnctTelno2 = this.dsMain.getColumn(0, "emgCnctTelno2");	
	var emgCnctTelno3 = this.dsMain.getColumn(0, "emgCnctTelno3");
	var emgCnctTelno  = [emgCnctTelno1, emgCnctTelno2, emgCnctTelno3].join("-"); 
	if ( emgCnctTelno == "--" ){
		emgCnctTelno = "";
	}
	this.dsMain.setColumn(0, "emgCnctTelno", emgCnctTelno );
}

//기준 항목 정보 저장
this.fnSetSaveCtrItm = function(fileRefrnId)
{
	//응시원서내역 세팅!!
	this.dsCtrItmList.clearData();
	for( var i=0; i < this.dsCtrItmCd.rowcount; i++){  
		if(this.dsCtrItmCd.getColumn(i,"useYn") == "Y"){

			var row = this.dsCtrItmList.addRow();
			this.dsCtrItmList.setColumn(row, "ctrItmCd" , this.dsCtrItmCd.getColumn(i,"ctrItmCd"));
			this.dsCtrItmList.setColumn(row, "ctrItmNm" , this.dsCtrItmCd.getColumn(i,"ctrItmNm"));
			this.dsCtrItmList.setColumn(row, "atchFileUseYn" , this.dsCtrItmCd.getColumn(i,"atchFileUseYn"));
			
			if(this.dsCtrItmCd.getColumn(i,"ctrItmCd") == "01"){
				//학년구분& 졸업상태 
				var rcognAcbgScCd = this.dsCtrItm.getColumn(0,"rcognAcbgScCd");
				var grdtnScCd     = this.dsCtrItm.getColumn(0,"grdtnScCd");
				this.dsCtrItmList.setColumn(row, "rcognAcbgScCd", rcognAcbgScCd);
				this.dsCtrItmList.setColumn(row, "grdtnScCd", grdtnScCd);
				this.dsCtrItmList.setColumn(row, "fileRefrnId", this.dsCtrItm.getColumn(0,"fileRefrnId1"));			
				this.dsCtrItmList.setColumn(row, "itmRlvtYn", "Y"); 
				
			}else if(this.dsCtrItmCd.getColumn(i,"ctrItmCd") == "02"){ 
				//취업지원가산점
				var emploSprtAdpn     = this.dsCtrItm.getColumn(0,"emploSprtAdpn");
				this.dsCtrItmList.setColumn(row, "emploSprtAdpn", emploSprtAdpn);
				
				this.dsCtrItmList.setColumn(row, "emploSprtAdpn", this.dsCtrItm.getColumn(0,"emploSprtAdpn"));
				this.dsCtrItmList.setColumn(row, "fileRefrnId", this.dsCtrItm.getColumn(0,"fileRefrnId2"));	
				if(this.dsCtrItm.getColumn(0,"emploSprtAdpn") != 0) 
				{
					this.dsCtrItmList.setColumn(row, "itmRlvtYn", 'Y');
				}
			}else if(this.dsCtrItmCd.getColumn(i,"ctrItmCd") == "03"){ 
				//의사상자 가점
				var exam1TmeMertAdpn     = this.dsCtrItm.getColumn(0,"exam1TmeMertAdpn");
				this.dsCtrItmList.setColumn(row, "exam1TmeMertAdpn", exam1TmeMertAdpn);
				
				this.dsCtrItmList.setColumn(row, "exam1TmeMertAdpn",this.dsCtrItm.getColumn(0,"exam1TmeMertAdpn"));
				this.dsCtrItmList.setColumn(row, "fileRefrnId", this.dsCtrItm.getColumn(0,"fileRefrnId3"));	
				if(this.dsCtrItm.getColumn(0,"exam1TmeMertAdpn") != 0) 
				{
					this.dsCtrItmList.setColumn(row, "itmRlvtYn", 'Y');
				}
			}else if(this.dsCtrItmCd.getColumn(i,"ctrItmCd") == "04"){ 
				var itmRlvtYn1     = this.dsCtrItm.getColumn(0,"itmRlvtYn1");
				this.dsCtrItmList.setColumn(row, "itmRlvtYn1", itmRlvtYn1);
			
				this.dsCtrItmList.setColumn(row, "itmRlvtYn", this.dsCtrItm.getColumn(0,"itmRlvtYn1"));
				if(this.dsCtrItm.getColumn(0,"itmRlvtYn1") == "1"){
					//주민등록전입일자
					this.dsCtrItmList.setColumn(row, "mvinYmd", this.dsCtrItm.getColumn(0,"mvinYmd"));
				}
				this.dsCtrItmList.setColumn(row, "fileRefrnId", this.dsCtrItm.getColumn(0,"fileRefrnId4"));	
			}else if(this.dsCtrItmCd.getColumn(i,"ctrItmCd") == "05"){
				var itmRlvtYn2     = this.dsCtrItm.getColumn(0,"itmRlvtYn2");
				this.dsCtrItmList.setColumn(row, "itmRlvtYn2", itmRlvtYn2);
			
				this.dsCtrItmList.setColumn(row, "itmRlvtYn", this.dsCtrItm.getColumn(0,"itmRlvtYn2"));
				this.dsCtrItmList.setColumn(row, "fileRefrnId", this.dsCtrItm.getColumn(0,"fileRefrnId5"));	
			}else if(this.dsCtrItmCd.getColumn(i,"ctrItmCd") == "06"){
				var itmRlvtYn3     = this.dsCtrItm.getColumn(0,"itmRlvtYn3");
				this.dsCtrItmList.setColumn(row, "itmRlvtYn3", itmRlvtYn3);			
			
				this.dsCtrItmList.setColumn(row, "itmRlvtYn", this.dsCtrItm.getColumn(0,"itmRlvtYn3"));
				this.dsCtrItmList.setColumn(row, "fileRefrnId", this.dsCtrItm.getColumn(0,"fileRefrnId6"));	
			}else if(this.dsCtrItmCd.getColumn(i,"ctrItmCd") == "07"){
				var itmRlvtYn4     = this.dsCtrItm.getColumn(0,"itmRlvtYn4");
				this.dsCtrItmList.setColumn(row, "itmRlvtYn4", itmRlvtYn4);					
			
				this.dsCtrItmList.setColumn(row, "itmRlvtYn", this.dsCtrItm.getColumn(0,"itmRlvtYn4"));
				this.dsCtrItmList.setColumn(row, "fileRefrnId", this.dsCtrItm.getColumn(0,"fileRefrnId7"));	
			}else if(this.dsCtrItmCd.getColumn(i,"ctrItmCd") == "08"){
				var itmRlvtYn5     = this.dsCtrItm.getColumn(0,"itmRlvtYn5");
				this.dsCtrItmList.setColumn(row, "itmRlvtYn5", itmRlvtYn5);					
			
				this.dsCtrItmList.setColumn(row, "itmRlvtYn", this.dsCtrItm.getColumn(0,"itmRlvtYn5"));
				this.dsCtrItmList.setColumn(row, "fileRefrnId", this.dsCtrItm.getColumn(0,"fileRefrnId8"));	
			}else if(this.dsCtrItmCd.getColumn(i,"ctrItmCd") == "09"){
				var itmRlvtYn6     = this.dsCtrItm.getColumn(0,"itmRlvtYn6");
				this.dsCtrItmList.setColumn(row, "itmRlvtYn6", itmRlvtYn6);		
				
				this.dsCtrItmList.setColumn(row, "itmRlvtYn", this.dsCtrItm.getColumn(0,"itmRlvtYn6"));
				this.dsCtrItmList.setColumn(row, "fileRefrnId", this.dsCtrItm.getColumn(0,"fileRefrnId9"));	
				if(this.dsCtrItm.getColumn(0,"itmRlvtYn6") != "N"){
					var dltClaCd     = this.dsCtrItm.getColumn(0,"dltClaCd");
					//장애등급코드
					this.dsCtrItmList.setColumn(row, "dltClaCd", dltClaCd);
				}
			}else if(this.dsCtrItmCd.getColumn(i,"ctrItmCd") == "10"){
				var itmRlvtYn7     = this.dsCtrItm.getColumn(0,"itmRlvtYn7");
				this.dsCtrItmList.setColumn(row, "itmRlvtYn7", itmRlvtYn7);					
			
				this.dsCtrItmList.setColumn(row, "itmRlvtYn", this.dsCtrItm.getColumn(0,"itmRlvtYn7"));
				this.dsCtrItmList.setColumn(row, "fileRefrnId", this.dsCtrItm.getColumn(0,"fileRefrnId10"));	
			}else if(this.dsCtrItmCd.getColumn(i,"ctrItmCd") == "11"){ 
				this.dsCtrItmList.setColumn(row, "fileRefrnId", this.dsCtrItm.getColumn(0,"fileRefrnId11"));	
				this.dsCtrItmList.setColumn(row, "itmRlvtYn", "Y"); 
			}else if(this.dsCtrItmCd.getColumn(i,"ctrItmCd") == "12"){   
				var rcognAcbgScCd2  = this.dsCtrItm.getColumn(0,"rcognAcbgScCd2");  //학위구분
				var grdtnYmd        = this.dsCtrItm.getColumn(0,"grdtnYmd");        //졸업일자
				var shlNm           = this.dsCtrItm.getColumn(0,"shlNm");           //학교명
				var dddepNm         = this.dsCtrItm.getColumn(0,"dddepNm");         //전공학과명 
				this.dsCtrItmList.setColumn(row, "rcognAcbgScCd", rcognAcbgScCd2);
				this.dsCtrItmList.setColumn(row, "grdtnYmd"     , grdtnYmd);
				this.dsCtrItmList.setColumn(row, "shlNm"        , shlNm);
				this.dsCtrItmList.setColumn(row, "dddepNm"      , dddepNm);
				this.dsCtrItmList.setColumn(row, "fileRefrnId"  , this.dsCtrItm.getColumn(0,"fileRefrnId12"));	
				this.dsCtrItmList.setColumn(row,"itmRlvtYn","Y");
			}else if(this.dsCtrItmCd.getColumn(i,"ctrItmCd") == "13"){
				this.dsCtrItmList.setColumn(row,"itmRlvtYn","Y");
			}else if(this.dsCtrItmCd.getColumn(i,"ctrItmCd") == "14"){ 		
				if(this.dsGridEssenCareer.getRowCount() != 0){	
					this.dsCtrItmList.setColumn(row, "itmRlvtYn","Y"); 
				}
			}else if(this.dsCtrItmCd.getColumn(i,"ctrItmCd") == "15"){ 
				this.dsCtrItmList.setColumn(row,"itmRlvtYn","Y");
			}else if(this.dsCtrItmCd.getColumn(i,"ctrItmCd") == "16"){ 
				if(this.dsGridCareer.getRowCount() != 0){	
					this.dsCtrItmList.setColumn(row, "itmRlvtYn","Y"); 	
				}
			}else if(this.dsCtrItmCd.getColumn(i,"ctrItmCd") == "17"){ 
				if(this.dsGridAwards.getRowCount() != 0){	
					this.dsCtrItmList.setColumn(row, "itmRlvtYn","Y"); 				
				}
			}else if(this.dsCtrItmCd.getColumn(i,"ctrItmCd") == "18"){ 
				if(!this.smfIsNull(fileRefrnId)){
					this.dsCtrItmList.setColumn(row, "fileRefrnId", fileRefrnId);	
				}	
				if(this.divCtrItm18.form.divAttach18.form.fnIsExistUploadFile()){
					this.dsCtrItmList.setColumn(row, "itmRlvtYn","Y"); 
				}
			}else if(this.dsCtrItmCd.getColumn(i,"ctrItmCd") == "19"){ 
				if(this.dsGridEtc.getRowCount() != 0){	
					this.dsCtrItmList.setColumn(row, "itmRlvtYn","Y"); 
				}	
			}
		}
	}
	//응시원서항목상세
	this.dsDtl.clearData();

	for(var i=0; i < this.dsGridEssenLicence.rowcount; i++){
		var nRow = this.dsDtl.addRow();
		this.dsDtl.copyRow(nRow,this.dsGridEssenLicence,i);
		this.dsDtl.setColumn(nRow, "cdSn", i+1);
	}
	for(var i=0; i < this.dsGridLicence.rowcount; i++){
		var nRow = this.dsDtl.addRow();
		this.dsDtl.copyRow(nRow,this.dsGridLicence,i);
		this.dsDtl.setColumn(nRow, "cdSn", i+1);
	}
	for(var i=0; i < this.dsGridEssenCareer.rowcount; i++){
		var nRow = this.dsDtl.addRow();
		this.dsDtl.copyRow(nRow,this.dsGridEssenCareer,i);
		this.dsDtl.setColumn(nRow, "cdSn", i+1);
	}
	for(var i=0; i < this.dsGridCareer.rowcount; i++){
		var nRow = this.dsDtl.addRow();
		this.dsDtl.copyRow(nRow,this.dsGridCareer,i);
		this.dsDtl.setColumn(nRow, "cdSn", i+1);
	}
	for(var i=0; i < this.dsGridAwards.rowcount; i++){
		var nRow = this.dsDtl.addRow();
		this.dsDtl.copyRow(nRow,this.dsGridAwards,i);
		this.dsDtl.setColumn(nRow, "cdSn", i+1);
	}
	for(var i=0; i < this.dsGridEtc.rowcount; i++){
		var nRow = this.dsDtl.addRow();
		this.dsDtl.copyRow(nRow,this.dsGridEtc,i);
		this.dsDtl.setColumn(nRow, "cdSn", i+1);
	}
};

// 원서접수 문자발송정보 SET
 this.fnSetSaveRcptSmsInfo = function(){
	// 초기화
	this.dsRcptSms.clearData();
