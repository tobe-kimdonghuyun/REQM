	this.dsRcptSms.setColumn(0, 'cddcScCd' ,this.smfGetCddcCode().slice(0,3)); //시도교육청구분코드
	this.dsRcptSms.setColumn(0, 'cddcNm' , this.smfGetCddcName()); //시도교육청명
	this.dsRcptSms.setColumn(0, 'rcptQustTelNo' , this.dsResultEmpmn.getColumn(0, 'rcptQustTelNo')); //발신번호
	this.dsRcptSms.setColumn(0, 'mblTelno' , this.smfGetSessionValue('mblTelNo')); //수신번호
};

