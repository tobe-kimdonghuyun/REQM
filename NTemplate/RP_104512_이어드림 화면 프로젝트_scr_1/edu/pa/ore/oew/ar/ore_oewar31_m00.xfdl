// raonkupload가 파일을 삭제 후 발생 콜백함수
this.fnEventUploadAfterDeleteFile = function(obj, paramObj)
{
 	var fileNm = paramObj.userdata.strKey;
 	var formThis = this.parent;
	var row = formThis.dsOutFileinfo.findRow('atchFileGuid', fileNm);
	if (row != -1){
		formThis.dsOutFileinfo.setColumn(row, 'useYn', 'N');
	}
};

// 파일 업로드 성공 콜백
this.fnFileUploadCompleteCallback = function(obj, paramObj, objResultDataset)
{
	var target = obj.parent.parent.id;
	switch(target){
		case 'divAttach01' : 
			this.divCtrItm01.form.divAttach01.form.fnSetUploadCompleteState(obj,paramObj);
			this.dsCtrItm.setColumn(0, "fileRefrnId1", objResultDataset.getColumn(0,"fileRefrnId"));
		break;
		case 'divAttach02' : 
			this.divCtrItm02.form.divAttach02.form.fnSetUploadCompleteState(obj,paramObj);
			this.dsCtrItm.setColumn(0, "fileRefrnId2", objResultDataset.getColumn(0,"fileRefrnId"));
		break;
		case 'divAttach03' : 
			this.divCtrItm03.form.divAttach03.form.fnSetUploadCompleteState(obj,paramObj);
			this.dsCtrItm.setColumn(0, "fileRefrnId3", objResultDataset.getColumn(0,"fileRefrnId"));
		break;
		case 'divAttach04' : 
			this.divCtrItm04.form.divAttach04.form.fnSetUploadCompleteState(obj,paramObj);
			this.dsCtrItm.setColumn(0, "fileRefrnId4", objResultDataset.getColumn(0,"fileRefrnId"));
		break;
		case 'divAttach05' : 
			this.divCtrItm05.form.divAttach05.form.fnSetUploadCompleteState(obj,paramObj);
			this.dsCtrItm.setColumn(0, "fileRefrnId5", objResultDataset.getColumn(0,"fileRefrnId"));
		break;
		case 'divAttach06' : 
			this.divCtrItm06.form.divAttach06.form.fnSetUploadCompleteState(obj,paramObj);
			this.dsCtrItm.setColumn(0, "fileRefrnId6", objResultDataset.getColumn(0,"fileRefrnId"));
		break;
		case 'divAttach07' : 
			this.divCtrItm07.form.divAttach07.form.fnSetUploadCompleteState(obj,paramObj);
			this.dsCtrItm.setColumn(0, "fileRefrnId7", objResultDataset.getColumn(0,"fileRefrnId"));
		break;
		case 'divAttach08' : 
			this.divCtrItm08.form.divAttach08.form.fnSetUploadCompleteState(obj,paramObj);
			this.dsCtrItm.setColumn(0, "fileRefrnId8", objResultDataset.getColumn(0,"fileRefrnId"));
		break;		
		case 'divAttach09' : 
			this.divCtrItm09.form.divAttach09.form.fnSetUploadCompleteState(obj,paramObj);
			this.dsCtrItm.setColumn(0, "fileRefrnId9", objResultDataset.getColumn(0,"fileRefrnId"));
		break;
		case 'divAttach10' : 
			this.divCtrItm10.form.divAttach10.form.fnSetUploadCompleteState(obj,paramObj);
			this.dsCtrItm.setColumn(0, "fileRefrnId10", objResultDataset.getColumn(0,"fileRefrnId"));
		break;
		case 'divAttach11' : 
			this.divCtrItm11.form.divAttach11.form.fnSetUploadCompleteState(obj,paramObj);
			this.dsCtrItm.setColumn(0, "fileRefrnId11", objResultDataset.getColumn(0,"fileRefrnId"));
		break;
		case 'divAttach12' : 
			this.divCtrItm12.form.divAttach12.form.fnSetUploadCompleteState(obj,paramObj);
			this.dsCtrItm.setColumn(0, "fileRefrnId12", objResultDataset.getColumn(0,"fileRefrnId"));
		break;	
	    case 'divAttach18' : 
			this.divCtrItm18.form.divAttach18.form.fnSetUploadCompleteState(obj,paramObj);
			var nRow = this.dsCtrItmList.findRow("ctrItmCd" , "18");
			if(nRow != -1){
				this.dsCtrItmList.setColumn(nRow, "fileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));	
			}
			
			// 저장
			this.smfSaveService("saveAppo")
				.showConfirm(false)
				.validateForm(this.divBasicInfo)
				.run()
				.callback(function(callbackParams){
					if(callbackParams.errors) return;
						this.dsMain.setColumn(0,"rcptNo",this.dsResult.getColumn(0,"rcptNo")); //수정일 경우 접수번호
						this.fnSelectApf();
						if(this.divActionBtn.form.btnNext.text == "접수완료"){   
							this.smfAlert('저장이 완료되었습니다.\접수완료버튼을 눌러 접수를 확인하시기 바랍니다.');
						}else{
							this.smfAlert('저장이 완료되었습니다.\다음버튼을 눌러 접수를 확인하시기 바랍니다.');
						}
					// 저장이 완료되었습니다.
					//this.smfAlert('CM002', [], function(){

					//});
			});	
		break;	
		case 'divFileUpload' :  //사진
			//2023.08.30 파일업로드 성공시에만 이미지 변경되도록 수정
			if(!this.smfIsNull(sImageDataBase64))
			{
				this.divBasicInfo.form.imgPicture._imagetype = sImageType; 
				this.divBasicInfo.form.imgPicture._imagename = sImageFileName; 
				// 이미지 용량 작은 데이터 SET
				if(sImageDataBase64.length > sImageDataBase64Reduce.length){
					this.divBasicInfo.form.imgPicture.set_image(sImageDataBase64Reduce);
				}else{
					this.divBasicInfo.form.imgPicture.set_image(sImageDataBase64);
				}
				this.divBasicInfo.form.imgPicture.set_text("");
			}
		
			this.divFileUpload.form.fnSetUploadCompleteState(obj,paramObj);
			this.dsMain.setColumn(0, "photoRefrnId", objResultDataset.getColumn(0, "fileRefrnId"));
			this.dsMain.setColumn(0, "apstPhotoFileNm", objResultDataset.getColumn(0, "atchFileNm"));
			
		break;	
	}
};

