    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-교육공무직-지원서 작성
*  @MenuPath    pa_ore_oew_ar
*  @FileName 	pa_ore_oewar31_m00.xfdl
*  @Creator 	
*  @CreateDate 	2022.8.4
*  @Desction    온라인통합채용-교육공무직-지원서 작성
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.8.4    	 	                    최초 생성 
*  2022.12.02        최정민
*******************************************************************************
*/

include "lib::cm_script.xjs";
include "lib::ore_script.xjs";
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.sFileinfoR = true; // 파일 조회 여부( 처음 한번만 조회 )
this.rcptQustTelNo = ""; //문의전화번호 

//2023.08.30 파일업로드 성공시에만 이미지 변경되도록 수정
this.sImageType       = "";
this.sImageFileName   = "";   // 선택된 파일이름
this.sImageDataBase64 = "";
this.sImageDataBase64Reduce = "";

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form 초기화
	this.smfInitForm(obj);
	
	//  본인인증
	this.dsMain.setColumn(0,"applpFlnm", this.smfGetSessionValue('userNm'));
	this.dsMain.setColumn(0,"mblTelno" , this.smfGetSessionValue('mblTelNo'));
	var brdt = this.smfGetSessionValue('brdt');
	if(this.smfIsNull(brdt)){
		 brdt = this.applpRrnoToBrdt(nexacro.base64Decode(this.smfGetSessionValue('userRrno')));
	}
	this.dsMain.setColumn(0,"applpBrdt", brdt);
	this.dsMain.setColumn(0,"applpBrdt1", brdt.substr(0,4)+"년"+brdt.substr(4,2)+"월"+brdt.substr(6)+"일");
	this.dsMain.setColumn(0,"pafrUserId" , this.smfGetSessionValue('userDtcNo'));

 	//원서 정보 세팅
 	this.pv_params  = this.smfGetFormParams();
 	var appoExamNm  = this.pv_params.appoExamNm;  // 시험명
 	var appoOccupNm = this.pv_params.occupNm;	  // 직종
 	var appoDistNm  = this.pv_params.distNm;      // 지역 
	var dltpRcritNmprCnt = this.pv_params.dltpRcritNmprCnt;	// 장애모집인원
	var rcritNmprCnt = this.pv_params.rcritNmprCnt;	// 모집인원(일반)
 	this.staSubTltInfo00.set_text(appoExamNm);
	this.staSubTltInfo01.set_text(appoOccupNm);
	this.staSubTltInfo02.set_text(appoDistNm);

	//서류첨부 초기설정 
	this.divCtrItm18.form.divAttach18.form.RaonkUpload.addEventHandler("RAONKUPLOAD_AfterDeleteFile", this.fnEventUploadAfterDeleteFile, false);
	
	//사진
	this.divFileUpload.UPLOAD_UploadComplete  = this.fnFileUploadCompleteCallback;
	this.divFileUpload.UPLOAD_OnError         = this.fnFileUploadErrorCallback; 
	this.divFileUpload.UPLOAD_Form            = this;
	
	// 공통코드
	// dsRcognAcbgScCd :학력사항 | dsGrdtnScCd:졸업상태 | dsDltClaCd:장애등급
	this.smfCodeList("code", [this.dsRcognAcbgScCd, this.dsGrdtnScCd, this.dsDltClaCd ])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.divCtrItm01.form.cboEdu.set_index(0);
			
			var cddcCd = this.smfGetCddcCode();
			this.dsSearch.setColumn(0, "cddcCd", cddcCd.slice(0,3));
			this.dsSearch.setColumn(0, "empmnExamId", this.pv_params.appoExamId);
			this.dsSearch.setColumn(0, "orgCd", this.pv_params.orgCd);
			this.dsSearch.setColumn(0, "eduPubsvCtpvOcptCd",this.pv_params.occupCd);
			this.dsSearch.setColumn(0, "dstrtCd", this.pv_params.distCd);
			
			//개요 상세 조회 
			this.smfSearchService('selectAppoExamDtl') 
			.run()
			.callback(function(callbackParams){
				if(callbackParams.errors) return;

					if(dltpRcritNmprCnt > 0 && rcritNmprCnt == 0 && this.dsResultEmpmn.getColumn(0, "dltYn") == "Y"){
						this.sta00.set_visible(true);
						this.sta00.set_text("※ 해당 채용시험은 장애인 등록이 된 지원자에게 특화된 채용시험입니다.");
					}
					// 접수문의번호
					this.rcptQustTelNo = this.dsResultEmpmn.getColumn(0, 'rcptQustTelNo');
					this.rcptQustHrValue = this.dsResultEmpmn.getColumn(0, 'rcptQustHrValue');	     		
					this.lcltyRcptInquiryInfo(this.rcptQustTelNo,this.rcptQustHrValue);	
		
					if(this.dsResultItm.rowcount > 0){
						this.dsCtrItmCd.clearData();
						this.dsCtrItmCd.copyData(this.dsResultItm);
					}
					
					this.dsCtrItm.setColumn(0,"emploSprtAdpn", "" );				
					this.dsCtrItm.setColumn(0,"exam1TmeMertAdpn", "" );					
					this.dsCtrItm.setColumn(0,"itmRlvtYn1", "" );
					this.dsCtrItm.setColumn(0,"itmRlvtYn2", "" );					
					this.dsCtrItm.setColumn(0,"itmRlvtYn3", "" );
					this.dsCtrItm.setColumn(0,"itmRlvtYn4", "" );
					this.dsCtrItm.setColumn(0,"itmRlvtYn5", "" );					
					this.dsCtrItm.setColumn(0,"itmRlvtYn6", "" );					
					this.dsCtrItm.setColumn(0,"itmRlvtYn7", "" );
					
					this.dsMain.setColumn(0,"appoExamMastrIdfId", this.dsResultEmpmn.getColumn(0,"empmnExamMastrIdfId"));

					this.fnDiableComponent();
			});	
			
		})		
		.run();		
};

/**
* 접수문의 정보
*/
this.lcltyRcptInquiryInfo= function(rcptQustTelNo,rcptQustHrValue){
	var returnValue ='';
	if( this.smfIsNull(rcptQustTelNo) 
	  || "undefined" === rcptQustTelNo
	  || this.smfIsNull(rcptQustHrValue) 
	  || "undefined" === rcptQustHrValue
	  )
	 {
		this.divInqInfo.form.staContent01.set_text("");
		this.divInqInfo.set_visible(false);
	}else{
		returnValue = rcptQustTelNo 
		             + "   |   " + rcptQustHrValue.substring(0, 2)
					 + ":" + rcptQustHrValue.substring(2, 4)
					 + "~" + rcptQustHrValue.substring(4, 6)
					 + ":" + rcptQustHrValue.substring(6, 8)
					 + "   |   " + "점심시간 12시 ~ 13시 제외";
		this.divInqInfo.form.staContent01.set_text(returnValue);
		this.divInqInfo.set_visible(true);
	}
}


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
//이미지 콜백
this.fnPopupCallback = function(e, sender){

	//2023.08.30 파일업로드 성공시에만 이미지 변경되도록 수정
	sImageType       = "";
	sImageFileName   = "";   // 선택된 파일이름
	sImageDataBase64 = "";
	sImageDataBase64Reduce = "";

	if(e.imageInfo)
	{
		sImageType       = e.imageInfo.imageType;       // 이미지 타입(image/png)
		sImageFileName   = e.imageInfo.imageFileName;    // 파일이름(test.png)
		// 사진파일 특수 문자 확인 
		var fileExtension = sImageFileName.substring(sImageFileName.lastIndexOf(".")); // 파일 확장자 
		var fileName = sImageFileName.split(fileExtension); // 파일명. 확장자 분리 
		/*var fileName = sImageFileName.split(/.png|.PNG|.jpg|.JPG|.JPEG|.jpeg|.bmp|.BMP/);*/
		var sMatch = fileName[0].match(/[\.\/\,\~\!\@\#\$\%\^\&\(\)\+\-\']/); // 파일명 특수문자 확인
		if ( sMatch != null)
		{
			this.smfAlert("사진 파일 이름에 특수 문자가 있습니다.");
			return;
		}
		sImageDataBase64 = e.imageInfo.imageDataBase64;  // BASE64의 이미지 파일
		sImageDataBase64Reduce = 	e.imageInfo.imageDataBase64Reduce; // BASE64의 이미지 파일(품질축소)
		
//2023.08.30 파일업로드 성공시에만 이미지 변경되도록 수정
// 		if(!this.smfIsNull(sImageDataBase64))
// 		{
// 			this.divBasicInfo.form.imgPicture._imagetype = sImageType; 
// 			this.divBasicInfo.form.imgPicture._imagename = sImageFileName; 
// 			// 이미지 용량 작은 데이터 SET
// 			if(sImageDataBase64.length > sImageDataBase64Reduce.length){
// 				this.divBasicInfo.form.imgPicture.set_image(sImageDataBase64Reduce);
// 			}else{
// 				this.divBasicInfo.form.imgPicture.set_image(sImageDataBase64);
// 			}
// 			this.divBasicInfo.form.imgPicture.set_text("");
// 		}
 	}

//2023.08.30 파일업로드 성공시에만 이미지 변경되도록 수정
// 	var sBase64Data = this.divBasicInfo.form.imgPicture.image;
// 	this.divFileUpload.form.fnResetUpload();
// 	this.divFileUpload.form.fnFileUploadWithBase64(sBase64Data, sImageFileName);
	this.divFileUpload.form.fnResetUpload();
	// 이미지 용량 작은 데이터 SET
	if(sImageDataBase64.length > sImageDataBase64Reduce.length){
		this.divFileUpload.form.fnFileUploadWithBase64(sImageDataBase64Reduce, sImageFileName);
	}else{
		this.divFileUpload.form.fnFileUploadWithBase64(sImageDataBase64, sImageFileName);
	}
	
};

//우편번호 검색 콜백 
this.fnCommpopRdnZip = function(e, sender){
	this.dsMain.setColumn(0, "dmclZip", e.zipCd);
	this.dsMain.setColumn(0, "dmclZipAddr", e.roadNmAddr);
	this.dsMain.setColumn(0, "dmclZipDaddr", e.roadNmDtl);
};

//  필수자격(면허)사항 추가 팝업 콜백
this.fnEssenLicenceAddModalCallback = function(e, sender){
	var idx = this.dsGridEssenLicence.addRow();
	this.dsGridEssenLicence.setColumn(idx, "issuInstNm"     , e.issuInstNm); // 발급기관
	this.dsGridEssenLicence.setColumn(idx, "qlflNm"         , e.qlflNm);     // 자격증명
	this.dsGridEssenLicence.setColumn(idx, "qlflNo"         , e.qlflNo);     // 자격번호
	this.dsGridEssenLicence.setColumn(idx, "qlfAcqsYmd"     , e.qlfAcqsYmd); // 발급일
	this.dsGridEssenLicence.setColumn(idx, "attachFl"       , e.attachFl);   // 첨부파일
	this.dsGridEssenLicence.setColumn(idx, "fileRefrnId"    , e.fileRefrnId); 
	this.dsGridEssenLicence.setColumn(idx, "ctrItmCd"       , "13");
};

