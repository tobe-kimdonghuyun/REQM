				return false;	
			}
			if(this.dsCtrItmList.getColumn(i,"atchFileUseYn") == "Y" && this.divCtrItm12.form.divAttach12.enable == true){
 				if(this.smfIsNull(this.dsCtrItm.getColumn(0, "fileRefrnId12")) || this.dsCtrItm.getColumn(0, "fileRefrnId12") == ""){
 					this.divCtrItm12.form.divAttach12.setFocus();
 					this.smfAlert('CM006', ["필수학력사항 증빙자료"]); 
 					return false;
 				}
			}
		}
	}
	// 필수자격(면허)사항 유효성 검증
	if(this.divCtrItm13.visible == true){
		if(this.dsGridEssenLicence.getRowCount() == 0){
			this.divCtrItm13.form.grd13.setFocus();
 			this.smfAlert('CM006', ["필수자격(면허)사항"]); 
 			return false;
		}
	}
	// 필수경력사항 유효성 검증
	if(this.divCtrItm15.visible == true){
		if(this.dsGridEssenCareer.getRowCount() == 0){
			this.divCtrItm15.form.grd15.setFocus();
 			this.smfAlert('CM006', ["필수경력사항"]); 
 			return false;
		}
	}
	
	this.smfConfirm("저장 하시겠습니까?\n저장만 해도 접수완료 처리됩니다.\n※원서 접수기간 내에는 저장 후에도 지원서 수정이 가능합니다.※", function(result){
		if(result.confirmResult){
			var fileCount = this.divCtrItm18.form.divAttach18.form.fnIsExistUploadFile();
			if(fileCount) {
				this.divCtrItm18.form.divAttach18.form.fnFileUpload();
			}else{
				this.smfSaveService("saveAppo")
					//.validateForm(this.divBasicInfo)
					.showConfirm(false)
					.run()
					.callback(function(callbackParams){
						if(callbackParams.errors) return;
							this.dsMain.setColumn(0,"rcptNo",this.dsResult.getColumn(0,"rcptNo")); //수정일 경우 접수번호
							this.fnSelectApf();	
							
							if(this.divActionBtn.form.btnNext.text == "접수완료"){   
								this.smfAlert('저장 및 접수가 완료되었습니다.\n접수완료버튼을 눌러 접수 내역을 확인하시기 바랍니다.\n※원서 접수기간 내에는 지원서 수정이 가능합니다.※');
							}else{
								this.smfAlert('저장이 완료되었습니다.\n다음버튼을 눌러 접수 내역을 확인하시기 바랍니다.\n※원서 접수기간 내에는 지원서 수정이 가능합니다.※');
							}
						// 저장이 완료되었습니다.
						//this.smfAlert('CM002', [], function(){

						//});
				});	
			}
		}
	});
};

// grid 추가 버튼 클릭
this.btnAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if( obj.name == "btnEssenLicenceAdd" ){
		var rowCount = this.dsGridEssenLicence.rowcount;
		if( rowCount == 10 ){
			this.smfAlert("행추가는 10개까지 가능합니다.");
			return false;
		}
		//필수자격(면허)사항 
		var popupParams = {
			callback: this.fnEssenLicenceAddModalCallback, // 콜백함수 지정
			sender: obj, // sender 지정
			params: {
				procType: 'none', // 처리타입 지정
				isEssen: true, // 필수여부 지정
				fileYn : this.divCtrItm13.form.grd13.fileYn
			},
		};
		// 모달팝업 실행
		this.smfDialog("_auto", "pa_ore_oew_ar::ore_oewar31_p00.xfdl", popupParams);
	}else if( obj.name == "btnLicenceAdd" ){
		var rowCount = this.dsGridLicence.rowcount;
		if( rowCount == 10 ){
			this.smfAlert("행추가는 10개까지 가능합니다.");
			return false;
		}
		//자격(면허)사항
		var popupParams = {
			callback: this.fnLicenceAddModalCallback, // 콜백함수 지정
			sender: obj, // sender 지정
			params: {
				procType: 'none', // 처리타입 지정
				fileYn : this.divCtrItm14.form.grd14.fileYn
			},
		};
		// 모달팝업 실행
		this.smfDialog("_auto", "pa_ore_oew_ar::ore_oewar31_p00.xfdl", popupParams);
	}else if ( obj.name == "btnEssenCarrAdd" ){
		var rowCount = this.dsGridEssenCareer.rowcount;
		if( rowCount == 10 ){
			this.smfAlert("행추가는 10개까지 가능합니다.");
			return false;
		}
		//필수 경력사항 
		var popupParams = {
			callback: this.fnEssenCareerAddModalCallback, // 콜백함수 지정
			sender: obj, // sender 지정
			params: {
				procType: 'none', // 처리타입 지정
				isEssen: true,  // 필수여부 지정
				fileYn : this.divCtrItm15.form.grd15.fileYn
			},
		};
		// 모달팝업 실행
		this.smfDialog("_auto", "pa_ore_oew_ar::ore_oewar31_p01.xfdl", popupParams);
	}else if ( obj.name == "btnCarrAdd" ){
		var rowCount = this.dsGridCareer.rowcount;
		if( rowCount == 10 ){
			this.smfAlert("행추가는 10개까지 가능합니다.");
			return false;
		}
		//경력사항
		var popupParams = {
			callback: this.fnCareerAddModalCallback, // 콜백함수 지정
			sender: obj, // sender 지정
			params: {
				procType: 'none', // 처리타입 지정
				isEssen: false,  // 필수여부 지정
				fileYn : this.divCtrItm16.form.grd16.fileYn
			},
		};
		// 모달팝업 실행
		this.smfDialog("_auto", "pa_ore_oew_ar::ore_oewar31_p01.xfdl", popupParams);
	}else if ( obj.name == "btnAwardsAdd" ){
		var rowCount = this.dsGridAwards.rowcount;
		if( rowCount == 3 ){
			this.smfAlert("행추가는 3개까지 가능합니다.");
			return false;
		}
		//수상내역 
		var popupParams = {
			callback: this.fnAwardsAddModalCallback, // 콜백함수 지정
			sender: obj, // sender 지정
			params: {
				procType: 'none', // 처리타입 지정
				fileYn : this.divCtrItm17.form.grd17.fileYn
			},
		};
		// 모달팝업 실행
		this.smfDialog("_auto", "pa_ore_oew_ar::ore_oewar31_p02.xfdl", popupParams);	
	}else{
		var rowCount = this.dsGridEtc.rowcount;
		if( rowCount == 3 ){
			this.smfAlert("행추가는 3개까지 가능합니다.");
			return false;
		}
		//기타 
		var popupParams = {
			callback: this.fnEtcAddModalCallback, // 콜백함수 지정
			sender: obj, // sender 지정
			params: {
				procType: 'none', // 처리타입 지정
				fileYn : this.divCtrItm19.form.grd19.fileYn
			},
		};
		// 모달팝업 실행
		this.smfDialog("_auto", "pa_ore_oew_ar::ore_oewar31_p03.xfdl", popupParams);	
	}
	
};

//grid 삭제 버튼 클릭
this.btnDel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var dsDataset;
	if(obj.name == "btnEssenLicenceDel"){
		dsDataset = "dsGridEssenLicence";
	}else if(obj.name == "btnLicenceDel"){
		dsDataset = "dsGridLicence";
	}else if(obj.name == "btnEssenCarrDel"){
		dsDataset = "dsGridEssenCareer";
	}else if(obj.name == "btnCarrDel"){
		dsDataset = "dsGridCareer";
	}else if(obj.name == "btnAwardsDel"){
		dsDataset = "dsGridAwards";
	}else if(obj.name == "btnEtcDel"){
		dsDataset = "dsGridEtc";
	}
	
	// 데이터 없을경우
	if(this.objects[dsDataset].rowcount < 1){
		this.smfAlert("삭제 대상이 없습니다.");
		return;
	}
	// 체크박스 ON ARRAY 
	var chkIdxArray = this.objects[dsDataset].extractRows("_chk ==1");
	
	if(this.isNil(chkIdxArray)){ 
		this.smfAlert("삭제 대상을 선택 해주세요. ");
		return;
	}
	
	// 확인 메시지 출력
	this.smfConfirm("삭제 하시겠습니까?", function(result){
		if(result.confirmResult){
			// 데이터삭제
			this.objects[dsDataset].deleteMultiRows(chkIdxArray);
		}
	});	
};

// 다음 버튼 클릭
this.divActionBtn_btnNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo){
	if ( this.dsResult.rowcount == 0 ){
		this.smfAlert('저장 후 진행가능합니다.');
		return false;
	}
 	// 파라메터 세팅
 	this.pv_params = this.smfGetFormParams();
 	var params = {
 		"appoExamId" : this.pv_params.appoExamId,
		"appoExamNm" : this.pv_params.appoExamNm,
		"occupCd" : this.pv_params.occupCd,
		"occupNm" : this.pv_params.occupNm,
		"distCd" : this.pv_params.distCd,
		"distNm" : this.pv_params.distNm,
		"rcptNo" : this.dsResult.getColumn(0,"rcptNo"),
		"applpFlnm" : this.dsMain.getColumn(0,"applpFlnm"),   //이름
		"applpBrdt" : this.dsMain.getColumn(0,"applpBrdt1"),//생년월일 
		"appoExamYr" : this.pv_params.appoExamYr,
		"rcptDt" : this.dsMain.getColumn(0,"rcptDt") ,
		"rcptQustTelNo" : this.rcptQustTelNo ,
		"chorDutyNm" : this.dsResultEmpmn.getColumn(0,"chorDutyNm") //기관장 명칭추가 
 	};
	this.smfSetWorkPage("pa_ore_oew_ar::ore_oewar31_m01.xfdl", params);
};

