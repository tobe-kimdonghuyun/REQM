            </Layout>
          </Layouts>
        </Div>
        <Static id="staContent04" taborder="6" text="다. 보유기간" left="19" top="336" width="220" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
        <Div id="div00_00_00" taborder="7" left="20" height="78" cssclass="div_WF_InfoBOX" right="20" top="365" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staContent05" taborder="0" left="24" top="12" cssclass="sta_WF_Black14" text="유/초등 채용연도 이듬해 1월1일부터 3년간 또는 본인의 채용 등록 취소 요청 전까지 보유" wordWrap="char" right="20" initvalueid="ivStcAccessibilityOn" onclick="div00_sta00_00_01_01_onclick" height="49"/>
              <Static id="staGd11" taborder="1" left="0" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staGd23" taborder="2" left="0" top="19" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="20" text="20" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staGd12" taborder="3" left="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" bottom="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staGd24" taborder="4" top="20" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="20" text="20" right="0" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staContent06" taborder="8" left="18" top="461" height="45" cssclass="sta_WF_Black14" text="위의 개인정보 제공에 대한 동의를 거부할 권리가 있습니다. &#13;&#10;그러나 &lt;b v='true'&gt;동의를 거부할 경우 원활한 계약제교원 인력풀 등록에 제한을 받을 수 있습니다.&lt;/b&gt;" usedecorate="true" right="80" initvalueid="ivStcAccessibilityOn"/>
        <Radio id="rdoYn00" taborder="9" top="524" width="137" height="33" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" rowcount="-1" value="01" text="동의" index="0" right="26" initvalueid="ivRdoNormal">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row>
                <Col id="codecolumn">01</Col>
                <Col id="datacolumn">동의</Col>
              </Row>
              <Row>
                <Col id="codecolumn">02</Col>
                <Col id="datacolumn">미동의</Col>
              </Row>
            </Rows>
          </Dataset>
        </Radio>
