        <Button id="btnConfirm00" taborder="11" text="확인" width="113" height="40" cssclass="btn_WF_Action" left="btnCancel00:8" top="590" initvalueid="ivBtnAccessibilityButton" onclick="btnConfirm00_onclick"/>
        <Static id="staGd00" taborder="12" left="20" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
