        <Static id="staContent02" taborder="4" text="나. 수집·이용 목적" left="19" top="203" width="220" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
        <Div id="div00_00" taborder="5" left="20" height="78" cssclass="div_WF_InfoBOX" right="20" top="232" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staContent03" taborder="0" left="24" top="12" cssclass="sta_WF_Black14" text="온라인 교원 채용 등재 및 호봉확정을 위한 경력, 자격, 최종학력 확인" wordWrap="char" right="20" initvalueid="ivStcAccessibilityOn" onclick="div00_sta00_00_01_01_onclick" height="49"/>
              <Static id="staGd07" taborder="1" left="0" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
