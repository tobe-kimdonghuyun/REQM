        <Static id="staContent00" taborder="2" text="가. 수집·이용 항목" left="19" top="69" width="220" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
        <Div id="div00" taborder="3" left="20" height="78" cssclass="div_WF_InfoBOX" right="20" top="99" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staContent01" taborder="0" left="24" top="14" height="49" cssclass="sta_WF_Black14" text="성명, 성별, 생년월일, 나이, 이메일, 연락처, 특이사항, 자격증, 희망지역, 시간강사, 희망여부, 현(전)근무기관, 계약만료일, 직명, 주소, 학력, 경력, 성적, 채용 등록정보" wordWrap="char" right="20" initvalueid="ivStcAccessibilityOn" onclick="div00_sta00_00_01_01_onclick"/>
              <Static id="staGd03" taborder="1" left="0" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
