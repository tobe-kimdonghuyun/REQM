    </Layouts>
    <Objects/>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-지방공무원-지원서 작성 동의서 상세 팝업3
*  @MenuPath    pa_ore_oew_ar
*  @FileName 	pa_ore_oewar20_p02.xfdl
*  @Creator 	shhan
*  @CreateDate 	2022.07.29
*  @Desction    온라인통합채용-지방공무원-교육부, 시도교육청내 자료 활용 내역 팝업
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.07.29    	shhan	 	        최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// default 초기처리를 한다.
	this.smfInitPopup(obj);

	// 파라메터 셋
	this.pv_params = this.smfGetPopupParams();

	// 동의여부 초기값 설정
	this.rdoYn00.set_value(this.pv_params.ynValue);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
//동의여부 선택 여부
this.fnRadioChoice = function(){
	// opener Res
	this.smfSendResponseToOpener({
		"ynValue": this.rdoYn00.value
	});
	this.close(true);
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// 확인버튼 클릭
this.btnConfirm00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnRadioChoice();
};

// 취소버튼 클릭
this.btnCancel00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};
]]></Script>
  </Form>
</FDL>
