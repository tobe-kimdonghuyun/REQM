    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-교원임용(중등)-지원서 작성-접수완료
*  @MenuPath    pa_ore_oew_ar
*  @FileName 	pa_ore_oewar11_m02.xfdl
*  @Creator 	shhan
*  @CreateDate 	2022.08.31
*  @Desction    온라인통합채용-교원임용(중등)-지원서 작성-접수완료
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.08.31    	shhan	 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::ore_script.xjs"
//include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.pv_params;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(this);
	
	this.pv_params = this.smfGetFormParams();
	
	// 기본정보 화면처리
	this.fnInitInfo();
	
	this.divContent02.form.staContent00.set_text(this.pv_params.appoExamNm);
	this.divContent02.form.staContent01.set_text("교과 : "+this.pv_params.appoFieldNm);
	this.divContent03.form.staContent05.set_text(this.pv_params.appoExamNm);
	this.divContent03.form.staContent06.set_text(this.pv_params.appoFieldNm);
	this.divContent03.form.staContent11.set_text(this.smfGetSessionValue('userNm'));
		
	this.dsSearch.setColumn(0, 'rcptNo', this.pv_params.rcptNo);
	this.dsSearch.setColumn(0, 'cddcScCd', this.smfGetCddcCode().slice(0,3));
	this.dsSearch.setColumn(0, 'appoExamId', this.pv_params.appoExamCd);
	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid, errcd, errmsg){

};

// 접수증 리포트 콜백
this.fnReportCallback = function(svcid, errcd, errmsg){

};

//접수 취소 완료 후 이동 
this.fnCancelMessageCallback = function(){
		// PARAM
		var params = {}
		// 접수 현황 PAGE
		this.smfSetWorkPage("pa_ore_oew_rm::ore_oewrm10_m00.xfdl", params);
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 // 접수증 조회 
this.fnSearchRcptReport = function(obj, e)
{
	// 접수증 조회
	this.smfSearchService('selectRcptReport') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) {
				return;
			}
	});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 this.fnInitInfo = function(){
	this.divContent02.form.staContent00.set_text(this.pv_params.appoExamNm);
	this.divContent02.form.staContent01.set_text("분야 : "+this.pv_params.appoFieldNm);
	this.divContent03.form.staContent05.set_text(this.pv_params.appoExamNm);
	this.divContent03.form.staContent06.set_text(this.pv_params.appoFieldNm);
	this.divContent03.form.staContent11.set_text(this.smfGetSessionValue('userNm'));
	
	// 응시료 면제자
	if(this.pv_params.rlesYn === 'Y' ){
		// 응시료 면제
		this.divContent03.form.staContent12.set_text('0원 (응시료면제)');
	}else{
		// 응시료
		var  aplemAmt = nexacro.toNumber(this.pv_params.stlmAmt);
		if(aplemAmt < 1){
			// 0원 결제 응시료
			this.divContent03.form.staContent12.set_text('0원 (응시료없음)');
		}else{
			// 응시료 TXT
			this.divContent03.form.staContent12.set_text(aplemAmt + '원 (납부완료)');
		}
	}
	// 문의정보
	var inquiry = this.mlvRcptInquiryInfo(this.pv_params.rcptQustTelNo);
	this.divContent10.form.staContent01.set_text(inquiry);
}
 
//접수취소
this.fnSaveRcptCancel = function(obj, e)
{
	this.dsMainCancel.clearData();
	this.dsMainCancel.addRow();
	this.dsMainCancel.setColumn(0, 'cddcScCd', this.smfGetCddcCode().slice(0,3));// 시도교육청구분코드
	this.dsMainCancel.setColumn(0, 'eamScCd', "2"); // 초중등 구분 (중등)
	this.dsMainCancel.setColumn(0, 'rcptNo', this.dsSearch.getColumn(0, 'rcptNo')); // 접수번호
	this.dsMainCancel.setColumn(0, 'mid', this.dsResultCancelCeck.getColumn(0, 'stlmNo'));// INICIS 상점아이디
	this.dsMainCancel.setColumn(0, 'tid', this.dsResultCancelCeck.getColumn(0, 'stlmKey'));// INICIS 거래번호
	this.dsMainCancel.setColumn(0, 'payMethod', this.dsResultCancelCeck.getColumn(0, 'stlmTypIdfCd'));// INICIS 결제수단
	this.dsMainCancel.setColumn(0, 'stlmAmt', this.dsResultCancelCeck.getColumn(0, 'stlmAmt'));// 응시료(응시료 면제 검증 외 0원 있음.)
	this.dsMainCancel.setColumn(0, 'rlesYn', this.dsResultCancelCeck.getColumn(0, 'rlesYn'));// 응시료면제여부
	
	// 원서접수취소 문자발송정보 SET
	this.fnSetSaveRcptSmsInfo();
	this.dsMainCancel.setColumn(0,'payCancel','Y');		
	// 접수취소
	this.smfSaveService("saveRcptCancel")
		.showConfirm(false)
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) {
				return;
			}
			this.smfAlert("결제 취소가 완료 되었습니다.", this.fnCancelMessageCallback);
	});
};

 /**
 * 원서접수취소 문자발송정보 SET
 **/
 this.fnSetSaveRcptSmsInfo = function(){
	// 초기화
	this.dsRcptSms.clearData();
	this.dsRcptSms.addRow();
	this.dsRcptSms.setColumn(0, 'appoExamScCd' , this.smfGetAppoExamScCd()); //임용시험구분코드
	this.dsRcptSms.setColumn(0, 'cddcScCd' ,this.smfGetCddcCode().slice(0,3)); //시도교육청구분코드
	this.dsRcptSms.setColumn(0, 'cddcNm' , this.smfGetCddcName()); //시도교육청명
	this.dsRcptSms.setColumn(0, 'rcptQustTelNo' , this.pv_params.rcptQustTelNo); //발신번호
	this.dsRcptSms.setColumn(0, 'mblTelno' , this.pv_params.mblTelno); //수신번호
 }
 
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.divContent09_btnContent01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 접수증 조회
	this.fnSearchRcptReport();
	
	// 출력물 주민번호 하이픈 추가
	this.dsResultReport.setColumn(0, 'applpRrno', this.applpRrnoHyphen(this.dsResultReport.getColumn(0, 'applpRrno')));
	
	// 버튼표시여부
	var objButton = {
		"toolbar.save" : "false"    // 저장 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)           
		, "toolbar.addmemo" : "false"    // 메모 추가 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
		, "toolbar.savedm" : "false"    // 데이터 모듈 저장 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
		, "toolbar.etc" : "false"    // 다른 메뉴 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
	}

	// 리포트를 생성하기 위한 옵션을 설정한다.
	var oOzOption = {
					    reports : [	
							{	
								  displayname  : "접수증"         
								, reportname : "/edu/pa/ore/oew/ar/ore_oewar01_r01.ozr"                                
								, jsonDs     : [this.dsResultReport ]     
								, jsonDsName : ["dsReport"]          
								// 추가/보안옵션
								, security     : "N"     // [선택] 위변조방지 삽입   ("Y"(default):표시,"N":비표시)
								, voiceBarcode : "N"     // [선택] 보이스바코드 삽입 ("Y"(default):표시,"N":비표시)
								, brailleCode  : "N"    // [선택] 점자문서 생성     ("Y":생성,"N"(default):미생성)
							}						
						]
						, hidestatus : true   // [선택] 하단 상태값 표시
						, button : objButton    // [선택] 버튼의 표시 비표시를 통제
	                };
					
	//리포트를 그린다
	this.smfReportView(this,"popup",oOzOption,this.fnReportCallback);           // Div로 표시
};

//접수 취소
this.divContent09_btnContent00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfConfirm("결제 취소시 결제를 다시하셔야 정상 접수가 완료됩니다. \n결제를 취소하시겠습니까?", function(result){
		if(result.confirmResult){
			this.dsSearch.setColumn(0, "chkGb", "1");//결재취소
			this.smfSearchService("selectRcptCancelCeck")
				.showConfirm(false)
				.run()
				// 콜백
				.callback(function(callbackParams){
					if(callbackParams.errors) {
						return;
					}

					this.fnSaveRcptCancel();
			});
		}
	});
};

// 이전
this.btnAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.pv_params = this.smfGetFormParams();

	var params = {
	  	appoExamCd  : this.pv_params.appoExamCd,
		appoExamNm  : this.pv_params.appoExamNm,
		appoFieldCd : this.pv_params.appoFieldCd,
		appoFieldNm : this.pv_params.appoFieldNm,
		rcptNo : this.pv_params.rcptNo,
		updateYn : this.pv_params.updateYn
	};

	this.smfSetWorkPage("pa_ore_oew_ar::ore_oewar11_m00.xfdl", params);
};
]]></Script>
    <Objects>
      <Dataset id="dsSearch">
        <ColumnInfo>
          <Column id="rcptNo" type="STRING" size="256"/>
          <Column id="onlEmpmnExamScCd" type="STRING" size="256"/>
          <Column id="cddcScCd" type="STRING" size="256"/>
          <Column id="appoExamId" type="STRING" size="256"/>
          <Column id="chkGb" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="onlEmpmnExamScCd">2</Col>
            <Col id="chkGb">1</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">selectRcptReport</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResultReport=dsResultReport</Col>
            <Col id="url">ore_oew_ar01_005.do</Col>
            <Col id="asynctp">false</Col>
          </Row>
          <Row>
            <Col id="id">selectRcptCancelCeck</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResultCancelCeck=dsResultCancelCeck</Col>
            <Col id="url">ore_oew_ar01_007.do</Col>
          </Row>
          <Row>
            <Col id="id">saveRcptCancel</Col>
            <Col id="inDatasets">dsMainCancel=dsMainCancel dsRcptSms=dsRcptSms</Col>
            <Col id="url">ore_oew_ar01_008.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsResultReport" useclientlayout="true">
        <ColumnInfo>
          <Column id="rcptNo" type="STRING" size="256" description="접수번호"/>
          <Column id="rcptDt" type="STRING" size="256" description="접수일(결제일)"/>
          <Column id="cddcScNm" type="STRING" size="256" description="시도교육청명"/>
          <Column id="appoExamNm" type="STRING" size="256" sumtext="" description="시험명"/>
          <Column id="currNm" type="STRING" size="256" description="직렬명"/>
          <Column id="applpFlnm" type="STRING" size="256" description="성명"/>
          <Column id="applpRrno" type="STRING" size="256" description="주민번호"/>
          <Column id="typeNm" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsMainCancel" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcScCd" type="STRING" size="256" description="시도교육청구분코드"/>
          <Column id="rcptNo" type="STRING" size="256" description="접수번호"/>
          <Column id="eamScCd" type="STRING" size="256" description="초중등구분코드"/>
          <Column id="rlesYn" type="STRING" size="256" description="응시료면제여부"/>
          <Column id="stlmAmt" type="STRING" size="256" description="응시료(응시료 면제 검증 외 0원 있음)"/>
          <Column id="mid" type="STRING" size="256" description="이니시스 상점아이디"/>
          <Column id="tid" type="STRING" size="256" description="이니시스  거래번호"/>
          <Column id="signKey" type="STRING" size="256" description="이니시스  사인키"/>
          <Column id="payMethod" type="STRING" size="256" description="이니시스  결제수단"/>
          <Column id="payCancel" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsResultCancelCeck" useclientlayout="true">
        <ColumnInfo>
          <Column id="rcptNo" type="STRING" size="20" description="접수번호"/>
          <Column id="stlmSn" type="STRING" size="2" description="결제일련번호"/>
          <Column id="stlmMnsCd" type="STRING" size="4" description="결제수단코드(내부결제수단코드)"/>
          <Column id="stlmTypIdfCd" type="STRING" size="30" description="결제유형식별코드(PG사 결제수단)"/>
          <Column id="stlmDsgnNo" type="STRING" size="40" description="결제지정번호 (PG사 거래번호TID)"/>
          <Column id="stlmIdntyBgngNo" type="STRING" size="30" description="결제확인시작번호(PG 결제일시)"/>
          <Column id="stlmKey" type="STRING" size="100" description="결제식별키 (PG사 주문번호"/>
          <Column id="stlmAmt" type="STRING" size="256" description="결제금액"/>
          <Column id="stlmPrcsRltCd" type="STRING" size="5" description="결제처리결과코드  (PG사 결제결과)"/>
          <Column id="stlmYn" type="STRING" size="1" description="결제여부"/>
          <Column id="stlmNo" type="STRING" size="256" description="추적번호(KCP)"/>
          <Column id="rcptRtrcnDtYn" type="STRING" size="256" description="접수취소기간내 여부"/>
          <Column id="rlesYn" type="STRING" size="256" description="응시료면제여부"/>
          <Column id="itnRcptRtrcnBgngDt" type="STRING" size="256" description="접수취소시작일"/>
          <Column id="itnRcptRtrcnEndDt" type="STRING" size="256" description="접수취소종료일"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsRcptSms" useclientlayout="true">
        <ColumnInfo>
          <Column id="appoExamScCd" type="STRING" size="256" description="임용시험구분코드"/>
          <Column id="cddcScCd" type="STRING" size="256" description="시도교육청구분코드"/>
          <Column id="cddcNm" type="STRING" size="256" description="시도교육청명"/>
          <Column id="rcptQustTelNo" type="STRING" size="256" description="발신전화번호-온라인마스터문의번호"/>
          <Column id="mblTelno" type="STRING" size="256" description="수신전화번호"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
  </Form>
</FDL>
