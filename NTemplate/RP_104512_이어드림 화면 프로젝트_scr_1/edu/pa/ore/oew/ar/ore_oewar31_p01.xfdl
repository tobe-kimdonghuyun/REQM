<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="popupForm" width="800" height="296" titletext="교육공무직-지원서작성-경력사항 팝업" onload="form_onload" canlayoutchange="btnCancel_onclick">
    <Layouts>
      <Layout height="296" width="800" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divMain" taborder="1" left="20" height="206" top="20" text="" cssclass="div_WF_Detail" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staCont00" taborder="0" left="120" height="42" cssclass="sta_WF_Input02Top" top="0" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staCont01" taborder="1" left="120" height="42" cssclass="sta_WF_Input02" top="41" right="0" initvalueid="ivStcAccessibilityOff" text=""/>
              <Static id="staCont02" taborder="2" left="120" height="42" cssclass="sta_WF_Input02" top="82" right="0" initvalueid="ivStcAccessibilityOff" text=""/>
              <Static id="staCont03" taborder="3" left="120" height="42" cssclass="sta_WF_Input02" top="123" right="0" initvalueid="ivStcAccessibilityOff" text=""/>
              <Static id="staCont04" taborder="4" left="120" height="42" cssclass="sta_WF_Input02" top="164" right="0" initvalueid="ivStcAccessibilityOff" text=""/>
              <Static id="staTltEmpNm" taborder="5" left="0" width="120" height="42" cssclass="sta_WF_Input01Top" text="근무기관" top="0" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtEmpNm" taborder="6" left="125" top="6" height="30" initvalueid="ivEdtEssential" onchanged="divMain_edtInstNm_onchanged" right="197" maxlength="100" cssclass="essential"/>
              <Static id="staTltEmpOccup" taborder="7" left="0" width="120" height="42" cssclass="sta_WF_Input01" text="직종(직위)" top="41" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtEmpOccup" taborder="8" left="125" top="47" height="30" right="387" initvalueid="ivEdtEssential" onchanged="divMain_edtInstNm_onchanged" maxlength="90" cssclass="essential"/>
              <Static id="staTltEmpPeriod" taborder="9" left="0" width="120" height="42" cssclass="sta_WF_Input01" text="근무기간" top="82" initvalueid="ivStcAccessibilityOn"/>
              <Calendar id="calEmpPeriodFrom" taborder="10" left="125" top="88" width="119" height="30" dateformat="yyyy.MM.dd " readonly="false" initvalueid="ivCalEssential" visible="true" editformat="yyyy.MM.dd" cssclass="essential"/>
              <Static id="staFromTo" taborder="11" text="~" left="244" top="86" width="15" height="30" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOff" textAlign="center" accessibilitylabel="부터"/>
              <Calendar id="calEmpPeriodTo" taborder="12" left="259" top="88" width="119" height="30" dateformat="yyyy.MM.dd " readonly="false" initvalueid="ivCalEssential" visible="true" editformat="yyyy.MM.dd" cssclass="essential"/>
              <Static id="staHoursPerWeek" taborder="13" text="주당근무시간" left="435" top="82" width="100" height="42" cssclass="sta_WF_Input01" initvalueid="ivStcAccessibilityOff" textAlign="center"/>
              <Edit id="edtHoursPerWeek" taborder="14" left="539" top="88" height="30" right="157" initvalueid="ivEdtEssential" onchanged="divMain_edtInstNm_onchanged" inputtype="number" maxlength="2" cssclass="essential"/>
              <Static id="staTltEtc" taborder="15" left="0" width="120" height="42" cssclass="sta_WF_Input01" text="비고" top="123" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtEtc" taborder="16" left="125" top="129" height="30" right="5" initvalueid="ivEdtNormal" onchanged="divMain_edtInstNm_onchanged" maxlength="500"/>
              <Static id="staTltAttachFl" taborder="17" left="0" width="120" height="42" cssclass="sta_WF_Input01" text="증빙자료" top="164" initvalueid="ivStcAccessibilityOn"/>
              <Div id="divAttachFl" taborder="18" text="div00" left="125" top="170" height="30" url="comm::comm_fileAdd2.xfdl" initvalueid="ivDivAccessibilityOff" right="197"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnCancel" taborder="2" text="취소" height="30" width="50" left="43.25%" fittocontents="width" cssclass="btn_WF_Custom" initvalueid="ivBtnAccessibilityButton" top="247" onclick="btnCancel_onclick"/>
        <Button id="btnRegist" taborder="3" text="적용" height="30" width="50" fittocontents="width" left="btnCancel:8" initvalueid="ivBtnAccessibilityButton" top="btnCancel:-30" onclick="btnRegist_onclick"/>
        <Static id="staGd00" taborder="4" left="20" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd04" taborder="5" left="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" height="20" bottom="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd01" taborder="6" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd02" taborder="7" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd03" taborder="8" left="20" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" bottom="50" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsFile">
        <ColumnInfo>
          <Column id="fileRefrnId" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-교육공무직-지원서작성-경력사항 추가 팝업
*  @MenuPath    pa_ore_oew_ar
*  @FileName 	pa_ore_oewar31_p01.xfdl
*  @Creator 	최재형
*  @CreateDate 	2022.8.26
*  @Desction    필수경력사항 , 경력사항 공통으로 사용
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.8.26    	최재형 	        최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

	// default 초기처리를 한다.
	this.smfInitPopup(obj);

	// 파라메터 셋
	this.pv_params = this.smfGetPopupParams();
	if(this.pv_params.isEssen){
		// 팝업 타이틀
		this.smfUpdatePopupTitle("필수경력사항");
	}else{
		this.smfUpdatePopupTitle("경력사항");
	}
	
	if( this.pv_params.fileYn == "N" ){
		this.divMain.form.staTltAttachFl.set_visible(false);
		this.divMain.form.staCont04.set_visible(false);
		this.divMain.form.divAttachFl.set_visible(false);
		this.btnCancel.set_top(205);
		this.set_height(255);
	}else{
	
		//파일업로드
		this.divMain.form.divAttachFl.UPLOAD_UploadComplete = this.fnFileUploadCompleteCallback;
		this.divMain.form.divAttachFl.UPLOAD_OnError        = this.fnFileUploadErrorCallback;
		this.divMain.form.divAttachFl.UPLOAD_AfterAddFile   = this.fnFileUploadChangeCallback;     
		this.divMain.form.divAttachFl.UPLOAD_Form           = this;
	}
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 파일 업로드 성공 콜백
this.fnFileUploadCompleteCallback = function(obj, paramObj, objResultDataset)
{
	this.divMain.form.divAttachFl.form.fnSetUploadCompleteState(obj,paramObj);
	this.dsFile.setColumn(0, "fileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
}

// 파일 업로드 실패 콜백
this.fnFileUploadErrorCallback = function(obj, paramObj)
{
	//this.smfAlert('파일 업로드에 실패 하였습니다.');
}

// 파일 업로드 변경 콜백
this.fnFileUploadChangeCallback = function(obj, paramObj, sCustomValue, sFileName, nFileSize)
{
	this.divMain.form.divAttachFl.form.fnFileUpload();
}
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// 확인버튼 클릭	
this.btnRegist_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 필수값 체크
	//{0}은(는) 필수 입력입니다.
	if(this.smfIsNull(this.divMain.form.edtEmpNm.value)){
		this.divMain.form.edtEmpNm.setFocus();
		this.smfAlert('CM006', ["근무기관"], this.fnMessageCallback ); 
		return;	
	}
	if(this.smfIsNull(this.divMain.form.edtEmpOccup.value)){
		this.divMain.form.edtEmpOccup.setFocus();
		this.smfAlert('CM006', ["직종"], this.fnMessageCallback ); 
		return;	
	}
	if(this.smfIsNull(this.divMain.form.calEmpPeriodFrom.value)){
		this.divMain.form.calEmpPeriodFrom.setFocus();
		this.smfAlert('CM006', ["근무기간"], this.fnMessageCallback ); 
		return;	
	}
	if(this.smfIsNull(this.divMain.form.calEmpPeriodTo.value)){
		this.divMain.form.calEmpPeriodTo.setFocus();
		this.smfAlert('CM006', ["근무기간"], this.fnMessageCallback ); 
		return;	
	}
	if(this.divMain.form.calEmpPeriodFrom.value > this.divMain.form.calEmpPeriodTo.value){
		this.divMain.form.calEmpPeriodFrom.setFocus();
		this.smfAlert("시작일이 종료일보다 큽니다."); 
		return;			
	}
	if(this.smfIsNull(this.divMain.form.edtHoursPerWeek.value)){
		this.divMain.form.edtHoursPerWeek.setFocus();
		this.smfAlert('CM006', ["주당근무시간"], this.fnMessageCallback ); 
		return;	
	}
	if(this.divMain.form.divAttachFl.visible == true){
		if(this.smfIsNull(this.dsFile.getColumn(0, "fileRefrnId")) || this.dsFile.getColumn(0, "fileRefrnId") == ""){
			this.divMain.form.divAttachFl.setFocus();
			this.smfAlert('CM006', ["증빙자료"], this.fnMessageCallback ); 
			return;
		}	
	}
	
	// 입력값 부모창 전달
	this.smfSendResponseToOpener({
		"workInstNm"  : this.divMain.form.edtEmpNm.value,    // 근무기관
		"ocptNm"      : this.divMain.form.edtEmpOccup.value, // 직종
		"carrYmd"     : this.divMain.form.calEmpPeriodFrom.text + " ~ " + this.divMain.form.calEmpPeriodTo.text, // 근무기간
		"carrBgngYmd" : this.divMain.form.calEmpPeriodFrom.value,
		"carrEndYmd"  : this.divMain.form.calEmpPeriodTo.value,
		"wperWorkHr"  : this.divMain.form.edtHoursPerWeek.value,          // 주당근무시간
		"rmkMteCn"    : this.divMain.form.edtEtc.value,                   // 기타사항
		"attachFl"    : this.divMain.form.divAttachFl.form.edtFile.value, // 첨부파일
		"fileRefrnId" : this.dsFile.getColumn(0, "fileRefrnId")
	});
	this.close(true);
};

// 취소버튼 클릭
this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};


]]></Script>
  </Form>
</FDL>
