        </Div>
        <ImageViewer id="imgTitle02" taborder="3" text="응시분야" left="0" top="2250" height="44" cssclass="img_WF_SubTit01" width="161" initvalueid="ivTitleAccessibilityOn" tabstop="false"/>
        <Div id="divContent01" taborder="4" left="0" height="76" cssclass="div_WF_InfoBOX" top="2319" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staContent09" taborder="0" left="30" top="26" height="21" text="응시시험" wordWrap="char" cssclass="sta_WF_InfoTit02" initvalueid="ivStcAccessibilityOn" width="67"/>
              <Combo id="cboAppoExam" taborder="1" left="109" top="23" height="30" value="-선택-" index="0" initvalueid="ivCmbEssential" right="309" enable="true" enableevent="true" cssclass="essential" accessibilitylabel="개요" innerdataset="dsAppoExamList" codecolumn="appoExamId" datacolumn="appoExamNm" onitemchanged="divContent01_cboAppoExam_onitemchanged">
                <Dataset id="innerdataset">
                  <ColumnInfo>
                    <Column id="codecolumn" size="256"/>
                    <Column id="datacolumn" size="256"/>
                  </ColumnInfo>
                  <Rows>
                    <Row>
                      <Col id="codecolumn">1</Col>
                      <Col id="datacolumn">테스트개요1</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">2</Col>
                      <Col id="datacolumn">테스트개요2</Col>
                    </Row>
                  </Rows>
                </Dataset>
              </Combo>
              <Static id="staContent10" taborder="2" top="25" height="21" text="교과" wordWrap="char" cssclass="sta_WF_InfoTit02" initvalueid="ivStcAccessibilityOn" width="44" right="230"/>
              <Combo id="cboAppoField" taborder="3" text="" top="22" height="30" value="" index="-1" initvalueid="ivCmbEssential" cssclass="essential" enable="true" accessibilitylabel="교과" left="staContent10:1" right="30" innerdataset="dsNewAppoCurrList" codecolumn="currCd" datacolumn="currNm"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnNext00" taborder="5" text="다음" left="43.42%" top="2425" width="158" height="40" cssclass="btn_WF_Action" initvalueid="ivBtnAccessibilityButton" onclick="btnNext00_onclick"/>
        <Static id="staGd00" taborder="6" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd01" taborder="7" left="31" top="114" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="879" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd02" taborder="8" left="30" top="166" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="880" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd04" taborder="9" left="31" top="2289" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="879" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd05" taborder="10" left="456" top="2395" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="454" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd03" taborder="11" left="30" top="2210" height="40" cssclass="sta_GD_Size" text="40" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="300" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsSearch">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="appoExamId" type="STRING" size="256"/>
          <Column id="onlEmpmnExamScCd" type="STRING" size="256"/>
          <Column id="currCd" type="STRING" size="256"/>
          <Column id="applpRrno" type="STRING" size="256"/>
          <Column id="appoExamYr" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="cddcCd"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">selectAppoExam</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsAppoExamList=dsAppoExamList dsNewAppoCurrList=dsNewAppoCurrList</Col>
            <Col id="svctp">R</Col>
            <Col id="url">ore_oew_ar10_000.do</Col>
            <Col id="callback"/>
            <Col id="message">조회</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="id">selectCheckData</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResultCheck=dsResultCheck</Col>
            <Col id="url">ore_oew_ar00_001.do</Col>
            <Col id="asynctp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsAppoExamList" useclientlayout="true">
        <ColumnInfo>
          <Column id="appoExamId" type="STRING" size="256"/>
          <Column id="appoExamNm" type="STRING" size="256"/>
          <Column id="appoExamMastrIdfId" type="STRING" size="256"/>
          <Column id="appoExamYr" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsNewAppoCurrList" useclientlayout="true">
        <ColumnInfo>
          <Column id="currCd" type="STRING" size="256"/>
          <Column id="currNm" type="STRING" size="256"/>
          <Column id="currSorSeqNo" type="STRING" size="256"/>
          <Column id="appoExamId" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsResultCheck" useclientlayout="true" updatecontrol="true">
        <ColumnInfo>
          <Column id="applpImYn" type="STRING" size="1" description="기타 지원불가"/>
          <Column id="unaExamYn" type="STRING" size="1" description="무효시험(삭제,마감)여부"/>
          <Column id="rcptImDtYn" type="STRING" size="1" description="접수불가기간여부"/>
          <Column id="dpcnYn" type="STRING" size="1" description="중복지원여부"/>
          <Column id="dpcn2Yn" type="STRING" size="256" description="타시도중복지원여부"/>
          <Column id="dpcnDp" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="unaExamYn">N</Col>
            <Col id="rcptImDtYn">N</Col>
            <Col id="dpcnYn">N</Col>
            <Col id="applpImYn">N</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-교원임용(중등)-지원서 작성 동의서
*  @MenuPath    pa_ore_oew_ar
*  @FileName 	pa_ore_oewar10_m00.xfdl
*  @Creator 	최지원
*  @CreateDate 	2022.7.29
*  @Desction    온라인통합채용-교원임용(중등)-지원서 작성 동의서
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.7.29    	최지원 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/


/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);
	
	// 시도코드
	this.dsSearch.setColumn(0, 'cddcCd', this.smfGetCddcCode().slice(0,3));
	this.dsSearch.setColumn(0, 'applpRrno', nexacro.base64Decode(this.smfGetSessionValue('userRrno')));
	this.dsSearch.setColumn(0, 'onlEmpmnExamScCd', this.smfGetAppoExamScCd());
	
	// 개요 검색
	this.fnSearch();
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
// 개요 검색
this.fnSearch = function()
{
	// 서비스 객체 생성
	this.smfSearchService('selectAppoExam') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.dsNewAppoCurrList.filter("appoExamId==''");
	});
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){

}

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 전체 체크 여부
this.fnIsAllChecked = function()
{
	this.divContent00.form.chkVal.set_value(
		this.divContent00.form.chkVal00.value && this.divContent00.form.chkVal02.value && this.divContent00.form.chkVal03.value && this.divContent00.form.chkVal04.value
		);
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// 전체 선택
this.divContent00_chkVal_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	this.divContent00.form.chkVal00.set_value(obj.value);
	this.divContent00.form.chkVal02.set_value(obj.value);
	this.divContent00.form.chkVal03.set_value(obj.value);
	this.divContent00.form.chkVal04.set_value(obj.value);
};

// 개인정보 수집 및 이용에 관한 동의
this.divContent00_chkVal00_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	this.fnIsAllChecked();
};

// 개인정보 제3자 제공에 관한 동의
this.divContent00_chkVal02_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	this.fnIsAllChecked();
};

// 행정정보공동이용 사전 동의
this.divContent00_chkVal03_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	this.fnIsAllChecked();
};

//주민번호 사전 동의
this.divContent00_chkVal04_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	this.fnIsAllChecked();
};
// 다음 단계
this.btnNext00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	var appoExamId = this.divContent01.form.cboAppoExam.value;
	var appoExamNm = this.divContent01.form.cboAppoExam.text;
	var currCd     = this.divContent01.form.cboAppoField.value ;
	var currNm     = this.divContent01.form.cboAppoField.text ;
	
	// 조건
	// 개인정보 수집 및 이용에 대한 동의
	if( !this.divContent00.form.chkVal00.value ) {
		this.divContent00.form.chkVal00.setFocus();
		this.smfAlert('개인정보 수집 및 이용에 대한 동의 후 진행 가능 합니다.');
		return false;
	}
	
	// 주민번호 사전 동의 
	if( !this.divContent00.form.chkVal04.value ) {
		this.divContent00.form.chkVal04.setFocus();
		this.smfAlert('고유식별번호 수집 및 이용에 관한 동의 후 진행 가능 합니다.');
		return false;
	}

	// 개인정보 제3자 제공에 관한 동의
	if( !this.divContent00.form.chkVal02.value ) {
		this.divContent00.form.chkVal02.setFocus();
		this.smfAlert('개인정보 제3자 제공에 관한 동의 후 진행 가능 합니다.');
		return false;
	}
	// 행정정보공동이용 사전 동의 
	if( !this.divContent00.form.chkVal03.value ) {
		this.divContent00.form.chkVal03.setFocus();
		this.smfAlert('행정정보공동이용 사전 동의 후 진행 가능 합니다.');
		return false;
	}
	
	// 개요 선택여부
	if(this.smfIsNull(appoExamId)) {
		this.divContent01.form.cboAppoExam.setFocus();
		this.smfAlert('시험개요 선택 후 진행 가능 합니다.');
		return false;
	}
	// 교과 선택여부
	if(this.smfIsNull(currCd) ) {
		this.divContent01.form.cboAppoField.setFocus();
		this.smfAlert('교과 선택 후 진행 가능 합니다.');
		return false;
	}

	var findRow = this.dsAppoExamList.findRow("appoExamId", appoExamId);
	var appoExamMastrIdfId = this.dsAppoExamList.getColumn(findRow, "appoExamMastrIdfId");
	this.dsSearch.setColumn(0, 'appoExamId'  , appoExamId);
	this.dsSearch.setColumn(0, 'currCd'      , currCd );
	
	var findRow = this.dsAppoExamList.findRow('appoExamId', appoExamId);
	this.dsSearch.setColumn(0, 'appoExamYr', this.dsAppoExamList.getColumn(findRow, 'appoExamYr'));
	
	
	
	//  지원서 가능 여부 체크 데이터- 비동기 = false
	this.smfSearchService('selectCheckData') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors)return;

			
			// PARAM
			var params = {
				appoExamCd : appoExamId,
				appoExamNm : appoExamNm,
				appoFieldCd : currCd,
				appoFieldNm : currNm,
				appoExamMastrIdfId : appoExamMastrIdfId,
				updateYn  : "N"
			};
			this.smfSetWorkPage("pa_ore_oew_ar::ore_oewar11_m00.xfdl", params);
			
	});

	
};

// 개요 선택
this.divContent01_cboAppoExam_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.dsNewAppoCurrList.filter("appoExamId=='"+obj.value+"'");
	this.divContent01.form.cboAppoField.set_value();
};

]]></Script>
  </Form>
</FDL>
