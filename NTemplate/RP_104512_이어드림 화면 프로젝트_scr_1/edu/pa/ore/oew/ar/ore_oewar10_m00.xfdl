              <Static id="staGd05_00" taborder="16" left="1056" top="777" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="-77" initvalueid="ivStcAccessibilityOff"/>
