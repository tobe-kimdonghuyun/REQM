    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-지방공무원-지원서 작성-응시료 납부
*  @MenuPath    pa_ore_oew_ar
*  @FileName 	pa_ore_oewar21_m01.xfdl
*  @Creator 	shhan
*  @CreateDate 	2022.08.01
*  @Desction    온라인통합채용-지방공무원-지원서 작성-응시료 납부
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.08.01    	shhan	 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 // 파라메터 세팅
this.pv_params;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);
	// PARAM SET
	this.pv_params = this.smfGetFormParams();

 	// 응시원서 기본정보 Dataset 파라메터에서 복사
 	var baseParam = this.pv_params.dsMainBase;
	this.dsMainBase.clearData();
	this.dsMainBase.loadJSON(baseParam);
	
	// 응시원서 상태  Dataset 파라메터에서 복사
	var statusParam = this.pv_params.dsMainStatus;
	this.dsMainStatus.clearData();
	this.dsMainStatus.loadJSON(statusParam);
	
	// 임용시험 개요 상태  Dataset 파라메터에서 복사
	var checkParam = this.pv_params.dsResultAppoExamCeck;
	this.dsResultAppoExamCeck.clearData();
	this.dsResultAppoExamCeck.loadJSON(checkParam);
	
//  	console.log("========this.dsMainBase.saveJSON()=================");
//  	console.log(this.dsMainBase.saveJSON());
//  	console.log("========this.dsMainStatus.saveJSON()=================");
//  	console.log(this.dsMainStatus.saveJSON());
	
	// 기본정보 화면처리
	this.fnInitInfo();

	//  응시료, 결제 정보 API 조회
	this.fnSearchStmlnfo();	
	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid, errcd, errmsg){

}

/**
 * KCP 결제 팝업 콜백 
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 *
 * (2023.08.18) 결제 후, update가 되지 않는 문제가 발생함.
 *              비동기방식이 문제라 판단하여 함수를 합침. dsKcpPayResult의 전달 역할을 제거.
 */
this.fnKcpPopupCallback = function(e, sender){
	if(e.result){
		// KCP 결제결과
		var jsonData = JSON.parse(e.data);
/*		
		this.dsKcpPayResult.clearData();
		this.dsKcpPayResult.addRow();	
		//console.log('==========KCP RESULT==========');
		//console.log(jsonData);
		// KCP 승인 결과코드 [정상승인] : 0000 4자리
		if(jsonData["res_cd"] === '0000'){
			// 정상 승인의 경우 결과 코드 완료변환 :00000 / 면제 99999
			this.dsKcpPayResult.setColumn(0,'resCd', '00000');
		}else{
			// KCP 승인결과 [승인실패]
			this.dsKcpPayResult.setColumn(0,'resCd', jsonData["res_cd"]);
		}
		
		// KCP 결과 메세지
		this.dsKcpPayResult.setColumn(0,'resMsg', jsonData["res_msg"]);
		// KCP 거래 고유번호 - 거래 취소시  KEY
		this.dsKcpPayResult.setColumn(0,'tno', jsonData["tno"]);
		// KCP 결제금액
		this.dsKcpPayResult.setColumn(0,'amount', jsonData["amount"]);
		// KCP 주문번호
		this.dsKcpPayResult.setColumn(0,'orderNo', jsonData["order_no"]);
		// KCP 처리시간
		 this.dsKcpPayResult.setColumn(0,'appTime', jsonData["app_time"]);
		// KCP 거래 추적번호
		this.dsKcpPayResult.setColumn(0,'traceNo', jsonData["trace_no"]);
*/
		/*****************************************
		 * 결제정보 저장(정상,실패 모두저장)
		 *****************************************/
		// 결제처리결과코드  (PG사 결제결과)
		// KCP 승인 결과코드 [정상승인] : 0000 4자리
		var resCd = '';
		if(jsonData["res_cd"] === '0000'){
			// 정상 승인의 경우 결과 코드 완료변환 :00000 / 면제 99999
			resCd = '00000';
		}else{
			// KCP 승인결과 [승인실패]
			resCd = jsonData["res_cd"];
		}
		
		// 결제완료정보 SET
		this.dsMainStlm.clearData();
		this.dsMainStlm.addRow();
		// 접수번호
		var v_rcptNo = this.dsMainStatus.getColumn(0, 'rcptNo');
		this.dsMainStlm.setColumn(0, 'rcptNo', v_rcptNo);
		// 결제일련번호
		this.dsMainStlm.setColumn(0, 'stlmSn', '1'); 
		// KCP 결제수단
		var sKcpMethodCd  = this.divAechgInfo.form.rdoPayMethod.value;
		// 결제유형식별코드(PG사 결제수단)
		this.dsMainStlm.setColumn(0, 'stlmTypIdfCd' , sKcpMethodCd); 
		for(var i=0 ; i<this.dsKcpPayMethod.rowcount ; i++){
			// 결제수단코드에서 채용 결제수단 코드 취득
			var kcpMethodCd = this.dsKcpPayMethod.getColumn(i, 'kcpMethodCd');
			if(kcpMethodCd === sKcpMethodCd ){
				// 결제수단코드(내부결제수단코드)
				this.dsMainStlm.setColumn(0, 'stlmMnsCd' ,this.dsKcpPayMethod.getColumn(i, 'usePayMethodCd'));
				break;
			}
		}
		// 결제지정번호 (KCP 거래번호TID)
		this.dsMainStlm.setColumn(0, 'stlmKey', jsonData["tno"]); 
		// 결제확인시작번호(KCP 결제일시)
		this.dsMainStlm.setColumn(0, 'stlmIdntyBgngNo', jsonData["app_time"]); 
		// 결제식별키 (KCP 주문번호) 
		this.dsMainStlm.setColumn(0, 'stlmDsgnNo', jsonData["order_no"]); 
		// 결제금액
		this.dsMainStlm.setColumn(0, 'stlmAmt', jsonData["amount"]); 
		// 결제처리결과코드 완료 :00000 / 면제 99999
		this.dsMainStlm.setColumn(0, 'stlmPrcsRltCd', resCd); 
		// 결제성공
		if(resCd === '00000'){
			// 결제여부
			this.dsMainStlm.setColumn(0, 'stlmYn', 'Y');
			// 메인 상태값 결제완료로 변경
			this.dsMainBase.setColumn(0, 'stlmYn', 'Y');
		}else{
			// 결제여부
			this.dsMainStlm.setColumn(0, 'stlmYn', 'N');
		}
		// 결제번호 (KCP 상점아이디)
		this.dsMainStlm.setColumn(0, 'stlmNo', this.dsKcpStlmInfo.getColumn(0, 'siteCd')); 
		
		// 원서접수 문자발송정보 SET
		this.fnSetSaveRcptSmsInfo();
		
		// 결제 정보 저장
		this.smfSaveService("saveStlm")
			.showConfirm(false)
			.run()
			// 콜백
			.callback(function(callbackParams){
				if(callbackParams.errors){
					return;
				}
				// 결제 실패
				if(resCd != '00000'){
					this.smfAlert('응시료 결제를 실패하였습니다. \n['+resCd+']'+jsonData["res_msg"]);
					return;
				}
				
				// PARAM
				var params = {
					"dsMainBase" : this.dsMainBase.saveJSON(),
					"dsMainStatus" : this.dsMainStatus.saveJSON(),
					"rcptQustTelNo" : this.pv_params.rcptQustTelNo
					,"rcptQustHrValue" : this.pv_params.rcptQustHrValue
				};
				// 접수완료 PAGE
				this.smfSetWorkPage("pa_ore_oew_ar::ore_oewar21_m02.xfdl", params);
		});
		
	}else{
		// 창닫기 (결제전취소)
		return;
	}
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 /**
 * 응시료, 결제 정보 조회
 */
this.fnSearchStmlnfo = function(obj, e)
{
	/** 조회조건**/
	// 시도코드
	this.dsSearch.setColumn(0, 'cddcCd', this.smfGetCddcCode());
	// 임용시험ID
	this.dsSearch.setColumn(0, 'appoExamId', this.dsMainBase.getColumn(0, 'appoExamId'));
	// 직류코드
	this.dsSearch.setColumn(0, 'ocptyCd', this.dsMainBase.getColumn(0, 'ocptyCd'));
	// 직급코드
	this.dsSearch.setColumn(0, 'jbgdCd', this.dsMainBase.getColumn(0, 'jbgdCd'));
	
	// 응시료, 결제 정보 조회
	this.smfSearchService('selectStlmInfo') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			// 응시료/납부여부
			this.fnAechgInit();

	});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnInitInfo = function(){
	// 임용시험명
	var appoExamNm = this.dsMainBase.getColumn(0, 'appoExamNm');
	// 직렬명
	var jblnNm = this.dsMainBase.getColumn(0, 'jblnNm');
	// 계급명
	var rksNm = this.dsMainBase.getColumn(0, 'rksNm');
	// 지원자성명
	var applpFlnm = this.dsMainBase.getColumn(0, 'applpFlnm');
	
	// 서브타이틀 시험명, 직렬
 	this.divSubTitle.form.staSubTlite00.set_text(appoExamNm);
	// 서브타이틀 직렬
	this.divSubTitle.form.staSubTlite01.set_text(jblnNm);
	// 서브타이틀 계급 SET
	this.divSubTitle.form.staSubTlite02.set_text(rksNm);
	
	// 응시료 납부영역 임용시험명
	this.divAechgInfo.form.staAppoExamNm.set_text(appoExamNm);
	// 응시료 납부영역 응시분야
	this.divAechgInfo.form.staRealm.set_text(jblnNm+' / '+rksNm);
	// 응시료 납부영역 지원자 성명
	this.divAechgInfo.form.staNm.set_text(applpFlnm);
	
	// ORE 공통 스크립트에서 정보 취득
	this.lcltyRcptInquiryInfo(this.pv_params.rcptQustTelNo, this.pv_params.rcptQustHrValue);

}

/**
* 응시료 정보
*/
this.fnAechgInit = function(){

	// 응시료
	var aplemAmt = nexacro.toNumber(this.dsKcpStlmInfo.getColumn(0, "goodMny"));
	// 응시료 TXT
	this.divAechgInfo.form.staPayAmount.set_text(aplemAmt+ "원 (응시료 미납)");
	
	// 메인 상태 값에 응시료 SET
	this.dsMainStatus.setColumn(0, 'aplemAmt', aplemAmt)
	
	// 결제식별ID
	var stlmIDfId = this.dsKcpStlmInfo.getColumn(0, "stlmIDfId");
	// 결제식별KEY
	var stlmKey = this.dsKcpStlmInfo.getColumn(0, "stlmKey");
}

 /**
 * 원서접수 문자발송정보 SET
 * 
 **/
 this.fnSetSaveRcptSmsInfo = function(){
	// 초기화
	this.dsRcptSms.clearData();
	this.dsRcptSms.addRow();
	this.dsRcptSms.setColumn(0, 'appoExamScCd' , this.smfGetAppoExamScCd()); //임용시험구분코드
	this.dsRcptSms.setColumn(0, 'cddcScCd' ,this.smfGetCddcCode().slice(0,3)); //시도교육청구분코드
	this.dsRcptSms.setColumn(0, 'cddcNm' , this.smfGetCddcName()); //시도교육청명
	this.dsRcptSms.setColumn(0, 'rcptQustTelNo' , this.pv_params.rcptQustTelNo); //발신번호
	this.dsRcptSms.setColumn(0, 'mblTelno' , this.dsMainBase.getColumn(0, 'mblTelno')); //수신번호
 }

/**
* KCP 결제 모듈 호출
*/
this.smfExecPayKCP = function(objParam)
{
	var objFuncCallback   = objParam.popupcallback;
	var objForm = objParam.objForm;
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: objFuncCallback, // 콜백함수 지정
		sender: objForm, // sender 지정
		titlebar:false,  // 타이틀바를 표시하지 않는다.
		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정(필수)
			procType : "none",  // "none","search","insert","update","delete"
		    order_info : objParam.order_info   //  주문정보
		}
	};

	// 모달팝업 실행
	this.smfDialog("_auto", "comm::comp_pay_kcp.xfdl", popupParams);
	
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

/**
 * [버튼클릭] 이전버튼
 */
this.btnPrev_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// PARAM
 	var params = {
		"dsMainBase" : this.dsMainBase.saveJSON(),
		"viewMode" : 'modify', // new(신규) / modify(수정)
		"rcptNo" : this.dsMainStatus.getColumn(0, 'rcptNo')
	}
	this.smfSetWorkPage("pa_ore_oew_ar::ore_oewar21_m00.xfdl", params);
};

/**
 * * [버튼클릭] KCP 결제
 */
this.divSubmitInfo_btnPay_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 개요정보 존재여부
	var useApplpYn = this.dsResultAppoExamCeck.getColumn(0, "useApplpYn");
	if(useApplpYn != 'Y' ){
		this.smfAlert("원서 등록이 불가능합니다.");
		return;
	}
	// 임용시험유효여부
	var useExamYn = this.dsResultAppoExamCeck.getColumn(0, "useExamYn");
	if(useExamYn != 'Y'){
		this.smfAlert("진행중인 임용 시험이 아닙니다.");
		return;
	}
	// 접수기간 여부
	var itnRcptYn = this.dsResultAppoExamCeck.getColumn(0, "itnRcptYn");
	if(itnRcptYn != 'Y'){
		this.smfAlert("원서접수 기간이 아닙니다. ");
		return;
	}
	
	// 결제 정보가 없을경우
	if(this.dsKcpStlmInfo.getRowCount() < 1){
		this.smfAlert('응시료 결제를 할 수 없습니다. \n(결제 정보가 없습니다.)');
		return;
	}
	
	// KCP Param Set
	var objParam = {  
		objForm : this
		, popupcallback : this.fnKcpPopupCallback
		, order_info : {
			ordr_idxx : this.dsKcpStlmInfo.getColumn(0, 'ordrIdxx')  // 주문번호
			, good_name  : this.dsKcpStlmInfo.getColumn(0, 'goodName')  // 상품명
			, good_mny : this.dsKcpStlmInfo.getColumn(0, 'goodMny')   // 결제금액
			, buyr_name : 	this.dsMainBase.getColumn(0, 'applpFlnm')  // 주문자명
			, buyr_tel1 : this.dsMainBase.getColumn(0, 'mblTelno')  // 주문자 연락처1
			, buyr_tel2 : this.dsMainBase.getColumn(0, 'emgCnctTelno')  // 휴대폰번호
			, buyr_mail : this.dsMainBase.getColumn(0, 'emlAddr')  // 주문자 E-mail							   
			, site_cd : this.dsKcpStlmInfo.getColumn(0, 'siteCd')   // 가맹점CD
			, site_name : this.dsKcpStlmInfo.getColumn(0, 'siteNm')  // 가맹점명
			, payMethod  : this.divAechgInfo.form.rdoPayMethod.value  // 결제수단
		}
	};
	//console.log(objParam)
	
	// 결제모듈 호출
	this.smfExecPayKCP(objParam);
};
]]></Script>
