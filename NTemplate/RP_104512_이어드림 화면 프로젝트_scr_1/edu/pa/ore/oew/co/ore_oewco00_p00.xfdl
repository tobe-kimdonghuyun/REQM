<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <TypeDefinition url="..\default_typedef.xml"/>
  <Form id="commpop_tchQlfIns" classname="form" inheritanceid="" titletext="학교찾기" onload="fnOnload" position="absolute" width="700" height="416">
    <Layouts>
      <Layout width="700" height="416" screenid="ScreenDeskTop,tablet">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divSearch" taborder="1" left="20" top="20" height="54" cssclass="div_WF_Search" right="20" initvalueid="ivDivAccessibilityOn" accessibilitylabel="조회영역">
          <Layouts>
            <Layout>
              <Static id="Static00" taborder="0" text="학교명" left="0" top="12" width="105" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtTchQlfInstNm" taborder="1" left="105" top="12" width="308" height="30" cssclass="essential" accessibilitylabel="학교명(필수입력)" maxlength="20" initvalueid="ivEdtEssential" onkeydown="divSearch_edtTchQlfInstNm_onkeydown"/>
              <Button id="btnSearch" taborder="2" text="조회" top="12" width="74" height="30" cssclass="btn_WF_Search03" right="20" onclick="btnSearch_onclick" initvalueid="ivBtnAccessibilityButton"/>
            </Layout>
          </Layouts>
        </Div>
        <Grid binddataset="dsMain" id="grdMain" left="20" top="94" height="252" taborder="2" autofittype="col" right="20" oncelldblclick="grdMain_oncelldblclick" initvalueid="ivGrdAccessibilityOn" selecttype="cell">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="40"/>
                <Column size="190"/>
                <Column size="150"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="순번" displaytype="normal" font="normal 15px/normal &quot;NotoSansKR-Regular&quot;"/>
                <Cell col="1" text="학교명" font="normal 15px/normal &quot;NotoSansKR-Regular&quot;"/>
                <Cell col="2" text="학교코드" displaytype="normal" font="normal 15px/normal &quot;NotoSansKR-Regular&quot;"/>
              </Band>
              <Band id="body">
                <Cell text="expr:currow+1" autosizerow="default" autosizecol="limitmin" displaytype="normal" font="normal 15px/normal &quot;NotoSansKR-Regular&quot;"/>
                <Cell col="1" text="bind:unyCdValueNm" combodataset="dsUseRelmScCd" combodatacol="unyCdValueNm" combocodecol="unyCdValue" font="normal 15px/normal &quot;NotoSansKR-Regular&quot;"/>
                <Cell col="2" text="bind:unyCdValue" autosizerow="default" autosizecol="limitmin" displaytype="normal" font="normal 15px/normal &quot;NotoSansKR-Regular&quot;"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="btnCancel" taborder="3" text="취소" height="30" width="50" left="42.00%" fittocontents="width" cssclass="btn_WF_Custom" initvalueid="ivBtnAccessibilityButton" top="365" onclick="btnCancel_onclick"/>
        <Button id="btnRegist" taborder="4" text="적용" height="30" width="50" fittocontents="width" left="354" initvalueid="ivBtnAccessibilityButton" top="365" onclick="btnSelect_onclick"/>
        <Static id="sta00" taborder="5" left="20" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta01" taborder="6" left="20" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" top="74" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta02" taborder="7" left="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff" height="20" top="346"/>
        <Static id="sta03" taborder="8" left="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff" height="20" top="395"/>
        <Static id="sta04" taborder="9" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta05" taborder="10" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsSearch">
        <ColumnInfo>
          <Column id="tchQlfInstNm" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">select</Col>
            <Col id="svctp">R</Col>
            <Col id="url">/ore_oew_co00_p00_000.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsMain=dsMain</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true">
        <ColumnInfo>
          <Column id="unyCdValue" type="STRING" size="256" description="조직코드"/>
          <Column id="unyCdValueNm" type="STRING" size="256" description="한글조직명"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    기관찾기
*  @FileName 	ore_oewco00.xfdl 
*  @CreateDate 	2022.11.02
*  @Desction    기관찾기 팝업 화면
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.11.02     		shhan 	                최초 생성
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
var pv_params;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 팝업 폼 초기화
	this.smfInitPopup(obj);

	pv_params = this.smfGetPopupParams();

	// validate
	this.smfUpdateValidateToComponent("title:기관명,required", this.divSearch.form.edtTchQlfInstNm);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 /**
 * 조회서비스
 */
this.fnSearchList = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("select")
		// 데이터 검증
		.validateForm(this.divSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 /**
 * 학교 선택
 */
 this.fnChoice = function(){
	if(this.dsMain.rowposition <= -1) return;
	
	this.smfSendResponseToOpener({
		"row": this.smfRowToObject(this.dsMain)
	});

	this.close(true);
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 입력창 입력 시
 */
this.divSearch_edtTchQlfInstNm_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	// 엔터키 이벤트
	if(e.keycode == "13"){
		this.btnSearch_onclick();
	}
};

/**
 * 검색 버튼 클릭 시
 */
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearchList();
};

/**
 * 그리드 셀 더블 클릭 시
 */
this.grdMain_oncelldblclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	this.fnChoice();
};

/**
 * 확인 버튼 클릭 시
 */
this.btnSelect_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnChoice();
};

//취소 버튼 클릭시
this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};
]]></Script>
    <Bind>
      <BindItem id="item2" compid="divSearch.form.edtTchQlfInstNm" propid="value" datasetid="dsSearch" columnid="tchQlfInstNm"/>
    </Bind>
  </Form>
</FDL>
