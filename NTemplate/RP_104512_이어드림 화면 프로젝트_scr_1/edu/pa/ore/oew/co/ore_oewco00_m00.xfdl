              <Div id="divEasyCertNoti" taborder="2" left="34" top="btnEasyLogin:24" width="679" height="78" background="white">
                <Layouts>
                  <Layout>
                    <Static id="staEastCertNoti" taborder="0" text="&lt;b v='true'&gt;본인인증은 행정안전부 인증체계 적용으로,  최초 한 번은 1단계 간편인증 후 2단계 휴대폰 본인 인증절차로 로그인되며, &#13;&#10;원서가 저장되면 간편인증만으로 로그인 가능합니다.&lt;/b&gt;" left="23" top="6" initvalueid="ivStcAccessibilityOn" usedecorate="true" onclick="div00_00_sta02_onclick" width="642" height="61" cssclass="sta_Login_MemberNotice"/>
                  </Layout>
                </Layouts>
              </Div>
              <Static id="sta02" taborder="3" text="팝업 차단을 해제한 후 인증을 진행 하시기 바랍니다." left="179" top="14" width="462" height="30" cssclass="sta_WF_SurvCautionS" initvalueid="ivStcAccessibilityOn" usedecorate="true" onclick="div00_00_sta02_onclick" font="normal 15px/1.5 &quot;Noto Sans KR&quot;,&quot;NotoSansKR-Regular&quot;,&quot;Malgun Gothic&quot;,&quot;Arial&quot;,&quot;MS PGothic&quot;"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="div00" taborder="5" left="0" top="709" cssclass="div_Login_Notice02" initvalueid="ivDivAccessibilityOff" width="1200" height="102" visible="false">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" left="55" width="134" cssclass="sta_Login_MemberNotice01" initvalueid="ivStcAccessibilityOn" top="38" height="30" accessibilitylabel="알려드립니다."/>
              <Static id="sta01" taborder="1" text="&lt;b v='true'&gt;교육공무원임용령 제23조의2에 의거 주민등록번호를 수집하여 교원임용 신규채용에 관한 업무를 처리합니다. &lt;/b&gt;" left="248" top="37" cssclass="sta_Login_MemberNotice" initvalueid="ivStcAccessibilityOn" usedecorate="true" onclick="div00_00_sta02_onclick" width="902" height="43"/>
            </Layout>
            <Layout name="default0">
              <Static id="sta00" taborder="0" left="20" cssclass="sta_Login_MemberNotice01_M" initvalueid="ivStcAccessibilityOn" top="40" height="50" accessibilitylabel="알려드립니다." right="20"/>
              <Static id="sta01" taborder="1" text="&lt;b v='true'&gt;나이스 학원서비스는 회원가입 없이 사용자의 인증서 인증만으로도 이용이 가능합니다.&lt;/b&gt;&#13;&#10;※ 개인용 인증서로 만 로그인이 가능(법인용 인증서 사용 불가)하며, 학원·교습소 등 설립등록(방문 민원) 시 '온라인사용자 등록'을 먼저 하셔야 합니다.&#13;&#10;   - 온라인사용자 등록 완료 후 인증서로 로그인하시면, 민원신청, 열람 등의 서비스를 별도의 인증절차 없이 이용하실 수 있습니다.&#13;&#10;      단, 로그인 시 타 시·도교육청으로 이동하거나 다른 서비스로 이동 시 다시 로그인을 하게 될 수도 있습니다.&#13;&#10;※ 민원신청, 열람 등의 인증서 로그인(가상키패드 사용 포함)이 필요 한 서비스는 PC환경 만 이용가능하며 모바일 환경에서는 이용하실 수 없습니다.&#13;&#10;   - 인증서 로그인 시 개인민감정보의 입력은 가상키패드 또는 키보드보안 프로그램을 통하여 입력이 가능합니다.&#13;&#10;     (가상키패드는 마우스를 사용하므로 불편하실 수 있습니다.)&#13;&#10;※ 보안성 향상 및 편의성 보장을 위하여, 키보드보안 프로그램 또한 제공하고 있습니다.(사용권장)&#13;&#10;※ 키보드보안 프로그램은 설치가 필요하며 보안 기능이 추가적으로 제공됩니다." left="20" cssclass="sta_Login_MemberNotice_M" initvalueid="ivStcAccessibilityOn" usedecorate="true" height="585" fittocontents="height" right="20" top="100"/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/***  
*  @MenuPath    본인인증
*  @FileName 	ore_oewco00_m00.xfdl 
*  @CreateDate 	2022.12.13
*  @Desction    본인인증
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.12.13          
*******************************************************************************
*/
/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/

// formParam
this.fv_param;
// 클릭 메뉴 경로
this.fv_resendUrl;
// 클릭메뉴 아이디
this.fv_resendMenuId;

// 인증서 타입  : copr(공동) | fnnc(금융) | easy(간편)
this.sCertType;

this.rrno = "";
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);
	
	this.fv_param = this.smfGetFormParams();
	this.fv_resendUrl = this.fv_param.resendUrl;
	this.fv_resendMenuId = this.fv_param.resendMenuId;

	this.divFnncCert.top = '135px';
	this.divEasyCert.left = '249px';
	
	//가상키보드 세팅
 	var objOption1 = {
 		target : this.divCoprCert.form.edtRrno01, //대상 Edit 컴포넌트 [필수]
 		targetKey : this.divCoprCert.form.staTransKey, //Edit와 쌍으로 있는 마우스입력 체크박스(static) [필수]
 		bshow :  true, //  마우스입력 체크박스 보이기 여부 (default = false) [선택]
 		maxLength : 7,
 		kbdType : "number", //라온 키보드 타입 number/qwerty (default = qwerty)[선택)
 	}
	this.smfInitTranskey(objOption1);
	var objOption2 = {
 		target : this.divFnncCert.form.edtRrno01, //대상 Edit 컴포넌트 [필수]
 		targetKey : this.divFnncCert.form.staTransKey, //Edit와 쌍으로 있는 마우스입력 체크박스(static) [필수]
 		bshow :  true, //  마우스입력 체크박스 보이기 여부 (default = false) [선택]
 		maxLength : 7,
 		kbdType : "number", //라온 키보드 타입 number/qwerty (default = qwerty)[선택)
 	}
	this.smfInitTranskey(objOption2);
	document.getElementsByClassName("staTransKey1")[0].children.item(0).children.item(0).click();
	document.getElementsByClassName("staTransKey2")[0].children.item(0).children.item(0).click();
	
	// 초기처리
	this.fnInitCertMetod();
	
	// 인증방식 : 주민번호(RRNO) OR 생년월일(BRDT)
	var sAuthMethod   = this.fnGetAuthMethod();
	var sAppoExamScCd = this.smfGetAppoExamScCd(); 
	// 주민번호 인증 방식
	if(sAuthMethod === 'RRNO'){
		this.div00.set_visible(true);
		if(sAppoExamScCd == "1" || sAppoExamScCd == "2"){
			this.div00.form.sta01.set_text("<b v='true'>교육공무원임용령 제23조의2에 의거 주민등록번호를 수집하여 교원임용 신규채용에 관한 업무를 처리합니다. </b>");
		}else if(sAppoExamScCd == "3"){
			this.div00.form.sta01.set_text("<b v='true'>지방공무원 임용령 제77조에 의거 주민등록번호를 수집하여 지방공무원 임용에 관한 사무를 처리합니다.</b>");
		}else{
			var sTxt = "<b v='true'>「아동ㆍ청소년의 성보호에 관한 법률」 제56조 및 같은 법 시행령 제25조와 「아동복지법」 제29조의3 및 같은 법 시행령 제26조의5에 따라 수집한 주민등록번호는<br>";
			sTxt = sTxt + "채용후보자의 성범죄 경력조회와 아동학대관련범죄 전력 조회 관한 사무를 처리합니다.</b>" 
			//문구 받아야함
			this.div00.form.sta01.set_text(sTxt);
		}
	}		
	
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 
 // 로그인 성공 , 페이지이동
 this.fnLoginSuccWithRedirect = function(){
		// 클라이언트세션 SET
		this.smfSetSessionDataset(this.dsOreHrdSession); 
		
		// 로그인 됐다고 판정
		this.smfSetLoginState(true);
		// 로그인세션타임과 로그아웃 버튼 설정
		this.getOwnerFrame().form.divTop.form.fnLoginAfter();
		
		// 메뉴 아이디가 없을경우 서브메인(해당임용시험+시도교육청 메인)으로
		if(this.smfIsNull(this.fv_resendMenuId)){
			//선택된 서브값을 세팅(유초등교원, 중등교원, 지방공무원, 교육공무직, 계약제)
			var selSubSystemTypeCd = this.smfGetSubSystemDetailGb();
			var oParam = {
					selSubSysType : selSubSystemTypeCd
			};	
			// 서브 메인 화면으로 이동
			this.smfSetWorkPage("frame::ore/frameSubMain.xfdl",oParam, false);
		}else{
			// 클릭 메뉴(이전) 화면으로 이동
			this.smfSetWorkPage(this.fv_resendUrl,null, false);
		}
 }

// 서버세션생성
 this.fnCreateServerSession = function(){
	// DS 초기화
	this.dsOreHrdSession.clearData();
	
	// 주민번호 인증 방식
	if(this.fnGetAuthMethod() === 'RRNO'){
		// 주민번호 암호화
		var encRrno = nexacro.base64Encode(this.dsMain.getColumn(0, 'applpRrno'));
		this.dsMain.setColumn(0, 'applpRrno', encRrno);
	}else{
		this.dsMain.setColumn(0, 'applpRrno', '');
	}
	
	// 서비스 객체 생성
	this.smfSaveService("saveSeverSession")
		.showConfirm(false)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				return;
			}
			// 로그인 타입
			var sLgnTypCd = "";
			if(this.sCertType === 'copr'){
				// 공동인증 로그인 타입
				sLgnTypCd ='LG002';
			} else if (this.sCertType === 'fnnc'){
				// 금융인증 로그인 타입
				sLgnTypCd ='LG009';
			} else if (this.sCertType === 'easy'){
				// 간편인증 로그인 타입
				sLgnTypCd ='LG005';
			}
			// 세션 생성후 로그인 이력 등록
			this.smfSendLoginLog(this, sLgnTypCd);
			
			// 세션 생성 후, 화면이동처리
			this.fnLoginSuccWithRedirect();
	});
}

// 서버세션취득
 this.fnGetServerSession = function(){
 
	this.dsOreHrdSession.clearData();
		// 서비스 객체 생성
	this.smfSearchService("selectSeverSession")
		.showConfirm(false)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				return;
			}
		});
		console.log("========== SERVER SESSION GET ==========");
}

