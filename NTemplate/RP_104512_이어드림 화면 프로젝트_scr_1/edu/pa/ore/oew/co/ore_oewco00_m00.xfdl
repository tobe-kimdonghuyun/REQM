/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback = function(svcid,errcd,errmsg){
};

/**
 * [공동인증서] 인증서 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnCoprPopupCallback = function(e, sender){
var sLog = "";
	if(e.result){
		var sData = e.data;
		
		sLog += "처리결과 : [성공]\n";

		// 입력 주민번호 일치여부
		var sVidResult = JSON.parse(sData).vidResult
		if(sVidResult == "true"){
			// 이름
			var applpFlnm = this.divCoprCert.form.edtNm.value; 
			// 공동인증 결과 DN값
			var sSubjectDn = JSON.parse(sData).subjectDn;
			// DN값에서 입력 성명 포함시 인증 성공
			if(sSubjectDn.indexOf(applpFlnm) != -1){  
				// 서버 세션 생성 + 화면이동
				this.fnCreateServerSession();
			}else{
				// 성명 불일치
				this.smfLiteralAlert("입력하신 정보와 인증서 정보가 일치하지 않습니다.");
			}			
		}else if(sVidResult.indexOf("VID") != -1){
			// 주민번호 불일치
			this.smfLiteralAlert("입력하신 정보와 인증서 정보가 일치하지 않습니다.");
		}else{
			this.smfLiteralAlert("인증 처리중 오류가 발생 하였습니다. \n지속적인 오류 발생시 관리자에 문의해주세요.");
		}
	
	}else{
		var sData = e.data;
		var arrData = sData.split(":");
		
		if(arrData[0].trim()=="800000")
		{  // 유저가 팝업을 강제 종료한 경우
			sLog += "처리결과 : [에러(유저강제종료)]\n";
			//console.log(sLog);
			
		}else{
			sLog += "처리결과 data : ["+sData+"]";
			//console.log(sLog);	
		}
	}
	
};

/**
 * [금융인증서] 인증서 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnFnncPopupCallback = function(e, sender){
	trace("===>this.fnFnncPopupCallback : popup callback");
	var sLog = "";
	if(e.result)
	{
		var sData = e.data;
		
		sLog += "처리결과 : [성공]\n";
		//console.log(sLog);
		
		var vidResult = JSON.parse(sData).vidresult.toString();
		if(vidResult == "true"){
			// 이름
			var applpFlnm = this.divFnncCert.form.edtNm.value; 
			// 금융인증 결과 DN값
			var sSubjectDn = JSON.parse(sData).certificate.subject_dn.toString();
			// DN값에서 입력 성명 포함시 인증 성공
			if(sSubjectDn.indexOf(applpFlnm) != -1){  
				// 서버 세션 생성 + 화면이동
				this.fnCreateServerSession();
			}else{
				// 성명 불일치
				this.smfLiteralAlert("입력하신 정보와 인증서 정보가 일치하지 않습니다.");
			}
		}else if(vidResult == "false"){
			// 주민번호 불일치
			this.smfLiteralAlert("입력하신 정보와 인증서 정보가 일치하지 않습니다.");
			
		}else{
			this.smfLiteralAlert("인증 처리중 오류가 발생 하였습니다. \n지속적인 오류 발생시 관리자에 문의해주세요.");
		}
	}else{
		var sData = e.data;
		var arrData = sData.split(":");
		
		if(arrData[0].trim()=="800000")
		{  // 유저가 팝업을 강제 종료한 경우
			sLog += "처리결과 : [에러(유저강제종료)]\n";
			sLog += "data : ["+sData+"]";
			//console.log(sLog);
		}else{
			sLog += "처리결과 data : ["+sData+"]";
			//console.log(sLog);		
		}
	}
};


/**
 * [간편인증] 인증 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnEasyPopupCallback = function(e, sender){
	trace("===>this.fnEasyPopupCallback : popup callback");
	var sLog = "";
	// 인증성공
	if(e.result){
		var sData = JSON.parse(e.data);
		if(this.smfIsNull(sData)){
			sLog += "처리결과 : [에러]\n";
			//console.log(sLog);
			this.smfLiteralAlert("간편 인증에 실패 하였습니다.");
			return;
		}
		
		sLog += "처리결과 : [성공]\n";	
		//console.log(sLog);

		// 세션 Parameters
		this.dsMain.clearData();
		this.dsMain.addRow();
		this.dsMain.setColumn(0, 'appoExamScCd', this.smfGetAppoExamScCd()); // 임용시험구분코드
		this.dsMain.setColumn(0, 'cddcCd', this.smfGetCddcCode()); // 시도교육청코드
		this.dsMain.setColumn(0, 'cddcNm', this.smfGetCddcName()); // 시도교육청명
		this.dsMain.setColumn(0, 'applpFlnm', sData.userNm);// 이름
		this.dsMain.setColumn(0, 'userDtcNo', sData.ci);// 간편인증 CI
		
		// 인증방식 : 주민번호(RRNO) OR 생년월일(BRDT)
		var sAuthMethod = this.fnGetAuthMethod();
		
		// 주민번호 인증 방식
		if(sAuthMethod === 'RRNO'){
			var resultRrno =  sData.ssn;
			resultRrno = resultRrno.replaceAll('-', '')
			this.dsMain.setColumn(0, 'applpRrno', resultRrno); // 주민번호 (하이픈X)
			this.dsMain.setColumn(0, 'applpBrdt', this.applpRrnoToBrdt(resultRrno)); // 생년월일 YYYMMDD
			// 서버 세션 생성 + 화면이동
			this.fnCreateServerSession();
		}	
		
		// 생년월일 인증 방식 - CI 체크 후 본인인증여
		if(sAuthMethod === 'BRDT'){
			// CI 조회정보 초기화
			this.dsResultUserCi.clearData();
			// 사용자 CI 조회
			this.smfSearchService("selectUserCi")
				.showConfirm(false)
				// 실행
				.run()
				// 콜백
				.callback(function(callbackParams){
					if(callbackParams.errors){
						return;
					}
					// CI 여부에 따라 휴대폰 본인인증 처리
					if(this.dsResultUserCi.getRowCount() <1){ // CI 없음
						this.smfAlert("휴대폰 본인인증 후 이용 해주세요.", this.fnEasyCertAlertCallback);
					}else{ // CI 있음
						// CI 정보에서 취득 값 SET
						this.dsMain.setColumn(0, 'applpRrno', '');
						this.dsMain.setColumn(0, 'applpFlnm', this.dsResultUserCi.getColumn(0,'applpFlnm')); // 이름
						this.dsMain.setColumn(0, 'applpBrdt', this.dsResultUserCi.getColumn(0,'applpBrdt')); // 생년월일 YYYMMDD
						this.dsMain.setColumn(0, 'mblTelNo', this.dsResultUserCi.getColumn(0,'mblTelno'));// 휴대전화(하이픈)
					
						// 서버 세션 생성 + 화면이동
						this.fnCreateServerSession();
					}
			});
		}
	}else{

		if(!this.smfIsNull(sData)){
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+sData+"]";
			//console.log(sLog);
			this.smfLiteralAlert("간편인증 처리중 오류가 발생 하였습니다. \n\n지속적인 오류 발생시 관리자에 문의해주세요.");
		}
	}
	
};

 /**
 * [간편인증- 주민번호미사용] CI 정보 미존재시 alert 콜백
 */
this.fnEasyCertAlertCallback = function(){ 

	// SCI 본인인증 팝업호출
	var popupParams = {
		callback: this.fnSciAuthModalCallback, // 콜백함수 지정
		sender: obj, // sender 지정
		// 팝업 전달 파라메터 지정
		params: {
			procType: 'none',
			dsMain: this.dsMain.saveJSON()
		},
		titlebar : false
	};
	// 휴대폰 본인인증 모달팝업 실행
	this.smfDialog("_auto", "pa_ore_oew_co::ore_oewco00_p01.xfdl ", popupParams);
}

 /**
 * [간편인증- 주민번호미사용] CI 정보 미존재시 SCI 휴대폰본인인증 모달 콜백
 */
this.fnSciAuthModalCallback = function(e, sender){	
	
	// 팝업 콜백 결과
	var resultSci = e.row;
	// SCI 휴대폰 본인인증 RES CI
	var sciCi = resultSci.strCi;
	// SCI 휴대폰 본인인증 RES 이름
	var sciNm = resultSci.applpFlnm;
	// SCI 휴대폰 본인인증 RES 휴대폰번호(하이픈X)
	var sciMblTelno = resultSci.mblTelNo;
	// SCI 휴대폰 본인인증 RES 생년월일 YYYYMMDD
	var sciBrdt = resultSci.applpBrdt;
	

	// 행안부 간편인증 CI
	var easyCertCi = this.dsMain.getColumn(0, 'userDtcNo');
		
	if(!this.smfIsNull(sciCi) && !this.smfIsNull(easyCertCi)){
		// 행안부 간편인증 CI , SCI CI 비교
		if(easyCertCi === sciCi){
			// 파라메터에  SCI CI 추가
			this.dsMain.setColumn(0, 'userDtcNo', sciCi);
			this.dsMain.setColumn(0, 'applpRrno', '');
			this.dsMain.setColumn(0, 'applpFlnm',sciNm); // 이름
			this.dsMain.setColumn(0, 'applpBrdt', sciBrdt); // 생년월일 YYYMMDD
			var addHyphenMblTelno = sciMblTelno.replace(/^(\d{2,3})(\d{3,4})(\d{4})$/ , '$1-$2-$3');
			this.dsMain.setColumn(0, 'mblTelNo',  addHyphenMblTelno);// 휴대전화(하이픈)
			// 세션생성 + 화면이동
			this.smfAlert("본인인증이 완료 되었습니다." , this.fnCreateServerSession);
		}else{
			this.smfAlert("간편인증 정보와 휴대폰 본인인증 정보가 일치 하지 않습니다.");
			return;
		}
	}else{
		this.smfAlert("본인인증에 실패 하였습니다.");
		this.close(false);
	}

}

/************************************************************************************************
 * 사용자 FUNCTION 영역
************************************************************************************************/

/**
* 인증방식 주민번호방식(RRNO) OR  생년월일방식 (BRDT)
*/
this.fnGetAuthMethod= function(){
// 임용시험구분코드
	var appoExamScCd = this.smfGetAppoExamScCd();
	
	// 인증방식 - 주민번호
	var authMethod = 'RRNO';
	
	// 유초등교원(1), 중등교원(2), 지방공무원(3) 주민번호 필수 인증
	if('1' === appoExamScCd || '2' === appoExamScCd || '3' === appoExamScCd){
		authMethod =  'RRNO'; // 주민번호 인증
		
	// 교육공무직, 계약제교원 : 생년월일, 특정 메뉴는 주민번호 필수
	}else if('4' === appoExamScCd || '5' === appoExamScCd){
		authMethod = 'BRDT'; //  생년월일 인증
		// 메뉴 클릭 아이디
		var menu = this.fv_resendMenuId;
		// 교육공무직 :  (5001)채용후보자등록 , (6002)전자근로계약서는 주민번호 필수
		if('4' === appoExamScCd && ('5001' === menu || '6002' === menu)){
			authMethod =  'RRNO'; // 주민번호인증
		}
		// 계약제교원 :  (4001)경력합산신청서 , (4002)전자근로계약서는 주민번호 필수
		if('5' === appoExamScCd && ('4001' === menu || '4002' === menu)){
			// 주민번호인증
			authMethod =  'RRNO';
		}
	}
	return authMethod;
};


/**
 * 초기표시 인증 방법
 */
this.fnInitCertMetod = function(){

	// 임용시험구분코드
	var appoExamScCd = this.smfGetAppoExamScCd();
	
	// 사용가능 인증방법
	// 유초등교원, 중등교원, 지방공무원  :  공동인증/금융인증/간편인증
	if('1' === appoExamScCd || '2' === appoExamScCd || '3' === appoExamScCd){
		// 초기 표시 인증방법 : copr(공동) | fnnc(금융) | easy(간편)
		this.sCertType = 'fnnc';
		this.divCertTab.form.btnTabFnncCert.setFocus();
		this.fnInitTab();
	}
	
	// >> 2023.08.25 수정
	// 교육공무직 + (6002)전자근로계약서	 : 공동인증/금융인증/간편인증
	// 교육공무직 그외					 : 메뉴에 따라 주민번호, 생년월일 분기 사용
	var menu = this.fv_resendMenuId;
	if ('4' === appoExamScCd && '6002' === menu){
		// 초기 표시 인증방법 : copr(공동) | fnnc(금융) | easy(간편)
		this.sCertType = 'easy';
		this.divCertTab.form.btnTabEasyCert.setFocus();
		this.fnInitTab();
	} else if('4' === appoExamScCd ){
		// 간편인증만 표시
		this.sCertType = 'easy'
		this.divCertTab.form.btnTabEasyCert.setFocus();
		this.fnOnlyEasyCert();
	}
	
	// 교육공무직, 계약제교원 : 메뉴에 따라 주민번호, 생년월일 분기 사용
	// >> 2023.08.25 수정 : 교육공무직 분기 제외
	if('5' === appoExamScCd ){
		// 간편인증만 표시
		this.sCertType = 'easy'
		this.divCertTab.form.btnTabEasyCert.setFocus();
		this.fnOnlyEasyCert();
	}
	
	// 인증방식 : 주민번호(RRNO) OR 생년월일(BRDT)
	var sAuthMethod = this.fnGetAuthMethod();
	if( sAuthMethod === 'RRNO'){
		// 본인인증 세션취득
		var applpRrno = nexacro.base64Decode(this.smfGetSessionValue('userRrno'));
		// 로그인 되어있으나 주민번호가 없을경우
		if(this.smfIsLogin() && this.smfIsNull(applpRrno)){
			this.smfLiteralAlert("해당 메뉴는 주민번호 인증이 필요합니다.\n재인증 후 이용 해주세요.");
		}
	}
	
	// 전체영역  RESET
	this.smfResetScroll(this);
}

/**
* 초기 표시 인증방법
* 유초등교원/ 중등교원/지방공무원 사용
*/
this.fnInitTab = function(){
	if(this.sCertType === 'copr'){
		// 공동인증 활성
		this.fnActiveCoprCert();
	} else if (this.sCertType === 'fnnc'){
		// 금융인증 활성
		this.fnActiveFnncCert();
	} else if (this.sCertType === 'easy'){
		// 간편인증 활성
		this.fnActiveEasyCert();
	} else {
		this.fnActiveCoprCert();
	}
}

/**
 * 간편인증만사용
 * 교육공무직/ 계약제교원
 */
this.fnOnlyEasyCert = function(){
	// 간편인증 활성
	this.fnActiveEasyCert();
	// 공동인증, 금융인증 미사용
	this.divCertTab.form.btnTabCoprCert.set_enable(false);
	this.divCertTab.form.btnTabFnncCert.set_enable(false);
	this.divCertTab.set_visible(false);
}

/**
 * 공동인증 활성처리
 */
this.fnActiveCoprCert = function(){
	// 공동인증 활성
	this.divCoprCert.set_visible(true);
	this.divCertTab.form.btnTabCoprCert.set_cssclass("btn_Login_TabCaseS");
	// 금융인증 비활성
	this.divFnncCert.set_visible(false);
	this.divCertTab.form.btnTabFnncCert.set_cssclass("btn_Login_TabCase");
	// 간편인증 비활성
	this.divEasyCert.set_visible(false);
	this.divCertTab.form.btnTabEasyCert.set_cssclass("btn_Login_TabCase");
	
};

/**
 * 금융인증 활성처리
 */
this.fnActiveFnncCert = function(){
	// 공동인증 비활성
	this.divCoprCert.set_visible(false);
	this.divCertTab.form.btnTabCoprCert.set_cssclass("btn_Login_TabCase");
	// 금융인증 활성
	this.divFnncCert.set_visible(true);
	this.divCertTab.form.btnTabFnncCert.set_cssclass("btn_Login_TabCaseS");
	//this.divFnncCert.form.edtNm.setFocus();
	// 간편인증 비활성
	this.divEasyCert.set_visible(false);
	this.divCertTab.form.btnTabEasyCert.set_cssclass("btn_Login_TabCase");	
};

/**
 * 간편인증 활성처리
 */
this.fnActiveEasyCert = function(){
	// 공동인증 비활성
	this.divCoprCert.set_visible(false);
	this.divCertTab.form.btnTabCoprCert.set_cssclass("btn_Login_TabCase");
	// 금융인증 비활성
	this.divFnncCert.set_visible(false);
	this.divCertTab.form.btnTabFnncCert.set_cssclass("btn_Login_TabCase");
	// 간편인증 활성
	this.divEasyCert.set_visible(true);
	this.divCertTab.form.btnTabEasyCert.set_cssclass("btn_Login_TabCaseS");
	
	var sAuthMethod = this.fnGetAuthMethod();

	if( sAuthMethod === 'RRNO'){
		this.divEasyCert.form.divEasyCertNoti.set_visible(false);
	}
	// 생년월일 인증시 메세지 표기
	if( sAuthMethod === 'BRDT'){
		this.divEasyCert.form.divEasyCertNoti.set_visible(true);
	}
};

/**
 * [공동인증] 입력값 체크  + 세션등록정보
 */
this.chk = function(obj){
    this.rrno = "";
    var sRtnVal =  this.smfGetValueTranskey(obj.parent.edtRrno01);
	if( this.smfIsNull(obj.parent.edtNm.value) || obj.parent.edtNm.value.length < 2){
		this.smfLiteralAlert("성명을 정확하게 입력 해주세요.");
		obj.parent.edtNm.setFocus();
		return false;
	}

	if(this.smfIsNull(obj.parent.edtRrno00.value) || obj.parent.edtRrno00.value.length != 6){
		this.smfLiteralAlert("주민번호 앞 6자리를 입력 해주세요. ");
		obj.parent.edtRrno00.setFocus();
		return false;
	}

	if(sRtnVal === "transkey")
	{
		//@KBR 입력된 참여번호 가져오기
		var transKey = this.fnTransKey(obj.parent.edtRrno01);
		this.dsRaonKeyData.setColumn(0,"trprRrno1",obj.parent.edtRrno00.value)
		this.smfSearchService("selectKeyDec").run().callback(function(callbackParams){});
		this.rrno = this.dsResult.getColumn(0,"rrno");
	}
	else {
		if(this.smfIsNull(obj.parent.edtRrno01.value) || obj.parent.edtRrno01.value.length != 7){
			this.smfLiteralAlert("주민번호 뒤 7자리를 입력 해주세요. ");
			obj.parent.edtRrno01.setFocus();
			return false;
		}
		this.rrno = obj.parent.edtRrno00.value + obj.parent.edtRrno01.value;
	}
	
	// 세션 Parameters
	this.dsMain.clearData();
	this.dsMain.addRow();
	this.dsMain.setColumn(0, 'appoExamScCd', this.smfGetAppoExamScCd()); // 임용시험구분코드
	this.dsMain.setColumn(0, 'cddcCd', this.smfGetCddcCode()); // 시도교육청코드
	this.dsMain.setColumn(0, 'cddcNm', this.smfGetCddcName()); // 시도교육청명
	this.dsMain.setColumn(0, 'applpFlnm', obj.parent.edtNm.value);
	this.dsMain.setColumn(0, 'applpRrno', this.rrno);
	this.dsMain.setColumn(0, 'applpBrdt', '');
	this.dsMain.setColumn(0, 'mblTelNo', '');	
	
	return true;
};

this.fnTransKey = function(obj)
{	
	var sVal    = "";
	var arrComp = [obj];  //대상 Edit component List: array [필수]
	
	if(!this.smfIsMobile()){
		// 키보드보안 적용여부
		var sRtnVal = this.smfGetValueTranskey(obj);
		
		if(sRtnVal == "transkey"){	//선택
			var sVal = this.smfGetEncDataTranskey(arrComp);
	
			//전달받은 파라미터 데이터셋에 담기
			this.smfConvRaonDataToDs(this.dsRaonKeyData,arrComp,sVal);
			this.dsRaonKeyData.setColumn(0, 'tk_col_check', "transkey");
			
		}else if(sRtnVal == "e2e"){ //미선택
			sVal= obj.value;
		}
	}else{
		sVal = this.smfGetEncDataTranskey(arrComp);
		//전달받은 파라미터 데이터셋에 담기
		this.smfConvRaonDataToDs(this.dsRaonKeyData,arrComp,sVal);
		this.dsRaonKeyData.setColumn(0, 'tk_col_check', "transkey");
	}
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 *  [탭 버튼] 공동인증 탭 버튼 클릭
 */
this.btnTabCoprCert_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// form 변수에 인증 타입 세팅
	this.sCertType = 'copr';
	// 공동인증 활성처리
	this.fnActiveCoprCert();	
};
/**
 *  [탭 버튼] 금융인증 탭 버튼 클릭
 */
this.btnTabFnncCert_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// form 변수에 인증 타입 세팅
	this.sCertType = 'fnnc';
	// 금융인증 활성처리
	this.fnActiveFnncCert();
};
/**
 *  [탭 버튼] 간편인증 탭 버튼 클릭
 */
this.btnTabEasyCert_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// form 변수에 인증 타입 세팅
	this.sCertType = 'easy';
	// 간편인증 활성처리
	this.fnActiveEasyCert();
};

/**
 *  [공동인증서-NPKI] 로그인 버튼 클릭
 */
this.divCoprCert_btnLoginCopr_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	// 공동인증 입력값 체크
	if(this.chk(obj)){
		// 주민번호
		//var rrno = this.divCoprCert.form.edtRrno00.value + this.divCoprCert.form.edtRrno01.value
		var objLoginInfo = {
			 initUrl  : "/cmc_fcm_es01_003.do"   
			, loginUrl : "/cmc_fcm_es01_004.do" 
			, userId : this.rrno
		}; 
		
		var objParam = {
			objForm:this,
			popupcallback :this.fnCoprPopupCallback,
			loginInfo:objLoginInfo
		};
		
		// 공동인증서 공통 모듈 호출
		this.smfExecNpkiAuth(objParam);	
	}
};

/**
 *  [금융인증서] 로그인 버튼 클릭
 */
this.divFnncCert_btnLoginFnnc_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 금융인증 입력값 체크
	if(this.chk(obj)){
		var objParam = {
			objForm : this,
			popupcallback : this.fnFnncPopupCallback,
			rrno : this.rrno
		};
		// 금융인증서 공통 모듈 호출
		this.smfExecFinAuth(objParam);
	}
};

/**
 *  [간편인증] 로그인 버튼 클릭
 */
this.divEasyCert_btnEasyLogin_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	// [선택] 간편인증 동작방식 -  "trans" : 중계형(온라인채용/검정고시) , "instl" : 설치형(교육비원클릭/그외)
	var sActionType = 'trans';  
	// [선택] Open방식 -  "birth"(default) : 생년월일 , "ssn" : 주민등록번호
	var sOpenType;
	
	// 인증방식 : 주민번호(RRNO) OR 생년월일(BRDT)
	var sAuthMethod = this.fnGetAuthMethod();
	// 주민번호 인증 방식
	if(sAuthMethod === 'RRNO'){
		sOpenType = 'ssn';
	}
	// 생년월일 인증 방식
	if(sAuthMethod === 'BRDT'){
		sOpenType = 'birth';
	}
	
	var objParam = {
		objForm:this,
		popupcallback :this.fnEasyPopupCallback ,
		openType: sOpenType,
		actionType: sActionType 
	};
	this.smfExecSimpleAuth(objParam);

};

this.divCoprCert_edtRrno01_onsetfocus = function(obj:nexacro.Edit,e:nexacro.SetFocusEventInfo)
{
	var checkBox = document.getElementsByClassName("staTransKey1")[0].children.item(0).children.item(0);

	// if() PC이고 키패드가 켜져있을 때만
	if(!this.smfIsMobile() && checkBox.src.indexOf("on") > -1){
		checkBox.click();
		checkBox.click();
	}
};

this.divFnncCert_edtRrno01_onsetfocus = function(obj:nexacro.Edit,e:nexacro.SetFocusEventInfo)
{
	var checkBox = document.getElementsByClassName("staTransKey2")[0].children.item(0).children.item(0);

	// if() PC이고 키패드가 켜져있을 때만
	if(!this.smfIsMobile() && checkBox.src.indexOf("on") > -1){
		checkBox.click();
		checkBox.click();
	}
};
]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">saveSeverSession</Col>
            <Col id="inDatasets">dsMain=dsMain</Col>
            <Col id="outDatasets">dsOreHrdSession=dsOreHrdSession</Col>
            <Col id="url">ore_oew_co00_000.do</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="id">selectSeverSession</Col>
            <Col id="inDatasets">dsMain=dsMain</Col>
            <Col id="outDatasets">dsOreHrdSession=dsOreHrdSession</Col>
            <Col id="url">ore_oew_co00_001.do</Col>
          </Row>
          <Row>
            <Col id="id">checkServerSession</Col>
            <Col id="inDatasets">dsMain=dsMain</Col>
            <Col id="outDatasets">dsOreHrdSession=dsOreHrdSession</Col>
            <Col id="url">ore_oew_co00_002.do</Col>
          </Row>
          <Row>
            <Col id="id">saveInvalidateServerSession</Col>
            <Col id="inDatasets">dsMain=dsMain</Col>
            <Col id="outDatasets">dsOreHrdSession=dsOreHrdSession</Col>
            <Col id="url">ore_oew_co00_003.do</Col>
          </Row>
          <Row>
            <Col id="id">selectUserCi</Col>
            <Col id="inDatasets">dsMain=dsMain</Col>
            <Col id="outDatasets">dsResultUserCi=dsResultUserCi</Col>
            <Col id="url">ore_oew_co00_004.do</Col>
          </Row>
          <Row>
            <Col id="id">selectKeyDec</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsRaonKeyData=dsRaonKeyData</Col>
            <Col id="outDatasets">dsResult=dsResult</Col>
            <Col id="url">ore_oew_co00_008.do</Col>
            <Col id="asynctp">false</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true" updatecontrol="false">
        <ColumnInfo>
          <Column id="appoExamScCd" type="STRING" size="256" description="임용시험구분코드"/>
          <Column id="cddcCd" type="STRING" size="256" description="접속시도 교육청코드"/>
          <Column id="cddcNm" type="STRING" size="256" description="접속시도 교육청명"/>
          <Column id="mblTelNo" type="STRING" size="256" description="휴대전화번호"/>
          <Column id="applpFlnm" type="STRING" size="256" description="이름"/>
          <Column id="applpRrno" type="STRING" size="256" description="주민번호"/>
          <Column id="applpBrdt" type="STRING" size="256" description="생년월일"/>
          <Column id="userDtcNo" type="STRING" size="256" description="사용자CI"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsOreHrdSession" useclientlayout="true" updatecontrol="false">
        <ColumnInfo>
          <Column id="appoExamScCd" type="STRING" size="256" description="임용시험구분코드"/>
          <Column id="cntnCtpvScCd" type="STRING" size="256" description="접속시도구분코드"/>
          <Column id="cddcCd" type="STRING" size="256" description="시도교육청코드"/>
          <Column id="cddcNm" type="STRING" size="256" description="시도교육청명"/>
          <Column id="userNm" type="STRING" size="256" description="성명"/>
          <Column id="userRrno" type="STRING" size="256" description="주민등록번호"/>
          <Column id="trprRrno" type="STRING" size="256" description="주민등록번호 암호화"/>
          <Column id="brdt" type="STRING" size="256" description="생년월일"/>
          <Column id="mblTelNo" type="STRING" size="256" description="휴대전화번호"/>
          <Column id="userDtcNo" type="STRING" size="256" description="사용자CI"/>
          <Column id="userScCd" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsResultUserCi" useclientlayout="true" updatecontrol="false">
        <ColumnInfo>
          <Column id="pafrUserId" type="STRING" size="256" description="사용자CI"/>
          <Column id="applpFlnm" type="STRING" size="256" description="성명"/>
          <Column id="applpBrdt" type="STRING" size="256" description="생년월일"/>
          <Column id="mblTelno" type="STRING" size="256" description="휴대전화번호"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsRaonKeyData" useclientlayout="true">
        <ColumnInfo>
          <Column id="elemid" type="STRING" size="256"/>
          <Column id="transkeyUuid" type="STRING" size="256"/>
          <Column id="tk_col_check" type="STRING" size="256"/>
          <Column id="transkey" type="STRING" size="256"/>
          <Column id="transkey_HM" type="STRING" size="256"/>
          <Column id="hid_key_data" type="STRING" size="256"/>
          <Column id="e2e" type="STRING" size="256"/>
          <Column id="trprRrno1" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="kornFlnm" type="STRING" size="256"/>
          <Column id="trprRrno" type="STRING" size="256"/>
          <Column id="tsCetCd" type="STRING" size="256"/>
          <Column id="tsCetYn" type="STRING" size="256"/>
          <Column id="jwt" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsResult" useclientlayout="true" updatecontrol="false">
        <ColumnInfo>
          <Column id="kornFlnm" type="STRING" size="256" description="임용시험구분코드"/>
          <Column id="encRrno" type="STRING" size="256" description="접속시도 교육청코드"/>
          <Column id="trprRrno2" type="STRING" size="256" description="접속시도 교육청명"/>
          <Column id="rrno" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
  </Form>
