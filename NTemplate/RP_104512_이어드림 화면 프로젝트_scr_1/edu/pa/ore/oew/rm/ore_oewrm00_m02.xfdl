    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-교원임용(초등)-합격자 안내
*  @MenuPath    pa_ore_oew_rm
*  @FileName 	pa_ore_oewrm00_m02.xfdl
*  @Creator 	shhan
*  @CreateDate 	2022.11.25
*  @Desction    온라인통합채용-교원임용(초등)-합격자 안내
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.11.25		shhan				최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.applpRrno;
this.applpNm;
this.applpBrdt;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);

	this.applpRrno = nexacro.base64Decode(this.smfGetSessionValue('userRrno'));
	this.applpNm   = this.smfGetSessionValue('userNm');
	this.applpBrdt = this.applpRrno.slice(0,6);
	
	//초기화
	this.divSummary.form.divContent00.form.staContent00.set_text("");
	this.divSummary.form.divContent00.form.staContent01.set_text("");
	this.divSfcIdnty.form.divContent00.form.staContent00.set_text("");
	this.divSfcIdnty.form.staAplemDsgnNo.set_text('');
	
	// 내 지원서 목록
	this.fnSearchRcptList();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid, errcd, errmsg){

};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 //지원서 목록 조회 
this.fnSearchRcptList = function(obj, e)
{
	var sCddcCd = this.smfGetCddcCode();
	this.dsSearch.clearData();
	this.dsSearch.addRow();
	this.dsSearch.setColumn(0, "applpRrno", this.applpRrno);
	this.dsSearch.setColumn(0, "cddcScCd", sCddcCd.slice(0,3));
	this.dsSearch.setColumn(0, "cddcCd", sCddcCd);
	this.dsSearch.setColumn(0, "onlEmpmnExamScCd", "1"); //유초등
	this.smfSearchService('listRcpt') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;	
			this.divSummary.form.divContent00.form.staContent00.set_text(this.applpNm + "(" +this.applpBrdt +")님.");
			this.divSummary.form.divContent00.form.staContent01.set_text("합격 조회를 해주세요.");
			var rcptCnt =  this.dsResultRcpt.getRowCount();
			if(rcptCnt <1){
				this.divAppoExam.form.divContent00.form.cboAppoExm.set_enable(false);
				this.divAppoExam.form.divContent00.form.btnSearchSfc.set_enable(false);
				this.divSummary.form.divContent00.form.staContent01.set_text(this.smfGetCddcName()+" 임용시험에 응시 내역이 없습니다.");
				this.divSfcIdnty.form.divContent00.form.staContent00.set_text(this.smfGetCddcName()+" 임용시험 응시자가 아닙니다.");
				
			}else{
				this.divAppoExam.form.divContent00.form.cboAppoExm.set_enable(true);
				this.divAppoExam.form.divContent00.form.btnSearchSfc.set_enable(true);
				this.divSfcIdnty.form.divContent00.form.staContent00.set_text("응시시험을 선택 후 합격 조회를 해주세요.");
			}
	});
};

//합격자 조회 
this.fnSearchSfc = function(sRcptNo)
{
	this.dsSearch.setColumn(0,"rcptNo",sRcptNo);
	this.dsSearch.setColumn(0,"appoExamId",this.dsResultRcpt.lookup("rcptNo",sRcptNo, "appoExamId") );
	this.dsSearch.setColumn(0,"eamScCd","1");
	this.dsSearch.setColumn(0,"currCd",this.dsResultRcpt.lookup("rcptNo",sRcptNo, "currCd"));
	
	
	this.dsResultSfc.clearData();
	// 합격조회
	this.smfSearchService('selectSfc') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			//조회 결과 메세지
			var returnMsg = this.dsResultSfc.getColumn(0, "returnMsg");
			// 응시번호
			this.divSfcIdnty.form.staAplemDsgnNo.set_text('');
			if(!this.smfIsNull(this.dsResultSfc.getColumn(0,"exmtNo"))){
				this.divSfcIdnty.form.staAplemDsgnNo.set_text('(응시번호 : ' + this.dsResultSfc.getColumn(0, 'exmtNo') +')') ;
			}
			
			this.divSfcIdnty.form.divContent00.form.staContent00.set_text(returnMsg);
			
			
	});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
//합격조회
this.divAppoExam_divContent00_btnSearchSfc_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sRcptNo = this.divAppoExam.form.divContent00.form.cboAppoExm.value;
	if(!sRcptNo){
		this.divAppoExam.form.divContent00.form.cboAppoExm.setFocus();
		this.smfAlert("응시 시험을 선택 해주세요.");
		return;
	}
	
	this.divSummary.form.divContent00.form.staContent01.set_text( this.dsResultRcpt.lookup("rcptNo",sRcptNo, "appoExamNmSum") );
	
	// 합격조회
	this.fnSearchSfc(sRcptNo);	
};
]]></Script>
    <Objects>
      <Dataset id="dsSearch" useclientlayout="false" updatecontrol="false">
        <ColumnInfo>
          <Column id="cddcScCd" type="STRING" size="256" description="접속시도교육청 구분코드"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="applpRrno" type="STRING" size="256" description="응시자주민번호"/>
          <Column id="onlEmpmnExamScCd" type="STRING" size="256"/>
          <Column id="rcptNo" type="STRING" size="256"/>
          <Column id="examDgr" type="STRING" size="256"/>
          <Column id="appoExamId" type="STRING" size="256"/>
          <Column id="eamScCd" type="STRING" size="256"/>
          <Column id="currCd" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsResultRcpt" useclientlayout="true">
        <ColumnInfo>
          <Column id="rcptNo" type="STRING" size="256" description="접수번호"/>
          <Column id="appoExamId" type="STRING" size="256" description="임용시험ID"/>
          <Column id="appoExamNm" type="STRING" size="256" description="임용시험명"/>
          <Column id="appoExamNmSum" type="STRING" size="256"/>
          <Column id="currCd" type="STRING" size="256" description="분야코드"/>
          <Column id="currNm" type="STRING" size="256" description="분야명"/>
          <Column id="cddcScCd" type="STRING" size="256"/>
          <Column id="cddcScNm" type="STRING" size="256"/>
          <Column id="applpFlnm" type="STRING" size="256"/>
          <Column id="applpRrno" type="STRING" size="256"/>
          <Column id="sxdsCd" type="STRING" size="256"/>
          <Column id="apstPhotoFileCn" type="BLOB" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listRcpt</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResultRcpt=dsResultRcpt</Col>
            <Col id="url">ore_oew_rm00_002.do</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="id">selectSfc</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResultSfc=dsResultSfc</Col>
            <Col id="url">ore_oew_rm00_004.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsResultSfc" useclientlayout="true">
        <ColumnInfo>
          <Column id="exmtNo" type="STRING" size="256" description="응시번"/>
          <Column id="returnMsg" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
  </Form>
</FDL>
