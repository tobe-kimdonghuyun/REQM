              <Static id="staVal09" taborder="18" left="160" height="42" cssclass="sta_WF_Input02" top="staVal06:-2" initvalueid="ivStcAccessibilityOn" text="0" right="0" textAlign="left" sfcDgrNo="1" visible="false"/>
              <Static id="staTxt10" taborder="19" left="0" width="160" height="42" cssclass="sta_WF_Input01" text="총성적" top="staTxt05:-1" initvalueid="ivStcAccessibilityOn" sfcDgrNo="all"/>
              <Static id="staVal10" taborder="20" left="160" height="42" cssclass="sta_WF_Input02" top="staVal05:-1" initvalueid="ivStcAccessibilityOn" text="0" right="0" textAlign="left" sfcDgrNo="all"/>
              <Static id="staTxt11" taborder="21" left="0" width="160" height="42" cssclass="sta_WF_Input01" text="석차" top="staTxt10:-2" initvalueid="ivStcAccessibilityOn" sfcDgrNo="all"/>
              <Static id="staVal11" taborder="22" left="160" height="42" cssclass="sta_WF_Input02" top="staVal10:-2" initvalueid="ivStcAccessibilityOn" text="0" right="0" textAlign="left" sfcDgrNo="all"/>
