        </Div>
        <Grid id="grdScre" taborder="4" left="-1" top="div00:37" height="224" autofittype="col" cellsizingtype="none" extendsizetype="none" autosizingtype="none" right="-1" initvalueid="ivGrdAccessibilityOn" nodatatext="성적 조회 자료가 없습니다." binddataset="dsResultScreSbjt" selecttype="cell" accessibilitylabel="성적조회 목록">
