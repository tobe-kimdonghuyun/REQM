              <Static id="staTxt03" taborder="7" left="0" width="160" height="42" cssclass="sta_WF_Input01" text="2차취업지원가산점" top="staTxt02:-1" initvalueid="ivStcAccessibilityOn" sfcDgrNo="2"/>
              <Static id="staVal03" taborder="8" left="159" height="42" cssclass="sta_WF_Input02" top="staVal02:-1" initvalueid="ivStcAccessibilityOn" right="0" textAlign="left" text="0" sfcDgrNo="2"/>
