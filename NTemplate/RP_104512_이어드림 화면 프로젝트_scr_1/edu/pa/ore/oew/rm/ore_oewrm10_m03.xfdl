    <Script type="xscript5.1"><![CDATA[/** 
*  온라인통합채용-교원임용(중등)-성적조회
*  @MenuPath    pa_ore_oew_rm
*  @FileName 	pa_ore_oewrm10_m03.xfdl
*  @Creator 	shhan
*  @CreateDate 	2022.11.25
*  @Desction    온라인통합채용-교원임용(중등)-성적조회
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.11.25		shhan				최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.applpRrno;
this.applpNm;
this.applpBrdt;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 본인인증 세션취득
	this.applpRrno = nexacro.base64Decode(this.smfGetSessionValue('userRrno'));
	this.applpNm = this.smfGetSessionValue('userNm');
	this.applpBrdt = this.applpRrno.slice(0,6);

	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);
	
	// 지원자정보영역 초기화
	this.divSummary.form.divContent00.form.staContent00.set_text("");
	this.divSummary.form.divContent00.form.staContent01.set_text("");
	
	//초기화
	this.div00.setOffsetHeight(0);
	this.grdScre.setOffsetHeight(0);
	this.smfResetScroll(this);
	
	// 내 지원서 목록
	this.fnSearchRcptList();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid, errcd, errmsg){

};
 /**
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
// 지원서 목록 검색
this.fnSearchRcptList = function(obj, e)
{
	this.dsSearch.clearData();
	this.dsResultRcpt.clearData();
	
	var sCddcCd = this.smfGetCddcCode();
	this.dsSearch.addRow();
	this.dsSearch.setColumn(0, "applpRrno"        , this.applpRrno);
	this.dsSearch.setColumn(0, "cddcScCd"         , sCddcCd.slice(0,3));
	this.dsSearch.setColumn(0, "cddcCd"           , sCddcCd);
	this.dsSearch.setColumn(0, "onlEmpmnExamScCd" , this.smfGetAppoExamScCd());
	
	this.smfSearchService('listRcpt') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;	
			
			this.divSummary.form.divContent00.form.staContent00.set_text(this.applpNm + "(" +this.applpBrdt +")님.");
			this.divSummary.form.divContent00.form.staContent01.set_text("응시 시험을 선택 후 성적 조회를 해주세요.");

			// 지원서 수
			var rcptCnt =  this.dsResultRcpt.getRowCount();
			if(rcptCnt <1){

				this.divAppoExam.form.divContent00.form.cboAppoExm.set_enable(false);
				this.divAppoExam.form.divContent00.form.btnSearchScre.set_enable(false);

				this.divSummary.form.divContent00.form.staContent01.set_text(this.smfGetCddcName()+" 임용시험에 응시 내역이 없습니다.");
			}else{
				this.divAppoExam.form.divContent00.form.cboAppoExm.set_enable(true);
				this.divAppoExam.form.divContent00.form.btnSearchScre.set_enable(true);
				
			
			}
		});
};

// 성적 조회
this.fnSearchScre = function(obj, e)
{
	//초기화
	this.div00.setOffsetHeight(0);
	this.grdScre.setOffsetHeight(0);
	this.smfResetScroll(this);
	
	// 내 지원서 목록
	this.fnSearchRcptList();
	// 성적조회
	this.smfSearchService('selectScre') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			// 성적 조회 결과 표시
			this.screResultView();
	});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 성적조회 결과 표시
this.screResultView = function()
{
	//초기화
	this.div00.setOffsetHeight(0);
	this.grdScre.setOffsetHeight(0);
	this.smfResetScroll(this);
	this.div00.form.staTxt11.sfcDgrNo = "all";    // 석차
	this.div00.form.staVal11.sfcDgrNo = "all";
	this.div00.form.staTxt06.sfcDgrNo = "1";      // 1차 1순위 , 1차 2순위 
	this.div00.form.staVal06.sfcDgrNo = "1";
	this.div00.form.staTxt09.sfcDgrNo = "1";
	this.div00.form.staVal09.sfcDgrNo = "1";
	

	// 발표 차수
 	var sfcDgrNo = this.dsResultSfc.getColumn(0, 'sfcDgrNo');
	
	var tmeTtsrYn;    // 총점여부
	var sbjtScreYn;   // 과목별성적 여부 
	var sfcDgrNoX;    // 제외차수
	var screRakYn;    // 석차여부
	var a1passExclYn = "N"; //1차합격자제외여부 (1차만)

	this.div00.form.staTxt11.set_text(this.dsResultScre.getColumn(0,"staTxt11"));//순위/석차
	this.div00.form.staTxt02.set_text(this.dsResultScre.getColumn(0,"staTxt02"));//1차의사상자가산점, 취업가산점
	this.div00.form.staTxt03.set_text(this.dsResultScre.getColumn(0,"staTxt03"));//2차의사상자가산점, 취업가산점
	
    if(sfcDgrNo == "1"){
		//발표차수가 1차일경우 
		tmeTtsrYn     = this.dsResultScre.getColumn(0,"a1tmeTtsrYn");    // 총점여부 
		sbjtScreYn    = this.dsResultScre.getColumn(0,"a1sbjtScreYn");   // 과목별성적 여부 
		screRakYn     = this.dsResultScre.getColumn(0,"a1screRakYn");    // 석차여부
		sfcDgrNoX  = "2";
		
			
		if(screRakYn == "N"){
			this.div00.form.staTxt11.sfcDgrNo = "2";
			this.div00.form.staVal11.sfcDgrNo = "2";
		}

	}else{
		//발표차수가 2차일경우 
		tmeTtsrYn   = this.dsResultScre.getColumn(0,"a2tmeTtsrYn");    // 총점여부 
		sbjtScreYn  = this.dsResultScre.getColumn(0,"a2sbjtScreYn");   // 과목별성적 여부 
		screRakYn = "Y";
		sfcDgrNoX  = "1";
		if(this.smfIsNull(this.dsResultScre.getColumn(0,"exam1TmeRnk"))){
			screRakYn = "N";
			this.dsResultScre.setColumn(0,"exam1TmeRnk","");
			this.div00.form.staTxt11.sfcDgrNo = "1";
			this.div00.form.staVal11.sfcDgrNo = "1";
		}
		
		
	}
	


	var iHeight = 0;
	for(var i=0; i < this.div00.form.components.length; i++)
	{
		this.div00.form.components[i].setOffsetHeight(0);
		if( tmeTtsrYn == "Y" ){ //총점
			if(this.div00.form.components[i].sfcDgrNo != sfcDgrNoX){
				this.div00.form.components[i].setOffsetHeight(42);
				iHeight++;
			}
		}
	}
	
	if( tmeTtsrYn == "N" && screRakYn == "Y" ){ //석차만 있는 경우 
		this.div00.form.staTxt11.setOffsetHeight(42);
		this.div00.form.staVal11.setOffsetHeight(42);
		iHeight = iHeight+2;
	}

	if(iHeight > 0 ){
		this.div00.setOffsetHeight( (iHeight/2*42) + 30 );
	}
	
	// 과목별성적 여부 
	if(sbjtScreYn == "Y"){
		this.grdScre.setOffsetHeight(224);
	}else{
		this.grdScre.setOffsetHeight(0);
	}
	
		
	
	
	// 전체영역  RESET
	this.smfResetScroll(this);
};
 
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
//성적조회 
this.divAppoExam_divContent00_btnSearchScre_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 선택한 응시원서 접수번호
	var sRcptNo = this.divAppoExam.form.divContent00.form.cboAppoExm.value;
	if(!sRcptNo){
		this.divAppoExam.form.divContent00.form.cboAppoExm.setFocus();
		this.smfAlert("응시 시험을 선택 해주세요.");
		return;
	}
	var sCddcCd = this.smfGetCddcCode();
	this.dsSearchSfc.clearData();
	this.dsSearchSfc.addRow();
	this.dsSearchSfc.setColumn(0,"cddcCd"            , sCddcCd.slice(0,3));	
	this.dsSearchSfc.setColumn(0,"appoExamId"        , this.dsResultRcpt.lookup("rcptNo",sRcptNo,"appoExamId"));	
	this.dsSearchSfc.setColumn(0,"onlEmpmnExamScCd"  , this.smfGetAppoExamScCd());
	this.dsSearchSfc.setColumn(0,"currCd"            , this.dsResultRcpt.lookup("rcptNo",sRcptNo,"currCd"));	
	this.dsSearchSfc.setColumn(0,"rcptNo"            , this.dsResultRcpt.lookup("rcptNo",sRcptNo,"rcptNo"));	
	
	// 성적조회
	this.fnSearchScre();
};

]]></Script>
    <Objects>
