              <Static id="staTxt05" taborder="11" left="0" width="160" height="42" cssclass="sta_WF_Input01" text="대학성적" top="staTxt04:-1" initvalueid="ivStcAccessibilityOn" sfcDgrNo="1"/>
              <Static id="staVal05" taborder="12" left="159" height="42" cssclass="sta_WF_Input02" top="staVal04:-1" initvalueid="ivStcAccessibilityOn" right="0" textAlign="left" text="0" sfcDgrNo="1"/>
              <Static id="staGd04_00" taborder="13" top="33" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" width="1200"/>
              <Static id="staGd04" taborder="14" left="0" top="661" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staTxt06" taborder="15" left="0" width="160" height="42" cssclass="sta_WF_Input01" text="1차 1순위시험성적" top="staTxt05:-1" initvalueid="ivStcAccessibilityOn" sfcDgrNo="1" onclick="div00_staTxt06_onclick" visible="false"/>
              <Static id="staVal06" taborder="16" left="159" height="42" cssclass="sta_WF_Input02" top="staVal05:-1" initvalueid="ivStcAccessibilityOn" right="0" textAlign="left" text="0" sfcDgrNo="1" visible="false"/>
