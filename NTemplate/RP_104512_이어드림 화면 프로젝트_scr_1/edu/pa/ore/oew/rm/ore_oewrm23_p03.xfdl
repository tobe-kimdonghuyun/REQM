<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="formMain" width="800" height="255" titletext="지방공무원-경력합산신청-자격증 팝업" onload="formMain_onload">
    <Layouts>
      <Layout height="255" width="800" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Static id="staGd00" taborder="1" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="221" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd01" taborder="2" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="221" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Div id="divContent01" taborder="3" text="div01" left="20" top="185" height="70" cssclass="div_WF_Detail" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Button id="btnCancel" taborder="0" text="취소" height="30" width="50" left="43.25%" fittocontents="width" cssclass="btn_WF_Custom" initvalueid="ivBtnAccessibilityButton" top="20" onclick="divContent01_btnCancel_onclick"/>
              <Button id="btnSave" taborder="1" text="적용" height="30" width="50" fittocontents="width" left="btnCancel:8" initvalueid="ivBtnAccessibilityButton" top="20" onclick="divContent01_btnSave_onclick"/>
              <Static id="staGd00" taborder="2" left="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" top="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staGd01" taborder="3" left="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" height="20" initvalueid="ivStcAccessibilityOff" top="50"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divContent00" taborder="4" left="20" height="185" top="0" text="" cssclass="div_WF_Detail" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staContent05" taborder="0" left="120" height="42" cssclass="sta_WF_Input02Top" top="20" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staContent00" taborder="1" left="120" height="42" cssclass="sta_WF_Input02" top="61" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staContent01" taborder="2" left="120" height="42" cssclass="sta_WF_Input02" top="102" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staContent07" taborder="3" left="119" height="42" cssclass="sta_WF_Input02" top="143" right="1" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staContent08" taborder="4" left="0" width="120" height="42" cssclass="sta_WF_Input01Top" text="자격증명" top="20" onclick="Static45_onclick" initvalueid="ivStcEssential"/>
              <Edit id="edtQlflNm" taborder="5" left="125" top="27" height="30" right="6" initvalueid="ivEdtEssential" value="한국산업인력공단" text="한국산업인력공단" cssclass="essential"/>
              <Static id="staContent02" taborder="6" left="0" width="120" height="42" cssclass="sta_WF_Input01" text="발급기관명" top="61" onclick="Static45_onclick" initvalueid="ivStcEssential"/>
              <Edit id="edtIssuInstNm" taborder="7" left="125" top="67" height="30" right="326" initvalueid="ivEdtEssential" value="한국산업인력공단" text="한국산업인력공단" cssclass="essential"/>
              <Static id="staContent03" taborder="8" left="440" height="42" cssclass="sta_WF_Input01" text="자격번호" top="61" onclick="Static45_onclick" width="120" initvalueid="ivStcEssential"/>
              <Edit id="edtQlflNo" taborder="9" left="565" top="67" height="30" right="6" initvalueid="ivEdtEssential" value="111-222-333-444" text="111-222-333-444" cssclass="essential"/>
              <Static id="staContent04" taborder="10" left="0" width="120" height="42" cssclass="sta_WF_Input01" text="발급일자" top="102" onclick="Static45_onclick" initvalueid="ivStcEssential"/>
              <Calendar id="calIssuYmd" taborder="11" left="125" top="108" width="130" height="30" dateformat="yyyy.MM.dd" initvalueid="ivCalEssential" editformat="yyyy.MM.dd" cssclass="essential"/>
              <Static id="staContent06" taborder="12" left="0" width="120" height="42" cssclass="sta_WF_Input01" text="증빙자료" top="143" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn"/>
              <Div id="divFileContent" taborder="13" left="125" top="149" height="33" background="green" url="comm::comm_fileAdd2.xfdl" initvalueid="ivDivAccessibilityOff" right="79"/>
              <Static id="staGd00" taborder="14" left="0" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsMain" useclientlayout="true">
        <ColumnInfo>
          <Column id="fileRefrnId" type="STRING" size="256" description="파일참조ID"/>
          <Column id="qlfAcqsSn" type="STRING" size="256" description="자격취득일련번호"/>
          <Column id="qlflNm" type="STRING" size="256" description="자격증명"/>
          <Column id="issuYmd" type="STRING" size="256" description="발급일자"/>
          <Column id="issuInstNm" type="STRING" size="256" description="발급기관명"/>
          <Column id="qlflNo" type="STRING" size="256" description="자격증번호"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsValidation" useclientlayout="true">
        <ColumnInfo>
          <Column id="code" type="STRING" size="256"/>
          <Column id="name" type="STRING" size="256" description="일련번호"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="code">edtQlflNm</Col>
            <Col id="name">자격증명</Col>
          </Row>
          <Row>
            <Col id="code">calIssuYmd</Col>
            <Col id="name">발급일자</Col>
          </Row>
          <Row>
            <Col id="name">발급기관명</Col>
            <Col id="code">edtIssuInstNm</Col>
          </Row>
          <Row>
            <Col id="name">자격번호</Col>
            <Col id="code">edtQlflNo</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-지방공무원-경력합산신청-임용전연수 팝업
*  @MenuPath    pa_ore_oew_rm
*  @FileName 	pa_ore_oewrm23_p03.xfdl
*  @Creator 	shhan
*  @CreateDate 	2022.09.13
*  @Desction    온라인통합채용-지방공무원-경력합산신청-임용전연수 팝업
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.09.13    	shhan 	        	최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitPopup(this);

	// 파일 업로드
	this.divContent00.form.divFileContent.UPLOAD_UploadComplete  = this.fnFileUploadCompleteCallback;
	this.divContent00.form.divFileContent.UPLOAD_OnError         = this.fnFileUploadErrorCallback;
	this.divContent00.form.divFileContent.UPLOAD_AfterAddFile    = this.fnFileUploadChangeCallback;     
	this.divContent00.form.divFileContent.UPLOAD_Form            = this;
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid, errcd, errmsg){

}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 파일 업로드 성공 콜백
this.fnFileUploadCompleteCallback = function(obj, paramObj, objResultDataset)
{
	this.divContent00.form.divFileContent.form.fnSetUploadCompleteState(obj,paramObj);
	this.dsMain.setColumn(0, "fileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
};

// 파일 업로드 실패 콜백
this.fnFileUploadErrorCallback = function(obj, paramObj)
{
	//this.smfAlert('파일 업로드에 실패 하였습니다.');
};

// 파일 업로드 변경 콜백
this.fnFileUploadChangeCallback = function(obj, paramObj, sCustomValue, sFileName, nFileSize)
{
	this.divContent00.form.divFileContent.form.fnFileUpload();	
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// 취소 버튼 
this.divContent01_btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);	
};

// 등록 버튼 
this.divContent01_btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//필수 값 체크 
	var components = this.divContent00.form.components;
	for(var i=0; i < components.length; i++){
		if(components[i].cssclass == "essential"){
			if(this.smfIsNull(components[i].value)){
				components[i].setFocus();
				var message =  this.dsValidation.lookup( "code" , components[i].name , "name" );
				this.smfAlert('CM006', [message], "" ); 
				return;	
			}
		}
	}
	// 입력값 부모창 전달
	this.smfSendResponseToOpener({
		dsMainP  : this.dsMain
	});
	this.close(true);
};
]]></Script>
    <Bind>
      <BindItem id="item1" compid="divContent00.form.edtIssuInstNm" propid="value" datasetid="dsMain" columnid="issuInstNm"/>
      <BindItem id="item2" compid="divContent00.form.edtQlflNo" propid="value" datasetid="dsMain" columnid="qlflNo"/>
      <BindItem id="item3" compid="divContent00.form.calIssuYmd" propid="value" datasetid="dsMain" columnid="issuYmd"/>
      <BindItem id="item0" compid="divContent00.form.edtQlflNm" propid="value" datasetid="dsMain" columnid="qlflNm"/>
    </Bind>
  </Form>
</FDL>
