<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmMain" width="1200" height="780" titletext="경력합산신청-사전동의서" onload="frmMain_onload">
    <Layouts>
      <Layout height="780" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="70" height="45" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle00" taborder="0" text="경력합산신청" left="0" top="1" height="44" cssclass="img_WF_SubTit01" width="200" initvalueid="ivTitleAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divContent00" taborder="1" left="0" height="517" right="0" top="145" text="" initvalueid="ivDivAccessibilityOff" cssclass="div_WF_InfoBOX">
          <Layouts>
            <Layout>
              <Static id="staTlt00" taborder="0" left="30" top="24" height="36" text="개인정보 수집 및 이용에 대한 동의" wordWrap="char" width="548" cssclass="sta_WF_WorkTit" initvalueid="ivStcAccessibilityOn" accessibilitylabel="교육부, 시도교육청내 자료 활용 동의서"/>
              <Div id="divContent01" taborder="1" left="30" height="383" cssclass="div_WF_InfoBOX" top="80" text="" right="30" initvalueid="ivDivAccessibilityOff">
                <Layouts>
                  <Layout>
                    <Static id="staContent01" taborder="0" left="30" height="338" text=" 가. 개인정보 수집 및 이용 목적&#13;&#10;     ○ 계약제교원 채용자에 대해 신규채용절차에 따라 결격사유확인, 호봉합산신청, 전자근로계약체결, 인사기록카드 생성을 처리하여 최종 계약제교원 인사를 관리하기 &#13;&#10;         위함&#13;&#10;&#13;&#10; 나. 수집하려는 개인정보의 항목&#13;&#10;     ○ 인사기록호봉 및 전자근로계약서 계약호봉 등록을 위해 아래와 같은 개인정보를 수집하고 있음&#13;&#10;         성명, 주민등록번호, 전임경력, 군경력, 학력, 교원자격 정보 호봉합산신청에 필요한 사항&#13;&#10;     ※ 주민등록번호는 「아동청소년의성보호에관한법률시행령」  제39조(민감정보 및 고유식별정보의 처리), 「소득세법」 제166조(주민등록 전산정보자료 등의 이용)에 &#13;&#10;      근거하여 처리합니다.&#13;&#10;&#13;&#10; &lt;b v='true'&gt;&lt;fs v='12'&gt;다. 개인정보의 보유기간&#13;&#10;    ○ 수집한 개인정보는 공공기록물 관리에 관한 법률에 의해 정해진 기간 동안(5년) 보유&lt;/fs&gt;&lt;/b&gt;&#13;&#10;&#13;&#10; 라. 동의를 거부할 권리 및 동의거부에 따른 제약사항&#13;&#10;    ○ 위사항에 대하여 동의를 거부할 권리가 있으며 동의거부시에는 본사이트에서 제공하는 온라인 호봉합산신청서 제출 서비스를 이용할 수 없음" wordWrap="char" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" right="30" top="15" usedecorate="true"/>
                  </Layout>
                </Layouts>
              </Div>
              <Static id="staContent05" taborder="2" left="30" top="473" height="23" text="위와 같이 행정정보 공동 이용에 동의하십니까?" wordWrap="char" width="368" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn"/>
              <Static id="staGd03" taborder="3" left="0" top="60" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staGd07" taborder="4" left="-1" top="463" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="-1" initvalueid="ivStcAccessibilityOff"/>
              <CheckBox id="chkVal01" taborder="5" text="동의합니다.  " left="1050" top="468" width="115" height="30" initvalueid="ivChkNormal"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnNext00" taborder="2" text="다음" left="43.50%" top="692" width="158" height="40" cssclass="btn_WF_Action" initvalueid="ivBtnAccessibilityButton" onclick="btnNext00_onclick"/>
        <Static id="staGd00" taborder="3" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd01" taborder="4" left="0" top="115" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd12" taborder="5" left="0" height="50" cssclass="sta_GD_Size" text="50" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" top="732"/>
        <Static id="staGd12_00" taborder="6" left="0" top="662" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-경력합산신청-사전동의서
*  @MenuPath    pa_ore_oew_rm
*  @FileName 	pa_ore_oewrm12_m00.xfdl
*  @Creator 	
*  @CreateDate 	2022.12.15
*  @Desction    경력합산신청-사전동의서 화면
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.12.15        	 	            최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);
	
	// 본인인증
	var rrno     = nexacro.base64Decode(this.smfGetSessionValue('userRrno'));  // 주민번호
	this.dsSearch.setColumn(0, "rrno", rrno);
	this.dsSearch.setColumn(0, "onlEmpmnExamScCd", this.smfGetAppoExamScCd());
	
	// 등록여부 조회 
	this.smfSearchService('selectChk') 
	.run()
	// 콜백
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
	    if(this.dsResult.getColumn(0,"insertYn") == "Y" ){
			// 페이지 이동 Param
			var params = {};
			if(this.smfGetAppoExamScCd() == "3"){
				//지방공무원일경우 
				this.smfSetWorkPage("pa_ore_oew_rm::ore_oewrm23_m00.xfdl", params);
			}else{
				this.smfSetWorkPage("pa_ore_oew_rm::ore_oewrm13_m00.xfdl", params);
			}
		}
	});
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){

};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
//다음 클릭 
this.btnNext00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 조건
	if( ! this.divContent00.form.chkVal01.value   ) {
		this.smfAlert('동의를 체크 하지 않을 경우, 서비스 이용이 불가능 합니다.');
		return false;
	}
	// 페이지 이동 Param
	var params = {};
	if(this.smfGetAppoExamScCd() == "3"){
		//지방공무원일경우 
		this.smfSetWorkPage("pa_ore_oew_rm::ore_oewrm23_m00.xfdl", params);
	}else{
		this.smfSetWorkPage("pa_ore_oew_rm::ore_oewrm13_m00.xfdl", params);
	}
};
]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">selectChk</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResult=dsResult</Col>
            <Col id="url">ore_oew_rm13_004.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="onlEmpmnExamScCd" type="STRING" size="256"/>
          <Column id="rrno" type="STRING" size="256" description="주민번호"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsResult" useclientlayout="true">
        <ColumnInfo>
          <Column id="insertYn" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
  </Form>
</FDL>
