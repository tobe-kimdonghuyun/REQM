<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="formMain" width="800" height="296" titletext="경력합산신청-대학학력-추가학력 팝업" onload="formMain_onload">
    <Layouts>
      <Layout height="296" width="800" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divContent00" taborder="1" left="20" height="226" top="0" text="" cssclass="div_WF_Detail" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Radio id="rdoContent00" taborder="0" left="5" top="25" width="235" height="30" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" rowcount="-1" initvalueid="ivRdoNormal" value="3" text="독학사" index="0">
                <Dataset id="innerdataset">
                  <ColumnInfo>
                    <Column id="codecolumn" size="256"/>
                    <Column id="datacolumn" size="256"/>
                  </ColumnInfo>
                  <Rows>
                    <Row>
                      <Col id="codecolumn">3</Col>
                      <Col id="datacolumn">독학사</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">4</Col>
                      <Col id="datacolumn">학점은행제</Col>
                    </Row>
                  </Rows>
                </Dataset>
              </Radio>
              <Static id="staContent00_00" taborder="1" left="120" height="42" cssclass="sta_WF_Input02Top" top="61" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staContent01" taborder="2" left="120" height="42" cssclass="sta_WF_Input02" top="143" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staContent07" taborder="3" left="119" height="42" cssclass="sta_WF_Input02" top="184" right="1" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staContent02_00" taborder="4" left="0" width="120" height="42" cssclass="sta_WF_Input01Top" text="학위구분" top="61" onclick="Static45_onclick" initvalueid="ivStcEssential"/>
              <Combo id="cboDgriCd" taborder="5" left="125" top="66" width="240" height="30" value="1" index="0" initvalueid="ivCmbEssential" innerdataset="dsDgriCd" codecolumn="unyCdValue" datacolumn="unyCdValueNm" text="육군" cssclass="essential"/>
              <Static id="staContent03" taborder="6" left="370" height="41" cssclass="sta_WF_Input01" text="취득일자" top="62" onclick="Static45_onclick" width="120" initvalueid="ivStcEssential"/>
              <Calendar id="calAcqsYmd" taborder="7" left="495" top="68" height="30" dateformat="yyyy.MM.dd" initvalueid="ivCalEssential" width="130" editformat="yyyy.MM.dd" cssclass="essential"/>
              <Static id="staContent04" taborder="8" left="0" width="120" height="42" cssclass="sta_WF_Input01" text="학교명" top="102" onclick="Static45_onclick" initvalueid="ivStcEssential"/>
              <Edit id="edtShlNm" taborder="9" left="125" top="107" height="30" right="5" initvalueid="ivEdtEssential" value="OOOO대학교" text="OOOO대학교" maxlength="300" cssclass="essential"/>
              <Static id="staContent06" taborder="10" left="0" width="120" height="42" cssclass="sta_WF_Input01" text="증빙자료" top="143" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn"/>
              <Div id="divFileContent" taborder="11" left="125" top="149" height="33" background="green" url="comm::comm_fileAdd2.xfdl" initvalueid="ivDivAccessibilityOff" right="79"/>
              <Static id="staContent06_00" taborder="12" left="0" width="120" height="42" cssclass="sta_WF_Input01" text="비고" top="184" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtContent00_00" taborder="13" left="125" top="190" height="30" right="5" initvalueid="ivEdtNormal" value="비고내용" text="비고내용" maxlength="3000"/>
              <Static id="staGd00" taborder="14" left="0" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divContent01" taborder="2" text="div01" left="20" top="226" height="70" cssclass="div_WF_Detail" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Button id="btnCancel" taborder="0" text="취소" height="30" width="50" left="43.25%" fittocontents="width" cssclass="btn_WF_Custom" initvalueid="ivBtnAccessibilityButton" top="20" onclick="divContent01_btnCancel_onclick"/>
              <Button id="btnSave" taborder="1" text="적용" height="30" width="50" fittocontents="width" left="btnCancel:8" initvalueid="ivBtnAccessibilityButton" top="20" onclick="divContent01_btnSave_onclick"/>
              <Static id="staGd00" taborder="2" left="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" top="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staGd01" taborder="3" left="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" height="20" initvalueid="ivStcAccessibilityOff" top="50"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staGd00" taborder="3" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd01" taborder="4" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsDgriCd" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="FirstCode" type="STRING" size="30" value="SEL" datapath=""/>
          <ConstColumn id="ClfCdValue" type="STRING" size="30" value="DGRI_CD"/>
          <ConstColumn id="FilterExpr" type="STRING" size="30" value=""/>
          <ConstColumn id="UnyCdGrpId" type="STRING" size="30" value=""/>
          <ConstColumn id="BfrClfCdValue" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd1Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd2Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd3Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd4Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd5Value" type="STRING" size="30" value=""/>
          <Column id="pgeId" type="STRING" size="256"/>
          <Column id="clfCdValue" type="STRING" size="30"/>
          <Column id="clfCdValueNm" type="STRING" size="120"/>
          <Column id="clfCdUseYn" type="STRING" size="150"/>
          <Column id="unyCdValue" type="STRING" size="10"/>
          <Column id="unyCdValueNm" type="STRING" size="30"/>
          <Column id="userDfnCd1Value" type="STRING" size="100"/>
          <Column id="userDfnCd2Value" type="STRING" size="100"/>
          <Column id="userDfnCd3Value" type="STRING" size="100"/>
          <Column id="userDfnCd4Value" type="STRING" size="100"/>
          <Column id="userDfnCd5Value" type="STRING" size="100"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true" cancolumnchange="dsMain_cancolumnchange">
        <ColumnInfo>
          <Column id="srclsAcbgScCd" type="STRING" size="256" description="추가학력구분"/>
          <Column id="dgriCd" type="STRING" size="256" description="학위코드"/>
          <Column id="acqsYmd" type="STRING" size="256" description="취득일자"/>
          <Column id="shlNm" type="STRING" size="256" description="학교명"/>
          <Column id="acbgMteRmkCn" type="STRING" size="256" description="비고"/>
          <Column id="fileRefrnId" type="STRING" size="256" description="파일참조ID"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="shlNm"/>
            <Col id="acbgMteRmkCn"/>
            <Col id="acqsYmd"/>
            <Col id="srclsAcbgScCd">3</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsValidation" useclientlayout="true">
        <ColumnInfo>
          <Column id="code" type="STRING" size="256"/>
          <Column id="name" type="STRING" size="256" description="일련번호"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="code">cboDgriCd</Col>
            <Col id="name">학위구분</Col>
          </Row>
          <Row>
            <Col id="code">calAcqsYmd</Col>
            <Col id="name">취득일자</Col>
          </Row>
          <Row>
            <Col id="code">edtShlNm</Col>
            <Col id="name">학교명</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-교원임용(중등)-경력합산신청-대학학력-추가학력 팝업
*  @MenuPath    pa_ore_oew_rm
*  @FileName 	pa_ore_oewrm13_p03.xfdl
*  @Creator 	shhan
*  @CreateDate 	2022.09.13
*  @Desction    온라인통합채용-교원임용(중등)-경력합산신청-대학학력-추가학력 팝업
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.09.13    	shhan	 	        최초 생성 
*  2022.12.12       최정민 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitPopup(this);
	
	// 공통코드
	// dsDgriCd : 학위
	this.smfCodeList("code", [this.dsDgriCd ])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		})		
		.run();
		
	// 파일 업로드
	this.divContent00.form.divFileContent.UPLOAD_UploadComplete  = this.fnFileUploadCompleteCallback;
	this.divContent00.form.divFileContent.UPLOAD_OnError         = this.fnFileUploadErrorCallback;
	this.divContent00.form.divFileContent.UPLOAD_AfterAddFile    = this.fnFileUploadChangeCallback;     
	this.divContent00.form.divFileContent.UPLOAD_Form            = this;
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid, errcd, errmsg){

}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 파일 업로드 성공 콜백
this.fnFileUploadCompleteCallback = function(obj, paramObj, objResultDataset)
{
	this.divContent00.form.divFileContent.form.fnSetUploadCompleteState(obj,paramObj);
	this.dsMain.setColumn(0, "fileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
};

// 파일 업로드 실패 콜백
this.fnFileUploadErrorCallback = function(obj, paramObj)
{
	//this.smfAlert('파일 업로드에 실패 하였습니다.');
};

// 파일 업로드 변경 콜백
this.fnFileUploadChangeCallback = function(obj, paramObj, sCustomValue, sFileName, nFileSize)
{
	this.divContent00.form.divFileContent.form.fnFileUpload();	
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// 등록 
this.divContent01_btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//필수 값 체크 
	var components = this.divContent00.form.components;
	for(var i=0; i < components.length; i++){
		if(components[i].cssclass == "essential"){
			if(this.smfIsNull(components[i].value)){
				components[i].setFocus();
				var message =  this.dsValidation.lookup( "code" , components[i].name , "name" );
				this.smfAlert('CM006', [message], "" ); 
				return;	
			}
		}
	}
	// 입력값 부모창 전달
	this.smfSendResponseToOpener({
		dsMainP  : this.dsMain,
	});
	this.close(true);
};

// 취소 버튼 
this.divContent01_btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};

// 취득날짜 체크 
this.dsMain_cancolumnchange = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	if(e.columnid == "acqsYmd"){
		if(!this.smfIsNull( e.newvalue )){
			if(e.newvalue > this.smfToday()){
				// 확인 메시지 출력
				this.smfConfirm("미래일자를 입력하셨습니다.\n그래도 진행을 하시겠습니까?", function(result){
					if(!result.confirmResult){ //취소 = 이전 값으로 복구
						//01. 값 원복으로 인해 이벤트가 무한으로 발생하여 삭제.
						obj.removeEventHandler("cancolumnchange", this.dsMain_cancolumnchange, this); 
						//02. 값 원복
						obj.setColumn(e.row, "acqsYmd", e.oldvalue);
						//03. 값 원복 후, 삭제한 이벤트 추가.
						obj.addEventHandler("cancolumnchange", this.dsMain_cancolumnchange, this);
						return false;
					}
				});
			}
		}
	}
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="divContent00.form.cboDgriCd" propid="value" datasetid="dsMain" columnid="dgriCd"/>
      <BindItem id="item2" compid="divContent00.form.edtShlNm" propid="value" datasetid="dsMain" columnid="shlNm"/>
      <BindItem id="item1" compid="divContent00.form.calAcqsYmd" propid="value" datasetid="dsMain" columnid="acqsYmd"/>
      <BindItem id="item3" compid="divContent00.form.edtContent00_00" propid="value" datasetid="dsMain" columnid="acbgMteRmkCn"/>
      <BindItem id="item4" compid="divContent00.form.rdoContent00" propid="value" datasetid="dsMain" columnid="srclsAcbgScCd"/>
    </Bind>
  </Form>
</FDL>
