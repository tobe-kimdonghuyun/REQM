/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.applpRrno;
this.applpFlnm;
this.applpBrdt;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	//본인 인증 
	this.applpRrno = nexacro.base64Decode(this.smfGetSessionValue('userRrno'));
	this.applpFlnm   = this.smfGetSessionValue('userNm');
	this.applpBrdt = this.applpRrno.slice(0,6);
	
	//Form의 default 초기처리를 한다.
	this.smfInitForm(obj);
	
	//파일 처리
	this.divAttach.form.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;       
	this.divAttach.form.divFileUpload.UPLOAD_OnError = this.fnEventUploadError;     
	this.divAttach.form.divFileUpload.UPLOAD_Form = this; 
	
	var sCddcCd = this.smfGetCddcCode();
	this.dsSearch.setColumn(0, "applpRrno"        , this.applpRrno);
	this.dsSearch.setColumn(0, "cddcCd"           , sCddcCd);
	this.dsSearch.setColumn(0, "cddcScCd"         , sCddcCd.slice(0,3));
	this.dsSearch.setColumn(0, "onlEmpmnExamScCd" , "2");
	this.dsSearch.setColumn(0, "applpFlnm"        , this.applpFlnm);
	this.dsSearch.setColumn(0, "applpBrdt"        , this.applpBrdt);
	this.dsSearch.setColumn(0, "arbilCd"          , "30");

	this.divSummary.form.divContent00.form.staContent00.set_text(this.applpFlnm + "(" +this.applpBrdt +")님.");
	
	// 내 지원서 목록
	this.fnSearchRcptList();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){

};

// 업로드성공 콜백
this.fnEventUploadComplete = function(obj,paramObj,objResultDataset)
{
	if(objResultDataset){
		var sFileRefrnId = objResultDataset.getColumn(0,"fileRefrnId");
		this.dsMain.setColumn(0, "fileRefrnId", sFileRefrnId);
		// 임용후보자 등록 처리
		this.fnSaveAppoCndtReg();
	}
};

// 파일 업로드 에러 콜백
this.fnEventUploadError = function(obj,paramObj)
{
	//this.smfAlert("첨부파일 업로드 실패 하였습니다. \n다시 시도해주세요.");
	//return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
// 내 지원서 목록
this.fnSearchRcptList = function()
{
	// 지원서목록조회
	this.smfSearchService("selectRcpt") 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			//  결과
			var resultCnt= this.dsResultRcpt.getRowCount();
			if(resultCnt < 1){
				this.divAppoExam.form.divContent00.form.cboAppoExm.set_enable(false);
				this.divActionBtn.form.btnReg.set_enable(false);
				this.divSummary.form.divContent00.form.staContent01.set_text(this.smfGetCddcName()+" 임용후보자 신청 대상 원서가 없습니다.");
			}
				
	});
};

// 임용후보자 등록처리
this.fnSaveAppoCndtReg = function()
{	
	// 저장
	this.smfSaveService("saveAppoCndtReg")
		.showConfirm(false)
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors){
					return;
			}
			this.smfAlert("임용후보자 신청이 완료 되었습니다.");
			this.divAttach.form.divFileUpload.form.fnResetUpload();
			this.fnSearchRcptList();
	});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// RAONK  옵션
this.fnSetRaonProp = function()
{
	var objAddRaonProps = {
		 MaxTotalFileCount : "3"	//업로드 할 최대 파일 개수 제한값을 설정합니다.
		, MaxOneFileSize : "3MB"	//업로드할 때 파일당 용량제한을 설정합니다.

	};						  
	return objAddRaonProps;
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
//임용후보자 등록
this.btnReg_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 유의사항
	if( !this.divAgree00.form.chkVal00.value ) {
		this.divAgree00.form.chkVal00.setFocus();
		this.smfAlert("유의 사항 확인 체크 후 등록 해주세요.");
		return false;
	}
	
	// 서약서
	if( !this.divAgree01.form.chkVal00.value ) {
		this.divAgree01.form.chkVal00.setFocus();
		this.smfAlert("서약서 확인 체크 후 등록 해주세요.");
		return false;
	}
	
	// 선택한 응시원서 접수번호
	var sRcptNo = this.divAppoExam.form.divContent00.form.cboAppoExm.value;
	if(!sRcptNo){
		this.divAppoExam.form.divContent00.form.cboAppoExm.setFocus();
		this.smfAlert("응시시험을 선택 해주세요.");
		return;
	}
	
	var sAppoExamId = this.dsResultRcpt.lookup("rcptNo",sRcptNo,"appoExamId");
	this.dsSearch.setColumn(0,"rcptNo",sRcptNo);
	this.dsSearch.setColumn(0,"appoExamId",sAppoExamId);

	this.smfConfirm("임용후보자 신청을 하시겠습니까?", function(result){
				if(result.confirmResult){
					var sCddcCd = this.smfGetCddcCode();
					this.dsMain.setColumn(0, "cddcCd"            , sCddcCd); 
					this.dsMain.setColumn(0, "applpFlnm"         , this.applpFlnm); 
					this.dsMain.setColumn(0, "applpRrno"         , this.applpRrno ); 
					this.dsMain.setColumn(0, "appoExamId"        , sAppoExamId); 
					this.dsMain.setColumn(0, "rcptNo"            , sRcptNo );
					this.dsMain.setColumn(0, "onlEmpmnExamScCd"  , "2" );
					
					var fileCount = this.divAttach.form.divFileUpload.form.fnGetTotalFileCount();
					if(fileCount > 0) {
						this.divAttach.form.divFileUpload.form.fnFileUpload();
					}else{
						this.fnSaveAppoCndtReg();
					}
				}
			});
};]]></Script>
  </Form>
</FDL>
