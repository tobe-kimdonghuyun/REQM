  <Form id="formMain" width="1200" height="1312" titletext="교원임용(중등)-임용후보자-임용후보자신청" onload="formMain_onload">
    <Layouts>
      <Layout height="1312" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="70" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
