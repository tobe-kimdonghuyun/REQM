        </Div>
        <Div id="divSummary" taborder="4" left="0" top="141" height="94" right="0" cssclass="div_WF_Detail" initvalueid="ivDivAccessibilityOff" visible="true">
          <Layouts>
            <Layout>
              <Div id="divContent00" taborder="1" left="0" top="2" height="60" cssclass="div_WF_Search" right="0" initvalueid="ivDivAccessibilityOff" tabstop="true">
                <Layouts>
                  <Layout>
                    <Static id="staContent00" taborder="0" text="테스트(891212)님. " top="12" height="34" cssclass="sta_WF_InfoTit02" initvalueid="ivStcAccessibilityOn" textAlign="left" width="885" left="20" onclick="divSearch_staSubTltInfo00_onclick" font="16px/1.5 &quot;Noto Sans KR&quot;,&quot;NotoSansKR-Regular&quot;,&quot;Malgun Gothic&quot;,&quot;Arial&quot;,&quot;MS PGothic&quot;"/>
