                <Layouts>
                  <Layout>
                    <Static id="staContent00" taborder="0" text="응시시험" top="15" height="30" cssclass="sta_WF_InfoTit02" initvalueid="ivStcAccessibilityOn" textAlign="left" width="93" left="21" onclick="divSummary_staSubTltInfo00_onclick"/>
                    <Combo id="cboAppoExm" taborder="1" text="" left="114" top="16" width="1066" height="30" index="-1" initvalueid="ivCmbEssential" cssclass="essential" innerdataset="dsResultRcpt" codecolumn="rcptNo" datacolumn="appoExamNmSum" displaynulltext="-선택-" accessibilitylabel="시험장" autoselect="false"/>
