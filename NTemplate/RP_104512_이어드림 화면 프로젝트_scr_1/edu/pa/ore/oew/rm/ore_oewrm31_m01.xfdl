              <Edit id="edtEmail" taborder="3" left="195" top="14" height="30" text="우리날" width="395" initvalueid="ivEdtEssential" cssclass="essential" accessibilitylabel="이메일" maxlength="100"/>
              <Static id="staTltMobileNo" taborder="4" left="599" width="190" height="50" cssclass="sta_WF_Input01Top" text="휴대전화" top="4" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtMblNo00" taborder="5" left="794" top="14" height="30" text="우리날" width="90" initvalueid="ivEdtEssential" cssclass="essential" accessibilitylabel="휴대전화" inputtype="number" maxlength="4"/>
              <Static id="staMblNo00_00" taborder="6" text="-" left="884" top="16" width="15" height="26" cssclass="sta_WF_AC" initvalueid="ivStcAccessibilityOn" accessibilitylabel="다음"/>
              <Edit id="edtMblNo01" taborder="7" left="899" top="14" height="30" text="우리날" width="90" initvalueid="ivEdtEssential" cssclass="essential" accessibilitylabel="휴대전화" inputtype="number" maxlength="4"/>
              <Static id="staMblNo01_00" taborder="8" text="-" left="989" top="16" width="15" height="26" cssclass="sta_WF_AC" initvalueid="ivStcAccessibilityOn" accessibilitylabel="다음"/>
              <Edit id="edtMblNo02" taborder="9" left="1004" top="14" width="90" height="30" cssclass="essential" initvalueid="ivEdtEssential" accessibilitylabel="휴대전화" inputtype="number" maxlength="4"/>
              <Static id="staTltAttach" taborder="10" left="0" width="190" height="50" cssclass="sta_WF_Input01" text="채용포기 증빙자료" top="53" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn"/>
              <Div id="divFileUpload" taborder="11" text="div00" left="195" top="62" width="425" height="30" url="comm::comm_fileAdd2.xfdl" initvalueid="ivDivAccessibilityOff" addProp="fnSetRaonProp" fileEncryptYn="N" fileInfSaveYn="Y" fileSaveStg="SV" Mode="upload" privInfoFiltYn="N" uploadLocation="PA.ORE.OEW" essential="Y"/>
