              <Combo id="cboQlfAsortCd" taborder="6" text="선택" left="125" top="66" width="160" height="30" value="" index="-1" initvalueid="ivCmbEssential" cssclass="essential" innerdataset="dsQlfAsortCd" codecolumn="unyCdValue" datacolumn="unyCdValueNm"/>
              <Static id="staContent02_01_00" taborder="7" left="290" width="120" height="42" cssclass="sta_WF_Input01" text="발급일자" top="61" onclick="Static45_onclick" initvalueid="ivStcEssential"/>
              <Calendar id="calIssuYmd" taborder="8" left="415" top="66" width="130" height="30" dateformat="yyyy.MM.dd" initvalueid="ivCalEssential" editformat="yyyy.MM.dd"/>
              <Static id="staContent02_01_01" taborder="9" left="0" width="120" height="42" cssclass="sta_WF_Input01" text="표시과목" top="101" onclick="Static45_onclick" initvalueid="ivStcEssential"/>
              <Combo id="cboTchQlfIndctSbjtCd" taborder="10" text="선택" left="125" top="107" width="160" height="30" value="" index="-1" initvalueid="ivCmbEssential" innerdataset="dsTchQlfIndctSbjtCd" codecolumn="unyCdValue" datacolumn="unyCdValueNm"/>
              <Static id="staContent02_01_00_00" taborder="11" left="290" width="120" height="42" cssclass="sta_WF_Input01" text="발급기관" top="101" onclick="Static45_onclick" initvalueid="ivStcEssential"/>
              <Edit id="edtIssuInstNm" taborder="12" left="415" top="108" height="30" text="우리날" width="275" initvalueid="ivEdtEssential" readonly="true" tabstop="false"/>
              <Button id="btnContent00" taborder="13" text="찾기" left="695" top="108" width="55" height="30" cssclass="btn_WF_Crud" initvalueid="ivBtnAccessibilityButton" onclick="divContent00_btnContent00_onclick"/>
              <Static id="staGd00" taborder="14" left="0" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divContent02" taborder="2" text="div01" left="20" top="170" height="70" cssclass="div_WF_Detail" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Button id="btnCancel" taborder="0" text="취소" height="30" width="50" left="43.25%" fittocontents="width" cssclass="btn_WF_Custom" initvalueid="ivBtnAccessibilityButton" top="20" onclick="divContent02_btnCancel_onclick"/>
              <Button id="btnSave" taborder="1" text="적용" height="30" width="50" fittocontents="width" left="btnCancel:8" initvalueid="ivBtnAccessibilityButton" top="20" onclick="divContent02_btnSave_onclick"/>
              <Static id="staGd00" taborder="2" left="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" top="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staGd01" taborder="3" left="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" height="20" initvalueid="ivStcAccessibilityOff" top="50"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staGd00" taborder="3" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd01" taborder="4" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta00" taborder="5" text="※ 교원자격증 부여 전일 경우, 자격종별 항목만 필수입력하시고 자격증코드, 발급일자를 입력하지 않고 적용하시기 바랍니다." left="20" top="143" width="760" height="25"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsMain" useclientlayout="true" cancolumnchange="dsMain_cancolumnchange">
        <ColumnInfo>
          <Column id="fileRefrnId" type="STRING" size="256" description="파일참조ID"/>
          <Column id="qlfAcqsSn" type="STRING" size="256" description="자격취득일련번호"/>
          <Column id="qlfAsortCd" type="STRING" size="256" description="자격종별코드"/>
          <Column id="issuYmd" type="STRING" size="256" description="발급일자"/>
          <Column id="tchQlfIndctSbjtCd" type="STRING" size="256" description="교원자격표시과목코드"/>
          <Column id="issuInstNm" type="STRING" size="256" description="발급기관명"/>
          <Column id="qlflNo" type="STRING" size="256" description="자격증번호"/>
          <Column id="tchQlfVrfcYn" type="STRING" size="256" description="교원자격검증여부"/>
          <Column id="tchQlfVrfcRltCn" type="STRING" size="256" description="교원자격검증결과내용"/>
          <Column id="applpRrno" type="STRING" size="256" description="생년월일"/>
          <Column id="flNm" type="STRING" size="256" description="성명"/>
          <Column id="tchQlfLCtrNo" type="STRING" size="256" description="자격증번호"/>
          <Column id="cddcCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="tchQlfVrfcYn">N</Col>
            <Col id="applpRrno">720421</Col>
            <Col id="flNm">이상경</Col>
            <Col id="tchQlfLCtrNo">0000001</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsQlfAsortCd" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="FirstCode" type="STRING" size="30" value="SEL" datapath=""/>
          <ConstColumn id="ClfCdValue" type="STRING" size="30" value="QLF_ASORT_CD"/>
          <ConstColumn id="FilterExpr" type="STRING" size="30" value=""/>
          <ConstColumn id="UnyCdGrpId" type="STRING" size="30" value=""/>
          <ConstColumn id="BfrClfCdValue" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd1Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd2Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd3Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd4Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd5Value" type="STRING" size="30" value=""/>
          <Column id="pgeId" type="STRING" size="256"/>
          <Column id="clfCdValue" type="STRING" size="30"/>
          <Column id="clfCdValueNm" type="STRING" size="120"/>
          <Column id="clfCdUseYn" type="STRING" size="150"/>
          <Column id="unyCdValue" type="STRING" size="10"/>
          <Column id="unyCdValueNm" type="STRING" size="30"/>
          <Column id="userDfnCd1Value" type="STRING" size="100"/>
          <Column id="userDfnCd2Value" type="STRING" size="100"/>
          <Column id="userDfnCd3Value" type="STRING" size="100"/>
          <Column id="userDfnCd4Value" type="STRING" size="100"/>
          <Column id="userDfnCd5Value" type="STRING" size="100"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsTchQlfIndctSbjtCd" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="FirstCode" type="STRING" size="30" value="SEL" datapath=""/>
          <ConstColumn id="ClfCdValue" type="STRING" size="30" value="INDCT_SBJT_CD"/>
          <ConstColumn id="FilterExpr" type="STRING" size="30" value=""/>
          <ConstColumn id="UnyCdGrpId" type="STRING" size="30" value=""/>
          <ConstColumn id="BfrClfCdValue" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd1Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd2Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd3Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd4Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd5Value" type="STRING" size="30" value=""/>
          <Column id="pgeId" type="STRING" size="256"/>
          <Column id="clfCdValue" type="STRING" size="30"/>
          <Column id="clfCdValueNm" type="STRING" size="120"/>
          <Column id="clfCdUseYn" type="STRING" size="150"/>
          <Column id="unyCdValue" type="STRING" size="10"/>
