          <Column id="userDfnCd1Value" type="STRING" size="100"/>
          <Column id="userDfnCd2Value" type="STRING" size="100"/>
          <Column id="userDfnCd3Value" type="STRING" size="100"/>
          <Column id="userDfnCd4Value" type="STRING" size="100"/>
          <Column id="userDfnCd5Value" type="STRING" size="100"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsValidation" useclientlayout="true">
        <ColumnInfo>
          <Column id="code" type="STRING" size="256"/>
          <Column id="name" type="STRING" size="256" description="일련번호"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="code">edtQlflNo</Col>
            <Col id="name">자격증코드</Col>
          </Row>
          <Row>
            <Col id="code">cboQlfAsortCd</Col>
            <Col id="name">자격종별</Col>
          </Row>
          <Row>
            <Col id="code">calIssuYmd</Col>
            <Col id="name">발급일자</Col>
          </Row>
          <Row>
            <Col id="code">cboTchQlfIndctSbjtCd</Col>
            <Col id="name">표시과목</Col>
          </Row>
          <Row>
            <Col id="code">edtIssuInstNm</Col>
            <Col id="name">발급기관</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-교원임용(중등)-경력합산신청-자격면허정보 팝업
*  @MenuPath    pa_ore_oew_rm
*  @FileName 	pa_ore_oewrm13_p05.xfdl
*  @Creator 	shhan
*  @CreateDate 	2022.09.13
*  @Desction    온라인통합채용-교원임용(중등)-경력합산신청-자격면허정보 팝업
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.09.13    	shhan	 	        최초 생성 
*  2022.12.12       최정민 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitPopup(this);

	// 공통코드
	// dsQlfAsortCd : 교원자격종별구분코드|dsTchQlfIndctSbjtCd : 표시과목 
	this.smfCodeList("code", [this.dsQlfAsortCd, this.dsTchQlfIndctSbjtCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		})		
		.run();

};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid, errcd, errmsg){

};

// 발급기관명 찾기 콜백
this.fnCommpopTchQlfInstCallback = function(e)
{
	this.dsMain.setColumn(0, "issuInstNm", e.row.unyCdValueNm);
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// 등록 버튼 
this.divContent02_btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//필수 값 체크 
	var components = this.divContent00.form.components;
	for(var i=0; i < components.length; i++){
		if(components[i].cssclass == "essential"){
			if(this.smfIsNull(components[i].value)){
				components[i].setFocus();
				var message =  this.dsValidation.lookup( "code" , components[i].name , "name" );
				this.smfAlert('CM006', [message], "" ); 
				return;	
			}
		}
	}
	
	// 입력값 부모창 전달
	this.smfSendResponseToOpener({
		dsMainP  : this.dsMain
	});
	this.close(true);
};

// 취소 버튼 
this.divContent02_btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};

//발급기관 찾기 
this.divContent00_btnContent00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: this.fnCommpopTchQlfInstCallback, // 콜백함수 지정
		sender: obj, // sender 지정
		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: 'search',
		},
	};

	// 모달팝업 실행
	this.smfDialog("_auto", "pa_ore_oew_co::ore_oewco00_p00.xfdl", popupParams);
};

// 발급날짜 체크 
this.dsMain_cancolumnchange = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	if(e.columnid == "issuYmd"){
		if(e.newvalue >= this.smfToday()){
			this.smfAlert('미래일자를 입력할 수 없습니다.');
			return false;
		}
	}
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="divContent00.form.cboQlfAsortCd" propid="value" datasetid="dsMain" columnid="qlfAsortCd"/>
      <BindItem id="item1" compid="divContent00.form.calIssuYmd" propid="value" datasetid="dsMain" columnid="issuYmd"/>
      <BindItem id="item2" compid="divContent00.form.cboTchQlfIndctSbjtCd" propid="value" datasetid="dsMain" columnid="tchQlfIndctSbjtCd"/>
      <BindItem id="item3" compid="divContent00.form.edtIssuInstNm" propid="value" datasetid="dsMain" columnid="issuInstNm"/>
      <BindItem id="item4" compid="divContent00.form.edtQlflNo" propid="value" datasetid="dsMain" columnid="qlflNo"/>
      <BindItem id="item5" compid="divContent00.form.edtQlflNo" propid="accessibilityaction" datasetid="dsMain" columnid="qlflNo"/>
    </Bind>
  </Form>
</FDL>
