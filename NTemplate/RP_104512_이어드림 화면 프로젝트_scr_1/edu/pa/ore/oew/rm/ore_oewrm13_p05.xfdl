<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="formMain" width="800" height="240" titletext="경력합산신청-자격면허정보 팝업" onload="formMain_onload">
    <Layouts>
      <Layout height="240" width="800" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divContent00" taborder="1" left="20" height="158" top="0" text="" cssclass="div_WF_Detail" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staContent00" taborder="0" left="120" height="42" cssclass="sta_WF_Input02Top" top="20" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staContent00_00" taborder="1" left="120" height="42" cssclass="sta_WF_Input02" top="61" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staContent00_00_00" taborder="2" left="120" height="42" cssclass="sta_WF_Input02" top="101" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staContent02" taborder="3" left="0" width="120" height="42" cssclass="sta_WF_Input01Top" text="자격증코드" top="20" onclick="Static45_onclick" initvalueid="ivStcEssential"/>
