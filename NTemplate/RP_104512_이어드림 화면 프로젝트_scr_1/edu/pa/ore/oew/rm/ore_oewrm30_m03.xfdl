    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-교육공무직-마이페이지-지원서반환
*  @MenuPath    pa_ore_oew_rm
*  @FileName 	pa_ore_oewrm30_m03.xfdl
*  @Creator 	
*  @CreateDate 	2022.09.13
*  @Desction    온라인통합채용-교육공무직-마이페이지-지원서반환
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.09.01    		 	        최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs"
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 휴대전화번호 필수 로그인 세션 체크
	var logInChkParam = {
		 redirectUrl : 'pa_ore_oew_rm::ore_oewrm30_m03.xfdl' // 현재 PAGE URL
		, redirectMenuId : '4004' // 교육공무직 지원서반환 메뉴 ID
	};
	
	// 휴대전화번호 세션 없을 시 로그인 페이지이동
	this.isEssenMblTelnoLogin(logInChkParam);
	
	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);
	
	//파일업로드
	this.divCont.form.divAttach.UPLOAD_UploadComplete = this.fnFileUploadCompleteCallback;
	this.divCont.form.divAttach.UPLOAD_OnError        = this.fnFileUploadErrorCallback;
	this.divCont.form.divAttach.UPLOAD_AfterAddFile   = this.fnFileUploadChangeCallback;     
	this.divCont.form.divAttach.UPLOAD_Form           = this;
	
	// 선택 시도교육청코드
	var sCddcCd = this.smfGetCddcCode();
	// 시도교육청 앞 3자리 = 시도교육청 구분코드
	this.dsSearch.setColumn(0, "cddcScCd", sCddcCd.slice(0,3));
	//  본인인증
	var applpFlnm = this.smfGetSessionValue('userNm');
	var applpBrdt = this.smfGetSessionValue('brdt');
	if(this.smfIsNull(applpBrdt)){
		 applpBrdt = this.applpRrnoToBrdt(nexacro.base64Decode(this.smfGetSessionValue('userRrno')));
	}
	this.dsSearch.setColumn(0,"applpFlnm", applpFlnm);
	this.dsSearch.setColumn(0,"applpBrdt", applpBrdt);
	this.dsSearch.setColumn(0,"mblTelno" , this.smfGetSessionValue('mblTelNo'));
	this.dsSearch.setColumn(0,"pafrUserId" , this.smfGetSessionValue('userDtcNo'));
	//  메세지1
	this.divSummary.form.divContent00.form.staContent00.set_text(applpFlnm + "(" +applpBrdt +")님.");
	
	// 내 지원서 목록
	this.fnSearchRcptList(true);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid, errcd, errmsg){

};

// 파일 업로드 성공 콜백
this.fnFileUploadCompleteCallback = function(obj, paramObj, objResultDataset)
{
	this.divCont.form.divAttach.form.fnSetUploadCompleteState(obj,paramObj);
	this.dsMain.setColumn(0, "fileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
};

// 파일 업로드 실패 콜백
this.fnFileUploadErrorCallback = function(obj, paramObj)
{
	//this.smfAlert('파일 업로드에 실패 하였습니다.');
};

// 파일 업로드 변경 콜백
this.fnFileUploadChangeCallback = function(obj, paramObj, sCustomValue, sFileName, nFileSize)
{
	this.divCont.form.divAttach.form.fnFileUpload();		
};	

//우편번호 검색 콜백 
this.fnCommpopRdnZip = function(e, sender){
	this.dsMain.setColumn(0, "dmclZip", e.zipCd);
	this.dsMain.setColumn(0, "dmclZipAddr" , e.roadNmAddr);
	this.dsMain.setColumn(0, "dmclZipDaddr", e.roadNmDtl);
};

this.fnCommpop = function(e, sender){
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
// 지원서 목록 검색
this.fnSearchRcptList = function(popYn)
{
	// 지원서목록조회
	this.smfSearchService('listRcpt') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;

			this.dsMain.setColumn(0,"applpFlnm", this.dsSearch.getColumn(0,"applpFlnm"));
			this.dsMain.setColumn(0,"applpBrdt", this.dsSearch.getColumn(0,"applpBrdt"));
			
			if(popYn){
				//팝업호출
				var popupParams = {
					callback: this.fnCommpop, // 콜백함수 지정
					sender: obj, // sender 지정
					// 팝업 전달 파라메터 지정
					params: {
						procType: 'none',
					},
					titlebar : false
				};
				// 모달팝업 실행
				this.smfDialog("_auto", "pa_ore_oew_rm::ore_oewrm30_p00.xfdl", popupParams);
			}else{
			
				this.dsMain.setColumn(0,"dmclZip","");
				this.dsMain.setColumn(0,"dmclZipAddr","");
				this.dsMain.setColumn(0,"dmclZipDaddr","");
				this.dsMain.setColumn(0,"mblTelno1","");
				this.dsMain.setColumn(0,"mblTelno2","");
				this.dsMain.setColumn(0,"mblTelno3","");
				this.dsMain.setColumn(0,"fileRefrnId","");
				this.divCont.form.divAttach.form.fnResetUpload();
				this.divCont.set_enable(false);
			}
	});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

// 지원서 반환 신청 버튼 클릭
this.btnApply_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//필수 값 체크 
	
	//주소 & 휴대전화
	if(this.smfIsNull(this.dsMain.getColumn(0,"dmclZipAddr"))){
		this.smfAlert('CM006', ["주소"], this.fnMessageCallback ); 
		return false;	
	}
	if(this.smfIsNull(this.dsMain.getColumn(0,"dmclZipDaddr"))){
		this.divCont.form.edtAddrDtl.setFocus();
		this.smfAlert('CM006', ["주소"], this.fnMessageCallback ); 
		return false;	
	}	
	if(this.smfIsNull(this.dsMain.getColumn(0,"mblTelno1"))){
		this.divCont.form.edtMblNo00.setFocus();
		this.smfAlert('CM006', ["휴대전화"], this.fnMessageCallback ); 
		return false;	
	}	
	if(this.smfIsNull(this.dsMain.getColumn(0,"mblTelno2"))){
		this.divCont.form.edtMblNo01.setFocus();
		this.smfAlert('CM006', ["휴대전화"], this.fnMessageCallback ); 
		return false;	
	}		
	if(this.smfIsNull(this.dsMain.getColumn(0,"mblTelno3"))){
		this.divCont.form.edtMblNo02.setFocus();
		this.smfAlert('CM006', ["휴대전화"], this.fnMessageCallback ); 
		return false;	
	}		
	
	// 연락처
	var mblTelNo = this.dsMain.getColumn(0, "mblTelno1")+'-'+this.dsMain.getColumn(0, "mblTelno2")+'-'+this.dsMain.getColumn(0, "mblTelno3");
	this.dsMain.setColumn(0, "mblTelNo", mblTelNo);	
	this.dsMain.setColumn(0, "mblTelno", mblTelNo);	

	// 저장
	this.smfSaveService("saveAppoRt")
		.showConfirm(false)
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors){
				return;
			}
			// 저장처리
			this.smfAlert("접수되었습니다. 이후 진행 상황은 담당자에 문의 바랍니다.");
			// 내 지원서 목록
			this.fnSearchRcptList(false);
	});	
	
};

// 우편번호 검색 
this.divBasicInfo_btnPostCode_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//팝업호출
	var popupParams = {
		callback: this.fnCommpopRdnZip, // 콜백함수 지정
		sender: obj, // sender 지정
		// 팝업 전달 파라메터 지정
		params: {
			procType: 'search'
		}
	};
	// 모달팝업 실행
	this.smfDialog("_auto", "commpop::commpop_rdn_zip.xfdl", popupParams);
};

// 응시시험 변경 시
this.divAppoExam_cboAppoExm_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	
	// 주소& 휴대폰번호 세팅
	var nRcptNo = e.postvalue;
	
	// 지원서 반환 가능 여부 조회 
	this.dsSearch.setColumn(0,"empmnExamId", this.dsResultRcpt.lookup("rcptNo",nRcptNo,"appoExamId"));
	this.dsSearch.setColumn(0,"dstrtCd", this.dsResultRcpt.lookup("rcptNo",nRcptNo,"dstrtCd"));
	this.dsSearch.setColumn(0,"eduPubsvCtpvOcptCd", this.dsResultRcpt.lookup("rcptNo",nRcptNo,"eduPubsvCtpvOcptCd"));
	this.dsSearch.setColumn(0,"orgCd", this.smfGetCddcCode());
	this.dsSearch.setColumn(0, "cddcCd", this.smfGetCddcCode());
	// 지원서목록조회
	this.smfSearchService('listAppoCndtRegCeck') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			var apfGvbkYn = this.dsResult.getColumn(0,"apfGvbkYn");
			if(apfGvbkYn == "N"){
				this.dsMain.clearData();
				this.divCont.set_enable(false);
				this.smfAlert("지원서 반환기간이 아닙니다.");
			}else{
				this.dsMain.clearData();
				this.dsMain.addRow();
				this.dsMain.setColumn(0, "rcptNo"        , nRcptNo);
				this.dsMain.setColumn(0, "empmnExamId"   , this.dsResultRcpt.lookup("rcptNo",nRcptNo,"appoExamId"));
				this.dsMain.setColumn(0, "applpFlnm"     , this.dsResultRcpt.lookup("rcptNo",nRcptNo,"applpFlnm"));
				this.dsMain.setColumn(0, "applpBrdt"     , this.dsResultRcpt.lookup("rcptNo",nRcptNo,"applpBrdt"));
				this.dsMain.setColumn(0, "mblTelno"      , this.dsResultRcpt.lookup("rcptNo",nRcptNo,"mblTelno"));
				this.dsMain.setColumn(0, "dmclZip"       , this.dsResultRcpt.lookup("rcptNo",nRcptNo,"dmclZip"));
				this.dsMain.setColumn(0, "dmclZipAddr"   , this.dsResultRcpt.lookup("rcptNo",nRcptNo,"dmclZipAddr"));
				this.dsMain.setColumn(0, "dmclZipDaddr"  , this.dsResultRcpt.lookup("rcptNo",nRcptNo,"dmclZipDaddr"));
				
				// 연락처
				var mblTelno = this.dsMain.getColumn(0, "mblTelno").split("-");

				this.dsMain.setColumn(0, "mblTelno1", mblTelno[0]);	
				this.dsMain.setColumn(0, "mblTelno2", mblTelno[1]);	
				this.dsMain.setColumn(0, "mblTelno3", mblTelno[2]);	
				this.dsMain.setColumn(0, "cddcCd", this.smfGetCddcCode());
				
				this.divCont.set_enable(true);
			}
			
	});
};
]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listRcpt</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResultRcpt=dsResultRcpt</Col>
            <Col id="url">ore_oew_rm30_002.do</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="id">saveAppoRt</Col>
            <Col id="inDatasets">dsMain=dsMain</Col>
            <Col id="outDatasets"/>
            <Col id="url">ore_oew_rm30_005.do</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="id">listAppoCndtRegCeck</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResult=dsResult</Col>
            <Col id="url">ore_oew_rm30_006.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="false" updatecontrol="false">
        <ColumnInfo>
          <Column id="cddcScCd" type="STRING" size="256" description="접속시도교육청 구분코드"/>
