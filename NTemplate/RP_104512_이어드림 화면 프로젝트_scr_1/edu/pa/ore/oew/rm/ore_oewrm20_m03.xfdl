    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-지방공무원-마이페이지-성적조회
*  @MenuPath    pa_ore_oew_rm
*  @FileName 	pa_ore_oewrm20_m03.xfdl
*  @Creator 	최재형
*  @CreateDate 	2022.11.28
*  @Desction    온라인통합채용-지방공무원-마이페이지-성적조회
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.11.28		최재형				최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.applpRrno;
this.applpFlnm;
this.applpBrdt;

this.divScreTlt; // 시험성적 DIV 높이
this.divScreTotalHeight; // 총점 DIV 높이
this.divScreRankHeight; // 순위 DIV 높이
this.divScreSbjtHeight; // 과목성적 DIV 높이
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 로그인 세션 체크 
	//this.isOreLogin();
	
	// 본인인증 세션취득
	this.applpRrno = nexacro.base64Decode(this.smfGetSessionValue('userRrno'));
	this.applpFlnm = this.smfGetSessionValue('userNm');
	this.applpBrdt = this.applpRrno.slice(0,6);

	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);
	
	// 지원자정보영역 초기화
	this.divSummary.form.divContent00.form.staContent00.set_text("");
	this.divSummary.form.divContent00.form.staContent01.set_text("");
	
	// 컨텐츠높이
	this.divScreTltHeight  = this.divScreTlt.height;
	this.divScreTotalHeight = this.divScreTotal.height;
	this.divScreRankHeight =this.divScreRank.height;
	this.divScreSbjtHeight =this.divScreSbjt.height;
	
	// 내 지원서 목록
	this.fnSearchRcptList();

};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid, errcd, errmsg){

}

this.fnScrePopupCallback = function(e, sender){
	// 업무콜백 처리
	//this.smfAlert("응답결과 ==>"+e.row.Column0+", "+e.row.Column1+", "+e.row.Column2+", "+e.row.Column3);
};
 /**
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 지원서 목록 검색
 */
this.fnSearchRcptList = function(obj, e)
{
	// 검색조건 초기화
	this.dsSearch.clearData();
	this.dsSearch.addRow();
	//  주민번호 : 본인인증 세션취득
	this.dsSearch.setColumn(0, "applpRrno", this.applpRrno);
	// 시도교육청 앞 3자리 = 시도교육청 구분코드
	this.dsSearch.setColumn(0, "cddcScCd", this.smfGetCddcCode().slice(0,3));
	
	// 결과 초기화
	this.dsResultRcpt.clearData();
	this.dsResultRcpt.addRow();
	// 지원서목록조회
	this.smfSearchService('listRcpt') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			// 페이지 VIEW SET
			this.initPage();
	});
}

/**
 * 성적 조회
 */
this.fnSearchScre = function(obj, e)
{
	// 성적 조회결과 리셋
	this.hideScreDiv();
	
	// 성적조회
	this.smfSearchService('selectScre') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			//console.log(this.dsResultSfc.saveJSON());
			//console.log(this.dsResultScre.saveJSON());
			//console.log(this.dsResultScreSbjt.saveJSON());
			// 성적 조회 결과 표시
			this.screResultView();
	});
}

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 this.initPage = function()
 {
	// 서머리영역 메세지1
	this.divSummary.form.divContent00.form.staContent00.set_text(this.applpFlnm + "(" +this.applpBrdt +")님.");
	this.divSummary.form.divContent00.form.staContent01.set_text("응시 시험을 선택 후 성적 조회를 해주세요.");
	
 	// 지원서 수
	var rcptCnt =  this.dsResultRcpt.getRowCount();
	if(rcptCnt <1){
		// 콤보 비활성
		this.divAppoExam.form.divContent00.form.cboAppoExm.set_enable(false);
		this.divAppoExam.form.divContent00.form.btnSearchScre.set_enable(false);
		
		// 서머리영역 메세지2
		this.divSummary.form.divContent00.form.staContent01.set_text(this.smfGetCddcName()+" 임용시험에 응시 내역이 없습니다.");
	}
 }
 
 /**
 * 성적영역 비표시
 */
 this.hideScreDiv = function()
 {
	// 제목, 성적이의신청 버튼 비표시
 	this.divScreTlt.setOffsetHeight(0);
	this.divScreTlt.set_visible(false);
	this.divScreTlt.form.btnObjcAply.set_visible(false);
	// 총점 비표시
	this.divScreTotal.setOffsetHeight(0);
	this.divScreTotal.set_visible(false);
	// 순위 비표시
	this.divScreRank.setOffsetHeight(0);
	this.divScreRank.set_visible(false);
	// 과목별성적비표시
	this.divScreSbjt.setOffsetHeight(0);
	this.divScreSbjt.set_visible(false);
	// 전체영역  RESET
	this.smfResetScroll(this);
 }
 
  /**
 * 성적조회 결과 표시
 */
 this.screResultView = function()
 {
	// 조회 결과가 없을경우
	var resSfcCnt = this.dsResultSfc.getRowCount();
	if(resSfcCnt < 1){
		this.smfAlert("성적을 조회 할 수 없습니다.");
		return;
	}

	// 무효(마감,삭제)한 임용시험 
	var unaAppoExamYn = this.dsResultSfc.getColumn(0, 'unaAppoExamYn');
	if(unaAppoExamYn === "Y"){
		this.smfAlert('진행중인 임용시험이 아닙니다.');
		return;
	}
	
	// 발표 차수
	var sfcDgrNo = this.dsResultSfc.getColumn(0, 'sfcDgrNo');
	// 사전 성적조회 기간 여부
	var screBefrRlsYn = this.dsResultSfc.getColumn(0, 'screBefrRlsYn');
	// 성적이의 신청 기간
	var screObjcYn = this.dsResultSfc.getColumn(0, 'screObjcYn');
	// 1차 필기 합격자 발표 기간 여부
	var sfc1AnnPrdYn = this.dsResultSfc.getColumn(0, 'sfc1AnnPrdYn');
	// 2차 최종 합격자 발표 기간 여부
	var sfc2AnnPrdYn = this.dsResultSfc.getColumn(0, 'sfc2AnnPrdYn');
	
	

	// 성적 조회기간 아님
	if(screBefrRlsYn === "N" && sfc1AnnPrdYn === "N" && sfc2AnnPrdYn === "N"){
		this.smfAlert('성적을 조회 할 수 없습니다.');
		return;
	}
	
	// 평균점수 
	var total = Number(this.dsResultScre.getColumn(0, 'examTotlScre'));
	var avgScore = total / this.dsResultScreSbjt.getRowCount();
	var avgResult = nexacro.round(avgScore, 2); // 소수점 3자리 반올림1
	this.divScreTotal.form.staScreAvg.set_text(avgResult.toFixed(2)); // 소수점 2자리 fixed

	var isTltViewYn = "N"; // 제목 표시여부
	var isScreObjcViewYn = "N" //성적이의 신청 버튼 표시 여부
	var isScreTotalViewYn = "N"; // 총점 표시여부
	var isScreSbjtViewYn = "N"; // 과목별성적 표시여부
	var isScreRankViewYn = "N"; // 순위 표시여부
	
	/*** [사전차수] 사전성적조회 ****/
	if(sfcDgrNo === "-1" &&  screBefrRlsYn === "Y"){
		var screBefrCd1Yn = this.dsResultSfc.getColumn(0, 'screBefrCd1Yn');// 사전성적조회 항목 : 총점 여부
		var screBefrCd2Yn = this.dsResultSfc.getColumn(0, 'screBefrCd2Yn');// 사전성적조회 항목 : 과목별 성적 여부
		var screBefrCd3Yn = this.dsResultSfc.getColumn(0, 'screBefrCd3Yn');// 사전성적조회 항목 : 가산점 성적 여부
		// 성적 조회 항목 설정이 없을경우
		if(screBefrCd1Yn ==="N" && screBefrCd2Yn ==="N"){
			this.smfAlert('성적을 조회 할 수 없습니다.');
			return;
		}
		// 제목 , 성적이의 신청 표시여부
		isTltViewYn = "Y";
		
		// 성적이의 신청 기간 여부 : 사전성적 조회 기간에만
		if(screObjcYn === "Y" ){
			isScreObjcViewYn = 'Y'
		}
		
		// 총점 표시여부
		if(screBefrCd1Yn === "Y"){
			isScreTotalViewYn = "Y"
		}
		// 과목별 성적 표시여부
		if(screBefrCd2Yn === "Y"){
			isScreSbjtViewYn = "Y"
			// 가산점 표시 설정이 없을경우
			if(screBefrCd3Yn != "Y"){
				// 가산점 비표시
				for(var i=0 ; i<this.dsResultScreSbjt.rowcount ; i++){
					this.dsResultScreSbjt.setColumn(i,'aplemSbjtAdtnScr', '-');
					 // 환산점수 = 점수
					 this.dsResultScreSbjt.setColumn(i, 'aplemSbjtCnvlScr', this.dsResultScreSbjt.getColumn(i, 'aplemSbjtScr'));
				}
			}
		}
		
		// 사전성적공개 : 가산점  표시 설정이 없을경우 처리 (총성적, 평균, 환산점 치환)
		if(screBefrCd3Yn != "Y"){
			// 총성적 재설정 : 총석적 = 필기시험성적
			this.divScreTotal.form.staScreTotal.set_text(this.divScreTotal.form.staScreWtg.text);
			
			// 평균 재계산 : 필기시험성적으로 평균 재계산 사용금지
			var reTotal = Number(this.dsResultScre.getColumn(0, 'wtg1TmeScre'));
			var reAvgScore = reTotal / this.dsResultScreSbjt.getRowCount();
			var reAvgResult = nexacro.round(reAvgScore, 2); // 소수점 3자리 반올림1
			this.divScreTotal.form.staScreAvg.set_text(reAvgResult.toFixed(2)); // 소수점 2자리 fixed
			
			// 과락 미반영 메세지 비표시
			this.divScreTlt.form.staScreNoti.set_visible(false);
			this.divScreTotal.form.staScreAdtn.set_text('-  [ 가산점이 적용되지 않은 원점수만 공개 ]');
		}else{
			this.divScreTlt.form.staScreNoti.set_visible(true);
		}
		
		// 사전성적은 순위 상시 미표시
	}
	
	// [1차수] 필기 합격발표기간 
	if(sfcDgrNo === "1" &&  sfc1AnnPrdYn === "Y"){
		var sfc1PassYn = this.dsResultSfc.getColumn(0, 'sfc1PassYn'); // 1차 합격자 여부
		var screSfc1Cd1Yn = this.dsResultSfc.getColumn(0, 'screSfc1Cd1Yn');// 1차 필기 성적조회 항목 : 총점 여부
		var screSfc1Cd2Yn = this.dsResultSfc.getColumn(0, 'screSfc1Cd2Yn');// 1차 필기 성적조회 항목 : 과목별성적 여부
		var screSfc1Cd3Yn = this.dsResultSfc.getColumn(0, 'screSfc1Cd3Yn');// 1차 필기 성적조회 항목 : 순위 여부
		var screSfc1Cd4Yn = this.dsResultSfc.getColumn(0, 'screSfc1Cd4Yn');// 1차 필기 성적조회 항목 : 1차발표 합격자 예외 여부
		
		// 성적 조회 항목 설정이 없을경우
		if(screSfc1Cd1Yn === "N" && screSfc1Cd2Yn === "N" && screSfc1Cd3Yn ==="N"){
			this.smfAlert('성적을 조회 할 수 없습니다.');
			return;
		}
		
		//	1차 필기 합격자 성적 조회 예외가 아닌 경우만
		if( !(screSfc1Cd4Yn === "Y" && sfc1PassYn == "Y")){
			// 제목+ 성적 이의 신청 영역 표시 여부
			isTltViewYn = "Y";
			// 총점 표시여부
			if(screSfc1Cd1Yn === "Y"){
				isScreTotalViewYn = "Y";
			}
			// 과목별 성적 표시여부
			if(screSfc1Cd2Yn === "Y"){
				isScreSbjtViewYn = "Y";
			}
			// 순위 표시여부 : 합격자만 순위 표시
			if(screSfc1Cd3Yn === "Y" && sfc1PassYn =="Y"){
				isScreRankViewYn = "Y";
			}
		}else{
			this.smfAlert('성적 공개 여부는 시도교육청별 채용절차에 따라 상이합니다. \n합격여부는 합격조회 메뉴에서 확인하시기 바랍니다.');
			return;
		}
	}
	
	// [2차수] 최종 합격발표기간 
	if(sfcDgrNo === "2" &&  sfc2AnnPrdYn === "Y"){
		var sfc2PassYn = this.dsResultSfc.getColumn(0, 'sfc2PassYn'); // 2차 합격자 여부
		var screSfc2Cd1Yn = this.dsResultSfc.getColumn(0, 'screSfc2Cd1Yn');// 2차 최종 성적조회 항목 : 총점 여부
		var screSfc2Cd2Yn = this.dsResultSfc.getColumn(0, 'screSfc2Cd2Yn');// 2차 최종 성적조회 항목 : 과목별성적 여부
		var screSfc2Cd3Yn = this.dsResultSfc.getColumn(0, 'screSfc2Cd3Yn');// 2차 최종 성적조회 항목 : 순위 여부
		var screSfc2Cd4Yn = this.dsResultSfc.getColumn(0, 'screSfc2Cd4Yn');// 2차 최종 성적조회 항목 : 2차발표 합격자 예외 여부
		// 성적 조회 항목 설정이 없을경우
		if(screSfc2Cd1Yn === "N" && screSfc2Cd2Yn === "N" && screSfc2Cd3Yn ==="N"){
			this.smfAlert('성적을 조회 할 수 없습니다.');
			return;
		}
		
		//	2차 최종 합격자 성적 조회 예외가 아닌 경우만
		if( !(screSfc2Cd4Yn ==="Y" && sfc2PassYn === "Y")){
			// 제목+ 성적 이의 신청 영역 표시 여부
			isTltViewYn = "Y";
			// 총점 표시여부
			if(screSfc2Cd1Yn === "Y"){
				isScreTotalViewYn = "Y";
			}
			// 과목별 성적 표시여부
			if(screSfc2Cd2Yn === "Y"){
				isScreSbjtViewYn = "Y";
			}
			// 순위 표시여부 : 합격자만 순위 표시 여부
			if(screSfc2Cd3Yn === "Y" && sfc2PassYn =="Y"){
				isScreRankViewYn = "Y";
			}
		}else{
			// 2차 합격자 , 성적 표시 예외의 경우
			if(screSfc2Cd4Yn ==="Y" && sfc2PassYn === "Y"){
				this.smfAlert('성적 공개 여부는 시도교육청별 채용절차에 따라 상이합니다. \n합격여부는 합격조회 메뉴에서 확인하시기 바랍니다!');
			}else{
				this.smfAlert('성적을 조회 할 수 없습니다.');
			}
			return;
		}
	}
	
	// 제목+ 성적 이의 신청 영역 표시
	if(isTltViewYn === "Y"){
		this.divScreTlt.setOffsetHeight(this.divScreTltHeight);
		this.divScreTlt.set_visible(true);
		// 성적이의 신청은 사전 성적 조회 시에만
		if(sfcDgrNo === "-1" && isScreObjcViewYn === "Y"){
			this.divScreTlt.form.btnObjcAply.set_visible(true);
		}
	}
	
	// 총점 영역 표시
	if(isScreTotalViewYn === "Y"){
		this.divScreTotal.setOffsetHeight(this.divScreTotalHeight);
		this.divScreTotal.set_visible(true);
	}
	// 과목별 성적 영역 표시
	if(isScreSbjtViewYn === "Y"){
		var height =this.divScreSbjtHeight;
		// 총점 N  순위 N 설정시 과목별 성절 위치조정
		if(isScreTotalViewYn === "N" && isScreRankViewYn === "N"){
			this.divScreSbjt.setOffsetHeight(height);
			this.divScreSbjt.form.grdScre.set_top(0);
		}else{
			this.divScreSbjt.form.grdScre.set_top(40);
			this.divScreSbjt.setOffsetHeight(height);
		}
		
		//this.divScreSbjt.setOffsetHeight(height);
		this.divScreSbjt.set_visible(true);
	}
	// 순위 영역 표시
	if(isScreRankViewYn === "Y"){
		this.divScreRank.setOffsetHeight(this.divScreRankHeight);
		this.divScreRank.set_visible(true);
	}

	// 전체영역  RESET
	this.smfResetScroll(this);
		
 }
 
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

/**
* 성적이의신청 팝업
**/
this.divScreInfo_btnObjcAply_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
		// 팝업을 동작에 필요한 파라메터 지정
		var popupParams = {
			callback: this.fnScrePopupCallback, // 콜백함수 지정
			sender: obj, // sender 지정

			// 팝업 전달 파라메터 지정
			params: {
				// 처리타입 지정
				procType: "none",
				appoExamId: this.dsResultSfc.getColumn(0, 'appoExamId'), 
				rcptNo: this.dsResultSfc.getColumn(0, 'rcptNo'), 
				applpRrno: this.applpRrno, 
				applpFlnm: this.applpFlnm, 
			}
		};
			this.smfDialog("_auto", "pa_ore_oew_rm::ore_oewrm20_p01.xfdl", popupParams);
};


/**
* 성적조회
**/
this.divAppoExam_divContent00_btnSearchScre_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 선택한 응시원서 접수번호
	var sRcptNo = this.divAppoExam.form.divContent00.form.cboAppoExm.value;
	if(!sRcptNo){
		this.divAppoExam.form.divContent00.form.cboAppoExm.setFocus();
		this.smfAlert("응시 시험을 선택 해주세요.");
		return;
	}
	
	for(var i = 0 ; i < this.dsResultRcpt.rowcount ; i++){
		var rcptNo = this.dsResultRcpt.getColumn(i, 'rcptNo');
		if(sRcptNo === rcptNo){
			this.dsSearch.clearData();
			this.dsSearch.addRow();
			// 시도 교육청 구분 코드
			this.dsSearch.setColumn(0, 'cddcScCd',this.smfGetCddcCode().slice(0,3));
			// 임용시험아이디
			this.dsSearch.setColumn(0, 'appoExamId', this.dsResultRcpt.getColumn(i, 'appoExamId'));
			// 직류코드
			this.dsSearch.setColumn(0, 'ocptyCd', this.dsResultRcpt.getColumn(i, 'ocptyCd'));
			// 직급코드
			this.dsSearch.setColumn(0, 'jbgdCd',  this.dsResultRcpt.getColumn(i, 'jbgdCd'));
			// 접수번호
			this.dsSearch.setColumn(0, 'rcptNo', sRcptNo);
			
			// 선택 임용시험 정보 표시
			this.divSummary.form.divContent00.form.staContent01.set_text( this.dsResultRcpt.getColumn(i, 'appoExamNmSum'));
			
			break;
		}
	}
	// 성적조회
	this.fnSearchScre();
};
]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listRcpt</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResultRcpt=dsResultRcpt</Col>
            <Col id="url">ore_oew_rm20_m03_000.do</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="id">selectScre</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResultSfc=dsResultSfc dsResultScre=dsResultScre dsResultScreSbjt=dsResultScreSbjt</Col>
            <Col id="url">ore_oew_rm20_m03_001.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="false" updatecontrol="false">
        <ColumnInfo>
          <Column id="cddcScCd" type="STRING" size="256" description="접속시도교육청 구분코드"/>
          <Column id="applpRrno" type="STRING" size="256" description="응시자주민번호"/>
          <Column id="appoExamId" type="STRING" size="256" description="임용시험아이디"/>
          <Column id="ocptyCd" type="STRING" size="256" description="직류코드"/>
          <Column id="jbgdCd" type="STRING" size="256" description="직급코드"/>
          <Column id="rcptNo" type="STRING" size="256" description="접수번호"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsResultRcpt" useclientlayout="true">
        <ColumnInfo>
          <Column id="rcptNo" type="STRING" size="256" description="접수번호"/>
          <Column id="cddcScCd" type="STRING" size="256" description="시도교육청구분코드"/>
          <Column id="cddcScNm" type="STRING" size="256" description="강원도교육청"/>
          <Column id="appoExamId" type="STRING" size="256" description="임용시험ID"/>
          <Column id="appoExamNm" type="STRING" size="256" description="임용시험명"/>
          <Column id="appoExamNmSum" type="STRING" size="256"/>
          <Column id="appoExamYr" type="STRING" size="256"/>
          <Column id="ocptyCd" type="STRING" size="256" description="직류코드"/>
          <Column id="ocptyNm" type="STRING" size="256" description="직류명"/>
          <Column id="jblnCd" type="STRING" size="256" description="직렬코드"/>
          <Column id="jblnNm" type="STRING" size="256" description="직렬명"/>
          <Column id="jbgdCd" type="STRING" size="256" description="직급코드"/>
          <Column id="jbgdNm" type="STRING" size="256" description="직급명"/>
          <Column id="rksCd" type="STRING" size="256" description="계급코드"/>
          <Column id="rksNm" type="STRING" size="256" description="계급명"/>
          <Column id="applpFlnm" type="STRING" size="256" description="응시자성명"/>
          <Column id="applpRrno" type="STRING" size="14" description="응시자주민등록번호"/>
          <Column id="sxdsCd" type="STRING" size="256" description="성별코드"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsResultSfc" useclientlayout="true">
        <ColumnInfo>
          <Column id="rcptNo" type="STRING" size="256"/>
          <Column id="appoExamId" type="STRING" size="256"/>
          <Column id="aplemDsgnNo" type="STRING" size="256" description="응시번"/>
          <Column id="unaAppoExamYn" type="STRING" size="256" description="무효임용시험여부"/>
          <Column id="sfcDgrNo" type="STRING" size="256" description="발표 차수"/>
          <Column id="screBefrRlsYn" type="STRING" size="256" description="사전성적조회 기간 여부"/>
          <Column id="screBefrFromDt" type="STRING" size="256" description="사전성적조회 기간 from"/>
          <Column id="screBefrToDt" type="STRING" size="256" description="사전성적조회 기간 to"/>
          <Column id="screBefrCd1Yn" type="STRING" size="256" description="사전성적조회 항목 : 총점 여부"/>
          <Column id="screBefrCd2Yn" type="STRING" size="256" description="사전성적조회 항목 : 과목 여부"/>
          <Column id="screBefrCd3Yn" type="STRING" size="256" description="사전성적조회 항목 : 가산점 여부"/>
          <Column id="screObjcYn" type="STRING" size="256" description="성적이의신청 여부"/>
          <Column id="screObjcFromDt" type="STRING" size="256" description="성적이의신청 기간 from"/>
          <Column id="screObjcToDt" type="STRING" size="256" description="성적이의신청 기간 to"/>
