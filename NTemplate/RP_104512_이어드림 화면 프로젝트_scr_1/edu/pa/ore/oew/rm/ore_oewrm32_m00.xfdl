<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmMain" width="1200" height="688" titletext="교육공무직-전자근로계약서-사전동의서" onload="frmMain_onload">
    <Layouts>
      <Layout height="688" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="70" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle00" taborder="0" text="전자근로계약서 사전동의서" left="0" top="0" height="44" cssclass="img_WF_SubTit01" initvalueid="ivTitleAccessibilityOn" right="780" tabstop="false"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divContent00" taborder="1" left="0" height="553" cssclass="div_WF_InfoBOX" top="135" text="" initvalueid="ivDivAccessibilityOff" right="0">
          <Layouts>
            <Layout>
              <Div id="div00_00_00_00" taborder="0" left="30" height="364" cssclass="div_WF_InfoBOX" top="30" text="" initvalueid="ivDivAccessibilityOn" right="30" accessibilitylabel="개인정보 수집 및 이용에 관한 그룹박스">
                <Layouts>
                  <Layout>
                    <Static id="sta00_00_01_01" taborder="1" left="30" top="52" height="302" text="가. 개인정보의 수집 및 이용 목적&#13;&#10;   ○ 교육공무직 채용자에 대해 근로기준법에 따라 근로계약 체결을 하기 위함&#13;&#10;&#13;&#10;나. 수집하려는 개인정보의 항목&#13;&#10;   ○ 전자근로계약서 서명을 위해 아래와 같은 개인정보를 수집하고 있음&#13;&#10;   ○ 성명, 주민등록번호, 서명이미지 전자근로계약서 서명에 필요한 사항&#13;&#10;   ※ 주민등록번호는 「아동청소년의성보호에관한법률시행령」  제39조(민감정보 및 고유식별정보의 처리), 「소득세법」 제166조(주민등록 전산정보자료 등의 이용)에 &#13;&#10;      근거하여 처리합니다.&#13;&#10;&#13;&#10; &lt;b v='true'&gt;&lt;fs v='12'&gt;다. 개인정보의 보유 기간&#13;&#10;   ○ 수집한 개인정보는 근로기준법 제42조에 의해 3년 기간 동안 보유&lt;/fs&gt;&lt;/b&gt;&#13;&#10;&#13;&#10;라. 동의를 거부할 권리 및 동의 거부에 따른 제약사항&#13;&#10;   ○ 위 사항에 대하여 동의를 거부할 권리가 있으며 동의 거부 시에는 본 사이트에서 제공하는 전자근로계약서 서명을 이용할 수 없음" wordWrap="char" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" verticalAlign="top" right="30" usedecorate="true"/>
                    <Static id="staTlt00" taborder="1" left="20" top="9" height="36" text="개인정보 수집 및 이용에 대한 동의" wordWrap="char" width="548" cssclass="sta_WF_WorkTit" initvalueid="ivStcAccessibilityOn" accessibilitylabel="교육부, 시도교육청내 자료 활용 동의서"/>
                  </Layout>
                </Layouts>
              </Div>
              <CheckBox id="chkVal00" taborder="1" text="동의합니다." left="1050" top="407" width="110" height="32" initvalueid="ivChkNormal" onclick="divContent00_chkVal00_onclick"/>
              <Static id="staGd05" taborder="2" left="946" top="394" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="33" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staGd06_00" taborder="3" left="339" top="439" height="22" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="33" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staGd12" taborder="4" left="0" height="50" cssclass="sta_GD_Size" text="50" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="-2" initvalueid="ivStcAccessibilityOff" top="502"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnNext00" taborder="2" text="다음" left="534" top="598" width="130" height="40" cssclass="btn_WF_Action" initvalueid="ivBtnAccessibilityButton" onclick="btnNext00_onclick"/>
        <Static id="staGd01" taborder="3" left="31" top="114" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="879" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-교육공무직-전자근로계약서-사전동의서
*  @MenuPath    pa_ore_oew_rm
*  @FileName 	pa_ore_oewrm32_m00.xfdl
*  @Creator 	
*  @CreateDate 	2022.9.14
*  @Desction    교육공무직 전자근로계약서 사전동의서 화면
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.9.14    	 	        최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{	
	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);
	
	// 서버시간 조회
	this.fnSearchDate();

};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){

}

/**
 * 교육공무직-지원서작성-동의서 동의서 상세 팝업1 콜백
 */
this.fnModal01Callback = function(e, sender){
	//this.smfAlert("응답결과 ==>"+e.agreeValue);
	// popup Modal에서 선택한 동의 여부set
	this.divContent00.form.rdo00.set_value(e.agreeValue)
};

/**
 * 교육공무직-지원서작성-동의서 상세 팝업2 콜백
 */
this.fnModal02Callback = function(e, sender){
	// popup Modal에서 선택한 동의 여부set
	this.divContent00.form.rdo01.set_value(e.agreeValue);
};



/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 *현재 일자 검색
 */
this.fnSearchDate = function(obj, e)
{	
	// 서비스 객체 생성
	this.smfSearchService("selectDate")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;

			// 시간을 표시한다.
			var sCurDate = this.dsDateTime.getColumn(0, "yyyymmdd");
			// 보기 좋게 표시하기 위해 formatting
			sCurDate = sCurDate.dateFormat("yyyy년 MM월 dd일");
			
			// 서버에서 가져온 시간을 표시한다.
			this.divContent00.form.staDate00.set_text(sCurDate);
		});
}
 

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.btnNext00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if( !this.divContent00.form.chkVal00.value  ) {
		this.divContent00.form.chkVal00.setFocus();
		this.smfAlert('개인정보 수집 및 이용에 대한 동의 후 진행 가능 합니다.');
		return false;
	}
	
	var params = {
	};
	this.smfSetWorkPage("pa_ore_oew_rm::ore_oewrm33_m00.xfdl", params);
};]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">selectDate</Col>
            <Col id="inDatasets"/>
            <Col id="outDatasets">dsDateTime=dsDateTime</Col>
            <Col id="url">cmc_fcm_dt01_001.do</Col>
            <Col id="asynctp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsDateTime" useclientlayout="true">
        <ColumnInfo>
          <Column id="mm" type="STRING" size="256"/>
          <Column id="dd" type="STRING" size="256"/>
          <Column id="hhmmss" type="STRING" size="256"/>
          <Column id="yyyymmdd" type="STRING" size="256"/>
          <Column id="yyyy" type="STRING" size="256"/>
          <Column id="hhmmsssss" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
  </Form>
</FDL>
