              <Static id="staContent00" taborder="0" text="응시시험" top="15" height="30" cssclass="sta_WF_InfoTit02" initvalueid="ivStcAccessibilityOn" textAlign="left" width="93" left="21" onclick="divSummary_staSubTltInfo00_onclick"/>
              <Button id="btnPassCrtf" taborder="2" text="합격증발급" top="13" height="35" fittocontents="width" cssclass="btn_WF_Write" visible="true" initvalueid="ivBtnAccessibilityButton" width="135" onclick="divAppoExam_btnPassCrtf_onclick" left="1043"/>
              <Combo id="cboAppoExm" taborder="1" text="" left="104" top="16" height="30" index="-1" initvalueid="ivCmbEssential" cssclass="essential" innerdataset="dsResultRcpt" codecolumn="rcptNo" datacolumn="appoExamNmSum" displaynulltext="-선택-" accessibilitylabel="시험장" autoselect="false" right="btnPassCrtf:10"/>
            </Layout>
