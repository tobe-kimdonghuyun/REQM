              <ImageViewer id="imgTitle00" taborder="1" text="합격증발급" left="0" top="70" height="44" cssclass="img_WF_SubTit01" width="170" initvalueid="ivTitleAccessibilityOn" onload="divTitle_imgTitle_onload"/>
              <Static id="staGd01" taborder="2" left="0" top="114" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staGd02" taborder="1" left="0" top="204" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Div id="divAppoExam" taborder="2" left="0" top="144" height="60" cssclass="div_WF_Search" right="0" initvalueid="ivDivAccessibilityOff" tabstop="true">
          <Layouts>
