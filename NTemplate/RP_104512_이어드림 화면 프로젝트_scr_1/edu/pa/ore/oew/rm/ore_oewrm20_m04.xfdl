<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="formMain" width="1200" height="700" titletext="지방공무원-마이페이지-합격증발급" onload="formMain_onload">
    <Layouts>
      <Layout height="700" width="1200" screenid="ScreenDeskTop">
