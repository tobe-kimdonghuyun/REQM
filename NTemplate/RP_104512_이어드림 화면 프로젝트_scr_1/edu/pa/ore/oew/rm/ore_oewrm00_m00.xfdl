<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="formMain" width="1200" height="630" titletext="교원임용(초등)-마이페이지-원서접수내역" onload="frmMain_onload">
    <Layouts>
      <Layout height="630" width="1200" screenid="ScreenDeskTop">
        <Div id="divContent00" taborder="0" left="0" top="0" height="144" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staGd00" taborder="1" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
              <ImageViewer id="imgTitleSrce" taborder="0" text="원서접수내역" left="0" top="70" height="44" cssclass="img_WF_SubTit01" width="194" initvalueid="ivTitleAccessibilityOn" onload="divTitle_imgTitle_onload" onclick="divContent00_imgTitleSrce_onclick"/>
              <Static id="staGd01" taborder="2" left="0" top="112" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
          </Layouts>
        </Div>
        <Grid id="grdAdf" taborder="1" left="0" top="139" height="281" autofittype="col" right="0" binddataset="dsGrdMain" initvalueid="ivGrdAccessibilityOn" autoenter="none" autosizingtype="row" extendsizetype="row" nodatatext="응시 내역이 없습니다." oncellclick="grdDsMain_oncellclick" accessibilitylabel="원서접수내역 목록" selecttype="cell" cursor="pointer" showselection="false">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="36"/>
                <Column size="384"/>
                <Column size="150"/>
                <Column size="152"/>
                <Column size="146"/>
                <Column size="80"/>
                <Column size="100"/>
                <Column size="100"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="번호"/>
                <Cell col="1" text="응시시험"/>
                <Cell col="2" text="분야"/>
                <Cell col="3" text="원서등록일"/>
                <Cell col="4" text="결제일"/>
                <Cell col="5" text="접수상태"/>
                <Cell col="6" text="접수/취소"/>
                <Cell col="7" text="출력/삭제"/>
              </Band>
              <Band id="body">
                <Cell expr="currow+1" padding="10px 10px"/>
                <Cell col="1" edittype="none" textAlign="left" wordWrap="char" text="bind:appoExamNm" padding="10px 10px" displaytype="decoratetext" cssclass="Static.sta_WF_underline" textDecoration="underline"/>
                <Cell col="2" text="bind:currNm" textAlign="center" wordWrap="char" padding="10px 10px"/>
                <Cell col="3" calendardateformat="yyyy-MM-dd " text="bind:adfRegDtTxt" textAlign="center" wordWrap="char" padding="10px 10px" calendardisplaynulltype="default"/>
                <Cell col="4" edittype="none" text="bind:payRegDtTxt" textAlign="center" wordWrap="char" padding="10px 10px" displaytype="normal" calendareditformat="yyyy-MM-dd" calendardisplaynulltype="nulltext" calendardateformat="yyyy-MM-dd "/>
                <Cell col="5" text="expr:payYn =='Y' ? '접수완료':'진행중'" textAlign="center" wordWrap="char" padding="10px 10px" cssclass="expr:payYn =='Y' ? 'cell_WF_BlueB':'cell_WF_RedB'"/>
                <Cell col="6" edittype="none" text="expr:payYn =='Y' ? '결제취소':'결제하기'" suppressalign="middle" textAlign="center" cssclass="cell_WF_PointBtn01, red" displaytype="buttoncontrol"/>
                <Cell col="7" displaytype="buttoncontrol" edittype="none" text="expr:payYn =='Y' ? '접수증출력':'지원서삭제'" suppressalign="middle" textAlign="center" cssclass="cell_WF_PointBtn01"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listAdf</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsGrdMain=dsGrdMain</Col>
            <Col id="url">ore_oew_rm00_001.do</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="id">selectRcptReport</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResultReport=dsResultReport</Col>
            <Col id="url">ore_oew_ar01_005.do</Col>
            <Col id="asynctp">false</Col>
          </Row>
          <Row>
            <Col id="id">selectRcptCancelCeck</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResultCancelCeck=dsResultCancelCeck</Col>
            <Col id="url">ore_oew_ar01_007.do</Col>
          </Row>
          <Row>
            <Col id="id">saveRcptCancel</Col>
            <Col id="inDatasets">dsMainCancel=dsMainCancel dsRcptSms=dsRcptSms</Col>
            <Col id="url">ore_oew_ar01_008.do</Col>
          </Row>
          <Row>
            <Col id="id">selectAppoExam</Col>
            <Col id="inDatasets">dsMain=dsMain</Col>
            <Col id="url">ore_oew_ar01_002.do</Col>
            <Col id="outDatasets">dsAppoExam=dsAppoExam dsSprtMetList=dsSprtMetList dsPrivShlList=dsPrivShlList dsKrhisRcgnCetYmdList=dsKrhisRcgnCetYmdList dsAppoOnlEmpmnMng=dsAppoOnlEmpmnMng dsA1passItmList=dsA1passItmList dsA2passItmList=dsA2passItmList dsAdtnList=dsAdtnList</Col>
            <Col id="asynctp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcScCd" type="STRING" size="256" description="시도교육청구분코드"/>
