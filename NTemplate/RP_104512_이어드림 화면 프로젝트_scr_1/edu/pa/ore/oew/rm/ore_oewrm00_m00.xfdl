    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-교원임용(중등)-마이페이지-원서접수내역
*  @MenuPath    pa_ore_oew_rm
*  @FileName 	ore_oewrm10_m00.xfdl
*  @Creator 	최정민
*  @CreateDate 	2022.12.29
*  @Desction    온라인통합채용-교원임용(중등)-마이페이지-원서접수내역
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.12.29             최초 생성
*******************************************************************************
*/
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 include "lib::ore_script.xjs"
 this.pv_params;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);	
	   
	// 검색조건 초기화
	this.dsSearch.clearData();
	this.dsSearch.addRow();


	this.pv_params = this.smfGetFormParams();

	// 선택 시도교육청코드
	var sCddcCd = this.smfGetCddcCode();
	
	// TODO 주민번호 : 본인인증 세션취득
	this.dsSearch.setColumn(0, "applpRrno", nexacro.base64Decode(this.smfGetSessionValue('userRrno')));
	                                         
	// 시도교육청 앞 3자리 = 시도교육청 구분코드
	this.dsSearch.setColumn(0, "cddcScCd", sCddcCd.slice(0,3));
	
	// 원서접수 내역 조회
	this.fnSearchAdfList();
	
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

// 원서접수 목록 조회
 this.fnSearchAdfList = function(){
		// 서비스 객체 생성
		this.smfSearchService("listAdf")
		
		// 데이터 존재 필수(검색 조건)
		.requireExistsData(this.dsSearch)

		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){

			if(callbackParams.errors) return;
			
		});
}


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/


/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 //  리스트 클릭
this.grdDsMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var nCell = e.cell;
	if(nCell == 1) { // 제목
		// 확인 메시지 출력
		this.smfConfirm("지원서 화면으로 이동 하시겠습니까?", function(result){
			if(result.confirmResult){
				var nRow = e.row;
				var objDs       = obj.getBindDataset();
				var rcptNo      = objDs.getColumn(nRow,"rcptNo");
				var appoExamCd  = objDs.getColumn(nRow,"appoExamId");
				var appoExamNm  = objDs.getColumn(nRow,"appoExamNm");
				var appoFieldCd	= objDs.getColumn(nRow,"currCd");			
				var appoFieldNm	= objDs.getColumn(nRow,"currNm");			

				var params = {
					"rcptNo"      : rcptNo,
					"appoExamCd"  : appoExamCd,
					"appoExamNm"  : appoExamNm,
					"appoFieldCd" : appoFieldCd,
					"appoFieldNm" : appoFieldNm,
					"updateYn"    : "Y"
				}
				// 지원서 수정화면
				this.smfSetWorkPage("pa_ore_oew_ar::ore_oewar01_m00.xfdl", params);
			}
		});
	}
	else if(nCell == 6) 
	{
		var nRow = e.row;
		var objDs       = obj.getBindDataset();
		if(objDs.getColumn(nRow,"payYn")=='Y') //결제취소
		{
		
			this.dsSearch.setColumn(0, 'rcptNo', objDs.getColumn(nRow,"rcptNo"));
			this.dsSearch.setColumn(0, 'cddcScCd', this.smfGetCddcCode().slice(0,3));
			this.dsSearch.setColumn(0, 'appoExamId', objDs.getColumn(nRow,"appoExamId"));
			this.dsSearch.setColumn(0, 'onlEmpmnExamScCd', "1"); // 초중등 구분 (초등)
			this.dsSearch.setColumn(0, 'chkGb', "1");//결재 취소
			
			this.smfConfirm("결제 취소시 결제를 다시하셔야 정상 접수가 완료됩니다. \n결제를 취소하시겠습니까?", function(result){
				if(result.confirmResult){
					this.smfSearchService("selectRcptCancelCeck")
						.showConfirm(false)
						.run()
						// 콜백
						.callback(function(callbackParams){
							if(callbackParams.errors) {
								return;
							}
						
							var payYn      = objDs.getColumn(nRow,"payYn");
							var appoFieldCd	= objDs.getColumn(nRow,"currCd");			
							var appoExamId = objDs.getColumn(nRow,"appoExamId");
							var cddcScCd = this.smfGetCddcCode().slice(0,3);
							var payCancel='Y';
							this.fnSaveRcptCancel(appoExamId,appoFieldCd,payYn,cddcScCd,payCancel);
					});
				}
			});
		}
		else//결제진행
		{
			this.smfConfirm("지원서 화면으로 이동후, 결제화면으로 자동이동 하시겠습니까?", function(result){
			if(result.confirmResult){
				var nRow = e.row;
				var objDs       = obj.getBindDataset();
				var rcptNo      = objDs.getColumn(nRow,"rcptNo");
				var appoExamCd  = objDs.getColumn(nRow,"appoExamId");
				var appoExamNm  = objDs.getColumn(nRow,"appoExamNm");
				var appoFieldCd	= objDs.getColumn(nRow,"currCd");			
				var appoFieldNm	= objDs.getColumn(nRow,"currNm");			

				var params = {
					"rcptNo"      : rcptNo,
					"appoExamCd"  : appoExamCd,
					"appoExamNm"  : appoExamNm,
					"appoFieldCd" : appoFieldCd,
					"appoFieldNm" : appoFieldNm,
					"updateYn"    : "Y",
					"gotoPay"	  : "Y"
				}
				// 지원서 수정화면
				this.smfSetWorkPage("pa_ore_oew_ar::ore_oewar01_m00.xfdl", params);
			}
		});
		}
	}
	else if(nCell == 7)
	{		
		//접수완료된 건
		//기존 접수취소 건과 동일하게 동작
		var nRow = e.row;
		var objDs = obj.getBindDataset();
		if(objDs.getColumn(nRow,"payYn")!='Y') //지원서 삭제
		{
			//접수완료된 건
			//기존 접수취소 건과 동일하게 동작
			this.dsSearch.setColumn(0, 'rcptNo', objDs.getColumn(nRow,"rcptNo"));
			this.dsSearch.setColumn(0, 'cddcScCd', this.smfGetCddcCode().slice(0,3));
			this.dsSearch.setColumn(0, 'appoExamId', objDs.getColumn(nRow,"appoExamId"));
			this.dsSearch.setColumn(0, 'onlEmpmnExamScCd', "1"); // 초중등 구분 (초등)
			this.dsSearch.setColumn(0, 'chkGb', "2");//지원서 삭제
			this.smfConfirm("지원서삭제 시 처음단계부터 재작성 해주셔야 합니다 \지원서삭제를 삭제하시겠습니까?", function(result){
				if(result.confirmResult){
					this.smfSearchService("selectRcptCancelCeck")
						.showConfirm(false)
						.run()
						// 콜백
						.callback(function(callbackParams){
							if(callbackParams.errors) {
								return;
							}
							
							var payYn      = objDs.getColumn(nRow,"payYn");
							var appoFieldCd	= objDs.getColumn(nRow,"currCd");			
							var appoExamId = objDs.getColumn(nRow,"appoExamId");
							var cddcScCd = this.smfGetCddcCode().slice(0,3);
							var payCancel='N';
							this.fnSaveRcptCancel(appoExamId,appoFieldCd,payYn,cddcScCd,payCancel);
					});
				}
			});
		}
		else // 접수증 출력
		{
			this.dsSearch.setColumn(0, 'rcptNo', objDs.getColumn(nRow,"rcptNo"));
			this.dsSearch.setColumn(0, 'cddcScCd', this.smfGetCddcCode().slice(0,3));
			this.dsSearch.setColumn(0, 'appoExamId', objDs.getColumn(nRow,"appoExamId"));
			this.dsSearch.setColumn(0, 'onlEmpmnExamScCd', "1"); // 초중등 구분 (초등)		
			// 접수증 조회
			this.fnSearchRcptReport();
			
			// 출력물 주민번호 하이픈 추가
			this.dsResultReport.setColumn(0, 'applpRrno', this.applpRrnoHyphen(this.dsResultReport.getColumn(0, 'applpRrno')));
			
			// 버튼표시여부
			var objButton = {
				"toolbar.save" : "false"    // 저장 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)           
				, "toolbar.addmemo" : "false"    // 메모 추가 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
				, "toolbar.savedm" : "false"    // 데이터 모듈 저장 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
				, "toolbar.etc" : "false"    // 다른 메뉴 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
			}
			
			// 리포트를 생성하기 위한 옵션을 설정한다.
			var oOzOption = {
								reports : [	
									{	
										  displayname  : "접수증"         
										, reportname : "/edu/pa/ore/oew/ar/ore_oewar01_r01.ozr"                                
										, jsonDs     : [this.dsResultReport ]     
										, jsonDsName : ["dsReport"]          
										// 추가/보안옵션
										, security     : "N"     // [선택] 위변조방지 삽입   ("Y"(default):표시,"N":비표시)
										, voiceBarcode : "N"     // [선택] 보이스바코드 삽입 ("Y"(default):표시,"N":비표시)
										, brailleCode  : "N"    // [선택] 점자문서 생성     ("Y":생성,"N"(default):미생성)
									}						
								]
								, hidestatus : true   // [선택] 하단 상태값 표시
								, button : objButton    // [선택] 버튼의 표시 비표시를 통제
							};
							
			//리포트를 그린다
			this.smfReportView(this,"popup",oOzOption,function(svcid, errcd, errmsg){});           // Div로 표시
		}
	}
};

//접수취소
this.fnSaveRcptCancel = function(appoExamId,appoFieldCd,payYn,cddcScCd,payCancel)
{
	this.dsMain.setColumn(0, 'eamScCd', 1); // 초중등 구분 (초등)
	this.dsMain.setColumn(0, 'currCd', appoFieldCd);
	this.dsMain.setColumn(0, 'appoExamId', appoExamId);
	this.dsMain.setColumn(0, 'cddcScCd', cddcScCd);
    
	
	this.smfSearchService('selectAppoExam') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;

			this.dsMainCancel.clearData();
			this.dsMainCancel.addRow();
			this.dsMainCancel.setColumn(0, 'cddcScCd', this.smfGetCddcCode().slice(0,3));// 시도교육청구분코드
			this.dsMainCancel.setColumn(0, 'eamScCd', "1"); // 초중등 구분 (초등)
			this.dsMainCancel.setColumn(0, 'rcptNo', this.dsSearch.getColumn(0, 'rcptNo')); // 접수번호
			this.dsMainCancel.setColumn(0, 'mid', this.dsResultCancelCeck.getColumn(0, 'stlmNo'));// INICIS 상점아이디
			this.dsMainCancel.setColumn(0, 'tid', this.dsResultCancelCeck.getColumn(0, 'stlmKey'));// INICIS 거래번호
			this.dsMainCancel.setColumn(0, 'payMethod', this.dsResultCancelCeck.getColumn(0, 'stlmTypIdfCd'));// INICIS 결제수단
			this.dsMainCancel.setColumn(0, 'stlmAmt', this.dsResultCancelCeck.getColumn(0, 'stlmAmt'));// 응시료(응시료 면제 검증 외 0원 있음.)
			this.dsMainCancel.setColumn(0, 'rlesYn', this.dsResultCancelCeck.getColumn(0, 'rlesYn'));// 응시료면제여부
			
			// 원서접수취소 문자발송정보 SET
			var rcptQustTelNo = this.dsAppoOnlEmpmnMng.getColumn(0,'rcptQustTelNo');
			this.fnSetSaveRcptSmsInfo(rcptQustTelNo);
			if(payCancel =='Y')
			{
				this.dsMainCancel.setColumn(0,'payCancel','Y');
			}else{
				this.dsMainCancel.setColumn(0,'payCancel','');
			}
			
			// 접수취소
			this.smfSaveService("saveRcptCancel")
				.showConfirm(false)
				.run()
				// 콜백
				.callback(function(callbackParams){
					if(callbackParams.errors) {
						return;
					}
					this.smfAlert("원서 접수 취소가 완료 되었습니다.", this.fnCancelMessageCallback);
					// 화면 refresh
					this.fnSearchAdfList();
			});
	
		});		
};

 /**
 * 원서접수취소 문자발송정보 SET
 **/
 this.fnSetSaveRcptSmsInfo = function(rcptQustTelNo){
	// 초기화
	this.dsRcptSms.clearData();
	this.dsRcptSms.addRow();
	this.dsRcptSms.setColumn(0, 'appoExamScCd' , this.smfGetAppoExamScCd()); //임용시험구분코드
	this.dsRcptSms.setColumn(0, 'cddcScCd' ,this.smfGetCddcCode().slice(0,3)); //시도교육청구분코드
	this.dsRcptSms.setColumn(0, 'cddcNm' , this.smfGetCddcName()); //시도교육청명
	this.dsRcptSms.setColumn(0, 'rcptQustTelNo' , rcptQustTelNo); //발신번호
	this.dsRcptSms.setColumn(0, 'mblTelno' , this.smfGetMblTelno()); //수신번호
}

 /**
 * 접수증 조회
 **/
this.fnSearchRcptReport = function(obj, e)
{
	// 접수증 조회
	this.smfSearchService('selectRcptReport') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) {
				return;
			}
			//trace(this.dsResultReport.saveXML());
	});
};]]></Script>
  </Form>
</FDL>
