    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listAppoCndtRcpt</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResultAppoCndtRcpt=dsResultAppoCndtRcpt</Col>
            <Col id="url">/ore_oew_rm21_m00_000.do</Col>
          </Row>
          <Row>
            <Col id="id">selectAppoCndtHestCeck</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResultAplyCeck=dsResultAplyCeck</Col>
            <Col id="url">ore_oew_rm21_m01_001.do</Col>
          </Row>
          <Row>
            <Col id="id">saveAppoCndtHest</Col>
            <Col id="inDatasets">dsMain=dsMain</Col>
            <Col id="outDatasets">dsMain=dsMain</Col>
            <Col id="url">/ore_oew_rm21_m01_002.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="false" updatecontrol="false">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256" description="접속시도교육청 구분코드"/>
          <Column id="appoExamId" type="STRING" size="256" description="임용시험아이디"/>
          <Column id="rcptNo" type="STRING" size="256" description="접수번호"/>
          <Column id="applpRrno" type="STRING" size="256" description="주민번호"/>
          <Column id="arbilCd" type="STRING" size="256" description="임용(채용)후보자 동의서코드"/>
          <Column id="ocptyCd" type="STRING" size="256"/>
          <Column id="jbgdCd" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true" updatecontrol="false">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256" description="시도교육청구분코드"/>
          <Column id="rcptNo" type="STRING" size="256"/>
          <Column id="appoExamId" type="STRING" size="256"/>
          <Column id="applpFlnm" type="STRING" size="256" description="응시자성명"/>
          <Column id="applpRrno" type="STRING" size="256" description="응시자주민번호"/>
          <Column id="applpBrdt" type="STRING" size="256" description="응시자생년월일"/>
          <Column id="emlAddr" type="STRING" size="256" description="이메일"/>
          <Column id="mblTelno" type="STRING" size="256" description="휴대전화"/>
          <Column id="mblTelno1" type="STRING" size="256" description="휴대전화1"/>
          <Column id="mblTelno2" type="STRING" size="256" description="휴대전화2"/>
          <Column id="mblTelno3" type="STRING" size="256" description="휴대전화3"/>
          <Column id="fileRefrnId" type="STRING" size="256" description="첨부파일내용"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsResultAppoCndtRcpt" useclientlayout="true">
        <ColumnInfo>
          <Column id="rcptNo" type="STRING" size="256" description="접수번호"/>
          <Column id="cddcScCd" type="STRING" size="256" description="시도교육청구분코드"/>
          <Column id="cddcScNm" type="STRING" size="256" description="강원도교육청"/>
          <Column id="appoExamId" type="STRING" size="256" description="임용시험ID"/>
          <Column id="appoExamNm" type="STRING" size="256" description="임용시험명"/>
          <Column id="appoExamNmSum" type="STRING" size="256" description="임용시험명 화면표시"/>
          <Column id="appoExamYr" type="STRING" size="256" description="임용시험연도"/>
          <Column id="ocptyCd" type="STRING" size="256" description="직류코드"/>
          <Column id="ocptyNm" type="STRING" size="256" description="직류명"/>
          <Column id="jblnCd" type="STRING" size="256" description="직렬코드"/>
          <Column id="jblnNm" type="STRING" size="256" description="직렬명"/>
          <Column id="jbgdCd" type="STRING" size="256" description="직급코드"/>
          <Column id="jbgdNm" type="STRING" size="256" description="직급명"/>
          <Column id="rksCd" type="STRING" size="256" description="계급코드"/>
          <Column id="rksNm" type="STRING" size="256" description="계급명"/>
          <Column id="applpFlnm" type="STRING" size="256" description="응시자성명"/>
          <Column id="applpRrno" type="STRING" size="14" description="응시자주민등록번호"/>
          <Column id="sxdsCd" type="STRING" size="256" description="성별코드"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsResultAplyCeck" useclientlayout="true">
        <ColumnInfo>
          <Column id="appoCndtYn" type="STRING" size="256" description="임용등록여부"/>
          <Column id="duplYn" type="STRING" size="256" description="중복여부"/>
          <Column id="apfGvbDtYn" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-지방공무원-임용후보자-유예신청
*  @MenuPath    pa_ore_oew_rm
*  @FileName 	pa_ore_oewrm21_m01.xfdl
*  @Creator 	jhchoi
*  @CreateDate 	2022.11.28
*  @Desction    온라인통합채용-지방공무원-임용후보자-유예신청
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.11.28    	jhchoi 	        	최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.applpRrno;
this.applpFlnm;
this.applpBrdt;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

	// 로그인 세션 체크 
	//this.isOreLogin();
	
	// 본인인증 세션취득
	this.applpRrno = nexacro.base64Decode(this.smfGetSessionValue('userRrno'));
	this.applpFlnm = this.smfGetSessionValue('userNm');
	this.applpBrdt = this.applpRrno.slice(0,6);
	
	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);
	// 파일업로드 Init
	this.fnInitFileUpload();
	
	// 메인 데이터 초기화
	this.dsMain.clearData();
	this.dsMain.addRow();

	//  메세지1
	this.divSummary.form.divContent00.form.staContent00.set_text(this.applpFlnm + "(" +this.applpBrdt +")님.");
	
	// 지원서 조회
	this.fnSearchAppoCndtRcpt();

};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
}

// 파일 업로드 변경 콜백
this.fnFileUploadChangeCallback = function(obj, paramObj, sCustomValue, sFileName, nFileSize)
{
	//this.divAplyInfo.form.divFileUpload.form.fnFileUpload();
}

/**
* 업로드성공 콜백
*/
this.fnEventUploadComplete = function(obj,paramObj,objResultDataset)
{
	// 업로드 성공 후, newfile에 있는 파일들을 webfile로 옮긴다.
	// 단건 업로드 파일의 경우 해당 기능 사용시 멀티파일 적용됨.
	//this.divAplyInfo.form.divFileUpload.form.fnSetUploadCompleteState(obj,paramObj);

	if(objResultDataset){
		var sFileRefrnId = objResultDataset.getColumn(0,"fileRefrnId");
		this.dsMain.setColumn(0, 'fileRefrnId', sFileRefrnId);
		// 임용 유예 신청 처리
		this.fnSaveAppoCndtHest();
	}
}

/**
* 파일 업로드 에러 콜백
*/
this.fnEventUploadError = function(obj,paramObj)
{
	//this.smfAlert("첨부파일 업로드 실패 하였습니다. \n다시 시도해주세요.");
	//return;
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 응시원서 조회
 */ 
this.fnSearchAppoCndtRcpt = function()
{
	this.dsSearch.clearData();
	this.dsSearch.addRow();
	this.dsSearch.setColumn(0, 'cddcCd', this.smfGetCddcCode()); // 시도교육청코드
	this.dsSearch.setColumn(0, 'applpRrno',this.applpRrno); //주민번호
	this.dsSearch.setColumn(0, 'arbilCd', '31'); // 임용(채용) 동의코드 : 30(등록), 31(유예), 32(포기)
	
	// 저장
	this.smfSearchService("listAppoCndtRcpt")
		.showConfirm(false)
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors){
					return;
			}

			// 응시원서 결과
			var resultCnt= this.dsResultAppoCndtRcpt.getRowCount();
			if(resultCnt < 1){
				this.divAppoExam.form.divContent00.form.cboAppoExm.set_enable(false);
				this.divAplyInfo.form.edtEmail.set_enable(false);
				this.divAplyInfo.form.edtMblNo00.set_enable(false);
				this.divAplyInfo.form.edtMblNo01.set_enable(false);
				this.divAplyInfo.form.edtMblNo02.set_enable(false);
				this.divActionBtn.form.btnAply.set_enable(false);
				this.divSummary.form.divContent00.form.staContent01.set_text(this.smfGetCddcName()+" 임용유예 신청 대상 원서가 없습니다.");
			}
	});
}
 
 /**
 * 임용유예 신청 가능 여부 조회
 */ 
this.fnSearchAppoCndtHestCeck = function()
{
	this.dsSearch.clearData();
	this.dsSearch.addRow();
	// 시도 교육청 코드SET
	this.dsSearch.setColumn(0, 'cddcCd', this.smfGetCddcCode());
	// 응시자 주민번호
	this.dsSearch.setColumn(0, 'applpRrno', this.applpRrno);
	this.smfSearchService("selectAppoCndtHestCeck")
		.showConfirm(false)
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors){
				return;
			}
			// 페이지 VIEW SET
			this.initPage();
		}
	);
}

/**
 * 임용유예 신청처리
 */ 
this.fnSaveAppoCndtHest = function()
{
	this.smfSaveService("saveAppoCndtHest")
		.showConfirm(false)
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors){
				return;
			}
			this.smfAlert('임용유예 신청이 등록 되었습니다.\n진행 사항은 담당자에게 문의 바랍니다');
		}
	);
}

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 
 /**
 *  파일 업로드 Init
 */
this.fnInitFileUpload = function()
{	
	this.divAplyInfo.form.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete; // 업로드 성공 이벤트 콜백
	this.divAplyInfo.form.divFileUpload.UPLOAD_AfterAddFile = this.fnFileUploadChangeCallback;// 파일 추가 이벤트 콜백
	this.divAplyInfo.form.divFileUpload.UPLOAD_OnError = this.fnEventUploadError; //에러 콜백
	this.divAplyInfo.form.divFileUpload.UPLOAD_Form = this; 
}

/**
 *  RAONK  옵션
 */ 
this.fnSetRaonProp = function()
{
	var objAddRaonProps = {
		// ExtensionAllowOrLimit : "1"        // 업로드 할 파일 확장자를 허용 또는 제한 설정("0":지정된 확장자를 제한(선택 금지) , "1":지정된 확장자만 허용(선택가능))
		//, ExtensionArr          : "gif,jpg,png"  // 제한 및 허용할 확장자명을 ",(콤마)"로 구분하여 설정
		//, AllowedZeroFileSize : "0"  // 0byte 파일의 업로드를 허용 할지 설정합니다.(기본값은 "0" 허용안함이고, "1"로 설정시 허용입니다.)
		//, ButtonBarEdit : "add,remove,remove_all"
		//, DisableAlertMessage	: {
		//	DisableDeleteConfirm: "1" 	// "1"로 설정시 파일 삭제시 confirm창 비활성.
		//}
		MaxTotalFileCount : "1"	//업로드 할 최대 파일 개수 제한값을 설정합니다.
		, MaxOneFileSize : "3MB"	//업로드할 때 파일당 용량제한을 설정합니다.

	};						  
	return objAddRaonProps;
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.btnAply_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	// 선택한 응시원서 접수번호
	var sRcptNo = this.divAppoExam.form.divContent00.form.cboAppoExm.value;
	if(!sRcptNo){
		this.divAppoExam.form.divContent00.form.cboAppoExm.setFocus();
		this.smfAlert("응시시험을 선택 해주세요.");
		return;
	}
	
	// 이메일
	var sEmail = this.divAplyInfo.form.edtEmail.value;
	if(this.smfIsNull(sEmail)){
		this.divAplyInfo.form.edtEmail.setFocus();
		this.smfAlert('이메일을 입력해주세요');
		return;
	}
	if(!this.smfIsEmail(sEmail)){
		this.divAplyInfo.form.edtEmail.setFocus();
		this.smfAlert('이메일의 형식이 잘못되었습니다.');
		return;
	}
	
	// 휴대전화번호
	var mblTelno1 = this.divAplyInfo.form.edtMblNo00.value;
	var mblTelno2 = this.divAplyInfo.form.edtMblNo01.value;
	var mblTelno3 = this.divAplyInfo.form.edtMblNo02.value;
	if(this.smfIsNull(mblTelno1)){
		this.divAplyInfo.form.edtMblNo00.setFocus();
		this.smfAlert('휴대전화 번호를 입력해주세요');
		return;
	}
	if(this.smfIsNull(mblTelno2)){
		this.divAplyInfo.form.edtMblNo01.setFocus();
		this.smfAlert('휴대전화 번호를 입력해주세요');
		return;
	}
	if(this.smfIsNull(mblTelno3)){
		this.divAplyInfo.form.edtMblNo02.setFocus();
		this.smfAlert('휴대전화 번호를 입력해주세요');
		return;
	}
	// 휴대전화번호 조합
	var sMblTelno = [mblTelno1, mblTelno2, mblTelno3].join("-"); 
	
	
	// 첨부파일용량
	var nTotalFileSize = this.divAplyInfo.form.divFileUpload.form.fnGetTotalFileSize();
	// 첨부여부
	if(1 >nTotalFileSize ){
		this.smfAlert('임용유예 증빙 자료는 필수 사항 입니다.');
		this.divAplyInfo.form.divFileUpload.setFocus();
		return false;
	}

	// 첨부파일용량 3M 제한
	if(3145728 <nTotalFileSize ){
		this.smfAlert('첨부 파일은 3MB 이하로 등록 해주세요.');
		this.divAplyInfo.form.divFileUpload.setFocus();
		return false;
	}

	
	// 선택 임용시험
	var sAppoExamId;
	for(var i = 0 ; i < this.dsResultAppoCndtRcpt.rowcount ; i++){
		var rcptNo = this.dsResultAppoCndtRcpt.getColumn(i, 'rcptNo');
		sAppoExamId = this.dsResultAppoCndtRcpt.getColumn(i, 'appoExamId');
		var ocptyCd = this.dsResultAppoCndtRcpt.getColumn(i, 'ocptyCd');
		var jbgdCd = this.dsResultAppoCndtRcpt.getColumn(i, 'jbgdCd');
		if(sRcptNo === rcptNo){
			this.dsSearch.clearData();
			this.dsSearch.addRow();
			this.dsSearch.setColumn(0, 'cddcCd',this.smfGetCddcCode()); // 시도 교육청 구분 코드
			this.dsSearch.setColumn(0, 'appoExamId', sAppoExamId); // 임용시험아이디
			this.dsSearch.setColumn(0, 'rcptNo', sRcptNo); // 접수번호
			this.dsSearch.setColumn(0, 'arbilCd', '31'); // 임용(채용) 동의코드 : 30(등록), 31(유예), 32(포기)
			this.dsSearch.setColumn(0,'applpRrno', this.applpRrno); // 주민번호 TEST : 9195111151984 : 임용등록
			this.dsSearch.setColumn(0, 'ocptyCd', ocptyCd);	// 직류코드
			this.dsSearch.setColumn(0, 'jbgdCd', jbgdCd);	// 직급코드
			//this.dsSearch.setColumn(0,'applpRrno', '9195111151984');	
			break;
		}
	}
	
	// 등록가능 여부 체크
	this.dsResultAplyCeck.clearData();
	this.dsResultAplyCeck.addRow();
	this.smfSearchService("selectAppoCndtHestCeck")
		.showConfirm(false)
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors){
				return;
			}
			// 임용후보자 등록 기간 여부 
			var apfGvbDtYn = this.dsResultAplyCeck.getColumn(0, 'apfGvbDtYn');
			var appoCndtYn = this.dsResultAplyCeck.getColumn(0, 'appoCndtYn');
			var duplYn = this.dsResultAplyCeck.getColumn(0, 'duplYn');
			
			// 임용후보자 등록 기간 아님
			if (apfGvbDtYn != 'Y')
			{
				this.smfAlert("임용유예신청을 할 수 없습니다.\n (임용유예신청 기간이 아닙니다.)");
				return;
			}
			// 이미 등록 되었음
			if(duplYn != 'N'){
				this.smfAlert("임용유예 신청을 할 수 없습니다.\n (이미 임용유예 신청을 하였습니다.)");
				return;
			}
			// 임용여부
			if(appoCndtYn != 'Y'){
				this.smfAlert("임용유예 신청을 할 수 없습니다.\n(임용 정보가 없습니다.)");
				return;
			}
			
			this.smfConfirm("임용유예 신청을 하시겠습니까?", function(result){
				if(result.confirmResult){
					this.dsMain.setColumn(0, 'cddcCd', this.smfGetCddcCode()); // 시도 교육청 코드SET
					this.dsMain.setColumn(0, 'applpFlnm', this.applpFlnm); // 본인인증 값 SET : 응시자성명
					this.dsMain.setColumn(0, 'applpRrno', this.applpRrno); // 본인인증 값 SET  :응시자주민등록번호
					this.dsMain.setColumn(0, 'applpBrdt',  this.applpBrdt); // 본인인증 값 SET  :응시자 샌년월일
					this.dsMain.setColumn(0, "mblTelno", sMblTelno);// 입력 휴대전화번호
					this.dsMain.setColumn(0, "emlAddr", sEmail); // 입력 이메일
					this.dsMain.setColumn(0, 'appoExamId', sAppoExamId); // 선택 임용시험아이디
					this.dsMain.setColumn(0, 'rcptNo', sRcptNo); // 선택 접수번호
					// [첨부파일] 업로드 체크
					var fileCount = this.divAplyInfo.form.divFileUpload.form.fnGetTotalFileCount();
					if(fileCount > 0) {
						// [첨부파일] 업로드 후 콜백에서 임용 유예 신청 처리
						this.divAplyInfo.form.divFileUpload.form.fnFileUpload();
					}else{
						// 임용 유예 신청 처리
						this.fnSaveAppoCndtHest();
					}
				}
			});
	});
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="divAplyInfo.form.edtEmail" propid="value" datasetid="dsMain" columnid="emlAddr"/>
      <BindItem id="item1" compid="divAplyInfo.form.edtNm" propid="value" datasetid="dsMain" columnid="applpFlnm"/>
      <BindItem id="item2" compid="divAplyInfo.form.edtBrdt" propid="value" datasetid="dsMain" columnid="applpBrdt"/>
      <BindItem id="item3" compid="divAplyInfo.form.edtPhoneNo01" propid="value" datasetid="dsMainBase" columnid="emgCnctTelno2"/>
      <BindItem id="item4" compid="divAplyInfo.form.edtPhoneNo02" propid="value" datasetid="dsMainBase" columnid="emgCnctTelno3"/>
      <BindItem id="item5" compid="divAplyInfo.form.edtPhoneNo00" propid="value" datasetid="dsMainBase" columnid="emgCnctTelno1"/>
      <BindItem id="item6" compid="divAplyInfo.form.edtMblNo00" propid="value" datasetid="dsMain" columnid="mblTelno1"/>
      <BindItem id="item7" compid="divAplyInfo.form.edtMblNo01" propid="value" datasetid="dsMain" columnid="mblTelno2"/>
      <BindItem id="item8" compid="divAplyInfo.form.edtMblNo02" propid="value" datasetid="dsMain" columnid="mblTelno3"/>
      <BindItem id="item9" compid="divAplyInfo.form.edtMblNo00" propid="value" datasetid="dsMain" columnid="mblTelno1"/>
      <BindItem id="item10" compid="divAplyInfo.form.edtMblNo01" propid="value" datasetid="dsMain" columnid="mblTelno2"/>
      <BindItem id="item11" compid="divAplyInfo.form.edtMblNo02" propid="value" datasetid="dsMain" columnid="mblTelno3"/>
    </Bind>
  </Form>
</FDL>
