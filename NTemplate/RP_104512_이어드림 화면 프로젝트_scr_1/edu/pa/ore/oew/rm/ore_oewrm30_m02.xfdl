    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-교육공무직-마이페이지-합격자조회
*  @MenuPath    pa_ore_oew_rm
*  @FileName 	pa_ore_oewrm30_m02.xfdl
*  @Creator 	
*  @CreateDate 	2022.09.06
*  @Desction    온라인통합채용-교육공무직-마이페이지-합격자조회
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.09.01    		 	        최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs"
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

	// 컨텐츠높이
	this.divScreTltHeight  = this.divScreTlt.height;		// 제목
	this.divScreTotalHeight = this.divScreTotal.height;		// 성적
	this.divScreSbjtHeight =this.divScreSbjt.height;		// 과목점수
	this.screSfc1Cd1Yn = "N"; // 과목별성적 표시여부
	
	// 성적 리셋
	this.hideScreDiv();
		
	// 휴대전화번호 필수 로그인 세션 체크
	var logInChkParam = {
		 redirectUrl : 'pa_ore_oew_rm::ore_oewrm30_m02.xfdl' // 현재 PAGE URL
		, redirectMenuId : '4003' // 교육공무직 합격조회 메뉴 ID
	};
	// 휴대전화번호 세션 없을 시 로그인 페이지이동
	this.isEssenMblTelnoLogin(logInChkParam);

	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);

	// 선택 시도교육청코드
	var sCddcCd = this.smfGetCddcCode();

	// 시도교육청 앞 3자리 = 시도교육청 구분코드
	this.dsSearch.setColumn(0, "cddcScCd", sCddcCd.slice(0,3));
	this.dsSearch.setColumn(0, "cddcCd", sCddcCd);
	//  본인인증
	this.dsSearch.setColumn(0,"applpFlnm", this.smfGetSessionValue('userNm'));
	var brdt = this.smfGetSessionValue('brdt');
	if(this.smfIsNull(brdt)){
		 brdt = this.applpRrnoToBrdt(nexacro.base64Decode(this.smfGetSessionValue('userRrno')));
	}
	this.dsSearch.setColumn(0,"applpBrdt", brdt);
	//this.dsSearch.setColumn(0,"mblTelno" , this.smfGetSessionValue('mblTelNo'));
	this.dsSearch.setColumn(0,"pafrUserId" , this.smfGetSessionValue('userDtcNo'));
	// 내 지원서 목록
	this.fnSearchRcptList();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid, errcd, errmsg){

};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 // 지원서 목록 검색
this.fnSearchRcptList = function(obj, e)
{
	// 지원서목록조회
	this.smfSearchService('listRcpt') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			var applpFlnm = this.dsSearch.getColumn(0,"applpFlnm")+"("+this.dsSearch.getColumn(0,"applpBrdt")+")님.";
			this.divSummary.form.staSummary.set_text(applpFlnm+" 합격 조회를 해주세요.");

			// 지원서 수
			var rcptCnt =  this.dsResultRcpt.getRowCount();
			if(rcptCnt <1){

				this.divSearch.form.cboAppoExm.set_enable(false);
				this.divSearch.form.btnReportView.set_enable(false);
				this.divSummary.form.staSummary.set_text(this.smfGetCddcName()+" 응시시험에 응시 내역이 없습니다.");
				this.divCont.form.divContents.form.staContents.set_text(this.smfGetCddcName()+" 응시시험 응시자가 아닙니다.");
				
			}else{
				// 합격확인영역
				this.divCont.form.divContents.form.staContents.set_text("응시시험을 선택 후 합격 조회를 해주세요.");
			}	
	});
};

//합격자 검색
this.fnSearch = function(obj, e){

	// 성적 리셋
	this.hideScreDiv();

	this.dsResult.clearData();
	var rcptNo = this.divSearch.form.cboAppoExm.value;

	if(this.smfIsNull(rcptNo)){
		this.divSearch.form.cboAppoExm.setFocus();
		this.smfAlert("응시 시험을 선택 해주세요.");
		return;
	}
	
	var i      = this.dsResultRcpt.findRow("rcptNo", rcptNo);
	this.dsSearch.setColumn(0, "rcptNo", rcptNo); // 접수번호
	this.dsSearch.setColumn(0, "empmnExamId", this.dsResultRcpt.getColumn(i, 'appoExamId'));  // 채용시험 ID
	
	//*** 응시일자 조회 용도 ****//
	this.dsSearch.setColumn(0,"orgCd"              , this.dsSearch.getColumn(0, 'cddcCd'));
	this.dsSearch.setColumn(0,"eduPubsvCtpvOcptCd" , this.dsResultRcpt.getColumn(i, 'eduPubsvCtpvOcptCd'));
	this.dsSearch.setColumn(0,"dstrtCd"            , this.dsResultRcpt.getColumn(i, 'dstrtCd'));
	

	var applpFlnm = this.dsSearch.getColumn(0,"applpFlnm")+"("+this.dsSearch.getColumn(0,"applpBrdt")+")님. ";
	
	this.smfSearchService('listPass') 
	
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;

			if(this.smfIsNull(this.dsResult.getColumn(0,"aplemDsgnNo"))){
			
				this.divSummary.form.staSummary.set_text(applpFlnm+ '지원내역이 없습니다.');
				this.divCont.form.divContents.form.staContents.set_text('');
				this.divCont.form.staAplemDsgnNo.set_text('');
			}else{
			
				var txtHeads = applpFlnm + this.dsResult.getColumn(0,"empmnExamNm")+" [직종] "+this.dsResult.getColumn(0,"eduPubsvCtpvOcptNm")+"[지역] "+this.dsResult.getColumn(0,"dstrtNm");
				this.divSummary.form.staSummary.set_text(txtHeads);
				this.divCont.form.staAplemDsgnNo.set_text("(응시번호 : " + this.dsResult.getColumn(0,"aplemDsgnNo") + ")");
					
				if ( this.dsResult.getColumn(0,"lastDgr") == 0){
					this.divCont.form.divContents.form.staContents.set_text('합격자 확인 기간이 아닙니다.');
				}else{
					var pass = "";
					
					if(this.dsResult.getColumn(0,"lastDgr") == "1"){
						if(this.dsResult.getColumn(0,"pass1Yn") == "-"){
							this.divCont.form.divContents.form.staContents.set_text('합격자 확인 기간이 아닙니다.');
							return;
						}else{
						
							pass = this.dsResult.getColumn(0,"pass1Yn") == 'Y' ? "합격을 진심으로 축하합니다." : "합격자 명단에 없습니다." ;
								this.screResultView(); //성적조회 				
						}
					}else if(this.dsResult.getColumn(0,"lastDgr") == "2"){
						if(this.dsResult.getColumn(0,"pass2Yn") == "-"){
							this.divCont.form.divContents.form.staContents.set_text('합격자 확인 기간이 아닙니다.');
							return;
						}else{
							pass = this.dsResult.getColumn(0,"pass2Yn") == 'Y' ? "2차 합격을 진심으로 축하합니다." : "2차 합격자 명단에 없습니다." ;
						}
					}else{
						if(this.dsResult.getColumn(0,"pass3Yn") == "-"){
							this.divCont.form.divContents.form.staContents.set_text('합격자 확인 기간이 아닙니다.');
							return;
						}else{
							pass = this.dsResult.getColumn(0,"pass3Yn") == 'Y' ? "3차 합격을 진심으로 축하합니다." : "3차 합격자 명단에 없습니다." ;
						}
					}
					this.divCont.form.divContents.form.staContents.set_text(pass);
				}
				
			}
			
	});

};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// 합격자 조회
this.divSummary00_btnReportView_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 합격자 조회한다.
	this.fnSearch();	
};


/**
 * 성적조회 결과 표시
 */
 this.screResultView = function()
 {
	
	//표시여부
	this.screSfc1Cd1Yn = "N"; // 과목별성적 표시여부

	//  성적조회 항목
	var screSfc1Cd1Yn = this.dsResultScre.getColumn(0, 'screSfc1Cd1Yn');
	
	// 과목별 성적 영역 표시
	if(screSfc1Cd1Yn === "Y"){
		
		// 총점영역
		this.divScreTotal.setOffsetHeight(this.divScreTotalHeight);
		this.divScreTotal.set_visible(true);
	
		// 제목영역 
		this.divScreTlt.setOffsetHeight(this.divScreTltHeight);
		this.divScreTlt.set_visible(true);

		// 과목점수
		this.divScreSbjt.setOffsetHeight(this.divScreSbjtHeight);
		this.divScreSbjt.set_visible(true);
		this.divScreSbjt.form.grdScre.set_top(40);
		
	}else{ // N 설정시 과목별 성적 위치조정
		// 성적 리셋
		this.hideScreDiv();
	}

	// 전체영역  RESET
	this.smfResetScroll(this);
 }

 /**
 * 성적영역 비표시
 */
 this.hideScreDiv = function()
 {
		// 필기성적 재설정 
		this.divScreTotal.form.staScreTotal.set_text("");

		// 제목
		this.divScreTlt.setOffsetHeight(0);
		this.divScreTlt.set_visible(false);

		// 총점 비표시
		this.divScreTotal.setOffsetHeight(0);
		this.divScreTotal.set_visible(false);

		// 과목별성적비표시
		this.divScreSbjt.setOffsetHeight(0);
		this.divScreSbjt.set_visible(false);
		// 전체영역  RESET
		this.smfResetScroll(this);	
 }]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listPass</Col>
