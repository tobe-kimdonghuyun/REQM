/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.pv_params = this.smfGetPopupParams();
	
	// Form의 default 초기처리를 한다.
	this.smfInitPopup(this);
	
	// 공통코드
	// dsCarrDtlScCd : 경력구분 | dsCarrExclScCd : 경력제외구분 | dsSrclsCarrScCd : 경력분류
	this.smfCodeList("code", [this.dsCarrDtlScCd , this.dsCarrExclScCd, this.dsSrclsCarrScCd ])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.dsCarrExclScCd.filter("unyCdValue != '3' && unyCdValue != '4'");
			
			if ( this.pv_params.popid == "1"){
				this.set_titletext("지방공무원-경력합산신청-공무원경력 팝업");
				//this.divContent00.form.staContent00.set_text("*공무원경력구분");
				this.dsSrclsCarrScCd.filter("unyCdValue == '11'");
				this.dsMain.setColumn(0,"srclsCarrScCd","11");
				this.divContent00.form.cboSrclsCarrSc.set_readonly(true);
				this.dsCarrDtlScCd.filter(" (unyCdValue >= 41 && unyCdValue <=43) || unyCdValue == '' ");
				
			}else{
				//유사경력 
				this.set_titletext("지방공무원-경력합산신청-유사경력 팝업");
				//this.divContent00.form.staContent00.set_text("*유사경력구분");
				this.dsSrclsCarrScCd.filter("unyCdValue == '22'|| unyCdValue == '41' || unyCdValue == ''");
				this.dsMain.setColumn(0,"srclsCarrScCd","");
				this.dsCarrDtlScCd.filter(" (unyCdValue >= 51 && unyCdValue <= 66) || unyCdValue == '' ");
			}
		})		
		.run();
		
	// 파일 업로드
	this.divContent02.form.div01.form.divFileContent.UPLOAD_UploadComplete  = this.fnFileUploadCompleteCallback;
	this.divContent02.form.div01.form.divFileContent.UPLOAD_OnError         = this.fnFileUploadErrorCallback;
	this.divContent02.form.div01.form.divFileContent.UPLOAD_AfterAddFile    = this.fnFileUploadChangeCallback;     
	this.divContent02.form.div01.form.divFileContent.UPLOAD_Form            = this;
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid, errcd, errmsg){

};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 파일 업로드 성공 콜백
this.fnFileUploadCompleteCallback = function(obj, paramObj, objResultDataset)
{
	this.divContent02.form.div01.form.divFileContent.form.fnSetUploadCompleteState(obj,paramObj);
	this.dsMain.setColumn(0, "fileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
};

// 파일 업로드 실패 콜백
this.fnFileUploadErrorCallback = function(obj, paramObj)
{
	//this.smfAlert('파일 업로드에 실패 하였습니다.');
};

// 파일 업로드 변경 콜백
this.fnFileUploadChangeCallback = function(obj, paramObj, sCustomValue, sFileName, nFileSize)
{
	this.divContent02.form.div01.form.divFileContent.form.fnFileUpload();	
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
//경력제외기간 행 추가 
this.divContent02_btnAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var nRow = this.dsDtl.addRow();	
	this.divContent02.form.grdExcl.setFocus();
	this.divContent02.form.grdExcl.setCellPos(1);
	this.dsDtl.set_rowposition(nRow);
	this.divContent02.form.grdExcl.showEditor();
};

//경력제외기간 행 삭제
this.divContent02_btnDel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 데이터 없을경우
	if(this.dsDtl.rowcount < 1){
		this.smfAlert("삭제 대상이 없습니다.");
		return;
	}
	// 체크박스 ON ARRAY 
	var chkIdxArray = this.dsDtl.extractRows("_chk ==1");
	
	if(this.isNil(chkIdxArray)){ 
		this.smfAlert("삭제 대상을 선택 해주세요. ");
		return;
	}
	
	// 확인 메시지 출력
	this.smfConfirm("삭제 하시겠습니까?", function(result){
		if(result.confirmResult){
			// 데이터삭제
			this.dsDtl.deleteMultiRows(chkIdxArray);
		}
	});	
};

// 등록 
this.divContent04_btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//필수 값 체크 
	var components = this.divContent00.form.components;
	for(var i=0; i < components.length; i++){
		if(components[i].cssclass == "essential"){
			if(this.smfIsNull(components[i].value)){
				components[i].setFocus();
				var message =  this.dsValidation.lookup( "code" , components[i].name , "name" );
				this.smfAlert('CM006', [message], "" ); 
				return;	
			}
		}
	}
	
	var sWorkBgngYmd  = this.dsMain.getColumn(0, "workBgngYmd");
	var sWorkEndYmd   = this.dsMain.getColumn(0, "workEndYmd"); 
	for(var i =0; i < this.dsDtl.rowcount; i++){
		var carrExclScCd = this.dsDtl.getColumn(i, "carrExclScCd");
		var workBgngYmd  = this.dsDtl.getColumn(i, "workBgngYmd");
		var workEndYmd   = this.dsDtl.getColumn(i, "workEndYmd");
		
		if(this.smfIsNull(carrExclScCd)){
			this.smfAlert('CM006', ["제외구분"], this.fnMessageCallback); 
			return;	
		}
		if(this.smfIsNull(workBgngYmd)){
			this.smfAlert('CM006', ["제외시작일"], this.fnMessageCallback); 
			return;	
		}
		if(this.smfIsNull(workEndYmd)){	
			this.smfAlert('CM006', ["제외종료일"], this.fnMessageCallback); 
			return;	
		}	
		
		////제외기간은 경력기간 사이여야합니다.
		if( sWorkBgngYmd > workBgngYmd || sWorkEndYmd < workBgngYmd 
		 || sWorkBgngYmd > workEndYmd || sWorkEndYmd < workEndYmd 
		){
			this.smfAlert('제외기간은 경력기간 사이여야합니다.'); 
			return;	
		}
	}

	// 입력값 부모창 전달
	this.smfSendResponseToOpener({
		dsMainP  : this.dsMain,
		dsDtlP: this.dsDtl
	});
	this.close(true);
};

// 취소 버튼 
this.divContent04_btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};

// 날짜 변경 시 이벤트 
this.ds_cancolumnchange = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	var workBgngYmd = obj.getColumn(e.row, "workBgngYmd");  //시작일
	var workEndYmd  = obj.getColumn(e.row, "workEndYmd");   //종료일 
	if(e.columnid == "workBgngYmd"){
		workBgngYmd = e.newvalue;
	}else if(e.columnid == "workEndYmd"){
		workEndYmd = e.newvalue;
	}
	if(e.columnid == "workBgngYmd" || e.columnid == "workEndYmd" ){
		if(!this.smfIsNull( e.newvalue )){
			if(e.newvalue > this.smfToday()){
				this.smfAlert('미래일자를 입력할 수 없습니다.');
				return false;
			}
		}
	}
	if( !this.smfIsNull(workBgngYmd) && !this.smfIsNull(workEndYmd) ){
		if ( workBgngYmd > workEndYmd ){
			this.smfAlert("시작일이 종료일보다 큽니다."); 
			return false;
		}
	}	
};

// 그리드 enter 이벤트 
this.divContent02_grdExcl_onenterdown = function(obj:nexacro.Grid,e:nexacro.GridEditEventInfo)
{
	if(e.cell != 3 ){
		this.divContent02.form.grdExcl.setCellPos(e.cell+1);
	}else{
		if( this.dsDtl.rowcount != this.dsDtl.rowposition+1 ){
			this.dsDtl.set_rowposition(this.dsDtl.rowposition+1);
			this.divContent02.form.grdExcl.setCellPos(1);
		}
	}
};

// 그리드 헤더클릭 공통
this.grd_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var columnName = obj.getCellProperty("body",e.cell,"text");
	if ("bind:_chk" == columnName){
		// 체크박스전체클릭
		this.smfToggleChkHeader(obj, e); 
	}	
};

//시간제 여부 변경 시 이벤트 
this.divContent00_rdoBthWorkYn_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	if(e.postvalue == "Y"){
		this.divContent00.form.edtWperWorkH.set_enable(true);
	}else{
		this.divContent00.form.edtWperWorkH.set_enable(false);
		this.dsMain.setColumn(0,"wperWorkHr", "");
	}
};

// 경력분류 변경에 따른 경력구분 변경 
this.divContent00_cboSrclsCarrSc_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	if(e.postvalue == "22"){
		//유사경력 : substr(0,1) == '5'
		this.dsCarrDtlScCd.filter(" (unyCdValue >= '51' && unyCdValue <= '53') || unyCdValue == '' ");
	}else if(e.postvalue == "41"){
		//기타경력 : substr(0,1) == '6'
		this.dsCarrDtlScCd.filter(" (unyCdValue >= '61' && unyCdValue <= '66') || unyCdValue == '' ");
	}
};
]]></Script>
    <Bind>
      <BindItem id="item2" compid="divContent00.form.edtWorkInstNm" propid="value" datasetid="dsMain" columnid="workInstNm"/>
