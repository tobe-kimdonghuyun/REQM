      <BindItem id="item0" compid="divContent00.form.cboCarrDtlScCd" propid="value" datasetid="dsMain" columnid="carrDtlScCd"/>
      <BindItem id="item1" compid="divContent00.form.calWorkfDt" propid="value" datasetid="dsMain" columnid="workBgngYmd"/>
      <BindItem id="item4" compid="divContent00.form.calWorktDt" propid="value" datasetid="dsMain" columnid="workEndYmd"/>
      <BindItem id="item5" compid="divContent00.form.chkRtrmDdIncls" propid="value" datasetid="dsMain" columnid="rtrmDdInclsYn"/>
      <BindItem id="item6" compid="divContent00.form.edtWperWorkH" propid="value" datasetid="dsMain" columnid="wperWorkHr"/>
      <BindItem id="item7" compid="divContent00.form.rdoBthWorkYn" propid="value" datasetid="dsMain" columnid="bthWorkYn"/>
      <BindItem id="item8" compid="divContent00.form.cboSrclsCarrSc" propid="value" datasetid="dsMain" columnid="srclsCarrScCd"/>
    </Bind>
