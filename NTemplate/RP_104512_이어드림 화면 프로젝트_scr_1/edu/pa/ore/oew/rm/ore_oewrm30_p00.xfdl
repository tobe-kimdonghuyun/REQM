              <Static id="staGd05" taborder="3" left="0" height="35" cssclass="sta_GD_Size" text="35" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" bottom="-2" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staGd07" taborder="4" top="35" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="35" text="30" right="0" initvalueid="ivStcAccessibilityOff"/>
