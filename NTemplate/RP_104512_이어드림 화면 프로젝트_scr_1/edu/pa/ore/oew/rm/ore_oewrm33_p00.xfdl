<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmTemp01" width="840" height="840" titletext="동의서" onload="form_onload" canlayoutchange="btnCancel_onclick">
    <Layouts>
      <Layout height="840" width="840" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="div00" taborder="1" left="20" height="196" cssclass="div_WF_InfoBOX" right="20" top="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="sta07" taborder="0" left="19" top="54" height="117" text="근로계약에 따라 다음 사항을 준수할 것을 엄숙히 서약합니다. (                        )&#13;&#10;1. 맡은바 직무를 충실히 수행하고, 신의에 따라 성실하게 근무한다.&#13;&#10;2. 근무 중 알게 된 모든 기밀사항은 계약기간중은 물론, 계약만료 후에도 외부에 일체 누설하지 않는다.&#13;&#10;3. 근무기간동안 사용자의 제규정 및 관계 법령을 준수하고 사용부서의 장의 업무상 지시에 따른다.&#13;&#10;4. 출퇴근 시간 및 근무기관의 제반 근무수칙을 엄수한다.&#13;&#10;5. 근무기관의 명예와 신용을 손상하거나 업무관련 자료를 유출하는 일이 없도록 한다." wordWrap="char" right="35" initvalueid="ivStcAccessibilityOn" font="normal 11pt/normal &quot;Arial&quot;" usedecorate="true"/>
              <Static id="staTlt00" taborder="1" left="20" top="19" height="36" text="서약서" wordWrap="char" width="548" cssclass="sta_WF_WorkTit" initvalueid="ivStcAccessibilityOn" accessibilitylabel="교육부, 시도교육청내 자료 활용 동의서"/>
              <CheckBox id="chkVal" taborder="2" text="동의여부" left="429" top="54" width="90" height="23" initvalueid="ivChkNormal" font="normal 11pt/normal &quot;Arial&quot;"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="div00_00" taborder="2" text="div_00" left="0" background="whitesmoke" bottom="0" height="50" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Button id="btnOk" taborder="0" text="동의" left="44.50%" width="80" defaultbutton="true" escapebutton="true" bottom="10" height="30" onclick="btnConfirm_onclick" initvalueid="ivBtnAccessibilityButton"/>
            </Layout>
            <Layout name="default0">
              <Button id="btnOk" taborder="0" text="확인" left="40%" top="20" width="108" height="50" defaultbutton="true" escapebutton="true"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="div01" taborder="3" left="20" height="514" cssclass="div_WF_InfoBOX" right="20" top="226" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staTlt00" taborder="0" left="20" top="19" height="36" text="개인정보 수집 및 이용 동의서" wordWrap="char" width="548" cssclass="sta_WF_WorkTit" initvalueid="ivStcAccessibilityOn" accessibilitylabel="교육부, 시도교육청내 자료 활용 동의서"/>
              <Static id="staCursor" taborder="1" left="20" top="60" width="216" height="111" cssclass="sta_WF_DtlLabel" text="개인정보의 수집 이용 목적" font="normal 12pt/normal &quot;Arial&quot;"/>
              <Static id="staCursor1" taborder="2" left="235" top="60" width="538" height="111" cssclass="sta_WF_DetailBg" text="1. 개인 식별의 목적&#13;&#10;2. 인사·급여관리(인사이동, 급여지급 등) 및 4대보험 가입, 연말정산, 외부교육의 목적&#13;&#10;3.  개인정보의 제3자 제공&#13;&#10;  - 개인정보를 제공받는 자 : 국세청(관할 지방세무서), 관공서(교육부, 고용노동부, 국민&#13;&#10;    연금공단, 국민건강보험공단, 근로복지공단 등), 각종 인사관리 관련 위탁(교육)기관" accessibilityenable="true" wordWrap="none" font="normal 10pt/normal &quot;Arial&quot;"/>
              <Static id="staCursor00" taborder="3" left="20" top="169" width="216" height="174" cssclass="sta_WF_DtlLabel" text="수집하는 개인정보 항목" font="normal 12pt/normal &quot;Arial&quot;"/>
              <Static id="staCursor1_00" taborder="4" left="235" top="169" width="538" height="174" cssclass="sta_WF_DetailBg" text="&#13;&#10;1. 개인식별정보(성명, 증명사진)&#13;&#10;2. 고유식별정보(주민등록번호, 외국인등록번호)&#13;&#10;3. 연락정보(주소, 전화번호, 휴대전화번호, 전자우편주소)&#13;&#10;4. 학력사항(재학기간, 학교명, 학과, 학위)&#13;&#10;5. 경력사항(근무처, 근무기간, 직종, 업무)&#13;&#10;6. 병역사항(복무기간, 병과)&#13;&#10;7. 가족사항(가족관계, 성명, 생년월일)&#13;&#10;8. 기타사항(자격, 면허, 장애여부, 장애유형, 장애구분, 장애인등급)&#13;&#10;" accessibilityenable="true" wordWrap="none" font="normal 10pt/normal &quot;Arial&quot;"/>
              <Static id="staCursor01" taborder="5" left="20" top="342" width="216" height="45" cssclass="sta_WF_DtlLabel" font="normal 12pt/normal &quot;Arial&quot;" text="개인정보의 보유 및 이용기간"/>
              <Static id="staCursor1_01" taborder="6" left="235" top="342" width="538" height="45" cssclass="sta_WF_DetailBg" text="위에 기재한 수집 이용의 목적을 모두 달성할 때까지 보유 이용 후, 법령에 따라 해당 &#13;&#10;개인 정보를 보존해야 하는 의무가 존재하지 않게 된 것이 확인된 때에 파기" accessibilityenable="true" wordWrap="none" font="normal 10pt/normal &quot;Arial&quot;"/>
              <Static id="staCursor01_00" taborder="7" left="20" top="386" width="216" height="43" cssclass="sta_WF_DtlLabel" font="normal 12pt/normal &quot;Arial&quot;" text="동의거부에 따른 불이익"/>
              <Static id="staCursor1_01_00" taborder="8" left="235" top="386" width="538" height="43" cssclass="sta_WF_DetailBg" text="인사·급여제도 운영 시 정보부재로 인한 불이익" accessibilityenable="true" wordWrap="none" font="normal 10pt/normal &quot;Arial&quot;"/>
              <Static id="sta07" taborder="9" left="21" top="455" height="23" text="위 내용을 충분히 숙지하고 개인정보의 수집 및 이용에 대해(                        )&#13;&#10;" wordWrap="char" right="33" initvalueid="ivStcAccessibilityOn" font="normal 11pt/normal &quot;Arial&quot;" usedecorate="true" textAlign="center"/>
              <CheckBox id="chkVal" taborder="10" text="동의여부" left="539" top="455" width="90" height="23" initvalueid="ivChkNormal" font="normal 11pt/normal &quot;Arial&quot;"/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">saveAgre</Col>
            <Col id="inDatasets">dsMain=dsMain</Col>
            <Col id="url">ore_oew_rm33_004.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsMain">
        <ColumnInfo>
          <Column id="searchKey" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-교육공무직-마이페이지-근로계약서 동의서
*  @MenuPath    pa_ore_oew_rm
*  @FileName 	pa_ore_oewrm33_p00.xfdl
*  @Creator 	
*  @CreateDate 	2023.2.7
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2023.2.7   	 	         최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitPopup(this);
	
	this.pv_params  = this.smfGetPopupParams();
 	var searchKey  = this.pv_params.searchKey;
	this.dsMain.setColumn(0,"searchKey", searchKey);

};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// 확인버튼 클릭	
this.btnConfirm_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if( ! this.div00.form.chkVal.value ) {
		this.div00.form.chkVal.setFocus();
		this.smfAlert('서약서에 동의 후 진행 가능 합니다.');
		return false;
	}
	if( ! this.div01.form.chkVal.value ) {
		this.div01.form.chkVal.setFocus();
		this.smfAlert('개인정보 수집 및 이용 동의서에 동의 후 진행 가능 합니다.');
		return false;
	}

	this.smfSaveService("saveAgre")
		.showConfirm(false)
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.smfSendResponseToOpener();
			this.close(true);
	});	
};

]]></Script>
  </Form>
</FDL>
