              <Button id="btnReportView" taborder="2" text="응시표조회" left="cboAppoExm:19" top="13" width="115" height="35" onclick="btnReportView_onclick" initvalueid="ivBtnAccessibilityButton" cssclass="btn_WF_Search03"/>
