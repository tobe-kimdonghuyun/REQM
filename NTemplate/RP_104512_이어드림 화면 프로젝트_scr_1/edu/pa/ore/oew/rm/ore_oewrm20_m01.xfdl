                <Layouts>
                  <Layout>
                    <Static id="staContent00" taborder="0" text="테스트(891212)님. " top="12" height="34" cssclass="sta_WF_InfoTit02" initvalueid="ivStcAccessibilityOn" textAlign="left" width="181" left="20" onclick="divSearch_staSubTltInfo00_onclick" font="16px/1.5 &quot;Noto Sans KR&quot;,&quot;NotoSansKR-Regular&quot;,&quot;Malgun Gothic&quot;,&quot;Arial&quot;,&quot;MS PGothic&quot;"/>
                    <Static id="staContent01" taborder="1" text="‘2022년 지방공무직(교육행정/9급)‘  수험번호 000-000-0000 " top="12" height="34" cssclass="sta_WF_InfoTit02" initvalueid="ivStcAccessibilityOn" textAlign="left" width="790" left="staContent00:7" onclick="divSearch_staSubTltInfo00_onclick" font="16px/1.5 &quot;Noto Sans KR&quot;,&quot;NotoSansKR-Regular&quot;,&quot;Malgun Gothic&quot;,&quot;Arial&quot;,&quot;MS PGothic&quot;"/>
