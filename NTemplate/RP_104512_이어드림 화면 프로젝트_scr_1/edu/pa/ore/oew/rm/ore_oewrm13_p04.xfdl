                      <Cell col="2" text="*부터"/>
                      <Cell col="3" text="*까지" cssclass="LineNo"/>
                    </Band>
                    <Band id="body">
                      <Cell text="bind:_chk" edittype="checkbox" displaytype="checkboxcontrol"/>
                      <Cell col="1" displaytype="combocontrol" edittype="combo" combodataset="dsAcbgExclScCd" combocodecol="unyCdValue" combodatacol="unyCdValueNm" text="bind:acbgExclScCd" comboautoselect="true"/>
