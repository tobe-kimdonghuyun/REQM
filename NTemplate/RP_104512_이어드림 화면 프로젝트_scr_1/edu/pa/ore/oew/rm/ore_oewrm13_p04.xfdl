    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-교원임용(중등)-경력합산신청-대학원정보 팝업
*  @MenuPath    pa_ore_oew_rm
*  @FileName 	pa_ore_oewrm13_p04.xfdl
*  @Creator 	shhan
*  @CreateDate 	2022.09.13
*  @Desction    온라인통합채용-교원임용(중등)-경력합산신청-대학원정보 팝업
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.09.13    	shhan	 	        최초 생성 
*  2022.12.12       최정민 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitPopup(this);
	
	// 공통코드
	// dsDgriCd : 학위 | dsLrnMthScCd : 계절제(야간)여부 | dsAcbgExclScCd : 수업제외구분 
	this.smfCodeList("code", [this.dsDgriCd, this.dsLrnMthScCd , this.dsAcbgExclScCd  ])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.dsDgriCd.filter("unyCdValue != '1' && unyCdValue  !=  '2' &&  unyCdValue  !=  '8'");
		})		
		.run();
		
	// 파일 업로드
	this.divContent02.form.div01.form.divFileContent.UPLOAD_UploadComplete  = this.fnFileUploadCompleteCallback;
	this.divContent02.form.div01.form.divFileContent.UPLOAD_OnError         = this.fnFileUploadErrorCallback;
	this.divContent02.form.div01.form.divFileContent.UPLOAD_AfterAddFile    = this.fnFileUploadChangeCallback;     
	this.divContent02.form.div01.form.divFileContent.UPLOAD_Form            = this;
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid, errcd, errmsg){

}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 파일 업로드 성공 콜백
this.fnFileUploadCompleteCallback = function(obj, paramObj, objResultDataset)
{
	this.divContent02.form.div01.form.divFileContent.form.fnSetUploadCompleteState(obj,paramObj);
	this.dsMain.setColumn(0, "fileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
};

// 파일 업로드 실패 콜백
this.fnFileUploadErrorCallback = function(obj, paramObj)
{
	//this.smfAlert('파일 업로드에 실패 하였습니다.');
};

// 파일 업로드 변경 콜백
this.fnFileUploadChangeCallback = function(obj, paramObj, sCustomValue, sFileName, nFileSize)
{
	this.divContent02.form.div01.form.divFileContent.form.fnFileUpload();	
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
//경력제외기간 행 추가 
this.divContent02_btnAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var nRow = this.dsDtl.addRow();	
	this.divContent02.form.grdExcl.setFocus();
	this.divContent02.form.grdExcl.setCellPos(1);
	this.dsDtl.set_rowposition(nRow);
	this.divContent02.form.grdExcl.showEditor();
};

//경력제외기간 행 삭제
this.divContent02_btnDel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 데이터 없을경우
	if(this.dsDtl.rowcount < 1){
		this.smfAlert("삭제 대상이 없습니다.");
		return;
	}
	// 체크박스 ON ARRAY 
	var chkIdxArray = this.dsDtl.extractRows("_chk ==1");
	
	if(this.isNil(chkIdxArray)){ 
		this.smfAlert("삭제 대상을 선택 해주세요. ");
		return;
	}
	
	// 확인 메시지 출력
	this.smfConfirm("삭제 하시겠습니까?", function(result){
		if(result.confirmResult){
			// 데이터삭제
			this.dsDtl.deleteMultiRows(chkIdxArray);
		}
	});	
};

// 등록 
this.divContent04_btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//필수 값 체크 
	var components = this.divContent00.form.components;
	for(var i=0; i < components.length; i++){
		if(components[i].cssclass == "essential"){
			if(this.smfIsNull(components[i].value)){
				components[i].setFocus();
				var message =  this.dsValidation.lookup( "code" , components[i].name , "name" );
				this.smfAlert('CM006', [message], "" ); 
				return;	
			}
		}
	}
	
	var sWorkBgngYmd  = this.dsMain.getColumn(0, "etrcYmd");
	var sWorkEndYmd   = this.dsMain.getColumn(0, "grdtnYmd"); 
	
	for(var i =0; i < this.dsDtl.rowcount; i++){
		var acbgExclScCd = this.dsDtl.getColumn(i, "acbgExclScCd");
		var etrcYmd      = this.dsDtl.getColumn(i, "etrcYmd");
		var grdtnYmd     = this.dsDtl.getColumn(i, "grdtnYmd");
		
		if(this.smfIsNull(acbgExclScCd)){
			this.smfAlert('CM006', ["수업제외구분"], this.fnMessageCallback); 
			return;	
		}
		if(this.smfIsNull(etrcYmd)){
			this.smfAlert('CM006', ["수업제외시작일"], this.fnMessageCallback); 
			return;	
		}
		if(this.smfIsNull(grdtnYmd)){	
			this.smfAlert('CM006', ["수업제외종료일"], this.fnMessageCallback); 
			return;	
		}	
		
		////제외기간은 경력기간 사이여야합니다.
		if( sWorkBgngYmd > etrcYmd || sWorkEndYmd < etrcYmd 
		 || sWorkBgngYmd > grdtnYmd || sWorkEndYmd < grdtnYmd 
		){
			this.smfAlert('제외기간은 수업기간 사이여야합니다.'); 
			return;	
		}
	}
	

	// 입력값 부모창 전달
	this.smfSendResponseToOpener({
		dsMainP  : this.dsMain,
		dsDtlP: this.dsDtl
	});
	this.close(true);
};

// 취소 버튼 
this.divContent04_btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};

// 날짜 변경 시 이벤트 
this.ds_cancolumnchange = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	var etrcYmd = obj.getColumn(e.row, "etrcYmd");  //시작일
	var grdtnYmd  = obj.getColumn(e.row, "grdtnYmd");   //종료일 
	
	if(e.columnid == "etrcYmd"){
		etrcYmd = e.newvalue;
	}else if(e.columnid == "grdtnYmd"){
		grdtnYmd = e.newvalue;
	}
	
	if( !this.smfIsNull(etrcYmd) && !this.smfIsNull(grdtnYmd) ){
		if ( etrcYmd > grdtnYmd ){
			this.smfAlert("시작일이 종료일보다 큽니다."); 
			return false;
		}
	}
	
	if(e.columnid == "etrcYmd" || e.columnid == "grdtnYmd" ){
		if(!this.smfIsNull( e.newvalue )){
			if(e.newvalue > this.smfToday()){
				// 확인 메시지 출력
				this.smfConfirm("미래일자를 입력하셨습니다.\n그래도 진행을 하시겠습니까?", function(result){
					if(!result.confirmResult){ //취소 = 이전 값으로 복구
						//01. 값 원복으로 인해 이벤트가 무한으로 발생하여 삭제.
						obj.removeEventHandler("cancolumnchange", this.ds_cancolumnchange, this); 
						//02. 값 원복
						(e.columnid == "etrcYmd") ? obj.setColumn(e.row, "etrcYmd", e.oldvalue) : obj.setColumn(e.row, "grdtnYmd", e.oldvalue);
						//03. 값 원복 후, 삭제한 이벤트 추가.
						obj.addEventHandler("cancolumnchange", this.ds_cancolumnchange, this);
						return false;
					}
				});
			}
		}
	}
};

// 그리드 enter 이벤트 
this.divContent02_grdExcl_onenterdown = function(obj:nexacro.Grid,e:nexacro.GridEditEventInfo)
{
	if(e.cell != 3 ){
		this.divContent02.form.grdExcl.setCellPos(e.cell+1);
	}else{
		if( this.dsDtl.rowcount != this.dsDtl.rowposition+1 ){
			this.dsDtl.set_rowposition(this.dsDtl.rowposition+1);
			this.divContent02.form.grdExcl.setCellPos(1);
		}
	}
};

// 그리드 헤더클릭 공통
this.grd_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var columnName = obj.getCellProperty("body",e.cell,"text");
	if ("bind:_chk" == columnName){
		// 체크박스전체클릭
		this.smfToggleChkHeader(obj, e); 
	}	
};]]></Script>
    <Bind>
      <BindItem id="item0" compid="divContent00.form.cboDgriCd" propid="value" datasetid="dsMain" columnid="dgriCd"/>
      <BindItem id="item3" compid="divContent00.form.edtShlNm" propid="value" datasetid="dsMain" columnid="shlNm"/>
      <BindItem id="item4" compid="divContent00.form.cboIrnMthScCd" propid="value" datasetid="dsMain" columnid="lrnMthScCd"/>
      <BindItem id="item5" compid="divContent00.form.edtLwetItrtGrd" propid="value" datasetid="dsMain" columnid="lwetItrtGrd"/>
      <BindItem id="item1" compid="divContent00.form.calEtrcYmd" propid="value" datasetid="dsMain" columnid="etrcYmd"/>
      <BindItem id="item2" compid="divContent00.form.calGrdtnYmd" propid="value" datasetid="dsMain" columnid="grdtnYmd"/>
    </Bind>
  </Form>
</FDL>
