// 군경력정보 삭제
this.divContent02_tabContent00_Tabpage1_btnDel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 데이터 없을경우
	if(this.dsTab1.rowcount < 1){
		this.smfAlert("삭제 대상이 없습니다.");
		return;
	}
	// 체크박스 ON ARRAY 
	var chkIdxArray = this.dsTab1.extractRows("_chk ==1");
	
	if(this.isNil(chkIdxArray)){ 
		this.smfAlert("삭제 대상을 선택 해주세요. ");
		return;
	}
	
	// 확인 메시지 출력
	this.smfConfirm("삭제 하시겠습니까?", function(result){
		if(result.confirmResult){
		
			// 제외내역 삭제 
			for( var i=0; i < chkIdxArray.length; i++ ){
				var appoBfrCarrSn = this.dsTab1.getColumn( chkIdxArray[i] , "appoBfrCarrSn" ); //임용이전경력일련번호
				var dtArray = this.dsTab1Ex.extractRows("appoBfrCarrSn =='"+appoBfrCarrSn+"'");
				this.dsTab1Ex.deleteMultiRows(dtArray);
			}
			// 신청내역 삭제 
			this.dsTab1.deleteMultiRows(chkIdxArray);
			
			// 일련번호 다시 채번 
			for( var i=0; i < this.dsTab1.rowcount; i++ ){
				var appoBfrCarrSn = this.dsTab1.getColumn( i , "appoBfrCarrSn" ); 
				var dtArray = this.dsTab1Ex.extractRows("appoBfrCarrSn =='"+appoBfrCarrSn+"'");
				for( var j=0; j < dtArray.length; j++ ){
					this.dsTab1Ex.setColumn(j, "appoBfrCarrSn" , i+1);
				}
				this.dsTab1.setColumn(i, "appoBfrCarrSn", i+1);
			}
		}
	});		
};

