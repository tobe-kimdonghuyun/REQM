				var appoBfrCarrSn = this.dsTab3.getColumn( i , "appoBfrCarrSn" ); 
				var dtArray = this.dsTab3Ex.extractRows("appoBfrCarrSn =='"+appoBfrCarrSn+"'");
				for( var j=0; j < dtArray.length; j++ ){
					this.dsTab3Ex.setColumn(j, "appoBfrCarrSn" , i+1);
