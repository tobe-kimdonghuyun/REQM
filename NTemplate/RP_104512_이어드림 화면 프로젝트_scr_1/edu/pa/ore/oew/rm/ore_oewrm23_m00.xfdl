    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-지방공무원-경력합산신청-신청서
*  @MenuPath    pa_ore_oew_rm
*  @FileName 	pa_ore_oewrm23_m00.xfdl
*  @Creator 	shhan
*  @CreateDate 	2022.09.13
*  @Desction    온라인통합채용-지방공무원-경력합산신청-신청서
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.09.13    	shhan 	        	최초 생성 
*  2022.12.08       최정민 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	//  본인인증
	var rrno     = nexacro.base64Decode(this.smfGetSessionValue('userRrno'));  // 주민번호
	var brdt     = this.applpRrnoToBrdt(rrno);           // 생년월일
	var sxdsCd   = this.applpRrnoToSxdsCd(rrno);         // 성별
	var mblTelno = this.smfGetSessionValue('mblTelNo');
	var kornFlnm = this.smfGetSessionValue('userNm');

	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);

	// 공통코드
	// dsCarrDtlScCd : 경력구분 | dsMsclCd : 군별 | dsMIlsStleScCd : 복무형태 | dsMIlrCd : 전역계급 |  dsQlfAsortCd : 자격급별 | dsSrclsCarrScCd : 경력분류
	this.smfCodeList("code", [this.dsCarrDtlScCd , this.dsMsclCd, this.dsMIlsStleScCd , this.dsMIlrCd , this.dsQlfAsortCd , this.dsSrclsCarrScCd ])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		})		
		.run();

	//*** 조회 추가 !!!!
	this.dsSearch.setColumn(0, "onlEmpmnExamScCd", this.smfGetAppoExamScCd());
	this.dsSearch.setColumn(0,"rrno"     , rrno);
	var cddcCd = this.smfGetCddcCode();
	this.dsSearch.setColumn(0, "cddcScCd", cddcCd.slice(0,3));
	
	this.dsMain.clearData();
	//개요 상세 조회 
	this.smfSearchService('selectCarrAdupReqs') 
	.run()
	// 콜백
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		var chk1 = this.dsMain.getColumn(0,"chk1") == "00" ? "Y" : "N";
		var chk2 = this.dsMain.getColumn(0,"chk2") == "Y" ? "Y" : "N";
		if(chk1 == "N" ){
			this.smfAlert("임용후보자가 아닙니다.");
		} else if(chk2 == "Y" ){
			this.smfAlert("이미 제출 되었습니다.");
		} 
		
		if(chk1 == "N" || chk2 == "Y" ){
			this.divContent03.form.btnSave.set_enable(false);
			this.divContent02.form.tabContent00.Tabpage1.form.btnAdd.set_enable(false);
			this.divContent02.form.tabContent00.Tabpage1.form.btnDel.set_enable(false);
			this.divContent02.form.tabContent00.Tabpage2.form.btnAdd1.set_enable(false);
			this.divContent02.form.tabContent00.Tabpage2.form.btnDel1.set_enable(false);
			this.divContent02.form.tabContent00.Tabpage3.form.btnAdd2.set_enable(false);
			this.divContent02.form.tabContent00.Tabpage3.form.btnDel2.set_enable(false);
			this.divContent02.form.tabContent00.Tabpage4.form.btnAdd.set_enable(false);
			this.divContent02.form.tabContent00.Tabpage4.form.btnDel.set_enable(false);
			this.divContent02.form.tabContent00.Tabpage5.form.btnAdd.set_enable(false);
			this.divContent02.form.tabContent00.Tabpage5.form.btnDel.set_enable(false);
		}
		
		if(this.smfIsNull(this.dsMain.getColumn(0,"rrno"))){
			this.dsMain.setColumn(0,"kornFlnm" , kornFlnm);
			this.dsMain.setColumn(0,"brdt"     , brdt);
			this.dsMain.setColumn(0,"rrno"     , rrno);
			this.dsMain.setColumn(0,"sxdsCd"   , sxdsCd);
			this.dsMain.setColumn(0,"mblTelno" , mblTelno);
			var sMblTelno = mblTelno.split("-");
			this.dsMain.setColumn(0, "mblTelno1", sMblTelno[0]);	
			this.dsMain.setColumn(0, "mblTelno2", sMblTelno[1]);	
			this.dsMain.setColumn(0, "mblTelno3", sMblTelno[2]);	
			this.dsMain.setColumn(0,"carrAdupReqsId","N");
		}else{
			// 비상연락처
			var emgCnctTelno = this.dsMain.getColumn(0, "emgCnctTelno").split("-");
			this.dsMain.setColumn(0, "emgCnctTelno1", emgCnctTelno[0]);	
			this.dsMain.setColumn(0, "emgCnctTelno2", emgCnctTelno[1]);	
			this.dsMain.setColumn(0, "emgCnctTelno3", emgCnctTelno[2]);	
		}
	});		
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){

}

// 군복무경력 추가 팝업 콜백
this.fnAdd00Callback = function(e, sender){

	this.fnSetYyMmDd( e.dsMainP  , e.dsDtlP);
	
	var nRow = this.dsTab1.addRow();
	this.dsTab1.copyRow( nRow , e.dsMainP , 0 );
	this.dsTab1.setColumn( nRow , "appoBfrCarrSn" , nRow+1 );
	
	for(var i=0; i < e.dsDtlP.rowcount; i++){
		var dRow = this.dsTab1Ex.addRow();
		this.dsTab1Ex.copyRow( dRow, e.dsDtlP , i );
		this.dsTab1Ex.setColumn( dRow , "appoBfrCarrSn" , nRow+1 );
		this.dsTab1Ex.setColumn( dRow , "carrSn" , dRow+1 );
	}
};

// 공무원 경력 추가 팝업 콜백
this.fnAdd01Callback = function(e, sender){

	this.fnSetYyMmDd( e.dsMainP  , e.dsDtlP);
	
	var nRow = this.dsTab2.addRow();
	this.dsTab2.copyRow( nRow , e.dsMainP , 0 );
	this.dsTab2.setColumn( nRow , "appoBfrCarrSn" , nRow+1 );
	this.dsTab2.setColumn( nRow , "srclsCarrScCd" , "11");    //공무원경력 
	
	for(var i=0; i < e.dsDtlP.rowcount; i++){
		var dRow = this.dsTab2Ex.addRow();
		this.dsTab2Ex.copyRow( dRow, e.dsDtlP , i );
		this.dsTab2Ex.setColumn( dRow , "appoBfrCarrSn" , nRow+1 );
		this.dsTab2Ex.setColumn( dRow , "carrSn" , dRow+1 );
	}
};

// 유사경력 추가 팝업 콜백
this.fnAdd02Callback = function(e, sender){

	this.fnSetYyMmDd( e.dsMainP  , e.dsDtlP);
	
	var nRow = this.dsTab3.addRow();
	this.dsTab3.copyRow( nRow , e.dsMainP , 0 );
	this.dsTab3.setColumn( nRow , "appoBfrCarrSn" , nRow+1 );
	//this.dsTab3.setColumn( nRow , "srclsCarrScCd" , "22");    //유사경력 
	
	for(var i=0; i < e.dsDtlP.rowcount; i++){
		var dRow = this.dsTab3Ex.addRow();
		this.dsTab3Ex.copyRow( dRow, e.dsDtlP , i );
		this.dsTab3Ex.setColumn( dRow , "appoBfrCarrSn" , nRow+1 );
		this.dsTab3Ex.setColumn( dRow , "carrSn" , dRow+1 );
	}
};

// 임용 전 연수 추가 팝업 콜백
/*
this.fnAdd03Callback = function(e, sender){

	this.fnSetYyMmDd( e.dsMainP  , e.dsDtlP);
	
	var nRow = this.dsTab4.addRow();
	this.dsTab4.copyRow( nRow , e.dsMainP , 0 );
	this.dsTab4.setColumn( nRow , "appoBfrCarrSn" , nRow+1 );
	this.dsTab4.setColumn( nRow , "srclsCarrScCd" , "23");    //임용 전 연수  
	
	for(var i=0; i < e.dsDtlP.rowcount; i++){
		var dRow = this.dsTab4Ex.addRow();
		this.dsTab4Ex.copyRow( dRow, e.dsDtlP , i );
		this.dsTab4Ex.setColumn( dRow , "appoBfrCarrSn" , nRow+1 );
		this.dsTab4Ex.setColumn( dRow , "carrSn" , dRow+1 );
	}
};
*/

// 자격증 추가 팝업 콜백
this.fnAdd04Callback = function(e, sender){
	var nRow = this.dsDtl4.addRow();
	this.dsDtl4.copyRow( nRow , e.dsMainP , 0 );
	this.dsDtl4.setColumn( nRow , "qlfAcqsSn" , nRow+1 );	
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 // 마지막일자 
this.fnGetLastDd = function(strDate)
{
	var s = "";
    if (strDate == null) {
	    var date = (new Date()).addMonth(1);
    }
    else {
	    var date = new Date(parseInt(strDate.substr(0,4)),parseInt(strDate.substr(4,2)),1);
    }

	date = (new Date(date)).addDate((new Date(date)).getDate()*-1);
	s = ((new Date(date)).getDate() + "").padLeft(2, '0');
	return parseInt(s);
};

//시간제가 아닐경우 년수 & 월수 & 일수  
this.fnGetDiffDate = function(sStartDate, sEndDate , type)
{
	var s_year = parseInt(sStartDate.substring(0, 4));
	var s_mon  = parseInt(sStartDate.substring(4, 6));
	var s_day  = parseInt(sStartDate.substring(6, 8));
	
	var e_year = parseInt(sEndDate.substring(0, 4));
	var e_mon  = parseInt(sEndDate.substring(4, 6));
	var e_day  = parseInt(sEndDate.substring(6, 8));

	var v_year = 0;
	var v_mon = 0;
	var v_day = 0;
	
	//전월말일
	var fDay = "";
	var mon  =  e_mon-1 ;
	if( mon == 0 ){
		fDay = this.fnGetLastDd ( e_year-1 + "12"); 
	}else{
		if(mon.length == 2){
			fDay = this.fnGetLastDd (e_year + mon); 
		}else{
			fDay = this.fnGetLastDd (e_year + "0" + mon); 
		}
	}
	//이달말일 
	var lDay = this.fnGetLastDd (sEndDate); 
	// 년 계산
	v_year = e_year - s_year;
		
	// 월 계산
	if(e_mon > s_mon) v_mon = e_mon - s_mon;
	else {
			v_year = v_year - 1;
			v_mon = (e_mon + 12) - s_mon;
	}
		
	// 일 계산
	if(e_day > s_day) {
		if(1 == s_day && e_day >= lDay) {
			v_mon = v_mon + 1;
		}
		else {
			v_day = e_day - s_day + 1;
			if(v_day >= 30 )  v_day = 29;
		}
	}
	else {
		if(e_day == s_day) v_day = 1;
		else if(e_day == (s_day - 1)) v_day = 0;
		else if(e_day >= lDay) v_day = 0;
		else {
			if(v_mon == 0) {
				v_year = v_year -1;
				v_mon = 11;
			}
			else
				v_mon = v_mon - 1;
			
			if(s_day >=fDay) fDay = s_day;
			
			v_day = (fDay - s_day + 1) + e_day;
			
			if(v_day >= 30) v_day = 29;
		}
	}
	if( v_mon >= 12) {
		v_year = v_year + 1;
		v_mon = v_mon - 12;
	}
	
	if(type == "H"){
		if(v_year.toString().length == 1) v_year = "0"+v_year;
		if(v_mon.toString().length == 1) v_mon = "0"+v_mon;
		if(v_day.toString().length == 1) v_day = "0"+v_day;
		return  v_year.toString()+v_mon.toString()+v_day.toString();
	}else{
		return  v_year.toString()+"/"+v_mon.toString()+"/"+v_day.toString();
	}
};

// 년,월,일을 일수로 변경
this.fnYyMmDdToDay = function(yyyymmdd){
	var yy = yyyymmdd.substr(0,2);
	var mm = yyyymmdd.substr(2,2);
	var dd = yyyymmdd.substr(4,2);
	var day = (Number(yy)*360) + (Number(mm)*30) + Number(dd);
	return day;
};

// 일수를 년,월,일로 변경
this.fnDayToYyMmDd = function(day){
	
	var yy = Math.floor(Number(day)/360);
	var mm = Math.floor(Number(day)/30)%12;
	var dd = Number(day) - (yy*360) - (mm*30);
	
	//if(String(yy).length == 1) yy = "0"+yy;
	//if(String(mm).length == 1) mm = "0"+mm;
	//if(String(dd).length == 1) dd = "0"+dd;
	
	return  yy.toString()+"/"+mm.toString()+"/"+dd.toString();
};

//시간제일 경우 년수 & 월수 & 일수 
this.fnGetDiffWorkHrDate = function(sStartDate, sEndDate , wperWorkHr)
{
	var day20050228 = "20050228";
	var day20060228 = "20060228";
	var day20111231 = "20111231";
	var day20120101 = "20120101";
	
	var startD = new Date(parseInt(sStartDate.substring(0,4),  10), parseInt(sStartDate.substring(4,6),  10), parseInt(sStartDate.substring(6,8), 10));
	var endD   = new Date(parseInt(sEndDate.substring(0,4),  10), parseInt(sEndDate.substring(4,6),  10), parseInt(sEndDate.substring(6,8), 10));
	
	var day20050228D = new Date(2005,2,28);
	var day20060228D = new Date(2006,2,28);
	var day20111231D = new Date(2011,12,31); 
	var day20120101D = new Date(2012,1,1); 
	
	var cal20050228 = "0", cal20060228 = "0", cal20111231 = "0", cal20120101 = "0", calTotal = "000000";
	var calDay20050228 = 0, calDay20060228 = 0, calDay20111231 = 0, calDay20120101 = 0, calDayTotal = 0;
	
	// 200050228 이전의 일자
	if( day20050228D-startD >= 0 && endD-day20050228D >= 0 )
	{
		cal20050228 = this.fnGetDiffDate(sStartDate, day20050228 , "H");
		var calDay = this.fnYyMmDdToDay(cal20050228);
		calDay20050228 = Math.round (calDay * (wperWorkHr /44.0));
		startD = new Date(2005,3,1);   
	}
	// 20060228 이전의 일자
	if( day20060228D-startD >= 0 && endD-day20060228D >= 0 )
	{
		cal20060228 = this.fnGetDiffDate(sStartDate, day20060228 , "H");
		var calDay = this.fnYyMmDdToDay(cal20060228);
		calDay20060228 = Math.round (calDay * (wperWorkHr /43.0));
		startD = new Date(2006,3,1);   
	}
	// 20111231 이전의 일자
	if( day20111231D-startD >= 0 && endD-day20111231D >= 0 )
	{
		cal20111231 = this.fnGetDiffDate(sStartDate, day20111231 , "H");
		var calDay = this.fnYyMmDdToDay(cal20111231);
		calDay20111231 = Math.round (calDay * (wperWorkHr /42.0));
		startD = new Date(2012,1,1);   
	}
	// 20120101 이후 
	if( day20120101D-startD <= 0 ) 
	{
		cal20120101 = this.fnGetDiffDate(sStartDate, sEndDate , "H");
		var calDay = this.fnYyMmDdToDay(cal20120101);
		calDay20120101 = Math.round (calDay * (wperWorkHr /40.0));
	}
	calDayTotal = calDay20050228 + calDay20060228 + calDay20111231 + calDay20120101;
	var result = this.fnDayToYyMmDd(calDayTotal);
	
	return result;
};

//날짜 계산 
this.fnAddDate = function(strDate, nOffSet)
{
	var date = new Date();
	
    var iYear = parseInt(strDate.substr(0, 4));
    var iMonth = parseInt(strDate.substr(4, 2) - 1);
    var iDate = parseInt(strDate.substr(6, 2)-(nOffSet*-1));
    
	date.setFullYear(iYear,iMonth,iDate);	
	return this.fnDateToStr(date);
};
this.fnDateToStr = function(date)
{
	var strYear = date.getYear().toString();
	var strMonth = (date.getMonth()+1).toString();
	var strDate = date.getDate().toString();
	if(strYear.length==2)
		strYear = '19'+strYear;
	else if(strYear.length==1)
		strYear = '190'+strYear;
		
	if(strMonth.length==1)
		strMonth = '0'+strMonth;
	if(strDate.length==1)
		strDate = '0'+strDate;
	return strYear+strMonth+strDate;
};

//경력기간 계산 
this.fnSetYyMmDd = function(objMain , objDtl , type)
{
	//경력기간 계산 
	//1. 경력 
	var workBgngYmd = objMain.getColumn(0,"workBgngYmd");
	var workEndYmd  = objMain.getColumn(0,"workEndYmd");
	
	//퇴직일포함여부가 Y이면 근무종료일 -1 
	if(objMain.getColumn(0,"rtrmDdInclsYn") == "Y"){
		workEndYmd = this.fnAddDate(workEndYmd,-1);
	}
	
	var cntArry = this.fnGetDiffDate(workBgngYmd, workEndYmd, "").split('/');
	
	//시간제 여부가 Y이면
	if(objMain.getColumn(0,"bthWorkYn") == "Y"){
		cntArry = this.fnGetDiffWorkHrDate(workBgngYmd, workEndYmd , objMain.getColumn(0, "wperWorkHr")).split('/');
	}
	
	objMain.setColumn(0, "carrYyCnt", cntArry[0]);
	objMain.setColumn(0, "carrMmCnt", cntArry[1]);
	objMain.setColumn(0, "carrDdCnt", cntArry[2]);

	// 경력 
	var carrDay = (nexacro.toNumber(cntArry[0])*360)+(nexacro.toNumber(cntArry[1])*30)+nexacro.toNumber(cntArry[2]);
	
	//2. 제외 경력
	for(var i=0; i < objDtl.rowcount; i++){
		workBgngYmd = objDtl.getColumn(i,"workBgngYmd");
		workEndYmd  = objDtl.getColumn(i,"workEndYmd");

		cntArry = this.fnGetDiffDate(workBgngYmd, workEndYmd).split('/');
		objDtl.setColumn(0,"exclCarrYyCnt", cntArry[0]);
		objDtl.setColumn(0,"exclCarrMmCnt", cntArry[1]);
		objDtl.setColumn(0,"exclCarrDdCnt", cntArry[2]);
	}
	
	//2-2. 총 제외 경력
	var SumDdcnt = objDtl.getSum("exclCarrDdCnt");
	var SumMmcnt = objDtl.getSum("exclCarrMmCnt");
	var SumYycnt = objDtl.getSum("exclCarrYyCnt");

	var exclDay = (nexacro.toNumber(SumYycnt)*360)+(nexacro.toNumber(SumMmcnt)*30)+nexacro.toNumber(SumDdcnt);
	//시간제 여부가 Y이면
	if(objMain.getColumn(0,"bthWorkYn") == "Y"){
		exclDay = Math.round (exclDay * (objMain.getColumn(0, "wperWorkHr") /40.0));
	}
	objMain.setColumn(0,"exclCarrDdCnt", nexacro.toNumber(exclDay) - (nexacro.toNumber(SumYycnt)*360) - (nexacro.toNumber(SumMmcnt)*30));
	objMain.setColumn(0,"exclCarrMmCnt", new nexacro.Decimal(nexacro.toNumber(exclDay)/30).floor()%12);
	objMain.setColumn(0,"exclCarrYyCnt", new nexacro.Decimal(nexacro.toNumber(exclDay)/360).floor());
	
	//3. 총 경력 
	var totalDay = carrDay - exclDay;

	if( totalDay < 0 ){
		objMain.setColumn(0, "totlCarrYyCnt", 0);
		objMain.setColumn(0, "totlCarrMmCnt", 0);
		objMain.setColumn(0, "totlCarrDdCnt", 0);	
		objMain.setColumn(0, "carrYyCnt", 0);
		objMain.setColumn(0, "carrMmCnt", 0);
		objMain.setColumn(0, "carrDdCnt", 0);
	}else{
		//총경력기간
		var totlCarrYyCnt = new nexacro.Decimal(nexacro.toNumber(totalDay)/360).floor();
		var	totlCarrMmCnt = new nexacro.Decimal(nexacro.toNumber(totalDay)/30).floor()%12;
		var	totlCarrDdCnt = nexacro.toNumber(totalDay) - (nexacro.toNumber(totlCarrYyCnt)*360) - (nexacro.toNumber(totlCarrMmCnt)*30);
			
		//if(totlCarrYyCnt.toString().length == 1) totlCarrYyCnt = "0"+totlCarrYyCnt;
		//if(totlCarrMmCnt.toString().length == 1) totlCarrMmCnt = "0"+totlCarrMmCnt;
		//if(totlCarrDdCnt.toString().length == 1) totlCarrDdCnt = "0"+totlCarrDdCnt;
		
		objMain.setColumn(0,"totlCarrYyCnt", totlCarrYyCnt);
		objMain.setColumn(0,"totlCarrMmCnt", totlCarrMmCnt);
		objMain.setColumn(0,"totlCarrDdCnt", totlCarrDdCnt);	
	}
}

//기본정보
this.fnSetSaveMain = function()
{
	//********************************************************************************
	//경력합산신청서기본 - OREOEWRM500MT
	//********************************************************************************
	// 채용시험구분코드
	this.dsMain.setColumn(0, "onlEmpmnExamScCd", this.smfGetAppoExamScCd());
	// 시도교육청코드
	var cddcCd = this.smfGetCddcCode();
	this.dsMain.setColumn(0, "cddcScCd", cddcCd.slice(0,3));
	
	var emgCnctTelno1 = this.dsMain.getColumn(0, "emgCnctTelno1");	
	var emgCnctTelno2 = this.dsMain.getColumn(0, "emgCnctTelno2");	
	var emgCnctTelno3 = this.dsMain.getColumn(0, "emgCnctTelno3");
	var emgCnctTelno  = [emgCnctTelno1, emgCnctTelno2, emgCnctTelno3].join("-"); 
	if ( emgCnctTelno == "--" ){
		emgCnctTelno = "";
	}
	this.dsMain.setColumn(0, "emgCnctTelno", emgCnctTelno );
	
	//********************************************************************************
	//경력합산신청서경력내역 - OREOEWRM510LT
	//경력합산신청서경력제외내역 - OREOEWRM511LT
	//군복무 경력(21) + 공무원경력(11) + 유사경력(22) + 임용 전 연수(23) 
	//********************************************************************************
	this.dsDtl.clearData();
	this.dsDtlEx.clearData();
	for(var i=0; i < this.dsTab1.rowcount; i++){
		var index = this.dsDtl.addRow();
		this.dsDtl.copyRow(index,this.dsTab1, i);
	}
	for(var i=0; i < this.dsTab1Ex.rowcount; i++){
		var index = this.dsDtlEx.addRow();
		this.dsDtlEx.copyRow(index,this.dsTab1Ex, i);
	}
	
	for(var i=0; i < this.dsTab2.rowcount; i++){
		var index = this.dsDtl.addRow();
		this.dsDtl.copyRow(index , this.dsTab2 , i);
		var appoBfrCarrSn = this.dsDtl.getColumn(index, "appoBfrCarrSn" );
		var chkArray = this.dsTab2Ex.extractRows("appoBfrCarrSn =='"+appoBfrCarrSn+"'");
		for( var j=0; j < chkArray.length; j++ ){
			var index2 = this.dsDtlEx.addRow();
			this.dsDtlEx.copyRow(index2 , this.dsTab2Ex , j);
			this.dsDtlEx.setColumn(index2, "appoBfrCarrSn" , index+1 );
		}
		this.dsDtl.setColumn(index , "appoBfrCarrSn" , index+1 );
	}
	
	for(var i=0; i < this.dsTab3.rowcount; i++){
		var index = this.dsDtl.addRow();
		this.dsDtl.copyRow(index , this.dsTab3 , i);
		var appoBfrCarrSn = this.dsDtl.getColumn(index, "appoBfrCarrSn" );
		var chkArray = this.dsTab3Ex.extractRows("appoBfrCarrSn =='"+appoBfrCarrSn+"'");
		for( var j=0; j < chkArray.length; j++ ){
			var index2 = this.dsDtlEx.addRow();
			this.dsDtlEx.copyRow(index2 , this.dsTab3Ex , j);
			this.dsDtlEx.setColumn(index2, "appoBfrCarrSn" , index+1 );
		}
		this.dsDtl.setColumn(index , "appoBfrCarrSn" , index+1 );
	}
	
	/*for(var i=0; i < this.dsTab4.rowcount; i++){
		var index = this.dsDtl.addRow();
		this.dsDtl.copyRow(index , this.dsTab4 , i);
		var appoBfrCarrSn = this.dsDtl.getColumn(index, "appoBfrCarrSn" );
		var chkArray = this.dsTab4Ex.extractRows("appoBfrCarrSn =='"+appoBfrCarrSn+"'");
		for( var j=0; j < chkArray.length; j++ ){
			var index2 = this.dsDtlEx.addRow();
			this.dsDtlEx.copyRow(index2 , this.dsTab4Ex , j);
			this.dsDtlEx.setColumn(index2, "appoBfrCarrSn" , index+1 );
		}
		this.dsDtl.setColumn(index , "appoBfrCarrSn" , index+1 );
	}*/
}

