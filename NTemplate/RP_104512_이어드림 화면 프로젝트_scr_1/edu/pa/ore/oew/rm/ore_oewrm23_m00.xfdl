	var chkIdxArray = this.dsTab2.extractRows("_chk ==1");
	
	if(this.isNil(chkIdxArray)){ 
		this.smfAlert("삭제 대상을 선택 해주세요. ");
		return;
	}
	
	// 확인 메시지 출력
	this.smfConfirm("삭제 하시겠습니까?", function(result){
		if(result.confirmResult){
		
			// 제외내역 삭제 
			for( var i=0; i < chkIdxArray.length; i++ ){
				var appoBfrCarrSn = this.dsTab2.getColumn( chkIdxArray[i] , "appoBfrCarrSn" ); //임용이전경력일련번호
				var dtArray = this.dsTab2Ex.extractRows("appoBfrCarrSn =='"+appoBfrCarrSn+"'");
				this.dsTab2Ex.deleteMultiRows(dtArray);
			}
			// 신청내역 삭제 
			this.dsTab2.deleteMultiRows(chkIdxArray);
			
			// 일련번호 다시 채번 
			for( var i=0; i < this.dsTab2.rowcount; i++ ){
				var appoBfrCarrSn = this.dsTab2.getColumn( i , "appoBfrCarrSn" ); 
				var dtArray = this.dsTab2Ex.extractRows("appoBfrCarrSn =='"+appoBfrCarrSn+"'");
				for( var j=0; j < dtArray.length; j++ ){
					this.dsTab2Ex.setColumn(j, "appoBfrCarrSn" , i+1);
				}
				this.dsTab2.setColumn(i, "appoBfrCarrSn", i+1);
			}
		}
	});	
};

