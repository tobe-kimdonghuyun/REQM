    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-교원임용(중등)-수험표 출력
*  @MenuPath    pa_ore_oew_rm
*  @FileName 	pa_ore_oewrm10_m01.xfdl
*  @Creator 	shhan
*  @CreateDate 	2022.11.25
*  @Desction    온라인통합채용-교원임용(중등)-수험표 출력
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.11.25		shhan				최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.applpRrno;
this.applpNm;
this.applpBrdt;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);
	
	// 검색조건 초기화
	this.dsSearch.clearData();
	this.dsSearch.addRow();

	// 선택 시도교육청코드
	var sCddcCd = this.smfGetCddcCode();
	
	// TODO 주민번호 : 본인인증 세션취득
	this.dsSearch.setColumn(0, "applpRrno", nexacro.base64Decode(this.smfGetSessionValue('userRrno')));
	// 시도교육청 앞 3자리 = 시도교육청 구분코드
	this.dsSearch.setColumn(0, "cddcScCd", sCddcCd.slice(0,3));
	this.dsSearch.setColumn(0, "onlEmpmnExamScCd", "2");
	this.dsSearch.setColumn(0, "cddcCd", sCddcCd);
	
	this.applpRrno = nexacro.base64Decode(this.smfGetSessionValue('userRrno'));
	this.applpNm   = this.smfGetSessionValue('userNm');
	this.applpBrdt = this.applpRrno.slice(0,6);
	
	// 지원자정보영역 초기화
	this.divSummary.form.divContent00.form.staContent00.set_text("");
	this.divSummary.form.divContent00.form.staContent01.set_text("");
	
	// 내 지원서 목록
	this.fnSearchRcptList();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid, errcd, errmsg){

};

this.fnReportCallback = function(svcid, errcd, errmsg){

};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
// 지원서 목록 검색
this.fnSearchRcptList = function(obj, e)
{
	// 지원서목록조회
	this.smfSearchService('listRcpt') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
				this.divSummary.form.divContent00.form.staContent00.set_text(this.applpNm + "(" +this.applpBrdt +")님.");
				this.divSummary.form.divContent00.form.staContent01.set_text("응시시험을 선택 후 수험표 조회를 해주세요.");
				// 지원서 수
				var rcptCnt =  this.dsResultRcpt.getRowCount();
				if(rcptCnt <1){
					// 콤보 비활성
					this.divContent01.form.cboAppoExm.set_enable(false);
					this.divContent01.form.btnReportView.set_enable(false);
					// 서머리영역 메세지2
					this.divSummary.form.divContent00.form.staContent01.set_text(this.smfGetCddcName()+" 임용시험에 응시 내역이 없습니다.");
				}else{
					this.divContent01.form.cboAppoExm.set_enable(true);
					this.divContent01.form.btnReportView.set_enable(true);
				}
	});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 수험표 리표트 표시
this.fnElOtptReportView = function(){

	// 출력물 주민번호 하이픈 추가
	this.dsMain.setColumn(0, 'applpRrno', this.applpRrnoHyphen(this.applpRrno));
	// 버튼표시여부
	var objButton = {
		"toolbar.save" : "false"    // 저장 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)           
		, "toolbar.addmemo" : "false"    // 메모 추가 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
		, "toolbar.savedm" : "false"    // 데이터 모듈 저장 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
		, "toolbar.etc" : "false"    // 다른 메뉴 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
	}
	// 리포트를 생성하기 위한 옵션을 설정한다.
	var oOzOption = {
			reports : [	
						{	
							// 기본데이터
							  displayname : "수험표"   // [필수] 멀티리포트시 Tree에 보여줄 이름
							, reportname : "/edu/pa/ore/oew/rm/ore_oewrm00_r01.ozr" // [필수] 리포트명  "/jsonsample.ozr"
								
							// json연동형
							//  - jsonDs/jsonDsName은 갯수가 같아야 됨
							, jsonDs     : [this.dsMain]  // [선택] json으로 변환할 데이터셋
							, jsonDsName : ["dsMain"]            // [선택] json으로 변환할 데이터의이름(ozr파일에서 지정된 값과 일치)
							, jsonParam  : ["viewerType=HTML5 Canvas Viewer 1"]  // [선택] json이외에추가할 데이터(KEY=VALUE형태의 스트링(배열))
							// 추가/보안옵션
							, security     : "Y"   // [선택] 위변조방지 삽입   ("Y"(default):표시,"N":비표시)
							, voiceBarcode : "Y"   // [선택] 보이스바코드 삽입 ("Y"(default):표시,"N":비표시)
							}
						]
						, hidestatus : true   // [선택] 하단 상태값 표시
						, button : objButton    // [선택] 버튼의 표시 비표시를 통제
	                };
					
	// 리포트를 그린다.
	// Report View Type ("embedded" : Form안의 Div에 표시 , "popup": 공통팝업으로 표시)
	//var sReportViewType = "embedded"; 
	// Div로 표시		
	//this.smfReportView(this,sReportViewType,oOzOption,this.divReportViewer);            
	//리포트를 그린다.
	//this.divReportViewer.optionReport = oOzOption;
	// report를 그린다.
	//this.divReportViewer.set_url("comm::comp_ozreport.xfdl");
	this.smfReportView(this,"popup",oOzOption,this.fnReportCallback);  
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.btnReportView_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 선택한 원서 접수번호
	var rcptNo = this.divContent01.form.cboAppoExm.value;
	if(this.smfIsNull(rcptNo)){
		this.divContent01.form.cboAppoExm.setFocus();
		this.smfAlert("응시 시험을 선택 해주세요.");
		return;
	}
	var i   = this.dsResultRcpt.findRow("rcptNo", rcptNo);
	this.dsSearch.setColumn(0,"rcptNo", rcptNo);      
	this.dsSearch.setColumn(0,"examDgr", "1");                                              // 차수(차수 가져오는거 생각좀 해봐야함...
	this.dsSearch.setColumn(0,"appoExamId", this.dsResultRcpt.getColumn(i, 'appoExamId'));  // 채용시험 ID
	this.dsSearch.setColumn(0,"eamScCd", "2");
		
	this.dsExmt.useclientlayout = false;
	
	// 지원서목록조회
	this.smfSearchService('listExmt') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.dsExmt.useclientlayout = true;
			this.dsMain.clearData();
			this.dsMain.addRow();
			this.dsMain.copyRow(0,this.dsExmt,this.dsExmt.rowcount-1);
			
	
				
			this.dsMain.setColumn(0, 'cddcScCd', this.dsResultRcpt.getColumn(i, 'cddcScCd')); //시도구분코드
			
			var cddcScNm = this.dsResultRcpt.getColumn(i, 'cddcScNm');
			cddcScNm = cddcScNm.replace("교육청","");
			this.dsMain.setColumn(0, 'cddcScNm', cddcScNm +' 교육감'); //시도구분명
			
			this.dsMain.setColumn(0, 'apstFlnm', this.dsResultRcpt.getColumn(i, 'applpFlnm'));
			this.dsMain.setColumn(0, 'applpRrno', this.dsResultRcpt.getColumn(i, 'applpRrno'));
			this.dsMain.setColumn(0, 'apstPhotoFileCn', this.dsResultRcpt.getColumn(i, 'apstPhotoFileCn'));
			this.dsMain.setColumn(0, 'sxdsNm', '여');  //성별
			if('1' === this.dsResultRcpt.getColumn(i, 'sxdsCd')){
				this.dsMain.setColumn(0, 'sxdsNm', '남');
			}
			this.dsMain.setColumn(0, "onlEmpmnExamScCd", "교과");
			
			if(this.dsExmt.rowcount > 0 ){
				this.dsMain.setColumn(0, 'mlvAppoCurrNm' , this.dsMain.getColumn(0, 'currNm')); //교과  
				var sprtShlNm = "";
				if(!this.smfIsNull(this.dsMain.getColumn(0,"sprt1RnkPrivShlNm"))){
					sprtShlNm = "1순위 "+this.dsMain.getColumn(0, 'sprt1RnkPrivShlNm')+" ";
				}
				if(!this.smfIsNull(this.dsMain.getColumn(0,"sprt2RnkPrivShlNm"))){
					sprtShlNm = sprtShlNm + "2순위 "+this.dsMain.getColumn(0, 'sprt2RnkPrivShlNm')+" ";
				}					

				this.dsMain.setColumn(0, 'sprtShlNm' , sprtShlNm );
				
				var exmrNmTxt = "";
				if(!this.smfIsNull(this.dsMain.getColumn(0,"exmrNm"))){
					exmrNmTxt = this.dsMain.getColumn(0, 'exmrNm')+"\n/";
				}
				if(!this.smfIsNull(this.dsMain.getColumn(0,"exrmNm"))){
					exmrNmTxt = exmrNmTxt + this.dsMain.getColumn(0, 'exrmNm');
				}		

				this.dsMain.setColumn(0, 'exmrNmTxt' , exmrNmTxt);
				if(!this.smfIsNull(this.dsMain.getColumn(0,"examDgr"))){
					this.dsMain.setColumn(0, 'examDgr' , '수   험   표   ['+ this.dsMain.getColumn(0, 'examDgr') +' 차시험]');
				}else{
					this.dsMain.setColumn(0, 'examDgr' , '수   험   표');
				}
			}
			this.fnElOtptReportView();
		
	});
};]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listRcpt</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResultRcpt=dsResultRcpt</Col>
            <Col id="url">ore_oew_rm00_002.do</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="id">listExmt</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsExmt=dsExmt</Col>
            <Col id="url">ore_oew_rm00_003.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="false" updatecontrol="false">
        <ColumnInfo>
          <Column id="cddcScCd" type="STRING" size="256" description="접속시도교육청 구분코드"/>
          <Column id="applpRrno" type="STRING" size="256" description="응시자주민번호"/>
          <Column id="onlEmpmnExamScCd" type="STRING" size="256"/>
          <Column id="rcptNo" type="STRING" size="256"/>
          <Column id="examDgr" type="STRING" size="256"/>
          <Column id="appoExamId" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="eamScCd" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsMain">
        <ColumnInfo>
          <Column id="rcptNo" type="STRING" size="256" description="접수번호"/>
          <Column id="appoExamId" type="STRING" size="256" description="임용시험ID"/>
          <Column id="appoExamNm" type="STRING" size="256" description="임용시험명"/>
          <Column id="appoExamNmSum" type="STRING" size="256"/>
          <Column id="currCd" type="STRING" size="256" description="분야코드"/>
          <Column id="currNm" type="STRING" size="256" description="분야명"/>
          <Column id="cddcScCd" type="STRING" size="256"/>
          <Column id="cddcScNm" type="STRING" size="256"/>
          <Column id="apstFlnm" type="STRING" size="256"/>
          <Column id="applpRrno" type="STRING" size="256"/>
          <Column id="sxdsCd" type="STRING" size="256"/>
          <Column id="examDgr" type="STRING" size="256"/>
          <Column id="mlvAppoCurrNm" type="STRING" size="256"/>
          <Column id="sxdsNm" type="STRING" size="256"/>
          <Column id="sprt1RnkPrivShlNm" type="STRING" size="256"/>
          <Column id="sprt2RnkPrivShlNm" type="STRING" size="256"/>
          <Column id="sprtShlNm" type="STRING" size="256"/>
          <Column id="exmtNo" type="STRING" size="256"/>
          <Column id="dstrtNm" type="STRING" size="256"/>
          <Column id="exmrNm" type="STRING" size="256"/>
          <Column id="exmrNmTxt" type="STRING" size="256"/>
          <Column id="otmpAtchFileCn" type="BLOB" size="256"/>
          <Column id="aiOffcsAtchFileCn" type="BLOB" size="256"/>
          <Column id="atentMteCn" type="STRING" size="256"/>
          <Column id="onlEmpmnExamScCd" type="STRING" size="256"/>
          <Column id="exrmNm" type="STRING" size="256"/>
          <Column id="apstPhotoFileCn" type="BLOB" size="256"/>
          <Column id="aiInqYn" type="STRING" size="256"/>
          <Column id="dataYn" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsResultRcpt" useclientlayout="true">
        <ColumnInfo>
          <Column id="rcptNo" type="STRING" size="256" description="접수번호"/>
          <Column id="appoExamId" type="STRING" size="256" description="임용시험ID"/>
          <Column id="appoExamNm" type="STRING" size="256" description="임용시험명"/>
          <Column id="appoExamNmSum" type="STRING" size="256"/>
          <Column id="currCd" type="STRING" size="256" description="분야코드"/>
          <Column id="currNm" type="STRING" size="256" description="분야명"/>
          <Column id="cddcScCd" type="STRING" size="256"/>
          <Column id="cddcScNm" type="STRING" size="256"/>
          <Column id="applpFlnm" type="STRING" size="256"/>
          <Column id="applpRrno" type="STRING" size="256"/>
          <Column id="sxdsCd" type="STRING" size="256"/>
          <Column id="apstPhotoFileCn" type="BLOB" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsExmt" useclientlayout="true">
        <ColumnInfo>
          <Column id="appoExamId" type="STRING" size="256" description="채용시험ID"/>
          <Column id="rcptNo" type="STRING" size="256" description="채용시험명"/>
          <Column id="appoExamNm" type="STRING" size="256" description="직종코드"/>
          <Column id="currCd" type="STRING" size="256" description="직종명"/>
