<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="formMain" width="1200" height="630" titletext="지방공무원-마이페이지-원서접수내역" onload="frmMain_onload">
    <Layouts>
      <Layout height="630" width="1200" screenid="ScreenDeskTop">
        <Div id="divContent00" taborder="0" left="0" top="0" height="190" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staGd00" taborder="1" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
              <ImageViewer id="imgTitleSrce" taborder="0" text="원서접수내역" left="-4" top="70" height="44" cssclass="img_WF_SubTit01" width="204" initvalueid="ivTitleAccessibilityOn" onload="divTitle_imgTitle_onload" onclick="divContent00_imgTitleSrce_onclick"/>
              <Static id="staGd01" taborder="2" left="0" top="107" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
          </Layouts>
        </Div>
        <Grid id="grdAdf" taborder="1" left="0" top="190" height="277" autofittype="col" right="0" binddataset="dsGrdMain" selecttype="cell" initvalueid="ivGrdAccessibilityOn" autoenter="none" autosizingtype="row" extendsizetype="row" nodatatext="응시 내역이 없습니다." oncellclick="grdDsMain_oncellclick" accessibilitylabel="원서접수내역 목록">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="36"/>
                <Column size="359"/>
                <Column size="156"/>
                <Column size="98"/>
                <Column size="114"/>
                <Column size="117"/>
                <Column size="76"/>
                <Column size="87"/>
                <Column size="106"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="번호"/>
                <Cell col="1" text="응시시험명"/>
                <Cell col="2" text="직렬"/>
                <Cell col="3" text="계급"/>
                <Cell col="4" text="원서등록일"/>
                <Cell col="5" text="결제일"/>
                <Cell col="6" text="접수상태"/>
                <Cell col="7"/>
                <Cell col="8"/>
              </Band>
              <Band id="body">
                <Cell expr="currow+1" padding="10px 10px"/>
                <Cell col="1" displaytype="normal" edittype="none" textAlign="left" wordWrap="char" text="bind:appoExamNm" padding="10px 10px"/>
                <Cell col="2" text="bind:jblnNm" textAlign="center" wordWrap="char" padding="10px 10px"/>
                <Cell col="3" displaytype="normal" edittype="none" text="bind:rksNm" textAlign="center" wordWrap="char" padding="10px 10px"/>
                <Cell col="4" calendardateformat="yyyy.MM.dd " text="bind:adfRegDtTxt" textAlign="center" wordWrap="char" displaytype="text" calendareditformat="yyyy.MM.dd" padding="10px 10px"/>
                <Cell col="5" edittype="none" text="bind:payRegDtTxt" textAlign="center" wordWrap="char" calendardateformat="yyyy.MM.dd" displaytype="text" calendareditformat="yyyy.MM.dd" padding="10px 10px"/>
                <Cell col="6" text="bind:payYn" textAlign="center" wordWrap="char" expr="[payYn]=='Y'?'접수완료':'결제대기'" padding="10px 10px"/>
                <Cell col="7" displaytype="expr:payYn =='Y' ? 'buttoncontrol':''" text="expr:payYn =='Y' ? '접수 취소':''"/>
                <Cell col="8" displaytype="expr:payYn =='Y' ? '':'buttoncontrol'" text="expr:payYn =='Y' ? '':'지원서 삭제'"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="sta00" taborder="3" text="4세대 나이스 개편(2023.6.21)에 따라, 원서접수 내역은 개편 이후 시행된 채용의 지원자만 확인 가능합니다." left="0" top="137" height="25" cssclass="sta_WF_Black14" right="0"/>
        <Static id="staScreNoti" taborder="2" text="※ 2023. 8. 21 ~ 이후 진행되는 '지방공무원 임용시험(2차) 접수내역부터 조회 가능" left="0" top="sta00:-2" height="30" cssclass="sta_WF_Red14" initvalueid="ivStcAccessibilityOn" right="0"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listAdf</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsGrdMain=dsGrdMain</Col>
            <Col id="url">ore_oew_rm20_m00_001.do</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="id">selectRcptCancelCeck</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResultCancelCeck=dsResultCancelCeck</Col>
            <Col id="url">ore_oew_ar21_m02_000.do</Col>
          </Row>
          <Row>
            <Col id="id">saveRcptCancel</Col>
            <Col id="inDatasets">dsMainCancel=dsMainCancel dsRcptSms=dsRcptSms</Col>
            <Col id="url">ore_oew_ar21_m02_001.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcScCd" type="STRING" size="256" description="시도교육청구분코드"/>
          <Column id="applpRrno" type="STRING" size="256" description="공공마이데이터-주민번호"/>
          <Column id="rcptNo" type="STRING" size="256"/>
          <Column id="onlEmpmnExamScCd" type="STRING" size="256"/>
          <Column id="appoExamId" type="STRING" size="256"/>
          <Column id="ocptyCd" type="STRING" size="256"/>
          <Column id="jbgdCd" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsGrdMain" useclientlayout="true" updatecontrol="false">
        <ColumnInfo>
          <Column id="rcptNo" type="STRING" size="256" description="접수번호"/>
          <Column id="apfSn" type="STRING" size="256" description="접수일련번호"/>
          <Column id="applpRrno" type="STRING" size="256" description="응시자주번호"/>
          <Column id="cddcScCd" type="STRING" size="256" description="시도교육청구분코드"/>
          <Column id="appoExamId" type="STRING" size="256" description="임용시험ID"/>
          <Column id="appoExamNm" type="STRING" size="256" description="임용시험명"/>
          <Column id="appoExamYr" type="STRING" size="256" description="임용시험연도"/>
          <Column id="ocptyCd" type="STRING" size="256" description="직류코드"/>
          <Column id="ocptyNm" type="STRING" size="256" description="직류명"/>
          <Column id="jblnCd" type="STRING" size="256" description="직렬코드"/>
          <Column id="jblnNm" type="STRING" size="256" description="직렬명"/>
          <Column id="jbgdCd" type="STRING" size="256" description="직급코드"/>
          <Column id="jbgdNm" type="STRING" size="256" description="직급명"/>
          <Column id="rksCd" type="STRING" size="256" description="계급코드"/>
          <Column id="rksNm" type="STRING" size="256" description="계급명"/>
          <Column id="dpcnSprtYn" type="STRING" size="256" description="중복지원여"/>
          <Column id="adfRegDt" type="STRING" size="256" description="원서등록일"/>
          <Column id="adfRegDtTxt" type="STRING" size="256" description="원서등록일Txt"/>
          <Column id="adfMdfcnDt" type="STRING" size="256" description="최종수정일"/>
          <Column id="adfMdfcnDtTxt" type="STRING" size="256" description="최종수정일Txt"/>
          <Column id="payYn" type="STRING" size="256" description="결제여부"/>
          <Column id="payRegDt" type="STRING" size="256" description="결제일"/>
          <Column id="payRegDtTxt" type="STRING" size="256" description="결제일Txt"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsResultCancelCeck" useclientlayout="true">
        <ColumnInfo>
          <Column id="rcptNo" type="STRING" size="20" description="접수번호"/>
          <Column id="stlmSn" type="STRING" size="2" description="결제일련번호"/>
          <Column id="stlmMnsCd" type="STRING" size="4" description="결제수단코드(내부결제수단코드)"/>
          <Column id="stlmTypIdfCd" type="STRING" size="30" description="결제유형식별코드(PG사 결제수단)"/>
          <Column id="stlmDsgnNo" type="STRING" size="40" description="결제지정번호 (PG사 거래번호TID)"/>
          <Column id="stlmIdntyBgngNo" type="STRING" size="30" description="결제확인시작번호(PG 결제일시)"/>
          <Column id="stlmKey" type="STRING" size="100" description="결제식별키 (PG사 주문번호"/>
          <Column id="stlmAmt" type="STRING" size="256" description="결제금액"/>
          <Column id="stlmPrcsRltCd" type="STRING" size="5" description="결제처리결과코드  (PG사 결제결과)"/>
          <Column id="stlmYn" type="STRING" size="1" description="결제여부"/>
          <Column id="stlmNo" type="STRING" size="256" description="추적번호(KCP)"/>
          <Column id="rcptRtrcnDtYn" type="STRING" size="256" description="접수취소기간내 여부"/>
          <Column id="rlesYn" type="STRING" size="256" description="응시료면제여부"/>
          <Column id="itnRcptRtrcnBgngDt" type="STRING" size="256" description="접수취소시작일"/>
          <Column id="itnRcptRtrcnBgngDtTxt" type="STRING" size="256" description="접수취소시작일 포멧"/>
          <Column id="itnRcptRtrcnEndDt" type="STRING" size="256" description="접수취소종료일"/>
          <Column id="itnRcptRtrcnEndDtTxt" type="STRING" size="256" description="접수취소종료일 포멧"/>
          <Column id="rcptRtrcnQustTelNo" type="STRING" size="256" description="접수취소문의전화번호"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsMainCancel" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcScCd" type="STRING" size="256" description="시도교육청구분코드"/>
          <Column id="rcptNo" type="STRING" size="256" description="접수번호"/>
          <Column id="appoExamId" type="STRING" size="256" description="임용시험아이디"/>
          <Column id="siteCd" type="STRING" size="256" description="상점코드"/>
          <Column id="tno" type="STRING" size="256" description="거래번호"/>
          <Column id="rlesYn" type="STRING" size="256" description="응시료면제여부"/>
          <Column id="payCancel" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsRcptSms" useclientlayout="true">
        <ColumnInfo>
          <Column id="appoExamScCd" type="STRING" size="256" description="임용시험구분코드"/>
          <Column id="cddcScCd" type="STRING" size="256" description="시도교육청구분코드"/>
          <Column id="cddcNm" type="STRING" size="256" description="시도교육청명"/>
          <Column id="rcptQustTelNo" type="STRING" size="256" description="발신전화번호-온라인마스터문의번호"/>
          <Column id="mblTelno" type="STRING" size="256" description="수신전화번호"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-지방공무원-마이페이지-원서내역
*  @MenuPath    pa_ore_oew_rm
*  @FileName 	ore_oewrm20_m00.xfdl
*  @Creator 	최재형
*  @CreateDate 	2022.08.10
*  @Desction    온라인통합채용-지방공무원-마이페이지-원서내역
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.12.06		최재형             최초 생성
*******************************************************************************
*/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.applpRrno;
this.applpFlnm;
this.applpBrdt;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{	
	// 본인인증 세션취득
	this.applpRrno = nexacro.base64Decode(this.smfGetSessionValue('userRrno'));
	this.applpFlnm = this.smfGetSessionValue('userNm');
	this.applpBrdt = this.applpRrno.slice(0,6);
	
	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);
	
	// 검색조건 초기화
	this.dsSearch.clearData();
	this.dsSearch.addRow();

	// 선택 시도교육청코드
	var sCddcCd = this.smfGetCddcCode();
	
	// 주민번호 : 본인인증 세션취득
	this.dsSearch.setColumn(0, "applpRrno", this.applpRrno);
	// 시도교육청 앞 3자리 = 시도교육청 구분코드
	this.dsSearch.setColumn(0, "cddcScCd", sCddcCd.slice(0,3));
	
	// 원서접수 내역 조회
	this.fnSearchAdfList();
	
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

// 원서접수 목록 조회
 this.fnSearchAdfList = function(){
		// 서비스 객체 생성
	this.smfSearchService("listAdf")
		
		// 데이터 존재 필수(검색 조건)
		.requireExistsData(this.dsSearch)

		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			if(this.dsGrdMain.getRowCount() <1){
				this.grdAdf.set_nodatatext('원서 조회 기간이 아니거나 접수 내역이 없습니다.');
			}
		});
}


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/


/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 //  리스트 클릭
this.grdDsMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var nCell = e.cell;
	if(nCell == 1) { // 제목
		// 확인 메시지 출력
		this.smfConfirm("지원서 화면으로 이동 하시겠습니까?", function(result){
			if(result.confirmResult){
				var nRow = e.row;
				var objDs = obj.getBindDataset();
				var rcptNo = objDs.getColumn(nRow,"rcptNo");
				// PARAM
				var params = {
					"viewMode" : 'modify', // new(신규) / modify(수정)
					"rcptNo" : rcptNo
				}
				// 지원서 수정화면
				this.smfSetWorkPage("pa_ore_oew_ar::ore_oewar21_m00.xfdl", params);
			}
		});
	}
	else if(nCell == 7) 
	{
		//접수완료된 건
		//기존 접수취소 건과 동일하게 동작
		var nRow = e.row;
		var objDs       = obj.getBindDataset();
		if(objDs.getColumn(nRow,"payYn")=='Y') //결제취소
		{
			this.dsSearch.setColumn(0, 'rcptNo', objDs.getColumn(nRow,"rcptNo"));
			this.dsSearch.setColumn(0, 'cddcScCd', this.smfGetCddcCode().slice(0,3));
			this.dsSearch.setColumn(0, 'appoExamId', objDs.getColumn(nRow,"appoExamId"));
			this.dsSearch.setColumn(0, 'ocptyCd', objDs.getColumn(0, 'ocptyCd'));// 직류코드
			this.dsSearch.setColumn(0, 'jbgdCd', objDs.getColumn(0, 'jbgdCd'));// 직급코드
			this.dsSearch.setColumn(0, 'onlEmpmnExamScCd', "3"); // 온라인채용시험구분코드 구분 (지방)
			this.smfConfirm("접수 취소시 응시료가 환불되고 접수한 지원서가 삭제됩니다. \n또한 재접수를 원할 경우 지원서를 처음단계부터 재작성해야 합니다. \n접수 취소하시겠습니까?", function(result){
				if(result.confirmResult){
					this.smfSearchService("selectRcptCancelCeck")
						.showConfirm(false)
						.run()
						// 콜백
						.callback(function(callbackParams){
							if(callbackParams.errors) {
								return;
							}
							// 접수취소 기간내 여부
							var rcptRtrcnDtYn = this.dsResultCancelCeck.getColumn(0, 'rcptRtrcnDtYn');
							if(rcptRtrcnDtYn === 'N'){
								this.smfAlert("원서 접수 취소 기간이 아닙니다.");
								return;
							}
							
							// 결제상태
							var stlmYn = this.dsResultCancelCeck.getColumn(0, 'stlmYn');
							//결제여부 N:결제대기 , Y:결제완료, C:취소
							if(rcptRtrcnDtYn === 'C'){
								this.smfAlert("이미 취소 되었습니다.");
								return;
							}
							var payYn      = objDs.getColumn(nRow,"payYn");
							var appoFieldCd	= objDs.getColumn(nRow,"currCd");			
							var appoExamId = objDs.getColumn(nRow,"appoExamId");
							var cddcScCd = this.smfGetCddcCode().slice(0,3);
							var payCancel='Y';
							var rcptRtrcnQustTelNo = this.dsResultCancelCeck.getColumn(0, 'rcptRtrcnQustTelNo');//접수취소문의전화번호
							this.fnSaveRcptCancel(appoExamId,appoFieldCd,cddcScCd,payCancel,rcptRtrcnQustTelNo);
					});
				}
			});
		}	
	}
	else if(nCell == 8) //지원서 삭제
	{		
		//접수완료된 건
		//기존 접수취소 건과 동일하게 동작
		var nRow = e.row;
		var objDs       = obj.getBindDataset();	
		if(objDs.getColumn(nRow,"payYn") !='Y') //결제취소
		{
			this.dsSearch.setColumn(0, 'rcptNo', objDs.getColumn(nRow,"rcptNo"));
			this.dsSearch.setColumn(0, 'cddcScCd', this.smfGetCddcCode().slice(0,3));
			this.dsSearch.setColumn(0, 'appoExamId', objDs.getColumn(nRow,"appoExamId"));
			this.dsSearch.setColumn(0, 'ocptyCd', objDs.getColumn(0, 'ocptyCd'));// 직류코드
			this.dsSearch.setColumn(0, 'jbgdCd', objDs.getColumn(0, 'jbgdCd'));// 직급코드
			this.dsSearch.setColumn(0, 'onlEmpmnExamScCd', "3"); // 온라인채용시험구분코드 구분 (지방)
			this.smfConfirm("지원서삭제 시 지원서를 처음단계부터 재작성해 주셔야 합니다. \n지원서삭제를 삭제하시겠습니까?", function(result){
				if(result.confirmResult){
					this.smfSearchService("selectRcptCancelCeck")
						.showConfirm(false)
						.run()
						// 콜백
						.callback(function(callbackParams){
							if(callbackParams.errors) {
								return;
							}
							// 접수취소 기간내 여부
							var rcptRtrcnDtYn = this.dsResultCancelCeck.getColumn(0, 'rcptRtrcnDtYn');
							if(rcptRtrcnDtYn === 'N'){
								this.smfAlert("원서 접수 취소 기간이 아닙니다.");
								return;
							}
							
							// 결제상태
							var stlmYn = this.dsResultCancelCeck.getColumn(0, 'stlmYn');
							//결제여부 N:결제대기 , Y:결제완료, C:취소
							if(rcptRtrcnDtYn === 'C'){
								this.smfAlert("이미 취소 되었습니다.");
								return;
							}
							var payYn      = objDs.getColumn(nRow,"payYn");
							var appoFieldCd	= objDs.getColumn(nRow,"currCd");			
							var appoExamId = objDs.getColumn(nRow,"appoExamId");
							var cddcScCd = this.smfGetCddcCode().slice(0,3);
							var payCancel='N';
							var rcptRtrcnQustTelNo = this.dsResultCancelCeck.getColumn(0, 'rcptRtrcnQustTelNo');//접수취소문의전화번호
						    this.fnSaveRcptCancel(appoExamId,appoFieldCd,cddcScCd,payCancel,rcptRtrcnQustTelNo);
					});
				}
			});		
		}
	}
};


/**
 *  접수취소
 */
this.fnSaveRcptCancel = function(appoExamId,appoFieldCd,cddcScCd,payCancel,rcptRtrcnQustTelNo)
{

	/** 처리조건**/
	this.dsMainCancel.clearData();
	this.dsMainCancel.addRow();
	this.dsMainCancel.setColumn(0, 'cddcScCd', cddcScCd);// 시도교육청구분코드
	this.dsMainCancel.setColumn(0, 'rcptNo', this.dsSearch.getColumn(0, 'rcptNo'));// 접수번호
	this.dsMainCancel.setColumn(0, 'appoExamId', appoExamId); //임용시험아이디
	this.dsMainCancel.setColumn(0, 'siteCd', this.dsResultCancelCeck.getColumn(0, 'stlmNo'));// KCP상점코드
	this.dsMainCancel.setColumn(0, 'tno', this.dsResultCancelCeck.getColumn(0, 'stlmKey'));// KCP거래번호
	this.dsMainCancel.setColumn(0, 'rlesYn', this.dsResultCancelCeck.getColumn(0, 'rlesYn'));// 응시료면제여부
	this.dsMainCancel.setColumn(0, 'payCancel', payCancel);// 결제취소여부
	// 원서접수취소 문자발송정보 SET
	this.fnSetSaveRcptSmsInfo(rcptRtrcnQustTelNo);
	
	// 접수취소
	this.smfSaveService("saveRcptCancel")
		.showConfirm(false)
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) {
				return;
			}
			this.smfAlert("원서 접수 취소가 완료 되었습니다.", this.fnCancelMessageCallback);
			// 화면 refresh
			this.fnSearchAdfList();			
	});
};


 /**
 * 원서접수취소 문자발송정보 SET
 * 
 **/
 this.fnSetSaveRcptSmsInfo = function(rcptRtrcnQustTelNo){
	// 초기화
	this.dsRcptSms.clearData();
	this.dsRcptSms.addRow();
	this.dsRcptSms.setColumn(0, 'appoExamScCd' , this.smfGetAppoExamScCd()); //임용시험구분코드
	this.dsRcptSms.setColumn(0, 'cddcScCd' ,this.smfGetCddcCode().slice(0,3)); //시도교육청구분코드
	this.dsRcptSms.setColumn(0, 'cddcNm' , this.smfGetCddcName()); //시도교육청명
	this.dsRcptSms.setColumn(0, 'rcptQustTelNo' , rcptRtrcnQustTelNo); //발신번호
	this.dsRcptSms.setColumn(0, 'mblTelno' , this.smfGetMblTelno()); //수신번호
 }]]></Script>
  </Form>
</FDL>
