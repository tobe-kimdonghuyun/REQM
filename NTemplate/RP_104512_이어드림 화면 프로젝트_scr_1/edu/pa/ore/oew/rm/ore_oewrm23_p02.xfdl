          <Column id="workBgngYmd" type="STRING" size="256" description="근무시작일자"/>
          <Column id="workEndYmd" type="STRING" size="256" description="근무종료일자"/>
          <Column id="exclCarrYyCnt" type="BIGDECIMAL" size="256" description="제외경력년수"/>
          <Column id="exclCarrMmCnt" type="BIGDECIMAL" size="256" description="제외경력월수"/>
