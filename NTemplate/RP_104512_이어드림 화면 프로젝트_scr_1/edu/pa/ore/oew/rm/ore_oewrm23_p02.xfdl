          <Column id="carrDdCnt" type="BIGDECIMAL" size="256" description="경력일수"/>
          <Column id="exclCarrYyCnt" type="BIGDECIMAL" size="256" description="제외경력년수"/>
          <Column id="exclCarrMmCnt" type="BIGDECIMAL" size="256" description="제외경력월수"/>
          <Column id="exclCarrDdCnt" type="BIGDECIMAL" size="256" description="제외경력일수"/>
          <Column id="totlCarrYyCnt" type="BIGDECIMAL" size="256" description="총경력년수"/>
          <Column id="totlCarrMmCnt" type="BIGDECIMAL" size="256" description="총경력월수"/>
          <Column id="totlCarrDdCnt" type="BIGDECIMAL" size="256" description="총경력일수"/>
          <Column id="fileRefrnId" type="STRING" size="256" description="파일참조ID"/>
