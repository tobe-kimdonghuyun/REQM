              <Button id="btnAdd" taborder="2" text="추가" top="82" height="30" width="71" cssclass="btn_WF_Write" right="58" initvalueid="ivBtnAccessibilityButton" onclick="divContent02_btnAdd_onclick"/>
              <Button id="btnDel" taborder="3" text="삭제" top="82" height="30" width="50" cssclass="btn_WF_Crud" right="0" initvalueid="ivBtnAccessibilityButton" onclick="divContent02_btnDel_onclick"/>
              <Grid id="grdExcl" taborder="4" left="0" top="122" height="119" right="0" autofittype="col" selecttype="cell" initvalueid="ivGrdAccessibilityOn" binddataset="dsDtl" onenterdown="divContent02_grdExcl_onenterdown" onheadclick="grd_onheadclick" autoenter="select" autoupdatetype="itemselect" accessibilitylabel="연수제외기간 목록">
