    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-교육공무직-채용후보자-채용후보자동의서
*  @MenuPath    pa_ore_oew_rm
*  @FileName 	pa_ore_oewrm31_m00.xfdl
*  @Creator 	최재형
*  @CreateDate 	2022.9.13
*  @Desction    교육공무직 채용후보자 동의서 화면
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.09.13    	 	        최초 생성 
*******************************************************************************
*/

//include "lib::cm_script.xjs"
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.m_applpRrno; 
this.m_applpFlnm;
this.m_mblTelno; 
this.m_applpBrdt;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

	// 주민번호 + CI 필수 로그인 세션 체크
	var logInChkParam = {
		 redirectUrl : 'pa_ore_oew_rm::ore_oewrm31_m00.xfdl' // 현재 PAGE URL
		, redirectMenuId : '5001' // 교육공무직 채용후보자등록 메뉴 ID
	};
	// 주민번호 + CI 세션 없을 시 로그인 페이지이동
	this.isRrnoAndCiEssenLogin(logInChkParam);

	// FORM변수에 세션 SET
	this.m_applpRrno = nexacro.base64Decode(this.smfGetSessionValue('userRrno'));    //주민번호
	this.m_applpFlnm = this.smfGetSessionValue('userNm');      //이름applpRrno
	this.m_mblTelno  = this.smfGetSessionValue('mblTelNo');     //전화
	this.m_applpBrdt = this.applpRrnoToBrdt(this.m_applpRrno); // yyyyMMdd
	
	//본인인증 
	this.dsSearch.setColumn(0,"applpFlnm", this.m_applpFlnm);
	this.dsSearch.setColumn(0,"applpBrdt", this.m_applpBrdt);
	this.dsSearch.setColumn(0,"mblTelno" , this.m_mblTelno);
	this.dsSearch.setColumn(0,"applpRrno", this.m_applpRrno);
	this.dsSearch.setColumn(0,"pafrUserId", this.smfGetSessionValue('userDtcNo'));
	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);
	
	// 파일업로드 Init
	this.divAttach.form.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;           
	this.divAttach.form.divFileUpload.UPLOAD_OnError        = this.fnEventUploadError;           
	this.divAttach.form.divFileUpload.UPLOAD_Form           = this;      
	
	this.divSummary.form.divContent00.form.staContent00.set_text(this.m_applpFlnm + "(" + this.m_applpBrdt +")님. 응시시험을 선택 해주세요.");

	var sCddcCd = this.smfGetCddcCode();
	this.dsSearch.setColumn(0, "cddcScCd", sCddcCd.slice(0,3)); // 시도교육청 앞 3자리 = 시도교육청 구분코드
	this.dsSearch.setColumn(0, "cddcCd", sCddcCd); // 선택 시도교육청코드
	// 내 지원서 목록
	this.fnSearchRcptList();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){

};

// 업로드성공 콜백
this.fnEventUploadComplete = function(obj,paramObj,objResultDataset)
{
	this.dsMain.setColumn(0, "fileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
	
	//채용후보자등록 
	this.fnSaveAppoCndtReg();
};

// 파일 업로드 에러 콜백
this.fnEventUploadError = function(obj,paramObj)
{
	//this.smfAlert("첨부파일 업로드 실패 하였습니다. \n다시 시도해주세요.");
	//return;
};

// RAONK  옵션
this.fnSetRaonProp = function()
{
	var objAddRaonProps = {
		  MaxTotalFileCount : "3"	//업로드 할 최대 파일 개수 제한값을 설정합니다.
		, MaxOneFileSize : "3MB"	//업로드할 때 파일당 용량제한을 설정합니다.
	};						  
	return objAddRaonProps;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 지원서 목록 검색
this.fnSearchRcptList = function()
{
	// 지원서목록조회
	this.smfSearchService('listRcpt') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.dsMain.setColumn(0,"applpFlnm", this.dsSearch.getColumn(0,"applpFlnm"));
			this.dsMain.setColumn(0,"applpBrdt", this.dsSearch.getColumn(0,"applpBrdt"));
			this.dsMain.setColumn(0,"mblTelno" , this.dsSearch.getColumn(0,"mblTelno"));
			
			// 응시원서 결과
			var resultCnt= this.dsResultRcpt.getRowCount();
			if(resultCnt < 1){
				this.divAppoExam.form.divContent00.form.cboAppoExm.set_enable(false);
				this.divActionBtn.form.btnAgree.set_enable(false);
				var applpFlnm = this.dsSearch.getColumn(0,"applpFlnm");
				var applpBrdt = this.dsSearch.getColumn(0,"applpBrdt");
				this.divSummary.form.divContent00.form.staContent00.set_text(applpFlnm + "(" + applpBrdt +")님. 채용후보자 신청 대상 원서가 없습니다.");
			}
			
	});
};

//채용후보자등록 
this.fnSaveAppoCndtReg = function()
{
	this.smfSaveService("saveEmpolymentAgree")
		.showConfirm(false)
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors){
					return;
			}
			// 저장이 완료되었습니다.
			this.smfAlert('채용후보자 신청이 완료 되었습니다.');
			this.divAttach.form.divFileUpload.form.fnResetUpload();
			this.fnSearchRcptList();
			
	});
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.btnAgree_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 유의사항
	if( !this.chkVal00.value ) {
		this.chkVal00.setFocus();
		this.smfAlert('유의 사항 확인 체크 후 등록 해주세요.');
		return false;
	}
	
	// 서약서
	if( !this.chkVal01.value ) {
		this.chkVal01.setFocus();
		this.smfAlert('서약서 확인 체크 후 등록 해주세요.');
		return false;
	}
	
	// 선택한 응시원서 접수번호
	var sRcptNo = this.divAppoExam.form.divContent00.form.cboAppoExm.value;
	if(!sRcptNo){
		this.divAppoExam.form.divContent00.form.cboAppoExm.setFocus();
		this.smfAlert("응시시험을 선택 해주세요.");
		return;
	}
		
	// 파일첨부여부
	if(!this.divAttach.form.divFileUpload.form.fnIsExistUploadFile()){
		this.smfAlert('채용후보자 신청 서류는 필수 사항 입니다.');
		return false;
	}
	/*
	// 첨부파일수
	var fileCnt= this.divAttach.form.divFileUpload.form.fnGetTotalFileCount();
	if(fileCnt >3){
		this.smfAlert('첨부 파일은 3개 이하만 등록 해주세요.');
		return false;
	}
	// 첨부파일용량 3M 제한
	var nTotalFileSize = this.divAttach.form.divFileUpload.form.fnGetTotalFileSize();
	if(3145728 <nTotalFileSize ){
		this.smfAlert('첨부 파일은 총 3MB 이하로 등록 해주세요.');
		return false;
	}
	*/
	
	this.dsSearch.setColumn(0,"rcptNo"      , sRcptNo);
	this.dsSearch.setColumn(0,"empmnExamId" , this.dsResultRcpt.lookup("rcptNo", sRcptNo , "appoExamId" ));

	// 등록가능여부체크
	this.dsResultAplyCeck.clearData();
	this.dsResultAplyCeck.addRow();
	this.smfSearchService("selectAppoCndtRegCeck")
		.showConfirm(false)
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors){
				return;
			}
			// 합격여부
			var sfcPassYn = this.dsResultAplyCeck.getColumn(0, 'sfcPassYn');
			// 중복여부
			var duplYn = this.dsResultAplyCeck.getColumn(0, 'duplYn');
			// 신청기간
			var useDtchk = this.dsResultAplyCeck.getColumn(0, 'useDtchk');
			
			// 채용후보자 신청 기간이 아닙니다.
			if(useDtchk != 'Y'){
				this.smfAlert("채용후보자 신청을 할 수 없습니다.\n(채용후보자 신청 기간이 아닙니다.)");
				return;
			}
			// 이미 등록 되었음
			if(duplYn != 'N'){
				this.smfAlert("채용후보자 신청을 할 수 없습니다.\n (이미 채용후보자 신청을 하였습니다.)");
				return;
			}
			// 불합격
			if(sfcPassYn != 'Y'){
				this.smfAlert("채용후보자 신청을 할 수 없습니다.\n(해당 응시시험에 합격 정보가 없습니다.)");
				return;
			}
			

			
			this.smfConfirm("채용후보자 신청을 하시겠습니까?", function(result){
				if(result.confirmResult){
				
			    	var sCddcCd = this.smfGetCddcCode();
					this.dsMain.setColumn(0, "cddcCd"      , sCddcCd);
					this.dsMain.setColumn(0, "cddcScCd"    , sCddcCd.slice(0,3)); // 시도교육청 앞 3자리 = 시도교육청 구분코드
					this.dsMain.setColumn(0, "rcptNo"      , sRcptNo);
					this.dsMain.setColumn(0, "empmnExamId" , this.dsResultRcpt.lookup("rcptNo", sRcptNo ,"appoExamId" ));
					this.dsMain.setColumn(0, "applpRrno"   , this.m_applpRrno );
					
					// [첨부파일] 첨부파일 업로드 체크
					var fileCount = this.divAttach.form.divFileUpload.form.fnGetTotalFileCount();
					if(fileCount > 0) {
						// [첨부파일]업로드 후 콜백에서 임용후보자 등록 처리
						this.divAttach.form.divFileUpload.form.fnFileUpload();
					}else{
						// 채용후보자등록 
						this.fnSaveAppoCndtReg();
					}
				}
		});
	});
};]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">saveEmpolymentAgree</Col>
            <Col id="inDatasets">dsMain=dsMain</Col>
            <Col id="outDatasets"/>
            <Col id="url">/ore_oew_rm31_001.do</Col>
          </Row>
          <Row>
            <Col id="id">listRcpt</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResultRcpt=dsResultRcpt</Col>
            <Col id="url">/ore_oew_rm30_002.do</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="id">selectAppoCndtRegCeck</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResultAplyCeck=dsResultAplyCeck</Col>
            <Col id="url">/ore_oew_rm31_000.do</Col>
          </Row>
        </Rows>
      </Dataset>
