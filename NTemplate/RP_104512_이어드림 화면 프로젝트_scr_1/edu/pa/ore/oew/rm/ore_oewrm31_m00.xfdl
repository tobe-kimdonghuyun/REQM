<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmMain" width="1200" height="1155" titletext="교육공무직-채용후보자-채용후보자 동의서" onload="frmMain_onload">
    <Layouts>
      <Layout height="1155" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="70" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle00" taborder="0" text="채용후보자신청" left="0" top="0" height="44" cssclass="img_WF_SubTit01" width="250" initvalueid="ivTitleAccessibilityOn" onclick="divTitle_imgTitle00_onclick"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staTlt00" taborder="1" left="10" top="150" height="36" text="유의사항" wordWrap="char" width="289" cssclass="sta_WF_WorkTit" initvalueid="ivStcAccessibilityOn" accessibilitylabel="유의사항"/>
        <Div id="divContentSub02" taborder="2" left="0" height="145" cssclass="div_WF_InfoBOX" top="189" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staContents" taborder="0" left="26" top="21" height="103" text=" 1. 채용후보자 등록과 관련된 사항, 제출서류는 반드시 해당 시도교육청 안내문(공고문 등)을 확인하시기 바랍니다. &#13;&#10; 2. 최종 합격자 공고 및 근로계약을 체결한 이후라도 해당 시도교육청의 응시결격 사유에 해당되는 것으로 판명된 자, 응시자격이 미달인 자, 채용신체검사 결과 불합격한 자, 자격요건 조회 결과 허위로 판명된 자는 합격 또는 채용을 취소 처리합니다.&#13;&#10; 3. 성범죄 경력 조회 및 아동학대 관련 범죄 전력 조회 결과 「아동․청소년의 성보호에 관한 법률」 및 「아동복지법」에 의거 취업제한 대상자로 확인될 경우 임용이 불가합니다.&#13;&#10; 4. 당초 원서기재 내용이 허위로 판명되어 응시자격제한 사유에 해당 되는 경우에는 합격 또는 임용이 취소될 수 있습니다." wordWrap="char" width="1132" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" onclick="divContent00_divContent01_staContent01_onclick" accessibilitydescription=" 1. 임용후보자 등록과 관련된 사항, 제출서류는 반드시 해당 시도교육청 안내문(공고문 등)을 확인하시기 바랍니다. " accessibilitylabel="유의사항설명"/>
              <Static id="staGd03" taborder="1" left="30" top="-1" height="22" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="29" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staGd01" taborder="2" left="30" top="125" height="21" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="29" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
          </Layouts>
