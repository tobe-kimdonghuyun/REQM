<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmMain" width="1200" height="345" titletext="교육공무직-마이페이지-응시표출력" onload="frmMain_onload" onactivate="test" ontimer="frmMain_ontimer">
    <Layouts>
      <Layout height="345" width="1200" screenid="ScreenDeskTop">
        <Div id="divMain" taborder="0" left="0" top="0" height="144" text="" initvalueid="ivDivAccessibilityOff" width="1200">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTltMain" taborder="0" text="응시표출력" left="0" top="70" height="44" cssclass="img_WF_SubTit01" width="180" initvalueid="ivTitleAccessibilityOn" onload="divTitle_imgTitle_onload"/>
              <Static id="staGd00" taborder="1" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staGd01" taborder="2" left="0" top="114" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divSummary" taborder="1" left="0" top="234" height="60" cssclass="div_WF_Search" right="0" initvalueid="ivDivAccessibilityOff" tabstop="true">
          <Layouts>
            <Layout>
              <Static id="staContent00" taborder="0" text="응시시험" top="15" height="30" cssclass="sta_WF_InfoTit02" initvalueid="ivStcAccessibilityOn" textAlign="left" width="83" left="31" onclick="divSummary_staSubTltInfo00_onclick"/>
              <Combo id="cboAppoExm" taborder="1" text="" left="114" top="16" width="930" height="30" index="-1" initvalueid="ivCmbEssential" cssclass="essential" innerdataset="dsResultRcpt" codecolumn="rcptNo" datacolumn="appoExamNmSum" displaynulltext="- 선택 -" accessibilitylabel="시험장" autoselect="true"/>
              <Button id="btnReportView" taborder="2" text="응시표조회" left="1063" top="13" width="103" height="36" onclick="btnReportView_onclick" initvalueid="ivBtnAccessibilityButton"/>
            </Layout>
            <Layout name="Layout0">
              <Edit id="edtSearchKeyword" left="217" top="11" width="223" height="30"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divContent" taborder="2" left="0" top="142" height="60" cssclass="div_WF_Search" right="0" initvalueid="ivDivAccessibilityOff" tabstop="true">
          <Layouts>
            <Layout>
              <Static id="staContent" taborder="0" top="12" height="34" cssclass="sta_WF_InfoTit02" initvalueid="ivStcAccessibilityOn" textAlign="left" width="1120" left="20" onclick="divSearch_staSubTltInfo00_onclick" font="16px/1.5 &quot;Noto Sans KR&quot;,&quot;NotoSansKR-Regular&quot;,&quot;Malgun Gothic&quot;,&quot;Arial&quot;,&quot;MS PGothic&quot;"/>
            </Layout>
            <Layout name="Layout0">
              <Edit id="edtSearchKeyword" left="217" top="11" width="223" height="30"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staGd02" taborder="3" left="0" top="204" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd03" taborder="4" left="0" top="295" height="50" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-교육공무직-마이페이지-합격자조회
*  @MenuPath    pa_ore_oew_rm
*  @FileName 	pa_ore_oewrm30_m02.xfdl
*  @Creator 	
*  @CreateDate 	2022.09.06
*  @Desction    온라인통합채용-교육공무직-마이페이지-합격자조회
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.09.01    		 	        최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs"
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

	// 휴대전화번호 필수 로그인 세션 체크
	var logInChkParam = {
		 redirectUrl : 'pa_ore_oew_rm::ore_oewrm30_m01.xfdl' // 현재 PAGE URL
		, redirectMenuId : '4002' // 교육공무직 응시표출력 메뉴 ID
	};
	// 휴대전화번호 세션 없을 시 로그인 페이지이동
	this.isEssenMblTelnoLogin(logInChkParam);
	
	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);

	// 선택 시도교육청코드
	var sCddcCd = this.smfGetCddcCode();
	
	// 지원자정보영역 초기화
	this.divContent.form.staContent.set_text("");
	
	// 시도교육청 앞 3자리 = 시도교육청 구분코드
	this.dsSearch.setColumn(0, "cddcScCd", sCddcCd.slice(0,3));
	this.dsSearch.setColumn(0, "cddcCd", sCddcCd);
	//  본인인증
	this.dsSearch.setColumn(0,"applpFlnm", this.smfGetSessionValue('userNm'));
	var brdt = this.smfGetSessionValue('brdt');
	if(this.smfIsNull(brdt)){
		 brdt = this.applpRrnoToBrdt(nexacro.base64Decode(this.smfGetSessionValue('userRrno')));
	}
	this.dsSearch.setColumn(0,"applpBrdt", brdt);
	//this.dsSearch.setColumn(0,"mblTelno" , this.smfGetSessionValue('mblTelNo'));
	this.dsSearch.setColumn(0,"pafrUserId" , this.smfGetSessionValue('userDtcNo'));
		
	// 내 지원서 목록
	this.fnSearchRcptList();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnReportCallback = function(svcid, errcd, errmsg){

};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
// 지원서 목록 검색
this.fnSearchRcptList = function(obj, e)
{
	// 지원서목록조회
	this.smfSearchService('listRcpt') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;

			var applpFlnm = this.dsSearch.getColumn(0,"applpFlnm");
			var applpBrdt = this.dsSearch.getColumn(0,"applpBrdt");
			this.divContent.form.staContent.set_text(applpFlnm + "(" + applpBrdt +")님. 응시시험을 선택 후 응시표 조회를 해주세요.");
			// 지원서 수
			var rcptCnt =  this.dsResultRcpt.getRowCount();
			if(rcptCnt <1){
				// 콤보 비활성
				this.divSummary.form.cboAppoExm.set_enable(false);
				this.divSummary.form.btnReportView.set_enable(false);
				this.divContent.form.staContent.set_text(applpFlnm + "(" + applpBrdt +")님. "+this.smfGetCddcName()+" 응시시험에 응시 내역이 없습니다.");
			}
	});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnElOtptReportView = function(){
	// 버튼표시여부
	var objButton = {
		"toolbar.save" : "false"    // 저장 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)           
		, "toolbar.addmemo" : "false"    // 메모 추가 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
		, "toolbar.savedm" : "false"    // 데이터 모듈 저장 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
		, "toolbar.etc" : "false"    // 다른 메뉴 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
	}
	var oOzOption = {
			reports : [	
						{	
							  displayname : "응시표"   
							, reportname : "/edu/pa/ore/oew/rm/ore_oewrm30_r01.ozr" 
							, jsonDs     : [this.dsMain] 
							, jsonDsName : ["dsMain"]         
							//, security     : "Y"   // [선택] 위변조방지 삽입   ("Y"(default):표시,"N":비표시)
							//, voiceBarcode : "Y"   // [선택] 보이스바코드 삽입 ("Y"(default):표시,"N":비표시)
							}
						]
						, hidestatus : true   // [선택] 하단 상태값 표시
						, button : objButton    // [선택] 버튼의 표시 비표시를 통제
	                };			
	this.smfReportView(this,"popup",oOzOption,this.fnReportCallback);  
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.btnReportView_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsEi.clearData();
	var rcptNo = this.divSummary.form.cboAppoExm.value;
	
	if(this.smfIsNull(rcptNo)){
		this.divSummary.form.cboAppoExm.setFocus();
		this.smfAlert("응시 시험을 선택 해주세요.");
		return;
	}

	var i      = this.dsResultRcpt.findRow("rcptNo", rcptNo);
	this.dsSearch.setColumn(0,"rcptNo"      , rcptNo); // 접수번호
	this.dsSearch.setColumn(0,"examDgr"     , "1"); // 차수
	this.dsSearch.setColumn(0,"empmnExamId" , this.dsResultRcpt.getColumn(i, 'appoExamId'));  // 채용시험 ID
	
	//*** 응시일자 조회 용도 ****//
	this.dsSearch.setColumn(0,"orgCd"              , this.dsSearch.getColumn(0, 'cddcCd'));
	this.dsSearch.setColumn(0,"eduPubsvCtpvOcptCd" , this.dsResultRcpt.getColumn(i, 'eduPubsvCtpvOcptCd'));
	this.dsSearch.setColumn(0,"dstrtCd"            , this.dsResultRcpt.getColumn(i, 'dstrtCd'));
	// 지원서목록조회
	this.smfSearchService('listEi') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			var applpFlnm = this.dsSearch.getColumn(0,"applpFlnm");
			var applpBrdt = this.dsSearch.getColumn(0,"applpBrdt");
			
			if( this.dsEi.rowcount == 0 ){
				this.smfAlert("응시표출력 내역이 없습니다.");
				return;
			}else{
				this.dsMain.clearData();
				this.dsMain.addRow();
				this.dsMain.copyRow(0,this.dsEi,this.dsEi.rowcount-1);
				if(this.dsMain.getColumn(0,"aiInqYn") == "N"){
					//this.divContent.form.staContent.set_text(applpFlnm + "(" + applpBrdt +") 응시자님. 응시표출력 조회기간이 아닙니다.");
					this.smfAlert("응시표 출력 기간이 아닙니다.");
					return;
				}else{
					this.dsMain.setColumn(0, 'applpFlnm', this.dsResultRcpt.getColumn(i, 'applpFlnm'));
					this.dsMain.setColumn(0, 'applpBrdt', this.dsResultRcpt.getColumn(i, 'applpBrdt'));
					this.dsMain.setColumn(0, 'sxdsNm', '여');  //성별
					if('1' === this.dsResultRcpt.getColumn(i, 'sxdsCd')){
						this.dsMain.setColumn(0, 'sxdsNm', '남');
					}
					this.fnElOtptReportView();
				}
			}
	});
};
]]></Script>
    <Objects>
      <Dataset id="dsMain" useclientlayout="true">
        <ColumnInfo>
          <Column id="aplemDsgnNo" type="STRING" size="256"/>
          <Column id="empmnExamId" type="STRING" size="256"/>
          <Column id="empmnExamNm" type="STRING" size="256"/>
          <Column id="eduPubsvCtpvOcptNm" type="STRING" size="256"/>
          <Column id="dstrtNm" type="STRING" size="256"/>
          <Column id="applpFlnm" type="STRING" size="256"/>
          <Column id="applpRrno" type="STRING" size="256"/>
          <Column id="sxdsCd" type="STRING" size="256"/>
          <Column id="sxdsNm" type="STRING" size="256"/>
          <Column id="chorDutyNm" type="STRING" size="256"/>
          <Column id="rcptNo" type="STRING" size="256"/>
          <Column id="applpBrdt" type="STRING" size="256"/>
          <Column id="atentMteCn" type="STRING" size="256"/>
          <Column id="otmpAtchFileCn" type="BLOB" size="256"/>
          <Column id="aiOffcsAtchFileCn" type="BLOB" size="256"/>
          <Column id="apstPhotoFileCn" type="BLOB" size="256"/>
          <Column id="aiInqYn" type="STRING" size="256"/>
          <Column id="aiInqBgngDt" type="STRING" size="256"/>
          <Column id="aiInqEndDt" type="STRING" size="256"/>
          <Column id="exmrNm" type="STRING" size="256" description="시험장명"/>
          <Column id="exrmNm" type="STRING" size="256" description="시험실명"/>
          <Column id="exmrRmkCn" type="STRING" size="256" description="비고"/>
          <Column id="examDgr" type="STRING" size="256" description="시험차수"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="false" updatecontrol="false">
        <ColumnInfo>
          <Column id="cddcScCd" type="STRING" size="256" description="접속시도교육청 구분코드"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="applpFlnm" type="STRING" size="256" description="응시시험목록조회용(X)"/>
          <Column id="applpBrdt" type="STRING" size="256" description="응시시험목록조회용(X)"/>
          <Column id="mblTelno" type="STRING" size="256" description="응시시험목록조회용(X)"/>
          <Column id="rcptNo" type="STRING" size="256" description="접수번호"/>
          <Column id="empmnExamId" type="STRING" size="256" description="채용시험개요ID"/>
          <Column id="examDgr" type="STRING" size="256" description="차수(무조건1차)"/>
          <Column id="orgCd" type="STRING" size="256" description="= cddcCd 조직코드"/>
          <Column id="eduPubsvCtpvOcptCd" type="STRING" size="256" description="직종코드"/>
          <Column id="dstrtCd" type="STRING" size="256" description="지역코드"/>
          <Column id="pafrUserId" type="STRING" size="256" description="응시시험목록조회용"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="applpFlnm">홍길동</Col>
            <Col id="applpBrdt">19950101</Col>
            <Col id="mblTelno">010-1234-5678</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsResultRcpt" useclientlayout="true">
        <ColumnInfo>
          <Column id="rcptNo" type="STRING" size="256" description="접수번호"/>
          <Column id="appoExamId" type="STRING" size="256"/>
          <Column id="appoExamNm" type="STRING" size="256" description="임용시험명"/>
          <Column id="eduPubsvCtpvOcptNm" type="STRING" size="256" description=""/>
          <Column id="eduPubsvCtpvOcptCd" type="STRING" size="256"/>
          <Column id="dstrtNm" type="STRING" size="256" description=""/>
          <Column id="dstrtCd" type="STRING" size="256"/>
          <Column id="applpFlnm" type="STRING" size="256"/>
          <Column id="aplemDsgnNo" type="STRING" size="256"/>
          <Column id="sxdsCd" type="STRING" size="256"/>
          <Column id="appoExamNmSum" type="STRING" size="256"/>
          <Column id="applpBrdt" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listRcpt</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResultRcpt=dsResultRcpt</Col>
            <Col id="url">ore_oew_rm30_002.do</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="id">listEi</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsEi=dsEi</Col>
            <Col id="url">ore_oew_rm30_003.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsEi" useclientlayout="true">
        <ColumnInfo>
          <Column id="empmnExamId" type="STRING" size="256" description="채용시험ID"/>
          <Column id="empmnExamNm" type="STRING" size="256" description="채용시험명"/>
          <Column id="eduPubsvCtpvOcptCd" type="STRING" size="256" description="직종코드"/>
          <Column id="eduPubsvCtpvOcptNm" type="STRING" size="256" description="직종명"/>
          <Column id="dstrtCd" type="STRING" size="256" description="지역코드"/>
          <Column id="dstrtNm" type="STRING" size="256" description="지역명"/>
          <Column id="aplemDsgnNo" type="STRING" size="256" description="응시지정번호"/>
          <Column id="exmrNm" type="STRING" size="256" description="시험장명"/>
          <Column id="exrmNm" type="STRING" size="256" description="시험실명"/>
          <Column id="exmrTelNo" type="STRING" size="256" description="시험장전화번호"/>
          <Column id="chorDutyNm" type="STRING" size="256" description="기관장 명칭"/>
          <Column id="atentMteCn" type="STRING" size="256" description="주의사항내용"/>
          <Column id="otmpAtchFileCn" type="BLOB" size="256"/>
          <Column id="aiOffcsAtchFileCn" type="BLOB" size="256"/>
          <Column id="apstPhotoFileCn" type="BLOB" size="256"/>
          <Column id="aiInqBgngDt" type="STRING" size="256"/>
          <Column id="aiInqEndDt" type="STRING" size="256"/>
          <Column id="aiInqYn" type="STRING" size="256"/>
          <Column id="exmrRmkCn" type="STRING" size="256" description="비고"/>
          <Column id="examDgr" type="STRING" size="256" description="시험차수"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="divBasicInfo.form.imgPicture00" propid="image" datasetid="dsMainBase" columnid="apstPhotoFileCn"/>
      <BindItem id="item1" compid="divMain.form.imgPicture" propid="image" datasetid="dsMain" columnid="otmpAtchFileCn"/>
    </Bind>
  </Form>
</FDL>
