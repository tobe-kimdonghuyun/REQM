<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmTemp01" width="1280" height="832" titletext="공지사항 목록조회" onload="frmTemp01_onload" nHeight="754">
    <Layouts>
      <Layout height="832" width="1280" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="69" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout/>
          </Layouts>
        </Div>
        <Div id="divSearch" taborder="1" left="0" top="30" height="70" cssclass="div_WF_Search" right="0" initvalueid="ivDivAccessibilityOn" accessibilitylabel="조회영역">
          <Layouts>
            <Layout>
              <Static id="Static00" taborder="0" text="검색" left="0" top="20" width="57" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Combo id="cboSearchType" taborder="1" left="57" width="105" height="30" innerdataset="dsSearchTypeCd" codecolumn="cd" datacolumn="text" index="0" text="제목+내용" readonly="false" top="20" value="ALL" initvalueid="ivCmbNormal"/>
              <Edit id="edtSearchKeyword" taborder="2" left="170" top="20" width="503" height="30" maxlength="30" initvalueid="ivEdtNormal"/>
              <Button id="btnInit" taborder="3" text="초기화" top="20" width="88" height="30" cssclass="btn_WF_Refresh03" onclick="divSearch_btnInit_onclick" right="104" initvalueid="ivBtnAccessibilityButton"/>
              <Button id="btnSearch" taborder="4" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="20" onclick="divSearch_btnSearch_onclick" initvalueid="ivBtnAccessibilityButton"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divPageSummary" taborder="2" left="7" top="120" width="393" height="30" url="comm::comp_pageSummary.xfdl" visible="true" text="" initvalueid="ivDivAccessibilityOff"/>
        <Grid id="grdMain" taborder="3" left="0" top="160" height="419" binddataset="dsResult" autofittype="col" right="0" oncellclick="grdMain_oncellclick" initvalueid="ivGrdAccessibilityOn" selecttype="cell" fillareatype="none">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="50"/>
                <Column size="638"/>
                <Column size="70"/>
                <Column size="110"/>
                <Column size="70"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="번호"/>
                <Cell col="1" text="제목"/>
                <Cell col="2" text="첨부"/>
                <Cell col="3" text="작성일"/>
                <Cell col="4" text="조회수" cssclass="LineNo"/>
              </Band>
              <Band id="body">
                <Cell text="expr:currow+1"/>
                <Cell col="1" displaytype="normal" edittype="none" text="bind:ntcMteTitlNm" cursor="pointer"/>
                <Cell col="2" displaytype="imagecontrol" edittype="none" cssclass="expr:(fileRefrnId != undefined &amp;&amp; fileRefrnId != &quot;&quot;) &amp;&amp; imptYn==&quot;Y&quot; ? &quot;cell_NotiFile,cell_bgGray&quot;:((fileRefrnId != undefined &amp;&amp; fileRefrnId != &quot;&quot;) &amp;&amp; imptYn == &quot;N&quot;?&quot;cell_NotiFile&quot;:((fileRefrnId == undefined || fileRefrnId == &quot;&quot;) &amp;&amp; imptYn== &quot;Y&quot;?&quot;cell_bgGray&quot;:&quot;&quot;))"/>
                <Cell col="3" displaytype="mask" edittype="none" text="bind:regDt" maskedittype="string" maskeditformat="@@@@-@@-@@ @@:@@"/>
                <Cell col="4" displaytype="normal" edittype="none" text="bind:ntcMteInqCnt" cssclass="LineNo"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Div id="divPaginator" taborder="4" left="0" top="599" height="30" url="comm::comp_paginator.xfdl" visible="true" pageViewSize="100" dsPage="dsPage" initvalueid="ivDivAccessibilityOff" right="0"/>
        <Static id="Static99_00_00_00_00_01" taborder="5" left="0" top="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_01" taborder="6" left="0" top="100" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_00_00" taborder="7" left="0" top="579" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_01_00" taborder="8" left="0" top="150" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_00_00_00" taborder="9" left="0" top="629" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsResult" useclientlayout="true">
        <ColumnInfo>
          <Column id="ntcMteId" type="STRING" size="256"/>
          <Column id="ntcMteTitlNm" type="STRING" size="256"/>
          <Column id="ntcMteCn" type="STRING" size="256"/>
          <Column id="ntcMteClfCd" type="STRING" size="256"/>
          <Column id="pstStsCd" type="STRING" size="256"/>
          <Column id="fileRefrnId" type="STRING" size="256"/>
          <Column id="ntcMteInqCnt" type="BIGDECIMAL" size="256"/>
          <Column id="aplcnBgngYmd" type="DATE" size="256"/>
          <Column id="aplcnEndYmd" type="DATE" size="256"/>
          <Column id="aplcnBgngTm" type="STRING" size="256"/>
          <Column id="aplcnEndTm" type="STRING" size="256"/>
          <Column id="imptYn" type="STRING" size="256"/>
          <Column id="rgtrNm" type="STRING" size="256"/>
          <Column id="rgtrDptNm" type="STRING" size="256"/>
          <Column id="mdfrNm" type="STRING" size="256"/>
          <Column id="mdfrDptNm" type="STRING" size="256"/>
          <Column id="rgtrId" type="STRING" size="256"/>
          <Column id="regDt" type="DATETIME" size="256"/>
          <Column id="mdfrId" type="STRING" size="256"/>
          <Column id="mdfcnDt" type="DATETIME" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">select</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsPageInfo=dsPageInfo</Col>
            <Col id="outDatasets">dsResult=dsResult dsPageInfo=dsPageInfo</Col>
            <Col id="svctp">R</Col>
            <Col id="url">ore_oew_bd00_001.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="message">조회</Col>
            <Col id="asynctp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsPageInfo" useclientlayout="true">
        <ColumnInfo>
          <Column id="pageIndex" type="INT" size="256"/>
          <Column id="pageSize" type="INT" size="256"/>
          <Column id="totalCount" type="INT" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="pageIndex">1</Col>
            <Col id="pageSize">10</Col>
            <Col id="totalCount">0</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="searchType" type="STRING" size="256"/>
          <Column id="searchKeyword" type="STRING" size="256"/>
          <Column id="appoExamScCd" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="ntcMteClfCd" type="STRING" size="256"/>
          <Column id="pafrSysClfCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="searchType">TITL</Col>
            <Col id="appoExamScCd">B</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearchTypeCd">
        <ColumnInfo>
          <Column id="cd" type="STRING" size="256"/>
          <Column id="text" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="cd">ALL</Col>
            <Col id="text">제목+내용</Col>
          </Row>
          <Row>
            <Col id="cd">TITL</Col>
            <Col id="text">제목</Col>
          </Row>
          <Row>
            <Col id="cd">CN</Col>
            <Col id="text">내용</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.cboSearchType" propid="value" datasetid="dsSearch" columnid="searchType"/>
      <BindItem id="item1" compid="divSearch.form.edtSearchKeyword" propid="value" datasetid="dsSearch" columnid="searchKeyword"/>
    </Bind>
    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 계약제교원 인력풀
*  @MenuPath    pa_ore_oew_bd
*  @FileName 	ore_oewbd00_m00.xfdl
*  @Creator 	최재형
*  @CreateDate 	2022.5.26
*  @Desction    계약제교원 인력풀 - 공지 목록
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.5.26    	최재형 	        최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frmTemp01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(this);
	
	// Form의 검색영역 초기화처리를 한다.
	this.fv_param = this.smfGetFormParams();
	this.fnFormInit(this.fv_param.menu);
	
	//  페이지를 조회한다.
	this.fnSearch();
	
	//선택 메뉴/ 임용코드에 따라 목록 제목 변경
	this.fnSetTitle(this.fv_param.menu);
};

this.fnFormInit = function(menuId)
{	
	// Form의 검색영역 초기화처리를 한다.(바인딩된 것)
	this.dsSearch.setColumn(0,"searchType"    , "ALL");
	this.dsSearch.setColumn(0,"searchKeyword" , ""   );
	this.dsSearch.setColumn(0,"cddcCd", this.smfGetCddcCode());
	this.dsSearch.setColumn(0,"appoExamScCd", this.smfGetAppoExamScCd());
	
	// 계약제교원인력풀로 접속할 경우 업무구분코드 HRD, 나머지는 ORE로 설정
	if (this.smfGetAppoExamScCd() == "5") {
		this.dsSearch.setColumn(0,"pafrSysClfCd", "HRD");
	} else {
		this.dsSearch.setColumn(0,"pafrSysClfCd", "ORE");
	}
	
	// 메뉴id == 2000 && 임용코드 5(계약제인력)아닐 경우 온라인임용/채용공고, 5일 경우 계약제 모집공고
	if (menuId == "2000" && this.smfGetAppoExamScCd() != "5") {
		this.dsSearch.setColumn(0,"ntcMteClfCd", "31");
	} else if (menuId == "2000" && this.smfGetAppoExamScCd() == "5") {
		this.dsSearch.setColumn(0,"ntcMteClfCd", "51");
	}
	
	// 메뉴id 6000이거나 8000 && 임용코드 5가 아닐 경우 온라인채용 공지사항
	if ((menuId == "6000" || menuId == "8000") && this.smfGetAppoExamScCd() != "5") {
		this.dsSearch.setColumn(0,"ntcMteClfCd", "30");
	}
	// 메뉴id 5000(상단 메뉴id) or 7000(퀵메뉴id)이고 임용코드 5일 경우 계약제 공지사항
	if ((menuId == "5000" || menuId == "7000") && this.smfGetAppoExamScCd() == "5") {
		this.dsSearch.setColumn(0,"ntcMteClfCd", "50");
	}

	// Form의 검색영역 초기화처리를 한다.(Form의 값 읽음)
	//this.divSearch.form.cboSearchType.set_index(0);
	//this.divSearch.form.edtSearchKeyword.set_value("");

	// 그리드 초기화
	
	
	// Page처리를 위한 값을 초기화한다.
	//this.divPage.form.fnInit();
}

//	공지사항, 임용/채용공고 제목 설정
this.fnSetTitle = function(menuId)
{
	return false;
	if (menuId == "6000" || menuId == "7000" || menuId == "8000") {
		this.divTitle.form.imgTitle.set_text("공지사항");
	}
	
	if (menuId == "2000" && (this.smfGetAppoExamScCd() != "4" || this.smfGetAppoExamScCd() != "5")) {
		this.divTitle.form.imgTitle.set_text("임용공고");
	}
	
	if (menuId == "2000" && this.smfGetAppoExamScCd() == "4") {
		this.divTitle.form.imgTitle.set_text("채용공고");
	}
	
	if (menuId == "2000" && this.smfGetAppoExamScCd() == "5") {
		this.divTitle.form.imgTitle.set_text("모집공고");
	}	
}

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

}


/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	// 업무콜백 처리
	this.smfAlert("응답결과 ==>"+e.row.Column0+", "+e.row.Column1+", "+e.row.Column2+", "+e.row.Column3);
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(obj, e)
{
 	// 서비스 객체 생성
	this.smfSearchService("select")
		// 데이터 검증
		.validateForm(this.divSearch)
		
		// 페이징처리
		.paginator(this.grdMain, this.divPaginator, this.divPageSummary, this.dsPageInfo, this.fnSearch, e)
		//.paging(this.grdMain, this.divPageInfo, this.dsPageInfo, obj, e)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.grdMain.set_nodatatext("교육현장에서 당신의 뛰어난 역량을 펼쳐주십시오");
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 
 // 초기화 버튼 클릭 이벤트
this.divSearch_btnInit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 값을 초기화한다.
	this.fnFormInit();
	// 
};

// 조회버튼 클릭 이벤트
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//  페이지를 조회한다.
	this.fnSearch();	
};


// 목록 셀클릭 이벤트
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	// 클릭한 셀을 구한다
	var nRow = e.row;
	var nCell = e.cell;
	if(nCell == 1) // 제목
	{

		var objDs = obj.getBindDataset();
		
		// 공지사항ID
		var sNtcMteId = objDs.getColumn(nRow,"ntcMteId");
		// 공지사항분류코드
		var sNtcMteClfCd = objDs.getColumn(nRow,"ntcMteClfCd");

		var params = {
				ntcMteId : sNtcMteId,
				ntcMteClfCd : sNtcMteClfCd,
				menuId : this.fv_param.menu,
				appoExamScCd : this.smfGetAppoExamScCd()
			};
		this.smfSetWorkPage("pa_ore_oew_bd::ore_oewbd00_m01.xfdl", params);
		
		// 서랍식 조회로 변경 예정 
	}
	else if(nCell == 2) // 첨부파일다운로드
	{
		var objDs = obj.getBindDataset();
		var sFileRefrnId = objDs.getColumn(nRow,"fileRefrnId");
		
		// 서버에 파일다운로드를 요청한다.(추후에 실시)
		
	}
};]]></Script>
  </Form>
</FDL>
