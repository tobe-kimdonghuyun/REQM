            </Layout>
          </Layouts>
        </Div>
        <Div id="div02" taborder="1" text="div02" left="0" top="154" height="40" width="1200" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Button id="btn01" taborder="0" text="мӣҗм„ңм ‘мҲҳ" left="0" top="0" width="130" height="40" cssclass="btn_WF_TabS" initvalueid="ivBtnAccessibilityLink" onclick="btn01_onclick"/>
              <Button id="btn02" taborder="1" left="140" top="0" width="170" height="40" cssclass="btn_WF_Tab" initvalueid="ivBtnAccessibilityLink" text="м „мһҗкІ°м ң" onclick="btn02_onclick"/>
              <Button id="btn03" taborder="2" text="мҲҳн—ҳн‘ң м¶ңл Ҙ" left="314" top="0" width="148" height="40" cssclass="btn_WF_Tab" initvalueid="ivBtnAccessibilityLink" onclick="btn03_onclick"/>
              <Button id="btn04" taborder="3" text="н•©кІ©мһҗ л°ңн‘ң" left="472" top="0" width="148" height="40" cssclass="btn_WF_Tab" initvalueid="ivBtnAccessibilityLink" onclick="btn04_onclick"/>
              <Button id="btn05" taborder="4" text="мһ„мҡ©(мұ„мҡ©)нӣ„ліҙмһҗ" left="631" top="0" width="170" height="40" cssclass="btn_WF_Tab" initvalueid="ivBtnAccessibilityLink" onclick="btn05_onclick"/>
