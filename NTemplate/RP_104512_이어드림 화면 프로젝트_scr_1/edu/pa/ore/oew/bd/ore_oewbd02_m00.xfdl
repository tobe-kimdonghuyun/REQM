        <Div id="divPaging" taborder="3" left="0" height="30" right="0" url="comm::comp_paginator.xfdl" dsPage="dsPage" pageViewSize="100" initvalueid="ivDivAccessibilityOff" tabstop="true" text="" top="divFAQ:40"/>
        <Static id="Static99_00_00_00_00" taborder="4" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01" taborder="5" left="0" top="114" height="40" cssclass="sta_GD_Size" text="40" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_01_00" taborder="6" left="0" top="194" height="40" cssclass="sta_GD_Size" text="40" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_00_00" taborder="7" left="0" top="740" height="40" cssclass="sta_GD_Size" text="40" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  лҢҖкөӯлҜј мҳЁлқјмқёмұ„мҡ©/кі„м•Ҫм ңкөҗмӣҗ - мһҗмЈјл¬»лҠ”м§Ҳл¬ё лӘ©лЎқмЎ°нҡҢ
*  @FileName 	ore_oewbd02_m00.xfdl
*  @Creator 	м„ңкҙ‘лӘ…
*  @CreateDate 	2022.10.18
*  @Desction    мһҗмЈјл¬»лҠ”м§Ҳл¬ё лӘ©лЎқмЎ°нҡҢ
************** мҶҢмҠӨ мҲҳм • мқҙл Ҙ ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.10.18     	м„ңкҙ‘лӘ… 	        мөңмҙҲ мғқм„ұ 
*******************************************************************************
*/

include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM ліҖмҲҳ м„ м–ё мҳҒм—ӯ
 ************************************************************************************************/
this.DivInfo = {};     // Q & A н•ӯлӘ© м •ліҙ 
this.fvTitleHeight = this.smfIsMobile()?104:70; // л””нҸҙнҠё лҶ’мқҙ
this.fvContentsHeight = this.smfIsMobile()?292:193; // л””нҸҙнҠё лҶ’мқҙ
this.fvContentsWidth = this.smfIsMobile()?400:747; // л””нҸҙнҠё лҶ’мқҙ

this.fv_prefixIdTitleDiv = "divTitle";
this.fv_prefixIdAreaStatic = "staArea";
this.fv_prefixIdTitleButton = "btnTitle";
this.fv_prefixIdOpenButton = "btnOpen";
this.fv_prefixIdHomeButton = "btnHome";
this.fv_prefixIdContentsDiv = "divContents";
this.fv_prefixIdContentsAnswer = "staAnswer";
this.fv_mofile = "";
if(this.smfIsMobile()){
	this.fv_mofile = "_M";
}

/************************************************************************************************
 * FORM EVENT мҳҒм—ӯ(onload, onbeforeclose)
 ************************************************************************************************/
this.faqFrm_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// нҸј мҙҲкё°нҷ”
	this.smfInitForm(obj);
	
	// мӢңмҠӨн…ң кө¬л¶„м—җ л”°лҘё кіөм§Җ мҪ”л“ң
	// [HRD] 30: мӣҗм„ңм ‘мҲҳм•ҲлӮҙ 31: м „мһҗкІ°м ңм•ҲлӮҙ 32: мҲҳн—ҳн‘ңм¶ңл Ҙм•ҲлӮҙ 33: н•©кІ©мһҗл°ңн‘ңм•ҲлӮҙ 34: мһ„мҡ©(мұ„мҡ©)нӣ„ліҙмһҗм•ҲлӮҙ
	// [ORE] 50: лӘЁм§‘л¶„м•ј 51: мӢ мІӯм„ңмһ‘м„ұл°©лІ• 52: мҰқл№ҷм„ңлҘҳм•ҲлӮҙ 53: н‘ңмӨҖк·јлЎңкі„м•Ҫм„ңм•ҲлӮҙ
	
	// нҢҢлқјл©”н„° м„ёнҢ…
	this.pv_params = this.smfGetFormParams();
	
	// мӢңлҸ„ көҗмңЎмІӯ мҪ”л“ң
	this.dsSearch.setColumn(0,"cddcCd", this.smfGetCddcCode());
	
	// м„ нғқн•ң мһ„мҡ©/мұ„мҡ© мң нҳ•мңјлЎң мӢңмҠӨн…ң кө¬л¶„ мҪ”л“ң set. 
	// 1: мң мҙҲл“ұ 2: мӨ‘л“ұ 3: м§Җл°©кіөл¬ҙмӣҗ 4: көҗмңЎкіөл¬ҙмӣҗ => ORE | 5: кі„м•Ҫм ңкөҗмӣҗ => HRD
	this.dsSearch.setColumn(0,"appoExamScCd", this.smfGetAppoExamScCd());
	
	if (this.dsSearch.getColumn(0,"appoExamScCd") == "5") {
			this.dsSearch.setColumn(0,"pafrSysClfCd", "HRD");
	} else {
			this.dsSearch.setColumn(0,"pafrSysClfCd", "ORE");
	}
		
	// кі„м•Ҫм ңкөҗмӣҗмңјлЎң м„ёнҢ…лҗ  кІҪмҡ° мғҒлӢЁ лІ„нҠјл“Өмқ„ лӢӨмқҢкіј к°ҷмқҙ ліҖкІҪн•ңлӢӨ.
	if (this.dsSearch.getColumn(0,"appoExamScCd") == "5") {
		this.div02.form.btn01.set_text("лӘЁм§‘л¶„м•ј");
		this.div02.form.btn02.set_text("мӢ мІӯм„ң мһ‘м„ұл°©лІ•");
		this.div02.form.btn03.set_text("мҰқл№ҷм„ңлҘҳ");
		this.div02.form.btn04.set_text("н‘ңмӨҖк·јлЎңкі„м•Ҫм„ң");
		this.div02.form.btn05.set_visible(false);
	}
	
	//2023.02.20 main л§ҒнҒ¬ м¶”к°Җ
	if(!this.smfIsNull(this.pv_params.sIndex)){
		if(this.pv_params.sIndex == "0"){
			this.div02.form.btn01.click();
		}else if(this.pv_params.sIndex == "1"){
			this.div02.form.btn02.click();
		}else if(this.pv_params.sIndex == "2"){
			this.div02.form.btn03.click();
		}else if(this.pv_params.sIndex == "3"){
			this.div02.form.btn04.click();
		}else if(this.pv_params.sIndex == "4"){
			this.div02.form.btn05.click();
		}
	}else{
		this.div02.form.btn01.click();
	}
	
	/*
	if (!this.smfIsNull(this.pv_params.tabGubun) && this.smfGetAppoExamScCd() != "5") {
		if (this.pv_params.tabGubun == "30"){
			this.div02.form.btn01.click();
		} else if (this.pv_params.tabGubun == "31") {
			this.div02.form.btn02.click();
		} else if (this.pv_params.tabGubun == "32") {
			this.div02.form.btn03.click();
		} else if (this.pv_params.tabGubun == "33") {
			this.div02.form.btn04.click();
		} else if (this.pv_params.tabGubun == "34") {
			this.div02.form.btn05.click();
		}
	}
	if (!this.smfIsNull(this.pv_params.tabGubun) && this.smfGetAppoExamScCd() == "5") {	
		if (this.pv_params.tabGubun == "50"){
			this.div02.form.btn01.click();
		} else if (this.pv_params.tabGubun == "51") {
			this.div02.form.btn02.click();
		} else if (this.pv_params.tabGubun == "52") {
			this.div02.form.btn03.click();
		} else if (this.pv_params.tabGubun == "53") {
			this.div02.form.btn04.click();
		}
	} else {
		this.div02.form.btn01.click();
	} 
	*/
	
	this.divFAQ.fv_DIV_MARGIN = 0;	
};

/************************************************************************************************
 * CALLBACK мҪңл°ұ мІҳлҰ¬л¶Җл¶„(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

};

/************************************************************************************************
 * CRUD л°Ҹ TRANSACTION м„ңл№„мҠӨ нҳём¶ң мІҳлҰ¬
 ************************************************************************************************/
this.fnSearch = function(obj, e)
{
	this.fnDeleteDiv();
 	// м„ңл№„мҠӨ к°қмІҙ мғқм„ұ
	this.smfSearchService("select")
		// лҚ°мқҙн„° кІҖмҰқ
		//.validateForm(this.edtSearchKeyword)
		// нҺҳмқҙм§•мІҳлҰ¬
		.paginator(this.dsResult, this.divPaging, this.div02.form.divTotal ,this.dsPageInfo, obj, e)
		// мӢӨн–ү
		.run()
		// мҪңл°ұ
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			//console.log("this.dsResult = " + this.dsResult.saveXML());
			
			var objTargetDivForm =  this.divFAQ.form;

			for(var i=0;i<this.dsResult.rowcount;i++)
			{
				this.fnAppendDiv(objTargetDivForm,this.dsResult, i);			
			}
			this.smfResetScroll(this.divFAQ.form);
		});
};

/************************************************************************************************
 * мӮ¬мҡ©мһҗ FUNCTION мҳҒм—ӯ
 ************************************************************************************************/
/**
 * н•ҳлӮҳмқҳ кІҢмӢңкёҖмқ„ м¶”к°Җн•ңлӢӨ.
 * @param : {object}   scope  лҢҖмғҒForm
 * @param : {object}   objDs  м¶”к°Җн•  лҚ°мқҙн„°м…Ӣ
 * @param : {Number}   nRow   м¶”к°Җн•  лҚ°мқҙн„°м…Ӣмқҳ row
 */
this.fnAppendDiv = function(scope,objDs,nRow)
{
	// м¶”к°Җлҗ  indexлҘј кө¬н•ңлӢӨ.
	// (кё°ліём ҒмңјлЎңлҠ” л¶ҖлӘЁ Divм—җ мһҲлҠ” _count мң м Җн”„лЎңнҚјнӢ° мӮ¬мҡ©. м—Ҷмңјл©ҙ 0мңјлЎң мҙҲкё°нҷ”)
	var nIdx = 0;
	if(this.smfIsNull(scope.parent._count))
	{  // м„ёнҢ…мқҙ м•Ҳлҗҳм–ҙ мһҲмңјл©ҙ 0мңјлЎң м„ёнҢ…
		nIdx = 0;
		scope.parent._count = 0;
	}
	else
	{
		nIdx = scope.parent._count;
	}
	
	// нғҖмқҙнӢҖ Div л§Ңл“Өкё°
	var objTitleDiv = this.fnAddTitleDiv(scope,nIdx,objDs,nRow);
	// мғҒм„ё Divл§Ңл“Өкё°
	var objContentsDiv = this.fnAddContentsDiv(scope,nIdx,objDs,nRow);

	// м№ҙмҡҙнҠё к°ҜмҲҳлҘј мҰқк°ҖмӢңнӮЁлӢӨ.
	scope.parent._count++;
}

/**
 * TitleDivлҘј м¶”к°Җн•ңлӢӨ.
 * @param : {object}   scope  лҢҖмғҒForm
 * @param : {Number}   nIdx   м¶”к°Җн•  div Index
 * @param : {object}   objDs  м¶”к°Җн•  лҚ°мқҙн„°м…Ӣ
 * @param : {Number}   nRow   м¶”к°Җн•  лҚ°мқҙн„°м…Ӣмқҳ row
 */
this.fnAddTitleDiv = function (scope,nIdx,objDs,nRow)
{
	var sDivId = this.fv_prefixIdTitleDiv + nIdx;
	var sFaqTitlNm = objDs.getColumn(nRow,"faqTitlNm");
	
	//===================================================================
	// Div мғқм„ұ
	//===================================================================
	var nHeight = this.fvTitleHeight;
	var sBeforeContentsId = "divContents"+(nIdx-1);
	var sChildId = "divContents"+nIdx;
	var sDivCssClass = "div_WF_FAQBox_Q02 div_FAQ_question"+this.fv_mofile;	// div_FAQ_question (нҒҙлҰӯлҗҳм§Җм•ҠмқҖ нғҖмқҙнӢҖ)
	var sDivArrow = "btn_FAQ_open"+this.fv_mofile; // лІ„нҠј (V м—ҙлҰјлІ„нҠј)
	
	var objDiv = scope[sDivId];
	
	if(!objDiv)
	{
		objDiv = new Div();
		if( nIdx==0 )
		{	// мөңмҙҲмқҳ мҳӨлёҢм қнҠёлҠ” мң„мқҳ Divмқҳ Topмқ„ 0мңјлЎң н•ңлӢӨ
			objDiv.init(sDivId, 0, 0, null, nHeight, 0, null);				//л§Ҳм§Җл§үм—җ лҶ’мқҙ мһ¬мЎ°м •н•ҳкё° л•Ңл¬ём—җ нҒ¬кІҢ мғҒкҙҖx 
		}
		else
		{   // мөңмҙҲ Divмқҙмҷёмқҳ кІғмқҖ л°”лЎңмң„мқҳ мҳӨлёҢм қнҠё л°”лЎңм•„лһҳм—җ мғқм„ұн•ңлӢӨ. 
			objDiv.init(sDivId, 0, sBeforeContentsId +":"+ 0, null, nHeight, 0, null);
			//objDiv.init(sDivId, 0, (nIdx*nHeight), null, nHeight, 0, null);
		}

		// л§Ңл“Өм–ҙм§„ DivлҘј л¶ҖлӘЁм—җ м¶”к°Җ
		// Add Object to Parent Form  
		scope.addChild(sDivId, objDiv); 
		
		//мІ«лІҲм§ён–үмқјл•Ң cssліҖкІҪ
		if(nRow == 0) sDivCssClass = "div_WF_FAQBox_Q01 div_FAQ_question"+this.fv_mofile;
		
		//л§Ҳм§Җл§үн–үмқјл•Ң cssліҖкІҪ
		if(nRow == this.dsResult.rowcount -1) sDivCssClass = "div_WF_FAQBox_Q03 div_FAQ_question_end"+this.fv_mofile;
		//н–үмқҙ 1к°ңмқјл•Ң
		if(nRow == 0 && nRow == this.dsResult.rowcount -1 )  sDivCssClass = "div_WF_FAQBox_Q04"+this.fv_mofile;
		
		// Divмқҳ мҶҚм„ұмқ„ м„ёнҢ…
		objDiv.set_cssclass(sDivCssClass);
		objDiv.set_initvalueid("ivDivAccessibilityOff");
		objDiv.childId = sChildId;
		objDiv.dirArrow = sDivArrow;
		
		
		
		// DivлҘј ліҙмқҙкІҢ м„Өм •(addChild()н•ҳл©ҙ л°ҳл“ңмӢң show()лҘј н•ҙмЈјм–ҙм•ј мӢӨм ңлЎң нҷ”л©ҙм—җ ліҙмһ„)  
		objDiv.show(); 
	}
	
	// м§Ҳл¬ё лІ„нҠј(Q) л„Јкё°
	var questionButton = new Static();
	var sQuestionButtonId = "question"+nIdx;
	// PCмқјл•Ңлһ‘ лӘЁл°”мқјмқјл•Ң кө¬л¶„н•ҙм„ң мғқм„ұ
	if(this.smfIsMobile()){
		questionButton.init(sQuestionButtonId, 28, 31, 34, 34, null, 0);
	} else {
		questionButton.init(sQuestionButtonId, 20, 19, 35, 30, null, 0);
	}
	questionButton.set_cssclass("sta_WF_FAQ_Q"+this.fv_mofile);
	questionButton.set_initvalueid("ivStcAccessibilityOn");
	//questionButton.set_text("Q");
	objDiv.form.addChild(sQuestionButtonId, questionButton); 
	questionButton.show();
	
	//===================================================================
	// нғҖмқҙнӢҖл¬ёмһҘ(Static) мғқм„ұ
	//===================================================================
	// =======л¬ёмһҘмқ„ н‘ңмӢңн•ҳлҠ” Staticмқ„ мғқм„ұ
	var sStaticId = this.fv_prefixIdTitleButton+nIdx;
	
	// м§Ҳл¬ёмҳҒм—ӯ(Question) мғқм„ұ
	var objStatic = objDiv.form[sStaticId];
	if(!objStatic)
	{
		objStatic = new Static();
		
		//right к°’ btnOpen м—җ м°ёмЎ°н• мҲҳ мһҲлҸ„лЎқ ліҖкІҪн•„мҡ”
		if(this.smfIsMobile()){
			objStatic.init(sStaticId, sQuestionButtonId + ":"+0, 0, null, null, 55, 0);				
		} else {
			objStatic.init(sStaticId, sQuestionButtonId + ":"+0, 0, null, null, 55, 0);
		}
		
		// л§Ңл“Өм–ҙм§„ Staticмқ„ Divм—җ м¶”к°Җ
		objDiv.form.addChild(sStaticId, objStatic); 
		
		// Staticмқҳ мҶҚм„ұ м„Өм •
		objStatic.set_initvalueid("ivStcAccessibilityOn");
		objStatic.set_verticalAlign("middle");
		objStatic.set_cssclass("sta_FAQ_hang"+this.fv_mofile);
		objStatic.dirArrow = sDivArrow;
		objStatic.childId = sChildId;
		
		// Staticм—җ нҒҙлҰӯмқҙлІӨнҠё м¶”к°Җ
		objStatic.addEventHandler("onclick",function(obj,e){
										this.fnReDraw(scope,obj,e,nIdx);
									}
									,this);
		objStatic.show();
	}
	objStatic.set_text(sFaqTitlNm);
	
	//мһ…л Ҙк°’ лҶ’мқҙ кө¬н•ҳкё°
	var expandtextHeight = this.fnGetContentsHeight(objStatic);

	//TODO: PCлһ‘ лӘЁл°”мқјмқҙлһ‘ лӮҳлҲ м„ң нҢЁл”©к°’ мӨҳм•јн•Ё(ліҖмҲҳлЎң м„Өм •)
	var plusHeight = this.smfIsMobile()?10:7;
	objDiv.setOffsetHeight(expandtextHeight+plusHeight);

	objDiv.set_visible(true);
	
	// м§Ҳл¬ёDivм—җ мҡ°мёЎ нҷ”мӮҙн‘ңлІ„нҠјмқ„ м¶”к°Җн•ңлӢӨ.
	this.fnCreateBtnOpen(objDiv.form,sChildId,nIdx);
	
	//м—¬кё° мқҙнӣ„м—җ нғҖмқҙнӢҖ rightк°’ м°ёмЎ°н•ҙм•ј н• л“Ҝ?
	
};

/**
 * Contents DivлҘј м¶”к°Җн•ңлӢӨ.
 * @param : {object}   scope  лҢҖмғҒForm
 * @param : {Number}   nIdx   м¶”к°Җн•  div Index
 * @param : {object}   objDs  м¶”к°Җн•  лҚ°мқҙн„°м…Ӣ
 * @param : {Number}   nRow   м¶”к°Җн•  лҚ°мқҙн„°м…Ӣмқҳ row
 */
this.fnAddContentsDiv = function (scope,nIdx,objDs,nRow)
{
	var sDivId = this.fv_prefixIdContentsDiv + nIdx;
	var sFaqCn = objDs.getColumn(nRow,"faqCn");		//лӢөліҖ

	//===================================================================
	// Div мғқм„ұ
	//===================================================================
	var nHeight = this.fvContentsHeight;
	var sBeforeContentsId = this.fv_prefixIdTitleDiv + nIdx;
	var sChildId = this.fv_prefixIdContentsDiv+nIdx;
	var sDivCssClass = "div_WF_FAQBox_A01 div_FAQ_answer"+this.fv_mofile;	
	var sDivArrow = "btn_FAQ_open"+this.fv_mofile;
	
	//л§Ҳм§Җл§үн–үмқјл•Ң cssліҖкІҪ(м¶”нӣ„ ліҖкІҪн•„мҡ”)
	if(nRow == this.dsResult.rowcount -1) sDivCssClass = "div_WF_FAQBoxEnd_A01 div_FAQ_answer_end"+this.fv_mofile;
	
	// Create Object  
	var objDiv = scope[sDivId];
	if(!objDiv)
	{
		objDiv = new Div();
		
		if(this.smfIsMobile()){
			objDiv.init(sDivId, 0, sBeforeContentsId +":"+ 0, null, nHeight, 0, null);
		} else {
			objDiv.init(sDivId, 0, sBeforeContentsId +":"+ 0, null, nHeight, 0, null);
		}
		
		// л§Ңл“Өм–ҙм§„ DivлҘј л¶ҖлӘЁм—җ м¶”к°Җ
		// Add Object to Parent Form  
		scope.addChild(sDivId, objDiv); 
		
		// Divмқҳ мҶҚм„ұмқ„ м„ёнҢ…
		objDiv.set_cssclass(sDivCssClass);
		objDiv.set_initvalueid("ivDivAccessibilityOff");
		objDiv.childId = sChildId;
		objDiv.dirArrow = sDivArrow;
		objDiv.divmargin = "2";
		
		// DivлҘј ліҙмқҙкІҢ м„Өм •(addChild()н•ҳл©ҙ л°ҳл“ңмӢң show()лҘј н•ҙмЈјм–ҙм•ј мӢӨм ңлЎң нҷ”л©ҙм—җ ліҙмһ„)  
		objDiv.show(); 
	}
	
	//===================================================================
	// Contentsл¬ёмһҘ(Static) мғқм„ұ
	//===================================================================
	var sStaticCssClass = "sta_FAQ_answer"+this.fv_mofile;
	
	// 1-1. лӢөліҖ лІ„нҠј(A) мғқм„ұ 
	var sBtnQuestion = "labelQuestion"+nIdx;
	var objButton = new Static();
	
	if(this.smfIsMobile()){
		objButton.init(sBtnQuestion, 28, 20, 34, 34, null, null);
	} else {
		objButton.init(sBtnQuestion, 20, 19, 35, 30, null, null);
	}
	objButton.set_cssclass("sta_WF_FAQ_A sta_FAQ_A"+this.fv_mofile);
	objButton.set_initvalueid("ivStcAccessibilityOn");
	//objButton.set_text("лӢөліҖ");
	objDiv.form.addChild(sBtnQuestion, objButton); 
	objButton.show();
	
	// 1-2. лӢөліҖ лӮҙмҡ© мһ…л Ҙ
	var sStaticAnswer = this.fv_prefixIdContentsAnswer+nIdx;

	var objStaticAnswer = objDiv.form[sStaticAnswer];
	if(!objStaticAnswer)
	{
		objStaticAnswer = new Div();  
		if(this.smfIsMobile()){
			objStaticAnswer.init(sStaticAnswer, sBtnQuestion + ":" + 0, 13, null, null, 20, 31);
		} else {
			objStaticAnswer.init(sStaticAnswer, sBtnQuestion + ":" + 0, 19, null, null, 53, 0);		
		}
		
		objDiv.form.addChild(sStaticAnswer, objStaticAnswer); 
		
		// Staticмқҳ мҶҚм„ұ м„Өм •
// 		objStaticAnswer.set_initvalueid("ivStcAccessibilityOn");
// 		objStaticAnswer.dirArrow = sDivArrow;	
// 		objStaticAnswer.childId = "";
		//objStaticAnswer.show();

		// Staticмқҳ мҶҚм„ұ м„Өм •
 		objStaticAnswer.set_initvalueid("ivStcAccessibilityOn");
		objStaticAnswer.set_async(false);
 		objStaticAnswer.set_url("comm::comp_webEditor.xfdl");

 		objStaticAnswer.form.fnInit(this, this.fnWebEditorCallback, this.fnWebEditorSetHtmlCallback);
		
 		//objStaticAnswer.autoHeight = "Y";
 		
 		objStaticAnswer._html = sFaqCn;
 		
 		objStaticAnswer.dirArrow = sDivArrow;	
 		objStaticAnswer.childId = "";
		
		objStaticAnswer.show();
	}
	objStaticAnswer.set_cssclass(sStaticCssClass);	
	objStaticAnswer.set_verticalAlign("top");
	objStaticAnswer.set_text(sFaqCn);
	
	// лӢөліҖ(Answer)мқҖ мІҳмқҢм—җлҠ” м•ҲліҙмқҙкІҢ мІҳлҰ¬(лҶ’мқҙлҘј 0, visible=false)
	objDiv.setOffsetHeight(0);
	objDiv.set_visible(false);
	
	this.smfResetScroll(objDiv);
}

/*
*	мӣ№м—җл””н„°к°Җ onloadлҗң мқҙнӣ„ нҳём¶ңлҗҳлҠ” callback
*   obj : мӣ№м—җл””н„° DivмҳӨлёҢм қнҠё
*/
this.fnWebEditorCallback = function(obj)
{
	// мқјл°ҳм ҒмңјлЎңлҠ” лҚ°мқҙн„°лҘј м„ёнҢ…
	obj.form.fnSetHtml(obj._html);
};

/*
*	мӣ№м—җл””н„°к°Җ textлҘј ліҖкІҪ н•  кІҪмҡ° нҳём¶ңн•ҳлҠ” callback
*   obj : мӣ№м—җл””н„° DivмҳӨлёҢм қнҠё
*/
this.fnWebEditorSetHtmlCallback = function(obj,contentHeight)
{
	// мқјл°ҳм ҒмңјлЎңлҠ” WebEditor DivлҘј resetScrollн•ҙмӨҢ.
	//  (Web Editorмқҳ лҶ’мқҙк°Җ ліҖкІҪмқҙ лҗҳм–ҙ мһҲмқҢ(autoHeight="Y"мқё кІҪмҡ°))
	//this.smfResetScroll(this.divDetail.form.divWebEditor);
};

/**
 * open лІ„нҠј мғқм„ұ
 * @param : scope ( Div.form)
 * @param : divInfo 
 */
this.fnCreateBtnOpen = function(scope,sChildId,nIdx)
{
	var sBtnId = this.fv_prefixIdOpenButton+nIdx;
	var sDivArrow = "btn_WF_FAQDrop btn_FAQ_open"+this.fv_mofile;
		
	// лІ„нҠјмқ„ мғқм„ұ
	var objButton = scope[sBtnId];
	if(!objButton)
	{
		objButton = new Button(); 
		if(this.smfIsMobile()){
			objButton.init(sBtnId, null, 0, 36, null, 30, 0);
		} else {
			objButton.init(sBtnId, null, 0, 30, null, 23, 2);
		}
		
		
		// л§Ңл“Өм–ҙм§„ Buttonмқ„ Divм—җ м¶”к°Җ
		scope.addChild(sBtnId, objButton);
		
		// лІ„нҠјмқҳ мҶҚм„ұмқ„ м„Өм •
		objButton.set_initvalueid("ivBtnAccessibilityButton");	
		objButton.childId = sChildId;
		objButton.dirArrow = sDivArrow;
		
		// Buttonм—җ нҒҙлҰӯмқҙлІӨнҠё м¶”к°Җ
		var sStaticId = this.fv_prefixIdTitleButton+nIdx;
		objButton.addEventHandler("onclick",function(obj,e){
			this.fnReDraw(scope.parent.parent, scope[sStaticId], e, nIdx);
		},this);
		
		// Buttonмқ„ ліҙмқҙкІҢ м„Өм •(addChild()н•ҳл©ҙ л°ҳл“ңмӢң show()лҘј н•ҙмЈјм–ҙм•ј мӢӨм ңлЎң нҷ”л©ҙм—җ ліҙмһ„)  
		objButton.show();  
	}
	objButton.set_cssclass("btn_WF_FAQDrop btn_FAQ_open"+this.fv_mofile);
	
};


/**
 * мғқм„ұ м»ҙнҸ¬л„ҢнҠё мһ¬ м„Өм • л°Ҹ reDraw н•Ё
 * @param : obj - Static
 * @param : e   - Static eventInfo
 */
this.fnReDraw = function(scope,obj,e, nIdx)
{
	// мғҒнғңк°’ м¶”к°Җ //мҲҳм •
	var openFlag = true;
	if(obj.parent.parent.form[this.fv_prefixIdOpenButton+nIdx].cssclass == "btn_WF_FAQDropup btn_FAQ_close"+this.fv_mofile){
		openFlag = false;
	}
	
	// class мҙҲкё°нҷ” 
	for(var i=0;i < scope.components.length;i++)
	{	
		if(scope.components[i] instanceof nexacro.Div )
		{
			// titleDiv мқҙл©ҙ
			if(scope.components[i].id.substr(0,this.fv_prefixIdTitleDiv.length) == this.fv_prefixIdTitleDiv)
			{
				
				if(i == 0) {
					scope.components[i].set_cssclass("div_WF_FAQBox_Q01 div_FAQ_question"+this.fv_mofile);
				} else if(i == (scope.components.length-2)) {
					scope.components[i].set_cssclass("div_WF_FAQBox_Q03 div_FAQ_question"+this.fv_mofile);
				} else {
					scope.components[i].set_cssclass("div_WF_FAQBox_Q02 div_FAQ_question"+this.fv_mofile);
				}
				
				//н–үмқҙ 1к°ңмқјл•Ң
				if(i == 0 && i == (scope.components.length-2)) {
					scope.components[i].set_cssclass("div_WF_FAQBox_Q04 div_FAQ_question"+this.fv_mofile);
				}				
				
				scope.components[i].form[this.fv_prefixIdOpenButton+(scope.components[i].id.substr(scope.components[i].id.length-1, scope.components[i].id.length))].set_cssclass("btn_WF_FAQDrop btn_FAQ_open"+this.fv_mofile);
				//лӢӨлҘё м§Ҳл¬ё нҒҙлҰӯн–Ҳмқ„ л•Ң нғҖмқҙнӢҖ к°•мЎ° н•ҙм ң
				scope.components[i].form[this.fv_prefixIdTitleButton+(scope.components[i].id.substr(scope.components[i].id.length-1, scope.components[i].id.length))].set_cssclass("sta_FAQ_hang"+this.fv_mofile);
			}
			// contentsDiv мқҙл©ҙ
			if(scope.components[i].id.substr(0,this.fv_prefixIdContentsDiv.length) == this.fv_prefixIdContentsDiv)
			{
				scope.components[i].setOffsetHeight(0);
				scope.components[i].set_visible(false);
				if(!this.smfIsNull(scope.components[i+1])){
					//scope.components[i+1].setOffsetHeight(79);
				}
			}
		}
	}
	
	//лӢөліҖ м—ҙкі  лӢ«мқ„ л•Ң, нҷ”л©ҙ мһ¬мЎ°м •
	this.smfResetScroll(this.divFAQ.form);
	

	var objTitleDiv = obj.parent.parent;
	var objTitleStatic = objTitleDiv.form[this.fv_prefixIdTitleButton+nIdx];
	var objTitleButton = objTitleDiv.form[this.fv_prefixIdOpenButton+nIdx];
	var objContentsDiv = scope[objTitleDiv.childId];
	var objContentsStatic = objContentsDiv.form[this.fv_prefixIdContentsAnswer+nIdx];
	
	// мһҗмЈјл¬»лҠ”м§Ҳл¬ё м •ліҙлҘј м„ңлһҚнҳ•мңјлЎң мҳӨн”Ҳ 
	if(!this.smfIsNull(obj.childId) && openFlag){
		if(nIdx == (scope.components.length / 2 - 1)) {
			objTitleDiv.set_cssclass("div_WF_FAQBox_Q02 div_FAQ_question"+this.fv_mofile);
		}
		//н–үмқҙ 1к°ңмқјл•Ң
		if(0 == (scope.components.length / 2 - 1)) {
			objTitleDiv.set_cssclass("div_WF_FAQBox_Q01 div_FAQ_question"+this.fv_mofile);
		}
		
		//мқҙкұ° мҷң м•Ҳлҗҳм§Җ?  м—¬кё°м„ң л¶Җн„° мӢңмһ‘=====================================
		if(this.smfIsMobile()){
			objTitleDiv.set_cssclass("div_FAQ_question_M");
		}
		
		//objTitleDiv.set_cssclass("div_FAQ_answer");
		
		//м„ңлһҚнҳ•мңјлЎң мҳӨн”Ҳлҗҳм—Ҳмқ„ л•Ң нғҖмқҙнӢҖ к°•мЎ°
		objTitleStatic.set_cssclass("sta_FAQ_hang_S"+this.fv_mofile);
		
		//objContentsDiv.setOffsetHeight(193);
		objTitleButton.set_cssclass("btn_WF_FAQDropup btn_FAQ_close"+this.fv_mofile);
		objContentsDiv.set_visible(true);
		var expandtextHeight = this.fnGetContentsHeight(objContentsStatic);
		objContentsDiv.setOffsetHeight(expandtextHeight+7);
		
		// лӢөліҖ div лҶ’мқҙ мЎ°м Ҳ
		var objStaticAnswer = objContentsDiv.form[objContentsStatic.id];
		objContentsDiv.setOffsetHeight(objStaticAnswer.form.fnGetHeight()+38+7);
		
	}
	this.smfResetScroll(scope);
};


//лӢӨмӢң мЎ°нҡҢн• л•Ң, лҜёлҰ¬ мЎ°нҡҢлҗҳм–ҙмһҲлҠ” к°’л“Өмқ„ м§Җмҡ°лҠ” н•ЁмҲҳ
this.fnDeleteDiv = function()
{
	var objComps = this.divFAQ.form.components;
	var nCount = objComps.length
	for(var i=nCount-1;i>=0;i--)
	{
		var objComp = objComps[i];
		//objComp.set_visible(false);
		var objDelete = this.divFAQ.removeChild(objComp.id);
		if(objDelete)
		{
			objDelete.destroy();
		}
	}
	
	this.divFAQ._count = 0;
}

//лҶ’мқҙ к°’ кө¬н•ҳлҠ” н•ЁмҲҳ
this.fnGetContentsHeight = function(objContentsStatic)
{
	var strFont = 'bold 16px/1.5 "NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic"';
	var strMFont = '28px/1.5 "NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic"';
	var Font = this.smfIsMobile()?strMFont:strFont;
	var nHeightPadding = 38;		//19 X 2 (н…ңн”ҢлҰҝм—җ 19px)	
	
	
	var staText = objContentsStatic.text;
	var staWidth = objContentsStatic.getOffsetWidth();
	var nTextHeight = nexacro.getTextSize(staText,Font,staWidth,"char");
	
	return nTextHeight.ny+nHeightPadding ;
};
/************************************************************************************************
 * к°Ғ COMPONENT лі„ EVENT мҳҒм—ӯ
 ************************************************************************************************/
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnDeleteDiv();
	this.fnSearch(obj, e);
};

this.btn01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (this.dsSearch.getColumn(0,"appoExamScCd") == "5") {
		this.dsSearch.setColumn(0,"faqClfCd" , "50"); //кі„м•Ҫм ңкөҗмӣҗ м ‘мҶҚмӢң faq мҪ”л“ң 50мңјлЎң set (лӘЁм§‘л¶„м•ј)
	} else {
		this.dsSearch.setColumn(0,"faqClfCd" , "30"); // нҶөн•©мұ„мҡ© мӣҗм„ңм ‘мҲҳм•ҲлӮҙfaq мҪ”л“ң 30
	}	
	this.div02.form.btn01.set_cssclass("btn_WF_TabS");
	this.div02.form.btn02.set_cssclass("btn_WF_Tab");
	this.div02.form.btn03.set_cssclass("btn_WF_Tab");
	this.div02.form.btn04.set_cssclass("btn_WF_Tab");
	this.div02.form.btn05.set_cssclass("btn_WF_Tab");
	
	this.fnSearch(obj, e);
};

this.btn02_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (this.dsSearch.getColumn(0,"appoExamScCd") == "5") {
		this.dsSearch.setColumn(0,"faqClfCd" , "52"); //кі„м•Ҫм ңкөҗмӣҗ м ‘мҶҚмӢң faq мҪ”л“ң 52лЎң set (мӢ мІӯм„ңмһ‘м„ұл°©лІ•)
	} else {
		this.dsSearch.setColumn(0,"faqClfCd" , "31"); //м „мһҗкІ°м ңм•ҲлӮҙ faq мҪ”л“ң 31
	}	
	this.div02.form.btn02.set_cssclass("btn_WF_TabS");
	this.div02.form.btn01.set_cssclass("btn_WF_Tab");
	this.div02.form.btn03.set_cssclass("btn_WF_Tab");
	this.div02.form.btn04.set_cssclass("btn_WF_Tab");
	this.div02.form.btn05.set_cssclass("btn_WF_Tab");
	
	this.fnSearch(obj, e);
};

this.btn03_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (this.dsSearch.getColumn(0,"appoExamScCd") == "5") {
		this.dsSearch.setColumn(0,"faqClfCd" , "53"); //кі„м•Ҫм ңкөҗмӣҗ м ‘мҶҚмӢң faq мҪ”л“ң 53мңјлЎң set (мҰқл№ҷм„ңлҘҳм•ҲлӮҙ)
	} else {
		this.dsSearch.setColumn(0,"faqClfCd" , "32"); //мҲҳн—ҳн‘ңм¶ңл Ҙм•ҲлӮҙ faq мҪ”л“ң 32
	}	
	this.div02.form.btn03.set_cssclass("btn_WF_TabS");
	this.div02.form.btn01.set_cssclass("btn_WF_Tab");
	this.div02.form.btn02.set_cssclass("btn_WF_Tab");
	this.div02.form.btn04.set_cssclass("btn_WF_Tab");
	this.div02.form.btn05.set_cssclass("btn_WF_Tab");
	
	this.fnSearch(obj, e);
};

this.btn04_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (this.dsSearch.getColumn(0,"appoExamScCd") == "5") { 
		this.dsSearch.setColumn(0,"faqClfCd" , "54"); //кі„м•Ҫм ңкөҗмӣҗ м ‘мҶҚмӢң faq мҪ”л“ң 54лЎң set (н‘ңмӨҖк·јлЎңкі„м•Ҫм„ңм•ҲлӮҙ)
	} else {
		this.dsSearch.setColumn(0,"faqClfCd" , "33"); //нҶөн•©мұ„мҡ© н•©кІ©мһҗл°ңн‘ң faq мҪ”л“ң 33
	}
	this.div02.form.btn04.set_cssclass("btn_WF_TabS");
	this.div02.form.btn01.set_cssclass("btn_WF_Tab");
	this.div02.form.btn02.set_cssclass("btn_WF_Tab");
	this.div02.form.btn03.set_cssclass("btn_WF_Tab");
	this.div02.form.btn05.set_cssclass("btn_WF_Tab");
	
	this.fnSearch(obj, e);
};

this.btn05_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsSearch.setColumn(0,"faqClfCd" , "34");	//нҶөн•©мұ„мҡ© мһ„мҡ©нӣ„ліҙмһҗ faqмҪ”л“ң 34
	this.div02.form.btn05.set_cssclass("btn_WF_TabS");
	this.div02.form.btn01.set_cssclass("btn_WF_Tab");
	this.div02.form.btn02.set_cssclass("btn_WF_Tab");
	this.div02.form.btn03.set_cssclass("btn_WF_Tab");
	this.div02.form.btn04.set_cssclass("btn_WF_Tab");
	
	this.fnSearch(obj, e);
};

	]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="нҢҢлқјл©”н„°к°Җ лҗ  Dataset list(кіөл°ұмңјлЎң кө¬л¶„)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="л°ӣм•„мҳ¬ Dataset list(кіөл°ұмңјлЎң кө¬л¶„)"/>
          <Column id="package" type="STRING" size="256" sumtext="voмҷҖ serviceм—җм„ң мӮ¬мҡ©н•  нҢЁм№ҳм§ҖлӘ…"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type м •мқҳ(Status м •ліҙ н‘ңнҳ„:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="м„ңл№„мҠӨк°Җ м„ұкіөм ҒмңјлЎң нҳём¶ңлҗҳл©ҙ 0лІҲм§ё лЎңмҡ°м—җ м „мІҙ,м„ нғқ,мӮӯм ң лЎңмҡ°лҘј м¶”к°Җн•ңлӢӨ."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="мҪңл°ұн•ЁмҲҳ (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(кіөнҶөм—җм„ңмӮ¬мҡ©)м„ңл№„мҠӨк°Җ нҳём¶ңлҗң мғҒнғң(ready:м„ңл№„мҠӨнҳём¶ңмӨҖл№„,succ:м„ңл№„мҠӨнҳём¶ңм„ұкіө,fail:м„ңл№„мҠӨм—җлҹ¬)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(кіөнҶөмӢңмҠӨн…ңм—җм„ңмӮ¬мҡ©)м„ңл№„мҠӨнҳём¶ңнӣ„ кІ°кіјмҪ”л“ң"/>
