        <Static id="sta99_00_00_00_00" taborder="6" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta99_00_00_00_00_00" taborder="7" left="0" top="114" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta99_00_00_00_00_00_03_00" taborder="8" left="0" top="499" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01" taborder="9" left="0" top="558" height="40" cssclass="sta_GD_Size" text="40" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">select</Col>
            <Col id="inDatasets">dsMain=dsMain</Col>
            <Col id="outDatasets">dsResult=dsResult</Col>
            <Col id="asynctp"/>
            <Col id="url">hrd_oew_rm02_p01_000.do</Col>
          </Row>
          <Row>
            <Col id="id">delete</Col>
            <Col id="url">hrd_oew_rm02_p01_001.do</Col>
            <Col id="inDatasets">dsDelList=dsResult</Col>
            <Col id="asynctp"/>
            <Col id="outDatasets"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsResult" useclientlayout="true">
        <ColumnInfo>
          <Column id="appoExamScCd" type="string" size="256"/>
          <Column id="sn" type="string" size="256"/>
          <Column id="ntcMteTitlNm" type="string" size="256"/>
          <Column id="ntcMteCn" type="string" size="256"/>
          <Column id="inqCnt" type="string" size="256"/>
          <Column id="maiNtcMteYn" type="bigdecimal" size="256"/>
          <Column id="pttTopFixYn" type="string" size="256"/>
          <Column id="popupYn" type="string" size="256"/>
          <Column id="atchFileGrpNo" type="string" size="256"/>
          <Column id="rgtrId" type="string" size="256"/>
          <Column id="regDt" type="DATETIME" size="256"/>
          <Column id="mdfrId" type="string" size="256"/>
          <Column id="mdfrNm" type="string" size="256"/>
          <Column id="mdfcnDt" type="DATETIME" size="256"/>
          <Column id="prevSn" type="string" size="256"/>
          <Column id="prevNtcMteTitlNm" type="STRING" size="256"/>
          <Column id="prevRegDt" type="DATETIME" size="256"/>
          <Column id="nextSn" type="string" size="256"/>
          <Column id="nextNtcMteTitlNm" type="string" size="256"/>
          <Column id="nextRegDt" type="DATETIME" size="256"/>
          <Column id="prevRegDtTxt" type="STRING" size="256"/>
          <Column id="nextRegDtTxt" type="STRING" size="256"/>
          <Column id="regDtTxt" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true">
        <ColumnInfo>
          <Column id="sn" type="STRING" size="256"/>
          <Column id="appoExamScCd" type="string" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="sn"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsDelList" useclientlayout="true">
        <ColumnInfo>
          <Column id="sn" type="STRING" size="256"/>
          <Column id="appoExamScCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="sn"/>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="divDetail.form.edt00_00_01" propid="value" datasetid="dsResult" columnid="ntcMteTitlNm"/>
      <BindItem id="item1" compid="divDetail.form.edt00_00" propid="value" datasetid="dsResult" columnid="inqCnt"/>
      <BindItem id="item2" compid="divDetail.form.edt00_00_00" propid="value" datasetid="dsResult" columnid="regDtTxt"/>
      <BindItem id="item3" compid="divDetail.form.txt00" propid="value" datasetid="dsResult" columnid="ntcMteCn"/>
      <BindItem id="item4" compid="divList.form.edtPreTitlNm" propid="value" datasetid="dsResult" columnid="preDataTitlNm"/>
      <BindItem id="item5" compid="divList.form.edtNextTitlNm" propid="value" datasetid="dsResult" columnid="nextDataTitlNm"/>
      <BindItem id="item6" compid="divList.form.edtPrevRegDt" propid="value" datasetid="dsResult" columnid="prevRegDtTxt"/>
      <BindItem id="item7" compid="divList.form.edtNextRegDt" propid="value" datasetid="dsResult" columnid="nextRegDtTxt"/>
      <BindItem id="item8" compid="divList.form.edtTitlNm" propid="value" datasetid="dsResult" columnid="prlDataTitlNm"/>
      <BindItem id="item9" compid="divList.form.edtRegDt" propid="value" datasetid="dsResult" columnid="regDtTxt"/>
      <BindItem id="item11" compid="divList.form.Static44" propid="text" datasetid="dsResult" columnid="nextNtcMteTitlNm"/>
      <BindItem id="item12" compid="divList.form.Static07_01" propid="text" datasetid="dsResult" columnid="prevNtcMteTitlNm"/>
      <BindItem id="item10" compid="divList.form.Static07" propid="text" datasetid="dsResult" columnid="ntcMteTitlNm"/>
    </Bind>
    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 계약제교원 인력풀
*  @MenuPath    pa_hrd_oew_rm
*  @FileName 	hrd_oewrm02_p01.xfdl
*  @Creator 	최재형
*  @CreateDate 	2022.5.25
*  @Desction    공지상세조회
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.5.25     	최재형 	        최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frmTemp02_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(this);
	// 파라메터 세팅
	this.pv_params = this.smfGetFormParams();

	// 상세조회 PARAMETERS
	// 공지번호
	this.dsMain.setColumn(0,"sn",this.pv_params.sn);
	// 임용시험구분코드
	this.dsMain.setColumn(0,"appoExamScCd",this.pv_params.appoExamScCd);
	this.fnSearch();

};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("select")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			if(this.dsResult.getColumn(0,"nextNtcMteTitlNm") == null){
				this.dsResult.setColumn(0,"nextNtcMteTitlNm","다음 게시글이 없습니다.");
				this.divList.form.btnNext.set_visible(false);
				this.divList.form.edtNextRegDt.set_visible(false);
			} else {
				this.divList.form.btnNext.set_visible(true);
				this.divList.form.edtNextRegDt.set_visible(true);
			}
			
			if(this.dsResult.getColumn(0,"prevNtcMteTitlNm") == null){
				this.dsResult.setColumn(0,"prevNtcMteTitlNm","이전 게시글이 없습니다.");
				this.divList.form.btnPre.set_visible(false);
				this.divList.form.edtPrevRegDt.set_visible(false);
			} else {
				this.divList.form.btnPre.set_visible(true);
				this.divList.form.edtPrevRegDt.set_visible(true);
			}
		});	
};

this.fnDelete = function()
{	
	// 서비스 객체 생성
	// 삭제처리
	this.smfDeleteService("delete")
		// 데이터 존재 필수
		.requireExistsData(this.dsMain) 

		// 삭제를 위한 검증수행
		.validateFormDelete(this.divDetail)
		
		.run()
		// 콜백
		.callback(function(callbackParams){ 
			if(callbackParams.errors) return;
			
			var alerter = this.smfAlerter();
			alerter.message = this.smfAfterServiceMessage();
			alerter.onOk = function(){
				// 목록으로 이동
				this.smfSetWorkPage("pa_ore_oew_bd::ore_oewrbd01_m00.xfdl");
			};
			alerter.run();
		})
		;
}

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// [목록]버튼클릭 처리
this.btnList_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSetWorkPage("pa_ore_oew_bd::ore_oewrbd01_m00.xfdl");
};

// [수정]버튼클릭 처리
this.btnUpdate_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 공지번호
	var sSn = this.dsMain.getColumn(0,"sn");
	// 임용시험구분코드
	var sAppoExamScCd = this.dsMain.getColumn(0,"appoExamScCd");
	var params = {
			sn:sSn, 
			appoExamScCd:sAppoExamScCd
	};
	
	this.smfSetWorkPage("pa_ore_oew_bd::ore_oewbd02_p00.xfdl", params);
};

// [삭제]버튼클릭 처리
this.btnDel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 공지 삭제 PARAMETER
	// 공지번호
	this.dsDelList.setColumn(0,"sn",this.pv_params.sn);
	// 임용시험구분코드
	this.dsDelList.setColumn(0,"appoExamScCd",this.pv_params.appoExamScCd);
	this.fnDelete();
};

// 다음 게시물
this.divList_btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 다음 공지번호
	this.dsMain.setColumn(0,"sn",this.dsResult.getColumn(0,"nextSn"));
	// 임용시험구분코드
	this.dsMain.setColumn(0,"appoExamScCd",this.dsResult.getColumn(0,"appoExamScCd"));
	this.fnSearch();
};

// 이전 게시물
this.divList_btnPre_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 이전 공지번호
	this.dsMain.setColumn(0,"sn",this.dsResult.getColumn(0,"prevSn"));
	// 임용시험구분코드
	this.dsMain.setColumn(0,"appoExamScCd",this.dsResult.getColumn(0,"appoExamScCd"));
	this.fnSearch();
};

]]></Script>
  </Form>
</FDL>
