    <Script type="xscript5.1"><![CDATA[/**
*  위생안전점검표및배점관리(모바일)
*  @MenuPath    급식 > 운영평가/위생안전점검(교육청) - 위생안전점검
*  @FileName 	sml_oeess01_m00.xfdl 
*  @Creator 	Kangchaeyoon
*  @CreateDate 	2022.08.22 
*  @Desction    급식 위생안전점검표및배점관리(모바일)
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.08.22          Kangchaeyoon                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_cddcCd; 		//시도교육청 코드
this.fv_PageBtnCd; 		//탭형식 버튼 페이지 변수
this.fv_btnTabIdx = 0;	//페이지 번호
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
			url : "/sml_oee_ss01_000.do",
		})
		.mappingRulesetToForm(this.divSearch, "search")
		.mappingRulesetToDataset(this.dsShlMlsvSnttSafeDtlValid, "save")
		.callback(function(callbackParams) {
		})
		.run()
	;
	
	// 공통코드의 코드구분
	this.smfCodeList("code", [this.dsChckTmeCd, this.dsDisfoTypCd])
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.dsChckTmeCd.setColumn(this.dsChckTmeCd.insertRow(0), 'unyCdValueNm', '- 선택 -');
		})
	;
					 
	//조회조건 필수값 세팅
	this.fnSetSearchVal();
	
	//조회조건 조회
	this.fnSearchCond();
	
	//조회조건 캘린더 날짜 세팅
	this.fnSetCalToday();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 조회조건 조회 Transaction
 */
 this.fnSearchCond = function() {
	// 서비스 객체 생성
	this.smfSearchService("listCondCn")
		// 데이터 검증
		.validateForm(this.divSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return; 
			
			this.dsCteShlList.setColumn(this.dsCteShlList.insertRow(0), 'shlNm', '- 선택 -');
			this.dsLgsEnfcYmdList.setColumn(this.dsLgsEnfcYmdList.insertRow(0), 'cdValueNm', '- 선택 -');             
			this.dsLgsEnfcYmdDgrList.setColumn(this.dsLgsEnfcYmdDgrList.insertRow(0), 'cdValueNm', '- 선택 -');
			this.divSearch.form.cboCteShl.set_index(0);
			this.divSearch.form.cboLgsEnfcYmd.set_index(0);
			this.divSearch.form.cboMdfcnDgr.set_index(0);
			this.divSearch.form.cboChckTme.set_index(0);
		});
}

/**
 * @description 위생안전점검 조회 Transaction
 */
 this.fnSearchSnttSafe = function() {
	// 서비스 객체 생성
	this.smfSearchService("list")
		// 데이터 검증
		.validateForm(this.divSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return; 
			
			//탭영역 기본 값 세팅
			this.fnChckrltValue();
			
			// 기본값 세팅
			this.fnInitData(this.dsShlMlsvEvlAllotRltList1, this.dsOperEvlShlMlsvEvlItmAnsList1);
			this.fnInitData(this.dsShlMlsvEvlAllotRltList2, this.dsOperEvlShlMlsvEvlItmAnsList2);
			this.fnInitData(this.dsShlMlsvEvlAllotRltList3, this.dsOperEvlShlMlsvEvlItmAnsList3);
						
			//급식 조리원 인원 합산 처리
			this.dsShlMlsvSnttSafeDtl.set_updatecontrol(false);
			this.fnSetApcceCnt();
			
			//급식 급식인원 합산 처리
			this.fnSetMlsvNmprCnt();
			this.dsShlMlsvSnttSafeDtl.set_updatecontrol(true);
			
			this.fnGrdSize(this.div05.form.div00.form.grdMain, this.div05.form.div00.form);
			this.fnGrdSize(this.div06.form.div00.form.grdMain1, this.div06.form.div00.form);
			this.fnGrdSize(this.div07.form.div00.form.grdMain2, this.div07.form.div00.form);
			this.fnGrdSize(this.div08.form.div00.form.grdMain3, this.div08.form.div00.form);
		});
}

/**
 * @description 위생안전점검 저장 Transaction
 */
this.fnSaveFigtAcpPrcs = function() {
	// 서비스 객체 생성
	this.smfSaveService("save")
		// (권장) 데이터 존재 필수
		.requireExistsData([this.dsShlMlsvEvlChckBsc, this.dsShlMlsvOperEvlDtl, this.dsShlMlsvEvlChckItmList, this.dsShlMlsvEvlInprList, this.dsShlMlsvEvlAllotRltList1, this.dsShlMlsvEvlAllotRltList2, this.dsShlMlsvEvlAllotRltList3])
		// 데이터 변경 필수
		.requireModifredData([this.dsShlMlsvEvlChckBsc, this.dsShlMlsvOperEvlDtl, this.dsShlMlsvEvlChckItmList, this.dsShlMlsvEvlInprList, this.dsShlMlsvEvlAllotRltList1, this.dsShlMlsvEvlAllotRltList2, this.dsShlMlsvEvlAllotRltList3])
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			if (this.dsApiResponseList.getColumn(0, 'resultCode') == 'SUCC'){
				this.smfAlert('CM002', [], function(result){	//저장이 완료되었습니다.
					if(result){
						//위생안전점검 조회
						this.fnSearchSnttSafe();
					}
				}); 	
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'resultMsg')]);
			}
		});  
};

/**
 * @description 위생안전점검 삭제 Transaction
 */
this.fnDeleteFigtAcpPrcs = function() {
	// 서비스 객체 생성
	this.smfDeleteService("delete")
		//메세지 설정
		.showConfirm(false)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			if (this.dsApiResponseList.getColumn(0, 'resultCode') == 'SUCC'){
				this.smfAlert('PA001', ['삭제'], function(result){	//삭제 되었습니다.
					if(result){
						//위생안전점검 조회
						this.fnSearchSnttSafe();
					}
				}); 
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'resultMsg')]);
			}
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 조회조건 필수값 세팅
*/
this.fnSetSearchVal = function(){
	this.dsSearch.setColumn(0, "evlWrkScCd", 20); // 10: 학교운영평가, 20: 학교위생평가
	this.dsSearch.setColumn(0, "cddcCd", this.smfGetCddcCode());
};

/**
 * @description 조회조건 캘린더 날짜 세팅
*/
this.fnSetCalToday = function(){
	var today = new nexacro.Date();
	var year = today.getFullYear();
	this.divSearch.form.spnYm.set_value(year);
}

/**
 * @description  학교현황 내 급식종사자 인원 합산 처리
*/
this.fnSetApcceCnt = function(){
	var apcceEcs = Number(this.div02.form.mskApcceEcs.value);
	var apcceOnslf = Number(this.div02.form.mskApcceOnslf.value);
	var etc = Number(this.div02.form.mskEtc.value);
	this.div02.form.mskAll.set_value(apcceEcs + apcceOnslf + etc);
} 

/**
 * @description  급식운영현황 내 급식인원 합산 처리
*/
this.fnSetMlsvNmprCnt = function(){
	var morn = Number(this.div03.form.mskMorn.value);
	var lunch = Number(this.div03.form.mskLunch.value);
	var dinnr = Number(this.div03.form.mskDinnr.value);
	this.div03.form.mskAll.set_value(morn + lunch + dinnr);
} 

/**
 * @description  탭영역 기본 값 세팅
*/
this.fnChckrltValue = function(){
	this.btnSnttSafeCtr.set_text(this.dsOperEvlShlMlsvEvlDdocuList1.getColumn(0, 'ddocuScNm'));
	this.btnOperCchRcmMte.set_text(this.dsOperEvlShlMlsvEvlDdocuList2.getColumn(0, 'ddocuScNm'));
	this.btnLgstrMteImprMte.set_text(this.dsOperEvlShlMlsvEvlDdocuList3.getColumn(0, 'ddocuScNm'));
	this.div06.form.img00.set_text(this.dsOperEvlShlMlsvEvlDdocuList1.getColumn(0, 'ddocuScNm'));
	this.div07.form.img00.set_text(this.dsOperEvlShlMlsvEvlDdocuList2.getColumn(0, 'ddocuScNm'));
	this.div08.form.img00.set_text(this.dsOperEvlShlMlsvEvlDdocuList3.getColumn(0, 'ddocuScNm'));
	
	var dgrArr = this.dsLgsEnfcYmdDgrList.extractRows("lgsEnfcYmd == " + this.dsSearch.getColumn(0, "lgsEnfcYmd") + " && lgsDgr == " + this.dsSearch.getColumn(0, "lgsDgr"));
	var mlsvEvlScrIndctScCd = this.dsLgsEnfcYmdDgrList.getColumn(dgrArr[0], "mlsvEvlScrIndctScCd");
	this.dsShlMlsvEvlChckBsc.setColumn(0, "mlsvEvlScrIndctScCd", mlsvEvlScrIndctScCd);
	this.div05.form.div00.form.staEvlRltCn.set_text(mlsvEvlScrIndctScCd == '1' ? '등급' : '점');
	
	//배점 값 세팅
	var cn = this.fnMlsvEvlItmAnsNm(this.dsShlMlsvEvlAllotRltList1, this.dsOperEvlShlMlsvEvlItmAnsList1, this.dsOperEvlShlMlsvEvlDdocuList1);
	this.div06.form.div00.form.staAllotCn.set_text(cn);

	cn = this.fnMlsvEvlItmAnsNm(this.dsShlMlsvEvlAllotRltList2, this.dsOperEvlShlMlsvEvlItmAnsList2, this.dsOperEvlShlMlsvEvlDdocuList2);
	this.div07.form.div00.form.staAllotCn.set_text(cn);
	
	var div06ansScrMax = +this.dsOperEvlShlMlsvEvlItmAnsList3.getCaseMax("ansSn==2","mlsvEvlItmAnsScr") * -1;
	var div06ansScrMin = +this.dsOperEvlShlMlsvEvlItmAnsList3.getCaseMin("ansSn==2","mlsvEvlItmAnsScr") * -1;
	cn = this.dsShlMlsvEvlAllotRltList3.getRowCount() + '개 항목 (적합 0점/부적합 '
		 + div06ansScrMin + '점 ~ ' + div06ansScrMax + '점)';
	this.div08.form.div00.form.staAllotCn.set_text(cn);
}

/**
 * @description 데이터 기본값 세팅
*/
this.fnInitData = function(dsRlt, dsAns){
	dsRlt.set_updatecontrol(false);
	for(var i = 0; i < dsRlt.rowcount; i++){
		if (this.smfIsNull(dsRlt.getColumn(i, 'ansSn'))){
			dsRlt.setColumn(i, 'ansSn', 1);
			var operEvlScr = this.fnGetMlsvEvlItmAnsScr(dsAns, dsRlt.getColumn(i, 'itmSn'), dsRlt.getColumn(i, 'ansSn')); // 평가항목답변점수
			dsRlt.setColumn(i, 'operEvlScr', operEvlScr);
		}
	}
	dsRlt.set_updatecontrol(true);
}

/**
 * @description 운영평가점수 찾기
*/
this.fnGetMlsvEvlItmAnsScr = function(ansDs, rowItmSn, rowAnsSn){
	var row = ansDs.extractRows('itmSn == ' + rowItmSn +' && ansSn == ' + rowAnsSn)[0];
	return +ansDs.getColumn(row, 'mlsvEvlItmAnsScr'); // 평가항목답변점수
}

/**
 * @description 배점 설명
*/
this.fnMlsvEvlItmAnsNm = function(dsRlt, dsAns, dsDdocu){
	var rows = dsAns.extractRows('itmSn == 1');
	var mlsvEvlItmAnsNmArray = new Array();
	
	for(var i = 0; i < rows.length; i++){
		mlsvEvlItmAnsNmArray.push(dsAns.getColumn(rows[i], 'mlsvEvlItmAnsNm') + ' '	+ Number(dsAns.getColumn(rows[i], 'mlsvEvlItmAnsScr')) + '점');
	}
	
	var cn = dsRlt.getRowCount() + '개 항목 '
		   + Number(dsDdocu.getColumn(0, 'mlsvEvlAptsMaxScr')) + '점 ('
		   + mlsvEvlItmAnsNmArray.join('/') + ')';
	return cn;
}

/**
 * @description 그리드 사이즈 조절
*/
this.fnGrdSize = function(grd, resetform){
	grd.set_height(grd.getRealRowFullSize() + 5);
	this.smfResetScroll(resetform);
}

/**
 * @description 저장 시, 평가결과점수 합산 처리
*/
this.fnAddScr = function(){

	var operEvlScr1 = this.dsShlMlsvEvlAllotRltList1.getSum('operEvlScr');
	var operEvlScr2 = this.dsShlMlsvEvlAllotRltList2.getSum('operEvlScr');
	var totalOperEvlScr = operEvlScr1 + operEvlScr2;
	var mlsvEvlDmmkScr = this.dsShlMlsvEvlAllotRltList3.getSum('operEvlScr');
	
	this.dsShlMlsvEvlChckBsc.set_updatecontrol(false);
	this.dsShlMlsvEvlChckBsc.setColumn(0, "mlsvEvlRltScr", totalOperEvlScr);
	this.dsShlMlsvEvlChckBsc.setColumn(0, "mlsvEvlDmmkScr", mlsvEvlDmmkScr);
	this.dsShlMlsvEvlChckBsc.set_updatecontrol(true);
}

/**
 * @description 탭 버튼 css 세팅
*/
this.fnTabBtnSet = function(btnType, btnTabIdx){
	//탭 div 배열 세팅
	var divObj = [this.div05, this.div06, this.div07, this.div08];
	
	//탭이름 배열 세팅
	var tapId = [this.btnChckRlt, this.btnSnttSafeCtr, this.btnOperCchRcmMte, this.btnLgstrMteImprMte];
	
	//기존화면 비활성화 세팅
	divObj[this.fv_btnTabIdx].set_visible(false);
	
	//fv_btnTabIdx 값 세팅
	if(btnType == 'next'){
		this.fv_btnTabIdx++;
		if(this.fv_btnTabIdx <= 3) this.fv_btnTabIdx == 3;
	}else if(btnType == 'bfr'){
		this.fv_btnTabIdx--;
		if(this.fv_btnTabIdx <= 0) this.fv_btnTabIdx == 0;
	}else if(btnType == 'tab'){
		this.fv_btnTabIdx = btnTabIdx;
	}
	
	//화면 활성화 세팅
	divObj[this.fv_btnTabIdx].set_visible(true);
	
	//선택된 버튼 css 추가
	for(var i = 0; i < tapId.length; i++){
		tapId[i].set_cssclass('btn_WF_Tab_Line');
	}
	tapId[this.fv_btnTabIdx].set_cssclass('btn_WF_Tab_LineS');
	
	//화면 스크롤 재조정
	this.smfResetScroll(divObj[this.fv_btnTabIdx].form);
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 초기화 버튼 클릭
*/
this.divSearch_btnInit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSetCalToday();
	this.divSearch.form.cboCteShl.set_index(0);
	this.divSearch.form.cboChckTme.set_index(0);
	this.divSearch.form.cboLgsEnfcYmd.set_index(0);
	this.divSearch.form.cboMdfcnDgr.set_index(0);
};

/**
 * @description 캘린더 오늘 이전 선택 막기
*/
this.fnCalValChk = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo){
	//오늘 이전 선택 안됨
	if (e.postvalue < this.smfToday()){
		this.smfAlert('CM108', ['오늘']);
		return false;
	}
};

/**
 * @description 조회 버튼 클릭
*/
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearchSnttSafe();
};

/**
 * @description 저장 버튼 클릭
*/
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//점검결과 필수 값 체크
	for(var i = 0; i < this.dsShlMlsvEvlChckItmList.getRowCount(); i++){
		var mlsvEvlChckItmCn = this.dsShlMlsvEvlChckItmList.getColumn(i, "mlsvEvlChckItmCn");
		if(this.smfIsNull(mlsvEvlChckItmCn)){
			this.smfAlert('점검결과의 지적내용 및 조치사항을 입력해주세요.');
			return;
		}
	}
	
	//평가결과점수 합산처리
	this.fnAddScr();
	
	//상태 값 저장 처리
	this.dsShlMlsvEvlChckBsc.set_updatecontrol(false);
	this.dsShlMlsvEvlChckBsc.setRowType(0, "u");
	this.dsShlMlsvEvlChckBsc.set_updatecontrol(true);
	
	//저장 처리
	this.fnSaveFigtAcpPrcs();
};

/**
 * @description '삭제' 버튼 클릭
*/
this.btnDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfConfirm("삭제 하시겠습니까?", function(result){
		if(result.confirmResult){
			//상태 값 삭제 처리
			this.dsShlMlsvEvlChckBsc.set_updatecontrol(false);
			this.dsShlMlsvEvlChckBsc.setRowType(0, "d");
			this.dsShlMlsvEvlChckBsc.set_updatecontrol(true);
			
			this.dsShlMlsvEvlAllotRltList1.deleteAll();
			this.dsShlMlsvEvlAllotRltList2.deleteAll();
			this.dsShlMlsvEvlAllotRltList3.deleteAll();
			this.dsShlMlsvEvlInprList.deleteAll();
			
			//삭제 처리
			this.fnDeleteFigtAcpPrcs();
		}
	})
};

/**
 * @description '이전', '다음'  버튼 클릭
*/
this.Button_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnTabBtnSet(obj.name == 'btnBfr' ? "bfr" : "next", this.fv_btnTabIdx);
};

/**
 * @description 버튼(탭) 클릭
*/
this.btnTap_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnTabBtnSet('tab', obj.btnTabIdx);
};

/**
 * @description 그리드 평점 라디오 클릭 시
*/
this.Grid_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var ds = obj.getBindDataset();
	var operEvlScr = this.fnGetMlsvEvlItmAnsScr(this[obj.ansDs], ds.getColumn(e.row, 'itmSn'), ds.getColumn(e.row, 'ansSn')); // 평가항목답변점수
	var mlsvEvlAasScCd = this[obj.ansDs].getColumn(e.row, "mlsvEvlAasScCd"); // 평가가감구분코드s
	
	if(mlsvEvlAasScCd == 2) operEvlScr *= -1;
	
	if(obj.name == 'grdMain1' && (e.col == 2 || e.col == 3)){
		ds.setColumn(e.row, 'ansSn', e.col == 2 ? 1 : 2);
		ds.setColumn(e.row, 'operEvlScr', operEvlScr);
	}
	if(obj.name == 'grdMain2' && (e.col == 2 || e.col == 3 || e.col == 4)){
		ds.setColumn(e.row, 'ansSn', e.col == 2 ? 1 : (e.col == 3 ? 2 : 3));
		ds.setColumn(e.row, 'operEvlScr', operEvlScr);
	}
	if(obj.name == 'grdMain3' && (e.col == 1 || e.col == 2)){
		ds.setColumn(e.row, 'ansSn', e.col == 1 ? 1 : 2);
		ds.setColumn(e.row, "jsbfrImrptCnt", e.col == 1 ? 0 : 1); // 2: 적합, 3: 부적합
		
		ds.setColumn(e.row, 'operEvlScr', operEvlScr);
	}
};

/**
 * @description 지침시행일자값에 따라 차수 값 변경
*/
this.divSearch_cboLgsEnfcYmd_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	var cboLgsEnfcYmdVal = this.dsLgsEnfcYmdList.getColumn(e.postindex, "lgsEnfcYmd");
	this.dsLgsEnfcYmdDgrList.filter("lgsEnfcYmd == " + cboLgsEnfcYmdVal);
	
	this.dsLgsEnfcYmdDgrList.setColumn(this.dsLgsEnfcYmdDgrList.insertRow(0), 'cdValueNm', '- 선택 -');
	this.divSearch.form.cboMdfcnDgr.set_index(0);
};]]></Script>
