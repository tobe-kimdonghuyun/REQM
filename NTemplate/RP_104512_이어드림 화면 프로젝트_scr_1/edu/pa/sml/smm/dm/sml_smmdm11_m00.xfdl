          <Column id="ccpScCd" type="STRING" size="256" description="CCP구분코드"/>
          <Column id="ccpSn" type="STRING" size="256" description="CCP일련번호"/>
          <Column id="mmealScCd" type="STRING" size="256" description="식사구분코드"/>
          <Column id="ntrstIdValue" type="STRING" size="256" description="영양사ID"/>
          <Column id="ddishCdValue" type="STRING" size="256" description="요리코드"/>
          <Column id="ddishCdValueCn" type="STRING" size="256" description="요리코드내용"/>
          <Column id="foodComCdValue" type="STRING" size="256" description="식품공통코드"/>
          <Column id="foodComCdValueCn" type="STRING" size="256" description="식품공통코드내용"/>
          <Column id="ccpCooMthCdValue" type="STRING" size="256" description="CCP조리방법코드"/>
          <Column id="ccpCooMthCdValueCn" type="STRING" size="256" description="CCP조리방법코드내용"/>
          <Column id="bfrHnrYn" type="STRING" size="256" description="이전처리실여부"/>
