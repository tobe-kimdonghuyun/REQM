          <Column id="mlsvYmd" type="STRING" size="256" description="급식일자"/>
          <Column id="ccpScCd" type="STRING" size="256" description="ccp구분코드"/>
          <Column id="ccpPrgStsCd" type="STRING" size="256" description="CCP진행상태코드"/>
          <Column id="ccpPrgStsCdNm" type="STRING" size="256" description="CCP진행상태코드명"/>
          <Column id="imprActnRecCn" type="STRING" size="256" description="개선조치기록내용"/>
          <Column id="mngCtrCn" type="STRING" size="256" description="관리기준내용"/>
          <Column id="mngWayCn" type="STRING" size="256" description="관리방안내용"/>
          <Column id="imprActnCn" type="STRING" size="256" description="개선조치내용"/>
          <Column id="ccpRmkCn" type="STRING" size="256" description="CCP비고내용"/>
