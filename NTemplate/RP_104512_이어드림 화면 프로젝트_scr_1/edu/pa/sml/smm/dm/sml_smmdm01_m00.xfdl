    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    식단관리 > CCP관리(모바일)
*  @FileName 	sml_smmdm01_m00.xfdl 
*  @Creator 	김민성
*  @CreateDate 	2022.08.22
*  @Desction    CCP관리(모바일)
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.08.22            김민성                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
var objDiv;
var compBtnList;
var divMList;
this.fvCcp2Row;
this.fvFristIndex;
this.fvFristSearch;
this.fvIsCp1AllNoNm;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	this.divSearch.form.calMlsvYmd.set_value(this.smfToday());
	this.dsSearch.setColumn(0, 'cddcCd', this.smfGetCddcCode());
	this.dsSearch.setColumn(0, 'mmealScCd', 2);
	this.divSearch.form.chkItm1.set_value(true);
	
	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
		url : "/sml_smm_dm01_000.do",
		})
		.mappingRulesetToForm(this.divSearch, "search")
		.mappingRulesetToDataset(this.dsCcpMngBscValid, "saveCcpBsc")
		.mappingRulesetToDataset(this.dsCcpMngDtlValid, "saveCcpDtl")
		.mappingRulesetToDataset(this.dsCp1MngDtlValid, "saveCp1Dtl")
		.mappingRulesetToDataset(this.dsCp2MngDtlValid, "saveCp2Dtl")
		.callback(function(callbackParams) {
		})
		.run()
	;
	
	// 공통코드의 코드구분
	this.smfCodeList("code", [this.dsCleWsiStsCd])
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		})
	;
	
	objDiv = {	"20" : "divCCP2A", "21" : "divCCP2B",
				"30" : "divCCP3A", "31" : "divCCP3B", "32" : "divCCP3C",
				"40" : "divCP1",
				"50" : "divCP2A", "51" : "divCP2B", "52" : "divCP2C"
				};
	compBtnList = ["btnCcp2", "btnCcp3", "btnCp1", "btnCp2"];
	divMList = ["divCCP2AM", "divCCP2BM", "divCCP3AM", "divCCP3BM", "divCCP3CM"];
	this.fvFristIndex = null;
	this.fvFristSearch = null;
	this.fnSearchList();
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
	if(!arguments[0].confirmResult) {
		return;
	}else{
		this.fnSearchList();
	}
}
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchList = function()
{
	this.dsCcpMngBsc.clearData();
	this.dsCcpMngDtl.clearData();
	this.dsCp1MngDtl.clearData();
	this.dsCp2MngDtl.clearData();
	this.dsCcp2MngDtl.clearData();
	this.dsCcp3MngDtl.clearData();
	
 	// 서비스 객체 생성
	this.smfSearchService("list")
		// 데이터 검증
		.validateForm(this.divSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'resultCode') == 'SUCC'){
				if (this.smfIsNull(this.fvFristSearch)){
					this.dsSearch.setColumn(0, 'mlsvYmd', this.dsLastMlsvYmdMap.getColumn(0, 'mlsvEndYmd'));
					this.fvFristSearch = 1;
					this.fnSearchList();
					return;
				}
				
				if (this.dsAccesPslYn.getColumn(0, 'pageAccesPslYn') == 'N'){
					this.divCCP2A.set_visible(true);
					this.smfResetScroll(this);
					for(var i = 0; i < this.components.length; i++){
						if (this.components[i].id != 'divSearch'){
							this.components[i].set_enable(false);
						}
					}
					this.smfAlert('LI155', [this.dsAccesPslYn.getColumn(0, 'pageAccesRltCn')], this.fnMessageCallback);
					return;
				}
				// ccp 버튼 조건 설정
				this.fnSetBtnSc();
				this.fnDsAddRow(this.dsCcpMngBsc, true);
				if (this.dsCp2MngDtl.rowcount == 0) this.fnDsAddRow(this.dsCp2MngDtl, null);
				// '취급 및 조리방법' 내용 채우기
				this.fnFillCooMthCdValueCn();
				this.dsCcpMngByDdishCd.setColumn(this.dsCcpMngByDdishCd.insertRow(0), 'label', '- 선택 -');
				// CP1 그리드 헤드 컬럼 수 조절
				this.fnCp1RefriFeezHeadCnt();
				// 개선조치기록
				this.fnSetImprActnRecCn();
				// ccp2, ccp3으로 분리
				this.fnSeparatedCcp();
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'resultMsg')], this.fnMessageCallback);
			}
		});
};

/**
 * 저장서비스
 * @param : obj
 * @param : N/A
 */
this.fnSave = function(obj)
{
	// 서비스 객체 생성
	this.smfSaveService("save")
		// (권장) 데이터 존재 필수
		.requireExistsData([this.dsCcpMngBsc, this.dsCcp2MngDtl, this.dsCcp3MngDtl, this.dsCp1MngDtl, this.dsCp2MngDtl])
		// 데이터 변경 필수
		.requireModifredData([this.dsCcpMngBsc, this.dsCcp2MngDtl, this.dsCcp3MngDtl, this.dsCp1MngDtl, this.dsCp2MngDtl])
		// 데이터 검증
		.validateForm(obj.parent.parent.parent.div00)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'resultCode') == 'SUCC'){
				this.smfAlert('CM002', []); // 저장이 완료되었습니다.
				this.fnSearchList();
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'resultMsg')], this.fnMessageCallback);
			}
		});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * ccp 버튼 조건 설정
 * @param : N/A
 * @param : N/A
 */
this.fnSetBtnSc = function(){
	var spliceList = new Array();
	for(var i = 0; i < compBtnList.length; i++){
		var compBtnCcpScs = this[compBtnList[i]].ccpSc.split(',');
		var isCcpSc = false;
		for(var j in compBtnCcpScs){
			var btnNm = this.dsCcpTab.lookupNF('ccpScCd', compBtnCcpScs[j], 'ccpScCdNm');
			if (!this.smfIsNull(btnNm)){
				isCcpSc = true;
				this[compBtnList[i]].set_text(btnNm);
				this[compBtnList[i]].divSc = objDiv[compBtnCcpScs[j]];
				if (this.smfIsNull(this.fvFristIndex)){
					this[objDiv[compBtnCcpScs[j]]].set_visible(true);
					this.fvFristIndex = objDiv[compBtnCcpScs[j]];
					this.smfResetScroll(this);
				}
			}
		}
		if (!isCcpSc){
			this[compBtnList[i]].set_width(0);
			spliceList.push(i);
		}
		isCcpSc = false;
	}
	
	for(var i = spliceList.length; i > 0; i--){
		compBtnList.splice(i,1);
	}
	this.smfResetScroll(this);
};

/**
 * '취급 및 조리방법' 내용 채우기
 * @param  : N/A
 * @param  : N/A
 */
this.fnFillCooMthCdValueCn = function(){
	this.dsCcpCooMthCd.filter("");
	var dsList = ["dsCcpMngDtl", "dsCcpMngDtlRtnInfo"]; // 기존 ccp데이터셋, 최근정보불러오기 데이터셋
	for(var ds in dsList){
		for(var i = 0; i < this[dsList[ds]].rowcount; i++){
			if (this.smfIsNull(this[dsList[ds]].getColumn(i, 'ccpCooMthCdValue'))) continue;
			
			var ccpCooMthCdValue = this[dsList[ds]].getColumn(i, 'ccpCooMthCdValue').split(',');
			
			for(var j = 0; j < ccpCooMthCdValue.length; j++){
				ccpCooMthCdValue[j] = this.dsCcpCooMthCd.lookup('value', ccpCooMthCdValue[j], 'label');
			}
			this[dsList[ds]].setColumn(i, 'ccpCooMthCdValueCn', ccpCooMthCdValue.join(","));
		}
	}
};

/**
 * CP1에서 그리드 헤드 텍스트값 동적 설정
 * @param : num - 냉장(동)고 순서
 * @return : 냉장(동)고 텍스트 값
 */
this.fnCp1RefriFeezHeadTxt = function(num){
	return this.dsCp1MngDtl.getColumn(this.dsCp1MngDtl.rowcount-1 , "refriFeez" + num + "Nm");
};

/**
 * CP1 그리드 헤드 컬럼 수 조절
 * @param : N/A
 * @return : N/A
 */
this.fnCp1RefriFeezHeadCnt = function(){
	this.fvIsCp1AllNoNm = true;
	for(var i = 0; i < 10; i++){
		var refriFeezNm = this.dsCp1MngDtl.getColumn(0, 'refriFeez' + (i + 1) + 'Nm');
		if (this.smfIsNull(refriFeezNm)){
			this.fvIsCp1AllNoNm = false;
			if (this.smfIsMobile()){
				this.divCP1.form.grdMain.setFormatRowProperty(i+2, "size", 0);
			}else{
				this.divCP1.form.grdMain.setRealColSize("body", i + 2, 0, false);
			}
		}
	}
	if (this.fvIsCp1AllNoNm){
		this.divCP1.set_enable(false);
	}
};

/**
 * 개선조치기록 textArea set
 * @param : N/A
 * @return : N/A
 */
this.fnSetImprActnRecCn = function(){
	for(var i = 0; i < this.dsCcpMngBsc.rowcount; i++){
		var ccpScCd = this.dsCcpMngBsc.getColumn(i, 'ccpScCd');
		var imprActnCn = this.dsCcpMngBsc.getColumn(i, 'imprActnCn');
		this[objDiv[ccpScCd]].form.div00.form.txtImprActnRecCn.set_value(imprActnCn);
	}
};

/**
 * 개선조치기록 dataset set
 * @param : N/A
 * @return : N/A
 */
this.fnSetImprActnRecCnDataset = function(){
	for(var i = 0; i < this.dsCcpMngBsc.rowcount; i++){
		var ccpScCd = this.dsCcpMngBsc.getColumn(i, 'ccpScCd');
		this.dsCcpMngBsc.setColumn(i, 'imprActnCn', this[objDiv[ccpScCd]].form.div00.form.txtImprActnRecCn.value);
	}
};

/**
 * ccp dataset set
 * @param : N/A
 * @return : N/A
 */
this.fnSeparatedCcp = function(){
	this.dsCcp2MngDtl.set_updatecontrol(false);
	this.dsCcp3MngDtl.set_updatecontrol(false);
	for(var i = 0; i < this.dsCcpTab.rowcount; i++){
		var ccpScCdTab = this.dsCcpTab.getColumn(i, 'ccpScCd');
		for(var j = 0; j < this.dsCcpMngDtl.rowcount; j++){
			var ccpScCdVal = this.dsCcpMngDtl.getColumn(j, 'ccpScCd');
			if (this.dsCcp2MngDtl.ccpScCd.indexOf(ccpScCdVal) > -1 && ccpScCdTab == ccpScCdVal){
				this.dsCcpMngDtl.filter("ccpScCd == " + ccpScCdVal);
				this.dsCcp2MngDtl.copyData(this.dsCcpMngDtl, true);
				this.dsCcpMngDtl.filter("");
			}
			if (this.dsCcp3MngDtl.ccpScCd.indexOf(ccpScCdVal) > -1 && ccpScCdTab == ccpScCdVal){
				this.dsCcpMngDtl.filter("ccpScCd == " + ccpScCdVal);
				this.dsCcp3MngDtl.copyData(this.dsCcpMngDtl, true);
				this.dsCcpMngDtl.filter("");
			}
		}
	}
	this.dsCcp2MngDtl.set_updatecontrol(true);
	this.dsCcp3MngDtl.set_updatecontrol(true);
};

/**
 * 데이터가 없을 때 행 추가
 * @param : ds					- 데이터셋
 * @param : bsc					- ccp 기본정보여부
 * @return : N/A
 */
this.fnDsAddRow = function(ds, bsc){
	ds.set_updatecontrol(false);
	if (bsc){
		for(var i = 0; i < this.dsCcpTab.rowcount; i++){
			if (this.smfIsNull(ds.lookup('ccpScCd', this.dsCcpTab.getColumn(i, 'ccpScCd'), 'ccpScCd'))){
				ds.addRow();
				ds.copyRow(ds.rowcount - 1, this.dsCcpTab, i);
				ds.setColumn(ds.rowcount - 1, 'ccpPrgStsCd', 10);
			}
		}
	}else{
		ds.addRow();
		ds.copyRow(0, this.dsCcpTab, 0);
	}
	
	for(var i = 0; i < ds.getColCount(); i++){
		if (ds.getColID(i).indexOf('Cnt') > -1){
			ds.setColumn(0, i, 0);
		}
		if (ds.getColID(i).indexOf('Yn') > -1){
			ds.setColumn(0, i, 'N');
		}
	}
	ds.set_updatecontrol(true);
};

/**
 * 그리드에서 멀티콤보 눌렸을 때 콤보리스트 그리드에 체크할 것들 설정
 * @param : gridObj		- 멀티콤보가 있는 그리드(모바일에서는 콤보)
 * @param : targetGrid	- 콤보리스트 그리드
 * @param : gridRow		- 멀티콤보가 있는 그리드의 현재 로우값
 */
this.fnSetCboGridChk = function(gridObj, targetGrid, gridRow){
	var dsTargetGrid = gridObj.parent[targetGrid].getBindDataset();
	var dsGridObj = gridObj instanceof nexacro.Grid ? gridObj.getBindDataset() : this[gridObj.gridBindDataset];
	
	for(var i = 0; i < dsTargetGrid.rowcount; i++){
		dsTargetGrid.setColumn(i, "chk", null);
	}
	var gridCol = targetGrid.substr(3,1).toLowerCase() + targetGrid.substr(4);
	var items = null;
	
	if (!this.smfIsNull(dsGridObj.getColumn(gridRow, gridCol))){
		items = dsGridObj.getColumn(gridRow, gridCol).split(',');
		var targetCol = 'value';
		
		for(var i = 0; i < items.length; i++){
			dsTargetGrid.setColumn(dsTargetGrid.findRow(targetCol, items[i]), "chk", 1);
		}
	}
};

/**
 * 콤보리스트 그리드에 체크 한 후 값들 ccp2 데이터셋에 세팅
 * @param : obj - 그리드 obj
 * @param : ds  - 그리드 데이터셋
 */
this.fnSetGrdToCbo = function(obj, ds){	
	var chkList = ds.extractRows("chk == 1");
	var txtCdList = new Array();
	var txtNmList = new Array();

	var colCd = 'value';
	var colNm = obj.id == 'grdFoodComCdValue' ? 'foodComCdNm' : 'label';
	
	for(var i in chkList){
		txtCdList.push(ds.getColumn(chkList[i], colCd));
		txtNmList.push(ds.getColumn(chkList[i], colNm));
	}
	
 	this.dsCcpMngDtl.setColumn(this.fvCcp2Row, obj.id == "grdFoodComCdValue" ? "foodComCdValue" : "ccpCooMthCdValue", txtCdList.join(","));
 	this.dsCcpMngDtl.setColumn(this.fvCcp2Row, obj.id == "grdFoodComCdValue" ? "foodComCdValueCn" : "ccpCooMthCdValueCn", txtNmList.join(","));
 	this.dsCcp2MngDtl.setColumn(this.fvCcp2Row, obj.id == "grdFoodComCdValue" ? "foodComCdValue" : "ccpCooMthCdValue", txtCdList.join(","));
 	this.dsCcp2MngDtl.setColumn(this.fvCcp2Row, obj.id == "grdFoodComCdValue" ? "foodComCdValueCn" : "ccpCooMthCdValueCn", txtNmList.join(","));
};

/**
 * 현재시간 설정
 * @param : ds					- 데이터셋
 * @param : targetRow			- 해당 row
 * @param : targetCol			- 해당 col
 * @return : N/A
 */
this.fnSetDateTime = function(ds, targetRow, targetCol){
	var objDate = new Date();
	var sToday = this.smfRight("0" + objDate.getHours(), 2) + this.smfRight("0" + objDate.getMinutes(), 2);
	ds.setColumn(targetRow, targetCol, sToday);
};

/**
 * 온도 설정
 * @param : ds					- 데이터셋
 * @param : targetRow			- 해당 row
 * @param : targetCol			- 해당 col
 * @param : value				- 해당 값
 * @param : obj					- 버튼 obj
 * @return : N/A
 */
this.fnSetTemCnt = function(ds, targetRow, targetCol, value, obj){
	// cp2 온도설정
	if (this.smfIsNull(ds)){
		if (obj.temCntSc == "Cle" && (obj.value < 0 || obj.value > 300.00)){
			this.smfAlert('CM132', [0, 300.00]); // {0}에서 {1} 사이의 숫자를 입력하세요
			obj.set_value(obj.value < 0 ? 0: 300.00);
			return;
		}
	}
	
	// ccp 온도 설정
	var objValue = this.smfIsNull(ds) ? obj.value : value;
	if(objValue < -300.00 || objValue > 300.00){
		this.smfAlert('CM132', [-300.00, 300.00]); // {0}에서 {1} 사이의 숫자를 입력하세요
		this.smfIsNull(ds) ? (obj.set_value(objValue < -300.00 ? -300.00 : 300.00)) : (ds.setColumn(targetRow, targetCol, objValue < -300.00 ? -300.00 : 300.00));
		return;
	}
};

/**
 * 모바일 시 상페 페이지 닫기
 * @param  : obj		- [object]Button
 * @param  : e			- [string]ClickEventInfo
 * @return : N/A
 */
this.fnCloseDivM = function(){
	for(var i = 0; i < divMList.length; i++){
		if (this[divMList[i]].visible){
			this[divMList[i].replaceAll('M', '')].set_visible(true);
		}
		this[divMList[i]].set_visible(false);
	}
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 초기화 조회
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
this.divSearch_btnInit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 급식일자 오늘날짜로 초기화, 식사구분 초기화
	this.divSearch.form.calMlsvYmd.set_value(this.smfToday());
	this.divSearch.form.chkItm.set_value(false);
	this.divSearch.form.chkItm1.set_value(true);
	this.divSearch.form.chkItm2.set_value(false);
	this.dsSearch.setColumn(0, 'mmealScCd', 2);
};

/**
 * 각탭 버튼 클릭 시
 * @param  : obj		- [object]Button
 * @param  : e			- [string]ClickEventInfo
 * @return : N/A
 */
this.Button_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (this.smfIsMobile())	this.fnCloseDivM();
	for(var i = 0; i < compBtnList.length; i++){
		this[compBtnList[i]].set_cssclass('btn_WF_Tab_Line');
		this[this[compBtnList[i]].divSc].set_visible(false);
	}
	
	obj.set_cssclass('btn_WF_Tab_LineS');
	this[obj.divSc].set_visible(true);
	this.smfResetScroll(this);
	
	if (this.fvIsCp1AllNoNm){
		this.smfAlert('LI155', ["학교기본정보에서 냉장/냉동고를 등록하여주십시오."]);
	}
};

/**
 * CCP 조회 버튼 클릭 시
 * @param  : obj		- [object]Button
 * @param  : e			- [string]ClickEventInfo
 * @return : N/A
 */
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (this.smfIsMobile())	this.fnCloseDivM();
	if (this.smfIsNull(this.dsSearch.getColumn(0, 'mlsvYmd'))){
		this.smfAlert('CM006', ["급식일자"]); // {0}은(는) 필수 입력입니다.
		return;
	}else if (this.smfIsNull(this.dsSearch.getColumn(0, 'mmealScCd'))){
		this.smfAlert('CM006', ["식사구분"]); // {0}은(는) 필수 입력입니다.
		return;
	}
	
	// 데이터셋 변경 여부 체크
	if (this.smfIsUpdateList([this.dsCcpMngBsc, this.dsCcp2MngDtl, this.dsCcp3MngDtl, this.dsCp1MngDtl, this.dsCp2MngDtl])){
		this.smfConfirm('PA060', ['변경된 데이터가 있습니다. 조회'], this.fnMessageCallback);
		return;
	}else{
		this.fnSearchList();
 	}
};

/**
 * 삭제 버튼 클릭시
 * @param  : obj		- [object]Button
 * @param  : e			- [string]ClickEventInfo
 * @return : N/A
 */
this.btnDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (obj.dsSc == 'dsCp1MngDtl'){
		for(var i = this[obj.dsSc].length-1; i > -1 ; i--){
			this[obj.dsSc].deleteRow(i);
		}
		return;
	}
	if (this.smfIsMobile()){
		this[obj.dsSc].setColumn(this[obj.dsSc].rowposition, 'chk', 1);
	}
	var chkList = this[obj.dsSc].extractRows("chk == 1");
	if (chkList.length == 0 || chkList == -1){
		this.smfAlert('CM012', []); //삭제할 자료를 먼저 선택하여 주십시오.
		return;
	}
	for(var i = chkList.length-1; i > -1 ; i--){
		this[obj.dsSc].deleteRow(chkList[i]);
	}
};

/**
 * 추가 버튼 클릭시
 * @param  : obj		- [object]Button
 * @param  : e			- [string]ClickEventInfo
 * @return : N/A
 */
this.btnAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var row = this[obj.dsSc].addRow();
	for(var i = 0; i < this[obj.dsSc].getColCount(); i++){
		if (this[obj.dsSc].getColID(i).indexOf('Cnt') > -1){
			this[obj.dsSc].setColumn(row, i, 0);
		}else if(this[obj.dsSc].getColID(i).indexOf('ccpScCd') > -1){
			this[obj.dsSc].setColumn(row, i, obj.ccpSc);
		}else if(this[obj.dsSc].getColID(i).indexOf('mmealScCd') > -1){
			if (this.dsCcpMngByMmealScCd.getCaseCountNF("value != ''") == 1){
				this[obj.dsSc].setColumn(row, i, this.dsCcpMngByMmealScCd.getColumn(0, 'value'));
			}
		}else if(this[obj.dsSc].getColID(i) == 'bfrHnrYn'){
			this[obj.dsSc].setColumn(row, i, 'Y');
		}
	}
	
	if (this.smfIsMobile()){
		var detailDivM = obj.parent.parent.parent.parent.id + 'M';
		this[detailDivM].set_left(20);
		this[detailDivM].set_right(20);
		obj.parent.parent.parent.parent.set_visible(false);
		this[detailDivM].set_visible(true);
		this.smfResetScroll(this);
	}
};

/**
 * 저장 버튼 클릭시
 * @param  : obj		- [object]Button
 * @param  : e			- [string]ClickEventInfo
 * @return : N/A
 */
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSetImprActnRecCnDataset();
	
	// 데이터셋 변경 여부 체크
	if (this.smfIsUpdateList([this.dsCcpMngBsc, this.dsCcp2MngDtl, this.dsCcp3MngDtl, this.dsCp1MngDtl, this.dsCp2MngDtl])){
		this.dsCcpMngBsc.set_updatecontrol(false);
		if (this.smfIsUpdateList([this.dsCcp2MngDtl])){
			this.dsCcpMngBsc.setRowType(this.dsCcpMngBsc.findRowExpr("ccpScCd == 20 || ccpScCd == 21"), "U");
		}else if (this.smfIsUpdateList([this.dsCcp3MngDtl])){
			this.dsCcpMngBsc.setRowType(this.dsCcpMngBsc.findRowExpr("ccpScCd == 30 || ccpScCd == 31 || ccpScCd == 32"), "U");
		}else if (this.smfIsUpdateList([this.dsCp1MngDtl])){
			this.dsCcpMngBsc.setRowType(this.dsCcpMngBsc.findRowExpr("ccpScCd == 40"), "U");
		}else if (this.smfIsUpdateList([this.dsCp2MngDtl])){
			this.dsCcpMngBsc.setRowType(this.dsCcpMngBsc.findRowExpr("ccpScCd == 50 || ccpScCd == 51 || ccpScCd == 52"), "U");
		}
		this.dsCcpMngBsc.set_updatecontrol(true);
	}
	
	// 유효성체크
	if (obj.dsSc == 'dsCcp2MngDtl'){
		for(var i = 0; i < this[obj.dsSc].rowcount; i++){
			if (this.smfIsNull(this[obj.dsSc].getColumn(i, 'foodComCdValue'))){
				this.smfAlert('CM006', ["식재료명"]); // {0}은(는) 필수 입력입니다.
				return;
			}
			if (this.smfIsNull(this[obj.dsSc].getColumn(i, 'ccpCooMthCdValue'))){
				this.smfAlert('CM006', ["취급 및 조리방법"]); // {0}은(는) 필수 입력입니다.
				return;
			}
		}
	}
	
	this.fnSave(obj);
};

/**
 * 콤보리스트 그리드 클릭시
 * @param  : obj		- [object]Grid
 * @param  : e			- [string]GridClickEventInfo
 * @return : N/A
 */
this.grdSeleteList_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var ds = obj.getBindDataset();
	if (e.col != 0){
		ds.setColumn(e.row, "chk", ds.getColumn(e.row, "chk") ? null : 1);
	}
	this.fnSetGrdToCbo(obj, ds);
};

/**
 * 그리드 헤드 체크박스 클릭시
 * @param  : obj		- [object]Grid
 * @param  : e			- [string]GridClickEventInfo
 * @return : N/A
 */
this.grdMain_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	this.smfToggleChkHeader(obj, e);
};

/**
 * 그리드 셀 클릭시
 * @param  : obj		- [object]Grid
 * @param  : e			- [string]GridClickEventInfo
 * @return : N/A
 */
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var ds = obj.getBindDataset();
	if (e.cell == 0 && obj.parent.parent.name != 'divCP1'){
		if (ds.extractRows("chk == 1").length != ds.rowcount){
			obj.setCellProperty( "head", e.cell, "expr", 0);
		}else{
			obj.setCellProperty( "head", e.cell, "expr", 1);
		}
	}
	
	var proCboSc = obj.getCellPropertyValue(e.row, e.cell, "cboSc");
	// 현재시간
	if (obj.getCellPropertyValue(e.row, e.cell, "edittype") == 'button'){
 		this.fnSetDateTime(ds, e.row, obj.getCellPropertyValue(e.row, e.cell, "sc"));
	} // 식재료명, 취급 및 조리방법 콤보
	else if (proCboSc == 'grdFoodComCdValue' || proCboSc == 'grdCcpCooMthCdValue'){
		this.fvCcp2Row = e.row;
		
		var dsProCboSc = obj.parent[proCboSc].getBindDataset();
		if (proCboSc == 'grdFoodComCdValue'){
			dsProCboSc.filter("mmealScCd == '" + ds.getColumn(e.row , 'mmealScCd') + "' && ddishCd == '" + ds.getColumn(e.row , 'ddishCdValue') + "'");
		}else{
			dsProCboSc.filter((ds.getColumn(e.row , 'bfrHnrYn') == 'Y' ? "upValue == 'Y'" : "upValue == 'N'") + " && useYn == 'Y'");
		}
		
		obj.parent[proCboSc].set_left(e.clientx);
		obj.parent[proCboSc].set_top(e.clienty + 70);
		obj.parent[proCboSc].set_visible(true);
		this.fnSetCboGridChk(obj, proCboSc, e.row);
	} // 음식명
	else if (proCboSc == 'dsCcpMngByDdishCd'){
		this[proCboSc].filter("mmealScCd == '" + ds.getColumn(e.row , 'mmealScCd') + "'");
	}
	
	if (this.smfIsMobile()){
		var detailDivM = obj.getCellPropertyValue(e.row, e.cell, "detailDivM");
		// 상세 버튼 클릭
		if (e.cell == 2){
 			this[detailDivM].form.staCnt.set_text(e.row + 1 + '/' + ds.rowcount);
			this[detailDivM].set_left(20);
			this[detailDivM].set_right(20);
 			obj.parent.parent.set_visible(false);
			this[detailDivM].set_visible(true);
			this.smfResetScroll(this);
		}
	}
};

/**
 * 현재시간 버튼 클릭시
 * @param  : obj		- [object]Button
 * @param  : e			- [string]ClickEventInfo
 * @return : N/A
 */
this.btnCurHr_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objDate = new Date();
	var sToday = this.smfRight("0" + objDate.getHours(), 2) + this.smfRight("0" + objDate.getMinutes(), 2);
	obj.parent[obj.targetComp].set_value(sToday);
};

/**
 * 마스크값 변경 시
 * @param  : obj		- [object]MaskEdit
 * @param  : e			- [string]ChangeEventInfo
 * @return : N/A
 */
this.MaskEdit_onchanged = function(obj:nexacro.MaskEdit,e:nexacro.ChangeEventInfo)
{
	var hh = e.postvalue.substr(0, 2);
	var mm = e.postvalue.substr(2);
	if (hh > 24 || mm > 60){
		this.smfAlert('PA058', ["올바른 형식의 시간을 입력"]); // 올바른 형식의 시간을 입력해주세요.
	}
};

/**
 * 온도 값 변경 시
 * @param  : obj		- [object]MaskEdit
 * @param  : e			- [string]KeyEventInfo
 * @return : N/A
 */
this.MaskEdit_onkeyup = function(obj:nexacro.MaskEdit,e:nexacro.KeyEventInfo)
{
	this.fnSetTemCnt(null, null, null, null, obj);
};

/**
 * dsCcpMngDtl 데이터셋 변경시
 * @param  : obj		- [object]NormalDataset
 * @param  : e			- [string]DSColChangeEventInfo
 * @return : N/A
 */
this.dsCcpMngDtl_oncolumnchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	// 온도 설정
	if (e.col == 19 || e.col == 23 || e.col == 26){ // foodTemCnt, lucTemCnt, disfoTemCnt
		this.fnSetTemCnt(obj, e.row, e.col, e.newvalue, null);
	}// 식사구분에 따른 음식코드 필터 
	else if (e.col == 5){
 		this.dsCcpMngByDdishCd.filter("mmealScCd == '" + e.newvalue + "'");
		if (e.oldvalue != e.newvalue){
			obj.setColumn(e.row, 7, null);
		}
	}// 음식명에 따른 식재료명 설정
	else if (e.col == 7){
		obj.setColumn(e.row, 'ddishCdValueCn', this.dsCcpMngByDdishCd.lookup('value', obj.getColumn(e.row , 'ddishCdValue'), 'label'));
		this.dsCcpMngByDdishCdFoodComCd.filter("mmealScCd == '" + obj.getColumn(e.row , 'mmealScCd') + "' && ddishCd == '" + obj.getColumn(e.row , 'ddishCdValue') + "'");
		if (e.oldvalue != e.newvalue){
			obj.setColumn(e.row, 9, null);
			obj.setColumn(e.row, 10, null);
			for(var i = 0; i < this.dsCcpMngByDdishCdFoodComCd.getRowCountNF(); i++){
				this.dsCcpMngByDdishCdFoodComCd.setColumnNF(i, 'chk', null);
			}
		}
	}// 취급장소에 따른 취급 및 조리방법 필터
	else if (e.col == 13 || e.col == 14){ // 전처리실, 조리실
		obj.setColumn(e.row, e.col == 13 ? 14 : 13, null);
		obj.setColumn(e.row, 11, null); // 취급 및 조리방법 코드
		obj.setColumn(e.row, 12, null); // 취급 및 조리방법 코드명
		for(var i = 0; i < this.dsCcpCooMthCd.getRowCountNF(); i++){
			this.dsCcpCooMthCd.setColumnNF(i, 'chk', null);
		}
		this.dsCcpCooMthCd.filter((e.col == 13 ? "upValue == 'Y'" : "upValue == 'N'") + " && useYn == 'Y'");
	}// 조리혼합시작시간
	else if (e.col == 15){
		if (!this.smfIsNull(e.newvalue) && !this.smfIsNull(obj.getColumn(e.row, 17)) && !(e.newvalue <= obj.getColumn(e.row, 17))){ // 조리혼합시작시간 < 조리완료시간
			this.smfAlert('CM020', ["조리혼합시작시간", "조리완료시간"]); // {0} 은(는) {1} 보다 작아야 합니다.
			obj.setColumn(e.row, 15, obj.getColumn(e.row, 17));
			return;
		}
	}// 조리완료시간
	else if (e.col == 17){
		if (!this.smfIsNull(e.newvalue) && !this.smfIsNull(obj.getColumn(e.row, 15)) && !(e.newvalue >= obj.getColumn(e.row, 15))){ // 조리완료시간 > 조리혼합시작시간
			this.smfAlert('CM021', ["조리완료시간", "조리혼합시작시간"]); // {0} 은(는) {1} 보다 커야 합니다.
			obj.setColumn(e.row, 17, obj.getColumn(e.row, 15));
			return;
		}
		if (!this.smfIsNull(e.newvalue) && !this.smfIsNull(obj.getColumn(e.row, 25)) && !(e.newvalue <= obj.getColumn(e.row, 25))){ // 조리완료시간 < 배식완료시간
			this.smfAlert('CM020', ["조리완료시간", "배식완료시간"]); // {0} 은(는) {1} 보다 작아야 합니다.
			obj.setColumn(e.row, 17, obj.getColumn(e.row, 25));
			return;
		}
	}// 배식완료시간
	else if (e.col == 25){
		if (!this.smfIsNull(e.newvalue) && !this.smfIsNull(obj.getColumn(e.row, 17)) && !(e.newvalue >= obj.getColumn(e.row, 17))){ // 배식완료시간 > 조리완료시간
			this.smfAlert('CM021', ["배식완료시간", "조리완료시간"]); // {0} 은(는) {1} 보다 커야 합니다.
			obj.setColumn(e.row, 25, obj.getColumn(e.row, 17));
			return;
		}
	}
};

/**
 * 식사구분 체크값 변경 시
 * @param  : obj		- [object]CheckBox
 * @param  : e			- [string]CheckBoxChangedEventInfo
 * @return : N/A
 */
this.CheckBox_onchanged = function(obj:nexacro.CheckBox,e:nexacro.CheckBoxChangedEventInfo)
{
	var chkList = new Array();
	for(var i = 0; i < 3; i++){
		if (this.divSearch.form["chkItm" + i].value){
			chkList.push(this.divSearch.form["chkItm" + i].mmealSc);
		}
	}
	
	this.dsSearch.setColumn(0, 'mmealScCd', chkList.join(','));
};

/**
 * 데이터셋 컬럼값 변경 시
 * @param  : obj		- [object]NormalDataset
 * @param  : e			- [string]DSColChangeEventInfo
 * @return : N/A
 */
this.dsCp1MngDtl_oncolumnchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	// 온도 설정
	if (obj.getColID(e.col).indexOf('Cnt') > -1){
		this.fnSetTemCnt(obj, e.row, e.col, e.newvalue, null);
	}
};

/**
 * 최근정보불러오기 버튼 클릭 시
 * @param  : obj		- [object]Button
 * @param  : e			- [string]ClickEventInfo
 * @return : N/A
 */
this.btnRntInfo_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (this[obj.rntInfoDsSc].rowcount == 0){
		this.smfAlert('LI002', []); // 조회된 자료가 없습니다.
		return;
	}
	
	// ccp2인 경우 멀티콤보를 위해 dsCcpMngDtl에 데이터 추가
	if (obj.rntInfoDsSc == 'dsCcpMngDtlRtnInfo'){
		for(var i = 0; i < this[obj.rntInfoDsSc].rowcount; i++){
			this.dsCcpMngDtl.copyRow(this.dsCcpMngDtl.addRow(), this[obj.rntInfoDsSc], i);
		}
	}
	
	this[obj.trgtDsSc].copyData(this[obj.rntInfoDsSc]);
};

/**
 * 모바일 이전 버튼 클릭 시
 * @param  : obj		- [object]Button
 * @param  : e			- [string]ClickEventInfo
 * @return : N/A
 */
this.btnPre_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var curentRow = this[obj.dsSc].rowposition;
	this[obj.dsSc].set_rowposition(curentRow - (curentRow == 0 ? 0 : 1));
	obj.parent.staCnt.set_text(curentRow - (curentRow == 0 ? 0 : 1) + 1 + '/' + this[obj.dsSc].rowcount);
};

/**
 * 모바일 다음 버튼 클릭 시
 * @param  : obj		- [object]Button
 * @param  : e			- [string]ClickEventInfo
 * @return : N/A
 */
this.btnNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var curentRow = this[obj.dsSc].rowposition;
	this[obj.dsSc].set_rowposition(curentRow + (curentRow == (this[obj.dsSc].rowcount - 1) ? 0 : 1));
	obj.parent.staCnt.set_text(curentRow + (curentRow == (this[obj.dsSc].rowcount - 1) ? 0 : 1) + 1 + '/' + this[obj.dsSc].rowcount);
};

/**
 * 모바일 목록 버튼 클릭 시
 * @param  : obj		- [object]Button
 * @param  : e			- [string]ClickEventInfo
 * @return : N/A
 */
this.ListButton_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var detailDiv = obj.parent.parent.parent.parent.id.replaceAll('M', '');
	obj.parent.parent.parent.parent.set_visible(false);
	this[detailDiv].set_visible(true);
	this.smfResetScroll(this);
};

/**
 * 각탭 초기화 버튼 클릭 시
 * @param  : obj		- [object]Button
 * @param  : e			- [string]ClickEventInfo
 * @return : N/A
 */
this.btnReset_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this[obj.dsSc].reset();
};

/**
 * 멀티콤보 그리드 확인 클릭 시
 * @param  : obj		- [object]Grid
 * @param  : e			- [string]GridClickEventInfo
 * @return : N/A
 */
this.Grid_onsummaryclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if (e.cell == 0){
		obj.set_visible(false);
	}
};

/**
 * 콤보 아이템 표시될 시
 * @param  : obj		- [object]Combo
 * @param  : e			- [string]EventInfo
 * @return : N/A
 */
this.Combo_ondropdown = function(obj:nexacro.Combo,e:nexacro.EventInfo)
{
	var proCboSc = obj.id == 'cboFoodComCdValueCn' ? 'grdFoodComCdValue' : 'grdCcpCooMthCdValue';
	var dsProCboSc = obj.parent[proCboSc].getBindDataset();
	var ds = this.dsCcp2MngDtl;
	var row = ds.rowposition;
	this.fvCcp2Row = row;
	
	if (proCboSc == 'grdFoodComCdValue'){
		dsProCboSc.filter("mmealScCd == '" + ds.getColumn(row, 'mmealScCd') + "' && ddishCd == '" + ds.getColumn(row, 'ddishCdValue') + "'");
	}else{
		dsProCboSc.filter((ds.getColumn(row, 'bfrHnrYn') == 'Y' ? "upValue == 'Y'" : "upValue == 'N'") + " && useYn == 'Y'");
	}
	obj.parent[proCboSc].set_visible(true);
	this.fnSetCboGridChk(obj, proCboSc, row);
	return false;
};
]]></Script>
