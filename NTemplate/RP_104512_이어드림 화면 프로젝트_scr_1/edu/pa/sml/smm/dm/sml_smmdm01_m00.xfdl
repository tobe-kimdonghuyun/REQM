        <Static id="sta01" left="0" top="135" height="60" right="0" text="60"/>
        <Static id="sta02" left="0" top="575" height="60" right="0" text="60"/>
        <Div id="divCCP2A" left="20" top="872" height="1505" right="20"/>
        <Div id="divCCP2B" left="20" top="872" height="1493" right="20"/>
        <Div id="divCCP3A" left="20" top="872" height="1410" right="20"/>
        <Div id="divCCP3B" left="30" top="872" height="1450" right="20"/>
        <Div id="divCCP3C" left="20" top="872" height="1562" right="20"/>
        <Div id="divCP1" left="20" top="872" height="1386" right="20"/>
        <Div id="divCP2A" left="20" top="872" height="1950" right="20"/>
        <Div id="divCP2B" left="20" top="872" height="1775" right="20"/>
        <Div id="divCP2C" left="20" top="872" height="1855" right="20"/>
