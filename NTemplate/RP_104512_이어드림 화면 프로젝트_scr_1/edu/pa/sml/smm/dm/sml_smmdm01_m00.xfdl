        <Button id="btnCcp3" left="20" top="btnCcp2:-1" height="60" right="20"/>
        <Button id="btnCp1" left="20" top="btnCcp3:-1" height="60" right="20"/>
        <Button id="btnCp2" left="20" top="btnCp1:-1" height="60" right="20"/>
        <Div id="divCCP2BM" left="1390" top="902" height="1368" width="600"/>
        <Div id="divCCP2AM" left="720" top="902" height="1290" width="600"/>
        <Div id="divCCP3AM" left="2090" top="902" width="600" height="1369"/>
        <Div id="divCCP3BM" left="2760" top="902" width="600" height="1448"/>
        <Div id="divCCP3CM" left="3410" top="902" height="1448" width="600"/>
