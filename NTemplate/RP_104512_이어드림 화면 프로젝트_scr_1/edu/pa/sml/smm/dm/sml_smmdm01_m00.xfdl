                    <Static id="staVhcInnerStsYn" left="0" top="553" width="200" height="80" cssclass="sta_WF_DtlLabel01"/>
                    <Static id="sta57" left="200" top="553" height="80" right="0" cssclass="sta_WF_Dtl01"/>
                    <CheckBox id="chkVhcInnerStsYn" left="210" top="563" width="60" height="60"/>
                    <MaskEdit id="mskCooMixtrBgngHr" left="210" top="168" width="200" height="60"/>
                    <Button id="btnCurHr00" left="420" top="168" width="158" height="60"/>
                    <MaskEdit id="mskCooEndHr" left="210" top="405" width="200" height="60"/>
                    <Button id="btnCurHr01" left="420" top="247" width="158" height="60"/>
                    <Static id="staSnttDreWearYn" left="0" top="790" width="200" height="80" cssclass="sta_WF_DtlLabel01"/>
                    <Static id="sta60" left="200" top="790" height="80" right="0" cssclass="sta_WF_Dtl01"/>
                    <MaskEdit id="mskDisfoTemCnt" left="210" top="484" width="180" height="60"/>
                    <Static id="staLucTemCnt" left="0" top="316" width="200" height="80" cssclass="sta_WF_DtlLabel01"/>
                    <Static id="sta56" left="200" top="474" height="80" right="0" cssclass="sta_WF_Dtl01"/>
                    <MaskEdit id="mskLucTemCnt" left="210" top="326" width="180" height="60"/>
                    <CheckBox id="chkSnttDreWearYn" left="210" top="800" width="60" height="60"/>
                  </Layout>
                </Layouts>
              </Div>
              <Static id="sta00" taborder="2" left="0" top="div00:0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Div id="div01" taborder="1" top="sta00:0" width="450" height="41" right="0">
                <Layouts>
                  <Layout>
                    <Button id="btnSave" taborder="0" text="저장" top="0" cssclass="btn_WF_Action" onclick="btnSave_onclick" initvalueid="ivBtnAccessibilityButton" height="40" width="120" right="0"/>
                    <Button id="btnList" taborder="1" text="목록" top="0" cssclass="btn_WF_ActionLine" initvalueid="ivBtnAccessibilityButton" height="40" width="120" right="260" onclick="ListButton_onclick" divMSc="divCCP3CM"/>
                    <Button id="btnDelete" taborder="2" text="삭제" top="0" cssclass="btn_WF_ActionLine" initvalueid="ivBtnAccessibilityButton" height="40" width="120" right="130" onclick="btnDelete_onclick" dsSc="dsCcp3MngDtl"/>
                  </Layout>
                  <Layout name="Layout1">
                    <Button id="btnSave" top="140" height="80" right="0" cssclass="btn_WF_Big" left="0"/>
                    <Button id="btnDelete" height="60" left="0" right="0" top="70" cssclass="btn_WF_FunctionN01"/>
                    <Button id="btnList" height="60" left="0" right="0" top="0" cssclass="btn_WF_Custom"/>
