        </Div>
        <Static id="Static99_00_00_00_00_01" taborder="2" left="0" top="0" height="60" cssclass="sta_GD_Size" text="60" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_00_00_00" taborder="4" left="0" top="div00:0" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" height="70"/>
        <WebBrowser id="webEpkiLogin" taborder="5" left="0" top="0" width="0" height="0" onusernotify="webEpkiLogin_onusernotify" initvalueid="iv_Web" onsize="webEpkiLogin_onsize"/>
      </Layout>
