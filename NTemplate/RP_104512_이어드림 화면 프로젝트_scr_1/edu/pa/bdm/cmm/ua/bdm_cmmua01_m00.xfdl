              <Edit id="edtCorpNm" taborder="1" left="349" top="62" height="60" cssclass="edt_LOGIN_Input" displaynulltext="설립허가 받은 정식 명칭을 입력하여 주시기 바랍니다." initvalueid="ivEdtNormal" width="500"/>
              <Static id="sta00" taborder="2" text="설립허가번호" left="349" top="145" width="92" height="30" cssclass="sta_LOGIN_Tit15B" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtPrmsnNo" taborder="3" left="349" top="183" width="500" height="60" cssclass="edt_LOGIN_Input" displaynulltext="설립허가 받은 정식 허가번호를 입력하여 주시기 바랍니다." initvalueid="ivEdtNormal"/>
              <Static id="sta02_00" taborder="4" text="허가번호를 한글, 숫자를 포함하여서 입력하여 주세요. 예) 허가xxx" left="359" top="edtPrmsnNo:5" width="412" height="26" cssclass="sta_Login_MemberNotice" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
              <Static id="sta00_00" taborder="5" text="사업자등록번호(고유번호)" left="349" top="298" width="180" height="29" cssclass="sta_LOGIN_Tit15B" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtBrno" taborder="6" left="349" top="336" width="500" height="60" cssclass="edt_LOGIN_Input" displaynulltext="사업자등록번호(고유번호)를 입력해주세요." initvalueid="ivEdtNormal" inputtype="number" maxlength="10"/>
              <Button id="btn00" taborder="7" text="공동인증서 인증" top="434" width="500" cssclass="btn_LOGIN_One" left="349" initvalueid="ivBtnAccessibilityButton" onclick="tab00_Tabpage3_div00_btn00_onclick" height="60"/>
              <Static id="Static99_00_00_00_00_01_00_00_00_01_01" taborder="8" left="349" top="0" height="25" cssclass="sta_GD_Size" text="25" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="110"/>
              <Static id="Static99_00_00_00_00_01_00_00_00_01_01_01_01" taborder="9" left="349" top="53" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="110"/>
              <Static id="Static99_00_00_00_00_01_00_00_00_01_01_00_01" taborder="10" left="349" top="121" height="25" cssclass="sta_GD_Size" text="25" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="110"/>
              <Static id="Static99_00_00_00_00_01_00_00_00_01_01_01" taborder="11" left="349" top="174" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="110"/>
              <Static id="Static99_00_00_00_00_01_00_00_00_01_01_00" taborder="12" left="349" top="274" height="25" cssclass="sta_GD_Size" text="25" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="110"/>
              <Static id="Static99_00_00_00_00_01_00_00_00_01_01_01_00" taborder="13" left="349" top="327" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="110"/>
              <Static id="Static99_00_00_00_00_01_00_00_00_01_01_00_00" taborder="14" left="349" top="395" height="40" cssclass="sta_GD_Size" text="40" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="110"/>
