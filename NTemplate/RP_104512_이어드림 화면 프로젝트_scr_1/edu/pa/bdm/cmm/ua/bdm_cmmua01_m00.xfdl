    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    TEMPLATE
*  @FileName 	frameLogin.xfdl
*  @Creator 	홍길동
*  @CreateDate 	2022.7.5
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.7.5     	홍길동 	        최초 생성 
*******************************************************************************
*/
include "lib::bdm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
var corpNm;
var prmsnNo;
var brno;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frameLogin_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

	// 폼 초기화
	this.smfInitForm(obj);
	
	this.dsCorpCertReg.setColumn(0,"cddcCd", this.smfGetCddcCode())
}; 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	var sLog = "";
	if(e.result){
		var sData = JSON.parse(e.data);
		if(sData.vidResult == "true"){
			this.smfSaveService("saveCorpCertReg")
				.showConfirm(false)
				.run()
				.callback(function(callbackParams){
					if(callbackParams.errors) return;
					
					var cetRlt = this.dsRspnsRlt.getColumn(0, "cetRlt")
					if(cetRlt == "0"){
						this.bdmAlert("PA026", []); // 정상등록되었습니다. 로그인을 진행해주세요
						
						var sMainUrl =  this.getOwnerFrame().form.fv_mainformUrl;
						
						var params = {resendUrl: sMainUrl};
						var sUrl = "pa_bdm_cmm_ua::bdm_cmmua00_m00.xfdl"
						var bHead = false;
						
						this.smfSetWorkPage(sUrl, params, bHead);

					}else if(cetRlt == "1"){
						this.bdmAlert("PA027", []); // 이미 등록된 사업자등록번호입니다.
					}else if(cetRlt == "2"){
						this.bdmAlert("PA028", []); // 해당 법인이 두건이상 존재합니다. 관리자에게 문의하세요.
					}else if(cetRlt == "3" || cetRlt == "4"){
						this.bdmAlert("PA029", []); // 입력한 법인정보가 없습니다. 다시한번 확인해 주세요.
					}else if(cetRlt == "5"){
						this.bdmAlert("PA040", []);//입력한 법인은 해산 또는 청산된 법인입니다. 다시 한번 확인해주세요
					}else{
						this.bdmAlert("PA025", []); // 인증서 인증에 에러가 발생했습니다. 관리자에게 문의하세요.
					}
				});
		}else if(sData.vidResult.indexOf("VID") != -1){
			this.bdmAlert("PA024", []); // 입력된 사업자등록번호와 일치하지 않습니다. 다시한번 확인해 주세요.
		}else{
			this.bdmAlert("PA025", []); // 인증서 인증에 에러가 발생했습니다. 관리자에게 문의하세요.
		}
		
	}else{
		var sData = e.data;
		var arrData = sData.split(":");
		
		if(arrData[0].trim()=="800000")
		{  // 유저가 팝업을 강제 종료한 경우
			sLog += "처리결과 : [에러(유저강제종료)]\n";
			sLog += "data : ["+sData+"]";
		}
		else
		{
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+sData+"]";	
		}
		trace(sLog);
	}

};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 
this.tab00_Tabpage3_div00_btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	corpNm = this.div00.form.edtCorpNm.value;
	prmsnNo = this.div00.form.edtPrmsnNo.value;
	brno = this.div00.form.edtBrno.value;
	
	if(this.smfIsNull(corpNm)){
		this.bdmAlert("PA014", ["법인명"]); // valNmArray[i]+"는 필수입력입니다.
		return false;
	}else if(this.smfIsNull(prmsnNo)){
		this.bdmAlert("PA014", ["설립허가번호"]); // valNmArray[i]+"는 필수입력입니다.
		return false;
	}else if(this.smfIsNull(brno)){
		this.bdmAlert("PA014", ["사업자등록번호"]); // valNmArray[i]+"는 필수입력입니다.
		return false;
	}
	
	var sConnectBaseUrl = window.location.protocol + "//" + window.location.host;

	var sInitUrl  = sConnectBaseUrl + "/cmc_fcm_es01_003.do";
	var sLoginUrl = sConnectBaseUrl + "/cmc_fcm_es01_004.do";
	
	var objLoginInfo = {
							initUrl  : sInitUrl    // init시 사용하는 서비스명(앞에 "/"을 붙일 것)
						,   loginUrl : sLoginUrl   // login시 사용하는 서비스명(앞에 "/"을 붙일 것)
						,	userId : brno
	                   };   // 생략가능

	var objParam = {objForm:this, popupcallback:this.fnPopupCallback, loginInfo:objLoginInfo};
	this.smfExecNpkiAuth(objParam);
};
]]></Script>
    <Objects>
      <Dataset id="dsCorpCertReg" useclientlayout="false">
        <ColumnInfo>
          <Column id="corpNm" type="STRING" size="256" description="법인명"/>
          <Column id="prmsnNo" type="STRING" size="256" description="허가번호"/>
          <Column id="brno" type="STRING" size="256" description="사업자등록번호"/>
          <Column id="cddcCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="description" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="url">/bdm_cmm_ua01_001.do</Col>
            <Col id="id">saveCorpCertReg</Col>
            <Col id="inDatasets">dsCorpCertReg=dsCorpCertReg</Col>
            <Col id="outDatasets">dsRspnsRlt=dsRspnsRlt</Col>
            <Col id="description">법인인증서등록</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsRspnsRlt" useclientlayout="true">
        <ColumnInfo>
          <Column id="cetRlt" type="STRING" size="256" description="인증결과"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="div00.form.edtBrno" propid="value" datasetid="dsCorpCertReg" columnid="brno"/>
      <BindItem id="item1" compid="div00.form.edtPrmsnNo" propid="value" datasetid="dsCorpCertReg" columnid="prmsnNo"/>
      <BindItem id="item2" compid="div00.form.edtCorpNm" propid="value" datasetid="dsCorpCertReg" columnid="corpNm"/>
    </Bind>
  </Form>
</FDL>
