/**
 * @description 보완제출 버튼 클릭
 */
this.btnSpmSbmsn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	// 수정사항 체크
	var rowTypeCount = 0;
	var count = this.dsExctvList.getRowCount();
	for(var i=0; i<count ; i++){
		var nRowType = this.dsExctvList.getRowType(i);
		var chgScCd = this.dsExctvList.getColumn(i, "chgScCd");
		if(nRowType != 1) {
			rowTypeCount = rowTypeCount + 1;
		}
	}
	
	if(rowTypeCount > 0){
		this.bdmAlert("PA035", []); // 변경사항이 있습니다. 임시저장 후 진행해주세요.
		return false;
	}
	
	// [첨부파일]전체업로드된 파일 중 중복된게 있는지 체크(임원취임승인신청)	
	if(this.checkFileNmDupl()) return false;
	
	// [첨부파일] 임원 첨부파일 변경여부
	if(this.divFileUpload.form.fnIsExistUploadFile()) {
		this.bdmAlert("PA035", []); // 변경사항이 있습니다. 임시저장 후 진행해주세요.
		return false;
	}
	
	this.fnSpmSbmsn();
};

this.divExctvDetail_rdoCnptYn_canitemchange = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	// 현재 올라가있는 파일명
	var fileName = this.divExctvDetail.form.divUpload03.form.edtFile.value;
	
	if (!this.smfIsNull(fileName)) {
		this.divExctvDetail.form.btnDelete03.click(); // 삭제버튼 클릭
		
		// 예를 눌러서 삭제가 됐다면 onitemchanged, 취소 눌러서 삭제안했으면 YN 안바뀌게
		if (fileName == this.divExctvDetail.form.divUpload03.form.edtFile.value) {
			return false;
		}
	}
};
this.divExctvDetail_rdoCnptYn_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	// [첨부파일]첨부파일 필수표시 변경
	this.changeFileRequire();
};

