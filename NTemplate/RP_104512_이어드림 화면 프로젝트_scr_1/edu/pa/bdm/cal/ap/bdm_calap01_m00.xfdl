/**
 * @description row가 변경되기전 이벤트
 */
this.dsExctvList_canrowposchange = function(obj:nexacro.NormalDataset,e:nexacro.DSRowPosChangeEventInfo)
{
	// Row를 변경하기전 저장해야함
	if(! this.smfIsUpdateRow(obj, e.oldrow) && ! this.divFileUpload.form.fnIsExistUploadFile()) {
		return true;
	} else{
 		this.bdmAlert("PA035", []); // 변경사항이 있습니다. 임시저장 후 진행해주세요.
		return false;
	}
};


/**
 * @description 주민등록번호 입력 시 생년월일 추출
 */
this.divExctvDetail_mskExctvRrno_onchanged = function(obj:nexacro.MaskEdit,e:nexacro.ChangeEventInfo)
{
	var nRow = this.dsExctvList.rowposition;
	var exctvRrno = this.dsExctvList.getColumn(nRow, "exctvRrno");

	var nYear = exctvRrno.substr(0,2).padLeft(2,"0");
	var nMonth = parseInt(exctvRrno.substr(2,2))-1;
	var nDay = parseInt(exctvRrno.substr(4,2));
	
	if(exctvRrno.substr(6,1) >= 3) {
		nYear = "20" + nYear;
	} else {
		nYear = "19" + nYear;
	}
	
	var objDate = new nexacro.Date(nYear, nMonth, nDay);
	
	this.dsExctvList.setColumn(nRow, "exctvBrdt", objDate)
};

/**
 * @description 신구대조표 버튼 클릭
 */
this.btnCrtExctvNwdCeckList_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSearchService("selectExctvNwdCmprs")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		// 리포트를 생성하기 위한 옵션을 설정한다.
		var oOzOption = {
			reports : [	
				{	
					// 기본데이터
					  displayname  : "임원신구대조표"   // [필수] 멀티리포트시 Tree에 보여줄 이름
					, reportname   : "/edu/pa/bdm/cal/ap/bdm_calap01_r00.ozr" // [필수] 리포트명  "/jsonsample.ozr"
					
					, jsonDs       : [this.dsExctvNwdCmprs]  // [선택] json으로 변환할 데이터셋
					, jsonDsName   : ["dsExctvNwdCmprs"] 
						
					// 추가/보안옵션
					, security     : "N"   // [선택] 위변조방지 삽입   ("Y"(default):표시,"N":비표시)
					, voiceBarcode : "N"   // [선택] 보이스바코드 삽입 ("Y"(default):표시,"N":비표시)
				}
			]
			, popupWidth  : 1300	// [선택]  팝업으로 띄울 경우 팝업의 width(팝업의 기본width:1000)
			, popupHeight : 700	// [선택]  팝업으로 띄울 경우 팝업의 height(팝업의 기본width:610)
		};
						
		//리포트를 그린다.
		this.smfReportView(this,"popup",oOzOption,this.fnReportCallback);
	
	})
	
};


