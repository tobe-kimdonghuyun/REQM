/**
 * @description [첨부파일]첫번째 첨부파일(멀티) uploadComplete callback
 */
this.fnEventUploadComplete1 = function(obj,paramObj,objResultDataset)
{
	var sFileRefrnId = this.bdmFnEventUploadComplete(obj,paramObj,objResultDataset, this.divFileUpload1, null, null, null, false);

	// fileRefrnId
	this.dsMain.setColumn(0, "fileRefrnId", sFileRefrnId);
	
	// [첨부파일]단일업로드
	this.divFileUpload.form.fnFileUpload();
}

/**
 * @description [첨부파일]두번째 첨부파일(싱글) uploadComplete callback
 */
this.fnEventUploadComplete = function(obj,paramObj,objResultDataset)
{
	var sFileRefrnId = this.bdmFnEventUploadComplete(obj,paramObj,objResultDataset, this.divFileUpload, this.dsCorpFileRefrnList, this.divExctvDetail, this.atchFileCount, true);

	// fileRefrnId
	var nRow = this.dsExctvList.rowposition;
	this.dsExctvList.setColumn(nRow, "fileRefrnId", sFileRefrnId);
	
	// 저장
	var tmprStrgYn = this.dsMain.getColumn(0, "tmprStrgYn");
	if(tmprStrgYn == "N"){
		this.smfSaveService("saveNoprfCvlcptOnlRcpt")
		.showConfirm(false)
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
	 
			this.bdmAlert("PA013", []); // 제출이 완료되었습니다.
				
			var params = {};
			this.smfSetWorkPage("pa_bdm_cas_as::bdm_casas00_m00.xfdl", params);
		});
	}else if(tmprStrgYn == "Y"){
		this.smfSaveService("saveNoprfCvlcptOnlRcpt")
		.showConfirm(false)
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
	 
			// 저장이 완료되었습니다.
			// this.bdmAlert('CM002');
			
			// 법인정보조회
			this.fnSelectCorpInfo();
			
			// [첨부파일] 첨부파일명 전체 목록 조회
			this.selectFileNm();
		});
	}
}
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 /**
 * @description 임기종료일 자동 입력
 */
 this.fnSetTerEndYmd = function()
 {
 	var nRow = this.dsExctvList.rowposition;
	var exctvTerPrdCd = this.dsExctvList.getColumn(nRow, "noprfExctvTerPrdCd");
	var terBgngYmd = this.dsExctvList.getColumn(nRow, "terBgngYmd");
	
	if(!this.smfIsNull(exctvTerPrdCd) && !this.smfIsNull(terBgngYmd)){
		var nYear = parseInt(terBgngYmd.substr(0,4));
		var nMonth = parseInt(terBgngYmd.substr(4,2))-1;
		var nDay = parseInt(terBgngYmd.substr(6,2));
		
		var objDate = new nexacro.Date(nYear, nMonth, nDay);
		objDate.addMonth(parseInt(exctvTerPrdCd * 12));
		objDate.addDate(-1);
		
		this.dsExctvList.setColumn(nRow, "terEndYmd", objDate)
	} else {
		this.dsExctvList.setColumn(nRow, "terEndYmd", "");
	}
 }
 
/**
 * @description 비영리법인구분 화면 변경
 */
this.fnNoprfCorpSc = function (noprfCorpScCd)
{
	
	if(this.divExctvDetail.form.rdoComtrYn.value == "Y") {
		this.smfInsertRuleToComponent("required", this.divExctvDetail.form.edtComtrNmNoRd);
		this.smfInsertRuleToComponent("required", this.divExctvDetail.form.Static10_00_01_00_00_00);
		this.divExctvDetail.form.edtComtrNmNoRd.set_readonly(false);
	} else {
		this.smfRemoveRuleFromComponent("required", this.divExctvDetail.form.edtComtrNmNoRd);
		this.smfRemoveRuleFromComponent("required", this.divExctvDetail.form.Static10_00_01_00_00_00);
		this.divExctvDetail.form.edtComtrNmNoRd.set_readonly(true);
	}
	
	if(noprfCorpScCd == "1"){
		//공익
		this.smfInsertRuleToComponent("required", this.divExctvDetail.form.Static10_00_01_00_00_01_00);
		this.smfInsertRuleToComponent("required", this.divExctvDetail.form.rdoCnptYn);
		this.smfInsertRuleToComponent("required", this.divExctvDetail.form.Static10_00_01_00_00);
		this.smfInsertRuleToComponent("required", this.divExctvDetail.form.rdoComtrYn);
		this.smfInsertRuleToComponent("required", this.divExctvDetail.form.Static10_00_01_00_00_01);
		this.smfInsertRuleToComponent("required", this.divExctvDetail.form.edtSpyRelNmNoRd);
		this.smfInsertRuleToComponent("required", this.divExctvDetail.form.btnSpyRelSch);
		
	}else{
		//비영리
		this.smfRemoveRuleFromComponent("required", this.divExctvDetail.form.Static10_00_01_00_00_01_00);
		this.smfRemoveRuleFromComponent("required", this.divExctvDetail.form.rdoCnptYn);
		this.smfRemoveRuleFromComponent("required", this.divExctvDetail.form.Static10_00_01_00_00);
		this.smfRemoveRuleFromComponent("required", this.divExctvDetail.form.rdoComtrYn);
		this.smfRemoveRuleFromComponent("required", this.divExctvDetail.form.Static10_00_01_00_00_01);
		this.smfRemoveRuleFromComponent("required", this.divExctvDetail.form.edtSpyRelNmNoRd);
		this.smfRemoveRuleFromComponent("required", this.divExctvDetail.form.btnSpyRelSch);
	}
};

/**
 * @description 동적 필수 체크 
 */
this.fnValChk = function (noprfCorpScCd)
{
	var nRowIndex = this.dsExctvList.rowposition;
	var nRowType = this.dsExctvList.getRowType(nRowIndex);
	//겸직여부
	var cnptYn = this.dsExctvList.getColumn(nRowIndex, "cnptYn"); 
	//당연직여부
	var comtrYn = this.dsExctvList.getColumn(nRowIndex, "comtrYn");
	//당연직명
	var comtrNm = this.dsExctvList.getColumn(nRowIndex, "comtrNm");
	//특수관계명
	var spyRelNm = this.dsExctvList.getColumn(nRowIndex, "spyRelNm");
	//변경일자
	var chgYmd = this.dsExctvList.getColumn(nRowIndex, "chgYmd");
	//변경사유 
	var chgRsnCn = this.dsExctvList.getColumn(nRowIndex, "chgRsnCn");
	var valChkArray = new Array();
	var valNmArray = new Array();
	
	if(nRowType != 1 || this.divFileUpload.form.fnIsExistUploadFile()) {
		if(noprfCorpScCd == "1"){
			//공익
			valChkArray = [cnptYn, comtrYn, spyRelNm, chgYmd, chgRsnCn];
			valNmArray = ["겸직여부", "당연직여부", "특수관계", "변경일자", "변경사유"];
			for(var i = 0; i < valChkArray.length; i++){
				if(this.smfIsNull(valChkArray[i])){
					this.bdmAlert("PA014", [valNmArray[i]]); // {0}는 필수입력입니다.
					return false;
				}
			}
			
			if(comtrYn == "Y" && this.smfIsNull(comtrNm)){
				this.bdmAlert("PA015", []); // 당연직명은 필수입력입니다.
				return false;
			}
			
		}else{
			//비영리
			valChkArray = [chgYmd, chgRsnCn];
			valNmArray = ["변경일자", "변경사유"];
			for(var i = 0; i < valChkArray.length; i++){
				if(this.smfIsNull(valChkArray[i])){
					this.bdmAlert("PA014", [valNmArray[i]]); // {0}는 필수입력입니다.
					return false;
				}
			}
		}
	}
	return true;
};

/**
 * @description 수정여부확인
 */
this.fnModifiedDataset = function ()
{
	var nRowIndex = this.dsExctvList.rowposition;
	var nRowType = this.dsExctvList.getRowType(nRowIndex);
	
	if(nRowType == 1) {
		if( !this.divFileUpload.form.fnIsExistUploadFile() && !this.divFileUpload1.form.fnIsExistUploadFile()){
			this.bdmAlert("PA033", []); // 변경된 내용이 없습니다.
			return false;
		}
	}
	return true;
};

/**
 * @description 임시저장 유효성 검사
 */
this.validateCheckTmp = function()
{
	/*필수체크*/
	if(!this.fnModifiedDataset()) return false;
	if(!this.svcfGetValidateCompList(this.divClaiInfo)) return false;
	if(!this.svcfGetValidateCompList(this.divExctvDetail)) return false;
	if(!this.fnValChk(this.dsCorpInfo.getColumn(0, "noprfCorpScCd"))) return false;
	
	return true;
};

/**
 * @description 첨부파일 필수표시 변경
 */
this.changeFileRequire = function()
{
	var nRow = this.dsExctvList.rowposition;
	var noprfHffcScCd = this.dsExctvList.getColumn(nRow, "noprfHffcScCd"); //재직구분코드
	var noprfCorpScCd = this.dsCorpInfo.getColumn(0, "noprfCorpScCd"); // 비영리법인구분코드


	// 공익 vs 비공익
	if (noprfCorpScCd != "1") {
		this.divExctvDetail.form.staFileUploadLabel02.set_cssclass("sta_WF_Input01");
		this.divExctvDetail.form.staFileUploadLabel03.set_cssclass("sta_WF_Input01");
		this.divExctvDetail.form.staFileUploadLabel04.set_cssclass("sta_WF_Input01");

	} else {
		
		// 겸직여부
		var cnptYn = this.dsExctvList.getColumn(nRow, "cnptYn");
		if (cnptYn == "Y") {
			this.divExctvDetail.form.staFileUploadLabel04.set_cssclass("sta_WF_Essential");
			this.divExctvDetail.form.staFileUploadLabel04.set_enable(true);
			this.divExctvDetail.form.divUpload03.set_enable(true);
		} else {
			this.divExctvDetail.form.staFileUploadLabel04.set_cssclass("sta_WF_Input01");
			this.divExctvDetail.form.staFileUploadLabel04.set_enable(false);
			this.divExctvDetail.form.divUpload03.set_enable(false);
			
			if (this.divExctvDetail.form.btnDelete03._divUploadObj.form.edtFile.value != "") {
				this.divExctvDetail.form.btnDelete03.click();
			}
		}

		// 특수관계
		var spyRelCd = this.dsExctvList.getColumn(nRow, "spyRelCd");
		if (spyRelCd == "00") {
			this.divExctvDetail.form.staFileUploadLabel02.set_cssclass("sta_WF_Essential");
			this.divExctvDetail.form.staFileUploadLabel03.set_cssclass("sta_WF_Input01");
			this.divExctvDetail.form.staFileUploadLabel02.set_enable(true);
			this.divExctvDetail.form.staFileUploadLabel03.set_enable(false);
			this.divExctvDetail.form.divUpload01.set_enable(true);
			this.divExctvDetail.form.divUpload02.set_enable(false);
			if (this.divExctvDetail.form.btnDelete02._divUploadObj.form.edtFile.value != "") {
				this.divExctvDetail.form.btnDelete02.click();
			}
		} else {
			this.divExctvDetail.form.staFileUploadLabel02.set_cssclass("sta_WF_Input01");
			this.divExctvDetail.form.staFileUploadLabel03.set_cssclass("sta_WF_Essential");
			this.divExctvDetail.form.staFileUploadLabel02.set_enable(false);
			this.divExctvDetail.form.staFileUploadLabel03.set_enable(true);
			this.divExctvDetail.form.divUpload01.set_enable(false);
			this.divExctvDetail.form.divUpload02.set_enable(true);
			if (this.divExctvDetail.form.btnDelete01._divUploadObj.form.edtFile.value != "") {
				this.divExctvDetail.form.btnDelete01.click();
			}
		}
	}
		
	if(noprfHffcScCd == 3 || noprfHffcScCd == 4 || noprfHffcScCd == 6){
		//해임, 임기만료
		
		this.divExctvDetail.form.Static10_00_01_00_00_01_00_01.set_cssclass("sta_WF_InputLeft_Box")
		this.divExctvDetail.form.staFileUploadLabel01.set_cssclass("sta_WF_Input01");
		this.divExctvDetail.form.staFileUploadLabel02.set_cssclass("sta_WF_Input01");
		this.divExctvDetail.form.staFileUploadLabel03.set_cssclass("sta_WF_Input01");
		this.divExctvDetail.form.staFileUploadLabel04.set_cssclass("sta_WF_Input01");
		this.divExctvDetail.form.staFileUploadLabel05.set_cssclass("sta_WF_Input01");
		this.divExctvDetail.form.staFileUploadLabel06.set_cssclass("sta_WF_Input01");
	}else{
		this.divExctvDetail.form.Static10_00_01_00_00_01_00_01.set_cssclass("sta_WF_InputLeft_Box,sta_WF_Red14")
		
		// 이력서
		if (noprfHffcScCd == 2) {
			this.divExctvDetail.form.staFileUploadLabel01.set_cssclass("sta_WF_Input01");
		} else {
			this.divExctvDetail.form.staFileUploadLabel01.set_cssclass("sta_WF_Essential");
		}
		
		this.divExctvDetail.form.staFileUploadLabel05.set_cssclass("sta_WF_Essential");
		this.divExctvDetail.form.staFileUploadLabel06.set_cssclass("sta_WF_Essential");
		this.divExctvDetail.form.staFileUploadLabel05.set_enable(true);
		this.divExctvDetail.form.staFileUploadLabel06.set_enable(true);
		this.divExctvDetail.form.divUpload04.set_enable(true);
		this.divExctvDetail.form.divUpload05.set_enable(true);
	}
	
}

/**
 * @description 단일첨부파일 파일선택 1개
 */
this.fnSetRaonProp = function()
{
	return this.bdmSetRaonProp();
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 신청 버튼 클릭
 */
this.btnApply_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 필수체크 (임시저장 한건이라도 있어야 진행가능)
	var rowTypeCount = 0;
	var chgScCdCount = 0;
	var count = this.dsExctvList.getRowCount();
	for(var i=0; i<count ; i++){
		var nRowType = this.dsExctvList.getRowType(i);
		var chgScCd = this.dsExctvList.getColumn(i, "chgScCd");
		if(nRowType != 1) {
			rowTypeCount = rowTypeCount + 1;
		}
		if(!this.smfIsNull(chgScCd)){
			chgScCdCount = chgScCdCount + 1; 
		}
	}
	
	if(rowTypeCount > 0 || this.divFileUpload.form.fnIsExistUploadFile()){
		this.bdmAlert("PA035", []); // 변경사항이 있습니다. 임시저장 후 진행해주세요.
		return false;
	}
	
	if(chgScCdCount == 0){
		this.bdmAlert("PA034", []); // 임시저장 후 신청 해주시기 바랍니다.
		return false;
	}
	
//	// [첨부파일]멀티첨부파일 필수체크
//	var nTotalCount = this.divFileUpload1.form.fnGetTotalFileCount();
//	if(nTotalCount == 0) {
//	   this.bdmAlert("PA016", []); // 공통첨부파일을 첨부 하셔야 합니다.
//	   return false;
//	}
	
	// [첨부파일]전체업로드된 파일 중 중복된게 있는지 체크(임원취임승인신청)	
	if(this.checkFileNmDupl()) return false;
	
	// 신청 버튼 클릭 시 민원요약 팝업 호출
	var popupParams = {
		callback: this.fncvlcptSmyCnCallback,
		sender: obj,
		params: {
			// 처리타입 지정
			procType: 'insert',
			// 파라메터 전달 
			cvlcptNm: '임원취임승인신청',
			cvlcptSmyCn: this.dsMain.getColumn(0, "cvlcptSmyCn")
		},
	}
	this.smfDialog("_auto", "pa_bdm_cal_ap::bdm_calap00_p01.xfdl", popupParams);
};

/**
 * @description 임원 목록 추가 버튼 클릭
 */
this.btnAddExctv_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var nRowIndex = this.dsExctvList.rowposition;
	var nRowType = this.dsExctvList.getRowType(nRowIndex);
	
	if(nRowType != 0 && nRowType != 1) {
		this.bdmAlert("PA035", []); // 변경사항이 있습니다. 임시저장 후 진행해주세요.
		return false;
	}
	
	this.dsExctvList.addRow();
	var nRow = this.dsExctvList.rowposition;
	this.dsExctvList.setColumn(nRow,"comtrYn", "N");
	this.dsExctvList.setColumn(nRow,"cnptYn", "N");
	this.divExctvDetail.form.edtSpyRelNmNoRd.set_value("");
	this.dsExctvList.setColumn(nRow, "nltyNm", "대한민국");
	this.dsExctvList.setColumn(nRow, "nltyCd", "410");
	this.dsExctvList.setColumn(nRow, "chgYmd", this.smfToday());
	this.dsExctvList.setColumn(nRow, "chgRsnCn", "신규 임원 취임");
};

/**
 * @description 임원 목록 삭제 버튼 클릭
 */
this.btnDelExctv_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var nRow = this.dsExctvList.rowposition;
	var rowType = this.dsExctvList.getRowType(nRow);
	var chgScCd = this.dsExctvList.getColumn(nRow, "chgScCd");
	
	if (this.dsExctvList.rowcount == 0) {
		this.bdmAlert("PA042", []); // 삭제할 임원이 없습니다.
		return false;
	} else if (rowType != "2" && chgScCd != "I") {
		this.bdmAlert("PA036", []); // 신규 임원만 삭제할 수 있습니다.
		return false;
	}
	
	// PA044: 선택한 임원을 삭제 하시겠습니까?
	this.smfConfirm("PA044", function(result){
 		if(result.confirmResult){
			if (rowType == "2") { // Dataset.ROWTYPE_INSERT
				this.dsExctvList.deleteRow(nRow);
			} else if (chgScCd == "I") {
				
				this.smfDeleteService("deleteTmprExctv")
				.showConfirm(false)
				.run()
				.callback(function(callbackParams){
					if(callbackParams.errors) return;
					
					this.bdmAlert("PA020", []); // 삭제가 완료되었습니다.
					
					// 법인정보조회
					this.fnSelectCorpInfo();
					
					// [첨부파일] 첨부파일명 전체 목록 조회
					this.selectFileNm();
				});
			}
 		}
 	});	
	
};

/**
 * @description 임시저장 버튼 클릭
 */
this.btnTmprSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnTmprSaveCvlcpt();
};

/**
 * @description 신청자 주소찾기 버튼 클릭
 */
this.divClaiInfo_btnClaiRdnAddrSch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: this.fnCommpopRdnZip, // 콜백함수 지정
		sender: obj, // sender 지정

		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: 'search',
			// 파라메터 전달 
			//dataset: this.dsSample1,
		},
	};

	// 모달팝업 실행
	this.smfDialog("_auto", "commpop::commpop_rdn_zip.xfdl", popupParams);
};

