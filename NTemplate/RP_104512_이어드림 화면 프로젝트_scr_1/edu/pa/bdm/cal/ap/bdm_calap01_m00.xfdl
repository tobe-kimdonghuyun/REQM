    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    대국민 비영리법인 민원신청 임원취임승인신청
*  @FileName 	bdm_calap01_m00.xfdl 
*  @Creator 	
*  @CreateDate 	2022.12.19
*  @Desction    임원취임승인신청
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.12.19                            최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::bdm_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
/**
 * @description 민원분류번호- 임원취임승인신청
 */
this.cddcCd = this.bdmGetUserInfo("cddcCd");
this.fv_cvlcptClfNo = "037AA01201";
this.atchFileCount = 6; // 단일 첨부파일 갯수
this.noprfCorpScCd;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	//로그인 확인
	this.bdmfChkLogin();
	
	// 폼을 초기화
	this.smfInitForm(obj);
	
	this.smfValidateService("validateMain", {
		url: "/bdm_cal_ap01_000.do",
	})
	.mappingRulesetToForm(this.divClaiInfo, "claiInfo")
	.mappingRulesetToForm(this.divExctvDetail, "exctvDetail")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
	})
	
	// [첨부파일]첨부파일 세팅, uploadComplete callback설정
	this.bdmFileLoad(this, this.divFileUpload, this.divExctvDetail, this.atchFileCount, true);
	this.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;
	this.bdmFileLoad(this, this.divFileUpload1, null, null, false);
	this.divFileUpload1.UPLOAD_UploadComplete = this.fnEventUploadComplete1;
	
	// 세션에서 시도코드 받아서 검색 파라미터 세팅
	this.dsSearch.setColumn(0,"cddcCd", this.cddcCd);
	// 민원코드 검색 파리미터 세팅
	this.dsSearch.setColumn(0,"cvlcptClfNo", this.fv_cvlcptClfNo);
	
	//민원목록에서 넘어온 파라미터 세팅
	this.fv_param = this.smfGetFormParams();
	this.dsSearch.setColumn(0, "corpSbmsnNo", this.fv_param.corpSbmsnNo);
	
	// 법인정보조회
	this.fnSelectCorpInfo();
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 법인정보조회
 */
this.fnSelectCorpInfo = function()
{
	this.smfSearchService("selectCorpInfo")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		// [첨부파일] 초기화
		// this.bdmFileReLoad(this.divFileUpload, this.divExctvDetail, this.atchFileCount, true);
		// this.bdmFileReLoad(this.divFileUpload1, null, null, false);
	
		this.fnSelectCvlcpt();
		
		this.dsSearch.setColumn(0, "noprfCorpScCd", this.dsCorpInfo.getColumn(0, "noprfCorpScCd"));
		this.noprfCorpScCd = this.dsCorpInfo.getColumn(0, "noprfCorpScCd");
		if(this.noprfCorpScCd == "2"){
			this.divExctvDetail.form.Static45_00_00.set_text("회장여부")
		}
		
		this.smfResetScroll(this);
	})
}

 /**
 * @description 임원취임승인신청 임시저장 조회 Transaction
 */
this.fnSelectCvlcpt = function()
{
	this.smfSearchService("selectCvlcpt")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		var corpSbmsnNo = this.dsMain.getColumn(0, "corpSbmsnNo");
		var state = this.dsMain.getColumn(0, "state");
		var spmSn = this.dsMain.getColumn(0, "spmSn");
		var sbmsnYmd = this.dsMain.getColumn(0, "sbmsnYmd");
		var onlAplyYn = this.dsMain.getColumn(0, "onlAplyYn");
		var noprfCorpScCd = this.dsCorpInfo.getColumn(0, "noprfCorpScCd");
		
		// 법인코드로 법인정보 조회하여 신청자정보 입력
		this.dsMain.setColumn(0, "cddcCd", this.bdmv_cddcCd);
		this.dsMain.setColumn(0, "cvlcptClfNo", this.fv_cvlcptClfNo);
		this.dsMain.setColumn(0, "ctefCd", this.dsCorpInfo.getColumn(0, "ctefCd"));
		this.dsMain.setColumn(0, "orgNm", this.dsCorpInfo.getColumn(0, "orgNm"));
		this.dsMain.setColumn(0, "corpNm", this.dsCorpInfo.getColumn(0, "corpNm"));
		this.dsMain.setColumn(0, "rveNm", this.dsCorpInfo.getColumn(0, "rveNm"));
		this.dsMain.setColumn(0, "revTelno", this.dsCorpInfo.getColumn(0, "rveMblTelno"));
		
		//방문접수차단
		if(onlAplyYn == "N"){
			this.bdmAlert("PA007", []); // 방문접수로 민원이 진행중입니다. 진행이 완료된 후 확인 부탁드립니다.
			var params = {};
			this.smfSetWorkPage("pa_bdm_cas_as::bdm_casas00_m00.xfdl", params);
		}
		
		if (state == undefined){
			//신규
			this.dsMain.setColumn(0, "newYn" , "Y");
			this.dsMain.setColumn(0, "claiFlnm", this.dsCorpInfo.getColumn(0, "prgeNm"));
			this.dsMain.setColumn(0, "claiBrdt", this.dsCorpInfo.getColumn(0, "prgeBrdt"));
			this.dsMain.setColumn(0, "claiAddr", this.dsCorpInfo.getColumn(0, "prgeAddr"));
			this.dsMain.setColumn(0, "claiDtlAddr", this.dsCorpInfo.getColumn(0, "prgeDaddr"));
			this.dsMain.setColumn(0, "claiTelno", this.dsCorpInfo.getColumn(0, "prgeTelno"));
			this.dsMain.setColumn(0, "claiMblTelno", this.dsCorpInfo.getColumn(0, "prgeMblTelno"));
			this.dsMain.setColumn(0, "claiEmlAddr", this.dsCorpInfo.getColumn(0, "prgeEmlAddr"));
			
			this.smfSetDatasetRowType(this.dsMain, 0, "C");
			
			this.smfSearchService("selectCorpExctvList")
			.run()
			.callback(function(callbackParams){
				if(callbackParams.errors) return;
				this.dsExctvList.setColumn()
				
				//화면 컨트롤
				this.bdmBtnVisible(this, "1");
				this.btnCrtExctvNwdCeckList.set_visible(false);
				this.btnAddExctv.set_visible(true);
				this.svcfTravelComponents(this.divClaiInfo, this.bdmOffReadOnly);
				this.svcfTravelComponents(this.divExctvDetail, this.bdmOffReadOnly);
				
				//비영리법인구분
				this.fnNoprfCorpSc(noprfCorpScCd);
			})
		} else {
			this.dsSearch.setColumn(0, "corpSbmsnNo", corpSbmsnNo);
			this.smfSearchService("selectTmprCvlcpt")
			.run()
			.callback(function(callbackParams){
			
				//신청자정보
				this.dsMain.setColumn(0, "newYn" , "N");
				this.dsMain.setColumn(0, "claiFlnm", this.dsApsInfo.getColumn(0, "claiFlnm"));
				this.dsMain.setColumn(0, "claiBrdt", this.dsApsInfo.getColumn(0, "claiBrdt"));
				this.dsMain.setColumn(0, "claiAddr", this.dsApsInfo.getColumn(0, "claiAddr"));
				this.dsMain.setColumn(0, "claiDtlAddr", this.dsApsInfo.getColumn(0, "claiDtlAddr"));
				this.dsMain.setColumn(0, "claiTelno", this.dsApsInfo.getColumn(0, "claiTelno"));
				this.dsMain.setColumn(0, "claiMblTelno", this.dsApsInfo.getColumn(0, "claiMblTelno"));
				this.dsMain.setColumn(0, "claiEmlAddr", this.dsApsInfo.getColumn(0, "claiEmlAddr"));
				
				//비영리법인구분
				this.fnNoprfCorpSc(noprfCorpScCd);
				
				if(state == "1") {
					/*임시저장인경우*/
					
					//화면 컨트롤
					this.bdmBtnVisible(this, "1");
					this.btnCrtExctvNwdCeckList.set_visible(true);
					this.btnAddExctv.set_visible(true);
					this.svcfTravelComponents(this.divClaiInfo, this.bdmOffReadOnly);
					this.svcfTravelComponents(this.divExctvDetail, this.bdmOffReadOnly);
					
				} else if(state == "2" && !this.smfIsNull(spmSn) && this.smfIsNull(sbmsnYmd)){
					/*보완요청이왔는경우*/
					var tmprStrgYn = this.dsMain.getColumn(0,"tmprStrgYn")
					if(tmprStrgYn == "N"){
						this.bdmAlert("PA008", []); // 보완요청된 상태입니다. 보완을 진행해주세요.
					}
					
					//화면 컨트롤
					this.bdmBtnVisible(this, "3");
					this.btnCrtExctvNwdCeckList.set_visible(true);
					this.btnAddExctv.set_visible(true);
					this.svcfTravelComponents(this.divClaiInfo, this.bdmOffReadOnly);
					this.svcfTravelComponents(this.divExctvDetail, this.bdmOffReadOnly);
					this.btnTmprSave.set_visible(true);
					
				}else if(state == "3"){
					//해결 반려 취하 등 
					
					//화면컨트롤
					this.bdmBtnVisible(this, "4");
					this.btnCrtExctvNwdCeckList.set_visible(false);
					this.btnAddExctv.set_visible(false);
					this.svcfTravelComponents(this.divClaiInfo, this.bdmOnReadOnly);
					this.svcfTravelComponents(this.divExctvDetail, this.bdmOnReadOnly);
					this.btnDelExctv.set_visible(false)
				}else{
					//제출된
					this.bdmAlert("PA009", []); // 제출된 민원을 불러왔습니다.

					//화면컨트롤
					this.bdmBtnVisible(this, "2");
					this.btnCrtExctvNwdCeckList.set_visible(false);
					this.btnAddExctv.set_visible(false);
					this.svcfTravelComponents(this.divClaiInfo, this.bdmOnReadOnly);
					this.svcfTravelComponents(this.divExctvDetail, this.bdmOnReadOnly);
					this.btnDelExctv.set_visible(false)
				}
				
				// [첨부파일]첨부파일조회. fileRefrnId있을때만 fileRefrnId 불러온뒤 호출
				var sFileRefrnId = this.dsApsInfo.getColumn(0, "fileRefrnId");
				this.bdmFileSelect(this, sFileRefrnId, this.divFileUpload1, this.dsOutFileinfo1, null, null, null, false);
			})
		}
	})
}
    
/**
 * @description 임원취임승인신청 임시저장 Transaction
 */
this.fnTmprSaveCvlcpt = function() 
{
	// [첨부파일]전체업로드된 파일 중 중복된게 있는지 체크(임원취임승인신청)	
	if(this.checkFileNmDupl()) return false;
	
	this.dsMain.setColumn(0, "tmprStrgYn", "Y");
	
	// 첨부파일 필수체크
	var noprfCorpScCd = this.dsCorpInfo.getColumn(0, "noprfCorpScCd"); // 비영리법인구분코드
	var nRow = this.dsExctvList.rowposition;
	var cnptYn = this.dsExctvList.getColumn(nRow, "cnptYn"); // 겸직여부
	var spyRelCd = this.dsExctvList.getColumn(nRow, "spyRelCd"); // 특수관계 00:해당없음
	var noprfHffcScCd = this.dsExctvList.getColumn(nRow, "noprfHffcScCd"); //재직구분코드
	var exctvRrno = this.dsExctvList.getColumn(nRow, "exctvRrno"); //주민등록번호
	var terBgngYmd = this.dsExctvList.getColumn(nRow, "terBgngYmd"); //임기시작일자
	var terEndYmd = this.dsExctvList.getColumn(nRow, "terEndYmd") // 임기종료일자
	var cbxAprv = this.divExctvDetail.form.cbxAprv.value;	  // 승인일로부터시작
	
	if(terEndYmd < terBgngYmd && cbxAprv == false){
		this.bdmAlert("PA050", []); //PA050 : 임기시작, 종료일을 확인해주세요.
		return false;
	}
	
	// 재직구분 신임, 연임일때 첨부파일 필수체크
	if(noprfHffcScCd == "1" || noprfHffcScCd == "2"){

		// 재직구분 신임일때 이력서 필수
		if (noprfHffcScCd == "1") {
			if(this.smfIsNull(this.divExctvDetail.form.divUpload00._FileGbnValue)) {
			   this.bdmAlert("PA012", []); // 필수 첨부파일을 확인해주세요.
			   return false;
			}
		}
		
		if (noprfCorpScCd == "1") { // 공익
			if(this.smfIsNull(this.divExctvDetail.form.divUpload04._FileGbnValue) ||
			   this.smfIsNull(this.divExctvDetail.form.divUpload05._FileGbnValue)) {
			   this.bdmAlert("PA012", []); // 필수 첨부파일을 확인해주세요.
			   return false;
			}
			
			// 특수관계 부존재divUpload01
			if (spyRelCd == "00" && this.smfIsNull(this.divExctvDetail.form.divUpload01._FileGbnValue)) {
				this.bdmAlert("PA012", []); // 필수 첨부파일을 확인해주세요.
			   return false;
			}
			
			// 특수관계 존재divUpload02
			if (spyRelCd != "00" && this.smfIsNull(this.divExctvDetail.form.divUpload02._FileGbnValue)) {
				this.bdmAlert("PA012", []); // 필수 첨부파일을 확인해주세요.
			   return false;
			}
			
			// 겸직여부 divUpload03
			if (cnptYn == "Y" && this.smfIsNull(this.divExctvDetail.form.divUpload03._FileGbnValue)) {
				this.bdmAlert("PA012", []); // 필수 첨부파일을 확인해주세요.
			   return false;
			}
		} else { // 비공익
			if(this.smfIsNull(this.divExctvDetail.form.divUpload04._FileGbnValue) ||
			   this.smfIsNull(this.divExctvDetail.form.divUpload05._FileGbnValue)) {
			   this.bdmAlert("PA012", []); // 필수 첨부파일을 확인해주세요.
			   return false;
			}
		}
	}
	// 필수체크
	if(!this.validateCheckTmp()) return false;
	//주민번호 체크
	if(!this.smfIsNull(exctvRrno)){
		if(!this.smfIsNull(exctvRrno.trim())){
			if(!this.smfIsRsrNoOld(exctvRrno)) {
				this.bdmAlert("PA051", []); // 올바른 주민번호를 입력해주세요
				return false;
			}
		}else{
			this.dsExctvList.setColumn(nRow, "exctvBrdt", "");
		}
	}else{
		this.dsExctvList.setColumn(nRow, "exctvBrdt", "");
	}
	
 	this.smfConfirm("PA046", function(result){ // 저장하시겠습니까?
		
		
		if(this.smfIsNull(terEndYmd) && cbxAprv == true){
			this.dsExctvList.setColumn(nRow, "terEndYmd", "        ")
		}
		
 		if(result.confirmResult){
			// [첨부파일]멀티업로드
			this.divFileUpload1.form.fnFileUpload();
 		}
 	});	
 	
}

/**
 * @description 임원취임승인신청 민원신청
 */
this.fnSaveCvlcpt = function() 
{
	this.dsMain.setColumn(0, "tmprStrgYn", "N");
	this.dsMain.setColumn(0, "aplyDt", new nexacro.Date());

	var tmprStrgYn = this.dsMain.getColumn(0, "tmprStrgYn");
	// [첨부파일]멀티업로드
	this.divFileUpload1.form.fnFileUpload();
}

/**
 * @description 민원 취하
 */
this.fnSaveCvlcptWtdr = function ()
{
	this.dsMain.setColumn(0, "aplyDt", new nexacro.Date());
	
	this.smfConfirm("PA047", function(result){ // 취하하시겠습니까?
		this.smfSaveService("saveNoprfCvlcptWtdr")
		.showConfirm(false)
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.bdmAlert("PA011", []); // 취하가 완료되었습니다.
			
			var params = {};
			this.smfSetWorkPage("pa_bdm_cas_as::bdm_casas00_m00.xfdl", params);
		})
	})
};

/**
 * @description 보완 제출
 */
this.fnSpmSbmsn = function ()
{
	this.dsMain.setColumn(0, "tmprStrgYn", "N");
	this.dsMain.setColumn(0, "sbmsnYmd", this.smfToday());
	
	this.smfConfirm("PA048", function(result){ // 보완 제출 진행하시겠습니까?
		if(result.confirmResult){
			// [첨부파일]멀티업로드
			this.divFileUpload1.form.fnFileUpload();
		}
		
	});
};

/**
 * @description 첨부파일명 목록조회
 */
this.selectFileNm = function()
{
	this.dsFileNm.deleteAll(); // 일단 전부 삭제
	for (var i=0;i<this.dsExctvList.rowcount;i++) {
		addFileNm(this, this.dsExctvList.getColumn(i, "fileRefrnId"));
	}
	addFileNm(this, this.dsApsInfo.getColumn(0, "fileRefrnId"));
	
	this.smfSearchService("selectFileNmList")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
	});
	
	function addFileNm(_this, p_fileRefrnId) {
		if (!_this.smfIsNull(p_fileRefrnId)) {
			var index = _this.dsFileNm.rowcount;
			_this.dsFileNm.addRow();
			_this.dsFileNm.setColumn(index, "fileRefrnId", p_fileRefrnId);
		}
	}
}

/**
 * @description 첨부파일명 중복체크
 */
this.checkFileNmDupl = function()
{
	// 저장된 파일명
	var arrFileNm = [];
	for (var i=0;i<this.dsFileNm.rowcount;i++) {
		arrFileNm.push(this.dsFileNm.getColumn(i, "fileNm"));
	}
	
	// 1. 삭제할 파일 먼저 제거
	var divFileUpload_getFileInfo = this.divFileUpload.form.RaonkUpload.GetListInfo("json");
	var divFileUpload1_getFileInfo = this.divFileUpload1.form.RaonkUpload.GetListInfo("json");
	
	if (divFileUpload_getFileInfo.deleteFile != null) {
		var divFileUpload_deleteFileNm = divFileUpload_getFileInfo.deleteFile.originalName;
		for (var i=0;i<divFileUpload_deleteFileNm.length;i++) {
			var index = arrFileNm.indexOf(divFileUpload_deleteFileNm[i]);
			if (index > -1) {
				arrFileNm.splice(index, 1);
			}
		}
	}
	if (divFileUpload1_getFileInfo.deleteFile != null) {
		var divFileUpload1_deleteFileNm = divFileUpload1_getFileInfo.deleteFile.originalName;
		for (var i=0;i<divFileUpload1_deleteFileNm.length;i++) {
			var index = arrFileNm.indexOf(divFileUpload1_deleteFileNm[i]);
			if (index > -1) {
				arrFileNm.splice(index, 1);
			}
		}
	}
	
	// 2-1. 이 상황에서, 추가할것들이 이미 있는지 확인
	if (divFileUpload_getFileInfo.newFile != null) {
		var divFileUpload_newFileNm = divFileUpload_getFileInfo.newFile.originalName;
		for (var i=0;i<divFileUpload_newFileNm.length;i++) {
			var index = arrFileNm.indexOf(divFileUpload_newFileNm[i]);
			if (index > -1) {
				this.bdmAlert(divFileUpload_newFileNm[i] + "인 파일은 이미 있습니다.");
				return true; 
			}
		}
	}
	if (divFileUpload1_getFileInfo.newFile != null) {
		var divFileUpload1_newFileNm = divFileUpload1_getFileInfo.newFile.originalName;
		for (var i=0;i<divFileUpload1_newFileNm.length;i++) {
			var index = arrFileNm.indexOf(divFileUpload1_newFileNm[i]);
			if (index > -1) {
				this.bdmAlert(divFileUpload1_newFileNm[i] + "인 파일은 이미 있습니다.");
				return true;
			}
		}
	}
	
	// 2-2.추가한것들 끼리 중복이 되는지 확인
	if (divFileUpload_getFileInfo.newFile != null && divFileUpload1_getFileInfo.newFile != null) {
		var divFileUpload_newFileNm = divFileUpload_getFileInfo.newFile.originalName;
		var divFileUpload1_newFileNm = divFileUpload1_getFileInfo.newFile.originalName;
		for (var i=0;i<divFileUpload_newFileNm.length;i++) {
			var index = divFileUpload1_newFileNm.indexOf(divFileUpload_newFileNm[i]);
			if (index > -1) {
				this.bdmAlert(divFileUpload_newFileNm[i] + "인 파일은 이미 있습니다.");
				return true;
			}
		}
	}
	
	return false;
}
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
 */
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd == -1) return;
};

/**
 * @description 도로명주소찾기 콜백
 */
this.fnCommpopRdnZip = function(e, sender)
{
	if(sender == this.divClaiInfo.form.btnClaiRdnAddrSch){
		var nRow = this.dsMain.rowposition;
		this.dsMain.setColumn(nRow, "claiAddr", e.roadNmAddr);
		this.dsMain.setColumn(nRow, "claiDtlAddr", e.roadNmDtl);
	}else if(sender == this.divExctvDetail.form.btnExctvRdnAddrSch){
		var nRow = this.dsExctvList.rowposition;
		this.dsExctvList.setColumn(nRow, "dmclRoadNmAddr", e.roadNmAddr);
		this.dsExctvList.setColumn(nRow, "dmclRoadNmDtlAddr", e.roadNmDtl);
	}
};

/**
 * @description 특수관계찾기 콜백
 */
 this.fnSpyRelSchCallback = function(e, sender)
 {
	var idx = 0;
	var nRow = this.dsExctvList.rowposition;
	var oldValue1 = this.dsExctvList.getColumn(nRow, "spyRelCd");
	var oldValue2 = this.dsExctvList.getColumn(nRow, "spyRelNm");
 	for(x in e.row){
		if(e.row[x] == "true") {
			switch(idx) {
				case 0:
					this.dsExctvList.setColumn(nRow, "spyRelCd", "00");
					this.dsExctvList.setColumn(nRow, "spyRelNm", "해당없음");
					break;
				case 1:
					this.dsExctvList.setColumn(nRow, "spyRelCd", "01");
					this.dsExctvList.setColumn(nRow, "spyRelNm", "출연자");
					break;
				case 2:
					this.dsExctvList.setColumn(nRow, "spyRelCd", "02");
					this.dsExctvList.setColumn(nRow, "spyRelNm", "출연자 또는 이사의 친족");
					break;
				case 3:
					this.dsExctvList.setColumn(nRow, "spyRelCd", "03");
					this.dsExctvList.setColumn(nRow, "spyRelNm", "사용인");
					break;
				case 4:
					this.dsExctvList.setColumn(nRow, "spyRelCd", "04");
					this.dsExctvList.setColumn(nRow, "spyRelNm", "생계의존");
					break;
				case 5:
					this.dsExctvList.setColumn(nRow, "spyRelCd", "05");
					this.dsExctvList.setColumn(nRow, "spyRelNm", "기타");
					break;
				default:
			}
			break;
		}
		idx++;
 	}
	
	var newValue1 = this.dsExctvList.getColumn(nRow, "spyRelCd");
	var newValue2 = this.dsExctvList.getColumn(nRow, "spyRelNm");
	
	if (oldValue1 == "00" && newValue1 != "00") {
		// 현재 올라가있는 파일명
		var fileName = this.divExctvDetail.form.divUpload01.form.edtFile.value;
		if (!this.smfIsNull(fileName)) {
			this.divExctvDetail.form.btnDelete01.click(); // 삭제버튼 클릭
			
			// 예를 눌러서 삭제가 됐다면 onitemchanged, 취소 눌러서 삭제안했으면 YN 안바뀌게
			if (fileName == this.divExctvDetail.form.divUpload01.form.edtFile.value) {
				this.dsExctvList.setColumn(nRow, "spyRelCd", oldValue1);
				this.dsExctvList.setColumn(nRow, "spyRelNm", oldValue2);
				return false;
			}
		}
	} else if (oldValue1 != "00" && newValue1 == "00") {
		// 현재 올라가있는 파일명
		var fileName = this.divExctvDetail.form.divUpload02.form.edtFile.value;
		if (!this.smfIsNull(fileName)) {
			this.divExctvDetail.form.btnDelete02.click(); // 삭제버튼 클릭
			
			// 예를 눌러서 삭제가 됐다면 onitemchanged, 취소 눌러서 삭제안했으면 YN 안바뀌게
			if (fileName == this.divExctvDetail.form.divUpload02.form.edtFile.value) {
				this.dsExctvList.setColumn(nRow, "spyRelCd", oldValue1);
				this.dsExctvList.setColumn(nRow, "spyRelNm", oldValue2);
				return false;
			}
		}
	}
	
	// [첨부파일]첨부파일 필수표시 변경
	this.changeFileRequire();
 }
   
