/**
 * @description 임원 그리드 oncellposchanged
 */
this.grdExctvList_oncellposchanged = function(obj:nexacro.Grid,e:nexacro.GridSelectEventInfo)
{
	var nRow = this.dsExctvList.rowposition;
	var state = this.dsMain.getColumn(0, "state");
	var spmSn = this.dsMain.getColumn(0, "spmSn");
	var sbmsnYmd = this.dsMain.getColumn(0, "sbmsnYmd");
	var chkState = false;
	if(state == undefined || state == "1" || (state == "2" && !this.smfIsNull(spmSn) && this.smfIsNull(sbmsnYmd))){
		chkState = true;
	}
	
	if(this.divExctvDetail.form.rdoComtrYn.value == "Y") {
		this.smfInsertRuleToComponent("required", this.divExctvDetail.form.edtComtrNmNoRd);
		this.smfInsertRuleToComponent("required", this.divExctvDetail.form.Static10_00_01_00_00_00);
		this.divExctvDetail.form.edtComtrNmNoRd.set_readonly(false);
	} else {
		this.smfRemoveRuleFromComponent("required", this.divExctvDetail.form.edtComtrNmNoRd);
		this.smfRemoveRuleFromComponent("required", this.divExctvDetail.form.Static10_00_01_00_00_00);
		this.divExctvDetail.form.edtComtrNmNoRd.set_readonly(true);
	}
	
	//임원임기기간 관련 시작
	var exctvTerPrdCd = this.dsExctvList.getColumn(nRow, "noprfExctvTerPrdCd");
	var terBgngYmd = this.dsExctvList.getColumn(nRow, "terBgngYmd");
	if(chkState == true){	
		if(exctvTerPrdCd == 5) {
			this.divExctvDetail.form.calExctvTerEndYmdNoRd.set_readonly(false);
		} else {
			this.divExctvDetail.form.calExctvTerEndYmdNoRd.set_readonly(true);
		}
	}
	
	this.smfInsertRuleToComponent("required", this.divExctvDetail.form.Static10_00_00_00);
	this.smfInsertRuleToComponent("required", this.divExctvDetail.form.calExctvTerBgngYmd);
	this.smfInsertRuleToComponent("required", this.divExctvDetail.form.Static10_01_01);
	this.smfInsertRuleToComponent("required", this.divExctvDetail.form.calExctvTerEndYmdNoRd);
	this.divExctvDetail.form.cbxAprv.set_value(false);
	//(chkState == true) ? this.divExctvDetail.form.calExctvTerBgngYmd.set_readonly(false) : this.divExctvDetail.form.calExctvTerBgngYmd.set_readonly(true);
	
	if(! this.smfIsUpdateRow(this.dsExctvList, nRow)){
		if(this.smfIsNull(terBgngYmd)){
			this.divExctvDetail.form.cbxAprv.set_value(true)
			this.divExctvDetail.form.calExctvTerBgngYmd.set_readonly(true);
			this.smfRemoveRuleFromComponent("required", this.divExctvDetail.form.Static10_00_00_00);
			this.smfRemoveRuleFromComponent("required", this.divExctvDetail.form.calExctvTerBgngYmd);
			this.smfRemoveRuleFromComponent("required", this.divExctvDetail.form.Static10_01_01);
			this.smfRemoveRuleFromComponent("required", this.divExctvDetail.form.calExctvTerEndYmdNoRd);
		}
	}
	//임원임기기간 관련 종료 
	
	// [첨부파일] 초기화 ds데이터 있을때만 fileReload
	//this.fnFileReload();
	if (this.dsExctvList.rowcount > 0) {
		this.bdmFileReLoad(this.divFileUpload, this.divExctvDetail, this.atchFileCount, true);
	}
	
	// [첨부파일]첨부파일 필수표시 변경
	this.changeFileRequire();
	
	var fileRefrnId = this.dsExctvList.getColumn(nRow, "fileRefrnId");
	
	// 일단 모두 삭제
	this.dsCorpFileRefrnList.deleteAll();
	this.dsCorpFileRefrnList.addRow();
	this.dsCorpFileRefrnList.setColumn(0, "fileRefrnId", fileRefrnId);
	
	this.smfSearchService("selectCorpFileRefrnList")
		.showConfirm(false)
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			// [첨부파일]첨부파일조회. fileRefrnId있을때만 fileRefrnId 불러온뒤 호출
			var sFileRefrnId =this.dsExctvList.getColumn(nRow, "fileRefrnId");
			this.bdmFileSelect(this, sFileRefrnId, this.divFileUpload, this.dsOutFileinfo, this.dsCorpFileRefrnList, this.divExctvDetail, this.atchFileCount, true);
	});
	
	// [첨부파일] 첨부파일명 전체 목록 조회
	this.selectFileNm();
};

/**
 * @description 재직구분 변경 
 */
this.divExctvDetail_cboNoprfHffcScCd_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	var nRow = this.dsExctvList.rowposition;
	var noprfHffcScCd = this.dsExctvList.getColumn(nRow, "noprfHffcScCd");
	
	if(noprfHffcScCd != 1 && noprfHffcScCd != 2){
		this.divExctvDetail.form.cbxAprv.set_value(false)
		this.divExctvDetail_cbxAprv_onchanged()
    }
	
	if(noprfHffcScCd == 3 || noprfHffcScCd == 6){
		//해임, 사임
		this.divExctvDetail.form.cboExctvTerPrdCd.set_value("5");
		this.divExctvDetail.form.calExctvTerEndYmdNoRd.set_readonly(false);
		this.divExctvDetail.form.calExctvTerEndYmdNoRd.set_value('');
	}
	
	this.changeFileRequire();
};

/**
 * @description 승인일로부터 시작 선택 canchange
 */
this.divExctvDetail_cbxAprv_canchange = function(obj:nexacro.CheckBox,e:nexacro.ChangeEventInfo)
{
	var nRow = this.dsExctvList.rowposition;
	var noprfExctvScCd = this.dsExctvList.getColumn(nRow, "noprfExctvScCd");
	var noprfHffcScCd = this.dsExctvList.getColumn(nRow, "noprfHffcScCd");
	
	if(noprfExctvScCd == undefined){
		this.bdmAlert("PA052", []);//임원구분을 먼저 선택해주십시오.
		return false;
	}
	
	if(noprfHffcScCd != 1 && noprfHffcScCd != 2){
		this.bdmAlert("PA053", []);//재직구분이 신임, 연임인 경우에만 가능합니다.
		return false;
    }
	
};

/**
 * @description 승인일로부터 시작 선택 onchange
 */
this.divExctvDetail_cbxAprv_onchanged = function(obj:nexacro.CheckBox,e:nexacro.CheckBoxChangedEventInfo)
{
	var cbxAprv = this.divExctvDetail.form.cbxAprv.value;
	var nRow = this.dsExctvList.rowposition;
	
	this.smfRemoveRuleFromComponent("required", this.divExctvDetail.form.Static10_00_00_00);
	this.smfRemoveRuleFromComponent("required", this.divExctvDetail.form.calExctvTerBgngYmd);
	this.smfRemoveRuleFromComponent("required", this.divExctvDetail.form.Static10_01_01);
	this.smfRemoveRuleFromComponent("required", this.divExctvDetail.form.calExctvTerEndYmdNoRd);
	
    if(cbxAprv == true){
		//승인일로부터 true
		this.divExctvDetail.form.calExctvTerBgngYmd.set_readonly(true);
		this.divExctvDetail.form.calExctvTerEndYmdNoRd.set_readonly(true);
		
		this.dsExctvList.setColumn(nRow, "terBgngYmd", "");
		this.dsExctvList.setColumn(nRow, "terEndYmd", "");
		
		if(this.dsExctvList.getColumn(nRow, "noprfExctvTerPrdCd") == "5"){
			this.dsExctvList.setColumn(nRow, "noprfExctvTerPrdCd", undefined);
		}
	}else{
		//승인일로부터 false
		this.smfInsertRuleToComponent("required", this.divExctvDetail.form.Static10_00_00_00);
		this.smfInsertRuleToComponent("required", this.divExctvDetail.form.calExctvTerBgngYmd);
		this.smfInsertRuleToComponent("required", this.divExctvDetail.form.Static10_01_01);
		this.smfInsertRuleToComponent("required", this.divExctvDetail.form.calExctvTerEndYmdNoRd);
		
		this.divExctvDetail.form.calExctvTerBgngYmd.set_readonly(false);
	}
};

/**
 * @description DataSet 값 변경시
 */
this.dsExctvList_oncolumnchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	var columnId = e.columnid;
	
	var exctvTerPrdCd = this.dsExctvList.getColumn(e.row, "noprfExctvTerPrdCd");
	var cbxAprv = this.divExctvDetail.form.cbxAprv.value;
	var chaiYn = this.dsExctvList.getColumn(e.row, "chaiYn");
	var noprfExctvScCd = this.dsExctvList.getColumn(e.row, "noprfExctvScCd");
		
	if(columnId == "noprfExctvTerPrdCd"){
		//임원임기 코드	
		if(exctvTerPrdCd == 5 && cbxAprv == true){
			//PA054 : 임기시작일이 승인일로부터인경우 기타를 선택할수없습니다.
			this.bdmAlert("PA054", [], function (){//
				this.dsExctvList.setColumn(e.row, "noprfExctvTerPrdCd", undefined);
			});
		}
		if(exctvTerPrdCd == 5) {
			this.divExctvDetail.form.calExctvTerEndYmdNoRd.set_readonly(false);
		} else {
			this.divExctvDetail.form.calExctvTerEndYmdNoRd.set_readonly(true);
			this.fnSetTerEndYmd();
		}
		
	}else if(columnId == "chaiYn" || columnId == "noprfExctvScCd"){
		//이사장 여부, 임원구분
		if(noprfExctvScCd != "01" && chaiYn == "Y"){
			//임원구분이 이사인 경우만 이사장여부를 선택 가능 합니다.
			this.bdmAlert("PA075", [], function (){
				this.dsExctvList.setColumn(e.row, "chaiYn", "N");
			});
		}
	}
};
]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
