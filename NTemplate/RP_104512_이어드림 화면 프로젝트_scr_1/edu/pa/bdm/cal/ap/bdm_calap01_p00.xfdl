    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    대국민 비영리법인 민원신청 임원취임승인신청 특수관계조회
*  @FileName 	bdm_calap01_p00.xfdl
*  @Creator 	서광명
*  @CreateDate 	2022.6.14
*  @Desction    
*
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.6.14     	서광명 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitPopup(obj);
	
	this.pv_params = this.smfGetPopupParams();
	
	var objDs = this.ds01;
	var sColId = objDs.getColID(this.pv_params.spyRelCd);
	
	objDs.setColumn("0",sColId,true);
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/


/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnChoice = function()
{
	this.smfSendResponseToOpener({
		"row": this.smfRowToObject(this.ds01)
	});
	
	this.close(true);
}


/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 그리드 체크박스 클릭시
 */
this.grd00_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if(e.col==0)
	{
		var sSelColId = obj.getCellProperty("body",e.cell,"text");
		sSelColId = nexacro.replaceAll(sSelColId,"bind:","");
		var objBindDs = obj.getBindDataset();
		for(var i=0;i<objBindDs.colcount;i++)
		{
			var sColId = objBindDs.getColID(i);
			if(sColId==sSelColId)
			{
				objBindDs.setColumn(e.row,sColId,true);
			}
			else
			{
				objBindDs.setColumn(e.row,sColId,false);
			}
		}
	}
	
};

/**
 * @description 저장버튼 클릭시
*/
this.btnSelect_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnChoice();
};

/**
 * @description 닫기버튼 클릭시
*/
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};
]]></Script>
  </Form>
</FDL>
