              </Rows>
              <Band id="body">
                <Cell rowspan="4" wordWrap="char" background="#eef0f5" border="1px solid #dddfe3,0px solid #f6f7f8,1px solid #dddfe3,1px solid #f6f7f8" displaytype="checkboxcontrol" edittype="checkbox" aa="0" text="bind:Column1"/>
                <Cell col="1" rowspan="4" text="출연자" textAlign="center" wordWrap="char" background="#eef0f5" aa="0"/>
                <Cell col="2" colspan="2" text="출연자가 자연인" wordWrap="char"/>
                <Cell col="4" text="출연자" wordWrap="char"/>
                <Cell row="1" col="2" colspan="2" text="출연자가 민법 제32조의 법인" wordWrap="char"/>
                <Cell row="1" col="4" text="당해 법인에 대한 출연자를 포함" wordWrap="char"/>
                <Cell row="2" col="2" colspan="2" text="출연자가 기타의 법인" wordWrap="char"/>
                <Cell row="2" col="4" wordWrap="char"/>
                <Cell row="3" col="2" colspan="3" text="* 이하에서 출연자는 위의 모든자를 포함함&#13;&#10;* 다만, 재산출연일 현재 해당 공익법인의 총출연재산가액의 100분의 1에 해당하는 금액과 2천만원 중 적은 금액을 출연하는 자는 제외" wordWrap="char"/>
                <Cell row="4" rowspan="4" wordWrap="char" background="#eef0f5" border="1px solid #dddfe3,0px solid #f6f7f8,1px solid #dddfe3,1px solid #f6f7f8" displaytype="checkboxcontrol" edittype="checkbox" _radiovalue="1" text="bind:Column2"/>
                <Cell row="4" col="1" rowspan="4" text="출연자 &#13;&#10;또는 &#13;&#10;이사의 &#13;&#10;친족" textAlign="center" wordWrap="char" background="#eef0f5"/>
                <Cell row="4" col="2" rowspan="4" wordWrap="char" text="부계" textAlign="center"/>
                <Cell row="4" col="3" wordWrap="char" text="6촌이내의 혈족"/>
                <Cell row="4" col="4" rowspan="4" text="출연자 또는 이사가 추가녀인 경우에는 남편과의 관계에 의함" wordWrap="char"/>
                <Cell row="5" col="3" wordWrap="char" text="4촌이내의 인척"/>
                <Cell row="6" col="3" wordWrap="char" text="배우자(사실혼 관계 포함)"/>
                <Cell row="7" col="3" wordWrap="char" text="친생자(친생자)로서 다른사람에게 친양자(친양자)로 입양된 사람과 그 배우자/직계비속(직계비속)"/>
                <Cell row="8" rowspan="2" wordWrap="char" background="#eef0f5" border="1px solid #dddfe3,0px solid #f6f7f8,1px solid #dddfe3,1px solid #f6f7f8" edittype="checkbox" displaytype="checkboxcontrol" text="bind:Column3"/>
                <Cell row="8" col="1" rowspan="2" wordWrap="char" textAlign="center" text="사용인" background="#eef0f5"/>
                <Cell row="8" col="2" colspan="3" wordWrap="char" text="출연자 또는 이사의 사용인 기타 고용 관계자"/>
                <Cell row="9" col="2" colspan="3" wordWrap="char" text="출연자 또는 이사가 출자에 의하여 사실상 지배하고 있는 법인의 사용인 기타 고용관계자"/>
                <Cell row="10" rowspan="2" wordWrap="char" background="#eef0f5" border="1px solid #dddfe3,0px solid #f6f7f8,1px solid #dddfe3,1px solid #f6f7f8" edittype="checkbox" displaytype="checkboxcontrol" text="bind:Column4"/>
                <Cell row="10" col="1" rowspan="2" wordWrap="char" textAlign="center" text="생계의존" background="#eef0f5"/>
                <Cell row="10" col="2" colspan="3" wordWrap="char" text="출연자 또는 이사의 금전 기타의 재산에 의하여 생계를 유지하는자"/>
                <Cell row="11" col="2" colspan="3" wordWrap="char" text="출연자 또는 이사가 생계를 함께 하는 자"/>
                <Cell row="12" wordWrap="char" background="#eef0f5" border="1px solid #dddfe3,0px solid #f6f7f8,1px solid #dddfe3,1px solid #f6f7f8" edittype="checkbox" displaytype="checkboxcontrol" text="bind:Column5"/>
                <Cell row="12" col="1" wordWrap="char" textAlign="center" text="기타" background="#eef0f5"/>
                <Cell row="12" col="2" colspan="3" wordWrap="char" text="출연자가 재산을 출연한 다른 공익사업을 영위하는 법인의 이사"/>
                <Cell row="13" rowspan="2" wordWrap="char" background="#eef0f5" border="1px solid #dddfe3,0px solid #f6f7f8,1px solid #dddfe3,1px solid #f6f7f8" edittype="checkbox" displaytype="checkboxcontrol" text="bind:Column0"/>
                <Cell row="13" col="1" rowspan="2" wordWrap="char" text="해당&#13;&#10;없음" textAlign="center" background="#eef0f5"/>
                <Cell row="13" col="2" rowspan="2" colspan="3" wordWrap="char" text="해당없음"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="btnClose" taborder="3" text="닫기" height="30" left="366" initvalueid="ivBtnAccessibilityButton" cssclass="btn_WF_Custom" top="553" onclick="btnClose_onclick" width="50"/>
        <Button id="btnSelect" taborder="4" text="저장" height="30" initvalueid="ivBtnAccessibilityButton" left="btnClose:8" top="553" onclick="btnSelect_onclick" width="50"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_01" taborder="5" left="20" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_01_00_00_00" taborder="6" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" initvalueid="ivStcAccessibilityOff"/>
