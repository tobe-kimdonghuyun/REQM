  <Form id="bdm_calap01_p00" width="840" height="603" titletext="특수관계선택" onload="form_onload">
    <Layouts>
      <Layout height="603" width="840" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <ImageViewer id="img00_00_01_00_00" taborder="1" text="특수관계자의 범위(공익령 제12조)" left="20" top="20" width="280" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
        <Grid id="grd00" taborder="2" left="20" top="60" height="473" binddataset="ds01" selecttype="cell" autofittype="col" oncellclick="grd00_oncellclick" right="20" initvalueid="ivGrdAccessibilityOn" scrollbartype="none none">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="41"/>
                <Column size="81"/>
                <Column size="66"/>
                <Column size="241"/>
                <Column size="367"/>
              </Columns>
              <Rows>
