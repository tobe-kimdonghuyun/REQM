<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="bdm_calap01_p01" width="400" height="489" titletext="국가조회" onload="bdm_calap01_p01_onload">
    <Layouts>
      <Layout height="489" width="400" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <ImageViewer id="img00_00_01_00_00" taborder="1" text="국가조회" left="20" top="20" width="80" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
        <Div id="divSearch" taborder="2" left="20" top="60" height="70" cssclass="div_WF_Search" text="" right="20" initvalueid="ivDivAccessibilityOn" accessibilitylabel="조회영역">
          <Layouts>
            <Layout>
              <Static id="staCoaAyr" taborder="0" text="국가명" left="0" top="20" height="30" cssclass="sta_WF_Searchtxt01" width="68" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtSearchKeyword" taborder="1" left="68" top="20" initvalueid="ivEdtNormal" onkeydown="edtSearchKeyword_onkeydown" height="30" right="112"/>
              <Button id="btnSearch" taborder="2" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="20" onclick="btnSearch_onclick" accessibilitylabel="조회" initvalueid="ivBtnAccessibilityButton"/>
            </Layout>
          </Layouts>
        </Div>
        <Grid id="grdList" taborder="3" left="20" top="140" height="279" binddataset="dsNtnList" right="20" autofittype="col" initvalueid="ivGrdAccessibilityOn" selecttype="cell">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="국가명"/>
              </Band>
              <Band id="body">
                <Cell text="bind:unyCdValueNm"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="btnClose" taborder="4" text="닫기" height="30" left="146" initvalueid="ivBtnAccessibilityButton" cssclass="btn_WF_Custom" top="439" onclick="btnClose_onclick" width="50"/>
        <Button id="btnSelect" taborder="5" text="확인" height="30" initvalueid="ivBtnAccessibilityButton" left="btnClose:8" top="439" onclick="btnSelect_onclick" width="50"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_01" taborder="6" left="20" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_00_00_00" taborder="7" left="20" top="50" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_00" taborder="8" left="20" top="divSearch:0" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_01_00" taborder="9" left="20" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff" top="grdList:0"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_01_00_00" taborder="10" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" bottom="0" left="20" height="20" right="20"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_01_00_00_00" taborder="11" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_01_00_00_00_00" taborder="12" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  컨설팅 표준화 작업
*  @MenuPath    샘플 > popup
*  @FileName 	samplePopup.xfdl 
*  @Creator 	consulting
*  @CreateDate 	2022.01.04
*  @Desction    popup 샘플
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.01.04     	consulting 	                최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.bdm_calap01_p01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitPopup(obj);
	
	this.divSearch.form.btnSearch.click();
	
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 국가조회
 */
this.fnSearch = function(obj, e)
{
	this.dsSearch.setColumn(0,"searchKeyword" , this.divSearch.form.edtSearchKeyword.value);
	
	this.smfSearchService("listNtnInq")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.erroes) return;
	})
}

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback  = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnChoice = function()
{
	this.smfSendResponseToOpener({
		"row": this.smfRowToObject(this.dsNtnList)
	});
	
	this.close(true);
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearch(obj, e);
};


this.edtSearchKeyword_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode == "13"){
		this.divSearch.form.btnSearch.click();
	}
};

this.btnSelect_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnChoice();
};

this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};





]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listNtnInq</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsNtnList</Col>
            <Col id="url">/bdm_cal_ap01_005.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="false">
        <ColumnInfo>
          <Column id="clfCdValue" type="STRING" size="256" description="공통코드값"/>
          <Column id="searchKeyword" type="STRING" size="256" description="키워드"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="clfCdValue">NTN_CD</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsNtnList" useclientlayout="true">
        <ColumnInfo>
          <Column id="_chk" type="STRING" size="1"/>
          <Column id="clfCdValue" type="STRING" size="50" description="분류코드값"/>
          <Column id="unyCdValue" type="STRING" size="30" description="통합코드값"/>
          <Column id="unyCdValueNm" type="STRING" size="200" description="통합코드값명"/>
          <Column id="unyCdValueEngNm" type="STRING" size="150" description="통합코드값영문명"/>
          <Column id="unyCdValueAbrvNm" type="STRING" size="300" description="통합코드값약어명"/>
          <Column id="unyCdValueSn" type="STRING" size="20" description="통합코드값일련번호"/>
          <Column id="unyCdEtcCn" type="STRING" size="500" description="통합코드기타내용"/>
          <Column id="unyCdUseYn" type="STRING" size="1" description="통합코드사용여부"/>
          <Column id="unyCdScCd" type="STRING" size="1" description="통합코드구분코드"/>
          <Column id="upClfCdValue" type="STRING" size="50" description="상위분류코드값"/>
          <Column id="upUnyCdValue" type="STRING" size="30" description="상위통합코드값"/>
          <Column id="bfrUnyCdValue" type="STRING" size="30" description="이전통합코드값"/>
          <Column id="bfrUnyCdValueNm" type="STRING" size="200" description="이전통합코드값명"/>
          <Column id="clfCdSn" type="STRING" size="20" description="분류코드일련번호"/>
          <Column id="unyCdSn" type="STRING" size="20" description="통합코드일련번호"/>
          <Column id="gtrnsId" type="STRING" size="64" description="전역트랜잭션ID"/>
          <Column id="rgtrNm" type="STRING" size="100" description="등록자명"/>
          <Column id="rgtrDptNm" type="STRING" size="90" description="등록자부서명"/>
          <Column id="mdfrNm" type="STRING" size="100" description="수정자명"/>
          <Column id="mdfrDptNm" type="STRING" size="90" description="수정자부서명"/>
          <Column id="rgtrId" type="STRING" size="30" description="등록자ID"/>
          <Column id="regDt" type="STRING" size="26" description="등록일시"/>
          <Column id="mdfrId" type="STRING" size="30" description="수정자ID"/>
          <Column id="mdfcnDt" type="STRING" size="26" description="수정일시"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.edtSearchKeyword" propid="value" datasetid="dsSearch" columnid="searchKeyword"/>
    </Bind>
  </Form>
</FDL>
