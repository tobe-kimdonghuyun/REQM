                  <Grid id="grdExctvList" taborder="1" left="0" top="60" height="236" autofittype="col" right="0" initvalueid="ivGrdAccessibilityOn" binddataset="dsExctvList" onselectchanged="grdExctvList_oncellclick" selecttype="cell">
                    <Formats>
                      <Format id="default">
                        <Columns>
                          <Column size="40"/>
                          <Column size="80"/>
                          <Column size="80"/>
                          <Column size="80"/>
                          <Column size="80"/>
                          <Column size="80"/>
                          <Column size="80"/>
