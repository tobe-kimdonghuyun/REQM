      <BindItem id="item66" compid="tab00.Tabpage5.form.divPtyDetail03.form.msk00" propid="value" datasetid="dsPtyList" columnid="qtySfar"/>
      <BindItem id="item39" compid="tab00.Tabpage5.form.divPtyDetail03.form.msk01" propid="value" datasetid="dsPtyList" columnid="ptyAmt"/>
      <BindItem id="item41" compid="tab00.Tabpage5.form.divPtyDetail02.form.msk00" propid="value" datasetid="dsPtyList" columnid="ptyAmt"/>
      <BindItem id="item79" compid="tab00.Tabpage2.form.edtSpyRelNm" propid="value" datasetid="dsExctvList" columnid="spyRelNm"/>
      <BindItem id="item80" compid="tab00.Tabpage2.form.rdoCnptYn00" propid="value" datasetid="dsExctvList" columnid="comtrYn"/>
      <BindItem id="item19" compid="tab00.Tabpage2.form.edt00_00_00_00" propid="value" datasetid="dsExctvList" columnid="wkpcNm"/>
      <BindItem id="item81" compid="tab00.Tabpage1.form.cboExctvTerPrdCd" propid="value" datasetid="dsCorpInfo" columnid="noprfMbdTerPrdCd"/>
      <BindItem id="item82" compid="tab00.Tabpage1.form.cboExctvTerPrdCd00" propid="value" datasetid="dsCorpInfo" columnid="noprfAdtTerPrdCd"/>
    </Bind>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    대국민 비영리법인 법인정보조회
*  @FileName 	bdm_ciici00_m00.xfdl 
*  @Creator 	서광명
*  @CreateDate 	2022.9.01
*  @Desction    비영리법인 법인정보조회
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.09.01           서광명                 최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::bdm_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.cddcCd = this.bdmGetUserInfo("cddcCd");
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{	
	//로그인 확인
	this.bdmfChkLogin();
	
	// 폼을 초기화
	this.smfInitForm(obj);
		
	// 세션에서 시도코드 받아서 검색 파라미터 세팅
	this.dsSearch.setColumn(0,"cddcCd", this.cddcCd);
	// 세션에서 시도교육청, 법인코드 받아서 검색 파라미터에 값 세팅
	
	// 법인 일반사항조회
	this.fnSelectCorpInfo();
	
	this.smfResetScroll(this.tab00.Tabpage1.form);
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 법인 일반사항조회
 */
this.fnSelectCorpInfo = function()
{
	this.smfSearchService("selectCorpInfo")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		// 법인 주소 + 상세주소
		this.tab00.Tabpage1.form.edtCorpAddr.set_value(this.dsCorpInfo.getColumn(0,"corpAddr") + " " + this.dsCorpInfo.getColumn(0,"corpDtlAddr"));
		// 설립자 주소 + 상세주소
		this.tab00.Tabpage1.form.edtFunrAddr.set_value(this.dsCorpInfo.getColumn(0,"funrAddr") + " " + this.dsCorpInfo.getColumn(0,"funrDtlAddr"));
		// 대표자 주소 + 상세주소
		this.tab00.Tabpage1.form.edtRveAddr.set_value(this.dsCorpInfo.getColumn(0,"rveAddr") + " " + this.dsCorpInfo.getColumn(0,"rveDtlAddr"));
		// 대리인 주소 + 상세주소
		this.tab00.Tabpage1.form.edtPrgeAddr.set_value(this.dsCorpInfo.getColumn(0,"prgeAddr") + " " + this.dsCorpInfo.getColumn(0,"prgeDaddr"));
		
		var noprfCorpScCd = this.dsCorpInfo.getColumn(0, "noprfCorpScCd")
		if(noprfCorpScCd == "2"){
			this.tab00.Tabpage2.form.Static45_00_00.set_text("회장여부")
		}
	})
}

/**
 * @description 법인 임원조회
 */
this.fnSelectExctvList = function()
{
	this.smfSearchService("selectExctvList")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		this.fnExctvAddr()
	})
}

/**
 * @description 법인 정관조회
 */
this.fnSelectArofaInfo = function()
{
	this.smfSearchService("selectArofaInfo")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
	})
}

/**
 * @description 법인 수익사업
 */
this.fnSelectErnBizList = function()
{
	this.smfSearchService("selectErnBizList")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
	})
}

/**
 * @description 법인 재산조회
 */
this.fnSelectPtyList = function()
{
	this.smfSearchService("selectPtyList")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		this.fnChgPtyDetaScCd();
		this.fnSelectPtyRevlList();
		this.fnSelectPtyDspsList();
	})
}

/**
 * @description 법인 재산 재평가목록 조회
 */
this.fnSelectPtyRevlList = function()
{
	var nRow = this.dsPtyList.rowposition;
	var ptySn = this.dsPtyList.getColumn(nRow,"ptySn")
	
	this.dsSearch.setColumn(0, "ptySn", ptySn);
	
	this.smfSearchService("selectPtyRevlList")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
	})
}

/**
 * @description 법인 처분재산조회
 */
this.fnSelectPtyDspsList = function()
{
	var nRow = this.dsPtyList.rowposition;
	var ptySn = this.dsPtyList.getColumn(nRow,"ptySn")
	
	this.dsSearch.setColumn(0, "ptySn", ptySn);
	
	this.smfSearchService("selectPtyDspsList")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
	})
}

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
 */
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd == -1) return;
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 재산세부구분에 따른 폼 변경
 */
this.fnChgPtyDetaScCd = function() 
{
	var nRow = this.dsPtyList.rowposition;
	var ptyDetaScCd = this.dsPtyList.getColumn(nRow, "ptyDetaScCd");
	
	this.tab00.Tabpage5.form.divPtyDetail01.set_visible(false)
	this.tab00.Tabpage5.form.divPtyDetail02.set_visible(false);
	this.tab00.Tabpage5.form.divPtyDetail03.set_visible(false);

	if(ptyDetaScCd == "11") {
		this.tab00.Tabpage5.form.divPtyDetail01.set_visible(true);
		this.tab00.Tabpage5.form.divPtyDetail01.form.edtPtyLctnAddr01.set_value(this.dsPtyList.getColumn(nRow, "lctnAddr") + " " + this.dsPtyList.getColumn(nRow, "lctnDtlAddr"));
		
		this.tab00.Tabpage5.form.divPtyDetail02.set_visible(false);
		this.tab00.Tabpage5.form.divPtyDetail03.set_visible(false);
	} else if(ptyDetaScCd == "12") {
		this.tab00.Tabpage5.form.divPtyDetail01.set_visible(true);
		this.tab00.Tabpage5.form.divPtyDetail01.form.edtPtyLctnAddr01.set_value(this.dsPtyList.getColumn(nRow, "lctnAddr") + " " + this.dsPtyList.getColumn(nRow, "lctnDtlAddr"));
		
		this.tab00.Tabpage5.form.divPtyDetail02.set_visible(false);
		this.tab00.Tabpage5.form.divPtyDetail03.set_visible(false);	
	} else if(ptyDetaScCd == "21") {
		this.tab00.Tabpage5.form.divPtyDetail01.set_visible(false);
		this.tab00.Tabpage5.form.divPtyDetail02.set_visible(true);
		this.tab00.Tabpage5.form.divPtyDetail03.set_visible(false);	
	} else if(ptyDetaScCd == "22") {
		this.tab00.Tabpage5.form.divPtyDetail01.set_visible(false);
		this.tab00.Tabpage5.form.divPtyDetail02.set_visible(false);
		this.tab00.Tabpage5.form.divPtyDetail03.set_visible(true);
	}
}

/**
 * @description 임원주소 
 */
this.fnExctvAddr = function() 
{
	var nRow = this.dsExctvList.rowposition;
	if(nRow != -1){
		this.tab00.Tabpage2.form.edtExctvAddrDetail.set_value(this.dsExctvList.getColumn(nRow, "dmclRoadNmAddr")+ " " +this.dsExctvList.getColumn(nRow, "dmclRoadNmDtlAddr"));
	}
	
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 탭 이동
 */
this.tab_onchanged = function(obj:nexacro.Tab,e:nexacro.TabIndexChangeEventInfo)
{
	switch(e.postindex) {
	case 0: 
		//일반사항조회
		if(this.dsCorpInfo.rowcount <= 0) this.fnSelectCorpInfo();
		this.smfResetScroll(this.tab00.Tabpage1.form);
		break;
	case 1: 
		//임원조회
		if(this.dsExctvList.rowcount <= 0) this.fnSelectExctvList();
		this.smfResetScroll(this.tab00.Tabpage2.form);
		break;
	case 2: 
		//정관조회
		if(this.dsArofaInfo.rowcount <= 0) this.fnSelectArofaInfo();
		this.smfResetScroll(this.tab00.Tabpage3.form);
		break;
	case 3: 
		//수익사업조회
		if(this.dsErnBizList.rowcount <= 0) this.fnSelectErnBizList();
		this.smfResetScroll(this.tab00.Tabpage4.form);
		break;
	case 4: 
		//재산조회
		if(this.dsPtyList.rowcount <= 0) this.fnSelectPtyList();
		this.smfResetScroll(this.tab00.Tabpage5.form);
		break;
	}
	
};

/**
 * @description 임원목록 클릭시 특수관계코드 텍스트 변환
 */
this.grdExctvList_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	this.fnExctvAddr()
};

/**
 * @description 재산목록 클릭
 */
this.tab00_Tabpage5_grdPtyList_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	this.fnChgPtyDetaScCd();
	this.fnSelectPtyRevlList();
	this.fnSelectPtyDspsList();
};
]]></Script>
  </Form>
</FDL>
