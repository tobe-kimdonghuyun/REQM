                          <Row size="40"/>
                        </Rows>
                        <Band id="head">
                          <Cell text="순번"/>
                          <Cell col="1" text="임원구분"/>
                          <Cell col="2" text="재직구분"/>
                          <Cell col="3" text="성명"/>
                          <Cell col="4" text="생년월일"/>
                          <Cell col="5" text="임기시작일"/>
                          <Cell col="6" text="임기종료일" cssclass="LineNo"/>
                        </Band>
                        <Band id="body">
                          <Cell text="expr:currow+1" textAlign="center"/>
                          <Cell col="1" text="expr:noprfCorpScCd == &quot;1&quot; &amp;&amp; noprfExctvScCd == &quot;01&quot; &amp;&amp; chaiYn == &quot;Y&quot; ? &quot;이사장&quot; : noprfCorpScCd == &quot;2&quot; &amp;&amp; noprfExctvScCd == &quot;01&quot; &amp;&amp; chaiYn == &quot;Y&quot; ? &quot;회장&quot; :noprfExctvScCd == &quot;01&quot; ? &quot;이사&quot; : noprfExctvScCd == &quot;02&quot; ? &quot;감사&quot; : noprfExctvScCd == &quot;03&quot; ? &quot;추천이사&quot; : noprfExctvScCd == &quot;04&quot; ? &quot;추천감사&quot; : &quot;&quot;" textAlign="center"/>
                          <Cell col="2" text="bind:noprfHffcScCd" displaytype="combotext" combodataset="dsNoprfHffcScCd" combocodecol="code" combodatacol="data"/>
                          <Cell col="3" text="bind:exctvNm" textAlign="center"/>
                          <Cell col="4" text="bind:exctvBrdt" displaytype="date" calendardateformat="yyyy.MM.dd" calendareditformat="yyyy.MM.dd" calendardisplaynulltype="none"/>
                          <Cell col="5" text="bind:terBgngYmd" displaytype="date" calendardateformat="yyyy.MM.dd" calendareditformat="yyyy.MM.dd" calendardisplaynulltype="none"/>
                          <Cell col="6" text="bind:terEndYmd" displaytype="date" calendardateformat="yyyy.MM.dd" calendareditformat="yyyy.MM.dd" calendardisplaynulltype="none" cssclass="LineNo"/>
                        </Band>
                      </Format>
