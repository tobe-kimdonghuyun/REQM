        <Static id="staSTitle04" taborder="13" text="담당하는 기관" left="0" top="697" height="63" cssclass="sta_WF_TitleAcc02" initvalueid="ivStcAccessibilityOn" width="200"/>
        <Static id="sta00_00_00_00_00_01_00_01_00_00_00" taborder="14" text="- 해당 민원에 대한 문의 사항은 접수처리기관에 연락하시기 바랍니다." left="10" top="760" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="800"/>
