        <Static id="staSTitle01" taborder="2" text="사무 개요" left="0" top="268" height="63" cssclass="sta_WF_TitleAcc02" initvalueid="ivStcAccessibilityOn" width="150"/>
        <Static id="sta00_00_00_00_00_01" taborder="3" text="- 공익법인이 상근직원의 정수에 대한 승인을 얻고자 기구도표와 부문별·개인별 관장업무를 명시한 설명서를 첨부하여 교육감 또는 지역교육청 교육장에게 신청하는 민원사무입니다." left="10" top="331" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="1190"/>
        <Static id="staSTitle02" taborder="4" text="신청 시 같이 제출해야 하는 구비서류(민원인이 제출해야 하는 서류)" left="0" top="361" height="63" cssclass="sta_WF_TitleAcc02" initvalueid="ivStcAccessibilityOn" width="600"/>
        <Static id="sta00_00_00_00_00_01_00" taborder="5" text="- 법인기구도표(조직표)" left="10" top="424" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="500"/>
        <Static id="sta00_00_00_00_00_01_00_00" taborder="6" text="- 부문별 또는 개인별 관장업무 설명서" left="10" top="454" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="500"/>
        <Static id="sta00_00_00_00_00_01_00_00_00" taborder="7" text="- 급여지급이 명시된 예산서" left="10" top="484" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="500"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_00" taborder="8" text="- 향후 3년간 추정손익계산서 및 부속명세서" left="10" top="514" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="500"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_00_00" taborder="9" text="- 이사회 회의록 및 총회 회의록" left="10" top="544" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="500"/>
        <Static id="staSTitle03" taborder="10" text="근거 법령" left="0" top="574" height="63" cssclass="sta_WF_TitleAcc02" initvalueid="ivStcAccessibilityOn" width="150"/>
        <Static id="sta00_00_00_00_00_01_00_01" taborder="11" text="- 「공익법인의 설립·운영에 관한 법률」제5조" left="10" top="637" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="500"/>
