              <Static id="Static06" taborder="1" left="Static03:0" top="0" height="42" cssclass="sta_WF_Input02Top" text="방문, 우편, 인터넷" accessibilityenable="true" wordWrap="none" width="410" initvalueid="ivStcAccessibilityOn"/>
              <Static id="Static03_00" taborder="2" left="640" top="0" width="230" height="42" cssclass="sta_WF_Input01Top" text="처리기간" initvalueid="ivStcAccessibilityOn"/>
              <Static id="Static06_00" taborder="3" left="Static03_00:0" top="0" height="42" cssclass="sta_WF_Input02Top" text="5일" accessibilityenable="true" wordWrap="none" right="0" initvalueid="ivStcAccessibilityOn"/>
