        <Static id="staSTitle01" taborder="2" text="사무 개요" left="0" top="268" height="63" cssclass="sta_WF_TitleAcc02" width="150" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_00_00_00_00_01" taborder="3" text="- 공익법인이 이사회에서 선임한 임원에 대하여 그 취임의 승인을 얻기 위해 교육감 또는 지역교육청 교육장에 신청하는 민원사무입니다." left="10" top="331" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="1000"/>
        <Static id="staSTitle02" taborder="4" text="신청 시 같이 제출해야 하는 구비서류(민원인이 제출해야 하는 서류)" left="0" top="361" height="63" cssclass="sta_WF_TitleAcc02" width="600" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_00_00_00_00_01_00" taborder="5" text="- 임원의 선임을 결의한 총회(사단) 또는 이사회의 회의록(재단) 사본" left="10" top="424" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="800"/>
        <Static id="sta00_00_00_00_00_01_00_00" taborder="6" text="- 임원이력서(명함판 사진 첨부, 공무원일 경우 겸직동의서)" left="10" top="454" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="800"/>
        <Static id="sta00_00_00_00_00_01_00_00_00" taborder="7" text="- 해당임원의 기본증명서 또는 가족관계등록부" left="10" top="484" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="800"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_00" taborder="8" text="- 취임승낙서" left="10" top="514" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="800"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_00_00" taborder="9" text="- 특수 관계 부존재 각서 또는 특수 관계 내용설명서" left="10" top="544" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="800"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_00_00_00" taborder="10" text="- 임원 신·구 대비표" left="10" top="574" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="800"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_00_00_00_00" taborder="11" text="- 행정정보 및 개인정보 동의서" left="10" top="604" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="800"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_00_00_00_00_00" taborder="12" text="※ 연임하는 임원의 경우에는 임원이력서, 특수 관계 부존재 각서(또는 특수 관계 내용설명서) 제출을 생략함" left="10" top="634" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="800"/>
        <Static id="staSTitle03" taborder="13" text="근거 법령" left="0" top="664" height="63" cssclass="sta_WF_TitleAcc02" width="200" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_00_00_00_00_01_00_01" taborder="14" text="- 「공익법인의 설립·운영에 관한 법률」제5조" left="10" top="727" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="600"/>
        <Static id="sta00_00_00_00_00_01_00_01_00" taborder="15" text="- 「공익법인의 설립·운영에 관한 법률」제10조" left="10" top="757" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="600"/>
        <Static id="staSTitle04" taborder="16" text="담당하는 기관" left="0" top="787" height="63" cssclass="sta_WF_TitleAcc02" width="250" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_00_00_00_00_01_00_01_00_00_00" taborder="17" text="- 해당 민원에 대한 문의 사항은 접수처리기관에 연락하시기 바랍니다." left="10" top="850" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="800"/>
