        <Div id="divStep02" taborder="5" left="0" top="381" height="166" cssclass="div_WF_WhiteBox_R20" right="0" borderRadius="10px" formscrollbartype="none none" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" left="0" top="0" width="350" cssclass="sta_WF_Txt16B" text="&lt;fc v='#2b72de'&gt;법인&lt;/fc&gt;&#13;&#10;(이행사항)" initvalueid="ivStcAccessibilityOn" bottom="0" textAlign="center" usedecorate="true" background="#fafcff"/>
              <Static id="sta01" taborder="1" text="설립등기(관할등기소에 등기)" left="370" top="28" cssclass="sta_WF_Info16Black" initvalueid="ivStcAccessibilityOn" width="600" height="24"/>
              <Static id="sta02" taborder="2" text="설립신고 및 사업자등록(관할세무서에 신고)" left="370" top="56" cssclass="sta_WF_Info16Black" initvalueid="ivStcAccessibilityOn" width="600" height="24"/>
              <Static id="sta03" taborder="3" text="재산이전(출연재산 법인 명의로 이전)" left="370" top="84" cssclass="sta_WF_Info16Black" initvalueid="ivStcAccessibilityOn" width="600" height="24"/>
              <Static id="sta04" taborder="4" text="설립등기 및 재산이전 보고(관할 교육청 또는 교육지원청에 제출)" left="370" top="112" cssclass="sta_WF_Info16Black" initvalueid="ivStcAccessibilityOn" width="600" height="24"/>
            </Layout>
            <Layout name="default0">
              <Static id="sta00" taborder="0" left="0" top="0" initvalueid="ivStcAccessibilityOn" textAlign="center" height="80" cssclass="sta_WF_Txt24B" right="0"/>
              <Static id="sta01" taborder="1" left="20" top="sta00:23" cssclass="sta_WF_Info24Black" initvalueid="ivStcAccessibilityOn" height="56" fittocontents="height" right="20"/>
