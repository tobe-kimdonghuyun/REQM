              <Static id="Static03" taborder="0" left="0" top="0" width="230" height="42" cssclass="sta_WF_Input01Top" text="신청방법" initvalueid="ivStcAccessibilityOn"/>
              <Static id="Static06" taborder="1" left="Static03:0" top="0" height="42" cssclass="sta_WF_Input02Top" text="방문, 우편, 인터넷" accessibilityenable="true" wordWrap="none" width="410" initvalueid="ivStcAccessibilityOn"/>
