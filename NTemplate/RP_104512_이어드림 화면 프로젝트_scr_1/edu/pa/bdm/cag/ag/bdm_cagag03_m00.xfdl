        <Static id="staSTitle01" taborder="2" text="사무 개요" left="0" top="268" height="63" cssclass="sta_WF_TitleAcc02" width="120" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_00_00_00_00_01" taborder="3" text="- 이 민원은 설립한 비영리법인(공익법인 포함)의 정관변경 허가를 받고자 할 때 설립 허가를 받은 주무관청에 신청하는 민원사무입니다." left="10" top="331" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="1000"/>
        <Static id="staSTitle02" taborder="4" text="신청 시 같이 제출해야 하는 구비서류(민원인이 제출해야 하는 서류)" left="0" top="361" height="63" cssclass="sta_WF_TitleAcc02" initvalueid="ivStcAccessibilityOn" width="600"/>
        <Static id="sta00_00_00_00_00_01_00" taborder="5" text="- 변경사유서" left="10" top="424" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" right="0"/>
        <Static id="sta00_00_00_00_00_01_00_00" taborder="6" text="- 개정될 정관(신·구 대비표 참조)" left="10" top="454" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="800"/>
        <Static id="sta00_00_00_00_00_01_00_00_00" taborder="7" text="- 정관변경과 관계있는 총회 또는 이사회 회의록 등 관련 서류" left="10" top="484" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="800"/>
        <Static id="sta00_00_00_00_00_01_00_00_00_00" taborder="8" text="- 기본재산의 처분에 따른 정관변경의 경우에는 처분의 사유, 처분재산의 목록, 처분방법 등을 기재한 서류" left="10" top="514" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="800"/>
        <Static id="staSTitle03" taborder="9" text="근거 법령" left="0" top="544" height="63" cssclass="sta_WF_TitleAcc02" initvalueid="ivStcAccessibilityOn" width="200"/>
        <Static id="sta00_00_00_00_00_01_00_01" taborder="10" text="- 「민법」제42조, 제45조, 제46조" left="10" top="607" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="800"/>
        <Static id="sta00_00_00_00_00_01_00_01_00" taborder="11" text="- 「공익법인의 설립·운영에 관한 법률」제10조" left="10" top="637" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="800"/>
        <Static id="sta00_00_00_00_00_01_00_01_00_00" taborder="12" text="- 「교육부 소관 비영리법인의 설립 및 감독에 관한 규칙」제6조" left="10" top="667" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="800"/>
        <Static id="staSTitle04" taborder="13" text="담당하는 기관" left="0" top="697" height="63" cssclass="sta_WF_TitleAcc02" initvalueid="ivStcAccessibilityOn" width="250"/>
        <Static id="sta00_00_00_00_00_01_00_01_00_00_00" taborder="14" text="- 해당 민원에 대한 문의 사항은 접수처리기관에 연락하시기 바랍니다." left="10" top="760" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" width="600"/>
