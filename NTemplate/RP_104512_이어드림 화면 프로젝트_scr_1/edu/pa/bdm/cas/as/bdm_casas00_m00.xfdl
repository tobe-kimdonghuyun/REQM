                <Cell col="4" text="expr:(dmndYmd != undefined &amp;&amp; dmndYmd != &quot;&quot; &amp;&amp; sbmsnYmd == undefined) ? &quot;보완요청&quot; : (dmndYmd != undefined &amp;&amp; dmndYmd != &quot;&quot; &amp;&amp; sbmsnYmd != &quot;&quot;) ?  &quot;보완완료&quot;  : &quot;&quot;" textAlign="center" cssclass="expr:spmYn == 'Y' &amp;&amp; isHighlighted == 'Y' ? 'cell_WF_Red' : ''"/>
                <Cell col="5" text="expr:(cvlcptPrcsRltCd != undefined &amp;&amp; cvlcptPrcsRltCd != &quot;&quot; &amp;&amp; cvlcptPrcsRltCd != &quot;00&quot;) ? &quot;접수증발급&quot; : &quot;&quot;" displaytype="normal" textAlign="center"/>
                <Cell col="6" text="expr:tmprStrgYn ==&quot;Y&quot; &amp;&amp; dmndYmd == undefined ? &quot;삭제&quot; : &quot;&quot;" textAlign="center" cssclass="LineNo"/>
              </Band>
            </Format>
          </Formats>
