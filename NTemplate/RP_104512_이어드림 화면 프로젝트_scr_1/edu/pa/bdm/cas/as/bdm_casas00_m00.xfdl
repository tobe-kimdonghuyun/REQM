        <ColumnInfo>
          <Column id="corpSbmsnNo" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsPageInfo" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="initPageIndex" type="INT" size="30" value="1"/>
          <ConstColumn id="initPageSize" type="INT" size="30" value="10"/>
          <Column id="pageIndex" type="INT" size="256"/>
          <Column id="pageSize" type="INT" size="256"/>
          <Column id="totalCount" type="INT" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    대국민 비영리법인 민원신청현황 민원진행상태조회
*  @FileName 	bdm_casas00_m00
*  @Creator 	서광명
*  @CreateDate 	2022.06.22
*  @Desction    민원진행상태조회
*
************** 소스 수정 이력 ***********************************************
*  date				Modifier				Description
*******************************************************************************
*  2022.06.22		서광명					최초 생성
*******************************************************************************
*/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::bdm_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.cddcCd = this.bdmGetUserInfo("cddcCd");
/************************************************************************************************
 * FORM EVENT 영역(onload)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	//로그인 확인
	this.bdmfChkLogin();

	// 폼 초기화
	this.smfInitForm(obj);
	
	this.smfValidateService("validateMain", {
		url: "/bdm_cas_as00_000.do",
	})
	.mappingRulesetToForm(this.divSearch, "listCvlAply")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
	})
	
	// 세션에서 시도코드 받아서 검색 파라미터 세팅
	this.dsSearch.setColumn(0,"cddcCd", this.cddcCd);
	// 세션에서 시도교육청, 법인코드 받아서 검색 파라미터에 값 세팅
	
	this.fnInitSearchDateRange();
	this.dsSearch.setColumn(0,"prgStsCd"    , "99");
	this.smfSetFirstCode(this.dsPgrStsCd);
	
	// 초기 페이징사이즈 설정
	this.divPageSummary.form.fnSetInitPageSize(10);
	
	//this.fnSearch(obj, e);
	this.divSearch.form.btnSearch.click();
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(obj, e)
{
	this.smfSearchService("listCvlAply")
	.paginator(this.grdMain, this.divPaginator, this.divPageSummary, this.dsPageInfo, obj, e)
	.validateForm(this.divSearch)
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
	})
}
/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
 */
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd == -1) return;
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnSpmCallback = function(e, sender){

};

/**
 * @description 검색날짜 초기화 오늘~1년전
 */
this.fnInitSearchDateRange = function() 
{
	var objDate = new nexacro.Date();
	
	this.divSearch.form.calInqBgngYmd.set_value(
		new nexacro.Date(
			(objDate.getFullYear()-1).toString(),
			objDate.getMonth().toString().padLeft(2,"0"),
			objDate.getDate().toString().padLeft(2,"0")
		)
	)
	
	this.divSearch.form.calInqEndYmd.set_value(
		new nexacro.Date(
			objDate.getFullYear().toString(),
			objDate.getMonth().toString().padLeft(2,"0"),
			objDate.getDate().toString().padLeft(2,"0")
		)
	);
}

this.cvlcptStsNm = function(tmprStrgYn, cvlcptAplyRltNm, cvlcptRcptRltNm, corpIdntyDmndStsNm){
	
	// 교육부 요청사항. "해결"->"승인"
	if (cvlcptRcptRltNm == "해결") cvlcptRcptRltNm = "승인";
	
	if(corpIdntyDmndStsNm != undefined) return corpIdntyDmndStsNm;
	if(tmprStrgYn == "Y" && cvlcptAplyRltNm == undefined) return "임시저장";
	if(cvlcptRcptRltNm != undefined) return cvlcptRcptRltNm;
	if(cvlcptAplyRltNm != undefined) return cvlcptAplyRltNm;
	//cvlcptPrcsRltCd == undefined ? cvlcptAplyRltNm : cvlcptPrcsRltNm
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 검색버튼클릭
 */
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 신청일자 유효성체크
	var inqBgngYmd = this.dsSearch.getColumn(0, "inqBgngYmd");
	var inqEndYmd = this.dsSearch.getColumn(0, "inqEndYmd");
	if (inqBgngYmd > inqEndYmd) {
		this.bdmAlert("PA019", []); // 신청일자의 시작일자가 종료일자보다 클 수 없습니다.
		return false;
	}
	
	this.fnSearch(obj, e);
};

/**
 * @description 그리드 보완사항/민원접수증 버튼 클릭
 */
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var nRow = this.dsMain.rowposition;
	var cvlcptPrcsRltCd = this.dsMain.getColumn(nRow, "cvlcptPrcsRltCd");
	var cvlcptAplyRltCd = this.dsMain.getColumn(nRow, "cvlcptAplyRltCd");
	var corpIdntyDmndStsCd = this.dsMain.getColumn(nRow, "corpIdntyDmndStsCd");
	var dmndYmd = this.dsMain.getColumn(nRow, "dmndYmd");
	
	if( e.col==1 )
	{
		var cvlcptClfNo = obj.getBindDataset().getColumn(nRow, "cvlcptClfNo");
		
		var params = {corpSbmsnNo : obj.getBindDataset().getColumn(nRow, "corpSbmsnNo")};
		
		if(cvlcptClfNo == "037AA01101") { // 민원분류번호-정관변경허가신청
			this.smfSetWorkPage("pa_bdm_cal_ap::bdm_calap00_m00.xfdl", params);
		} else if(cvlcptClfNo == "037AA01201") { //민원분류번호- 임원취임승인신청
			this.smfSetWorkPage("pa_bdm_cal_ap::bdm_calap01_m00.xfdl", params);
		} else if(cvlcptClfNo == "037AA01501") { //민원분류번호- 이사회소집승인신청
			this.smfSetWorkPage("pa_bdm_cal_ap::bdm_calap02_m00.xfdl", params);
		} else if(cvlcptClfNo == "037AA01401") { //민원분류번호- 상근직원정수승인신청
			this.smfSetWorkPage("pa_bdm_cal_ap::bdm_calap03_m00.xfdl", params);
		} else if(cvlcptClfNo == "037AA01301") { //민원분류번호- 수익사업승인신청
			this.smfSetWorkPage("pa_bdm_cal_ap::bdm_calap04_m00.xfdl", params);
		} else if(cvlcptClfNo == "999ZZ99999") { //민원분류번호- 설립등기등보고
			this.smfSetWorkPage("pa_bdm_cal_ap::bdm_calap05_m00.xfdl", params);
		}
	}
	
	else if( e.col==3 )
	{
		if (cvlcptPrcsRltCd == "08" || corpIdntyDmndStsCd == "04") { // 유기한민원 반려 || 확인요청 반려
			var popupParams = {
				callback: function(){},
				sender: obj,
				params: {
					procType: "search",
					cvlcptNm: cvlcptPrcsRltCd == "08" ? this.dsMain.getColumn(nRow, "cvlcptOfcrkNm") :
					          corpIdntyDmndStsCd == "04" ? this.dsMain.getColumn(nRow, "corpIdntyDmndNm") : "",
					rjctRsnCn: cvlcptPrcsRltCd == "08" ? this.dsMain.getColumn(nRow, "rcptRjctRsnCn") :
					           corpIdntyDmndStsCd == "04" ? this.dsMain.getColumn(nRow, "rjctRsnCn") : "",
				}
			};
			this.smfDialog("_auto", "pa_bdm_cas_as::bdm_casas00_p02.xfdl", popupParams);
		}else if(cvlcptPrcsRltCd == "07" || cvlcptAplyRltCd == '5'){//취하, 취소
			var popupParams = {
				callback: function(){},
				sender: obj,
				params: {
					procType: "search",
					cvlcptNm: this.dsMain.getColumn(nRow, "cvlcptOfcrkNm"),
					wtdrRsnCn: cvlcptPrcsRltCd == "07" ? this.dsMain.getColumn(nRow, "rcptWtdrRsnCn") :
					           cvlcptAplyRltCd == "5"  ? this.dsMain.getColumn(nRow, "wtdrRsnCn") : "",
					chkType : "N"
				}
			};
			this.smfDialog("_auto", "pa_bdm_cas_as::bdm_casas00_p03.xfdl", popupParams);
		}
	}
	
	else if( e.col==4 && !this.smfIsNull(dmndYmd))
	{
		var popupParams = {
			callback: this.fnSpmCallback,
			sender: obj,
			params: {
				procType: "search",
				corpSbmsnNo: this.dsMain.getColumn(nRow, "corpSbmsnNo")
			}
		};
		this.smfDialog("_auto", "pa_bdm_cas_as::bdm_casas00_p01.xfdl", popupParams);
	}
	
	else if( e.col==5 && obj.getCellText(nRow, 5).length>0 )
	{
		// 리포트를 생성하기 위한 옵션을 설정한다.
		var oOzOption = {
							reports : [	
								{	
									// 기본데이터
									  displayname         : "리포트1"   // [필수] 멀티리포트시 Tree에 보여줄 이름
									, reportname : "/edu/pa/bdm/cas/as/bdm_casas00_r00.ozr" // [필수] 리포트명  "/jsonsample.ozr"
									
									// json연동형
									//  - Odi인 경우 지정안해도 됨
									//  - jsonDs/jsonDsName은 갯수가 같아야 됨
									// , jsonDs     : [this.dsCategory,this.dsProduct]  // [선택] json으로 변환할 데이터셋
									// , jsonDsName : ["Category","Product"]            // [선택] json으로 변환할 데이터의이름(ozr파일에서 지정된 값과 일치)
									, jsonParam  : ["viewerType=HTML5 Canvas Viewer 1"
									               ,"cvlcptRcptNo=" + this.dsMain.getColumn(nRow, "cvlcptRcptNo")
												   ,"rcptDt=" + this.dsMain.getColumn(nRow, "rcptDt")
												   ,"cvlcptNm=" + this.dsMain.getColumn(nRow, "cvlcptNm")
												   ,"cpttrFlnm=" + this.dsMain.getColumn(nRow, "cpttrFlnm")
												   ,"prcsDdlnDt=" + this.dsMain.getColumn(nRow, "prcsDdlnDt")
												   ,"rcptPrgeFlnm=" + this.dsMain.getColumn(nRow, "rcptPrgeFlnm")
												   ,"prcsPrgeTelno=" + this.dsMain.getColumn(nRow, "prcsPrgeTelno")
												   ,"ctefNm=" + this.dsMain.getColumn(nRow, "ctefNm")]  // [선택] json이외에추가할 데이터(KEY=VALUE형태의 스트링(배열))
									
									// odi연동형
									//  - json인 경우 지정안해도 됨
									//  - odiDs/odiDsName은 갯수가 같아야 됨
									//, odiDs      : [this.dsOdiParam]  // [선택] odi로 변환할 데이터셋
									//, odiDsName  : ["userdata"]       // [선택] odi로 변환할 데이터의이름(ozr파일에서 지정된 값과 일치)
									
									// 추가/보안옵션
									, security     : "N"       // [선택] 위변조방지 삽입   ("Y"(default):표시,"N":비표시)
									, voiceBarcode : "N"   // [선택] 보이스바코드 삽입 ("Y"(default):표시,"N":비표시)
								}
							]
						, popupWidth  : 900	// [선택]  팝업으로 띄울 경우 팝업의 width(팝업의 기본width:1000)
						, popupHeight : 900	// [선택]  팝업으로 띄울 경우 팝업의 height(팝업의 기본width:610)
						};
		this.smfReportView(this, "popup", oOzOption, this.fnReportCallback);
		

	}
	
	else if( e.col==6 && obj.getCellText(nRow, 6)=="삭제" )
	{
		var corpSbmsnNo = obj.getBindDataset().getColumn(nRow, "corpSbmsnNo");
		this.dsCorpSbmsnNo.setColumn(0, "corpSbmsnNo", corpSbmsnNo);
		this.dsCorpSbmsnNo.setColumn(0, "cddcCd", this.bdmv_cddcCd);
		
		this.smfDeleteService("deleteTmprCvlcpt")
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;

			var params = {};
			this.smfSetWorkPage("pa_bdm_cas_as::bdm_casas00_m00.xfdl", params);
			var _this = this;
			var timeId = setTimeout(function(){
				_this.bdmAlert("PA020", []); // 삭제가 완료되었습니다.
			}, 250);
		})
	}
};

this.fnReportCallback = function()
{

}]]></Script>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.calInqBgngYmd" propid="value" datasetid="dsSearch" columnid="inqBgngYmd"/>
      <BindItem id="item1" compid="divSearch.form.calInqEndYmd" propid="value" datasetid="dsSearch" columnid="inqEndYmd"/>
      <BindItem id="item2" compid="divSearch.form.cboPrgStsCd" propid="value" datasetid="dsSearch" columnid="prgStsCd"/>
      <BindItem id="item3" compid="divSearch.form.cboPrgStsCd" propid="text" datasetid="dsPgrStsCd" columnid="data"/>
    </Bind>
  </Form>
</FDL>
