          <Column id="searchKeyword" type="STRING" size="256"/>
          <Column id="pafrBbsId" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="cddcCd">B100000001</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsListTemp" useclientlayout="true">
        <ColumnInfo>
          <Column id="faqId" type="string" size="256"/>
