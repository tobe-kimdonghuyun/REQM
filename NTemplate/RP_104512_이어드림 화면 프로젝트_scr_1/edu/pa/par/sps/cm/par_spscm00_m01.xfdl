    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    유아 조회
*  @FileName 	par_spscm00_m01.xfdl
*  @Creator 	안배식
*  @CreateDate 	2023.02.10
*  @Desction    유치원 학부모서비스 - 유치원 조회
************** 소스 수정 이력 ***********************************************
*  date				Modifier				Description
*******************************************************************************
*  2023.02.10		안배식					최초 생성
*******************************************************************************
*/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::cm_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
var cddcScCd;

/************************************************************************************************
 * FORM EVENT 영역(onload)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리
 */
this.par_spscm00_m01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitPopup(obj);
};

/************************************************************************************************
 * TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
};



/**
 * @description 엔터키실행
 */
this.fnKeyUp = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode=='13'){
		this.divSearch_btnSearch_onclick();
	}
};

this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (this.divClaiInfo.form.edtStuFlnm.text == '') {
		this.smfAlert('검색하실 유아의 이름을 입력하세요.');
		this.divClaiInfo.form.edtStuFlnm.setFocus();
		return false;
	}

	if (this.smfIsNull(this.divClaiInfo.form.calClaiBrdt.value)) {
		this.smfAlert('생년월일을 입력하세요.');
		this.divClaiInfo.form.calClaiBrdt.setFocus();
		return false;
	}
	
	if (this.divClaiInfo.form.edtClsNm.text == '') {
		this.smfAlert('검색하실 유아의 학급명을 입력하세요.');
		this.divClaiInfo.form.edtClsNm.setFocus();
		return false;
	}
	
	if (this.smfIsNull(this.divClaiInfo.form.edtShlCd.value)) {
		this.smfAlert('검색하실 유치원을 입력하세요.');
		this.divClaiInfo.form.edtShlCd.setFocus();
		return false;
	}

	this.dsSearch.setColumn(0, "shlCd", this.divClaiInfo.form.edtShlCd.value);
	this.dsSearch.setColumn(0, "stuFlnm", this.divClaiInfo.form.edtStuFlnm.text);
	this.dsSearch.setColumn(0, "brdt", this.divClaiInfo.form.calClaiBrdt.value);
	this.dsSearch.setColumn(0, "clsNm", this.divClaiInfo.form.edtClsNm.text);
	this.dsSearch.setColumn(0, "cddcScCd", this.cddcScCd);

	this.smfSearchService("selectStuList")
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.dsResult.getRowCount() > 0){
				this.div00.form.grdStuList.setFocus();
			}
		});
};

this.fnPopupCallback = function(e, sender){
	this.divClaiInfo.form.edtKndgr.set_value(e.kornOrgNm);
	this.divClaiInfo.form.edtShlCd.set_value(e.orgCd);
	this.cddcScCd = e.cddcScCd;
}

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd <= -1) return;	
};

this.fnKndgrSchPopup = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var procType = "none";
	var sType = "2";

	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback : this.fnPopupCallback, // 콜백함수 지정
		sender : obj, // sender 지정
		// 팝업 전달 파라메터 지정
		params : {
			// 처리타입 지정
			procType	: procType,
			// 파라메터 전달
			sType 		: sType
		},
	};
	
	this.smfDialog("_auto", "pa_par_sps_cm::par_spscm00_m00.xfdl", popupParams);
};

this.grdStuList_onCellDbClick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	this.smfSendResponseToOpener({
		"shlCd": this.dsResult.getColumn(e.row, "shlCd"),
		"kornOrgNm": this.dsResult.getColumn(e.row, "kornOrgNm"),
		"stuDtcNo": this.dsResult.getColumn(e.row, "stuDtcNo"),
		"stuInvlNo": this.dsResult.getColumn(e.row, "stuInvlNo"),
		"stuFlnm": this.dsResult.getColumn(e.row, "stuFlnm"),
		"ayr": this.dsResult.getColumn(e.row, "ayr"),
		"clsCd": this.dsResult.getColumn(e.row, "clsCd"),
		"clsNm": this.dsResult.getColumn(e.row, "clsNm"),
		"clsScCd": this.dsResult.getColumn(e.row, "clsScCd"),
		"clsScNm": this.dsResult.getColumn(e.row, "clsScNm"),
		"eduCrseClsNm": this.dsResult.getColumn(e.row, "eduCrseClsNm"),
		"eduCrseCno": this.dsResult.getColumn(e.row, "eduCrseCno")
	});	
	
	this.close(true);
};
this.btn_close_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};

this.sta02_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	
};
]]></Script>
