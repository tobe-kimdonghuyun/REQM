      <BindItem id="item9" compid="divClaiInfo.form.edtClaiTelNo" propid="value" datasetid="dsMain" columnid="claiTelno"/>
      <BindItem id="item10" compid="divClaiInfo.form.edtClaiMblTelNo" propid="value" datasetid="dsMain" columnid="claiMblTelno"/>
