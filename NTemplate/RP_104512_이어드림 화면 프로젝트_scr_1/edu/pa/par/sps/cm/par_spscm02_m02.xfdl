    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    공지사항
*  @FileName 	ues_ueudi02_m01
*  @Creator 	최재영
*  @CreateDate 	2022.05.31
*  @Desction    대입전형-공지사항
************** 소스 수정 이력 ***********************************************
*  date				Modifier				Description
*******************************************************************************
*  2022.05.31		최재영					최초 생성
*******************************************************************************
*/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::cm_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.pafrBbsId = "";
this.dsSearchParam;
this.dsPagingParam;
this.dsListParam ;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리
 */
this.par_spscm02_m02_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);
	
	// 파라메터 세팅
	this.pv_params = this.smfGetFormParams();

	if(!this.smfIsNull(this.pv_params)){
		this.pafrBbsId = this.pv_params.pafrBbsId;
		this.dsSearchParam = this.pv_params.dsSearchParam;
		this.dsPagingParam = this.pv_params.dsPagingParam;
		this.dsListParam = this.pv_params.dsListParam;
		
		// 웹 에디터 셋팅 
		this.divDetail.form.divWebEditor.form.fnInit(this,this.fnWebEditorCallback,this.fnWebEditorSetHtmlCallback);
	}
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
};

/*
*	웹에디터가 onload된 이후 호출되는 callback
*   obj : 웹에디터 Div오브젝트
*/
this.fnWebEditorCallback = function(obj)
{
	// 일반적으로는 데이터를 세팅
	this.fnSearch(this.pafrBbsId);
};

/*
*	웹에디터가 text를 변경 할 경우 호출하는 callback
*   obj : 웹에디터 Div오브젝트
*/
this.fnWebEditorSetHtmlCallback = function(obj,contentHeight)
{
	//trace("***  웹에디터에 Text를 세팅했습니다.["+obj.id+"] contentHeight[=" + contentHeight + "]");
	
	// 일반적으로는 WebEditor Div를 resetScroll해줌.
	//  (Web Editor의 높이가 변경이 되어 있음(autoHeight="Y"인 경우))
	this.smfResetScroll(this.divDetail.form.divWebEditor);
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(pafrBbsId)
{
	this.divDetail.form.divFileDownload.set_height(0);
	this.dsSearch.setColumn(0,"faqId", pafrBbsId);

 	// 서비스 객체 생성
	this.smfSearchService("selectDtl")
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.parent.parent.scrollTo(0,0);
			
			//모바일 경우
			if(this.smfIsMobile()){
				this.divDetail.form.sta45.set_text(this.dsResult.getColumn(0, "faqTitlNm"));
				this.divDetail.form.sta10_00.set_text(this.dsResult.getColumn(0, "regDt").substring(0,4)+"."+this.dsResult.getColumn(0, "regDt").substring(4,6)+"."+this.dsResult.getColumn(0, "regDt").substring(6,8)+".");
				this.divDetail.form.sta10_00_00.set_text("조회수 "+this.dsResult.getColumn(0, "faqInqCnt"));
				
				//제목 div 크기 조정
				var title = this.divDetail.form.sta45;
				var textHeight = this.fnGetContentsHeight(title);

				this.divDetail.form.sta44.setOffsetHeight(textHeight + 70);
				this.divDetail.form.sta45.setOffsetHeight(textHeight-10);
				this.smfResetScroll(this.divDetail.form);
			}
			
			this.divDetail.form.divWebEditor.form.fnSetHtml(this.dsResult.getColumn(0,"faqCn"));
			
			//첨부파일조회. fileRefrnId있을때만 fileRefrnId 불러온뒤 호출
			var sFileRefrnId = this.dsResult.getColumn(0, "fileRefrnId");
			
			//첨부파일조회. fileRefrnId있을때만 fileRefrnId 불러온뒤 호출
			if(sFileRefrnId != undefined && sFileRefrnId != ''){
				this.selectAtchFile(sFileRefrnId);
				this.divDetail.form.sta44_00_01_01_00_00.set_visible(true);
			}else{
				this.divDetail.form.sta44_00_01_01_00_00.set_visible(false);
			}
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// [목록]버튼클릭 처리
this.btnList_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var params = {"dsSearchParam":this.dsSearchParam
				, "dsPagingParam":this.dsPagingParam
				, "dsListParam" : this.dsListParam
				};
	this.smfSetWorkPage("pa_par_sps_cm::par_spscm02_m01.xfdl", params);
};

//첨부 공통
this.selectAtchFile = function(fileRefrnId){

	// 업로드 초기화
	this.transaction("fn_filesearch"
		,"baseUrl::/cm_cmc_file_upload_001.do"
		,""
		,"dsOutFileinfo=atchFileinfo" 
		,"fileRefrnId='"+fileRefrnId+"'"
		,this.btnUpload_FileSearch_callback
		,false // 동기
	);
	
	if(this.dsOutFileinfo.rowcount > 0){
		var addHeight = this.smfIsMobile() ? (65 + (this.dsOutFileinfo.rowcount-1)*50) : (45 + (this.dsOutFileinfo.rowcount-1)*30);
		this.divDetail.form.divFileDownload.set_height(parseInt(this.divDetail.form.divFileDownload.height) + parseInt(addHeight));
	}
	
	for (var i=0;i<this.dsOutFileinfo.rowcount;i++) {
		var handlerCode = "PA.PAR.SPS";
		var fileSn = this.dsOutFileinfo.getColumn(i, "fileRefrnId"); // "[avBzfFfD1CCzzV1+O4RpwITvxrUZAA/gm8OZ9a6pZ2Y=";
		var fileId = this.dsOutFileinfo.getColumn(i, "fileId"); // "0"
		var fileSize = this.dsOutFileinfo.getColumn(i, "atchFileMg"); // 72239;
		var backendFilename = this.dsOutFileinfo.getColumn(i, "atchFileGuid"); // '670272e75319870bdf1751ec3aa18e82.jpg';
		var frontendFilename = this.dsOutFileinfo.getColumn(i, "atchFileNm"); // '화면1.jpg';
		
		var sDownloadPath    = this.dsOutFileinfo.getColumn(i, "fileCoursNm"); // "";
		var sFileEncryptYn   = this.dsOutFileinfo.getColumn(i, "fileEncryptYn"); // "N" ;
		var sPrivInfoFiltYn  = this.dsOutFileinfo.getColumn(i,"privInfoFiltYn");
		var sFileSaveStg     = this.dsOutFileinfo.getColumn(i, "fileSaveStg"); // "SV";
		var sFileInfSaveYn   = this.dsOutFileinfo.getColumn(i,"fileInfSaveYn" );
		
		this.divDetail.form.divFileDownload.form.fnAddUploadedFile(handlerCode, fileSn, fileSize, backendFilename, frontendFilename , fileId
													,sDownloadPath,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn);
	}
}


//높이 값 구하는 함수
this.fnGetContentsHeight = function(objContentsStatic)
{
	var strMFont = 'bold 28px/1.4 "NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic"';
	var Font = strMFont;
	var nHeightPadding = 20;
	
	var staText = objContentsStatic.text;
	var staWidth = objContentsStatic.getOffsetWidth();	
	var nTextHeight = nexacro.getTextSize(staText,Font,staWidth,"char");

	return nTextHeight.ny+nHeightPadding ;
};]]></Script>
    <Objects>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="faqId" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">selectDtl</Col>
            <Col id="inDatasets">dsSearchDtl=dsSearch</Col>
            <Col id="outDatasets">dsResult=dsResult</Col>
            <Col id="url">/par_sps_cm05_003.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsResult" useclientlayout="true">
        <ColumnInfo>
          <Column id="faqId" type="string" size="256"/>
          <Column id="faqTitlNm" type="string" size="256"/>
          <Column id="faqCn" type="string" size="256"/>
          <Column id="faqClfCd" type="string" size="256"/>
          <Column id="pstStsCd" type="string" size="256"/>
          <Column id="fileRefrnId" type="string" size="256"/>
          <Column id="faqInqCnt" type="string" size="256"/>
          <Column id="rgtrNm" type="string" size="256"/>
          <Column id="rgtrDptNm" type="string" size="256"/>
          <Column id="mdfrNm" type="string" size="256"/>
          <Column id="mdfrDptNm" type="string" size="256"/>
          <Column id="rgtrId" type="string" size="256"/>
          <Column id="regDt" type="string" size="256"/>
          <Column id="mdfrId" type="string" size="256"/>
          <Column id="mdfcnDt" type="string" size="256"/>
          <Column id="rowNum" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsOutFileinfo">
        <ColumnInfo>
          <Column id="fileRefrnId" type="STRING" size="256"/>
          <Column id="fileId" type="STRING" size="256"/>
          <Column id="suc" type="STRING" size="256"/>
          <Column id="atchFileNm" type="STRING" size="256"/>
          <Column id="atchFileGuid" type="STRING" size="256"/>
          <Column id="atchFileMg" type="STRING" size="256"/>
          <Column id="fileExtsnNm" type="STRING" size="256"/>
          <Column id="minTypeNm" type="STRING" size="256"/>
          <Column id="fileCoursNm" type="STRING" size="256"/>
          <Column id="fileObjKey" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="divDetail.form.edt00" propid="value" datasetid="dsResult" columnid="faqTitlNm"/>
      <BindItem id="item1" compid="divDetail.form.msk00" propid="value" datasetid="dsResult" columnid="regDt"/>
      <BindItem id="item2" compid="divDetail.form.edt00_00_00" propid="value" datasetid="dsResult" columnid="faqInqCnt"/>
      <BindItem id="item3" compid="divDetail.form.mskDate" propid="value" datasetid="dsResult" columnid="regDt"/>
    </Bind>
  </Form>
</FDL>
