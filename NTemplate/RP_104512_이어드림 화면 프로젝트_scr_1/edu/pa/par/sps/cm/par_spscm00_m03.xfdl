    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    학부모 정보 수정
*  @FileName 	par_spscm00_m02.xfdl
*  @Creator 	안배식
*  @CreateDate 	2023.02.10
*  @Desction    유치원 학부모서비스 - 학부모 정보 수정
************** 소스 수정 이력 ***********************************************
*  date				Modifier				Description
*******************************************************************************
*  2023.02.10		안배식					최초 생성
*******************************************************************************
*/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::cm_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_sAgree = "";

/************************************************************************************************
 * FORM EVENT 영역(onload)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리
 */
this.par_spscm00_m02_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);

	//공통 코드 조회
	this.smfSearchService("listApsRelList")
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		}) // 콜백
	;

	// 세션 정보 조회
	this.getSessionInfo();
};

this.getSessionInfo = function () {
	//학부모 정보 조회
	this.smfSearchService("selectSessionInfo")
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.afsfSplitTelno(this.dsSchpaInfo, "mblTelno");
			
			if(this.smfIsMobile()){
				var grdH = this._smfappendHeight(this.div01.form.grdStuList);
				if(grdH < 564) grdH = 564;
				this.div01.form.grdStuList.setOffsetHeight(grdH);
				this.div01.setOffsetHeight(grdH);
				this.smfResetScroll(this);
			}
		}) // 콜백
	;
}

this.afsfSplitTelno = function (ds, colNm) { 
	ds.set_updatecontrol(false);
	if ( this.smfIsEmptyObject(ds) ) return;
	if ( this.smfIsNull(colNm) ) return;
	
	if ( !this.smfIsNull(ds.getColumn(0, colNm)) ) {
		var mblTelno = ds.getColumn(0, colNm);
		if(mblTelno.indexOf("-") == -1){
			ds.setColumn(0, colNm+"1", mblTelno.substr(0, 3));
			ds.setColumn(0, colNm+"2", mblTelno.substr(3, 4));
			ds.setColumn(0, colNm+"3", mblTelno.substr(7, 4));
		}else{
			var sTelno = mblTelno.split("-");
			ds.setColumn(0, colNm+"1", sTelno[0]);
			ds.setColumn(0, colNm+"2", sTelno[1]);
			ds.setColumn(0, colNm+"3", sTelno[2]);
		}
	}
	ds.set_updatecontrol(true);
}

/************************************************************************************************
 * TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
};

this.fnPopupCallback = function(e, sender){

	if(sender == "agreePersInfo"){
		this.div02.form.chk00.set_value(e.agreePersInfo);
		this.fv_sAgree = e.agreePersInfo;
	}else if(sender == "addStu"){
		var nRow = this.dsResult.findRow("stuDtcNo", e.stuDtcNo);
		if (nRow > -1) {
			this.smfAlert('이미 자녀 추가 신청중이거나 승인완료(재학생 포함) 되었습니다. 추가 등록하실 필요가 없습니다.');
			return false;
		}
		
		var i = this.dsResult.rowcount ;
		
		this.dsResult.addRow();
		this.dsResult.setColumn(i, 'idx' , i+1);
		this.dsResult.setColumn(i, 'shlCd' , e.shlCd);
		this.dsResult.setColumn(i, 'kornOrgNm' , e.kornOrgNm);
		this.dsResult.setColumn(i, 'stuDtcNo' , e.stuDtcNo);
		this.dsResult.setColumn(i, 'stuInvlNo' , e.stuInvlNo);
		this.dsResult.setColumn(i, 'infntFlnm' , e.stuFlnm);
		this.dsResult.setColumn(i, 'ayr' , e.ayr);
		this.dsResult.setColumn(i, 'clsScCd' , e.clsScCd);
		this.dsResult.setColumn(i, 'clsCd' , e.clsCd);
		this.dsResult.setColumn(i, 'clsNm' , e.clsNm);
		this.dsResult.setColumn(i, 'admClsNm' , e.clsScNm);
		this.dsResult.setColumn(i, 'stuClsNo' , e.eduCrseCno);
		this.dsResult.setColumn(i, 'clsNm' , e.eduCrseClsNm);
		this.dsResult.setColumn(i, 'clsCd' , e.clsCd);
		this.dsResult.setColumn(i, 'apsRelCd' , '');
		this.dsResult.setColumn(i, 'aprvStsCd' , '신규');
		
		if(this.smfIsMobile()){
			var grdH = this._smfappendHeight(this.div01.form.grdStuList);
			if(grdH < 564) grdH = 564;
			this.div01.form.grdStuList.setOffsetHeight(grdH);
			this.div01.setOffsetHeight(grdH);
			this.smfResetScroll(this);
		}
	}
}

this.tabDtl_tapAcbg_divBtnAcbg_btnAddAcbg_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var procType = "none";
	var sType = "2";

	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback : this.fnPopupCallback, // 콜백함수 지정
		sender : "addStu", // sender 지정
		// 팝업 전달 파라메터 지정
		params : {
			// 처리타입 지정
			procType	: procType,
			// 파라메터 전달
			sType 		: sType
		},
	};
	
	var srcInfo = this.smfCurScreenInfo();
	var srcInfoW = 950;
	var srcInfoH = 520+45;
		
	if(this.smfIsMobile()){		
		srcInfoW = 640;
		srcInfoH = srcInfo[1];
	}
	
	this.smfDialog("_auto", "pa_par_sps_cm::par_spscm00_m01.xfdl", popupParams, "", "", srcInfoW, srcInfoH);
};

this.tabDtl_tapAcbg_divBtnAcbg_btnDeleteAcbg_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var arrChk = this.dsResult.extractRows("_chk");
	
	if (arrChk.length == 0){
		 this.smfAlert('CM013', ['행'], this.callback ); // 선택된 행이(가) 없습니다. 행을(를) 선택하여 주십시오.
		 return;
	}
	
	var chkList2 = this.dsResult.extractRows("_chk == 1 && (aprvStsCd != '승인' && aprvStsCd != '반려')");
	
	if (chkList2.length > 0){
		this.smfAlert('PA004', ['승인상태가 [승인/반려]상태만 삭제가'], this.callback ); //[등록요청/수정요청]상태만 취소가 가능합니다.
		return;
	}
	
	//this.dsResult.deleteMultiRows(arrChk);
	
	this.smfDeleteService("delete")
		.messagePrefix(["삭제"])
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.smfAlert('PA001', ['삭제'], this.callback ); 
			
			//학부모 정보 조회
			this.smfSearchService("selectSessionInfo")
				.run() // 실행
				.callback(function(callbackParams){
					if(callbackParams.errors) return;
					this.afsfSplitTelno(this.dsSchpaInfo, "mblTelno");
				}) // 콜백
			;
		});	
};

this.fnMessageCallback = function(){
	// 서비스 객체 생성 
	this.smfSaveService("saveApsRelInfo")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;
			this.smfAlert('CM002');	//저장이 완료되었습니다.			

			//학부모 정보 조회
			this.smfSearchService("selectSessionInfo")
				.run() // 실행
				.callback(function(callbackParams){
					if(callbackParams.errors) return;
					this.afsfSplitTelno(this.dsSchpaInfo, "mblTelno");
				}) // 콜백
			;
		});
}


this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	this.dsSchpaInfo.set_updatecontrol(false);
	//전화번호 결합
	var telno1 = this.dsSchpaInfo.getColumn(0,"mblTelno1");	
	var telno2 = this.dsSchpaInfo.getColumn(0,"mblTelno2");	
	var telno3 = this.dsSchpaInfo.getColumn(0,"mblTelno3");
	
	if (telno1 == "" || telno2 == "" || telno3 == "") {
		this.smfAlert('전화번호를 정확히 입력하세요.');
		return false;
	}
	
	var telno = [telno1,telno2,telno3].join("-"); 
	if ( telno == "--" ) telno = "";

	if (telno == "") {
		this.smfAlert('전화번호를 입력하세요.');
		return false;
	}
	
	if (this.smfIsNull(this.div00.form.calClaiBrdt.value)) {
		this.smfAlert('생년월일를 입력하세요.');
		return false;
	}
	
	var chkList = this.dsResult.extractRows("apsRelCd == '' ");
	
	if (chkList.length > 0){
		this.smfAlert('유아와의 관계를 입력하세요.');
		return;
	}
	
	var nRows = this.dsResult.extractRows("aprvStsCd == '신규'");
	if(nRows.length > 0 || this.dsResult.getRowCount() == 0){
		if (this.div02.form.chk00.value != "Y"){
			this.smfAlert("개인정보 수집·이용 동의가 필요합니다.", function(){
				this.div02.form.chk00.setFocus();
			});
			
			return false;
		}
	}
	
	this.dsSchpaInfo.setColumn(0, "mblTelno", telno);
	
	this.dsSchpaInfo.set_updatecontrol(true);

	var message = "입력하신 전화 번호 " + this.dsSchpaInfo.getColumn(0,"mblTelno") + " 정확한지 확인하세요.\n"
	            + "전화가 번호가 틀린 경우 알림 등의 서비스를 받지 못할 수 있습니다.\n"

	this.smfAlert(message, this.fnMessageCallback);

};

this.fnAgreePersInfo = function(){
	var pType = "none";
	
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback : this.fnPopupCallback, // 콜백함수 지정
		sender : "agreePersInfo", // sender 지정
		// 팝업 전달 파라메터 지정
		params : {
			// 처리타입 지정
			procType	: pType,
			sAgree		: this.fv_sAgree
		},
	};
	
	var srcInfo = this.smfCurScreenInfo();
	var srcInfoW = 940;
	var srcInfoH = 612 + 45;
		
	if(this.smfIsMobile()){		
		srcInfoW = 640;
		if(srcInfo[1] > 1187 + 65){
			srcInfoH = 1187 + 65;
		}else{
			srcInfoH = srcInfo[1];
		}
	}
	
	this.smfDialog("_auto", "pa_par_sps_cm::par_spscm04_p00.xfdl", popupParams, "", "", srcInfoW, srcInfoH);
}]]></Script>
