<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="par_spscm03_p01" width="640" height="682" titletext="학부모서비스를 가장 잘 활용하는 방법" onload="par_spscm03_p01_onload">
    <Layouts>
      <Layout height="682" width="640" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="24" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Static id="Static99_00_00_00_00" taborder="25" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0"/>
        <Static id="Static99_00_00_00_00_00_00" taborder="26" left="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" height="20" top="0"/>
        <Static id="Static99_00_00_00_00_01" taborder="27" left="620" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0"/>
        <ImageViewer id="titleResult" taborder="0" text="내 자녀 손쉽게 등록하기" left="18" top="19" width="388" height="30" cssclass="img_WF_SubTit03" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="label00_00" taborder="1" text="&lt;b v='true'&gt;* 학부모서비스 자녀등록&lt;/b&gt;" left="20" top="69" height="22" initvalueid="ivStcAccessibilityOn" right="20" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char"/>
        <Static id="label00_00_01_02" taborder="28" left="20" top="91" height="22" initvalueid="ivStcAccessibilityOn" onclick="div00_label00_00_onclick" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height" text="-" verticalAlign="top" width="20"/>
        <Static id="label00_00_01" taborder="2" text="학부모서비스는 유치원 자녀부터 초등학교, 중학교, 고등학교 자녀까지 등록이 가능합니다." left="31" top="91" height="22" initvalueid="ivStcAccessibilityOn" right="20" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height"/>
        <Static id="label00_00_01_02_00" taborder="29" left="20" top="113" height="22" initvalueid="ivStcAccessibilityOn" onclick="div00_label00_00_onclick" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height" text="-" verticalAlign="top" width="20"/>
        <Static id="label00_00_01_00" taborder="3" text="다자녀 등록이 가능하며, 유치원 및 초중고등학교 자녀와 함께 등록할 수 있습니다. " left="31" top="113" height="22" initvalueid="ivStcAccessibilityOn" right="20" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height"/>
        <Static id="label00_00_02_00" taborder="4" text="&lt;b v='true'&gt;* 학부모 서비스 이용 방법&lt;/b&gt;" left="20" top="150" height="22" initvalueid="ivStcAccessibilityOn" right="20" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height"/>
        <Static id="label00_00_01_01_00" taborder="5" text="﻿(1) 4세대 학부모서비스 접속: https://parents.neis.go.kr 접속" left="20" top="172" height="22" initvalueid="ivStcAccessibilityOn" right="20" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height"/>
        <Static id="label00_00_01_01_00_00" taborder="6" text="(2) 학부모서비스 로그인: 아이디/패스워드 로그인 또는 디지털원패스 로그인" left="20" top="194" height="22" initvalueid="ivStcAccessibilityOn" right="20" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height"/>
        <Static id="label00_00_01_01_00_00_01" taborder="7" text="(3) (학부모서비스 메인화면) &lt;b v='true'&gt;'자녀등록하기'&lt;/b&gt; 클릭" left="20" top="216" height="22" initvalueid="ivStcAccessibilityOn" right="20" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height"/>
        <Static id="label00_00_01_01_00_00_00_00_00" taborder="8" text="(자녀 프로필 화면) &lt;b v='true'&gt;'자녀정보관리'&lt;/b&gt; 클릭" left="40" top="238" height="22" initvalueid="ivStcAccessibilityOn" right="20" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height"/>
        <Static id="label00_00_01_01_00_00_01_00" taborder="9" text="(4) (자녀정보관리) '유치원 자녀등록', '초중등 자녀등록' 버튼 클릭" left="20" top="260" height="22" initvalueid="ivStcAccessibilityOn" right="20" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height"/>
        <Static id="label00_00_01_01_00_00_01_00_00" taborder="10" text="(5) &lt;b v='true'&gt;자녀의 소속 유형별 상세 등록 방법&lt;/b&gt;" left="20" top="282" height="22" initvalueid="ivStcAccessibilityOn" right="20" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height"/>
        <Static id="label00_00_01_02_00_00_00_01" taborder="30" left="20" top="304" height="22" initvalueid="ivStcAccessibilityOn" onclick="div00_label00_00_onclick" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height" text="&lt;b v='true'&gt;-&lt;/b&gt;" verticalAlign="top" textAlign="right" width="20"/>
        <Static id="label00_00_01_01_00_00_00_02" taborder="11" text="&lt;b v='true'&gt;유치원 자녀 등록&lt;fc v='red'&gt;(자녀등록 및 신청 → 소속 유치원 승인)&lt;/fc&gt;&lt;/b&gt;" left="43" top="304" height="22" initvalueid="ivStcAccessibilityOn" right="20" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height"/>
        <Static id="label00_00_01_01_00_00_01_00_00_00" taborder="12" text="① 학부모의 유아 자녀 등록 화면에서 '추가‘ 버튼 클릭" left="43" top="326" height="22" initvalueid="ivStcAccessibilityOn" right="20" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height"/>
        <Static id="label00_00_01_01_00_00_00_02_00" taborder="13" text="② 유아명과 생년월일을 입력하고 소속 유치원을 조회" left="43" top="348" height="22" initvalueid="ivStcAccessibilityOn" right="20" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height"/>
        <Static id="label00_00_01_01_00_00_01_00_00_00_00" taborder="14" text="③ 조회된 유아 정보 확인하여 ＇등록＇ 버튼 클릭" left="43" top="370" height="22" initvalueid="ivStcAccessibilityOn" right="20" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height"/>
        <Static id="label00_00_01_01_00_00_01_00_00_00_00_00" taborder="15" text="④ (소속 유치원 승인) 소속 유치원 선생님 승인" left="43" top="392" height="22" initvalueid="ivStcAccessibilityOn" right="20" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height"/>
        <Static id="label00_00_01_01_00_00_00_02_01" taborder="16" text="&lt;b v='true'&gt;초중고등학교 자녀 등록&lt;fc v='red'&gt;(자녀 등록 및 신청 → 나이스플러스 자녀 계정에서 학부모 정보제공 동의)&lt;/fc&gt;&lt;/b&gt;" left="43" top="414" height="22" initvalueid="ivStcAccessibilityOn" right="20" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height"/>
        <Static id="label00_00_01_02_00_00_00_01_00" taborder="31" left="20" top="414" height="22" initvalueid="ivStcAccessibilityOn" onclick="div00_label00_00_onclick" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height" text="&lt;b v='true'&gt;-&lt;/b&gt;" verticalAlign="top" textAlign="right" width="20"/>
        <Static id="label00_00_01_01_00_00_01_00_00_00_01" taborder="17" text="① 제3자 정보제공 동의 확인" left="43" top="436" height="22" initvalueid="ivStcAccessibilityOn" right="20" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height"/>
        <Static id="label00_00_01_01_00_00_01_00_00_00_01_00" taborder="18" text="② 자녀의 정확한 정보(소속학교명, 학년, 반, 번호, 학생명) 조회 및 입력" left="43" top="458" height="22" initvalueid="ivStcAccessibilityOn" right="20" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height"/>
        <Static id="label00_00_01_01_00_00_01_00_00_00_01_00_00" taborder="19" text="③ 조회된 학생 정보 확인하여 '등록' 버튼 클릭" left="43" top="480" height="22" initvalueid="ivStcAccessibilityOn" right="20" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height"/>
        <Static id="label00_00_01_01_00_00_01_00_00_00_01_00_00_00" taborder="20" text="④ (학생 승인) 나이스플러스 학생(자녀) 계정 로그인 → 나의정보관리-보호자승인관리 → 학부모 확인 후 저장" left="43" top="502" height="42" initvalueid="ivStcAccessibilityOn" right="20" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height"/>
        <Static id="label00_00_01_01_00_00_01_00_00_00_01_00_00_01" taborder="21" text="※ 나이스플러스에서 학생 계정으로 승인하기 어려운 경우, 선생님께서 학부모서비스 승인 처리 지원 가능" left="43" top="544" height="42" initvalueid="ivStcAccessibilityOn" right="20" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height"/>
        <Static id="label00_00_01_01_00_00_01_00_01" taborder="22" text="(6) 학부모서비스에서 등록된 자녀 정보 확인" left="20" top="586" height="22" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Black14" usedecorate="true" wordWrap="char" fittocontents="height" right="20"/>
        <Button id="btnClose" taborder="23" text="닫기" height="34" left="283" initvalueid="ivBtnAccessibilityButton" top="628" onclick="btnClose_onclick" width="74"/>
      </Layout>
