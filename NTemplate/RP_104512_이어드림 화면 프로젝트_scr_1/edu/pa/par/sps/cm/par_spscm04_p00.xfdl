    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 > 학부모서비스(유) > 개인정보수집이용동의
*  @FileName 	par_spscm04_p00
*  @Creator 	문형선
*  @CreateDate 	2022.07.14
*  @Desction    개인정보수집이용동의
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.07.14            문형선                   최초 생성 
*******************************************************************************
*/ 

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
//include "lib::cm_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
//this.fv_sType = "";
this.fv_chkPersonalInfo = false;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{ 
	//폼을 초기화 
	this.smfInitPopup(obj);
	
	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	var sAgree = this.pv_params.sAgree;
	
	if(!this.smfIsNull(sAgree)){
		this.divDetail.form.rdoPersonalInfo.set_value(sAgree);
		this.divDetail.form.chkLegalRepr.set_value("Y");
	}
	
	var objParForm = this.opener.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form;
	
	var sYear  = this.smfSubStr(objParForm.dsStuIduzEduYn.getColumn(0, "toDay"), 0, 4);
	var sMonth = this.smfSubStr(objParForm.dsStuIduzEduYn.getColumn(0, "toDay"), 4, 6);
	var sDay   = this.smfSubStr(objParForm.dsStuIduzEduYn.getColumn(0, "toDay"), 6, 8);
	
	var objDate = new Date();
	sYear  = objDate.getFullYear().toString();
	sMonth = objDate.getMonth() + 1;
	sDay = objDate.getDate();
	
	this.divDetail.form.staToDay.set_text(sYear + "년    " + sMonth + "월    " + sDay + "일");
	this.divDetail.form.staLegalRepr.set_text("보호자(법정대리인)   성명 :  " + objParForm.dsSchpaInfo.getColumn(0, "schpaNm"));		
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

this.btnOk_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	
	if(this.smfIsNull(this.divDetail.form.rdoPersonalInfo.value)){
		this.smfAlert("개인정보 수집·이용 동의 여부를 선택하여 주세요.", function(){
				this.divDetail.form.chkLegalRepr.setFocus();
			});
			return false;
	}else{	
		if(this.divDetail.form.chkLegalRepr.value != "Y"){
			this.smfAlert("만 14세 미만의 경우 \"개인정보 수집·이용 동의\"를 위한 \n보호자(법정대리인)의 동의가 필요합니다.", function(){
				this.divDetail.form.chkLegalRepr.setFocus();
			});
			return false;
		}
	}
	
	if(this.divDetail.form.rdoPersonalInfo.value != "Y"){
		this.smfConfirm("개인정보 수집·이용 동의를 하지 않는 경우\n자녀를 등록하실 수 없습니다.\n계속 지행하시겠습니까?",function(result){			
			if(result.confirmResult){
				this.smfSendResponseToOpener({
					"agreePersInfo": "N"
				}, "par_spscm04_p00");	
				this.close(true);
			}else {
				return false;
			}
		});
	}else{
		this.smfSendResponseToOpener({
			"agreePersInfo": "Y"
		}, "par_spscm04_p00");	
		
		this.close(true);
	}
};

this.btn_close_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};]]></Script>
