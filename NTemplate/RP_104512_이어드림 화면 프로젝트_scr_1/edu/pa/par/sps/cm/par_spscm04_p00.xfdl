      <BindItem id="item11" compid="divDetail.form.edtExperDays" propid="value" datasetid="dsExperLrn" columnid="abeDdCnt"/>
      <BindItem id="item12" compid="divDetail.form.edtApsTelno" propid="value" datasetid="dsExperLrn" columnid="apsTelno"/>
