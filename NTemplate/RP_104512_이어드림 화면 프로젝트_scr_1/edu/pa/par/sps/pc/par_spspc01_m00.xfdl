                <Formats>
                  <Format id="default">
                    <Columns>
                      <Column size="228"/>
                      <Column size="100"/>
                      <Column size="80"/>
                      <Column size="80"/>
                      <Column size="150"/>
                      <Column size="150"/>
                      <Column size="150"/>
                      <Column size="150"/>
                      <Column size="109"/>
                    </Columns>
                    <Rows>
                      <Row size="36" band="head"/>
                      <Row size="40"/>
                    </Rows>
                    <Band id="head">
                      <Cell text="유치원"/>
                      <Cell col="1" text="청구년도"/>
                      <Cell col="2" text="청구분기"/>
                      <Cell col="3" text="청구월"/>
                      <Cell col="4" text="교육과정비(원)"/>
                      <Cell col="5" text="방과후 과정비(원)"/>
                      <Cell col="6" text="추가 지원금(원)"/>
                      <Cell col="7" text="청구합계(원)"/>
                      <Cell col="8" text="청구상태"/>
                    </Band>
                    <Band id="body">
                      <Cell text="bind:shlNm" textAlign="center" suppress="1" suppressalign="middle"/>
                      <Cell col="1" text="bind:sprtAyr" textAlign="center" suppress="2" suppressalign="middle"/>
                      <Cell col="2" displaytype="normal" edittype="none" text="bind:qtr" textAlign="center" suppress="3" suppressalign="middle"/>
                      <Cell col="3" text="bind:clmMm"/>
                      <Cell col="4" textAlign="right" text="bind:eduCrseAmt" displaytype="mask" maskeditformat="999,999,999"/>
                      <Cell col="5" textAlign="right" text="bind:aslCrseAmt" displaytype="mask" maskeditformat="999,999,999"/>
                      <Cell col="6" textAlign="right" text="bind:clclnAmt" displaytype="mask" maskeditformat="999,999,999"/>
                      <Cell col="7" textAlign="right" text="bind:clmTtlAmt" displaytype="mask" maskeditformat="999,999,999"/>
                      <Cell col="8" textAlign="center" text="expr:comp.parent.parent.parent.fnClmYnText(clmYn)"/>
                    </Band>
                  </Format>
                  <Format id="format00">
                    <Columns>
                      <Column size="220" band="left"/>
