                    <Band id="head">
                      <Cell text="유치원"/>
                      <Cell col="1" text="청구년도"/>
                      <Cell col="2" text="청구분기"/>
                      <Cell col="3" text="청구월"/>
                      <Cell col="4" text="교육과정비(원)"/>
