                      <Cell row="5" col="1" text="bind:aslCrseAmt" displaytype="mask" textAlign="left" maskeditformat="999,999,999" maskedittype="number"/>
                      <Cell row="6" text="추가 지원금(원)" cssclass="cell_WF_Label"/>
                      <Cell row="6" col="1" text="bind:clclnAmt" displaytype="mask" textAlign="left" maskeditformat="999,999,999" maskedittype="number"/>
                      <Cell row="7" text="청구합계(원)" cssclass="cell_WF_Label"/>
                      <Cell row="7" col="1" displaytype="mask" text="bind:clmTtlAmt" textAlign="left" maskeditformat="999,999,999" maskedittype="number"/>
                      <Cell row="8" text="청구상태" cssclass="cell_WF_Label, cell_WF_MiddleLine"/>
                      <Cell row="8" col="1" text="expr:comp.parent.parent.parent.fnClmYnText(clmYn)" cssclass="cell_WF_MiddleLine"/>
