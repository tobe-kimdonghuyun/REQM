                      <Cell col="1" text="bind:sprtAyr" textAlign="center" suppressalign="middle" suppress="2"/>
                      <Cell col="2" displaytype="normal" edittype="none" text="bind:qtr" textAlign="center" suppress="3" suppressalign="middle"/>
                      <Cell col="3" text="bind:clmMm"/>
                      <Cell col="4" textAlign="right" text="bind:eduCrseAmt" displaytype="mask" maskeditformat="999,999,999"/>
                      <Cell col="5" textAlign="right" text="bind:clclnAmt" displaytype="mask" maskeditformat="999,999,999"/>
                      <Cell col="6" textAlign="right" text="bind:aslCrseAmt" displaytype="mask" maskeditformat="999,999,999"/>
                      <Cell col="7" textAlign="right" text="bind:clmTtlAmt" displaytype="mask" maskeditformat="999,999,999"/>
                      <Cell col="8" textAlign="center" text="expr:comp.parent.parent.parent.fnClmYnText(clmYn)"/>
