                      <Cell col="1" text="bind:shlNm" textAlign="left"/>
                      <Cell row="1" text="청구년도" cssclass="cell_WF_Label"/>
                      <Cell row="1" col="1" text="bind:sprtAyr"/>
                      <Cell row="2" text="청구분기" cssclass="cell_WF_Label"/>
                      <Cell row="2" col="1" text="bind:qtr"/>
