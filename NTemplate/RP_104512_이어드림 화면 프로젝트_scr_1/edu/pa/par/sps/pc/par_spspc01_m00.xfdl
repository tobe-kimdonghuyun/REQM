    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 학부모서비스(유)
*  @MenuPath    TEMPLATE
*  @FileName 	par_spspc01_moo.xfdl
*  @Creator 	
*  @CreateDate 	2022.07.04
*  @Desction    학부모 청구
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.07.04     	문형선 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::par_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(this);
	
	//검색영역 초기화처리를 한다.
	var objParForm = this.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form;
	this.dsSearch.copyRow(0, objParForm.dsStuIduzEduYn, 0);
	this.dsSearch.setColumn(0, "clmYn", "");
	
	//학년도 조건 목록
	this.dsSearchAyr.copyData(objParForm.dsStuAyrList);
	
	this.divSearch.form.cboSearchAyr.set_index(0);
	//this.smfResetScroll(this);
	
	if(objParForm.fv_stuLoad){
		//소재정보, 개인번호 체크
		var validate = this.parfValidate(this.dsSearch);	
		if(!validate) return false;
		
		this.divSearch.form.btnSearch.click();
	}
	
	
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//소재정보, 개인번호 체크
	var validate = this.parfValidate(this.dsSearch);	
	if(!validate) return false;
	
	// 서비스 객체 생성
	this.smfSearchService("selectClmList")		
		.validateForm(this.divSearch)
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});	
};

this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 서비스 객체 생성 
	this.smfSaveService("updateClmYn")
		.messagePrefix("청구")
		// 데이터 존재 필수
//		.requireExistsData(this.dsInfntSceSprtList)
//		.validateGrid(this.grdInfntSceSprtList, this.dsInfntSceSprtListValid)
// 		// 데이터 검증
//		.validateForm(this.divCardNo)
// 		// 데이터 변경 필수
// 		.requireModifredData(this.dsExperlrnInfo)
// 		// 중복검사
// 		.validateDuplicate({
// 			grid: this.grdMain,
// 			// gridText: "음반목록",
// 			columnNames: ["name", "artist", "release"], // 중복검사할 컬럼명
// 			columnText: "이름, 아티스트, 출시일자",
// 		})

		// 실행
		.run() 

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			// 저장이 완료되었습니다.
			// 재조회
			this.smfAlert(this.smfAfterServiceMessage());
		});
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
	
	if(svcid == "selectClmList" || svcid == "updateClmYn"){
	
		if(this.smfIsMobile()){
			var grdH = this._smfappendHeight(this.divGrd.form.grdMain);
			if(this.dsClmList.getRowCount() == 0 ) grdH = 365;
			this.divGrd.form.grdMain.setOffsetHeight(grdH);
			this.divGrd.setOffsetHeight(grdH);
			this.smfResetScroll(this);	
		}

		if(this.dsClmList.getRowCount() > 0 && this.dsClmList.getColumn(0, "trstAgreYn") == "N" && this.dsClmList.findRowExpr("clmYn == 'N'") > -1){
			this.btnSave.set_enable(true);
			this.staClmYnTit.set_visible(false);
			this.btnSave.set_visible(true);
		}else if(this.dsClmList.getRowCount() > 0 && this.dsClmList.getColumn(0, "trstAgreYn") == "Y"){
			this.btnSave.set_visible(false);
			this.staClmYnTit.set_visible(true);
		}else{
			this.btnSave.set_enable(false);
			this.staClmYnTit.set_visible(false);
			this.btnSave.set_visible(true);
		}
	}
	if(this.dsChildInfo.getRowCount() > 0){
		this.imgName.set_text("이름: " + this.dsChildInfo.getColumn(0, "stuFlnm") + "(" + this.dsChildInfo.getColumn(0, "sxdsScCd") + ")");
	}
};

this.fnClmYnText = function(clmYn){
	if(clmYn == "Y"){
		return "청구완료";
	}else if(clmYn == "N"){
		return "미청구";
	}else{
		return "-";
	}
};]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">selectClmList</Col>
            <Col id="inDatasets">dsSearch</Col>
            <Col id="outDatasets">dsClmList dsChildInfo</Col>
            <Col id="url">par_sps_pc01_001.do</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="inDatasets">dsSearch dsClmList</Col>
            <Col id="outDatasets">dsClmList dsChildInfo</Col>
            <Col id="asynctp"/>
            <Col id="url">par_sps_pc01_002.do</Col>
            <Col id="id">updateClmYn</Col>
          </Row>
        </Rows>
      </Dataset>
