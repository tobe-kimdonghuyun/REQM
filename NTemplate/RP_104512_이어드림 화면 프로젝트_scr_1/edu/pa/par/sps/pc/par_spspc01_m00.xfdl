          <Column id="infntShepSprtQtrCd" type="STRING" size="2" sumtext="분기구분코드"/>
          <Column id="qtr" type="STRING" size="10" sumtext="분기"/>
          <Column id="clmMm" type="STRING" size="256"/>
          <Column id="stuInvlNo" type="STRING" size="10" sumtext="학생개인번호"/>
          <Column id="stuFlnm" type="STRING" size="100" sumtext="학생이름"/>
          <Column id="sxdsScCd" type="STRING" size="1" sumtext="학생성별"/>
          <Column id="eduCrseAmt" type="STRING" size="15" sumtext="교육과정금액"/>
          <Column id="aslCrseAmt" type="STRING" size="15" sumtext="방과후과정금액"/>
          <Column id="clclnAmt" type="STRING" size="15" sumtext="추가지원금액"/>
          <Column id="clmTtlAmt" type="STRING" size="15" sumtext="청구합계금액"/>
