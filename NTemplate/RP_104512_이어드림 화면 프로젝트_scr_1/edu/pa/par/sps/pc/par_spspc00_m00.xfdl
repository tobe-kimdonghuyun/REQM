      <BindItem id="item0" compid="divCardNo.form.edtAckyCardNoFirst" propid="value" datasetid="dsSearch" columnid="ackyCardNoFirst"/>
      <BindItem id="item1" compid="divCardNo.form.edtAckyCardNoEnd" propid="value" datasetid="dsSearch" columnid="ackyCardNoEnd"/>
    </Bind>
  </Form>
