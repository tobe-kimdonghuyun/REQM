    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 학부모서비스(유)
*  @MenuPath    TEMPLATE
*  @FileName 	par_spsci00_m00.xfdl
*  @Creator 	
*  @CreateDate 	2022.07.04
*  @Desction    생활기록부조회
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.07.04     	홍길동 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::par_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(this);
	
	//검색영역 초기화처리를 한다.
	var objParForm = this.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form;
	this.dsSearch.copyRow(0, objParForm.dsStuIduzEduYn, 0);
	//학부모명, 학부모 생년월일 설정
	this.dsSearch.setColumn(0, "cardUserNm", objParForm.dsSchpaInfo.getColumn(0, "schpaNm"));
	this.dsSearch.setColumn(0, "schpaBrdt", objParForm.dsSchpaInfo.getColumn(0, "brdt"));
	
	this.sta03.set_text(objParForm.dsSchpaInfo.getColumn(0, "schpaNm")+" 님 자녀의 유아학비 지원자격 및 지원정보 입니다.");
	
	if(objParForm.fv_stuLoad){
		//소재정보, 개인번호 체크
		var validate = this.parfValidate(this.dsSearch);	
		if(!validate) return false;
	}
	
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
 	//소재정보, 개인번호 체크
	var validate = this.parfValidate(this.dsSearch);	
	if(!validate) return false;
	
	this.dsSearch.setColumn(0, "prcsSc", "1");

	// 서비스 객체 생성
	this.smfSearchService("selectChldInfo")		
		.validateForm(this.divCardNo)
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			//임시(23.9월 유아학비 오픈 이후 삭제) - 유치원청구위임을 강제로 "Y"로 설정한다. START
			/*
			this.dsSchpaClmTrstList.set_enableevent(false);
			this.dsSchpaClmTrstList.setColumn(0, "trstAgreYn", "Y");
			this.dsSchpaClmTrstList.setColumn(0, "schpaSvcClmYn", "N");
			this.dsSchpaClmTrstList.set_enableevent(true);
			//임시(23.9월 유아학비 오픈 이후 삭제) - 유치원청구위임을 강제로 "Y"로 설정한다. END
			*/
			
			// 유치원청구위임이 "Y"가 되도록 기본값 설정
			if(this.dsSchpaClmTrstList.getColumn(0, "schpaSvcClmYn") != "Y"){
				this.dsSchpaClmTrstList.set_enableevent(false);
				this.dsSchpaClmTrstList.setColumn(0, "trstAgreYn", "Y");
				this.dsSchpaClmTrstList.setColumn(0, "schpaSvcClmYn", "N");
				this.dsSchpaClmTrstList.set_enableevent(true);
			}
			
			if(this.dsInfntSceSprtList.getRowCount() > 0){
				this.btnSave.set_enable(true);
			}else{
				this.btnSave.set_enable(false);
			}
			
			var sprtAprvStsCd = this.dsInfntSceSprtList.getColumn(0, "sprtAprvStsCd");
			
			if(sprtAprvStsCd == 'APA17' || sprtAprvStsCd == 'APA02'){
				this.btnSave.set_enable(false);
				this.divGrd01.form.grdInfntSceSprtList.set_enable(false);
				this.divGrd02.form.grdSchpaClmTrstList.set_enable(false);
				this.sta00_00_00_00_00_00_00_00_01.set_visible(true);
				
				var text = "이미 인증된 카드입니다.\n추가로 인증절차를 진행하실 필요가 없습니다.";
				
				this.smfAlert(text);
			}else{
				this.btnSave.set_enable(true);
				this.divGrd01.form.grdInfntSceSprtList.set_enable(true);
				this.divGrd02.form.grdSchpaClmTrstList.set_enable(true);
				this.sta00_00_00_00_00_00_00_00_01.set_visible(false);
			}
			this.smfResetScroll(this);
		});	
};

this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(!this.chkAgmt01.isChecked()){
		this.smfAlert("개인정보 수집 및 이용 동의가 필요합니다.");
		this.chkAgmt01.setFocus();
		return false;
	}
	
	var agreYn = this.dsInfntSceSprtList.getColumn(0, "infntShepSprtAplyAgreYn");
	if(this.smfIsNull(agreYn) || agreYn == "N"){
		this.smfAlert("유아학비지원 동의여부를 체크하세요.");
		return false;
	}else{
		this.dsSchpaClmTrstList.setColumn(0, "infntShepSprtAplyAgreYn", agreYn);
	}
	
	var kndgrTrstYn = this.dsSchpaClmTrstList.getColumn(0, "trstAgreYn");
	var schpaSvcClmYn = this.dsSchpaClmTrstList.getColumn(0, "schpaSvcClmYn");
	
	if((this.smfIsNull(kndgrTrstYn) || kndgrTrstYn == "N") && (this.smfIsNull(schpaSvcClmYn) || schpaSvcClmYn == "N")){
		this.smfAlert("유치원 위임 또는 학부모 청구를 체크하세요.");
		return false;
	}
	
	this.dsSearch.setColumn(0, "prcsSc", "2");
	// 서비스 객체 생성 
	this.smfSaveService("updateAgreYnSbmsn")
		.messagePrefix(obj.text)
		// 데이터 존재 필수
//		.requireExistsData(this.dsInfntSceSprtList)
//		.validateGrid(this.grdInfntSceSprtList, this.dsInfntSceSprtListValid)
// 		// 데이터 검증
//		.validateForm(this.divCardNo)
// 		// 데이터 변경 필수
// 		.requireModifredData(this.dsExperlrnInfo)
// 		// 중복검사
// 		.validateDuplicate({
// 			grid: this.grdMain,
// 			// gridText: "음반목록",
// 			columnNames: ["name", "artist", "release"], // 중복검사할 컬럼명
// 			columnText: "이름, 아티스트, 출시일자",
// 		})

		// 실행
		.run() 

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			var sprtAprvStsCd = this.dsInfntSceSprtList.getColumn(0, "sprtAprvStsCd");
			
			if(sprtAprvStsCd == 'APA17' || sprtAprvStsCd == 'APA02'){
				this.btnSave.set_enable(false);
				this.divGrd01.form.grdInfntSceSprtList.set_enable(false);
				this.divGrd02.form.grdSchpaClmTrstList.set_enable(false);
				this.sta00_00_00_00_00_00_00_00_01.set_visible(true);
			}else{
				this.btnSave.set_enable(true);
				this.divGrd01.form.grdInfntSceSprtList.set_enable(true);
				this.divGrd02.form.grdSchpaClmTrstList.set_enable(true);
				this.sta00_00_00_00_00_00_00_00_01.set_visible(false);
			}
			
			// 저장이 완료되었습니다.
			// 재조회
			this.smfAlert(this.smfAfterServiceMessage());
		});
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
	
	if(svcid == "selectChldInfo"){
		if(errcd == "FAIL" && errmsg != "SUCCESS"){
			this.smfAlert(errmsg);
		}
	}
};

this.dsSchpaClmTrstList_oncolumnchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	this.dsSchpaClmTrstList.set_enableevent(false);
	if("trstAgreYn" == e.columnid){
		if(this.dsSchpaClmTrstList.getColumn(0, e.columnid) == "Y"){
			this.dsSchpaClmTrstList.setColumn(0, "schpaSvcClmYn", "N");
		}else{
			this.smfAlert("학부모 청구 선택 시 매분기 청구 신청이 필요하며, \n유치원 위임 시 자동청구 됩니다.");
			this.dsSchpaClmTrstList.setColumn(0, "schpaSvcClmYn", "Y");
		}
	}else if("schpaSvcClmYn" == e.columnid){
		if(this.dsSchpaClmTrstList.getColumn(0, e.columnid) == "Y"){
			this.smfAlert("학부모 청구 선택 시 매분기 청구 신청이 필요하며, \n유치원 위임 시 자동청구 됩니다.");
			this.dsSchpaClmTrstList.setColumn(0, "trstAgreYn", "N");
		}else{
			this.dsSchpaClmTrstList.setColumn(0, "trstAgreYn", "Y");
		}
	}
	this.dsSchpaClmTrstList.set_enableevent(true);
};

//개인정보수집 동의
this.btnOk_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.chkAgmt01.set_value(true);
	this.chkAgmt02.set_value(true);
};


this.par_spspc00_m00_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnSetResize();
};

//컨텐츠 리사이징
this.fnSetResize = function(){
	this.div00.form.resetScroll();
	this.div00.setOffsetHeight(parseInt(this.div00.form.sta00_00_00_00_00_00_00_00_01.getOffsetBottom(),10)+35);
	this.smfResetScroll(this.div00);
	
	this.resetScroll();
}]]></Script>
