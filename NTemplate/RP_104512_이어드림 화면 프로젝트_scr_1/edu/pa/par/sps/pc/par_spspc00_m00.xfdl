          <Layouts>
            <Layout>
              <Grid id="grdInfntSceSprtList" taborder="0" left="0" binddataset="dsInfntSceSprtList" autofittype="col" top="0" selecttype="cell" right="0" initvalueid="ivGrdAccessibilityOn" accessibilitylabel="유아학비지원 동의 목록" bottom="0" scrollbartype="none">
                <Formats>
                  <Format id="default">
                    <Columns>
                      <Column size="128"/>
                      <Column size="120"/>
                      <Column size="120"/>
                      <Column size="120"/>
                      <Column size="120"/>
                      <Column size="120"/>
                      <Column size="124"/>
                      <Column size="105"/>
                    </Columns>
                    <Rows>
                      <Row size="36" band="head"/>
                      <Row size="40"/>
                    </Rows>
                    <Band id="head">
                      <Cell text="성명"/>
                      <Cell col="1" text="생년월일"/>
                      <Cell col="2" text="자격시작일"/>
                      <Cell col="3" text="자격종료일"/>
                      <Cell col="4" text="지원시작일"/>
                      <Cell col="5" text="지원종료일"/>
                      <Cell col="6" text="카드인증여부"/>
                      <Cell col="7" text="동의여부"/>
                    </Band>
                    <Band id="body">
                      <Cell displaytype="normal" text="bind:stuFlnm" textAlign="center"/>
                      <Cell col="1" text="bind:stuBrdt" displaytype="mask" edittype="none" textAlign="center" calendardateformat="yyyy-MM-dd" maskeditformat="@@@@.@@.@@." maskedittype="string"/>
                      <Cell col="2" text="bind:startDay" textAlign="center" maskedittype="string" maskeditformat="@@@@.@@.@@." displaytype="mask"/>
                      <Cell col="3" text="bind:endDay" textAlign="center" maskedittype="string" maskeditformat="@@@@.@@.@@." displaytype="mask"/>
                      <Cell col="4" text="bind:sprtBgngYmd" textAlign="center" displaytype="mask" maskedittype="string" maskeditformat="@@@@.@@.@@."/>
                      <Cell col="5" text="bind:sprtEndYmd" textAlign="center" displaytype="mask" maskedittype="string" maskeditformat="@@@@.@@.@@."/>
                      <Cell col="6" text="bind:sprtAprvStsCd" textAlign="center" expr="sprtAprvStsCd == &quot;APA17&quot; ? '카드인증' : (sprtAprvStsCd == &quot;APA02&quot; ? '카드인증승인' : '미인증')"/>
                      <Cell col="7" displaytype="checkboxcontrol" edittype="checkbox" text="bind:infntShepSprtAplyAgreYn" textAlign="center" checkboxfalsevalue="N" checkboxtruevalue="Y"/>
                    </Band>
                  </Format>
