          <Column id="stuInvlNo" type="STRING" size="18" sumtext="" description="학생개인번호"/>
          <Column id="ackyCardNoFirst" type="STRING" size="4" sumtext="" description="인증카드첫째번호"/>
          <Column id="ackyCardNoEnd" type="STRING" size="4" sumtext="" description="인증카드마지막번호"/>
          <Column id="prcsSc" type="STRING" size="2" sumtext="" description="처리구분"/>
          <Column id="schpaDtcNo" type="STRING" size="32" sumtext="" description="학부모고유번호"/>
          <Column id="cddcScCd" type="STRING" size="3"/>
          <Column id="sprtYr" type="STRING" size="4" description="지원연도"/>
