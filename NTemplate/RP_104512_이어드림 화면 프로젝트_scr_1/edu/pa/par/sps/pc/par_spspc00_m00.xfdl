          <Column id="stuInvlNo" type="STRING" size="10" sumtext="" description="학생개인번호"/>
          <Column id="stuDtcNo" type="STRING" size="256"/>
          <Column id="stuFlnm" type="STRING" size="100" sumtext="" description="성명"/>
          <Column id="stuBrdt" type="STRING" size="8" sumtext="" description="생년월일"/>
          <Column id="startDay" type="STRING" size="8" sumtext="" description="자격시작일자"/>
          <Column id="endDay" type="STRING" size="8" sumtext="" description="자격종료일자"/>
          <Column id="sprtBgngYmd" type="STRING" size="8" sumtext="" description="지원시작일자"/>
          <Column id="sprtEndYmd" type="STRING" size="8" sumtext="" description="지원종료일자"/>
          <Column id="infntShepSprtAplyAgreYn" type="STRING" size="1" sumtext="" description="유아학비지원신청여부(임시)"/>
