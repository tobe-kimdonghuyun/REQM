        <Static id="sta00" taborder="1" text="※ 카드번호를 입력하시면 카드 소지자의 자녀가 조회됩니다." left="0" top="134" width="824" height="25" cssclass="sta_WF_Blue14" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta02" taborder="2" text="※ 학부모 청구 위임 여부를 선택해주세요.&#13;&#10; - 유치원 위임: 입학 시 1회 유아학비지원 카드 인증 시 청구 위임(이후 유치원 일괄처리)&#13;&#10; - 학부모 서비스 청구: 분기별 학부모 서비스 접속하여 청구" left="0" top="159" width="824" height="65" cssclass="sta_WF_Blue14" initvalueid="ivStcAccessibilityOn"/>
        <Static id="Static001" taborder="17" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static002" taborder="18" left="0" top="114" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <ImageViewer id="imgTitle01" taborder="3" text="개인정보 수집 및 이용" left="1" top="255" height="30" cssclass="img_WF_SubTit04" width="230" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="Static003_00" taborder="15" left="1" top="285" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="-1" initvalueid="ivStcAccessibilityOff"/>
        <Div id="div00" taborder="4" left="1" top="295" height="354" cssclass="div_WF_KinderBox" right="0" initvalueid="ivDivAccessibilityOff" text="">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" text="나이스 학부모서비스는 양질의 서비스 제공을 위하여 정보주체의 동의에 따라 다음과 같이 최소한의 개인정보를 수집하고 있습니다. " left="30" top="40" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="29"/>
              <Static id="sta00_00" taborder="1" text="수집한 개인정보는 본 수집이용 목적 외의 다른 목적으로 사용되지 않습니다." left="30" top="sta00:0" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="29"/>
              <Static id="sta00_00_00" taborder="2" text="■ 수집 및 이용 항목" left="50" top="sta00_00:20" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="29"/>
              <Static id="sta00_00_00_00" taborder="3" text="(필수) 개인식별정보: 성명, 카드정보(카드번호, 발급처, 발급일, 사고정보 등)" left="80" top="sta00_00_00:0" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="29"/>
              <Static id="sta00_00_00_00_00" taborder="4" text="■ 수집목적: 유아학비지원금 산정을 위한 자격관리, 유아학비 카드인증정보 관리 등 업무 수행" left="50" top="sta00_00_00_00:20" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="29"/>
              <Static id="sta00_00_00_00_00_00" taborder="5" text="■ 보유기간: 유아 최종 퇴원 후 5년" left="50" top="sta00_00_00_00_00:20" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="29"/>
              <Static id="sta00_00_00_00_00_00_00" taborder="6" text="■ 수집 및 이용근거" left="50" top="sta00_00_00_00_00_00:20" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="29"/>
              <Static id="sta00_00_00_00_00_00_00_00" taborder="7" text="- 개인정보보호법 제 15조, 제 17조" left="60" top="sta00_00_00_00_00_00_00:0" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="29"/>
              <Static id="sta00_00_00_00_00_00_00_00_00" taborder="8" text="- 사회복지사업법 제 6 조의 2" left="60" top="sta00_00_00_00_00_00_00_00:0" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="29"/>
              <Static id="sta00_00_00_00_00_00_00_00_01" taborder="9" text="- 유아교육법 시행령 제 34조의 2, 제 34조의 3" left="60" top="sta00_00_00_00_00_00_00_00_00:0" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="29"/>
            </Layout>
