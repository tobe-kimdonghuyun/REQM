        </ColumnInfo>
      </Dataset>
      <Dataset id="dsEtcList" useclientlayout="true">
        <ColumnInfo>
          <Column id="etcAge" type="STRING" size="2" sumtext="연령"/>
          <Column id="clsNm" type="STRING" size="150" sumtext="반명"/>
          <Column id="pulCthrNm" type="STRING" size="100" sumtext="담임성명"/>
          <Column id="grdtnRgrNo" type="STRING" size="256" sumtext="수료ㆍ졸업대장번호"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsEtcListTemp">
        <ColumnInfo>
          <Column id="gbNm" type="STRING" size="256"/>
          <Column id="age0" type="STRING" size="150" sumtext=""/>
          <Column id="age1" type="STRING" size="100" sumtext=""/>
          <Column id="age2" type="STRING" size="150" sumtext=""/>
          <Column id="age3" type="STRING" size="100" sumtext=""/>
          <Column id="age4" type="STRING" size="150" sumtext=""/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="gbNm">수료ㆍ졸업대장번호</Col>
          </Row>
          <Row>
            <Col id="gbNm">반</Col>
          </Row>
          <Row>
            <Col id="gbNm">담임성명</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSchorList" useclientlayout="true">
        <ColumnInfo>
          <Column id="flctnYmd" type="STRING" size="8" sumtext="학적사항 일자"/>
          <Column id="schorFlctnMteCn" type="STRING" size="500" sumtext="학적사항 내용"/>
          <Column id="schorSpablMteCn" type="STRING" size="1500" sumtext="학적사항 특기사항"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsAtteList" useclientlayout="true">
        <ColumnInfo>
          <Column id="atteAge" type="STRING" size="2" description="" sumtext="출결사항 연령"/>
          <Column id="itrtDdCnt" type="INT" size="5" description="" sumtext="출력사항 수업일수"/>
          <Column id="atendDdCnt" type="INT" size="5" description="" sumtext="출력사항 출석일수"/>
          <Column id="abeDiseDdCnt" type="INT" size="5" description="" sumtext="출력사항 질병결석일수"/>
          <Column id="abeWopmDdCnt" type="INT" size="5" description="" sumtext="출력사항 미인정결석일수"/>
          <Column id="abeEtcDdCnt" type="INT" size="5" description="" sumtext="출력사항 기타결석일수"/>
          <Column id="atteSpablMteCn" type="STRING" size="1500" description="" sumtext="출력사항 특기사항내용"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsInfntDevSittnList" useclientlayout="true">
        <ColumnInfo>
          <Column id="infntAge" type="STRING" size="2"/>
          <Column id="infntDevSittnCn" type="STRING" size="5000"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsAddrList" useclientlayout="true">
        <ColumnInfo>
          <Column id="stuAddr" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsAddrListTmp" useclientlayout="true">
        <ColumnInfo>
          <Column id="stuAddr" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSelectStu" useclientlayout="true">
        <ColumnInfo>
          <Column id="stuInvlNo" type="STRING" size="256"/>
          <Column id="flctnYmd" type="STRING" size="256"/>
          <Column id="flctnYear" type="STRING" size="256"/>
          <Column id="kndgrSchorFlctnScCd" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSelectYear" useclientlayout="true">
        <ColumnInfo>
          <Column id="flctnYear" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 학부모서비스(유)
*  @MenuPath    TEMPLATE
*  @FileName 	par_spsci00_m00.xfdl
*  @Creator 	
*  @CreateDate 	2022.07.04
*  @Desction    생활기록부조회
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.07.04     	홍길동 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::par_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	
	// Form의 default 초기처리를 한다.
	this.smfInitForm(this);
	
	if(this.smfIsMobile()){
		this.fnMiddleAlign();
	}
	
	//검색조건 설정
	var objParForm = this.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form;			
	this.dsSearch.copyRow(0, objParForm.dsStuIduzEduYn, 0);
	
	
	// 유치원 생기부 임시 조회 불가
// 	var text = "";
// 	if(this.smfIsMobile()) {
// 		text = "생활기록부 조회 서비스 준비중입니다. 8월 이후 생활기록부 조회가 가능합니다."
// 	}else{
// 		text = "생활기록부 조회 서비스 준비중입니다.\n8월 이후 생활기록부 조회가 가능합니다."
// 	}
// 
// 	this.smfAlert(text, function ()
// 	{
// 		var objFrame = this.getOwnerFrame();
// 	
// 		if(objFrame.form.divAll)
// 		{
// 			// Top 에 값을 세팅
// 			var sMainUrl = objFrame.form.fv_firstformUrl;
// 			
// 			// 메인URL로 이동한다.
// 			if(!this.smfIsNull(sMainUrl))
// 			{
// 				
// 				//@KBR 채용/업무지원 Top영역 조절
// 				var sSubSystemGb =  this.smfGetSubSystemGb();
// 				if(  (sSubSystemGb=="AFS")   // 업무지원(외부강사)
// 				  || (sSubSystemGb=="ECC")   // 업무지원(돌봄인력서비스)
// 				  || (sSubSystemGb=="IBM")   // 업무지원(교과용도서)
// 				  || (sSubSystemGb=="SEM")   // 업무지원(학교환경관리)
// 				  || (sSubSystemGb=="PHE")   // 업무지원(체육)
// 				  || (sSubSystemGb=="SML")   // 업무지원(급식)
// 				  || (sSubSystemGb=="SPR")   // 업무지원(교육복지)
// 				  || (sSubSystemGb=="ORE")   // 온라인채용(교원임용)
// 				  || (sSubSystemGb=="HRD")   // 온라인채용(계약제교원인력풀)	
// 				 )
// 				{
// 					objFrame.form.divTop.form.fnRearrageTopComp(sSubSystemGb,"collapse");
// 				}			
// 				
// 				// 메인화면으로 이동한다.
// 				objFrame.form.fnSetMainpage(sMainUrl);	
// 			}
// 		}
// 		
// 	});
	
	if(objParForm.fv_stuLoad){
		//소재정보, 개인번호 체크
		var validate = this.parfValidate(this.dsSearch);	
		trace("소재정보, 개인번호 체크 완료");
		if(!validate) return false;
		
		//trace("shlcd: " + this.dsSearch.getColumn(0,"shlCd"));
		//trace("ayr: " + this.dsSearch.getColumn(0,"ayr"));
		//trace("stuInvlNo: " + this.dsSearch.getColumn(0,"stuInvlNo"));
		//trace("cddcScCd: " + this.dsSearch.getColumn(0,"cddcScCd"));
	
		//학생선택 서비스 호출
		this.fnSelectStu();
	}
	
	
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
//생기부 데이터
this.fnSearch = function(obj, e)
{
 	// 서비스 객체 생성
	this.smfSearchService("select")		
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
		});	
};


//학생선택
this.fnSelectStu = function(obj, e)
{
	trace("학생선택 서비스 호출");
 	// 서비스 객체 생성
	this.smfSearchService("selectStu")		
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			//날짜 포멧 변경
			for(var i=0; i<this.dsSelectStu.getRowCount(); i++){
				var flctnYmd = this.dsSelectStu.getColumn(i,"flctnYmd");
				
				var formatFlctnYmd = flctnYmd.substr(0,4) + "." + flctnYmd.substr(4,2) + "." + flctnYmd.substr(6,2) ;
				//trace(i + ": " + formatFlctnYmd);
				
				this.dsSelectStu.setColumn(i, "flctnYmd",formatFlctnYmd);
			}
		
			//trace("학생선택 서비스 콜백");
			//생기부 선택 콤보박스 설정
			this.div00_00.form.cboYear.set_index(0);
			this.div00_00.form.cboFlctnYmd.set_index(0);
	
			this.dsSelectStu.filter("flctnYear==" + "'" + this.div00_00.form.cboYear.value + "'");
		
			if(callbackParams.errors) return;
			
		});	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
	
	if(svcid== "select"){
		var grdH = 0;
		if(this.smfIsMobile()){
			grdH = this._smfappendHeight(this.div00.form.grdBasicInfo);
			if(this.dsEtcList.getRowCount() == 0 ) grdH = 300;
			this.div00.form.grdBasicInfo.setOffsetHeight(grdH);
			this.div00.setOffsetHeight(508 + grdH);
		}
		
		grdH = this._smfappendHeight(this.div02.form.grdSchorList);
		if(this.dsSchorList.getRowCount() == 0 ) grdH = 300;
		this.div02.form.grdSchorList.setOffsetHeight(grdH);
		this.div02.setOffsetHeight(grdH);
		
		grdH = this._smfappendHeight(this.div03.form.grdAtteList);
		if(this.dsAtteList.getRowCount() == 0 ) grdH = 300;
		this.div03.form.grdAtteList.setOffsetHeight(grdH);
		this.div03.setOffsetHeight(grdH);
		
		grdH = this._smfappendHeight(this.div04.form.grdInfntDevSittnList);
		if(this.dsInfntDevSittnList.getRowCount() == 0 ) grdH = 300;
		this.div04.form.grdInfntDevSittnList.setOffsetHeight(grdH);
		this.div04.setOffsetHeight(grdH);
		
		if(this.dsEtcList.getRowCount() > 0){
			this.staNoData.set_visible(false);
			
			this.div00_00.form.chkSearchVal_04.set_enable(true);
			
			this.imgSubTit01.set_visible(true);
			this.div00.set_visible(true);
			this.imgSubTit02.set_visible(true);
			this.div01.set_visible(true);
			this.imgSubTit03.set_visible(true);
			this.div02.set_visible(true);
			this.imgSubTit04.set_visible(true);
			this.div03.set_visible(true);
			if(this.div00_00.form.chkSearchVal_04.value){
				this.imgSubTit05.set_visible(true);
				this.div04.set_visible(true);
			}else{
				this.imgSubTit05.set_visible(false);
				this.div04.set_visible(false);
			}
			
			this.divSpace.setOffsetHeight(0);
			//this.smfResetScroll(this);
			
			this.fnAddrSet();
			this.fnEctGridValueSet();
			if(this.dsMain.getRowCount() > 0){
				this.imgSubTit05.set_text("5. 유아발달상황(성명: " + this.dsMain.getColumn(0, "stuFlnm") + ")");
			}else{
				this.dsMain.addRow();
			}
		}else{
			this.staNoData.set_visible(true);
			this.div00_00.form.chkSearchVal_04.set_enable(false);
			
			this.imgSubTit01.set_visible(false);
			this.div00.set_visible(false);
			this.imgSubTit02.set_visible(false);
			this.div01.set_visible(false);
			this.imgSubTit03.set_visible(false);
			this.div02.set_visible(false);
			this.imgSubTit04.set_visible(false);
			this.div03.set_visible(false);
			this.imgSubTit05.set_visible(false);
			this.div04.set_visible(false);
			
			this.divSpace.setOffsetHeight(600);
			//this.smfResetScroll(this);
		}
		
		this.smfResetScroll(this);
	}
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * 유아발달상황 visible 처리
 */
this.fnSearchOnClick= function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	if(obj.value && this.dsEtcList.getRowCount() > 0){
		this.imgSubTit05.set_visible(true);
		this.div04.set_visible(true);
	}else{
		this.imgSubTit05.set_visible(false);
		this.div04.set_visible(false);
	}
	
	this.smfResetScroll(this);
};

//유아 주소 세팅
this.fnAddrSet = function()
{	
	for(i = 0; i < this.dsAddrList.rowcount; i++){
		var stuAddr = this.dsAddrList.getColumn(i, "stuAddr").split("\n");
		
		for(i = 0; i < stuAddr.length; i++){
			nRow = this.dsAddrListTmp.addRow();
			this.dsAddrListTmp.setColumn(nRow, "stuAddr", stuAddr[i]);
		}
	}
}

/**
 * 학년이력 dataset을 그리드 바인딩 dsEtcListTemp dataset에 매칭한다.
 */
this.fnEctGridValueSet = function()
{		
	// 그리드 포멧 초기화
	this.div00.form.grdBasicInfo.set_formats(this.div00.form.grdBasicInfo.formats);
	
	
	
	if(!this.smfIsMobile()){
		// pc용 포멧 설정
		this.div00.form.grdBasicInfo.set_formatid("default_00");
		for(i = 0; i < this.dsEtcList.rowcount; i++){
			this.dsEtcListTemp.setColumn(0, "age"+i, this.dsEtcList.getColumn(i, "grdtnRgrNo"));
			this.dsEtcListTemp.setColumn(1, "age"+i, this.dsEtcList.getColumn(i, "clsNm"));
			this.dsEtcListTemp.setColumn(2, "age"+i, this.dsEtcList.getColumn(i, "pulCthrNm"));
			
			var nCol = this.div00.form.grdBasicInfo.appendContentsCol();
			var merge = this.div00.form.grdBasicInfo.mergeCell( nCol, nCol, -1, -1);
			
			this.div00.form.grdBasicInfo.setFormatColProperty(nCol, "size", 215);
			this.div00.form.grdBasicInfo.setCellProperty("head", nCol - 1, "textAlign", "center");
			this.div00.form.grdBasicInfo.setCellProperty("head", nCol - 1, "text", this.dsEtcList.getColumn(i, "etcAge") + "세");
			this.div00.form.grdBasicInfo.setCellProperty("body", nCol - 1, "textAlign", "center");
			this.div00.form.grdBasicInfo.setCellProperty("body", nCol - 1, "text", "bind:age"+i);
		}
	}
	
	if(this.smfIsMobile()){
		// 모바일용 포멧 설정
		this.div00.form.grdBasicInfo.set_formatid("format00");
		
		gformatId = this.div00.form.grdBasicInfo.formatid;
		if("tablet" == gformatId){
			var grdSize = 240 + (this.dsEtcList.rowcount * 215);
			this.div00.form.grdBasicInfo.setOffsetWidth(grdSize);
		}
		
		//this.div00.form.grdBasicInfo.setBandProperty( "body", "autofittype", "col" );
		this.div00.form.resetScroll();
	}else{
		var grdSize = 160 + (this.dsEtcList.rowcount * 215);	
		this.div00.form.grdBasicInfo.setOffsetWidth(grdSize);
	}
}

this.par_spsci00_m00_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	if(this.smfIsMobile()){
		this.fnMiddleAlign();
	}
};

this.fnMiddleAlign = function()
{
	var nAllWidth = this.width;  // 전체 form의 사이즈
	var nMaxWidth = 214; // 가운데정렬되는 Div의 가로사이즈(기존1200)
	var nLeft,nWidth;
	
	if(nAllWidth >= nMaxWidth)	//1280 사용
	{
		nLeft = parseInt((nAllWidth - nMaxWidth) / 2);
		if(nLeft < 0) nLeft = 0;
		
		nWidth = nMaxWidth;
	}
	else
	{
		nLeft = 0;
		nWidth = nAllWidth;
	}
	// 1번째 
	this.div00.form.img00.setOffsetLeft(nLeft);
	this.div00.form.img00.setOffsetWidth(nWidth);		
}

//조회버튼 onclick
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	trace("학생번호: " + this.div00_00.form.cboFlctnYmd.value);
	
	this.dsSearch.setColumn(0,"stuInvlNo",this.div00_00.form.cboFlctnYmd.value);
	
	trace("dsSearch: " + this.dsSearch.getColumn(0,"stuInvlNo"));
	
	//소재정보, 개인번호 체크
	var validate = this.parfValidate(this.dsSearch);	
	if(!validate) return false;
	
	//  페이지를 조회한다.
	this.fnSearch();
};



this.div00_00_cboYear_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.dsSelectStu.filter("flctnYear==" + "'" + this.div00_00.form.cboYear.value + "'");
	this.div00_00.form.cboFlctnYmd.set_index(0);
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="div01.form.edtInfntFlnm" propid="value" datasetid="dsMain" columnid="stuFlnm"/>
      <BindItem id="item1" compid="div01.form.edtInfntSxds" propid="value" datasetid="dsMain" columnid="sxdsScCd"/>
      <BindItem id="item3" compid="div00.form.img00" propid="image" datasetid="dsMain" columnid="photoFileCn"/>
      <BindItem id="item2" compid="div01.form.edtStuRrno" propid="value" datasetid="dsMain" columnid="stuRrno"/>
      <BindItem id="item4" compid="div01.form.txt00" propid="value" datasetid="dsAddrList" columnid="stuAddr"/>
    </Bind>
  </Form>
</FDL>
