    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 > 학부모서비스(유) > 교회체험학습
*  @FileName 	par_spssl05_p00
*  @Creator 	문형선
*  @CreateDate 	2022.07.14
*  @Desction    교외체험학습 신청/상세조회/수정
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.07.14            문형선                   최초 생성 
*******************************************************************************
*/ 

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
//include "lib::cm_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
//this.fv_sType = "";
this.fv_schpaDtcNo = "";

var fv_shlNm = "";
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{ 
	//폼을 초기화 
	this.smfInitPopup(obj);
	
	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	this.dsSearch.copyData(this.pv_params.dataset);
	this.dsSearch.setColumn(0, "sType", this.pv_params.sType); // C : 등록, R: 조회
	
	//신청정보 설정
	var objParForm = this.opener.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form;
	fv_schpaDtcNo = objParForm.dsStuIduzEduYn.getColumn(0, "schpaDtcNo");
	//유치원 명 가져오기
	fv_shlNm = objParForm.dsStuIduzEduYn.getColumn(0, "shlNm");

	this.dsExperLrn.setColumn(0, "apsId", 		fv_schpaDtcNo);
	this.dsExperLrn.setColumn(0, "apsNm", 		objParForm.dsSchpaInfo.getColumn(0, "schpaNm"));
	this.dsExperLrn.setColumn(0, "apsRelNm", 	objParForm.dsSchpaInfo.getColumn(0, "apsRelNm"));
	this.dsExperLrn.setColumn(0, "apsTelno", 	objParForm.dsSchpaInfo.getColumn(0, "mblTelno"));
	this.dsExperLrn.setColumn(0, "stuInvlNo", 	this.dsSearch.getColumn(0, "stuInvlNo"));	
	this.dsExperLrn.setColumn(0, "clsScNm", 	objParForm.dsStuIduzEduYn.getColumn(0, "clsScNm"));
	this.dsExperLrn.setColumn(0, "stuFlnm", 	objParForm.dsStuIduzEduYn.getColumn(0, "stuFlnm"));
	this.dsExperLrn.setColumn(0, "clsNm", 		objParForm.dsStuIduzEduYn.getColumn(0, "clsNm"));
	this.dsExperLrn.setColumn(0, "schpaDtcNo", 	fv_schpaDtcNo);

	
	if("R" == this.pv_params.sType){
 		var experLrnNo = this.pv_params.experLrnNo;
		this.dsSearch.setColumn(0, "experLrnNo", experLrnNo);
 		this.fnSelect();
	}else if("C" == this.pv_params.sType){
		var sYear  = this.smfSubStr(objParForm.dsStuIduzEduYn.getColumn(0, "toDay"), 0, 4);
		var sMonth = this.smfSubStr(objParForm.dsStuIduzEduYn.getColumn(0, "toDay"), 4, 6);
		var sDay   = this.smfSubStr(objParForm.dsStuIduzEduYn.getColumn(0, "toDay"), 6, 8);
		
		this.divDetail.form.div00.form.staToDay.set_text(sYear + "년    " + sMonth + "월    " + sDay + "일");
		//this.divDetail.form.div00.form.staLegalRepr01.set_text("본인   성명 :  " + this.dsExperLrn.getColumn(0, "stuFlnm"));
		this.divDetail.form.div00.form.staLegalRepr02.set_text("보호자(법정대리인)   성명 :  " + objParForm.dsSchpaInfo.getColumn(0, "schpaNm"));
		this.divDetail.form.div00.form.staShlNm.set_text(fv_shlNm + "장 귀하");
	
		this.dsExperLrn.setColumn(0, "ayr", this.pv_params.nowAyr);		
		this.fnButtonControl();
	}
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 /**
 * @description 조회
 */
this.fnSelect = function()
{
//	this.dsSearch.setColumn(0, "sType", "R"); // R: 조회
 	// 서비스 객체 생성
	this.smfSearchService("selectExperLrn")
//		.confirmIfModifiedGrid(this.grdExperLrnList)						// 데이터가 변경되었으면 확인메시지
//		.validateForm(this.divSearch) 										// 폼 유효성검사	
		.run() 																// 실행
		.callback(function(callbackParams){									// 콜백
			if(callbackParams.errors) return;
			
			var sYear  = this.smfSubStr(this.dsExperLrn.getColumn(0, "regDt"), 0, 4);
			var sMonth = this.smfSubStr(this.dsExperLrn.getColumn(0, "regDt"), 4, 6);
			var sDay   = this.smfSubStr(this.dsExperLrn.getColumn(0, "regDt"), 6, 8);
			
			this.divDetail.form.div00.form.staToDay.set_text(sYear + "년    " + sMonth + "월    " + sDay + "일");
			//this.divDetail.form.div00.form.staLegalRepr01.set_text("본인   성명 :  " + this.dsExperLrn.getColumn(0, "stuFlnm"));
			this.divDetail.form.div00.form.staLegalRepr02.set_text("보호자(법정대리인)   성명 :  " + this.dsExperLrn.getColumn(0, "apsNm"));
			this.divDetail.form.div00.form.staShlNm.set_text(fv_shlNm + "장 귀하");
			
			this.divDetail.form.div00.form.rdoPersonalInfo.set_value("Y");
			//this.divDetail.form.div00.form.chkLegalRepr01.set_value("Y");
			this.divDetail.form.div00.form.chkLegalRepr02.set_value("Y");
		}) 
	;
};


this.fnSave = function(txtMessage){
	
	// 서비스 객체 생성 
	this.smfSaveService("saveExperLrnTemp")
		.messagePrefix(txtMessage)
		// 데이터 존재 필수
		.requireExistsData(this.dsExperLrn) 
		// 데이터 검증
		.validateForm(this.divDetail)

		// 실행
		.run() 

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;			
			// 저장이 완료되었습니다.
			// 재조회
			//this.smfAlert('CM002', [], this.opener.fnSearch());
			this.trace("txtMessage : " + txtMessage);
			this.trace("smfAfterServiceMessage : " + this.smfAfterServiceMessage());
			if(txtMessage == "제출"){
				this.smfAlert("제출이 완료되었습니다.\n신청서 제출 후 유치원에서 신청내역 승인(결재) 처리 이후 결과보고서 제출이 가능합니다.", this.opener.fnSearch());
			}else{
				this.smfAlert(this.smfAfterServiceMessage(), this.opener.fnSearch());
			}
			//this.smfAlert(this.smfAfterServiceMessage(), this.opener.fnSearch());
		});
}

this.fnDelete = function(){
	// 서비스 객체 생성
	this.smfDeleteService("deleteExperLrn")
		.run() 																// 실행
		.callback(function(callbackParams){									// 콜백
			// 삭제하였습니다 알림 후 재조회
			this.smfAlert(this.smfAfterServiceMessage(), this.opener.fnSearch());
		}) 
	;
}

this.selectExperDays = function(){
	
	this.smfSearchService("selectExperDays")
//		.confirmIfModifiedGrid(this.grdExperLrnList)						// 데이터가 변경되었으면 확인메시지
//		.validateForm(this.divSearch) 										// 폼 유효성검사	
		.run() 																// 실행
		.callback(function(callbackParams){									// 콜백
			if(callbackParams.errors) return;
			this.divDetail.form.edtExperDays.set_value(this.dsExperDays.getColumn(0, "experDays"));
		}) 
	;
}

this.selectVctDays = function(){
	
	this.smfSearchService("selectVctDays")
//		.confirmIfModifiedGrid(this.grdExperLrnList)						// 데이터가 변경되었으면 확인메시지
//		.validateForm(this.divSearch) 										// 폼 유효성검사	
		.run() 																// 실행
		.callback(function(callbackParams){									// 콜백
			if(callbackParams.errors) return;
			trace(this.dsVctDayList.saveXML());
			
			var experBgngYmd = this.dsExperDays.getColumn(0, "experBgngYmd");
			var experEndYmd = this.dsExperDays.getColumn(0, "experEndYmd");
			
			var dsVctDayList = this.dsVctDayList;
			
			for(var i = 0; i < dsVctDayList.getRowCount(); i++) {
				var shfYmd = dsVctDayList.getColumn(i, "shfYmd");
				
				if(shfYmd >= experBgngYmd && shfYmd <= experEndYmd) {
					// 메시지를 이용한 처리
					this.smfAlert("신청기간 중 방학일이 포함될 수 없습니다.", function(){
						this.divDetail.form.calExperBgngYmd.set_value("");
						this.divDetail.form.calExperEndYmd.set_value("");
						this.divDetail.form.edtExperDays.set_value("");
					});
					
					return;
				}
			}
		}) 
	;
}
/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd <= -1) return;
	
	if(svcid == "saveExperLrnTemp" || svcid == "selectExperLrn"){
		this.dsSearch.setColumn(0, "sType", "U"); // U : 수정
		//등록자와 로그인사용자 아이디비교 로직 추가 필요
		this.dsExperLrn.setColumn(0, "schpaDtcNo", fv_schpaDtcNo);
		
// 		var experDays = this.fnExperDaysSet(this.dsExperLrn.getColumn(0, "experBgngYmd"), this.dsExperLrn.getColumn(0, "experEndYmd"));
// 		this.divDetail.form.edtExperDays.set_value( experDays);
		
		sType = this.dsSearch.getColumn(0, "sType"); // C : 생성, R : 조회, U : 수정, D : 삭제, L : 목록
		experLrnStsCd = this.dsExperLrn.getColumn(0, "experLrnStsCd");
		var aplyAtrzStsCd = this.dsExperLrn.getColumn(0, "aplyAtrzStsCd");
		trace(svcid);
		trace("sType : " + sType + ", experLrnStsCd : " + experLrnStsCd + ", aplyAtrzStsCd : " + aplyAtrzStsCd);
		if(sType == "U" && (experLrnStsCd == "2" && !this.smfIsNull(aplyAtrzStsCd))){
			// 팝업 종료
			//this.close(true);
		}
	}else if(svcid == "deleteExperLrn"){
		// 팝업 종료
 		this.close(true);
	}

	var experLrnStsCd = this.dsExperLrn.getColumn(0, "experLrnStsCd");
	if(svcid != "insertMenuHstr"){
		this.fnButtonControl(experLrnStsCd);
	}
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
//체험학습 기간을 계산하여 세팅.
this.fnExperDaysSet = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{
	var sStartDate = this.divDetail.form.calExperBgngYmd.value;
	var sEndDate = this.divDetail.form.calExperEndYmd.value;
	if( this.smfIsNull(sStartDate) || this.smfIsNull(sEndDate) ) return;
	
	var days = this.smfDiffDate(sStartDate, sEndDate);
	
	if(days < 0){
		// 메시지를 이용한 처리
		this.smfAlert("종료일자가 시작일자보다 빠릅니다.", function(){
			obj.set_value(e.prevalue);
		});
	}else{	
		this.divDetail.form.edtExperDays.set_value(this.fnExperDaysSet(sStartDate, sEndDate));
	}
};

 /**
 * @description 임시저장 버튼 onclick
 */
this.btnSaveTemp_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(!this.fnPersonalInfoAgreeChk()){
		return false;
	}
	
	if(this.divDetail.form.edtExperDays.value < 1){
		this.smfAlert("신청일수가 0일입니다. 신청기간을 다시 확인하세요.");
		return false;
	}
		
	if(this.smfIsNull(this.dsExperLrn.getColumn(0, "experLrnNo"))){
		this.dsSearch.setColumn(0, "sType", "C"); // C : 생성, R : 조회, U : 수정, D : 삭제, L : 목록
	}else{
		this.dsSearch.setColumn(0, "sType", "U"); // C : 생성, R : 조회, U : 수정, D : 삭제, L : 목록
	}
	
	this.dsExperLrn.setColumn(0, "experLrnStsCd", "1");
	this.dsExperLrn.setColumn(0, "reqInfoYn", "Y"); // 개인정보동의여부
	this.dsExperLrn.setColumn(0, "reqApsYn", "Y"); // 학부모 서명 확인
	this.fnSave(obj.text);
};
 /**
 * @description 제출버튼 onclick
 */
this.btnSubmit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(!this.fnPersonalInfoAgreeChk()){
		return false;
	}
	
	if(this.divDetail.form.edtExperDays.value < 1){
		this.smfAlert("신청일수가 0일입니다. 신청기간을 다시 확인하세요.");
		return false;
	}
	
	this.dsSearch.setColumn(0, "sType", "U"); // C : 생성, R : 조회, U : 수정, D : 삭제, L : 목록
	this.dsExperLrn.setColumn(0, "experLrnStsCd", "2"); // 1:임시저장, 2:제출, 3:취소, 4:미승인, 5:승인
	this.dsExperLrn.setColumn(0, "reqInfoYn", "Y"); // 개인정보동의여부
	this.dsExperLrn.setColumn(0, "reqApsYn", "Y"); // 학부모 서명 확인
	this.fnSave(obj.text);
};

this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsSearch.setColumn(0, "sType", "U"); // C : 생성, R : 조회, U : 수정, D : 삭제, L : 목록
	this.dsExperLrn.setColumn(0, "experLrnStsCd", "3"); // 1:임시저장, 2:제출, 3:취소, 4:미승인, 5:승인
	this.fnSave(obj.text);
};

this.btnDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsSearch.setColumn(0, "sType", "D"); // C : 생성, R : 조회, U : 수정, D : 삭제, L : 목록
	this.fnDelete();
};

// 버튼 설정
this.fnButtonControl = function(experLrnStsCd){
	//체험학습상태에 따른 "제출", "임시저장" 버튼 visible 설정
	//체험학습상태에 따른 "체험학습형태코드" readonly 설정

	var aplyAtrzStsCd = this.dsExperLrn.getColumn(0, "aplyAtrzStsCd");
	
	if(this.smfIsNull(experLrnStsCd)){
		this.divDetail.form.rdoExperLrnStleCd.set_readonly(false);
		//"제출", "임시저장" 버튼
		this.divDetail.form.btnSaveTemp.set_enable(true);
		this.divDetail.form.btnSubmit.set_enable(false);
		this.divDetail.form.btnCancel.set_enable(false);
		this.divDetail.form.btnDelete.set_enable(false);		
	}else if(experLrnStsCd == "1"){ //임시저장
		this.divDetail.form.rdoExperLrnStleCd.set_readonly(false);
		//"제출", "임시저장" 버튼
		this.divDetail.form.btnSaveTemp.set_enable(true);
		this.divDetail.form.btnSubmit.set_enable(true);
		this.divDetail.form.btnCancel.set_enable(false);
		this.divDetail.form.btnDelete.set_enable(true);		
	}else if(experLrnStsCd == "2"){ //제출
		if(!this.smfIsNull(aplyAtrzStsCd) && (aplyAtrzStsCd == "1" || aplyAtrzStsCd == "4")) { // 신청서 결재단계
			// 신청서 결재상태가 1:상신(진행) or 4:완결 이면 제출, 신청취소, 삭제 불가능
			this.divDetail.form.rdoExperLrnStleCd.set_readonly(true);
			//"제출", "신청취소", "삭제" 버튼
			this.divDetail.form.btnSubmit.set_enable(false);
			this.divDetail.form.btnCancel.set_enable(false);
			this.divDetail.form.btnDelete.set_enable(false);
		}else{
			this.divDetail.form.rdoExperLrnStleCd.set_readonly(false);
			//"제출", "신청취소", "삭제" 버튼
			this.divDetail.form.btnSubmit.set_enable(true);
			this.divDetail.form.btnCancel.set_enable(true);
			this.divDetail.form.btnDelete.set_enable(true);
		}
		//"임시저장" 버튼
		this.divDetail.form.btnSaveTemp.set_enable(false);
	}else if(experLrnStsCd == "3" || experLrnStsCd == "4"){ //취소, 미승인
		this.divDetail.form.rdoExperLrnStleCd.set_readonly(false);
		//"제출", "임시저장" 버튼
		this.divDetail.form.btnSaveTemp.set_enable(false);
		this.divDetail.form.btnSubmit.set_enable(false);
		this.divDetail.form.btnCancel.set_enable(false);
		this.divDetail.form.btnDelete.set_enable(true);
	}else{
		this.divDetail.form.rdoExperLrnStleCd.set_readonly(true);
		//"제출", "임시저장" 버튼
		this.divDetail.form.btnSaveTemp.set_enable(false);
		this.divDetail.form.btnSubmit.set_enable(false);
		this.divDetail.form.btnCancel.set_enable(false);
		this.divDetail.form.btnDelete.set_enable(false);
	}
};

this.btn_close_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};

//두날짜 사이의 일자구하기
this.fnExperDaysSet = function(experBgngYmd, experEndYmd)
{
	return this.smfDiffDate(experBgngYmd, experEndYmd) + 1;
};

//교외체험학습 기간 선택 시 신청일수를 구한다.
this.divDetail_calExperYmd_onchanged = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{
	var sStartDate = this.divDetail.form.calExperBgngYmd.value;
	var sEndDate   = this.divDetail.form.calExperEndYmd.value;
	
	var objParForm = this.opener.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form;
	var ayr = objParForm.dsStuIduzEduYn.getColumn(0, "ayr");
	var ayrStartYmd = objParForm.dsStuIduzEduYn.getColumn(0, "startYmd");
	var ayrEndYmd = objParForm.dsStuIduzEduYn.getColumn(0, "endYmd");
	
	var oName = obj.name

	if( (oName == "calExperBgngYmd" && (ayrStartYmd > e.postvalue || ayrEndYmd < e.postvalue)) || (oName == "calExperEndYmd" && (ayrStartYmd > e.postvalue || ayrEndYmd < e.postvalue))){
		if(!this.smfIsNull(e.postvalue)){
			this.smfAlert("해당 학년도만 신청 가능합니다.", function(){
				this.divDetail.form.calExperBgngYmd.set_value("");
				this.divDetail.form.calExperEndYmd.set_value("");
			});
			
			return false;
		}
	}
	
	if( this.smfIsNull(sStartDate) || this.smfIsNull(sEndDate) ) return;
	
	var days = this.smfDiffDate(sStartDate, sEndDate);
	
	if(days < 0){
		// 메시지를 이용한 처리
		this.smfAlert("종료일자가 시작일자보다 빠릅니다.", function(){
			this.divDetail.form.calExperBgngYmd.set_value("");
			this.divDetail.form.calExperEndYmd.set_value("");
		});
	}else{
		this.dsExperDays.copyRow(0, this.dsSearch, 0);
		this.dsExperDays.setColumn(0, "sType", "X"); // X : 신청일수조회
		this.dsExperDays.setColumn(0, "experBgngYmd", sStartDate);
		this.dsExperDays.setColumn(0, "experEndYmd", sEndDate);	
	
		this.selectExperDays();
		this.selectVctDays();	// 방학 조회
		//this.divDetail.form.edtExperDays.set_value(this.fnExperDaysSet(sStartDate, sEndDate));
	}
};

var oldText = "";
this.divDetail_txtExperLrnPlanCn_oninput = function(obj:nexacro.TextArea,e:nexacro.InputEventInfo)
{
	var nLength = this.smfLength(obj.value, 3);

	if(nLength > 5000){
		this.smfAlert("학습계획은 5000byte까지 입력이 가능합니다.", function(){
			obj.set_value(oldText);
		});
		return false;
	}else{
		oldText = obj.value
	}
	this.divDetail.form.staByte00.set_text(nLength);
};

//개인정보 수집 및 법정대리인 동의 여부 체크
this.fnPersonalInfoAgreeChk = function(){
	if(this.divDetail.form.div00.form.rdoPersonalInfo.value != "Y"){
		this.smfAlert("개인정보 수집·이용 동의가 필요합니다.", function(){
			this.divDetail.form.div00.form.rdoPersonalInfo.setFocus();
		});
		return false;
	}
	
// 	if(this.divDetail.form.div00.form.chkLegalRepr01.value != "Y"){
// 		this.smfAlert("만 14세 미만의 경우 \"개인정보 수집·이용 동의\"를 위한 \n보호자(법정대리인)의 동의가 필요합니다.", function(){
// 			this.divDetail.form.div00.form.chkLegalRepr01.setFocus();
// 		});
// 		return false;
// 	}
	
	if(this.divDetail.form.div00.form.chkLegalRepr02.value != "Y"){
		this.smfAlert("만 14세 미만의 경우 \"개인정보 수집·이용 동의\"를 위한 \n보호자(법정대리인)의 동의가 필요합니다.", function(){
			this.divDetail.form.div00.form.chkLegalRepr02.setFocus();
		});
		return false;
	}
	
	return true;
}
this.divDetail_staByte_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	
};

this.divDetail_txtExperLrnPlanCn_onchanged = function(obj:nexacro.TextArea,e:nexacro.ChangeEventInfo)
{
	
};

]]></Script>
