              <Button id="btnCancel" taborder="30" text="신청취소" top="div00:20" height="30" width="80" cssclass="btn_WF_Crud" right="58" onclick="btnCancel_onclick" visible="true" enable="false" initvalueid="ivBtnAccessibilityButton"/>
              <Button id="btnDelete" taborder="31" text="삭제" top="div00:20" height="30" width="50" cssclass="btn_WF_Crud" right="0" onclick="btnDelete_onclick" visible="true" enable="false" initvalueid="ivBtnAccessibilityButton"/>
