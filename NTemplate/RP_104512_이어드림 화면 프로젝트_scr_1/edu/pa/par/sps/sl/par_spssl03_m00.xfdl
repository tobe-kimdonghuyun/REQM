        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 공지사항 목록조회
*  @MenuPath    TEMPLATE
*  @FileName 	Temp01.xfdl
*  @Creator 	홍길동
*  @CreateDate 	2022.5.12
*  @Desction    검정고시p72+(공지목록)+(타이틀,그리드)
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.5.12     	홍길동 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::par_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 
var fv_year;
var fv_month;

this.par_spssl03_m00_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(this);
	
	var today = new Date();//오늘 날짜 얻기 함수
	fv_year = today.getFullYear();
	fv_month = today.getMonth()+1;
	//fv_year = 2019;
	this.staYear.set_text(fv_year+"년");

	if(fv_month < 10){
		fv_month = "0" + fv_month;
	}
	this.cboMonth.set_value(fv_month);
	
	//검색조건 설정
	var objParForm = this.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form;
	this.dsSearch.copyRow(0, objParForm.dsStuIduzEduYn, 0, "shlCd=shlCd,instCd=shlCd,ayr=ayr,cddcScCd=cddcScCd,userId=schpaDtcNo,stuDtcNo=stuDtcNo,stuInvlNo=stuInvlNo");
	this.dsSearch.setColumn(0, "mlsvInqScCd", 1);	// 1 : 월간
	this.dsSearch.setColumn(0, "mlsvYm", fv_year + "" + fv_month);
	//this.dsSearch.setColumn(0, "mlsvYm", "201908");
	this.dsSearch.setColumn(0, "mmealScCd", 2); //2 : 중식
	
	//소재정보, 개인번호 체크
	var validate = this.parfValidate(this.dsSearch);	
	if(!validate) return false;
	
	this.fnSelectStuAgy();
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 this.fnSelectStuAgy = function(obj, e)
{

 	// 서비스 객체 생성
	this.smfSearchService("selectStuAgy")
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});
};

this.fnSearch = function(obj, e)
{
	this.dsSearch.setColumn(0, "ayr", nexacro.replaceAll(this.staYear.text, "년", ""));
	this.dsSearch.setColumn(0, "mlsvYm", nexacro.replaceAll(this.staYear.text, "년", "") + "" + this.cboMonth.value);
	
 	// 서비스 객체 생성
	this.smfSearchService("selectDietList")
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});	
};

this.fnSearchAgyScList = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("selectAgyScList")
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});	
};


/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
	
	if(svcid == "selectStuAgy"){
		this.fnSearch();
	}else if(svcid == "selectDietList"){
		var eRows = this.dsDietList.extractRows("diet6 != '' && diet6 != null");
		
		if(eRows.length > 0){//토요일 식단이 있는 경우
			var nCol = this.div00.form.grd01.appendContentsCol("body");
		
			this.div00.form.grd01.setCellProperty("head", nCol, "text", "토요일");
			this.div00.form.grd01.setCellProperty("head", nCol, "color", "#2b71bf");
			
			this.div00.form.grd01.setCellProperty("body", nCol, "color", "#2b71bf");
			this.div00.form.grd01.setCellProperty("body", nCol, "text", "bind:day6");
			this.div00.form.grd01.setCellProperty("body", nCol, "cssclass", "cell_WF_day");
			this.div00.form.grd01.setCellProperty("body", nCol, "textAlign", "left");
			this.div00.form.grd01.setCellProperty("body", nCol, "autosizerow", "limitmin");
			
			
			this.div00.form.grd01.setCellProperty("body", nCol+6, "cursor", "pointer");
			this.div00.form.grd01.setCellProperty("body", nCol+6, "text", "bind:diet6");
			this.div00.form.grd01.setCellProperty("body", nCol+6, "displaytype", "decoratetext");
			this.div00.form.grd01.setCellProperty("body", nCol+6, "textAlign", "left");
			this.div00.form.grd01.setCellProperty("body", nCol+6, "expr", "comp.parent.parent.parent.fnDiteText(diet6)");
			this.div00.form.grd01.setCellProperty("body", nCol+6, "autosizerow", "limitmin");
			
			this.div00.form.grd01.setFormatColProperty(0,"size",1200/6);
			this.div00.form.grd01.setFormatColProperty(1,"size",1200/6);
			this.div00.form.grd01.setFormatColProperty(2,"size",1200/6);
			this.div00.form.grd01.setFormatColProperty(3,"size",1200/6);
			this.div00.form.grd01.setFormatColProperty(4,"size",1200/6);
			this.div00.form.grd01.setFormatColProperty(5,"size",1200/6);
			
			//프린트용 Grid 작업
			var pCol = this.divPrint.form.grd01.appendContentsCol("body");
		
			this.divPrint.form.grd01.setCellProperty("head", pCol, "text", "토요일");
			this.divPrint.form.grd01.setCellProperty("head", pCol, "color", "#2b71bf");
			
			this.divPrint.form.grd01.setCellProperty("body", pCol, "color", "#2b71bf");
			this.divPrint.form.grd01.setCellProperty("body", pCol, "text", "bind:day6");
			this.divPrint.form.grd01.setCellProperty("body", pCol, "cssclass", "cell_WF_day");
			this.divPrint.form.grd01.setCellProperty("body", pCol, "textAlign", "left");
			this.divPrint.form.grd01.setCellProperty("body", pCol, "autosizerow", "limitmin");
			
			
			this.divPrint.form.grd01.setCellProperty("body", pCol+6, "cursor", "pointer");
			this.divPrint.form.grd01.setCellProperty("body", pCol+6, "text", "bind:diet6");
			this.divPrint.form.grd01.setCellProperty("body", pCol+6, "displaytype", "decoratetext");
			this.divPrint.form.grd01.setCellProperty("body", pCol+6, "textAlign", "left");
			this.divPrint.form.grd01.setCellProperty("body", pCol+6, "expr", "comp.parent.parent.parent.fnDiteText(diet6)");
			this.divPrint.form.grd01.setCellProperty("body", pCol+6, "autosizerow", "limitmin");
			
			this.divPrint.form.grd01.setFormatColProperty(0,"size",1000/6);
			this.divPrint.form.grd01.setFormatColProperty(1,"size",1000/6);
			this.divPrint.form.grd01.setFormatColProperty(2,"size",1000/6);
			this.divPrint.form.grd01.setFormatColProperty(3,"size",1000/6);
			this.divPrint.form.grd01.setFormatColProperty(4,"size",1000/6);
			this.divPrint.form.grd01.setFormatColProperty(5,"size",1000/6);
		}else{//토요일 식단이 없는 경우
			dCol = this.div00.form.grd01.deleteContentsCol("body",5);
			this.div00.form.grd01.setFormatColProperty(0,"size",1200/5);
			this.div00.form.grd01.setFormatColProperty(1,"size",1200/5);
			this.div00.form.grd01.setFormatColProperty(2,"size",1200/5);
			this.div00.form.grd01.setFormatColProperty(3,"size",1200/5);
			this.div00.form.grd01.setFormatColProperty(4,"size",1200/5);
			
			//프린트용 Grid 작업
			this.divPrint.form.grd01.deleteContentsCol("body",5);
			this.divPrint.form.grd01.setFormatColProperty(0,"size",1000/5);
			this.divPrint.form.grd01.setFormatColProperty(1,"size",1000/5);
			this.divPrint.form.grd01.setFormatColProperty(2,"size",1000/5);
			this.divPrint.form.grd01.setFormatColProperty(3,"size",1000/5);
			this.divPrint.form.grd01.setFormatColProperty(4,"size",1000/5);
		}
		
		this.div00.form.grd01.setBandProperty( "body", "autofittype", "row" );
		this.div00.form.resetScroll();
		//프린트용 Grid 작업
		this.divPrint.form.grd01.setBandProperty( "body", "autofittype", "row" );
		this.divPrint.form.resetScroll();
		
		if(this.dsDietList.getRowCount() == 0){
			var grdH = 300;
			this.div00.form.grd01.setOffsetHeight(grdH);
			this.div00.setOffsetHeight(grdH);
			//프린트용 Grid 작업
			this.divPrint.form.grd01.setOffsetHeight(grdH);
			this.divPrint.setOffsetHeight(grdH);
			
			this.smfResetScroll(this);
		}else{
			this.divPrint.form.edt00.set_value(this.staYear.text + " " + this.cboMonth.text);
			var grdH = this._smfappendHeight(this.div00.form.grd01);
			if(this.dsDietList.getRowCount() == 0 ) grdH = 300;
			this.div00.form.grd01.setOffsetHeight(grdH);
			this.div00.setOffsetHeight(grdH);
			//프린트용 Grid 작업
			grdH = this._smfappendHeight(this.divPrint.form.grd01);
			if(this.dsDietList.getRowCount() == 0 ) grdH = 300;
			this.divPrint.form.grd01.setOffsetHeight(grdH);
			this.divPrint.setOffsetHeight(grdH+100);
			
			this.smfResetScroll(this);			
		}
			
		this.fnSearchAgyScList();
	}else if(svcid == "selectAgyScList"){//알레르기 정보
		var agyScText = "";
		for(i = 0; i < this.dsAgySc.getRowCount(); i++){
			if(i != 0) agyScText += ", ";
			
			agyScText += this.dsAgySc.getColumn(i, "agy");
		}
		this.div00_00.form.staAgySc.set_text(agyScText);
		this.smfResetScroll(this.div00_00.form.staAgySc);
	}
};


/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/


this.btnRight_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)	//다음 연도 클릭 버튼
{
	fv_year++;
	this.staYear.set_text(fv_year+"년");
	this.fnSearch();
	
};

this.btnLeft_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)	//이전 연도 클릭 버튼
{
	fv_year--;
	this.staYear.set_text(fv_year+"년");
	this.fnSearch();	
};

this.grd01_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var dsObj 	 = obj.getBindDataset();
	var cellText = obj.getCellProperty("body", e.cell, "text");
	var dietText = "";
	var day 	 = "";
	var mlsvYmd  = "";
	
	if(cellText.substr(5, 3) == "day"){//날자 cell을 선택하면 날자의 식단에서 
		dietText = dsObj.getColumn(e.row, "diet" + cellText.substr(8, 1));
		mlsvYmd = obj.getCellValue( e.row, e.cell );
		return false;
	}else{//식단 cell을 선택하면 식단에서 
		dietText = obj.getCellValue( e.row, e.cell );
		mlsvYmd = dsObj.getColumn(e.row, "date" + cellText.substr(9, 1));
	}

	if(this.smfIsNull(dietText)) return false;
	
	//상세조회 날자설정
// 	if(day < 10){
// 		day = "0" + day;
// 	}	
// 	var mlsvYmd = fv_year + fv_month + day;

	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback : this.fnPopupCallback, // 콜백함수 지정
		sender : obj, // sender 지정
		// 팝업 전달 파라메터 지정
		params : {  
			// 처리타입 지정
			procType 	: "search",
			mlsvYmd		: mlsvYmd,
			dataset 	: this.dsSearch
		},
	};
	
	if(this.smfIsMobile()){
		var srcInfo = this.smfCurScreenInfo();
		var srcInfoW = 640;
		var srcInfoH = srcInfo[1];
		if(srcInfoH > 1105) srcInfoH = 1105;
		this.smfDialog("_auto", "pa_par_sps_sl::par_spssl03_p00.xfdl", popupParams, "", "", srcInfoW, srcInfoH);
	}else{
		this.smfDialog("_auto", "pa_par_sps_sl::par_spssl03_p00.xfdl",popupParams);
	}	
};

//팝업 콜백
this.fnPopupCallback = function(context, responseParams, sender){
}

this.cboMonth_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	fv_month = e.postvalue;
	this.fnSearch();
};

this.btnPrinter_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	bSucc = system.print(this.divPrint);
};

//자녀 알레르기를 식단에 표시
this.fnDiteText = function(diteText){
	returnText = "";	
	diteText   = this.smfReplace(diteText, "<br />", "<br/>")
	diteTmp01  = diteText.split("<br/>");
	
	for(i = 0; i < diteTmp01.length; i++){
	
		diteTmp02 = diteTmp01[i].split(",");
		if(i != 0) returnText += "<br/>";

 		for(j = 0; j < diteTmp02.length; j++){	
			agyScCd 	= this.smfRight(diteTmp02[j], 2);
			agyScCdTmp  = this.smfRight(diteTmp02[j], 2);

			for(k = 0; k < this.dsStuAgyList.getRowCount(); k++){
				if(this.dsStuAgyList.getColumn(k, "stuAgyRegYn") == "N") continue;
				
				agyScCd = this.dsStuAgyList.getColumn(k, "agyScCd");
				
				if(agyScCdTmp == agyScCd){	
					agyScCd = "<fc v='#e52058'>" + agyScCd +"</fc>";
					break;
				}else{
					agyScCd = agyScCdTmp;
				}
			}
		
			if(j != 0) returnText += ",";
			returnText += this.smfRtrim(diteTmp02[j], agyScCdTmp);
			returnText += agyScCd;
		}		
	}

	return returnText;
}

this.par_spssl03_m00_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnSetResize();
	//this.smfResetScroll();
};

//컨텐츠 리사이징
this.fnSetResize = function(){
	this.div00_00.form.resetScroll();
	this.div00_00.setOffsetHeight(parseInt(this.div00_00.form.staAgySc.getOffsetBottom(),10)+40);
	this.smfResetScroll(this.div00_00);
	
	this.resetScroll();
}
]]></Script>
  </Form>
</FDL>
