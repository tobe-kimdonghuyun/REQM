    <Script type="xscript5.1"><![CDATA[/**
*   유치원 기본정보
*  @MenuPath    TEMPLATE
*  @FileName 	Temp01.xfdl
*  @Creator 	홍길동
*  @CreateDate 	2022.5.12
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.5.12     	홍길동 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::par_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 
this.par_spssl00_m00_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(this);
	
	//검색조건 설정
	var objParForm = this.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form;
	this.dsSearch.copyRow(0, objParForm.dsStuIduzEduYn, 0);
	
	if(objParForm.fv_stuLoad){
		//소재정보, 개인번호 체크
		var validate = this.parfValidate(this.dsSearch);	
		if(!validate) return false;

		this.fnSearch();
	}
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(obj, e)
{		
 	// 서비스 객체 생성
	this.smfSearchService("select")
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){		
			if(callbackParams.errors) return;
			
			if(this.smfIsNull(this.dsInfo.getColumn(0, "hmpgAddr"))){
				this.div00.form.edtHmpgAddr.set_visible(false);
			}
		});	
};


/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.div00_edtHmpgAddr_oneditclick = function(obj:nexacro.Edit,e:nexacro.EditClickEventInfo)
{
	system.execBrowser(obj.value);
};

this.div00_edt00_01_06_oneditclick = function(obj:nexacro.Edit,e:nexacro.EditClickEventInfo)
{
	system.execBrowser("https://e-childschoolinfo.moe.go.kr/presch/preschSumry.do?pPresch="+this.dsSearch.getColumn(0, "shlCd"));
};
]]></Script>
