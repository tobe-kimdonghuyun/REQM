    <Script type="xscript5.1"><![CDATA[/**
*  대국민 - 학부모서비스(유)
*  @MenuPath    TEMPLATE
*  @FileName 	par_spssl02_m00.xfdl
*  @Creator 	김지영
*  @CreateDate 	2022.06.20
*  @Desction    연간학사일정
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.06.20            김지영                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::par_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_years;

 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리
	this.smfInitForm(this);
		
	
	//검색조건 설정
	var objParForm = this.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form;
	this.dsSearch.copyRow(0, objParForm.dsStuIduzEduYn, 0);
	this.dsSearch.setColumn(0, "aaFxType", "1");
	
	//날짜(년도)
	var objDate = new nexacro.Date();
	fv_years = this.dsSearch.getColumn(0, "ayr");
	this.yearText.set_text(fv_years+"년");
	
	//소재정보, 개인번호 체크
	var validate = this.parfValidate(this.dsSearch);	
	if(!validate) return false;
	
	//  페이지 조회
	this.fnSearch();
};

 /************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(obj, e)
{
	this.dsSearch.setColumn(0, "ayr", nexacro.replaceAll(this.yearText.text, "년", ""));
 	// 서비스 객체 생성
	this.smfSearchService("select")
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;

			var grdH = this._smfappendHeight(this.divGrid.form.grdGrid00);
			this.divGrid.form.grdGrid00.setOffsetHeight(grdH);
			this.divGrid.setOffsetHeight(grdH);
			this.smfResetScroll(this);
			
			var grdH = this._smfappendHeight(this.divPrint.form.grdGrid00);
			this.divPrint.form.grdGrid00.setOffsetHeight(grdH);
			this.divPrint.setOffsetHeight(grdH);
			this.smfResetScroll(this);
		});	
};
 
/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
		
	if(svcid== "select"){	
		this.monthSet();
		this.divPrint.form.edt00.set_value(this.yearText.text + " " + this.cboAaFxType.text);
	}
};

/**
 * 팝업 콜백
 */
this.fnPopupCallback = function(context, responseParams, sender){
}

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.monthSet = function()
{	
	sVal = this.cboAaFxType.value;
	var arrMonth = new Array("03월:04월:05월:06월:07월:08월","09월:10월:11월:12월:01월:02월");
	arrMmlist = arrMonth[nexacro.toNumber(sVal-1)].split(":");
	
	for(var i = 0; i < arrMmlist.length; i++) {
		this.divGrid.form.grdGrid00.setCellProperty("Head",i+1,"text",arrMmlist[i]);
		this.divPrint.form.grdGrid00.setCellProperty("Head",i+1,"text",arrMmlist[i]);
	}
};


this.fnDisplayText = function(obj,nCell,nRow,sLongText)
{
	var sFont = 'normal 400 26px/normal "Noto Sans KR","NotoSansKR-Regular"';
	var nPadding = 15;

	return this.smfDispLongTextGrid(obj,nCell,nRow,sLongText,sFont,nPadding);
};
 /************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// '>'버튼
this.btnNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.yearText.set_text(++fv_years +"년");
	this.cboAaFxType.set_index(0);
	this.fnSearch();
};

// '<'버튼
this.btnBefore_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.yearText.set_text(--fv_years +"년");
	this.cboAaFxType.set_index(0);
	this.fnSearch();
};

//그리드 셀헤드명 변경(1학기/2학기)
this.cboAaFxType_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.fnSearch();
};

// Grid에 행사명만 나타내기 위한 함수 <fc value='red'>column</fc>
// argVal    9003:20220301:3·1절:전체:1|0001:20220301:학부모서비스 테스트:전체:1
this.fnSetEnter = function(argVal)
{
	argVal =  this.smfTrim(argVal);
	if(this.smfIsNull(argVal)) return "";

	var arrValList = new String(argVal).split("|");
	var len = arrValList.length;
	var sRtn = "";

	if(len < 1) len = 1;

	for(var i=0; i < len; i++){
		var oldInArrCode = arrValList[i].split(":");
		
		if(this.smfIsNull(oldInArrCode[2])){ 
			break;
		}
		var eventNm = oldInArrCode[2];
		var scCode = oldInArrCode[4]; 

		if(scCode == "2"){
			eventNm = "<fc v='#2b71bf'>" + eventNm +"</fc>";
		}else if(scCode == "1"){
			eventNm = "<fc v='#e52058'>" + eventNm +"</fc>";
		}
		
		if (i == 0) {
			sRtn += eventNm;
		} else {
			sRtn += "\r\n" + eventNm;
		}
	}
	
	if (this.smfIsNull(sRtn)) sRtn = "";

	return sRtn; 
}


this.grid00_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if (e.cell < 1 || e.row < 0 || (e.cell % 2 ) == 1 ) return;	

	var dsObj = obj.getBindDataset();
	var sColID = obj.getCellProperty("body", e.cell, "text");

 	sColID = sColID.slice(5); 
 	sColVal = dsObj.getColumn(e.row, sColID);

	if (this.smfIsNull(sColVal) || String(this.smfTrim(sColVal)).length == 0) {
		return;
	}

	// Popup Div Dataset에 행사목록 추가 === 시작
	var sValList = String(sColVal).substr(0, String(sColVal).length - 1).split("|");

	this.dsDaysList.set_enableevent(false);
	this.dsDaysList.clearData();

	var nRow = -1;

	for (var k = 0; k < sValList.length; k++) {
		var arrValList = new String(sValList[k]).split(":");	
		
		nRow = this.dsDaysList.addRow();
		this.dsDaysList.setColumn(nRow, "dd", arrValList[0]);
		this.dsDaysList.setColumn(nRow, "day", arrValList[1]);
		this.dsDaysList.setColumn(nRow, "event", arrValList[2]);
		this.dsDaysList.setColumn(nRow, "classNm", nexacro.replaceAll(this.smfLtrim(arrValList[3], "/"), "/", ", "));
		this.dsDaysList.setColumn(nRow, "ddcDdScCd", arrValList[4]);		
	}
	this.dsDaysList.set_enableevent(true);
	
	//div00 form 선언
	var objDiv00Form = this.divGrid.form;
	
	if (this.dsDaysList.getRowCount() > 0) this.dsDaysList.set_rowposition(0);

	// Popup Div 높이 초기화
	if(this.smfIsMobile()){
		objDiv00Form.pdvDaysList.setOffsetHeight(84);
	}else{
		objDiv00Form.pdvDaysList.setOffsetHeight(50);
	}

	//변경된 그리드의 높이에 맞춰 PopupDiv 높이를 변경
	var nVarHeight = objDiv00Form.pdvDaysList.form.grd00.getRealRowFullSize();
	objDiv00Form.pdvDaysList.setOffsetHeight(nVarHeight + 10);  // Popup Div Height 변경

	// popup Division open
	//var objRect= this.grdGrid00.getCellRect(e.row, 2);
	//this.pdvDaysList.trackPopupByComponent(this.grdGrid00, objRect.left, objRect.bottom+1);
	if(sValList.length > 1){
		objDiv00Form.pdvDaysList.trackPopupByComponent(objDiv00Form.grdGrid00, e.clientx, e.clienty);
	}else{
		this.fnAaFxPop(0);
	}
}

this.pdvDaysList_grd00_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	this.fnAaFxPop(e.row);
};

//상세조회 팝업
this.fnAaFxPop = function(nRow){
	var procType = "search";
	
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback : this.fnPopupCallback, // 콜백함수 지정
		sender : obj, // sender 지정
		// 팝업 전달 파라메터 지정
		params : {
			// 처리타입 지정
			procType 	: procType,
			// 파라메터 전달
			//dataset 	: this.dsDaysList,
			selRow 		: nRow
		},
	};
	
	if(this.smfIsMobile()){
		var srcInfo = this.smfCurScreenInfo();
		var srcInfoW = 640;
		var srcInfoH = srcInfo[1];
		if(srcInfoH > 626) srcInfoH = 626;
		this.smfDialog("_auto", "pa_par_sps_sl::par_spssl02_p00.xfdl", popupParams, "", "", srcInfoW, srcInfoH);
	}else{
		this.smfDialog("_auto", "pa_par_sps_sl::par_spssl02_p00.xfdl", popupParams);
	}
	
}

// 인쇄 버튼
this.btnPrinter_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	bSucc = system.print(this.divPrint);
};]]></Script>
