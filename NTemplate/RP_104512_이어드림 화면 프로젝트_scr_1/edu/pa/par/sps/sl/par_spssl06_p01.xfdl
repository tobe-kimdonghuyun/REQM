    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 > 학부모서비스(유) > 가정통신문
*  @FileName 	par_spssl06_p01
*  @Creator 	홍길동
*  @CreateDate 	2022.07.14
*  @Desction    가정통신문 조회/질의답변
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.07.14            문형선                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
//include "lib::cm_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
//this.fv_cddcCd = ""; //시도교육청 코드

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{ 
	//폼을 초기화 
	this.smfInitPopup(obj);
	//this.smfInitForm(this);
	
	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	this.dsSearch.copyRow(0, this.pv_params.dataset, 0);
	this.dsSearch.setColumn(0, "sType", this.pv_params.sType); // 2 : 조회, 1 : 목록, 3 : 답변
	this.dsSearch.setColumn(0, "nttId", this.pv_params.nttId);

	this.fnSearch();	
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 /**
 * @description 조회버튼 onclick
 */
this.fnSearch = function(obj, e)
{
 	// 서비스 객체 생성
	this.smfSearchService("selectSchneDetail")
//		.confirmIfModifiedGrid(this.grdExperlrnList)						// 데이터가 변경되었으면 확인메시지
//		.validateForm(this.divSearch) 										// 폼 유효성검사	
//		.paginator(this.grdExperlrnList, this.divPaginator, this.divPageSummary, this.dsPageInfo, obj, e)	// 페이징처리
		.run() 																// 실행
		.callback(function(callbackParams){									// 콜백
			if(callbackParams.errors) return;
		}) 
	;
}

//답변 제출
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.dsQestnList.getCaseCountNF( "ansNo != null" ) == 0){
		this.smfAlert("답변을 선택하고 제출하세요.");
		return;
	}
	
	this.dsSearch.setColumn(0, "sType", "3"); // 2 : 조회, 1 : 목록, 3 : 답변
// 서비스 객체 생성
	this.smfSaveService("saveQestnAns")
		.messagePrefix(obj.text)
//		.confirmIfModifiedGrid(this.grdExperlrnList)						// 데이터가 변경되었으면 확인메시지
//		.validateForm(this.divSearch) 										// 폼 유효성검사	
//		.paginator(this.grdExperlrnList, this.divPaginator, this.divPageSummary, this.dsPageInfo, obj, e)	// 페이징처리
		.run() 																// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.smfAlert(this.smfAfterServiceMessage(), this.opener.fnSearchSchne());
		});
}

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd <= -1) return;
	//this.dsQestnList.clearData();
	if(svcid == "selectSchneDetail"){
	
		//공개여부 텍스트로 표현
		if(this.dsSchneDetail.getColumn(0, "privateYn") == "N"){
			this.edtPrivate.set_value("공개");
		}else{
			this.edtPrivate.set_value("비공개");
		}
		
		//가정통신문이 마감되면 답변을 제출 못함.
		if("1" == this.dsSchneDetail.getColumn(0, "scnlSts")){
			this.btnSave.set_enable(true);
		}else{
			this.btnSave.set_enable(false);
		}
		
		//첨부파일 설정
		for(i = 0; i < this.dsFileInfo.getRowCount(); i++){			
			var sHandlerCode 		= "PA.PAR.SPS";
			var sFileSn				= this.dsFileInfo.getColumn(i, "fileRefrnId");
			var sFileId 			= this.dsFileInfo.getColumn(i, "fileId");
			var sFileSize 			= this.dsFileInfo.getColumn(i, "atchFileMg");
			var sBackendFilename	= this.dsFileInfo.getColumn(i, "atchFileGuid");
			var sFrontendFilename 	= this.dsFileInfo.getColumn(i, "atchFileNm");
			var sDownloadPath 		= "";
			var sFileEncryptYn 		= this.dsFileInfo.getColumn(i, "fileEncryptYn");
			var sPrivInfoFiltYn 	= this.dsFileInfo.getColumn(i, "atchFileNm");
			var sFileSaveStg 		= this.dsFileInfo.getColumn(i, "fileSaveStg");
			var sFileInfSaveYn 		= "Y";

			this.divFileDownload.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sFrontendFilename , sFileId
												,sDownloadPath,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn);
 		}
		
		if(this.dsSchneDetail.getColumn(0, "rplyUseYn") == "Y"){
			if(!this.smfIsMobile()) this.btnSave.set_visible(true);
			this.mskRplyBgngYmd.set_visible(true);
			this.Static65.set_visible(true);
			this.mskRplyEndYmd.set_visible(true);
			this.edtPrivate.set_visible(true);
			
			//가정통신문에 질의가 존재하면 질의목록을 생성한다.
			var setHeigth = 0;
			var staQestnNoTitleTop;
			var tapOrder = 14;
			
			if(this.smfIsMobile()){
				
				//모바일,태블릿
				if(this.dsQestnList.getRowCount() > 0){
					setHeigth = 460 + ((this.dsQestnList.getRowCount() - 1) * 455);
					//staFileTit
					var staQestnBack = new Static("staQestnBack", 20, "staFileTit:-1", null, setHeigth, 30, null);
					staQestnBack.set_cssclass("sta_WF_Dtl01");					
					this.addChild(staQestnBack.name, staQestnBack);
					staQestnBack.show();
					
					var staQestn = new Static("staQestn", 20, "staFileTit:-1", 150, setHeigth, null, null);
					staQestn.set_cssclass("sta_WF_DtlLabel01");
					staQestn.set_text("질의");
					this.addChild(staQestn.name, staQestn);
					staQestn.show();
				}
				
				
				for(i = 0; i < this.dsQestnList.getRowCount(); i++){
					var qestnNo = this.dsQestnList.getColumn(i, "qestnSn");
					
					if(i == 0){
						staQestnNoTitleTop = "staFileBak:-1";
					}else{
						staQestnNoTitleTop = "staQestnCnTitle"+this.dsQestnList.getColumn(i-1, "qestnSn")+":-1";
					}
				
					//질의번호 Line Static
					var staBg = new Static("staBg"+qestnNo, "staQestn:0", staQestnNoTitleTop, null, 80, 20, null);
					staBg.set_cssclass("sta_WF_Dtl01");
					this.addChild(staBg.name, staBg);
					staBg.show();			
					
					//질의번호 타이틀 StaticbtnSave:20
					//var staQestnNoTitle = new Static("staQestnNoTitle"+qestnNo, 180, 920 + (i * 309), 120, 80, null, null);
					var staQestnNoTitle = new Static("staQestnNoTitle"+qestnNo, "staQestn:0", "staBg"+qestnNo+":-80", 120, 80, null, null);
					staQestnNoTitle.set_cssclass("sta_WF_DtlLabel01");
					staQestnNoTitle.set_text("질의번호");
					this.addChild(staQestnNoTitle.name, staQestnNoTitle);
					staQestnNoTitle.show();
					
					//질의번호 Edit
					var edtQestnNo = new Edit("edtQestnNo"+qestnNo, "staQestnNoTitle"+qestnNo+":10", "staBg"+qestnNo+":-70", 100, 60, null, null);			
					edtQestnNo.set_cssclass("edi_WF_Input");
					edtQestnNo.set_enable(true);
					edtQestnNo.set_textAlign("center");
					edtQestnNo.set_value(qestnNo);
					edtQestnNo.set_readonly(true);
					edtQestnNo.set_taborder(tapOrder++);
					this.addChild(edtQestnNo.name, edtQestnNo);
					edtQestnNo.show();
					
					//답변 타이틀 Line Static
					var staBg = new Static("staQestnAnsBg"+qestnNo, "staQestn:0", "staQestnNoTitle"+qestnNo+":-1", null, 80, 20, null);
					staBg.set_cssclass("sta_WF_Dtl01");
					this.addChild(staBg.name, staBg);
					staBg.show();
					
					//답변 타이틀 Static
					var staQestnAnsTitle = new Static("staQestnAnsTitle"+qestnNo, "staQestn:0", "staQestnNoTitle"+qestnNo+":-1", 120, 80, null, null);
					staQestnAnsTitle.set_cssclass("sta_WF_DtlLabel01");
					staQestnAnsTitle.set_text("답변");
					this.addChild(staQestnAnsTitle.name, staQestnAnsTitle);
					staQestnAnsTitle.show();
					
					//답변 라디오
					//라디오버튼용 Innerdataset
					var ds = new Dataset("innerdataset");			
					//this.rdoQestnAns1.addChild("innerdataset", ds);
					ds.addColumn( "codecolumn", "string" );
					ds.addColumn( "datacolumn", "string" );
					for(ansNu = 0; ansNu <= this.dsQestnList.getColumn(i, "ansNu"); ansNu++){
						var row = ds.addRow();
						if(ansNu == 0){
							ds.setColumn(row, "codecolumn", null);
							ds.setColumn(row, "datacolumn", "선택");
						}else{
							ds.setColumn(row, "codecolumn", ansNu);
							ds.setColumn(row, "datacolumn", ansNu);
						}
					}
					//라디오버튼
// 					var rdoQestnAns = new Radio("rdoQestnAns"+qestnNo, "staQestnAnsTitle"+qestnNo+":10", "staQestnAnsTitle"+qestnNo+":-80", 286, 80, null, null);
// 					rdoQestnAns.setInnerDataset(ds);
// 					rdoQestnAns.set_codecolumn("codecolumn");
// 					rdoQestnAns.set_datacolumn("datacolumn");			
// 					rdoQestnAns.set_columncount(this.dsQestnList.getColumn(i, "ansNu"));			
// 					//rdoQestnAns.set_index(-1);
// 					rdoQestnAns.set_value(this.dsQestnList.getColumn(i, "ansNo"));
// 					rdoQestnAns.set_fittocontents("width");
// 					rdoQestnAns.setEventHandler("onitemchanged", this.rdo_onitemchanged, this );
// 					this.addChild(rdoQestnAns.name, rdoQestnAns);
// 					rdoQestnAns.show();
					var cmboQestnAns = new Combo("cmboQestnAns"+qestnNo, "staQestnAnsTitle"+qestnNo+":10", "staQestnAnsTitle"+qestnNo+":-70", 140, 60, null, null);
					cmboQestnAns.setInnerDataset(ds);
					cmboQestnAns.set_codecolumn("codecolumn");
					cmboQestnAns.set_datacolumn("datacolumn");
					var ansNo = null;
					if(!this.smfIsNull(this.dsQestnList.getColumn(i, "ansNo"))){
						ansNo = this.dsQestnList.getColumn(i, "ansNo");
					}
					cmboQestnAns.set_value(ansNo);
					cmboQestnAns.set_taborder(tapOrder++);
// 					cmboQestnAns.set_value(this.dsQestnList.getColumn(i, "ansNo"));
					cmboQestnAns.setEventHandler("onitemchanged", this.cmboQestnAns_onitemchanged, this );
					if("1" == this.dsSchneDetail.getColumn(0, "scnlSts")){						
						cmboQestnAns.set_enable(true);						
					}else{
						cmboQestnAns.set_enable(true);
					}
					this.addChild(cmboQestnAns.name, cmboQestnAns);
					
					cmboQestnAns.show();
					
					//질의내용 타이틀 Static
					var staQestnCnTitle = new Static("staQestnCnTitle"+qestnNo, "staQestn:0", "staQestnAnsTitle"+qestnNo+":-1", 120, 300, null, null);
					staQestnCnTitle.set_cssclass("sta_WF_DtlLabel01");
					staQestnCnTitle.set_text("질의내용");
					this.addChild(staQestnCnTitle.name, staQestnCnTitle);
					staQestnCnTitle.show();
					
					//질의내용 textarea
					var txtQestnCn = new TextArea("txtQestnCn"+qestnNo, "staQestnCnTitle"+qestnNo+":10", "staQestnCnTitle"+qestnNo+":-290", null, 280, 20, null);
					txtQestnCn.set_cssclass("txt_WF_Input");
					txtQestnCn.set_readonly(true) // set
					txtQestnCn.set_value(this.dsQestnList.getColumn(i, "qestnCn"));
					txtQestnCn.set_taborder(tapOrder++);
					this.addChild(txtQestnCn.name, txtQestnCn);
					txtQestnCn.show();
				}
				
				if(this.dsQestnList.getRowCount() > 0){
					var buttonSave = new Button("btnSaveMob", null, "staQestn:20", 108, 60, 20, null);
					buttonSave.set_cssclass("btn_WF_Crud");
					buttonSave.set_initvalueid("ivBtnAccessibilityButton");
					buttonSave.addEventHandler( "onclick", this.btnSave_onclick, this);
					buttonSave.set_text("제출");
					this.addChild(buttonSave.name, buttonSave);
					buttonSave.show();
					
					if(this.dsSchneDetail.getColumn(0, "rplyUseYn") == "Y"){
						buttonSave.set_visible(true);
					}else{
						buttonSave.set_visible(false);
					}
					
					if("1" == this.dsSchneDetail.getColumn(0, "scnlSts")){
						buttonSave.set_enable(true);
					}else{
						buttonSave.set_enable(false);
					}
				}
				
				if(this.dsQestnList.getRowCount() > 0){
					var btnClose = new Button("btnCloseMob", 20, "btnSaveMob:20", null, 80, 20, null);				
				
					btnClose.set_cssclass("btn_pop_normal");
					btnClose.set_initvalueid("ivBtnAccessibilityButton");
					btnClose.addEventHandler( "onclick", this.btn_close_onclick, this);
					btnClose.set_text("닫기");
					this.addChild(btnClose.name, btnClose);
					btnClose.show();
				}
					
			}else{//데스크탑
				if(this.dsQestnList.getRowCount() > 0){
					setHeigth = 150 + ((this.dsQestnList.getRowCount() - 1) * 149);
					
					var staQestnBack = new Static("staQestnBack", 20, 510, null, setHeigth, 20, null);
					staQestnBack.set_cssclass("sta_WF_Input02");
					this.addChild(staQestnBack.name, staQestnBack);
					staQestnBack.show();
					
					var staQestn = new Static("staQestn", 20, 510, 120, setHeigth, null, null);
					staQestn.set_cssclass("sta_WF_Input01");
					staQestn.set_text("질의");
					this.addChild(staQestn.name, staQestn);
					staQestn.show();
				}
				//this.staQestn.set_height(setHeigth);
				//this.staQestnBack.set_height(setHeigth);

				for(i = 0; i < this.dsQestnList.getRowCount(); i++){
					var qestnNo = this.dsQestnList.getColumn(i, "qestnSn");
					
					if(i == 0){
						staQestnNoTitleTop = "510";
					}else{
						staQestnNoTitleTop = "staQestnCnTitle"+this.dsQestnList.getColumn(i-1, "qestnSn")+":-1";
					}
				
					//질의번호 Line Static
					var staBg = new Static("staBg"+qestnNo, "staQestn:0", staQestnNoTitleTop, null, 42, 20, null);
					staBg.set_cssclass("sta_WF_Input02");
					this.addChild(staBg.name, staBg);
					staBg.show();			
					
					//질의번호 타이틀 Static
					var staQestnNoTitle = new Static("staQestnNoTitle"+qestnNo, "staQestn:0", "staBg"+qestnNo+":-42", 120, 42, null, null);
					staQestnNoTitle.set_cssclass("sta_WF_Input01Right_Box");
					staQestnNoTitle.set_text("질의번호");
					this.addChild(staQestnNoTitle.name, staQestnNoTitle);
					staQestnNoTitle.show();
					
					//질의번호 Edit
					var edtQestnNo = new Edit("edtQestnNo"+qestnNo, "staQestnNoTitle"+qestnNo+":5", "staQestnNoTitle"+qestnNo+":-37", 99, 30, null, null);			
					edtQestnNo.set_cssclass("edi_WF_Input");
					edtQestnNo.set_enable(true);
					edtQestnNo.set_value(qestnNo);
					edtQestnNo.set_readonly(true);
					edtQestnNo.set_taborder(tapOrder++);
					this.addChild(edtQestnNo.name, edtQestnNo);
					edtQestnNo.show();
					
					//답변 타이틀 Static
					var staQestnAnsTitle = new Static("staQestnAnsTitle"+qestnNo, 389, "staQestnNoTitle"+qestnNo+":-42", 120, 42, null, null);
					staQestnAnsTitle.set_cssclass("sta_WF_Input01");
					staQestnAnsTitle.set_text("답변");
					this.addChild(staQestnAnsTitle.name, staQestnAnsTitle);
					staQestnAnsTitle.show();
					
					//답변 라디오
					//라디오버튼용 Innerdataset
					var ds = new Dataset("innerdataset");			
					//this.rdoQestnAns1.addChild("innerdataset", ds);
					ds.addColumn( "codecolumn", "string" );
					ds.addColumn( "datacolumn", "string" );
					for(ansNu = 1; ansNu <= this.dsQestnList.getColumn(i, "ansNu"); ansNu++){
						var row = ds.addRow();
						ds.setColumn(row, "codecolumn", ansNu);
						ds.setColumn(row, "datacolumn", ansNu);
					}
					//라디오버튼
					var rdoQestnAns = new Radio("rdoQestnAns"+qestnNo, 514, "staQestnNoTitle"+qestnNo+":-42", 286, 37);
					rdoQestnAns.setInnerDataset(ds);
					rdoQestnAns.set_codecolumn("codecolumn");
					rdoQestnAns.set_datacolumn("datacolumn");			
					rdoQestnAns.set_columncount(this.dsQestnList.getColumn(i, "ansNu"));			
					//rdoQestnAns.set_index(-1);
					rdoQestnAns.set_value(this.dsQestnList.getColumn(i, "ansNo"));
					rdoQestnAns.set_taborder(tapOrder++);
					rdoQestnAns.set_fittocontents("width");
					rdoQestnAns.setEventHandler("onitemchanged", this.rdo_onitemchanged, this );
					if("1" == this.dsSchneDetail.getColumn(0, "scnlSts")){
						rdoQestnAns.set_enable(true);
					}else{
						rdoQestnAns.set_enable(false);
					}
					this.addChild(rdoQestnAns.name, rdoQestnAns);
					rdoQestnAns.show();
					
					//질의내용 타이틀 Static
					var staQestnCnTitle = new Static("staQestnCnTitle"+qestnNo, "staQestn:0", "staQestnNoTitle"+qestnNo+":-1", 120, 109, null, null);
					staQestnCnTitle.set_cssclass("sta_WF_Input01Right_Box");
					staQestnCnTitle.set_text("질의내용");
					this.addChild(staQestnCnTitle.name, staQestnCnTitle);
					staQestnCnTitle.show();
					
					//질의내용 textarea
					var txtQestnCn = new TextArea("txtQestnCn"+qestnNo, "staQestnCnTitle"+qestnNo+":5", "staQestnCnTitle"+qestnNo+":-105", null, 96, 20, null);
					txtQestnCn.set_cssclass("txt_WF_Input");
					txtQestnCn.set_readonly(true);
					txtQestnCn.set_value(this.dsQestnList.getColumn(i, "qestnCn"));
					txtQestnCn.set_taborder(tapOrder++);
					this.addChild(txtQestnCn.name, txtQestnCn);
					txtQestnCn.show();
				}
				
				this.btnSave.set_top(510 + setHeigth + 20);
					
			}
			this.resetScroll();
		}else{
			this.btnSave.set_visible(false);
			//this.mskRplyBgngYmd.set_visible(false);
			this.mskRplyBgngYmd.set_format("@");
			this.mskRplyBgngYmd.set_value("-");
			this.Static65.set_visible(false);
			this.mskRplyEndYmd.set_visible(false);
			//this.edtPrivate.set_visible(false);
			this.edtPrivate.set_value("-");
			this.btnClose.set_visible(true);
			this.smfResetScroll(this);
		}
	}
}

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
//답변을 질문dataset에 세팅(PC용 라디오)
this.rdo_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	var ansRow = obj.name.substring(11) - 1;
	this.dsQestnList.setColumn(ansRow, "ansNo", obj.value);
}

//답변을 질문dataset에 세팅(모바일용 콤보)
this.cmboQestnAns_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	var ansRow = obj.name.substring(12) - 1;
	this.dsQestnList.setColumn(ansRow, "ansNo", obj.value);
}

this.btn_close_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};
]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsSchneDetail=dsSchneDetail dsQestnList=dsQestnList dsFileInfo=dsFileInfo</Col>
            <Col id="asynctp"/>
            <Col id="url">par_sps_sl06_002.do</Col>
            <Col id="id">selectSchneDetail</Col>
          </Row>
          <Row>
            <Col id="id">saveQestnAns</Col>
            <Col id="url">par_sps_sl06_003.do</Col>
            <Col id="outDatasets">dsSchneDetail=dsSchneDetail dsQestnList=dsQestnList</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsQestnList=dsQestnList</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="shlCd" type="STRING" size="10"/>
          <Column id="ayr" type="STRING" size="4"/>
          <Column id="stuInvlNo" type="STRING" size="10"/>
          <Column id="wrtPrdBngnYmd" type="STRING" size="8"/>
          <Column id="wrtPrdEndYmd" type="STRING" size="8"/>
          <Column id="titlNm" type="STRING" size="150"/>
          <Column id="nttId" type="STRING" size="20"/>
          <Column id="sType" type="STRING" size="1"/>
          <Column id="cddcScCd" type="STRING" size="3"/>
          <Column id="schpaDtcNo" type="STRING" size="256" description="학부모고유번호"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsSchneDetail" useclientlayout="true">
        <ColumnInfo>
          <Column id="nttTitlNm" type="STRING" size="150" sumtext="제목"/>
          <Column id="nttId" type="STRING" size="15" sumtext="게시물번호"/>
          <Column id="rplyBgngYmd" type="STRING" size="8" sumtext="회신시작일자"/>
          <Column id="rplyEndYmd" type="STRING" size="8" sumtext="회신종료일자"/>
          <Column id="rplyUseYn" type="STRING" size="1"/>
          <Column id="privateYn" type="STRING" size="150" sumtext="비공개여부"/>
          <Column id="nttCn" type="STRING" size="5000" sumtext="게시물내용"/>
          <Column id="regId" type="STRING" size="30" sumtext="등록자ID"/>
          <Column id="regDt" type="STRING" size="8" sumtext="등록일자"/>
          <Column id="scnlSts" type="STRING" size="1" sumtext="1:진행중, 2:마감"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsQestnList" useclientlayout="true">
        <ColumnInfo>
          <Column id="nttId" type="STRING" size="20" sumtext="게시물ID"/>
          <Column id="shlCd" type="STRING" size="256"/>
          <Column id="ayr" type="STRING" size="256"/>
          <Column id="clsScCd" type="STRING" size="256"/>
          <Column id="clsCd" type="STRING" size="256"/>
          <Column id="stuInvlNo" type="STRING" size="256"/>
          <Column id="qestnSn" type="STRING" size="20" sumtext="질문번호"/>
          <Column id="qestnCn" type="STRING" size="1500" sumtext="질문내용"/>
          <Column id="ansNu" type="STRING" size="2" sumtext="답변개수"/>
          <Column id="ansNo" type="STRING" size="2" sumtext="답변번호"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="ds00">
        <ColumnInfo>
          <Column id="Column0" type="STRING" size="256"/>
          <Column id="Column1" type="STRING" size="256"/>
          <Column id="Column2" type="STRING" size="256"/>
          <Column id="Column3" type="STRING" size="256"/>
          <Column id="Column4" type="STRING" size="256"/>
          <Column id="Column5" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="Column0">질의번호</Col>
            <Col id="Column1">1</Col>
            <Col id="Column2">답변</Col>
            <Col id="Column3">4</Col>
            <Col id="Column4">질의내용</Col>
            <Col id="Column5">참석하시겠습니까?
1. 참석
2. 미참석</Col>
          </Row>
          <Row>
            <Col id="Column0">질의번호</Col>
            <Col id="Column2">답변</Col>
            <Col id="Column4">질의내용</Col>
            <Col id="Column1">2</Col>
            <Col id="Column5">참가하신다면 누구와 같이 참여하시나요?
1. 아이혼자
2. 아이와 엄마
3. 아이와 아빠
4. 참가안함</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsCheckApply" useclientlayout="true">
        <ColumnInfo>
          <Column id="datacolumn" type="STRING" size="256"/>
          <Column id="codecolumn" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="datacolumn">1</Col>
            <Col id="codecolumn">1</Col>
          </Row>
          <Row>
            <Col id="datacolumn">2</Col>
            <Col id="codecolumn">2</Col>
          </Row>
          <Row>
            <Col id="codecolumn">3</Col>
            <Col id="datacolumn">3</Col>
          </Row>
          <Row>
            <Col id="codecolumn">4</Col>
            <Col id="datacolumn">4</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsFileInfo" useclientlayout="true">
        <ColumnInfo>
          <Column id="fileRefrnId" type="string" size="32"/>
          <Column id="fileId" type="string" size="32"/>
          <Column id="suc" type="string" size="32"/>
          <Column id="atchFileNm" type="string" size="32"/>
          <Column id="atchFileGuid" type="string" size="32"/>
          <Column id="atchFileMg" type="string" size="32"/>
          <Column id="atchFileFirstMg" type="string" size="32"/>
          <Column id="fileExtsnNm" type="string" size="32"/>
          <Column id="minTypeNm" type="string" size="32"/>
          <Column id="fileCoursNm" type="string" size="32"/>
          <Column id="fileObjKey" type="string" size="32"/>
          <Column id="useYn" type="string" size="32"/>
          <Column id="fileEncryptYn" type="string" size="32"/>
          <Column id="fileSaveStg" type="string" size="32"/>
          <Column id="fileGubunCd" type="string" size="32"/>
          <Column id="gtrnsId" type="string" size="32"/>
          <Column id="rgtrNm" type="string" size="32"/>
          <Column id="rgtrDptNm" type="string" size="32"/>
          <Column id="mdfrNm" type="string" size="32"/>
          <Column id="mdfrDptNm" type="string" size="32"/>
          <Column id="rgtrId" type="string" size="32"/>
          <Column id="regDt" type="string" size="32"/>
          <Column id="mdfrId" type="string" size="32"/>
          <Column id="mdfcnDt" type="string" size="32"/>
          <Column id="chk" type="int" size="1"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="txt00" propid="value" datasetid="dsSchneDetail" columnid="nttCn"/>
      <BindItem id="item1" compid="divDetail.form.edt00_00_01" propid="value" datasetid="dsSchneDetail" columnid="nttTitlNm"/>
      <BindItem id="item2" compid="divDetail.form.edt00_00_02" propid="value" datasetid="dsSchneDetail" columnid="regYmd"/>
      <BindItem id="item3" compid="divDetail.form.edt00_00_00" propid="value" datasetid="dsSchneDetail" columnid="privateYn"/>
      <BindItem id="item5" compid="msk00" propid="value" datasetid="dsSchneDetail" columnid="regDt"/>
      <BindItem id="item7" compid="edt00_00_01" propid="value" datasetid="dsSchneDetail" columnid="nttTitlNm"/>
      <BindItem id="item4" compid="mskRplyBgngYmd" propid="value" datasetid="dsSchneDetail" columnid="rplyBgngYmd"/>
      <BindItem id="item6" compid="mskRplyEndYmd" propid="value" datasetid="dsSchneDetail" columnid="rplyEndYmd"/>
      <BindItem id="item8" compid="sta00" propid="text" datasetid="dsSchneDetail" columnid="nttTitlNm"/>
    </Bind>
    <InitValue>
      <MaskEdit id="mskRplyEndYmd" format="@@@@.@@.@@" type="string"/>
    </InitValue>
  </Form>
</FDL>
