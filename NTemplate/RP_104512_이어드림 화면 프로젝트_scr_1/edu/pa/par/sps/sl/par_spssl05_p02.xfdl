    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 > 학부모서비스(유) > 신청서 알림
*  @FileName 	par_spssl05_p02
*  @Creator 	문형선
*  @CreateDate 	2022.11.17
*  @Desction    신청서 알림 팝업
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.11.17            문형선                   최초 생성 
*******************************************************************************
*/ 

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
//include "lib::cm_script.xjs";
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{ 
	// 폼을 초기화
	this.smfInitPopup(obj);


	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	this.dsSearch.copyData(this.pv_params.dataset);
	this.dsSearch.addColumn("notiScCd", "string", 6);
	this.dsSearch.setColumn(0, "notiScCd", this.pv_params.notiScCd);

	this.fnSelectNoti();
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
* @description 신청서 알림 목록 조회
*/
this.fnSelectNoti = function(obj, e){
	var sServiceId = "selectNoti";
	
	if(this.smfIsMobile()){
		//this.dsPageInfo.setColumn(0, "pageSize", 5);
		sServiceId = "selectNotiTemp";
	}

	// 서비스 객체 생성
	this.smfSearchService(sServiceId)
//		.confirmIfModifiedGrid(this.grd36ExperlrnList)						// 데이터가 변경되었으면 확인메시지
//		.validateForm(this.divSearch) 										// 폼 유효성검사	
		.paginator(this.div00.form.grdNoti, this.divPaginator, this.divPageSummary, this.dsPageInfo, this.fnSelectNoti, e)	// 페이징처리
		.run() 																// 실행
		.callback(function(callbackParams){									// 콜백
			if(callbackParams.errors) return;
			
			if(this.smfIsMobile()){
				this.smfDataAppend(this, this.div00.form.grdNoti, this.dsNotiTemp);
				// 총 검색결과와 현재 검색 결과 수가 일치할 경우 [더보기]버튼 숨김 (TODO)
				if(this.dsPageInfo.getColumn(0, "totalCount")==this.dsNoti.getRowCount()){
					this.divPaginator.set_enable(false);
				}else{
					this.divPaginator.set_enable(true);
				}
				
				//this.smfResetScroll(this.div00.form);
				this.div00.form.resetScroll();
			}
		});
}

/**
* @description 알림 확인
*/
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 서비스 객체 생성
	this.smfSaveService("updateIdntyYn")
		.messagePrefix(obj.text)
//        .confirm("oooooo")
		.validateGridDelete(this.div00.form.grdNoti)						// 데이터가 변경되었으면 확인메시지
//		.validateForm(this.divSearch) 										// 폼 유효성검사
		.run() 																// 실행
		.callback(function(callbackParams){									// 콜백
			if(callbackParams.errors) return;
			this.smfAlert(this.smfAfterServiceMessage());
			this.fnSelectNoti();
			
			//알림건수 재조회
			this.opener.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form.fnSelectNotiCnt();
		}) 
	;
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd <= -1) return;
	
// 	if(svcid == "selectNoti"){
// 		if(this.smfIsMobile()){
// 			// 총 검색결과와 현재 검색 결과 수가 일치할 경우 [더보기]버튼 숨김 
// 			var pageIndex = this.dsPageInfo.getColumn(0, "pageIndex");
// 			var pageSize = this.dsPageInfo.getColumn(0, "pageSize");
// 			var totalCount = this.dsPageInfo.getColumn(0, "totalCount");
// 
// 			if(totalCount <= pageIndex * pageSize){	
// 				this.divPaginator.set_enable(false);
// 			}else{
// 				this.divPaginator.set_enable(true);
// 			}
// 		}
// 	}
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
//전체선택
this.grdNoti_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
    var columnName = obj.getCellProperty("body",e.cell,"text");
	if ("bind:_chk" == columnName){
		this.smfToggleChkHeader(obj, e);
	}else{
		// 정렬
		this.smfCheckAndSort(obj, e);
	}
};

//닫기
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};

this.form_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.div00.form.grdNoti.set_enableredraw(false);
	
	this.div00.form.grdNoti.set_enableredraw(true);
};
]]></Script>
    <Objects>
      <Dataset id="dsSearch" useclientlayout="true">
