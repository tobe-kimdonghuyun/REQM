    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 > 학부모서비스(유) > 신청서 알림
*  @FileName 	par_spssl05_p02
*  @Creator 	문형선
*  @CreateDate 	2022.11.17
*  @Desction    신청서 알림 팝업
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.11.17            문형선                   최초 생성 
*******************************************************************************
*/ 

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
//include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{ 
	// 폼을 초기화
	this.smfInitPopup(obj);

	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	this.dsSearch.copyData(this.pv_params.dataset);
	
	this.fnSelectNoti();
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
* @description 신청서 알림 목록 조회
*/
this.fnSelectNoti = function(){
	// 서비스 객체 생성
	this.smfSearchService("selectNoti")
//		.confirmIfModifiedGrid(this.grd36ExperlrnList)						// 데이터가 변경되었으면 확인메시지
//		.validateForm(this.divSearch) 										// 폼 유효성검사	
		.paginator(this.grdNoti, this.divPaginator, this.divPageSummary, this.dsPageInfo)	// 페이징처리
		.run() 																// 실행
		.callback(function(callbackParams){									// 콜백
			if(callbackParams.errors) return;

		}) 
	;
}

/**
* @description 알림 확인
*/
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 서비스 객체 생성
	this.smfSaveService("updateIdntyYn")
		.messagePrefix(obj.text)
//        .confirm("oooooo")
		.validateGridDelete(this.grdNoti)						// 데이터가 변경되었으면 확인메시지
//		.validateForm(this.divSearch) 										// 폼 유효성검사
		.run() 																// 실행
		.callback(function(callbackParams){									// 콜백
			if(callbackParams.errors) return;
			this.smfAlert(this.smfAfterServiceMessage());
			this.fnSelectNoti();
		}) 
	;
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd <= -1) return;
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
//전체선택
this.grdNoti_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
    var columnName = obj.getCellProperty("body",e.cell,"text");
	if ("bind:_chk" == columnName){
		this.smfToggleChkHeader(obj, e);
	}else{
		// 정렬
		this.smfCheckAndSort(obj, e);
	}
};

//닫기
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};]]></Script>
    <Objects>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="shlCd" type="STRING" size="256" description="배치JOBID"/>
          <Column id="stuInvlNo" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">selectNoti</Col>
            <Col id="inDatasets">dsSearch dsPageInfo</Col>
            <Col id="outDatasets">dsNoti dsPageInfo</Col>
            <Col id="url">/par_sps_sl05_006.do</Col>
          </Row>
          <Row>
            <Col id="id">updateIdntyYn</Col>
            <Col id="inDatasets">dsNoti=dsNoti:U dsSearch</Col>
            <Col id="url">/par_sps_sl05_007.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsNoti" useclientlayout="true" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="_chk" type="STRING" size="1"/>
          <Column id="rowNum" type="STRING" size="256"/>
          <Column id="shlCd" type="STRING" size="256"/>
          <Column id="stuInvlNo" type="STRING" size="256"/>
          <Column id="svcId" type="STRING" size="256"/>
          <Column id="nttId" type="STRING" size="256"/>
          <Column id="seqSn" type="STRING" size="256"/>
          <Column id="regDt" type="STRING" size="256"/>
          <Column id="iapWdsCn" type="STRING" size="256"/>
          <Column id="userId" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsPageInfo" useclientlayout="true">
        <ColumnInfo>
          <Column id="pageIndex" type="INT" size="256"/>
          <Column id="pageSize" type="INT" size="256"/>
          <Column id="totalCount" type="INT" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="pageIndex">1</Col>
            <Col id="pageSize">10</Col>
            <Col id="totalCount">0</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
  </Form>
</FDL>
