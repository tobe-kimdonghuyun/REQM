                <Cell col="2" text="구분"/>
                <Cell col="3" text="수신일"/>
                <Cell col="4" text="알림메세지"/>
              </Band>
              <Band id="body">
                <Cell edittype="checkbox" displaytype="checkboxcontrol" text="bind:_chk"/>
                <Cell col="1" text="bind:rowNum" edittype="none" textAlign="center"/>
                <Cell col="2" displaytype="normal" edittype="none" comboautoselect="false" combocodecol="businessCode" combodatacol="businessNm" combodataset="dsBunsCd" text="bind:svcId" textAlign="center"/>
                <Cell col="3" text="bind:regDt" textAlign="center" displaytype="mask" maskedittype="string" maskeditformat="@@@@.@@.@@"/>
                <Cell col="4" text="bind:iapWdsCn"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
