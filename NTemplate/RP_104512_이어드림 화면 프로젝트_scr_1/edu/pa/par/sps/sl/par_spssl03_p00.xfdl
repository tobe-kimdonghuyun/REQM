          <Column id="mlsvYmd" type="STRING" size="6" description="급식년월일"/>
          <Column id="mmealScCd" type="STRING" size="1" description="식사구분코드(1 조식 2 중식 3 석식, 파라미터가 널일 경우 기본값 중식(2) 설정)"/>
