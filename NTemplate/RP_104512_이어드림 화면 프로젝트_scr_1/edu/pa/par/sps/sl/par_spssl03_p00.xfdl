    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 공지사항 목록조회
*  @MenuPath    TEMPLATE
*  @FileName 	Temp01.xfdl
*  @Creator 	홍길동
*  @CreateDate 	2022.5.12
*  @Desction    검정고시p72+(공지목록)+(타이틀,그리드)
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.5.12     	홍길동 	        최초 생성 
*******************************************************************************
*/

//include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

this.par_spssl03_p00_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitPopup(this);
	
	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();

	this.dsSearch.addRow();
	this.dsSearch.copyRow(0, this.pv_params.dataset, 0);
	this.dsSearch.setColumn(0, "wlkMntlyScCd", "tday"); //tday : 당일조회
	this.dsSearch.setColumn(0, "mlsvYmd", this.pv_params.mlsvYmd); //조회일자

	this.fnSearch();
	this.fnSelectStuAgy();

};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 this.fnSelectStuAgy = function(obj, e)
{

 	// 서비스 객체 생성
	this.smfSearchService("selectStuAgy")
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});
};

this.fnSearch = function(obj, e)
{

 	// 서비스 객체 생성
	this.smfSearchService("selectDiet")
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});	
};

this.fnSearchAgyScList = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("selectAgyScList")
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});	
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
	
	if(svcid == "selectStuAgy"){
		this.fnSearch();
	}else if(svcid == "selectDiet"){
		//식단내용
		var dietNm = this.fnDiteText(this.dsDietList.getColumn(0, "dietNm"));
		dietNm = this.smfReplace(dietNm, "<br/>", "\n");
		dietNm = this.smfReplace(dietNm, "<br />", "\n");		
		//this.div00.form.txtDietNm.set_value(dietNm);
		this.div00.form.staOrigin.set_text(dietNm);

		//칼로리
		if(this.dsNtrCalInfoList.getRowCount() > 0) this.div00.form.edtCal.set_value(this.dsNtrCalInfoList.getColumn(0, "cotnCnt"));
		
		//원산지
		var plorNm = "";
		for(i = 0; i < this.dsPlorInfoList.getRowCount(); i++){
			if(i != 0 && !this.smfIsNull(this.dsPlorInfoList.getColumn(i, "plorNtnCdNm"))) plorNm += ", ";
			
			if(!this.smfIsNull(this.dsPlorInfoList.getColumn(i, "plorNtnCdNm"))){
				plorNm += this.dsPlorInfoList.getColumn(i, "plorMngPrdlCdNm") + "(" + this.dsPlorInfoList.getColumn(i, "plorNtnCdNm") + ")";
			}
		}
		
		this.div00.form.txtOrigin.set_value(plorNm);
		//this.smfResetScroll(this);
		
		//알레르기정보 조회
		this.fnSearchAgyScList();
	}else if(svcid == "selectAgyScList"){//알레르기 정보
		var agyScText = "";
		for(i = 0; i < this.dsAgySc.getRowCount(); i++){
			if(i != 0) agyScText += ", ";
			
			agyScText += this.dsAgySc.getColumn(i, "agy");
		}
		this.div00.form.txtAlerInfo.set_value(agyScText);
	}
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/



this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close();
};

this.div00_edtDiet_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{

};

//자녀 알레르기를 식단에 표시
this.fnDiteText = function(diteText){
	returnText = "";	
	diteText   = this.smfReplace(diteText, "<br />", "<br/>")
	diteTmp01  = diteText.split("<br/>");
	
	for(i = 0; i < diteTmp01.length; i++){

		diteTmp02 = diteTmp01[i].split(",");
		if(i != 0) returnText += "<br/>";
		
 		for(j = 0; j < diteTmp02.length; j++){
			agyScCd 	= this.smfRight(diteTmp02[j], 2);
			agyScCdTmp  = this.smfRight(diteTmp02[j], 2);

			for(k = 0; k < this.dsStuAgyList.getRowCount(); k++){
				if(this.dsStuAgyList.getColumn(k, "stuAgyRegYn") == "N") continue;
				
				agyScCd = this.dsStuAgyList.getColumn(k, "agyScCd");

				if(agyScCdTmp == agyScCd){	
					agyScCd = "<fc v='#e52058'>" + agyScCd +"</fc>";
					break;
				}else{
					agyScCd = agyScCdTmp;
				}
			}
			
			if(j != 0) returnText += ",";
			returnText += this.smfRtrim(diteTmp02[j], agyScCdTmp);
			returnText += agyScCd;
		}		
	}

	return returnText;
}
]]></Script>
    <Bind>
      <BindItem id="item3" compid="div00.form.mskDate" propid="value" datasetid="dsDietList" columnid="mlsvYmd"/>
    </Bind>
  </Form>
</FDL>
