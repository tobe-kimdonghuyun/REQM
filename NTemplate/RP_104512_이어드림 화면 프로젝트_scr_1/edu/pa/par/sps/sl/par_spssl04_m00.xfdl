    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">selectPadNefList</Col>
            <Col id="inDatasets">dsSearch</Col>
            <Col id="outDatasets">dsPadNefList=dsPadNefList dsMessage=message</Col>
            <Col id="url">par_sps_sl04_001.do</Col>
            <Col id="asynctp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="shlCd" type="STRING" size="10"/>
          <Column id="ayr" type="STRING" size="4"/>
          <Column id="stuInvlNo" type="STRING" size="10"/>
          <Column id="subSysCd" type="STRING" size="256"/>
          <Column id="cddcScCd" type="STRING" size="3" description="연계시도코드"/>
          <Column id="shlKndScCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="ayr"/>
            <Col id="subSysCd">PAR</Col>
            <Col id="shlKndScCd">01</Col>
            <Col id="shlCd"/>
            <Col id="stuInvlNo"/>
            <Col id="cddcScCd"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsPadNefList" useclientlayout="true">
        <ColumnInfo>
          <Column id="paymtYr" type="STRING" size="256" description="납부년도"/>
          <Column id="paymtTmd" type="STRING" size="256" description="납부일자"/>
          <Column id="cvaplQtrCodeNm" type="STRING" size="256" description="분기"/>
          <Column id="padCodeNm" type="STRING" size="256" description="납입코드명"/>
          <Column id="paymtAmt" type="BIGDECIMAL" size="256" description="납부금액"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsMessage" useclientlayout="true">
        <ColumnInfo>
          <Column id="message" type="STRING" size="256" sumtext="리턴메시지"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsStuAyrList">
        <ColumnInfo>
          <Column id="shlCd" type="STRING" size="256"/>
          <Column id="stuInvlNo" type="STRING" size="256"/>
          <Column id="ayr" type="STRING" size="256"/>
          <Column id="ayrNm" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    대국민 > 학부모서비스(유) > 교육비납입내역
*  @MenuPath    TEMPLATE
*  @FileName 	par_spssl06_m00.xfdl
*  @Creator 	
*  @CreateDate 	2022.07.20
*  @Desction    교육비납입내역
*
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.07.20     	홍길동 	        최초 생성 
*******************************************************************************
*/


/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::par_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(this);
	
	//검색영역 초기화처리를 한다.
	this.fnSearchInit();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 // 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
// 교육비납입내역 조회
this.fnSelectPadNef = function()
{
	// 서비스 객체 생성
	this.smfSearchService("selectPadNefList")
	// 데이터 검증
	//.validateForm(this.divReg)
	// 실행
	.run()
	// 콜백
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
	});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
//조회조건 초기화
this.fnSearchInit = function()
{
	//검색영역 초기화처리를 한다.
	//자녀정보에서 조회한 학년도학적 이력의 학년도 설정
	var objParForm = this.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form;
	
	//검색영역 초기화처리를 한다.
	//학년도 설정
	this.dsStuAyrList.copyData(objParForm.dsStuAyrList);
	this.dsStuAyrList.set_enableevent(false);
	for(i = 0; i < this.dsStuAyrList.getRowCount(); i++){
		this.dsStuAyrList.setColumn(i, "ayrNm", this.dsStuAyrList.getColumn(i, "ayrNm")+ "년")
	}
	this.dsStuAyrList.set_enableevent(true);
	
	//검색조건 설정
	this.dsSearch.copyRow(0, objParForm.dsStuIduzEduYn, 0);
	
	//소재정보, 개인번호 체크
	var validate = this.parfValidate(this.dsSearch);	
	if(!validate) return false;
	
	//자녀정보 설정
	this.fnSetChildInfo();
	
	//납입내역조회
	this.fnSelectPadNef();
}

//자녀정보 설정
this.fnSetChildInfo = function(){
	var dsStuInfo = fv_objParForm.dsStuIduzEduYn;
	//이름 설정
	this.div03.form.ediStuNm.set_value(this.smfStr(dsStuInfo.getColumn(0, "stuFlnm")));
	//만나이/반명
	this.div03.form.ediClsNm.set_value(this.smfStr(dsStuInfo.getColumn(0, "clsScNm")) + "/" + this.smfStr(dsStuInfo.getColumn(0, "clsNm")));
	//유치원명
	this.div03.form.ediShlNm.set_value(this.smfStr(dsStuInfo.getColumn(0, "shlNm")));
	//유아와의 관계
	this.div03.form.ediGnm.set_value(fv_objParForm.dsSchpaInfo.getColumn(0, "apsRelNm"));
	//소재지
	this.div03.form.ediShlAddr.set_value(this.smfStr(dsStuInfo.getColumn(0, "stuRoadAddr")));
}

this.cboSearchAyr_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	//납입내역조회
	this.fnSelectPadNef();
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="cboSearchAyr" propid="value" datasetid="dsSearch" columnid="ayr"/>
    </Bind>
  </Form>
</FDL>
