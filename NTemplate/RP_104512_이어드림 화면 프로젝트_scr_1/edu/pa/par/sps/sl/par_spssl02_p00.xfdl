    <Script type="xscript5.1"><![CDATA[/**
*  대국민 - 학부모서비스(유)
*  @MenuPath    
*  @FileName 	par_spssl02_p00
*  @Creator 	김지영
*  @CreateDate 	2022.06.20
*  @Desction    학사일정상세조회
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.06.20            김지영                   최초 생성 
*******************************************************************************
*/ 

 /************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
//include "lib::cm_script.xjs" 

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.pv_params;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitPopup(this);

	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	
	this.dsDaysList.addRow();
	this.dsDaysList.copyRow(0, this.opener.dsDaysList , this.pv_params.selRow);
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/


 /************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};
]]></Script>
    <Objects>
      <Dataset id="dsDaysList" useclientlayout="false">
        <ColumnInfo>
          <Column id="dd" type="STRING" size="2" description="일자" sumtext="년간:일자"/>
          <Column id="day" type="STRING" size="3" description="요일(일자)1" sumtext="요일(일자)1"/>
          <Column id="event" type="STRING" size="500" description="이벤트명1" sumtext="이벤트명1"/>
          <Column id="classNm" type="STRING" size="200" description="적용 학급연령1" sumtext="적용 학급연령1"/>
          <Column id="ddcDdScCd" type="STRING" size="1" sumtext="휴일구분"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item1" compid="div00.form.mskExperBgngYmd" propid="value" datasetid="dsDaysList" columnid="day"/>
      <BindItem id="item0" compid="div00.form.edtInfntFlnm00" propid="value" datasetid="dsDaysList" columnid="classNm"/>
      <BindItem id="item2" compid="div00.form.edtInfntFlnm01" propid="value" datasetid="dsDaysList" columnid="event"/>
      <BindItem id="item3" compid="div00.form.txtInfntFlnm01" propid="value" datasetid="dsDaysList" columnid="event"/>
    </Bind>
