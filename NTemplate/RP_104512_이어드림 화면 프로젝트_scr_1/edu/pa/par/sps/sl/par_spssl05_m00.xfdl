    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    대국민 > 학부모서비스(유) > 교회체험학습
*  @MenuPath    문형선
*  @FileName 	par_spssl05_m00.xfdl
*  @Creator 	
*  @CreateDate 	2022.07.07
*  @Desction    교외체험학습 목록
*
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.07.07     	문형선 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::par_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 
 //첨부파일 관련 변수 선언
var vFile;					//VirtualFile
var FileDialog0;			//FileDialog
var HttpObject0;			//HttpObject

var httpobject_isrunning 	= false; 		//파일다운로드 진행여부
var fv_shlNm = "";
var fv_nowAyr = 0;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(this);

	//검색영역 초기화처리를 한다.
	this.fnSearchInit();
	
	// Grid Checkbox 활성화/활성화 제어
	this.smfUpdateRednerGridCheckbox(this.div01.form.grdExperLrnList, 0, this.fnRenderGridCheckbox); 
};

this.fnSearchInit = function()
{
	//자녀정보에서 조회한 학년도학적 이력의 학년도 설정
	var objParForm = this.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form;
	this.dsAyr.copyData(objParForm.dsStuAyrList);
	
	//검색영역 초기화처리를 한다.
	//검색조건 설정
	this.dsSearch.copyRow(0, objParForm.dsStuIduzEduYn, 0);
	fv_nowAyr = objParForm.dsStuIduzEduYn.getColumn(0, "ayr");
	
	//1. 조회학년도 : 나이스 교무에 설정된 오늘날짜에 해당하는 학년도
	if(this.dsAyr.getCaseCountNF("ayr == '" + objParForm.dsStuIduzEduYn.getColumn(0, "ayr") + "'") > 0){
		this.divSearch.form.cboSearchAyr.set_value(objParForm.dsStuIduzEduYn.getColumn(0, "ayr"));
	}else{
		this.divSearch.form.cboSearchAyr.set_index(0);
	}
	
	fv_shlNm = objParForm.dsStuIduzEduYn.getColumn(0, "shlNm");
	
	//소재정보, 개인번호 체크
	var validate = this.parfValidate(this.dsSearch);	
	if(!validate) return false;
	
	this.fnSearch();
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 /**
 * @description 조회버튼 onclick
 */
this.fnSearch = function(obj, e)
{
	this.dsSearch.setColumn(0, "sType", "L"); // L : 목록조회
	
	var sServiceId = "selectExperLrnList";
	if(this.smfIsMobile()){
		sServiceId = "selectExperLrnListTemp";
	}
	
 	// 서비스 객체 생성
	this.smfSearchService(sServiceId)
//		.confirmIfModifiedGrid(this.grdExperLrnList)						// 데이터가 변경되었으면 확인메시지
		.validateForm(this.divSearch) 										// 폼 유효성검사	
		.paginator(this.div01.form.grdExperLrnList, this.divPaginator, this.divPageSummary, this.dsPageInfo, obj, e)	// 페이징처리
		.run() 																// 실행
		.callback(function(callbackParams){									// 콜백
			if(callbackParams.errors) return;
			
			if(this.smfIsMobile()){
				this.smfDataAppend(this, this.div01.form.grdExperLrnList, this.dsExperLrnListTemp);
				// 총 검색결과와 현재 검색 결과 수가 일치할 경우 [더보기]버튼 숨김 (TODO)
				if(this.dsPageInfo.getColumn(0, "totalCount")==this.dsExperLrnList.getRowCount()){
					this.divPaginator.set_enable(false);
				}else{
					this.divPaginator.set_enable(true);
				}
				
				this.smfResetScroll(this.div01.form);
			}
			
			if(this.dsExperLrnDayCntList.getRowCount() > 0){
				if(this.smfIsNull(this.dsExperLrnDayCntList.getColumn(0,"experLrnAllDay"))){
					experLrnAllDay = 0;
				}else{
					experLrnAllDay = this.dsExperLrnDayCntList.getColumn(0,"experLrnAllDay");
				}
				
				if(this.smfIsNull(this.dsExperLrnDayCntList.getColumn(0,"atendRcogDay"))){
					atendRcogDay = 0;
				}else{
					atendRcogDay = this.dsExperLrnDayCntList.getColumn(0,"atendRcogDay");
				}
				
				this.staCntTxt.set_text("교외체험학습 신청일수(누계)는「"+experLrnAllDay+"」일(현장신청포함)이며, 출석인정일수(누계)는「"+atendRcogDay+"」일입니다.");
			}else{
				this.staCntTxt.set_text("교외체험학습 신청일수(누계)는「0」일(현장신청포함)이며, 출석인정일수(누계)는「0」일입니다.");
			}
			
// 			if(this.smfIsMobile()){
// 				// 총 검색결과와 현재 검색 결과 수가 일치할 경우 [더보기]버튼 숨김 
// 				var pageIndex 	= this.dsPageInfo.getColumn(0, "pageIndex");
// 				var pageSize 	= this.dsPageInfo.getColumn(0, "pageSize");
// 				var totalCount 	= this.dsPageInfo.getColumn(0, "totalCount");
// 
// 				if(totalCount <= pageIndex * pageSize){	
// 					this.divPaginator.set_enable(false);
// 				}else{
// 					this.divPaginator.set_enable(true);
// 				}
// 			}
		}) 
	;
};

/**
 * @description 체험학습 신청취소 
 */
this.fnExecuteExperLrnAplyRtrcn = function(message)
{
	this.dsSearch.setColumn(0, "sType", "U"); // U : 수정(experLrnSttusCd	- 3 : 취소)

	// 서비스 객체 생성
	this.smfSaveService("updateExperLrnAplyRtrcn")
		.messagePrefix(message)
//        .confirm("oooooo")
//		.confirmIfModifiedGrid(this.grdExperLrnList)						// 데이터가 변경되었으면 확인메시지
		.validateForm(this.divSearch) 										// 폼 유효성검사
		.run() 																// 실행
		.callback(function(callbackParams){									// 콜백
			if(callbackParams.errors) return;
			
			this.fnSearch();
		}) 
	;
}

 /**
 * @description 삭제버튼 onclick
 */
this.btnDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	this.dsSearch.setColumn(0, "sType", "D"); // 2 : 삭제

	// 서비스 객체 생성
	this.smfDeleteService("deleteExperLrnList")
		.validateGridDelete(this.div01.form.grdExperLrnList, this.dsExperLrnListValid)
		.run() 																// 실행
		.callback(function(callbackParams){									// 콜백
			// 삭제하였습니다 알림 후 재조회
			//this.smfAlert(this.smfAfterServiceMessage(), this.fnSearch);
			this.smfAlert(this.smfAfterServiceMessage());
			
			this.fnSearch();
		}) 
	;
};
