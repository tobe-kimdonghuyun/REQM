/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
//날짜 포멧 설정
this.fnDateFormat = function(date)
{	
	return date.dateFormat("yyyy.MM.dd.");
}

// 그리드 헤더 클릭
this.grdExperLrnList_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
    var columnName = obj.getCellProperty("body",e.cell,"text");
	if ("bind:_chk" == columnName){
		this.smfToggleChkHeader(obj, e, this.fnRenderGridCheckbox);
	}else{
		// 정렬
		this.smfCheckAndSort(obj, e);
	}
};


// 그리드 체크박스 enable 처리
this.fnRenderGridCheckbox = function(ds, nRow){
	var atrzStsCd = this.dsExperLrnList.getColumn(nRow, "atrzStsCd");
	var aplyAtrzStsCd = this.dsExperLrnList.getColumn(nRow, "aplyAtrzStsCd");
	
	// 신청서, 보고서 결재상태가 1:상신(진행) or 4:완결 이면 삭제 불가능
	if((atrzStsCd == "1" || atrzStsCd == "4") || (aplyAtrzStsCd == "1" || aplyAtrzStsCd == "4")){
		return false;
	}else{
		return true;
	}
};


//그리드 Cell 클릭
this.grdExperLrnList_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	this.fnDetailView(obj,e);
};

this.div01_grdExperLrnList_onkeydown = function(obj:nexacro.Grid,e:nexacro.KeyEventInfo)
{
	if(e.keycode == 13){
		this.fnDetailView(obj,e);
	}
};

this.fnDetailView = function(obj,e)
{
	var experLrnStsCd = this.dsExperLrnList.getColumn(e.row, "experLrnStsCd");
	var experLrnRltStsCd = this.dsExperLrnList.getColumn(e.row, "experLrnRltStsCd");

	if((e.cell == 10 && experLrnStsCd == "3" && experLrnRltStsCd != "2")
		|| (e.cell == 11 && (experLrnStsCd == "3" || experLrnStsCd == "5"))){
		return false;
	}
	
	if(e.cell == 10 && experLrnStsCd == "5" && experLrnRltStsCd != "2"){ //결과제출
		this.fnExecuteExperLrnResult(this.dsExperLrnList.getColumn(e.row, "experLrnNo"));
	}else if(e.cell == 11 && experLrnStsCd == "2" && this.smfIsNull(this.dsExperLrnList.getColumn(e.row, "aplyAtrzStsCd"))){//체험학습신청취소
		//취소할 교외체험학습 정보를 Temp Dataset에 복사한다.
		this.dsExperLrnListCancel.clearData();
		var nRow = this.dsExperLrnListCancel.addRow();
		this.dsExperLrnListCancel.copyRow(nRow, this.dsExperLrnList, e.row);
		this.dsExperLrnListCancel.setColumn(nRow, "shlCd", this.dsSearch.getColumn(0, "shlCd"));
		this.dsExperLrnListCancel.setColumn(nRow, "experLrnStsCd", "3"); //체험학습상태코드(3 : 취소)
		this.fnExecuteExperLrnAplyRtrcn("취소");
	}else{
	
		if(e.cell == 0 || (e.cell == 10 && experLrnStsCd == "5" && experLrnRltStsCd != "2") || (e.cell == 11 && experLrnStsCd == "2")){
			return false;
		}else{
			var procType = "none";
			var sType = "R";
			
			// 팝업을 동작에 필요한 파라메터 지정
			var popupParams = {
				callback : this.fnPopupCallback, // 콜백함수 지정
				sender : obj, // sender 지정
				// 팝업 전달 파라메터 지정
				params : {
					// 처리타입 지정
					procType 	: procType,
					// 파라메터 전달
					dataset 	: this.dsSearch,
					experLrnNo 	: this.dsExperLrnList.getColumn(e.row, "experLrnNo"),
					sType 		: sType
				},
			};
			
			var srcInfo = this.smfCurScreenInfo();
			var srcInfoW = 0;
			var srcInfoH = srcInfo[1];
				
			if(this.smfIsMobile()){	
				srcInfoW = srcInfo[0];
			}else{
				srcInfoW = 940;				
			}
			var aplyAtrzStsCd = this.dsExperLrnList.getColumn(e.row, "aplyAtrzStsCd");
			var aplyAtrzStsNm = this.dsExperLrnList.getColumn(e.row, "aplyAtrzStsNm");
			trace("aplyAtrzStsCd:" + aplyAtrzStsCd + ", aplyAtrzStsNm : " + aplyAtrzStsNm);
			trace(this.dsExperLrnList.saveXML());
			if(("2" == this.dsExperLrnList.getColumn(e.row, "experLrnStsCd") && "4" == this.dsExperLrnList.getColumn(e.row, "aplyAtrzStsCd")) || !this.smfIsNull(this.dsExperLrnList.getColumn(e.row, "experLrnRltStsCd"))){					
				this.smfDialog("_auto", "pa_par_sps_sl::par_spssl05_p01.xfdl", popupParams, "", "", srcInfoW, srcInfoH);
			}else{
				this.smfDialog("_auto", "pa_par_sps_sl::par_spssl05_p00.xfdl", popupParams, "", "", srcInfoW, srcInfoH);
			}
		}
	}
};

//결과제출
this.fnExecuteExperLrnResult = function(experLrnNo){
	var procType = "none";
	var sType = "R";
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback : this.fnPopupCallback, // 콜백함수 지정
		sender : obj, // sender 지정
		// 팝업 전달 파라메터 지정
		params : {
			// 처리타입 지정
			procType 	: procType,
			// 파라메터 전달
			dataset 	: this.dsSearch,
			experLrnNo 	: experLrnNo,
			sType 		: sType
		},
	};
	
	var srcInfo = this.smfCurScreenInfo();
	var srcInfoW = 0;
	var srcInfoH = srcInfo[1];
		
	if(this.smfIsMobile()){
		srcInfoW = srcInfo[0];
	}else{
		srcInfoW = 940;		
	}
	
	this.smfDialog("_auto", "pa_par_sps_sl::par_spssl05_p01.xfdl", popupParams, "", "", srcInfoW, srcInfoH);
}

/**
 * @description 조회버튼 onclick
 */
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
 	//소재정보, 개인번호 체크
	var validate = this.parfValidate(this.dsSearch);	
	if(!validate) return false;
	
	if(this.smfIsMobile()){
		this.dsExperLrnListTemp.clearData();
	}
	
	if(this.smfIsNull(this.divSearch.form.calSearchBngnYmd.value) && !this.smfIsNull(this.divSearch.form.calSearchEndYmd.value)){
		this.smfAlert("시작일자를 지정하세요!", function(){
			this.divSearch.form.calSearchBngnYmd.setFocus();
			//this.divSearch.form.calSearchBngnYmd.set_value("1");
		});
		return false;
	}else if(!this.smfIsNull(this.divSearch.form.calSearchBngnYmd.value) && this.smfIsNull(this.divSearch.form.calSearchEndYmd.value)){
		this.smfAlert("종료일자를 지정하세요!", function(){
			this.divSearch.form.calSearchEndYmd.setFocus();
			//this.divSearch.form.calSearchEndYmd.set_value("1");
		});
		return false;
	}
	
	
	this.dsSearch.getColumnInfo()
	this.fnSearch(obj, e);
};

//[등록] 버튼 onclick
this.btnWrite_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var procType = "none";
	var sType 	 = "";
	
	if(obj == this.btnWrite){ // 등록버튼클릭
		procType = "none";
		sType 	 = "C";
	}
	
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback : this.fnPopupCallback, // 콜백함수 지정
		sender : obj, // sender 지정
		// 팝업 전달 파라메터 지정
		params : {
			// 처리타입 지정
			procType : procType,
			// 파라메터 전달
			dataset: this.dsSearch,
			sType : sType,
			nowAyr : fv_nowAyr
		},
	};
	
	var srcInfo = this.smfCurScreenInfo();
	var srcInfoW = 0;
	var srcInfoH = srcInfo[1];
		
	if(this.smfIsMobile()){		
		srcInfoW = srcInfo[0];
	}else{
		srcInfoW = 940;
	}
	
	this.smfDialog("_auto", "pa_par_sps_sl::par_spssl05_p00.xfdl", popupParams, "", "", srcInfoW, srcInfoH);
}


this.fnCheckSearchDays = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{
	var sStartDate = this.divSearch.form.calSearchBngnYmd.value;
	var sEndDate = this.divSearch.form.calSearchEndYmd.value;
	if( this.smfIsNull(sStartDate) || this.smfIsNull(sEndDate) ) return;
	
	var days = this.smfDiffDate(sStartDate, sEndDate);
	
	if(days < 0){
		// 메시지를 이용한 처리
		this.smfAlert("종료일자가 시작일자보다 빠릅니다.", function(){
			obj.set_value(e.prevalue);
		});
	}
};

//두날짜 사이의 일자구하기
this.fnExperDaysSet = function(experBgngYmd, experEndYmd)
{
	return this.smfDiffDate(experBgngYmd, experEndYmd) + 1;
};

this.btnGoUrl_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
 	var sUrl = 'pa_par_sps_ms::par_spsms00_m00.xfdl';
 	var params = {};
 				 
 	this.smfSetWorkPage(sUrl, params);  //자주묻는질문 세번째 탭으로 이동
};

this.btnDownLoad_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var fileUrl  = "/doc/edu/pa/par/";		
	var fileName = "Sample.hwp";
	//파일불러오기	
	var strServerUrl = fileUrl + fileName;
	
	var objComp = new FileDownload();
	objComp.download(strServerUrl);	
};

this.fnReportView = function()
{
	var sSecurityYN     = "N";   // 위변조방지 삽입
	var sReportName  = "/edu/pa/par/sps/sl/sample.ozr";

	// 리포트를 생성하기 위한 옵션을 설정한다.
	var oOzOption = {
					    reports : [	
									{	
										// 기본데이터
										  displayname : "교외체험할동 결과보고서"  // [필수] 멀티리포트시 Tree에 보여줄 이름
										, reportname  : sReportName  // [필수] 리포트명  "/jsonsample.ozr"
										
										// json연동형
										//  - jsonDs/jsonDsName은 갯수가 같아야 됨
										//, jsonDs     : [this.dsActCft, this.dsActCftList, this.dsRltList]   // [선택] json으로 변환할 데이터셋
										//, jsonDsName : ["ActCft", "ActCftList", "RltList"]                  // [선택] json으로 변환할 데이터의이름(ozr파일에서 지정된 값과 일치)
										, jsonParam  : ["viewerType=HTML5 Canvas Viewer 1"
									               ,"shlNm=" + fv_shlNm +"장 귀하"]  // [선택] json이외에추가할 데이터(KEY=VALUE형태의 스트링(배열))
										
										// 추가/보안옵션
										, security     : sSecurityYN       // [선택] 위변조방지 삽입   ("Y"(default):표시,"N":비표시)
									}
							      ]
	                };
					
	//리포트를 그린다.
	this.smfReportView(this, "popup", oOzOption, this.fnReportCallback);  // 팝업으로 표시(아직기능구현안됨)
};

this.par_spssl05_m00_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.smfResetScroll();
};
]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">selectExperLrnList</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsPageInfo=dsPageInfo</Col>
            <Col id="outDatasets">dsExperLrnList=dsExperLrnList dsPageInfo=dsPageInfo dsExperLrnDayCntList=dsExperLrnDayCntList</Col>
            <Col id="url">par_sps_sl05_001.do</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="id">selectExperLrnListTemp</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsPageInfo=dsPageInfo</Col>
            <Col id="outDatasets">dsExperLrnListTemp=dsExperLrnList dsPageInfo=dsPageInfo dsExperLrnDayCntList=dsExperLrnDayCntList</Col>
            <Col id="url">par_sps_sl05_001.do</Col>
          </Row>
          <Row>
            <Col id="id">updateExperLrnAplyRtrcn</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsExperLrnList=dsExperLrnListCancel</Col>
            <Col id="outDatasets"/>
            <Col id="url">par_sps_sl05_002.do</Col>
          </Row>
          <Row>
            <Col id="id">deleteExperLrnList</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsExperLrnList=dsExperLrnList:U</Col>
            <Col id="outDatasets"/>
            <Col id="url">par_sps_sl05_003.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="shlCd" type="STRING" size="10"/>
          <Column id="ayr" type="STRING" size="4"/>
          <Column id="stuInvlNo" type="STRING" size="10"/>
          <Column id="inqBngnYmd" type="STRING" size="8"/>
          <Column id="inqEndYmd" type="STRING" size="8"/>
          <Column id="experLrnNo" type="STRING" size="15" sumtext="체험학습번호"/>
          <Column id="sType" type="STRING" size="1"/>
          <Column id="cddcScCd" type="STRING" size="3"/>
          <Column id="schpaDtcNo" type="STRING" size="256"/>
          <Column id="searchKid" type="STRING" size="1"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="searchKid">1</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsAyr">
        <ColumnInfo>
          <Column id="ayr" type="STRING" size="4"/>
          <Column id="ayrNm" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsExperLrnList" useclientlayout="true">
        <ColumnInfo>
          <Column id="_chk" type="int" size="1"/>
          <Column id="experLrnNo" type="STRING" size="15" sumtext="체험학습번호"/>
          <Column id="experLrnStleCd" type="STRING" size="1" sumtext="체험학습형태코드"/>
          <Column id="experLrnStleNm" type="STRING" size="50" sumtext="체험학습형태명"/>
          <Column id="experBgngYmd" type="STRING" size="8" sumtext="체험시작일자"/>
          <Column id="experEndYmd" type="STRING" size="8" sumtext="체험종료일자"/>
          <Column id="experDay" type="STRING" size="2" sumtext="체험일수"/>
          <Column id="apsId" type="STRING" size="32" sumtext="신청자ID"/>
          <Column id="apsNm" type="STRING" size="32" sumtext="신청자이름"/>
          <Column id="apsRelNm" type="STRING" size="50" sumtext="신청자관계명"/>
          <Column id="stuInvlNo" type="STRING" size="10" sumtext="학생개인번호"/>
          <Column id="stuFlnm" type="STRING" size="100" sumtext="유아성명"/>
          <Column id="experLrnStsCd" type="STRING" size="1" sumtext="체험학습상태코드(1:임시저장, 2:제출, 3:취소, 4:미승인, 5:승인)"/>
          <Column id="experLrnStsNm" type="STRING" size="1" sumtext="체험학습상태명"/>
          <Column id="experLrnRltStsCd" type="STRING" size="30" sumtext="체험학습결과상태코드(1:임시저장, 2:제출)"/>
