    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    대국민 > 학부모서비스(유) > 가정통신문
*  @MenuPath    TEMPLATE
*  @FileName 	par_spssl06_m00.xfdl
*  @Creator 	
*  @CreateDate 	2022.07.20
*  @Desction    가정통신문
*
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.07.20     	홍길동 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::par_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(this);
	
	//검색영역 초기화처리를 한다.
	this.fnSearchInit();
};

this.fnSearchInit = function()
{
	//검색영역 초기화처리를 한다.
	//자녀정보에서 조회한 학년도학적 이력의 학년도 설정
	var objParForm = this.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form;
	this.dsAyr.copyData(objParForm.dsStuAyrList);
	
	//검색영역 초기화처리를 한다.
	//1. 조회학년도 : 나이스 교무에 설정된 오늘날짜에 해당하는 학년도
	//this.divSearch.form.cboSearchAyr.set_value(objParForm.dsStuIduzEduYn.getColumn(0, "ayr"));
	//검색조건 설정
	this.dsSearch.copyRow(0, objParForm.dsStuIduzEduYn, 0);
	this.divSearch.form.cboSearchAyr.set_index(0);
	
	//소재정보, 개인번호 체크
	var validate = this.parfValidate(this.dsSearch);	
	if(!validate) return false;
	
	this.fnSearchSchne();
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 /**
 * @description 조회버튼 onclick
 */
this.fnSearchSchne = function(obj, e)
{
	this.dsSearch.setColumn(0, "sType", "1"); // 2 : 조회, 1 : 목록, 3 : 답변
	
	var sServiceId = "selectSchneList";
	if(this.smfIsMobile()){
		sServiceId = "selectSchneListTemp";
	}

 	// 서비스 객체 생성
	this.smfSearchService(sServiceId)
//		.confirmIfModifiedGrid(this.grdExperlrnList)						// 데이터가 변경되었으면 확인메시지
		.validateForm(this.divSearch) 										// 폼 유효성검사	
		.paginator(this.div00.form.grdSchneList, this.divPaginator, this.divPageSummary, this.dsPageInfo, obj, e)	// 페이징처리
		.run() 																// 실행
		.callback(function(callbackParams){									// 콜백
			if(callbackParams.errors) return;
			
			if(this.smfIsMobile()){
				this.smfDataAppend(this, this.div00.form.grdSchneList, this.dsSchneListTemp);
				// 총 검색결과와 현재 검색 결과 수가 일치할 경우 [더보기]버튼 숨김 (TODO)
				if(this.dsPageInfo.getColumn(0, "totalCount")==this.dsSchneList.getRowCount()){
					this.divPaginator.set_enable(false);
				}else{
					this.divPaginator.set_enable(true);
				}
				
				this.smfResetScroll(this.div00.form);
			}
		}) 
	;
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd <= -1) return;
	
// 	if(svcid == "selectSchneList"){
// 		if(this.smfIsMobile()){
// 			// 총 검색결과와 현재 검색 결과 수가 일치할 경우 [더보기]버튼 숨김 
// 			var pageIndex 	= this.dsPageInfo.getColumn(0, "pageIndex");
// 			var pageSize 	= this.dsPageInfo.getColumn(0, "pageSize");
// 			var totalCount 	= this.dsPageInfo.getColumn(0, "totalCount");
// 
// 			if(totalCount <= pageIndex * pageSize){	
// 				this.divPaginator.set_enable(false);
// 			}else{
// 				this.divPaginator.set_enable(true);
// 			}
// 		}
// 	}
	
};

this.fnPopupCallback = function(context, responseParams, sender){
}

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 /**
 * @description 조회버튼 onclick
 */
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
 	//소재정보, 개인번호 체크
	var validate = this.parfValidate(this.dsSearch);	
	if(!validate) return false;
	
	if(this.smfIsMobile()){
		this.dsSchneListTemp.clearData();
	}
	
	if(this.smfIsNull(this.divSearch.form.calSearchBngnYmd.value) && !this.smfIsNull(this.divSearch.form.calSearchEndYmd.value)){
		this.smfAlert("시작일자를 지정하세요!", function(){
			this.divSearch.form.calSearchBngnYmd.setFocus();
			//this.divSearch.form.calSearchBngnYmd.set_value("1");
		});
		return false;
	}else if(!this.smfIsNull(this.divSearch.form.calSearchBngnYmd.value) && this.smfIsNull(this.divSearch.form.calSearchEndYmd.value)){
		this.smfAlert("종료일자를 지정하세요!", function(){
			this.divSearch.form.calSearchEndYmd.setFocus();
			//this.divSearch.form.calSearchBngnYmd.set_value("1");
		});
		return false;
	}
	
	this.fnSearchSchne(obj, e);
};

//날짜 포멧 설정fnDateFormat("20220720", "yyyy.MM.dd"); => 2022.07.20
this.fnDateFormat = function(date, dateFormat)
{
	if(this.smfIsNull(date)){
		return "";
	}else{
		return date.dateFormat(dateFormat);
	}
}

this.grdSchneList_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	this.fnDetailView(obj,e);
};

this.div00_grdSchneList_onkeydown = function(obj:nexacro.Grid,e:nexacro.KeyEventInfo)
{
	if(e.keycode == 13){
		this.fnDetailView(obj,e);
	}
};

this.fnDetailView = function(obj,e)
{
	var procType = "none";
	var sType = "2";

	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback : this.fnPopupCallback, // 콜백함수 지정
		sender : obj, // sender 지정
		// 팝업 전달 파라메터 지정
		params : {
			// 처리타입 지정
			procType	: procType,
			// 파라메터 전달
			dataset 	: this.dsSearch,
			nttId 		: this.dsSchneList.getColumn(e.row, "nttId"),
			sType 		: sType
		},
	};
	
	if(this.smfIsMobile()){
		var srcInfo = this.smfCurScreenInfo();
		var srcInfoW = srcInfo[0];
		var srcInfoH = srcInfo[1];
		this.smfDialog("_auto", "pa_par_sps_sl::par_spssl06_p01.xfdl", popupParams, "", "", srcInfoW, srcInfoH);
	}else{
		this.smfDialog("_auto", "pa_par_sps_sl::par_spssl06_p01.xfdl", popupParams);
	}
};

this.fnCheckSearchDays = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{
	var sStartDate = this.divSearch.form.calSearchBngnYmd.value;
	var sEndDate = this.divSearch.form.calSearchEndYmd.value;
	
	if( this.smfIsNull(sStartDate) || this.smfIsNull(sEndDate) ) return;
	
	var days = this.smfDiffDate(sStartDate, sEndDate);
	
	if(days < 0){
		// 메시지를 이용한 처리
		this.smfAlert("종료일자가 시작일자보다 빠릅니다.", function(){
			obj.set_value(e.prevalue);
		});
	}
};

this.expr_result = function(aplcnt, rplyYn) { 
	if(aplcnt == 0){
		return "";
	}else if(aplcnt > 0 && rplyYn == "Y"){
		return "회신";
	}else{
		return "미회신";
	}
}


this.par_spssl06_m00_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.smfResetScroll();
};

this.divSearch_edtSearchTitl_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode == 13)  this.divSearch.form.btnSearch.click();
};

this.fnDisplayText = function(obj,nCell,nRow,sLongText)
{
	var sFont = 'normal 400 26px/normal "Noto Sans KR","NotoSansKR-Regular"';
	var nPadding = 40;


	return this.smfDispLongTextGrid(obj,nCell,nRow,sLongText,sFont,nPadding);
};]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">selectSchneList</Col>
            <Col id="inDatasets">dsSearch dsPageInfo</Col>
            <Col id="outDatasets">dsSchneList dsPageInfo</Col>
            <Col id="url">par_sps_sl06_001.do</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="id">selectSchneListTemp</Col>
            <Col id="inDatasets">dsSearch dsPageInfo</Col>
            <Col id="outDatasets">dsSchneListTemp=dsSchneList dsPageInfo</Col>
            <Col id="url">par_sps_sl06_001.do</Col>
            <Col id="asynctp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsAyr">
        <ColumnInfo>
          <Column id="ayr" type="STRING" size="4"/>
          <Column id="ayrNm" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="shlCd" type="STRING" size="10"/>
          <Column id="ayr" type="STRING" size="4"/>
          <Column id="stuInvlNo" type="STRING" size="10"/>
          <Column id="wrtPrdBngnYmd" type="STRING" size="8"/>
          <Column id="wrtPrdEndYmd" type="STRING" size="8"/>
          <Column id="titlNm" type="STRING" size="150"/>
