    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 > 학부모서비스(유) > 교회체험학습 
*  @FileName 	par_spssl05_p01
*  @Creator 	문형선
*  @CreateDate 	2022.07.14
*  @Desction    교외체험학습 결과
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.07.14            문형선                   최초 생성 
*******************************************************************************
*/ 

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
//include "lib::cm_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
//this.fv_cddcCd = ""; //시도교육청 코드
this.fv_buttonMsg  = "";
this.fv_schpaDtcNo = "";

var fv_shlNm = "";
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{ 
	// 폼을 초기화
	this.smfInitPopup(obj);

	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();

	this.dsSearch.copyData(this.pv_params.dataset);
	this.dsSearch.setColumn(0, "sType", this.pv_params.sType); // C : 등록, R: 조회
	
	//신청정보 설정
	var objParForm = this.opener.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form;
	fv_schpaDtcNo = objParForm.dsStuIduzEduYn.getColumn(0, "schpaDtcNo");
	//유치원 명 가져오기
	fv_shlNm = objParForm.dsStuIduzEduYn.getColumn(0, "shlNm");
	
	this.dsExperLrn.setColumn(0, "apsId", 		fv_schpaDtcNo);
	this.dsExperLrn.setColumn(0, "stuInvlNo", 	this.dsSearch.getColumn(0, "stuInvlNo"));	
	this.dsExperLrn.setColumn(0, "stuFlnm", 	objParForm.dsStuIduzEduYn.getColumn(0, "stuFlnm"));
	this.dsExperLrn.setColumn(0, "clsNm", 		objParForm.dsStuIduzEduYn.getColumn(0, "clsNm"));	
	this.dsExperLrn.setColumn(0, "schpaDtcNo", 	fv_schpaDtcNo);

	
	if("R" == this.pv_params.sType){
 		var experLrnNo = this.pv_params.experLrnNo;
		this.dsSearch.setColumn(0, "experLrnNo", experLrnNo);
 		this.fnSelect();
	}
	
	//=======================================
	// 업로드관련 초기설정을 한다.
	//=======================================
	// 업로드시 저장위치등을 판별할 정보 세팅(대문자 : 시스템코드(2)+"."+서브시스템코드(3)+"."+대분류코드(3))
	this.divRltDetail.form.divFileUpload.UPLOAD_CreateComplete = this.fnEventUploadCreateComplete;  // 필요한 경우만 세팅
	this.divRltDetail.form.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;        // 필요한 경우만 세팅(세팅권장)
	this.divRltDetail.form.divFileUpload.UPLOAD_OnError        = this.fnEventUploadError;           // 필요한 경우만 세팅(세팅권장)
	this.divRltDetail.form.divFileUpload.UPLOAD_AfterAddFile   = this.fnEventUploadAfterAddFile;     
	this.divRltDetail.form.divFileUpload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)
	
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
* @description 교외체험학습 정보 조회
*/
this.fnSelect = function(){
	// 서비스 객체 생성
	this.smfSearchService("selectExperLrn")
//		.confirmIfModifiedGrid(this.grd36ExperlrnList)						// 데이터가 변경되었으면 확인메시지
//		.validateForm(this.divSearch) 										// 폼 유효성검사	
//		.paginator(this.grdExperlrnList, this.divPaginator, this.divPageSummary, this.dsPageInfo, obj, e)	// 페이징처리
		.run() 																// 실행
		.callback(function(callbackParams){									// 콜백
			if(callbackParams.errors) return;
			
			var sYear  = this.smfSubStr(this.dsExperLrn.getColumn(0, "regDt"), 0, 4);
			var sMonth = this.smfSubStr(this.dsExperLrn.getColumn(0, "regDt"), 4, 6);
			var sDay   = this.smfSubStr(this.dsExperLrn.getColumn(0, "regDt"), 6, 8);
			
			this.div00.form.staToDay.set_text(sYear + "년    " + sMonth + "월    " + sDay + "일");
			//this.div00.form.staLegalRepr01.set_text("본인   성명 :  " + this.dsExperLrn.getColumn(0, "stuFlnm"));
			this.div00.form.staLegalRepr02.set_text("보호자(법정대리인)   성명 :  " + this.dsExperLrn.getColumn(0, "apsNm"));
			this.div00.form.staShlNm.set_text(fv_shlNm + "장 귀하");
			
			this.div00.form.rdoPersonalInfo.set_value("Y");
			//this.div00.form.chkLegalRepr01.set_value("Y");
			this.div00.form.chkLegalRepr02.set_value("Y");
		}) 
	;
}
 /**
 * @description 교외체험학습 결과 저장
 */
this.fnSave = function(txtMessage){
	// 서비스 객체 생성 
	this.smfSaveService("saveExperLrnRslt")
		.messagePrefix(txtMessage)
		.showConfirm(false)
		// 데이터 검증
		.validateForm(this.divRltDetail)
		// 데이터 존재 필수
//		.requireExistsData(this.dsExperLrn)
// 		
// 		// 데이터 변경 필수
// 		.requireModifredData(this.dsExperlrnInfo)
// 		// 중복검사
// 		.validateDuplicate({
// 			grid: this.grdMain,
// 			// gridText: "음반목록",
// 			columnNames: ["name", "artist", "release"], // 중복검사할 컬럼명
// 			columnText: "이름, 아티스트, 출시일자",
// 		})
		// 실행
		.run() 

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			if(callbackParams.message != "SUCCESS"){
				this.smfAlert(callbackParams.message, this.opener.fnSearch());
			}else{
			
			// 저장이 완료되었습니다.
			// 재조회
			this.smfAlert(fv_buttonMsg+ " 하였습니다.", this.opener.fnSearch());
			//this.fnSelect();
			}
		});
}

this.fnDelete = function(){
	// 서비스 객체 생성
	this.smfDeleteService("deleteExperLrn")
		.run() 																// 실행
		.callback(function(callbackParams){									// 콜백
			// 삭제하였습니다 알림 후 재조회
			this.smfAlert(this.smfAfterServiceMessage(), this.opener.fnSearch());
		}) 
	;
}
/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd <= -1) return;
	
	if(svcid == "selectExperLrn"){
		//첨부파일 div처리
		if(!("1" == this.dsExperLrn.getColumn(0, "atrzStsCd") || "4" == this.dsExperLrn.getColumn(0, "atrzStsCd"))
			&& ("4" == this.dsExperLrn.getColumn(0, "aplyAtrzStsCd"))
			&& !("2" == this.dsExperLrn.getColumn(0, "experLrnRltStsCd") && this.smfIsNull(this.dsExperLrn.getColumn(0, "lrnCn")))){
			// 신청서가 완결 상태여야 보고서 제출 가능
			this.divRltDetail.form.divFileUpload.set_visible(true);
 			this.divRltDetail.form.divFileDownload.set_visible(false);
			this.divRltDetail.form.divFileUpload.form.fnSetButtonBarEdit("add,remove,remove_all,download");
		}else{
			this.divRltDetail.form.divFileUpload.set_visible(false);
 			this.divRltDetail.form.divFileDownload.set_visible(true);
		}
		
		//등록자와 로그인사용자 아이디비교 로직 추가 필요
		//this.dsExperLrn.setColumn(0, "schpaDtcNo", "PAR_TEST_ID");
		
		//var experDays = this.fnExperDaysSet(this.dsExperLrn.getColumn(0, "experBgngYmd"), this.dsExperLrn.getColumn(0, "experEndYmd"));
		this.edtExperDays.set_value(this.dsExperLrn.getColumn(0, "abeDdCnt") + " 일");
		
		//체험학습상태에 따른 "제출", "임시저장" 버튼 visible 설정
		//체험학습상태에 따른 "체험학습형태코드" readonly 설정
		
		for(i = 0; i < this.dsFileinfo.getRowCount(); i++){
			var sHandlerCode 		= "PA.PAR.SPS";
			var sFileSn 			= this.dsFileinfo.getColumn(i, "fileRefrnId");
			var sFileId 			= this.dsFileinfo.getColumn(i, "fileId");
			var sFileSize 			= this.dsFileinfo.getColumn(i, "atchFileMg");
			var sBackendFilename 	= this.dsFileinfo.getColumn(i, "atchFileGuid");
			var sFrontendFilename	= this.dsFileinfo.getColumn(i, "atchFileNm");
			var sDownloadPath 		= "";
			var sFileEncryptYn 		= this.dsFileinfo.getColumn(i, "fileEncryptYn");
			var sPrivInfoFiltYn 	= this.dsFileinfo.getColumn(i, "atchFileNm");
			var sFileSaveStg 		= this.dsFileinfo.getColumn(i, "fileSaveStg");
			var sFileInfSaveYn 		= "Y";
			
 			if(!("1" == this.dsExperLrn.getColumn(0, "atrzStsCd") || "4" == this.dsExperLrn.getColumn(0, "atrzStsCd"))
				&& ("4" == this.dsExperLrn.getColumn(0, "aplyAtrzStsCd"))){
// 				this.divRltDetail.form.divFileUpload.set_visible(true);
// 				this.divRltDetail.form.divFileDownload.set_visible(false);				
				this.divRltDetail.form.divFileUpload.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sFrontendFilename , sFileId
												,sDownloadPath,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn);
 			}else{
// 				this.divRltDetail.form.divFileDownload.set_visible(true);
// 				this.divRltDetail.form.divFileUpload.set_visible(false);
//  				//this.divRltDetail.form.divFileDownload.form.fnAddUploadedFile(handlerCode, fileSn, fileSize, backendFilename, frontendFilename , fileId);
// 				//this.divRltDetail.form.divFileUpload.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sFrontendFilename);	
				this.divRltDetail.form.divFileDownload.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sFrontendFilename , sFileId
												,sDownloadPath,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn);
 			}
// 			this.divRltDetail.form.divFileUpload.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sFrontendFilename , sFileId
// 												,sDownloadPath,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn);
			
			
 		}
	}else if(svcid == "deleteExperLrn"){
		// 팝업 종료
 		this.close(true);
	}

	var experLrnStsCd = this.dsExperLrn.getColumn(0, "experLrnStsCd");
	var experLrnRltStsCd = this.dsExperLrn.getColumn(0, "experLrnRltStsCd");
	if(svcid != "insertMenuHstr"){
		this.fnButtonControl(experLrnStsCd, experLrnRltStsCd);
	}
};

this.fnEventUploadCreateComplete = function(obj,paramObj)
{
	
}
//파일업로드 성공 CALLBACK
this.fnEventUploadComplete = function(obj, paramObj, objResultDataset)
{
	// 업로드 성공 후, newfile에 있는 파일들을 webfile로 옮긴다.
	this.divRltDetail.form.divFileUpload.form.fnSetUploadCompleteState(obj,paramObj);	

	// 업로드한 file을 가져오는 법(샘플 가이드)	
	if(objResultDataset){
		var sFileRefrnId = objResultDataset.getColumn(0,"fileRefrnId");
		// 테스트를 위해 아래의 sFileRefrnId를 세팅
		if(!this.smfIsNull(sFileRefrnId))
		{
			this.dsExperLrn.setColumn(0, "fileRefrnId", sFileRefrnId);
		}
	}
	//return true;
	this.fnSave(fv_buttonMsg);
}

//파일업로드 에러 CALLBACK
this.fnEventUploadError = function(obj,paramObj)
{
	//this.smfAlert("파일 업로드에 실패하였습니다.");
	//return false;
}

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
//임시저장
this.btnSaveTemp_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//개인정보 동의 여부 체크
	if(!this.fnPersonalInfoAgreeChk()){
		return false;
	}
	
	if(this.smfIsNull(this.divRltDetail.form.txtExperlrnCn.value)){
		this.smfAlert("학습내용은 필수입니다.",[],function(){this.divRltDetail.form.txtExperlrnCn.setFocus(true);});
		return;
	}
	this.smfConfirm("임시저장 하시겠습니까?", function(confirmParams){
		if(confirmParams.confirmResult){
			this.dsSearch.setColumn(0, "sType", "U"); // C : 생성, R : 조회, U : 수정, D : 삭제, L : 목록
			this.dsExperLrn.setColumn(0, "experLrnRltStsCd", "1");
			this.dsExperLrn.setColumn(0, "schpaDtcNo", fv_schpaDtcNo);
			this.dsExperLrn.setColumn(0, "rltInfoYn", "Y"); // 개인정보동의여부
			this.dsExperLrn.setColumn(0, "rltApsYn", "Y"); // 학부모 서명 확인
			fv_buttonMsg = "임시저장";
			
			this.divRltDetail.form.divFileUpload.form.fnFileUpload();
		}
	});
};

//제출
this.btnSubmit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//개인정보 동의 여부 체크
	if(!this.fnPersonalInfoAgreeChk()){
		return false;
	}
	
	if(this.smfIsNull(this.divRltDetail.form.txtExperlrnCn.value)){
		this.smfAlert("학습내용은 필수입니다.",[],function(){this.divRltDetail.form.txtExperlrnCn.setFocus(true);});
		return;
	}
	
	this.smfConfirm("제출 하시겠습니까?", function(confirmParams){
		if(confirmParams.confirmResult){
			this.dsSearch.setColumn(0, "sType", "U"); // C : 생성, R : 조회, U : 수정, D : 삭제, L : 목록
			this.dsExperLrn.setColumn(0, "experLrnRltStsCd", "2");
			this.dsExperLrn.setColumn(0, "schpaDtcNo", fv_schpaDtcNo);
			this.dsExperLrn.setColumn(0, "rltInfoYn", "Y"); // 개인정보동의여부
			this.dsExperLrn.setColumn(0, "rltApsYn", "Y"); // 학부모 서명 확인
			fv_buttonMsg = "제출";
			
			this.divRltDetail.form.divFileUpload.form.fnFileUpload();
		}
	});
};

this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
	this.smfConfirm("신청취소 하시겠습니까?", function(confirmParams){
		if(confirmParams.confirmResult){
			this.dsSearch.setColumn(0, "sType", "U"); // C : 생성, R : 조회, U : 수정, D : 삭제, L : 목록
			this.dsExperLrn.setColumn(0, "experLrnStsCd", "3"); // 1:임시저장, 2:제출, 3:취소, 4:미승인, 5:승인
			this.dsExperLrn.setColumn(0, "schpaDtcNo", fv_schpaDtcNo);
			fv_buttonMsg = "신청취소";
			this.fnSave(obj.text);
		}
	});
};

this.btnDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsSearch.setColumn(0, "sType", "D"); // C : 생성, R : 조회, U : 수정, D : 삭제, L : 목록
	this.fnDelete();	
};

// 버튼 설정
this.fnButtonControl = function(experLrnStsCd, experLrnRltStsCd){
	//체험학습상태에 따른 "제출", "임시저장" 버튼 visible 설정
	//체험학습상태에 따른 "체험학습형태코드" readonly 설정
	
	var atrzStsCd = this.dsExperLrn.getColumn(0, "atrzStsCd");
	var aplyAtrzStsCd = this.dsExperLrn.getColumn(0, "aplyAtrzStsCd");
	
	if(experLrnStsCd == "5"){ //체험학습상태 "5:승인"이면 임시저장, 제출 모두 안됨.
		//"제출", "임시저장" 버튼
		this.btnSaveTemp.set_enable(false);
		this.btnSubmit.set_enable(false);
		this.btnCancel.set_enable(false);
		this.btnDelete.set_enable(false);
		
		this.divRltDetail.form.txtExperlrnCn.set_readonly(true);
		this.div00.form.rdoPersonalInfo.set_readonly(true);
		this.div00.form.chkLegalRepr01.set_readonly(true);
		this.div00.form.chkLegalRepr02.set_readonly(true);
	}else if(experLrnStsCd == "3" || experLrnStsCd == "4"){ //체험학습상태 "5:승인"이면 임시저장, 제출 모두 안됨.
		//"제출", "임시저장" 버튼
		this.btnSaveTemp.set_enable(false);
		this.btnSubmit.set_enable(false);
		this.btnCancel.set_enable(false);
		this.btnDelete.set_enable(true);
		
		this.divRltDetail.form.txtExperlrnCn.set_readonly(true);
		this.div00.form.rdoPersonalInfo.set_readonly(true);
		this.div00.form.chkLegalRepr01.set_readonly(true);
		this.div00.form.chkLegalRepr02.set_readonly(true);
	}else if(experLrnRltStsCd == "1"){ //1:임시저장, 2:제출
		//"제출", "임시저장" 버튼
		if(!(aplyAtrzStsCd == "1" || aplyAtrzStsCd == "4")){
			// 신청서 결재상태가 1:상신(진행) or 4:완결이 아니면 제출, 삭제 가능
			this.btnSaveTemp.set_enable(true);
			this.btnSubmit.set_enable(true);
			this.btnCancel.set_enable(false);
			this.btnDelete.set_enable(true);
		}else{
			// 신청서 결재상태가 1:상신(진행) or 4:완결이면 제출, 삭제 불가능
			this.btnSaveTemp.set_enable(true);
			this.btnSubmit.set_enable(true);
			this.btnCancel.set_enable(false);
			this.btnDelete.set_enable(false);
		}
	}else if(experLrnRltStsCd == "2"){ //1:임시저장, 2:제출
		//"제출", "임시저장" 버튼
		if(!this.smfIsNull(atrzStsCd) && (atrzStsCd == "1" || atrzStsCd == "4")) { // 결과보고서 결재단계
			// 보고서 결재상태가 1:상신(진행) or 4:완결이면 제출, 삭제 불가능
			this.btnSubmit.set_enable(false);
			this.btnDelete.set_enable(false);
			
			this.divRltDetail.form.txtExperlrnCn.set_readonly(true);
			this.div00.form.rdoPersonalInfo.set_readonly(true);
			this.div00.form.chkLegalRepr01.set_readonly(true);
			this.div00.form.chkLegalRepr02.set_readonly(true);
		}else{
			 // 신청서가 상신 및 완결 상태여야 보고서 제출 가능
			if((aplyAtrzStsCd == "1" || aplyAtrzStsCd == "4")){
				// 결과보고서 제출 상태 + 학습내용 null이면 나이스 제출으로 수정 불가능
				if(this.smfIsNull(this.dsExperLrn.getColumn(0, "lrnCn"))){
					this.btnSubmit.set_enable(false);
					this.btnDelete.set_enable(false);
					
					this.divRltDetail.form.txtExperlrnCn.set_readonly(true);
					this.div00.form.rdoPersonalInfo.set_readonly(true);
					this.div00.form.chkLegalRepr01.set_readonly(true);
					this.div00.form.chkLegalRepr02.set_readonly(true);
				}else{
					this.btnSubmit.set_enable(true);
					this.btnDelete.set_enable(false);
				
					this.divRltDetail.form.txtExperlrnCn.set_readonly(false);
					this.div00.form.rdoPersonalInfo.set_readonly(false);
					this.div00.form.chkLegalRepr01.set_readonly(false);
					this.div00.form.chkLegalRepr02.set_readonly(false);
				}
			}else{
				this.btnSubmit.set_enable(false);
				this.btnDelete.set_enable(true);
			
				this.divRltDetail.form.txtExperlrnCn.set_readonly(true);
				this.div00.form.rdoPersonalInfo.set_readonly(true);
				this.div00.form.chkLegalRepr01.set_readonly(true);
				this.div00.form.chkLegalRepr02.set_readonly(true);
			}
		}
		this.btnSaveTemp.set_enable(false);
		this.btnCancel.set_enable(false);
	}else{
		//"제출", "임시저장" 버튼
		this.btnSaveTemp.set_enable(true);
		this.btnSubmit.set_enable(false);
		this.btnCancel.set_enable(false);
		this.btnDelete.set_enable(false);
	}
};

//팝업 닫기
this.btn_close_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};

//두날짜 사이의 일자구하기
this.fnExperDaysSet = function(experBgngYmd, experEndYmd)
{
	return this.smfDiffDate(experBgngYmd, experEndYmd) + 1;
};


// KUpload를 생성시 지정할 property값
//  Property의 자세한 설명은 
//  \12 나이스개발센터\17. 도입SW\01. 나이스클라우드\분리-06.파일 업로드 관리(RAON K Upload 2018)\raonkupload\sdk\index.html 참조 
this.fnSetRaonProp = function()
{
	var objAddRaonProps = {
								ExtensionAllowOrLimit : "0"        // 업로드 할 파일 확장자를 허용 또는 제한 설정
							,   ExtensionArr          : "exe,apk,ipa,msi,css"  // 제한 및 허용할 확장자명을 ",(콤마)"로 구분하여 설정
							,   AllowedZeroFileSize   : "1"        // 0byte 파일의 업로드를 허용 할지 설정합니다.(기본값은 "0" 허용안함이고, "1"로 설정시 허용입니다.)
							,	MaxOneFileSize		  : '8MB'									// 파일당 최대 사이즈
							,	MaxTotalFileSize	  : '25MB'									// 첨부 최대 사이즈
						  };
	return objAddRaonProps;
}

//개인정보 수집 및 법정대리인 동의 여부 체크
this.fnPersonalInfoAgreeChk = function(){
	if(this.div00.form.rdoPersonalInfo.value != "Y"){
		this.smfAlert("개인정보 수집·이용 동의가 필요합니다.", function(){
			this.div00.form.rdoPersonalInfo.setFocus();
		});
		return false;
	}
	
// 	if(this.div00.form.chkLegalRepr01.value != "Y"){
// 		this.smfAlert("만 14세 미만의 경우 \"개인정보 수집·이용 동의\"를 위한 \n보호자(법정대리인)의 동의가 필요합니다.", function(){
// 			this.div00.form.chkLegalRepr01.setFocus();
// 		});
// 		return false;
// 	}
	
	if(this.div00.form.chkLegalRepr02.value != "Y"){
		this.smfAlert("만 14세 미만의 경우 \"개인정보 수집·이용 동의\"를 위한 \n보호자(법정대리인)의 동의가 필요합니다.", function(){
			this.div00.form.chkLegalRepr02.setFocus();
		});
		return false;
	}
	
	return true;
}
]]></Script>
