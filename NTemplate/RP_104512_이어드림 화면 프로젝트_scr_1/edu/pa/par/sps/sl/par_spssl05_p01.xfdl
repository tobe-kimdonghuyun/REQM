        <Button id="btnDelete" taborder="31" text="삭제" top="div00:20" height="30" width="50" cssclass="btn_WF_Crud" onclick="btnDelete_onclick" enable="false" right="20" initvalueid="ivBtnAccessibilityButton"/>
        <Button id="btnClose" taborder="32" text="닫기" onclick="btn_close_onclick" cssclass="btn_pop_normal" left="432" top="btnSaveTemp:20" width="74" height="34" escapebutton="true" hotkey="ALT+C" initvalueid="ivBtnAccessibilityButton"/>
      </Layout>
