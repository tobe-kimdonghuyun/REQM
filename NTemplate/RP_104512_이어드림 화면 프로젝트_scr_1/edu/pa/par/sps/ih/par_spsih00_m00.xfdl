/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(obj, e)
{

 	// 서비스 객체 생성
	this.smfSearchService("list")
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});	
};


/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
	
	if(svcid == "list"){
		if(this.dsBdyDevSittnList.getRowCount() > 0) this.divTitle.form.imgStuFlnm.set_text(this.dsBdyDevSittnList.getColumn(0, "stuFlnm") + "의 건강기록");
	}
};

