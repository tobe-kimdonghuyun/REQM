          </Row>
          <Row>
            <Col id="agyScCd">4</Col>
            <Col id="agyScCdNm">4</Col>
            <Col id="cdSorNo">4</Col>
            <Col id="stuAgyRegYn">4</Col>
          </Row>
          <Row/>
          <Row/>
          <Row/>
          <Row/>
          <Row/>
          <Row/>
          <Row/>
          <Row/>
          <Row/>
          <Row/>
          <Row/>
          <Row/>
          <Row/>
          <Row/>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsService" useclientlayout="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256"/>
          <Column id="outDatasets" type="STRING" size="256"/>
          <Column id="asynctp" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">selectStuAgy</Col>
            <Col id="url">/par_sps_ih01_001.do</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsStuAgyList=dsAgyList</Col>
          </Row>
          <Row>
            <Col id="id">selectAgyScList</Col>
            <Col id="url">/par_sps_sl03_003.do</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsAgySc=dsAgySc</Col>
          </Row>
          <Row>
            <Col id="id">saveStuAgy</Col>
            <Col id="url">/par_sps_ih01_002.do</Col>
            <Col id="inDatasets">dsStuAgyInsList=dsStuAgyInsList dsStuInfo=dsStuInfo</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="false">
        <ColumnInfo>
          <Column id="shlCd" type="STRING" size="256"/>
          <Column id="ayr" type="STRING" size="256"/>
          <Column id="stuDtcNo" type="STRING" size="256"/>
          <Column id="cddcScCd" type="STRING" size="3"/>
          <Column id="userId" type="STRING" size="256"/>
          <Column id="instCd" type="STRING" size="256"/>
          <Column id="stuInvlNo" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsAgySc" useclientlayout="true">
        <ColumnInfo>
          <Column id="agy" type="STRING" size="256"/>
          <Column id="agyScCd" type="STRING" size="256"/>
          <Column id="agyScCdNm" type="STRING" size="256"/>
          <Column id="cdSorNo" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsStuAgyListTmp" useclientlayout="true">
        <ColumnInfo>
          <Column id="cdSorNo1" type="STRING" size="256"/>
          <Column id="agyScCdNm1" type="STRING" size="32"/>
          <Column id="agyScCd1" type="STRING" size="32"/>
          <Column id="stuAgyRegYn1" type="STRING" size="1"/>
          <Column id="cdSorNo2" type="STRING" size="256"/>
