    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 공지사항 목록조회
*  @MenuPath    TEMPLATE
*  @FileName 	Temp01.xfdl
*  @Creator 	홍길동
*  @CreateDate 	2022.5.12
*  @Desction    검정고시p72+(공지목록)+(타이틀,그리드)
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.5.12     	홍길동 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::par_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.par_spsih01_m00_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(this);
	
	//검색영역 초기화처리를 한다.
	this.fnSearchInit();
	
	//소재정보, 개인번호 체크
	var validate = this.parfValidate(this.dsSearch);	
	if(!validate) return false;
	
	this.fnSearchAgySc();
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
//알레르기 코드 조회
this.fnSearchAgySc = function()
{
	// 서비스 객체 생성
	this.smfSearchService("selectAgyScList")
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});	
}

this.fnSearch = function(obj, e)
{

 	// 서비스 객체 생성
	this.smfSearchService("selectStuAgy")
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			
		});
};

this.fnSave = function(){
	// 서비스 객체 생성 
	this.smfSaveService("saveStuAgy")
	
	//.validateGrid(this.div00.form.grdAgyList, this.dsStuAgyInsListValid)
		// 데이터 존재 필수
// 		.requireExistsData(this.dsExperLrn) 
// 		// 데이터 검증
// 		.validateForm(this.divDetail)
		// 데이터 변경 필수
//		.requireModifredData(this.dsExperLrn)
// 		// 중복검사
// 		.validateDuplicate({
// 			grid: this.grdMain,
// 			// gridText: "음반목록",
// 			columnNames: ["name", "artist", "release"], // 중복검사할 컬럼명
// 			columnText: "이름, 아티스트, 출시일자",
// 		})

		// 실행
		.run() 

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;			
			// 저장이 완료되었습니다.
			// 재조회
			//this.smfAlert('CM002', [], this.opener.fnSearch());
			this.smfAlert(this.smfAfterServiceMessage());
		});
}
/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
	
	if(svcid =="selectAgyScList"){
		this.fnSearch();
	}else if(svcid =="selectStuAgy"){
		var nCnt  = 0;
		var nRow  = 0;
		var nCell = 0;
		
		this.dsStuAgyListTmp.set_updatecontrol(false);
  		for(i = 0; i < this.dsStuAgyList.getRowCount(); i++){
			if(this.smfIsMobile()){
				nCell = i % 3;
			}else{
				nCell = i % 4;
			}
			nCnt++;
			
			
 			if(nCell == 0) nRow = this.dsStuAgyListTmp.addRow(); 

			if(this.dsStuAgyList.getRowCount() >= nCnt){
				this.dsStuAgyListTmp.setColumn(nRow, "cdSorNo" + (nCell + 1), this.dsStuAgyList.getColumn(i, "cdSorNo"));
				this.dsStuAgyListTmp.setColumn(nRow, "agyScCdNm" + (nCell + 1), this.dsStuAgyList.getColumn(i, "agyScCdNm"));
				this.dsStuAgyListTmp.setColumn(nRow, "agyScCd" + (nCell + 1), this.dsStuAgyList.getColumn(i, "agyScCd"));
				this.dsStuAgyListTmp.setColumn(nRow, "stuAgyRegYn" + (nCell + 1), this.dsStuAgyList.getColumn(i, "stuAgyRegYn"));
			}
			
  		}
		this.dsStuAgyListTmp.set_updatecontrol(true);
		if(this.dsStuAgyList.getRowCount() > 0) this.div00.form.grdAgyList.selectCell(0, 0);
		
		var grdH = this._smfappendHeight(this.div00.form.grdAgyList);
		this.div00.form.grdAgyList.setOffsetHeight(grdH);
		this.div00.setOffsetHeight(grdH);
		this.smfResetScroll(this);
	}
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.fnSearchInit = function()
{
	//자녀정보에서 조회한 학년도학적 이력의 학년도 설정
	var objParForm = this.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form;
	
	//검색영역 초기화처리를 한다.
	//검색조건 설정
	this.dsSearch.copyRow(0, objParForm.dsStuIduzEduYn, 0, "shlCd=shlCd,instCd=shlCd,stuInvlNo=stuInvlNo,stuDtcNo=stuDtcNo,ayr=ayr,cddcScCd=cddcScCd,userId=schpaDtcNo");
	this.dsStuInfo.copyRow(0, objParForm.dsStuIduzEduYn, 0, "shlCd=shlCd,instCd=shlCd,ayr=ayr,grd=clsScCd,clsScCd=clsScCd,stuInvlNo=stuInvlNo,stuDtcNo=stuDtcNo,stuNm=stuFlnm,clsCd=clsCd,clsNm=clsNm,clsNo=stuClsNo,cddcScCd=cddcScCd,userId=schpaDtcNo");
}

//저장
this.btnWrite_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(!this.smfIsUpdate(this.dsStuAgyListTmp)){
		this.smfAlert("변경된 데이터가 없어서 저장할 수 없습니다.");
		return false;
	}
	
	this.dsStuAgyInsList.clearData();
	
	if(this.smfIsMobile()){
		nCell = 3;
	}else{
		nCell = 4;
	}
	
	for(i = 0; i < this.dsStuAgyListTmp.getRowCount(); i++){
		for(j = 0; j < nCell; j++){
			var stuAgyRegYn = this.dsStuAgyListTmp.getColumn(i, "stuAgyRegYn" + (j+1));
			if(stuAgyRegYn == "Y"){
				var nRow = this.dsStuAgyInsList.addRow();
				this.dsStuAgyInsList.setColumn(nRow, "agyScCdNm", this.dsStuAgyListTmp.getColumn(i, "agyScCdNm"+ (j+1)));
				this.dsStuAgyInsList.setColumn(nRow, "agyScCd", this.dsStuAgyListTmp.getColumn(i, "agyScCd"+ (j+1)));
				this.dsStuAgyInsList.setColumn(nRow, "stuAgyRegYn", stuAgyRegYn);
			}
		}
	}
	
	this.dsStuInfo.setColumn(0, "invlInfoPrcusAgreYn", "Y"); //개인정보활용동의여부
	this.dsStuInfo.setColumn(0, "stuAgyOcrnWrkScCd", "20"); //학생알레르기발생업무구분코드(20 : 학부모서비스(학부모))
	
	this.fnSave();
};
]]></Script>
    <Objects>
      <Dataset id="dsStuAgyList" useclientlayout="true">
        <ColumnInfo>
          <Column id="agyScCd" type="string" size="32"/>
          <Column id="agyScCdNm" type="string" size="32"/>
