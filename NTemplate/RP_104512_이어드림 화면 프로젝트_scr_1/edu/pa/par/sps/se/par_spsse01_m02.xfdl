        <Static id="sta00_03" taborder="41" text="※ 학부모서비스를 통한 자녀 유아학비 관리는 2024년 3월부터 가능합니다.&#13;&#10;    (2024학년도 이전에는 e유치원 활용) " left="320" top="1338" width="724" height="45" cssclass="sta_WF_Blue14" initvalueid="ivStcAccessibilityOn"/>
        <ImageViewer id="imgTitle01" taborder="12" text="유치원에 계속 재원하는 경우" left="0" top="1424" height="40" cssclass="img_WF_SubTit02" width="300" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_00" taborder="13" text="‘국민행복카드’ 신규발급 받거나 기존 사용중인 ‘ 아이즐거운카드’, ‘아이행복카드’ 사용가능" left="0" top="1466" width="628" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
        <ImageViewer id="imgTitle00_00" taborder="15" text="어린이집에서 유치원으로 시설 이동하는 경우" left="0" top="1585" height="40" cssclass="img_WF_SubTit02" width="460" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_00_00" taborder="14" text="※ 기존 아이즐거운카드 중 현금 IC카드는 2016년 2월 29일까지 사용가능" left="0" top="1490" width="628" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_00_01_01" taborder="16" text="유치원 입학 전에, 유아학비(사회복지서비스 및 급여) 자격신청을 주민센터나 복지로 사이트에서 기존과 동일하게 신청하셔야 합니다." left="0" top="1627" width="910" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_00_01_00_01" taborder="17" text="&lt;fc v='#2b72de'&gt;- 국민행복카드를 신규발급(주민센터/복지로 사이트에서 일괄신청, 혹은 금융기관 영업점에서 발급)&lt;/fc&gt;" left="0" top="1654" width="800" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
        <Static id="sta00_00_01_00_00_00" taborder="18" text="&lt;fc v='#2b72de'&gt;- 기존아이사랑 카드를 유치원에 전환 등록하여 사용&lt;/fc&gt;" left="0" top="1679" width="500" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
