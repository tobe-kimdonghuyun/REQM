    <Script type="xscript5.1"><![CDATA[
this.sta00_01_00_00_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	system.execBrowser("http://www.bokjiro.go.kr");
};
this.par_spsse01_m01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	if(this.smfIsMobile()){
		this.fnMiddleAlign();
	}
};

this.fnMiddleAlign = function()
{
	var nAllWidth = this.width;  // 전체 form의 사이즈
	var nMaxWidth = 578; // 가운데정렬되는 Div의 가로사이즈(기존1200)
	var nLeft,nWidth;
	
	if(nAllWidth >= nMaxWidth)	//1280 사용
	{
		nLeft = parseInt((nAllWidth - nMaxWidth) / 2);
		if(nLeft < 0) nLeft = 0;
		
		nWidth = nMaxWidth;
	}
	else
	{
		nLeft = 0;
		nWidth = nAllWidth;
	}
	// 1번째 
	this.div00_01.form.div00.setOffsetLeft(nLeft);
	this.div00_01.form.div00.setOffsetWidth(nWidth);
	
	this.div00_00_00.form.div00.setOffsetLeft(nLeft);
	this.div00_00_00.form.div00.setOffsetWidth(nWidth);
	
	this.div01_00.form.div00.setOffsetLeft(nLeft);
	this.div01_00.form.div00.setOffsetWidth(nWidth);
}

this.par_spsse01_m01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	if(this.smfIsMobile()){
		this.fnMiddleAlign();
	}
	
	this.fnSetResize();
};


//컨텐츠 리사이징
this.fnSetResize = function(){
	this.div00.form.resetScroll();
	this.div00.setOffsetHeight(parseInt(this.div00.form.sta00.getOffsetBottom(),10)+40);
	this.smfResetScroll(this.div00);
	
	this.div00_02.form.resetScroll();
	this.div00_02.setOffsetHeight(parseInt(this.div00_02.form.sta00_01_00_00_00_00_00_00.getOffsetBottom(),10)+40);
	this.smfResetScroll(this.div00_02);
	
	this.resetScroll();
}
]]></Script>
    <Objects/>
  </Form>
</FDL>
