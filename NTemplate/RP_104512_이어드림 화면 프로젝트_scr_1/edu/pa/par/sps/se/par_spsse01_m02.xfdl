      <Layout height="8236" width="640" screenid="mobile,tablet" name="default0">
        <Div id="divTitle" taborder="0" left="20" top="70" height="65" text="" right="20" initvalueid="ivDivAccessibilityOff"/>
        <Div id="div00" taborder="1" left="20" top="divTitle:60" height="630" cssclass="div_WF_kinder" initvalueid="ivDivAccessibilityOff" right="20"/>
        <Static id="sta00_00_01" taborder="2" left="20" top="div00:70" width="60" height="60" cssclass="sta_WF_KinderGrayBlTxt" initvalueid="ivStcAccessibilityOn" text="1"/>
        <Static id="sta00_02" taborder="3" text="국민행복카드 하나로 어린이집(보육료 결제), 유치원(유아학비 인증), 건강보험 임신・출산 진료비 및 사회서비스 전자바우처 등의 사용이 가능합니다." left="110" top="div00:70" height="120" cssclass="sta_WF_Txt26" initvalueid="ivStcAccessibilityOn" right="20" fittocontents="height"/>
        <Static id="sta00_00_01_00" taborder="4" left="20" top="sta00_02:50" width="60" height="60" cssclass="sta_WF_KinderGrayBlTxt" initvalueid="ivStcAccessibilityOn" text="2"/>
        <Static id="sta00_02_00" taborder="5" text="국민행복카드의 복수 발급은 가능하지만, 가족구성원(신청 시 등록한 가족)&#13;중에서 인증용으로 1개 카드만 등록하여 사용 가능합니다." left="110" top="sta00_02:50" height="120" cssclass="sta_WF_Txt26" initvalueid="ivStcAccessibilityOn" right="20" fittocontents="height"/>
        <Static id="sta00_00_01_00_00" taborder="6" left="20" top="sta00_02_00:50" width="60" height="60" cssclass="sta_WF_KinderGrayBlTxt" initvalueid="ivStcAccessibilityOn" text="3"/>
        <Static id="sta00_02_00_00" taborder="7" text="국민행복카드 신청은 복지로 사이트, 주민센터, 금융기관 영업점에서 가능합니다." left="110" top="sta00_02_00:50" height="60" cssclass="sta_WF_Txt26" initvalueid="ivStcAccessibilityOn" right="20" fittocontents="height"/>
        <ImageViewer id="imgTitle00" taborder="8" text="다양한 카드사에서 선택가능!" left="20" top="sta00_02_00_00:80" height="50" cssclass="img_WF_SubTit03" width="400" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_01_02_00_01_00" taborder="9" text="전국 8개 카드사와 14개 금융기관에서 발급 가능하여 카드 선택의 폭이 넓어졌습니다." left="20" top="imgTitle00:20" height="70" cssclass="sta_WF_Txt26" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="20"/>
        <Div id="div01" taborder="10" left="20" top="sta00_01_02_00_01_00:20" height="1006" cssclass="div_WF_Detail" initvalueid="ivDivAccessibilityOff" right="20"/>
        <Div id="divTitle00" taborder="11" left="20" top="div01:70" height="65" text="" right="20" initvalueid="ivDivAccessibilityOff"/>
        <ImageViewer id="imgTitle01" taborder="12" text="유치원에 계속 재원하는 경우" left="20" top="sta00_03:20" height="50" cssclass="img_WF_SubTit03" initvalueid="ivTitleAccessibilityOn" right="20"/>
        <Static id="sta00_00" taborder="13" text="‘국민행복카드’ 신규발급 받거나 기존 사용중인 ‘ 아이즐거운카드’, ‘아이행복카드’ 사용가능&#13;&#10;  ※ 기존 아이즐거운카드 중 현금 IC카드는 2016년 2월 29일까지 사용가능" left="20" top="imgTitle01:20" height="58" cssclass="sta_WF_Txt24" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="20"/>
        <Static id="sta00_00_00" taborder="14" text="" left="20" top="2934" height="16" cssclass="sta_WF_Txt24" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="20"/>
        <ImageViewer id="imgTitle00_00" taborder="15" text="어린이집에서 유치원으로 &#13;&#10;시설 이동하는 경우" left="20" top="sta00_00:30" height="100" cssclass="img_WF_SubTit03" width="610" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_00_01_01" taborder="16" text="유치원 입학 전에, 유아학비(사회복지서비스 및 급여) 자격신청을 주민센터나 복지로 사이트에서 기존과 동일하게 신청하셔야 합니다." left="20" top="imgTitle00_00:20" height="96" cssclass="sta_WF_Txt24" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="20"/>
        <Static id="sta00_00_01_00_01" taborder="17" text="&lt;fc v='#2b72de'&gt;- 국민행복카드를 신규발급(주민센터/복지로 사이트에서 일괄신청, 혹은 금융기관 영업점에서 발급)&lt;/fc&gt;" left="20" top="sta00_00_01_01:10" height="68" cssclass="sta_WF_Txt24" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="20" fittocontents="height"/>
        <Static id="sta00_00_01_00_00_00" taborder="18" text="&lt;fc v='#2b72de'&gt;- 기존아이사랑 카드를 유치원에 전환 등록하여 사용&lt;/fc&gt;" left="20" top="sta00_00_01_00_01:10" height="30" cssclass="sta_WF_Txt24" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="20"/>
        <Div id="div00_01" taborder="19" left="20" top="sta00_00_01_00_00_00:10" height="940" cssclass="div_WF_kinder" initvalueid="ivDivAccessibilityOn" accessibilitydescription="국민행복카드 상세히 넣어주세요" visible="true" text="" right="20"/>
        <Static id="sta00_00_00_01" taborder="20" text="※ 기존아이사랑 카드는 유효기간까지 사용가능" top="div00_01:10" height="31" cssclass="sta_WF_Txt24" initvalueid="ivStcAccessibilityOn" textAlign="left" left="20" right="20"/>
        <ImageViewer id="imgTitle00_00_00" taborder="21" text="유치원에서 어린이집으로&#13;&#10;시설 이동하는 경우" left="20" top="sta00_00_00_01:30" height="100" cssclass="img_WF_SubTit03" width="610" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_00_01_01_00" taborder="22" text="어린이집 입소 전에 보육료 자격신청을 주민센터나 복지로 사이트에서 동일하게 신청하셔야 합니다." left="20" top="imgTitle00_00_00:20" height="62" cssclass="sta_WF_Txt24" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="20"/>
        <Static id="sta00_00_01_00_01_00" taborder="23" text="&lt;fc v='#2b72de'&gt;- 국민행복카드를 신규발급(주민센터/복지로 사이트에서 일괄신청, 혹은 금융기관 영업점에서 발급)&lt;/fc&gt;" left="20" top="sta00_00_01_01_00:30" height="68" cssclass="sta_WF_Txt24" initvalueid="ivStcAccessibilityOn" usedecorate="true" fittocontents="height" right="20"/>
        <Static id="sta00_00_01_00_00_00_00" taborder="24" text="&lt;fc v='#2b72de'&gt;- 기존아이즐거운 카드(신용카드, 체크카드)는 어린이집에서 전환 등록하여 사용&lt;/fc&gt;" left="20" top="sta00_00_01_00_01_00:30" height="68" cssclass="sta_WF_Txt24" initvalueid="ivStcAccessibilityOn" usedecorate="true" fittocontents="height" right="20"/>
        <Div id="div00_00_00" taborder="25" left="20" top="sta00_00_01_00_00_00_00:10" height="940" cssclass="div_WF_kinder" initvalueid="ivDivAccessibilityOn" accessibilitydescription="국민행복카드 상세히 넣어주세요" visible="true" text="" right="20"/>
        <Static id="sta00_00_00_01_00" taborder="26" text="※ 아이즐거운카드 : 신용카드, 체크카드는 유효기간까지 사용가능" top="div00_00_00:10" height="64" cssclass="sta_WF_Txt24" initvalueid="ivStcAccessibilityOn" textAlign="left" left="20" fittocontents="height" right="20"/>
        <Static id="sta00_00_00_01_00_00" taborder="27" text="현금 IC카드는 어린이집 사용불가" top="sta00_00_00_01_00:10" height="32" cssclass="sta_WF_Txt24" initvalueid="ivStcAccessibilityOn" textAlign="left" left="20" width="600"/>
        <Div id="divTitle01" taborder="28" left="20" top="sta00_00_00_01_00_00:40" height="65" text="" initvalueid="ivDivAccessibilityOff" width="600"/>
