        <Static id="sta00_00_00_01_00" taborder="30" text="※ 아이즐거운카드 : 신용카드, 체크카드는 유효기간까지 사용가능" top="div00_00_00:10" height="64" cssclass="sta_WF_Txt24" initvalueid="ivStcAccessibilityOn" textAlign="left" left="20" fittocontents="height" right="20"/>
