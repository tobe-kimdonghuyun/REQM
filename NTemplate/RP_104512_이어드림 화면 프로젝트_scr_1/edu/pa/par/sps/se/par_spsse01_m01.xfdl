    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    
*  @FileName 	Resize
*  @Creator 	투비소프트
*  @CreateDate 	2022.07.21
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.07.21     	TOBESOFT 	               최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/

this.samplePortalResize = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.fnMiddleAlign();
};

this.fnMiddleAlign = function()
{
	if(this.smfIsMobile())
	{	
		var nAllWidth = this.width;  // 전체 form의 사이즈
		var nMaxWidth = 640; // 가운데정렬되는 Div의 가로사이즈(기존1200)
		var nLeft,nWidth;
		
		if(nAllWidth >= nMaxWidth)	//1280 사용
		{
			nLeft = parseInt((nAllWidth - nMaxWidth) / 2);
			if(nLeft < 0) nLeft = 0;
			
			nWidth = nMaxWidth;
		}
		else
		{
			nLeft = 0;
			nWidth = nAllWidth;
		}
		this.divStep.setOffsetLeft(nLeft);
		this.divStep.setOffsetWidth(nWidth);					
	}
}


this.par_spsse01_m01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);
	
	this.fnMiddleAlign();	
};

this.par_spsse01_m01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnMiddleAlign();		
};

]]></Script>
