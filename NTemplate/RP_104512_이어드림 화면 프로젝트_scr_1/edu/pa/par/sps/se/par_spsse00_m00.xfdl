this.par_spsse00_m00_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnSetResize();
};



//컨텐츠 리사이징
this.fnSetResize = function(){
	this.div00_01.form.resetScroll();
	this.div00_01.setOffsetHeight(parseInt(this.div00_01.form.sta00.getOffsetBottom(),10)+35);
	
	this.div00_00.form.resetScroll();
	this.div00_00.setOffsetHeight(parseInt(this.div00_00.form.sta02.getOffsetBottom(),10)+35);
	
	this.div01.form.resetScroll();
	this.div01.setOffsetHeight(parseInt(this.div01.form.sta00_00_00_00_00.getOffsetBottom(),10)+35);
	this.smfResetScroll(this);
	
	this.resetScroll();
}]]></Script>
