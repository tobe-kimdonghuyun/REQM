    <Script type="xscript5.1"><![CDATA[
this.frmTemp01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(this);
};

this.par_spsse00_m01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnSetResize();
};


//컨텐츠 리사이징
this.fnSetResize = function(){
	//this.div02.form.resetScroll();
	
	// 지원대상
	var height1 = parseInt(this.div02.form.div01.form.sta006.getOffsetBottom(),10)+30;
	this.div02.form.div01.form.resetScroll();
	this.div02.form.div01.form.sta01.setOffsetHeight(height1);
	this.div02.form.div01.form.sta005.setOffsetHeight(height1);
	this.div02.form.div01.setOffsetHeight(height1);
	//this.smfResetScroll(this.div02.form.div01.form.sta005);
	
	//지원내용
	var height2 = parseInt(this.div02.form.div02.form.sta0010.getOffsetBottom(),10)+30;
	this.div02.form.div02.form.resetScroll();
	this.div02.form.div02.form.sta02.setOffsetHeight(height2);
	this.div02.form.div02.form.sta007.setOffsetHeight(height2);
	this.div02.form.div02.setOffsetHeight(height2);
	//this.smfResetScroll(this.div02.form.div02.form.sta007);
	
	this.div02.setOffsetHeight(135 + height1 + height2);
	
	
	//밑
	this.div03.form.resetScroll();
