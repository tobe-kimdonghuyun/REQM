              <Div id="div01" taborder="1" text="div01" left="0" top="div00:0" height="140" right="0">
                <Layouts>
                  <Layout>
                    <Static id="sta01" taborder="0" text="지원대상" left="0" top="0" width="302" height="140" cssclass="sta_WF_DtlTop04" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta005" taborder="1" left="301" top="0" cssclass="sta_WF_DtlCnt03" initvalueid="ivStcAccessibilityOff" height="140" right="0" textAlign="left"/>
                    <Static id="sta006" taborder="2" text="・유아학비 지원자격이 있고, 사립유치원에 다니는 법정 저소득 유아&#13;&#13;&#10;    ※ 기초생활수급자, 차상위계층, 한부모가정" left="352" top="40" width="700" height="50" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
                  </Layout>
                  <Layout name="Layout0">
                    <Static id="sta01" cssclass="sta_WF_DtlTop04_M" width="160" left="0" top="0" height="176"/>
                    <Static id="sta005" cssclass="sta_WF_DtlCnt03_M" left="sta01:0" top="0" height="176" right="0" text=""/>
                    <Static id="sta006" left="sta01:40" top="25" height="114" cssclass="sta_WF_surveyDot24" text="유아학비 지원자격이 있고, 사립유치원에 다니는 법정저소득 유아&#13;&#13;&#10;※ 기초생활수급자, 차상위계층, 한부모가정" right="30" fittocontents="height"/>
                  </Layout>
                </Layouts>
              </Div>
              <Div id="div02" taborder="2" text="div02" left="0" top="div01:0" right="0" bottom="0">
                <Layouts>
                  <Layout>
                    <Static id="sta02" taborder="0" text="지원내용" left="0" top="0" width="302" height="236" cssclass="sta_WF_DtlTop04" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta007" taborder="1" left="sta02:-1" top="0" cssclass="sta_WF_DtlCnt03" initvalueid="ivStcAccessibilityOff" textAlign="left" right="0" height="236"/>
                    <Static id="sta008" taborder="2" text="・기존에 다른 복지서비스(보육료, 양육수당 등)의 지원자격을 보유하고 있는 경우, 반드시 유아학비 미 저소득층 유아학비로&#13;&#10;    변경&#13;신청해야 지원가능" left="sta02:50" top="40" height="50" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn" width="800"/>
                    <Static id="sta009" taborder="3" text="・유아학비 지원자격을 보유하고 있는 경우에도 저소득층 유아학비 지원을 위해서는 별도로 신청해야 지원가능" left="sta02:50" top="sta008:9" width="800" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta0010" taborder="4" text="・다만 이전 저소득층 유아학비 지원을 받고 있었던 경우에는 저소득층 유아학비 지원자격이 유지되나, 저소득층 수급자격&#13;&#13;&#10;    (기초생활 수급자, 차상위 계층, 한부모 가정)에 변동이 있을 경우 지원이 중단될 수 있음" left="sta02:50" top="sta009:9" width="800" height="50" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
                  </Layout>
                  <Layout name="Layout0">
                    <Static id="sta02" top="-1" left="0" width="160" height="620" cssclass="sta_WF_DtlTop04_M"/>
                    <Static id="sta007" cssclass="sta_WF_DtlCnt03_M" left="sta02:0" top="0" height="620" right="0"/>
                    <Static id="sta008" right="30" left="sta02:50" top="40" height="114" cssclass="sta_WF_surveyDot24" fittocontents="height" text="기존에 다른 복지서비스(보육료, 양육수당 등)의 지원 자격을 보유하고 있는 경우, 반드시 유아학비 미 저소득층 유아학비로 변경&#13;신청해야 지원가능"/>
                    <Static id="sta009" top="sta008:20" left="sta02:50" height="86" right="30" cssclass="sta_WF_surveyDot24" fittocontents="height" text="유아학비 지원자격을 보유하고 있는 경우에도 저소득층 유아학비 지원을 위해서는 별도로 신청해야 지원가능"/>
                    <Static id="sta0010" top="sta009:20" left="sta02:50" height="198" right="30" cssclass="sta_WF_surveyDot24" fittocontents="height" text="다만 이전 저소득층 유아학비 지원을 받고 있었던 경우에는 저소득층 유아학비 지원 자격이 유지되나, 저소득층 수급 자격&#13;&#13;&#10;(기초생활 수급자, 차상위 계층, 한부모 가정)에 변동이 있을 경우 지원이 중단될 수 있음"/>
