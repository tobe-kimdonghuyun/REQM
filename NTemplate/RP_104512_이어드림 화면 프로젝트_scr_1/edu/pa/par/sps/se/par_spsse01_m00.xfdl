        <Static id="Static99_00_00_00_00" left="0" top="0" height="70" right="0" text="70" taborder="8"/>
        <Static id="Static99_00_00_00_00_00_00" left="0" top="371" height="30" right="0" text="30" taborder="9"/>
        <Static id="Static99_00_00_00_00_00" left="0" top="587" height="60" right="0" text="60" taborder="10"/>
