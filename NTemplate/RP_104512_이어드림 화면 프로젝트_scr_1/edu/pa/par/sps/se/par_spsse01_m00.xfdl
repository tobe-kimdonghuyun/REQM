    <Script type="xscript5.1"><![CDATA[
this.div00_00_btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	system.execBrowser("http://www.bokjiro.go.kr");
};

this.div00_onsize = function(obj:nexacro.Div,e:nexacro.SizeEventInfo)
{
	this.fnSetResize();
};

//컨텐츠 리사이징
this.fnSetResize = function(){
	this.div00.form.resetScroll();
	this.div00.setOffsetHeight(parseInt(this.div00.form.sta00.getOffsetBottom(),10)+40);
	this.smfResetScroll(this.div00);
	
	this.div01.form.resetScroll();
	this.div01.setOffsetHeight(parseInt(this.div01.form.sta02.getOffsetBottom(),10)+40);
	this.smfResetScroll(this.div01);
	
	this.resetScroll();
}]]></Script>
    <Objects/>
  </Form>
