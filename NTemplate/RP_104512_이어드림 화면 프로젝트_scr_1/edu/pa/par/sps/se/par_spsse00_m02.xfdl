    <Script type="xscript5.1"><![CDATA[

this.btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	system.execBrowser("https://www.childschool.go.kr");
};

this.par_spsse00_m02_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnSetResize();
};

//컨텐츠 리사이징
this.fnSetResize = function(){
	this.div00.form.resetScroll();
	this.div00.setOffsetHeight(parseInt(this.div00.form.sta00_02_01_00.getOffsetBottom(),10)+40);
	this.smfResetScroll(this.div00);
	
	this.resetScroll();
}]]></Script>
