    <Script type="xscript5.1"><![CDATA[/**
*  대국민 - 학부모서비스(유)
*  @MenuPath    TEMPLATE
*  @FileName 	par_spsms00_m00
*  @Creator 	김지영
*  @CreateDate 	2022.06.20
*  @Desction    MY유아학비 유아학비 지원현황
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.06.20            김지영                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::par_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.par_spsms00_m00_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리
	this.smfInitForm(this);
	
	var objParForm = this.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form;
	this.dsSearch.copyRow(0, objParForm.dsStuIduzEduYn, 0);
	
	//소재정보, 개인번호 체크
	var validate = this.parfValidate(this.dsSearch);	
	if(!validate) return false;
	
	//  페이지 조회
	this.fnSearch();
};

 /************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(obj, e)
{
 	// 서비스 객체 생성
	this.smfSearchService("select")
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.smfIsMobile()){
				if(this.dsInfntSceSprtInfoList.getRowCount() == 0) this.dsInfntSceSprtInfoList.addRow();
				if(this.dsInfntSceSprtBrkdnList.getRowCount() == 0) this.dsInfntSceSprtBrkdnList.addRow();
				
				var grdH = this._smfappendHeight(this.divGrid02.form.grdInfntSceSprtBrkdnList);
				if(this.dsInfntSceSprtBrkdnList.getRowCount() == 0 ) grdH = 365;
				this.divGrid02.form.grdInfntSceSprtBrkdnList.setOffsetHeight(grdH);
				this.divGrid02.setOffsetHeight(grdH);
				this.smfResetScroll(this);
			}
		});	
};
 
/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
	
// 	if(svcid== "select"){	
// 		this.setName();
// 	}
};

 /************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
