// {
// 	if(this.dsInfntSceSprtInfoList.getRowCount() > 0){
// 		stuName = this.dsInfntSceSprtInfoList.getColumn(0,"stdntNm");
// 		this.imgTitle.set_text(stuName+"의 유아학비 지원현황");
// 	}else{
// 		this.imgTitle.set_text(this.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form.cboStuList.text+"의 유아학비 지원현황");
// 	}
// };

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.grdInfntSceSprtInfoList_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var cellBtn = this.divGrid01.form.grdInfntSceSprtInfoList.getCellText(e.row,e.cell);
	var cellName = this.dsInfntSceSprtInfoList.getColumn(e.cell,"stdntNm");

	//'청구' 버튼만 클릭돼도록
	if(cellBtn=="청구"){
		//'셀버튼' 클릭 시, 청구화면으로 이동
		//this.go("pa_par_sps_pc::par_spspc01_m00.xfdl");
		var params = {};
		this.smfSetWorkPage("pa_par_sps_pc::par_spspc01_m00.xfdl", params);
	}
};

this.par_spsms00_m00_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.smfResetScroll(this);
};]]></Script>
