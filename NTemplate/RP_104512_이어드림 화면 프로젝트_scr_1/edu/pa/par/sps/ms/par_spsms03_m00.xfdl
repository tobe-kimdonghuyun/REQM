    <Script type="xscript5.1"><![CDATA[/**
*  대국민 - 학부모서비스(유)
*  @MenuPath    TEMPLATE
*  @FileName 	par_spsms03_m00
*  @Creator 	문형선
*  @CreateDate 	2022.11.01
*  @Desction    MY유아학비 카드변경
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.11.01            문형선                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::par_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.par_spsms03_m00_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리
	this.smfInitForm(this);
	
	var objParForm = this.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form;
	this.dsSearch.copyRow(0, objParForm.dsStuIduzEduYn, 0);
	
	//학부모명 설정
	this.divCardNo.form.edtCardUserNm.set_value(objParForm.dsSchpaInfo.getColumn(0, "schpaNm"));
	//생년월일 설정
	this.dsSearch.setColumn(0, "schpaBrdt", objParForm.dsSchpaInfo.getColumn(0, "brdt"));
	trace(this.dsSearch.saveXML());
	//소재정보, 개인번호 체크
	var validate = this.parfValidate(this.dsSearch);	
	if(!validate) return false;
};

 /************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//소재정보, 개인번호 체크
	var validate = this.parfValidate(this.dsSearch);	
	if(!validate) return false;
	
	if(!this.chkAgmt01.isChecked()){
		this.smfAlert("개인정보 수집 및 이용 동의가 필요합니다.");
		this.chkAgmt01.setFocus();
		return false;
	}
	
 	var cardNo = this.divCardNo.form.edtCardNo01.value + this.divCardNo.form.edtCardNo02.value + this.divCardNo.form.edtCardNo03.value + this.divCardNo.form.edtCardNo04.value;
	this.dsSearch.setColumn(0, "cardNo", cardNo);
	
	// 서비스 객체 생성
	this.smfSaveService("saveCard")
		.messagePrefix(this.btnSave.text)
		.validateForm(this.divCardNo)
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			// 저장이 완료되었습니다.
		});	
};
 
/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
	
	if(svcid == "saveCard"){
		if( errmsg != "SUCCESS"){
			this.smfAlert(errmsg);
		}else{
			this.smfAlert("변경되었습니다.");
		}
	}
};

 /************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/


/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.btnOk_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.chkAgmt01.set_value(true);
	this.chkAgmt02.set_value(true);
};

this.par_spsms03_m00_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnSetResize();
};

//컨텐츠 리사이징
this.fnSetResize = function(){
	this.div00.form.resetScroll();
	this.div00.setOffsetHeight(parseInt(this.div00.form.sta00_00_00_00_00_00_00_00_01.getOffsetBottom(),10)+35);
	this.smfResetScroll(this.div00);
	
	this.resetScroll();
}]]></Script>
    <Bind>
      <BindItem id="item0" compid="divCardNo.form.edtCardUserNm" propid="value" datasetid="dsSearch" columnid="cardUserNm"/>
    </Bind>
  </Form>
</FDL>
