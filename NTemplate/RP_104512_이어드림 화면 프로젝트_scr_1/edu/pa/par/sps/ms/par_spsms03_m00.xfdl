              <Static id="sta00_00_00_00_00_00_00" cssclass="sta_WF_Txt24" height="30" left="50" top="sta00_00_00_00_00_00:20" right="30" fittocontents="height"/>
              <Static id="sta00_00_00_00_00_00_00_00" cssclass="sta_WF_Txt24" height="30" left="60" top="sta00_00_00_00_00_00_00:10" right="30" fittocontents="height"/>
