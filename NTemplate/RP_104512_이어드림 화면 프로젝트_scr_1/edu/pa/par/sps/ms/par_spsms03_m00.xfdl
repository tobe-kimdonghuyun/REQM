          <Column id="cardNo" type="STRING" size="256"/>
          <Column id="cardUserNm" type="STRING" size="256"/>
          <Column id="cddcScCd" type="STRING" size="3"/>
          <Column id="sprtYr" type="STRING" size="4" description="지원연도"/>
          <Column id="schpaBrdt" type="STRING" size="256"/>
