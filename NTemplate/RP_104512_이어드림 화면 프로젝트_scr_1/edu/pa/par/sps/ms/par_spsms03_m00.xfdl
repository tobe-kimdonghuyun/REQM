  <Form id="par_spsms03_m00" width="1200" height="756" titletext="카드 변경" onload="par_spsms03_m00_onload" onsize="par_spsms03_m00_onsize">
    <Layouts>
      <Layout height="756" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="56" height="54" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="카드 변경" left="0" top="0" height="54" cssclass="img_WF_SubTit01" width="180" initvalueid="ivTitleAccessibilityOn"/>
            </Layout>
            <Layout name="default0">
              <ImageViewer id="imgTitle" taborder="0" text="카드변경" left="0" top="0" height="65" cssclass="img_WF_SubTit01" width="180" initvalueid="ivTitleAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <ImageViewer id="imgTitle01" taborder="1" text="개인정보 수집 및 이용" left="0" top="140" height="30" cssclass="img_WF_SubTit04" width="230" initvalueid="ivTitleAccessibilityOn"/>
        <Div id="div00" taborder="2" left="0" top="180" height="354" cssclass="div_WF_KinderBox" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" text="나이스 학부모서비스는 양질의 서비스 제공을 위하여 정보주체의 동의에 따라 다음과 같이 최소한의 개인정보를 수집하고 있습니다. " left="30" top="40" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="30"/>
              <Static id="sta00_00" taborder="1" text="수집한 개인정보는 본 수집이용 목적 외의 다른 목적으로 사용되지 않습니다." left="30" top="sta00:0" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="30"/>
              <Static id="sta00_00_00" taborder="2" text="■ 수집 및 이용 항목" left="50" top="sta00_00:20" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="30"/>
              <Static id="sta00_00_00_00" taborder="3" text="(필수) 개인식별정보: 성명, 카드정보(카드번호, 발급처, 발급일, 사고정보 등)" left="80" top="sta00_00_00:0" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="30"/>
              <Static id="sta00_00_00_00_00" taborder="4" text="■ 수집목적: 유아학비지원금 산정을 위한 자격관리, 유아학비 카드인증정보 관리 등 업무 수행" left="50" top="sta00_00_00_00:20" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="30"/>
              <Static id="sta00_00_00_00_00_00" taborder="5" text="■ 보유기간: 유아 최종 퇴원 후 5년" left="50" top="sta00_00_00_00_00:20" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="30"/>
              <Static id="sta00_00_00_00_00_00_00" taborder="6" text="■ 수집 및 이용근거" left="50" top="sta00_00_00_00_00_00:20" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="30"/>
              <Static id="sta00_00_00_00_00_00_00_00" taborder="7" text="- 개인정보보호법 제 15조, 제 17조" left="60" top="sta00_00_00_00_00_00_00:0" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="30"/>
              <Static id="sta00_00_00_00_00_00_00_00_00" taborder="8" text="- 사회복지사업법 제 6 조의 2" left="60" top="sta00_00_00_00_00_00_00_00:0" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="30"/>
              <Static id="sta00_00_00_00_00_00_00_00_01" taborder="9" text="- 유아교육법 시행령 제 34조의 2, 제 34조의 3" left="60" top="sta00_00_00_00_00_00_00_00_00:0" height="20" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="30"/>
            </Layout>
            <Layout name="default0">
              <Static id="sta00" cssclass="sta_WF_Txt24" top="30" left="30" height="100" right="30" fittocontents="height"/>
              <Static id="sta00_00" cssclass="sta_WF_Txt24" top="sta00:0" left="30" height="70" right="30" fittocontents="height"/>
