<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="par_spsms01_m00" width="1200" height="755" titletext="지원자격 조회" onload="par_spsms01_m00_onload" oninit="par_spsms01_m00_oninit">
    <Layouts>
      <Layout height="755" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="56" height="54" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="유아학비 지원자격 조회" left="0" top="0" height="54" cssclass="img_WF_SubTit01" width="370" initvalueid="ivTitleAccessibilityOn"/>
