              <ImageViewer id="imgTitle" height="65" left="0" top="0" width="420"/>
            </Layout>
            <Layout name="Layout1">
              <ImageViewer id="imgTitle" height="65" left="0" top="0" width="420"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staText1" taborder="1" text="유치원에서 유아 등록 후 국민행복카드 인증된 보호자(카드발급자)만 확인 가능합니다." left="0" top="124" width="820" height="30" cssclass="sta_WF_Txt16" initvalueid="ivStcAccessibilityOn"/>
        <ImageViewer id="imgTitle2" taborder="2" text="복지서비스 자격(유아학비)" left="0" top="194" height="30" cssclass="img_WF_SubTit04" width="240" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="staText3" taborder="3" text="※ 해당 정보는 주민센터/복지로에서 보호자가 신청한 유아학비 자격 정보입니다. 오류 시 해당 주민센터 또는 복지로(1566-0313)로 문의하여 주세요." left="234" top="197" height="25" cssclass="sta_WF_Blue14" width="900" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divGrid01" taborder="4" left="0" top="234" height="236" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Grid id="grdGrid" taborder="0" left="0" binddataset="dsWelfSvcQlfcList" autofittype="col" top="0" right="0" initvalueid="ivGrdAccessibilityOn" bottom="0" selecttype="cell" accessibilitylabel="복지서비스 자격(유아학비)">
                <Formats>
                  <Format id="default">
                    <Columns>
                      <Column size="120" band="left"/>
                      <Column size="80" band="left"/>
                      <Column size="150" band="left"/>
                      <Column size="150"/>
                      <Column size="150"/>
                      <Column size="150"/>
                      <Column size="150"/>
                    </Columns>
                    <Rows>
                      <Row size="36" band="head"/>
                      <Row size="40"/>
                    </Rows>
                    <Band id="head">
                      <Cell text="유아성명"/>
                      <Cell col="1" text="성별"/>
                      <Cell col="2" text="자격"/>
                      <Cell col="3" text="자격신청일"/>
                      <Cell col="4" text="자격결정일"/>
                      <Cell col="5" text="자격시작일"/>
                      <Cell col="6" text="자격종료일"/>
                    </Band>
                    <Band id="body">
                      <Cell text="bind:stuFlnm" textAlign="center"/>
                      <Cell col="1" text="bind:sxds" textAlign="center" expr="sxds == &quot;1&quot; ? &quot;남&quot; : &quot;여&quot;"/>
                      <Cell col="2" text="bind:qlfcNm" textAlign="center"/>
                      <Cell col="3" text="bind:qlfcAplyYmd" displaytype="expr:qlfcAplyYmd!=undefined?'mask':'none'" calendardateformat="yyyy-MM-dd" edittype="none" maskeditformat="@@@@.@@.@@." maskedittype="string" textAlign="center"/>
                      <Cell col="4" text="bind:qlfcDcsnYmd" displaytype="expr:qlfcDcsnYmd!=undefined?'mask':'none'" calendardateformat="yyyy-MM-dd" maskeditformat="@@@@.@@.@@." maskedittype="string" textAlign="center"/>
                      <Cell col="5" text="bind:qlfcBngnYmd" displaytype="expr:qlfcBngnYmd!=undefined?'mask':'none'" calendardateformat="yyyy-MM-dd" maskeditformat="@@@@.@@.@@." maskedittype="string" textAlign="center"/>
                      <Cell col="6" text="bind:qlfcEndYmd" calendardateformat="yyyy-MM-dd" displaytype="expr:qlfcEndYmd!=undefined?'mask':'none'" maskeditformat="@@@@.@@.@@." maskedittype="string" textAlign="center"/>
                    </Band>
                  </Format>
                  <Format id="format00">
                    <Columns>
                      <Column size="250"/>
                      <Column size="250"/>
                    </Columns>
                    <Rows>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                      <Row size="50"/>
                    </Rows>
                    <Band id="body">
                      <Cell text="유아성명" cssclass="cell_WF_Label"/>
                      <Cell col="1" text="bind:stuFlnm"/>
                      <Cell row="1" text="성별" cssclass="cell_WF_Label"/>
                      <Cell row="1" col="1" text="bind:sxds" expr="sxds == &quot;1&quot; ? &quot;남&quot; : &quot;여&quot;"/>
                      <Cell row="2" text="자격" cssclass="cell_WF_Label"/>
                      <Cell row="2" col="1" text="bind:qlfcNm"/>
                      <Cell row="3" text="자격신청일" cssclass="cell_WF_Label"/>
                      <Cell row="3" col="1" text="bind:qlfcAplyYmd" maskeditformat="@@@@.@@.@@." maskedittype="string" displaytype="expr:qlfcAplyYmd!=undefined?'mask':'none'"/>
                      <Cell row="4" text="자격결정일" cssclass="cell_WF_Label"/>
                      <Cell row="4" col="1" text="bind:qlfcDcsnYmd" maskedittype="string" maskeditformat="@@@@.@@.@@." displaytype="expr:qlfcDcsnYmd!=undefined?'mask':'none'"/>
                      <Cell row="5" text="자격시작일" cssclass="cell_WF_Label"/>
                      <Cell row="5" col="1" text="bind:qlfcBngnYmd" maskeditformat="@@@@.@@.@@." maskedittype="string" displaytype="expr:qlfcBngnYmd!=undefined?'mask':'none'"/>
                      <Cell row="6" text="자격종료일" cssclass="cell_WF_Label, cell_WF_MiddleLine"/>
                      <Cell row="6" col="1" text="bind:qlfcEndYmd" maskedittype="string" maskeditformat="@@@@.@@.@@." displaytype="expr:qlfcEndYmd!=undefined?'mask':'none'" cssclass="cell_WF_MiddleLine"/>
                    </Band>
                  </Format>
