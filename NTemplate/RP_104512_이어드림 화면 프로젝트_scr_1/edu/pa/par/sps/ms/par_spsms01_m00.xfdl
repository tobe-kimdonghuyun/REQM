    <Script type="xscript5.1"><![CDATA[/**
*  대국민 - 학부모서비스(유)
*  @MenuPath    TEMPLATE
*  @FileName 	par_spsms01_m00
*  @Creator 	김지영
*  @CreateDate 	2022.06.20
*  @Desction    MY유아학비 지원자격 조회
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.06.20            김지영                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::par_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.par_spsms01_m00_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리
	this.smfInitForm(this);
	
	var objParForm = this.getOwnerFrame().form.divTop.form.divDispArea.form.divPARLink.form;
	this.dsSearch.copyRow(0, objParForm.dsStuIduzEduYn, 0);
	
	//소재정보, 개인번호 체크
	var validate = this.parfValidate(this.dsSearch);	
	if(!validate) return false;
	
	// 페이지를 조회한다.
 	this.fnSearch();
	
	/*
	varSum = this.dsMt36HstrList.getSum("sprtDds");
	trace(varSum);
	this.grdGrid2.setCellProperty("summary",1,"text",varSum);
	*/
};



 /************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(obj, e)
{
 	// 서비스 객체 생성
	this.smfSearchService("select")
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});	
};
 
/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
	
	if(svcid== "select"){
		this.copy();
		//this.mathDays();
	}
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 콤보박스에 데이터(유아이름) 불러오기
//유아명 중복 X처리
 this.copy = function()
 {	
 	for(j=0; j<this.dsWelfSvcQlfcList.rowcount; j++){
		stuNm = this.dsWelfSvcQlfcList.getColumn(j,"stdntNm");
		this.dsStu.insertRow(j);
		this.dsStu.setColumn(j,"stdntNm",stuNm);
	}
	
	this.dsStu.insertRow();
	this.dsStu.setColumn(0,"stdntNm","전체");
	this.cbo1.set_index(0);
	idx = this.cbo1.index;
	
	//var arr = [];
	var arr = this.dsStu.extractRows( "stdntNm" );
	var strArr = this.dsWelfSvcQlfcList.getColumn(arr,"stdntNm");
// 	var emptyArr = {};
// 	var uniqueArr = strArr.filter(function(item){
// 		return emptyArr.hasOwnProperty(item) ? false : (emptyArr[item] = true);
// 	})
 };
 
 this.setName = function()
{
	stuName = selectName
		if(stuName){
			this.imgTitle3.set_text(stuName+"의 유아학비 36개월 이력");
		}
 		if(idx==0 && selectName=="전체" && selectName!=stuName){
 			this.imgTitle3.set_text("유아학비 36개월 이력");
		}
};
 
