 this.delAll = function ()
 {
 	this.dsWelfSvcQlfcList.deleteAll();
	this.dsMt36HstrList.deleteAll();
 };

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.cbo1_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	selectName = e.posttext;	// 선택된 콤보값
};

// 조회 버튼 클릭
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	this.dsWelfSvcQlfcList.reset();
	//this.dsMt36HstrList.reset();
	
	this.dsWelfSvcQlfcList.filter("");
	
	a = this.dsWelfSvcQlfcList.rowcount;
	for(i=0; i<a; i++){		//유아 이름 배열
		stuName = this.dsWelfSvcQlfcList.getColumn(i,"stdntNm");

		//유아 이름에 따라 콤보에 해당하는 이름만 조회되도록
		if(selectName==stuName){
			this.dsWelfSvcQlfcList.filter("stdntNm=='"+selectName+"'");
		}
 		if(idx==0 && selectName=="전체" && selectName!=stuName){
 			this.dsWelfSvcQlfcList.filter("");
		}
	}
	this.setName();
};
]]></Script>
  </Form>
</FDL>
