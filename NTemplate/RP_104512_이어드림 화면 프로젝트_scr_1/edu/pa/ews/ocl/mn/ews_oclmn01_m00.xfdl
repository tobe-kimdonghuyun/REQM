    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    신청안내 > 시도교육청별 지원안내
*  @FileName 	ews_oclmn01_m00.xfdl
				ews_oclmn02_m00.xfdl
				ews_oclmn03_m00.xfdl
*  @Creator 	김지영
*  @CreateDate 	2023.02.06
*  @Desction    시도교육청별 지원안내
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.02.06            김지영                   최초 생성
* 2023.05.06            류찬욱                   수정
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
// 시도코드 구분
var sSelectedCddcCode = this.divKorMap.form.fnGetSelectCode();
var sSelectedCddcName = this.divKorMap.form.fnGetSelectName();
 
this.linkNo;	// link넘버

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose) 
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	//파라미터 세팅
	this.pv_params = this.smfGetFormParams();

	if(!this.smfIsNull(this.pv_params)){	// param 데이터가 있으면
		this.linkNo = this.pv_params.linkNo;
	
		// onload시 이미지 텍스트 내용 세팅
		if(this.linkNo == '500'){
			this.div03.form.imgTitle.set_text("교육비 신청 여부 조회");
			//this.imgTitle.set_text("교육비 신청 대상여부 조회");
			this.btnGo.set_text("학생 신청 여부 조회하기");
		} 
		if(this.linkNo == '600'){
			this.div03.form.imgTitle.set_text("수혜현황 조회");
			//this.imgTitle.set_text("수혜현황 조회"); 
			this.sta01_00_00_00_00.set_text("교육복지 <fc v='#2b72de'>신청 대상 학생이 다니고 있는</fc>"
											+ "<br>학교의 <fc v='#2b72de'>시·도</fc>를"
											+ "<br>아래 지도에서 선택하세요.");
			// 문구 수정(2024.06.24)
			this.sta01_00_00_00.set_text("해당 메뉴는 교육복지(교육급여, 교육비지원) 수혜현황을 확인하는 메뉴입니다."
											+ "<br>서비스를 이용하기 위해서는 이용하고자 하는 시·도교육청을 선택해야 합니다."
											+ "<br>아래 지도에서 서비스를 이용하고자 하는 교육청을 선택해주세요.");

			this.btnGo.set_text("학생 수혜현황 조회하기");
		}
		if(this.linkNo == '800'){
			this.div03.form.imgTitle.set_text("시도교육청 자체 복지사업 신청");
			//this.imgTitle.set_text("시도교육청별 교육복지 사업신청");
			this.sta01_00_00_00_00.set_text("<fc v='#2b72de'>신청 대상 학생이 다니고 있는</fc>"
											+ "<br>학교의 <fc v='#2b72de'>시·도</fc>를"
											+ "<br>아래 지도에서 선택하세요.");
			this.sta01_00_00_00.set_text("시도 교육청별 복지 사업은, 초중고 교육비지원 및 교육급여와는 별개의 시도교육청 자체 복지사업 입니다."
											+ "<br>시도 교육청별 복지 추가사업 운영은 사업명, 지원항목, 기간 등이 다를 수 있습니다."
											+ "<br>신청 시 학생이 재학중인 관할 교육청, 학교를 선택하여 신청 해주시기 바랍니다."
											+ "<br>원클릭 신청시스템으로 교육청 자체 사업 운영 교육청(2025.3월 기준 : 제주)"
											);
			this.btnGo.set_text("제주특별자치도교육청사업 신청하기");
			// 25.4월부터 활성화
			// this.btnGo.set_text("시도교육청 자체 복지사업 신청하기");
			// this.btnGo.set_enable(false);
			
			// this.sta01_00_00_00_00_00.set_text("지금은 신청 기간이 아닙니다.")
		}
	}
	 
	this.btnGo.set_visible(false);
	this.divKorMap.form.fnSetInit(this,this.fnMapSelecetCallback);
	
	this.cboCddcList.set_index(0);
	
	if(this.linkNo == '800'){
		this.divKorMap.set_url("comm::comp_korMap3.xfdl");
		this.cboCddcList.set_index(16);
		this.cboCddcList.set_enable(false);
		this.fnCboCddcList("T100000001", "제주특별자치도교육청");
	} else {
		this.fnCboCddcList("B100000001", "서울특별시교육청");
	}
	
	
	this.frmTemp01_onsize();
    this.resetScroll();
};


this.frmTemp01_onsize = function(obj,e)
{
	//divKorMap 가운데 정렬
	if( this.smfIsMobile() )
	{
		var nWidth = this.width;
		var nLeft = (this.width - this.divKorMap.getOffsetWidth()) /2;
		this.divKorMap.set_left(nLeft);
		this.resetScroll();
	}else {
		var nPos = nexacro.toNumber(this.cboCddcList.left) + nexacro.toNumber(this.cboCddcList.width)+4;
		if (this.width < nPos) {
			this.sta00.set_width(nPos);
		}else {
			this.sta00.set_right(0);
		}

		var nWidth  = this.width;
		var nDispWidth =  this.divKorMap.getOffsetRight() -  this.sta01_00_00_00_00.getOffsetLeft();
		var nLeft = parseInt(nWidth-nDispWidth)/2;

		if(nLeft<0) nLeft=0;

		trace("=====nLeft:");

		//this.staPopupTitleAss.setOffsetLeft(nLeft);

		this.resetScroll();
	}
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 팝업 CALLBACK
 */
this.fnPopupCallback = function(e, sender){
	if(e.type == 'search'){
		this.fnSearchCompeList();
	}
};

/**
 * 맵클릭 CALLBACK
 */
this.fnMapSelecetCallback = function (sSelCode,sSelName)
{
	if (!this.smfIsNull(sSelCode)) {
		//this.btnGo.set_visible(true);
		//this.smfSetCddcCode(sSelCode);
		
		//if(this.linkNo == '800'){
		//	this.btnGo.set_text(sSelName + "사업 신청하기");
		//}
		
		if(this.linkNo != '800'){
			
			this.btnGo.set_visible(true);
			this.smfSetCddcCode(sSelCode);
			
			this.dsOrgCode.setColumn(0, "cddcOrgCd", sSelCode);
			this.dsOrgCode.setColumn(0, "cddcOrgCdNm", sSelName);
			
			// combo의 값을 변경한다.
			this.cboCddcList.set_value(sSelCode);
		}
		
	}else{
		this.btnGo.set_visible(false);
	}
	
	this.resetScroll();
}

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnPopup = function(obj:nexacro.Button,e:nexacro.ClickEventInfo){
	var popupParams = {
		sender: obj,
		callback: this.fnPopupCallback,
		params: {
			procType: 'search',
			linkNo: this.linkNo,
			cddcOrgCd: this.dsOrgCode.getColumn(0, "cddcOrgCd"),
			cddcOrgCdNm: this.dsOrgCode.getColumn(0, "cddcOrgCdNm"),
			usertype:1
		},
	};
	
	if(this.linkNo == '500'){
		this.smfDialog("_auto", "pa_ews_ocl_su::ews_oclsu01_p01.xfdl", popupParams);	// 간편인증 화면 이동			
	} else if(this.linkNo == '600'){
		this.smfDialog("_auto", "pa_ews_ocl_su::ews_oclsu02_p01.xfdl", popupParams);	// 간편인증 화면 이동
	} else if(this.linkNo == '800'){
		//var params = {usertype:2};   // 0:교직원, 1:개인, 2:사업자
		//var sUrl = "frame::frameLoginNpki02.xfdl";
		//var bShowHead = false;
		//this.smfSetWorkPage(sUrl,params,bShowHead);
		// return ; // 2025.04월부터 비활성화
		this.smfDialog("_auto", "pa_ews_ocl_su::ews_oclsu03_p01.xfdl", popupParams);	
	}
}

this.fnCboCddcList = function(sCddcCd, sSelName){
	
	if(!this.smfIsNull(sCddcCd))
	{
		this.smfSetCddcCode(sCddcCd);
		this.divKorMap.form.fnSetCddcCode(sCddcCd);
		
		this.dsOrgCode.setColumn(0, "cddcOrgCd", sCddcCd);
		this.dsOrgCode.setColumn(0, "cddcOrgCdNm", sSelName);
	}


	var sText = "";
	if(this.smfIsNull(sSelName))
	{
		this.btnGo.set_visible(false);
	}
	else
	{
		this.btnGo.set_visible(true);
	}
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 자세히보기 버튼 클릭
*/
this.btnGo_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnPopup();
};

this.cboCddcList_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	var sCddcCd = e.postvalue;
	var sSelName = e.posttext;
	if(!this.smfIsNull(sCddcCd))
	{
		this.divKorMap.form.fnSetCddcCode(sCddcCd);
		
		this.dsOrgCode.setColumn(0, "cddcOrgCd", sCddcCd);
		this.dsOrgCode.setColumn(0, "cddcOrgCdNm", sSelName);
	}
	
	
	var sText = "";
	if(this.smfIsNull(sSelName))
	{
		this.btnGo.set_visible(false);
	}
	else
	{
		if(this.linkNo == '800'){
			this.btnGo.set_text(sSelName + "사업 신청하기");
		}
		
		this.btnGo.set_visible(true);
	}

	this.resetScroll();
};
]]></Script>
  </Form>
</FDL>
