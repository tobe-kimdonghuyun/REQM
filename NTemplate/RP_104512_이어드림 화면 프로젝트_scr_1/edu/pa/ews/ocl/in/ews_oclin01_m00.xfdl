    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    신청안내 > 시도교육청별 지원안내
*  @FileName 	ews_oclin01_m00.xfdl 
*  @Creator 	김지영
*  @CreateDate 	2023.02.02
*  @Desction    시도교육청별 지원안내
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.02.02            김지영                   최초 생성 
* 2023.05.02            류찬욱                   수정 
*******************************************************************************
*/

// 시도코드 구분
var sSelectedCddcCode = this.divKorMap.form.fnGetSelectCode();
var sSelectedCddcName = this.divKorMap.form.fnGetSelectName();

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitForm(this);
	// params 
	this.fv_param = this.smfGetFormParams();
	
	this.btnGo.set_visible(false);
	this.divKorMap.form.fnSetInit(this,this.fnMapSelecetCallback);
	
	this.cboCddcList.set_index(0);
	this.fnCboCddcList("B100000001", "서울특별시교육청");
	
	this.frmTemp01_onsize();
    this.resetScroll();
};


this.frmTemp01_onsize = function(obj,e)
{
	//divKorMap 가운데 정렬
	if( this.smfIsMobile() )
	{
		var nWidth = this.width;
		var nLeft = (this.width - this.divKorMap.getOffsetWidth()) /2;
		this.divKorMap.set_left(nLeft);
		this.resetScroll();
	}else {
		var nPos = nexacro.toNumber(this.cboCddcList.left) + nexacro.toNumber(this.cboCddcList.width)+4;
		if (this.width < nPos) {
			this.sta00.set_width(nPos);
		}else {
			this.sta00.set_right(0);
		}

		var nWidth  = this.width;
		var nDispWidth =  this.divKorMap.getOffsetRight() -  this.sta01_00_00_00_00.getOffsetLeft();
		var nLeft = parseInt(nWidth-nDispWidth)/2;

		if(nLeft<0) nLeft=0;

		trace("=====nLeft:");

		//this.staPopupTitleAss.setOffsetLeft(nLeft);

		this.resetScroll();
	}
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 팝업 CALLBACK

this.fnPopupCallback = function(e, sender){
	if(e.type == 'search'){
		this.fnSearchCompeList();
	}
};
 */
 
/**
 * 맵클릭 CALLBACK
 */
this.fnMapSelecetCallback = function (sSelCode,sSelName)
{
	if (!this.smfIsNull(sSelCode)) {
		this.btnGo.set_visible(true);
		this.smfSetCddcCode(sSelCode);
		
		// combo의 값을 변경한다.
		this.cboCddcList.set_value(sSelCode);
	}else{
		this.btnGo.set_visible(false);
	}
	
	this.resetScroll();
}

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnGo = function(obj:nexacro.Button,e:nexacro.ClickEventInfo){
	var params = {
 		// 시도코드 가져가기
		cddcCd: this.smfGetCddcCode()
 	};
	
	this.smfSetWorkPage("pa_ews_ocl_in::ews_oclin01_s00.xfdl", params);	// 시도별 지원 상세 화면 이동
}

this.fnCboCddcList = function(sCddcCd, sSelName){
	
	if(!this.smfIsNull(sCddcCd))
	{
		this.smfSetCddcCode(sCddcCd);
		this.divKorMap.form.fnSetCddcCode(sCddcCd);
	}


	var sText = "";
	if(this.smfIsNull(sSelName))
	{
		this.btnGo.set_visible(false);
	}
	else
	{
		this.btnGo.set_visible(true);
	}
}


/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 자세히보기 버튼 클릭
*/
this.btnGo_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnGo();
};

this.cboCddcList_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	var sCddcCd = e.postvalue;
	var sSelName = e.posttext;
	if(!this.smfIsNull(sCddcCd))
	{
		this.smfSetCddcCode(sCddcCd);
		this.divKorMap.form.fnSetCddcCode(sCddcCd);
	}
	
	
	var sText = "";
	if(this.smfIsNull(sSelName))
	{
		this.btnGo.set_visible(false);
	}
	else
	{	
		this.btnGo.set_visible(true);
	}

	this.resetScroll();
};
]]></Script>
