    <Script type="xscript5.1"><![CDATA[/** 
*  @MenuPath    신청안내 > 시도교육청별지원기준 > 상세
*  @FileName 	ews_oclin01_s00.xfdl 
*  @Creator 	김지영
*  @CreateDate 	2023.02.07
*  @Desction    시도교육청별 지원기준 상세
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.02.07            김지영                   최초 생성 
* 2023.06.07            류찬욱                   수정 
*******************************************************************************
*/

// this.cddcCd;	// 시도교육청 코드
// this.dataset;	// 시도교육청 데이터셋
// 
// /************************************************************************************************
//  * FORM EVENT 영역(onload, onbeforeclose)
//  ************************************************************************************************/
 this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
 {
 	// 폼 초기화 
 	this.smfInitForm(obj);
 	
 	//파라미터 세팅
 	this.pv_params = this.smfGetFormParams();
 	
	
	trace(this.pv_params.dataset);
 	if(!this.smfIsNull(this.pv_params)){	// param 데이터가 있으면
 		this.cddcCd = this.pv_params.cddcCd;
 	}
	
	
	this.dsSearch.setColumn(0, 'formType', "all");

	// 서비스 객체 생성
	this.smfSearchService("listCombo")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				this.smfAlert('PA066', ['콤보 목록을 가져오는 '] );
				return;
			}
			
			this.div00.form.cboCode.set_value(this.cddcCd)
			//this.div00.form.cboCode.set_index(0);
			this.fnSearchList();
		});
 };
// 
// /************************************************************************************************
//  * CALLBACK 콜백 처리부분(Transaction, Popup)
//  ************************************************************************************************/
	this.fnTransCallback = function(svcid,errcd,errmsg){
		if(errcd == -1) return;
	};
// 

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 
/**
 * 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchList = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				this.smfAlert('PA066', ['조회 '] );
				return;
			}
			
			for(var i=0; i<this.dsEduGrd.rowcount; i++){
				if(this.dsEduGrd.getColumn(i, "hshEnfTrgtScValue") == "F"){
					this.dsEduGrd.setColumn(i, "hshEnfTrgtScText", "무상교육");
				}else{
					this.dsEduGrd.setColumn(i, "hshEnfTrgtScText", this.dsEduGrd.getColumn(i, "hshEnfTrgtScValue"));
				}
				
				if(this.dsEduGrd.getColumn(i, "hshTutfTrgtScValue") == "F"){
					this.dsEduGrd.setColumn(i, "hshTutfTrgtScText", "무상교육");
				}else{
					this.dsEduGrd.setColumn(i, "hshTutfTrgtScText", this.dsEduGrd.getColumn(i, "hshTutfTrgtScValue"));
				}
				
				if(this.dsEduGrd.getColumn(i, "hshMseTrgtScValue") == "F"){
					this.dsEduGrd.setColumn(i, "hshMseTrgtScText", "무상교육");
				}else{
					this.dsEduGrd.setColumn(i, "hshMseTrgtScText", this.dsEduGrd.getColumn(i, "hshMseTrgtScValue"));
				}
				
				if(this.dsEduGrd.getColumn(i, "lmTrgtScValue") == "F"){
					this.dsEduGrd.setColumn(i, "lmTrgtScText", "무상급식");
				}else{
					this.dsEduGrd.setColumn(i, "lmTrgtScText", this.dsEduGrd.getColumn(i, "lmTrgtScValue"));
				}
			}
			
			this.div00.form.sta00.set_text("<fc v='#2b72de'>"+this.div00.form.cboCode.text + "</fc>교육비 지원기준 안내");
			
			if(this.dsEtcCntn.getColumn(0, "edufSprtCn") == null || this.dsEtcCntn.getColumn(0, "edufSprtCn") == "" || this.dsEtcCntn.getColumn(0, "edufSprtCn") == "undefined" ){
				this.div07.set_height(0);
			} else {
				this.div07.set_height(245);
			}
			
			if(this.dsEtcCntn.getColumn(0, "etcSprtScopeCn") == null || this.dsEtcCntn.getColumn(0, "etcSprtScopeCn") == "" || this.dsEtcCntn.getColumn(0, "etcSprtScopeCn") == "undefined" ){
				this.div09.set_height(0);
			} else {
				this.div09.set_height(245);
			}
			
			this.smfResetScroll(this);
		});
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 
 /************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 조회 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearchList();
};
this.div03_sta00_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	this.smfSetWorkPage("pa_ews_ocl_in::ews_oclin07_m00.xfdl");
};
]]></Script>
