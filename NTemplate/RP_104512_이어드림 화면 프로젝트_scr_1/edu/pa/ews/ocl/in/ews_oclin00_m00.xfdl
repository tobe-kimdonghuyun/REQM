        <Static id="sta01_00_00_01_01_01_00_00" taborder="20" text="&lt;b v='true'&gt;교육급여 :&lt;/b&gt; 보장기주의 &lt;b v='true'&gt;“소득인정액”&lt;/b&gt;이 기준 &lt;b v='true'&gt;중위소득 50% 이하&lt;/b&gt;인 대상자를 선정" left="0" top="1280" height="28" cssclass="sta_WF_Info16Blue" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="0" accessibilitylabel="교육급여: 보장기주의 &quot;소득인정액&quot;이 기준 중위소득 50% 이하인 대상자를 선정"/>
        <Static id="sta01_00_00_02_00_00_00" taborder="21" text="※ 국민기초생활보장법 제12조의 3항 따라 부양 의무자 기준은 적용하지 아니함" left="79" top="1308" width="556" height="28" cssclass="sta_WF_Txt16" usedecorate="true" initvalueid="ivStcAccessibilityOn" accessibilitylabel="국민기초생활보장법 제12조의 3항에 따라 부양 의무무자 기존은 적용하지 아니함."/>
        <Static id="sta01_00_00_01_01_01_00_00_00" taborder="22" text="&lt;b v='true'&gt;교육비지원 :&lt;/b&gt; 신청자 가구원(학생의 부모,형제·자매)의 소득과 재산을 기준으로 가구별 &lt;b v='true'&gt;“소득인정액”&lt;/b&gt;을 산정하여 대상자 선정" left="0" top="1356" height="28" cssclass="sta_WF_Info16Blue" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="0" accessibilitylabel="교육비지원 : 신청자 가구원(학생의 부모,형제·자매)의 소득과 재산을 기준으로 가구별 &quot;소득인정액&quot;을 산정하여 대상자 선정"/>
