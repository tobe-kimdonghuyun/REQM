        <Static id="sta01_00_00_01_00" taborder="8" text="&lt;b v='true'&gt;교육비지원 :&lt;/b&gt; 저소득층 수급 자격자(기초, 한부모, 법정 차상위) 등 기타 저소득층(교육청별 지원범위상이)" left="20" top="grd00:20" height="74" cssclass="sta_WF_Info24Blue" usedecorate="true" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="20"/>
        <Static id="sta01_00_00_01_01" taborder="10" text="&lt;b v='true'&gt;교육급여 :&lt;/b&gt; 교육활동지원비(초중고), 교과서(고), 입학금(고), 수업료(고)" left="20" top="imgTitle00_00_00:10" height="74" cssclass="sta_WF_Info24Blue" usedecorate="true" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="20" nHeight=""/>
        <Static id="sta01_00_00_01_01_00" taborder="11" text="&lt;b v='true'&gt;교육비지원 :&lt;/b&gt; 고교 학비, 학교급식비, 방과후학교 자유수강권, 교육정보화 지원(PC 및 인터넷통신비)" left="20" top="sta01_00_00_01_01:10" height="74" cssclass="sta_WF_Info24Blue" usedecorate="true" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="20"/>
        <Static id="sta01_00_00_00_00" taborder="13" text="학부모가 아래 ①, ② 방식 중 편한 방법으로 신청" left="20" top="imgTitle00_00_00_00:0" height="32" cssclass="sta_WF_Txt24" initvalueid="ivStcAccessibilityOn" fittocontents="height" right="20"/>
        <Div id="div03_00" taborder="15" left="20" top="div03:20" height="129" initvalueid="ivDivAccessibilityOff" right="20" cssclass="div_WF_radiusline_M"/>
        <Static id="sta01_00_00_01_01_01" taborder="17" text="&lt;b v='true'&gt;교육급여 :&lt;/b&gt; (동 주민센터 비치서류)사회복지서비스 및 급여 제공(변경) 신청서, 소득·재산서신고서, 금융정보 등 제공동의서" left="20" top="imgTitle00_00_00_00_00:10" height="93" cssclass="sta_WF_Info24Blue" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="20" fittocontents="height"/>
        <Static id="sta01_00_00_01_01_01_00" taborder="18" text="&lt;b v='true'&gt;교육비지원 :&lt;/b&gt; 신청서, 소득·재산신고서, 금융정보 등 제공동의서, 임대차 계약서 등 소득·재산 증빙서류, 신분증, 급여를 받고자하는 통장사본" left="20" top="sta01_00_00_01_01_01:10" height="93" cssclass="sta_WF_Info24Blue" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="20" fittocontents="height"/>
        <Static id="sta01_00_00_01_01_01_00_00" taborder="20" text="&lt;b v='true'&gt;교육급여 :&lt;/b&gt; 보장기주의 &lt;b v='true'&gt;“소득인정액”&lt;/b&gt;이 기준 &lt;b v='true'&gt;중위소득 50% 이하&lt;/b&gt;인 대상자를 선정" left="20" top="imgTitle00_00_00_00_00_00:10" height="74" cssclass="sta_WF_Info24Blue" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="20" fittocontents="height"/>
        <Static id="sta01_00_00_02_00_00_00" taborder="21" text="※ 국민기초생활보장법 제12조의 3항 따라 부양 의무자 기준은 적용하지 아니함" left="34" top="sta01_00_00_01_01_01_00_00:0" height="68" cssclass="sta_WF_Txt24" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="20" fittocontents="height"/>
        <Static id="sta01_00_00_01_01_01_00_00_00" taborder="22" text="&lt;b v='true'&gt;교육비지원 :&lt;/b&gt; 신청자 가구원(학생의 부모,형제·자매)의 소득과 재산을 기준으로 가구별 &lt;b v='true'&gt;“소득인정액”&lt;/b&gt;을 산정하여 대상자 선정" left="20" top="sta01_00_00_02_00_00_00:20" height="108" cssclass="sta_WF_Info24Blue" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="20" fittocontents="height"/>
        <Static id="sta01_00_00_02_00_00_00_00" taborder="23" text="※ 기초생활수급자, 한부모가족지원, 법정차상위 저격 보유자는 소득인정액 산정 없이 대상자 선정 가능" left="34" top="sta01_00_00_01_01_01_00_00_00:0" height="68" cssclass="sta_WF_Txt24" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="20" fittocontents="height"/>
        <Static id="Static99_00_00_00_00" taborder="24" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
