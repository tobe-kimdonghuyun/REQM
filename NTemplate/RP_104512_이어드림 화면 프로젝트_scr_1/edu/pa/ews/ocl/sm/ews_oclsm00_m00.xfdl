              <ImageViewer id="imgTitle" taborder="0" text="공지사항" left="0" top="0" height="44" cssclass="img_WF_SubTit01" width="137" initvalueid="ivTitleAccessibilityOn" accessibilitylabel="공지사항"/>
            </Layout>
            <Layout name="Layout0">
              <ImageViewer id="imgTitle" left="20" top="0" height="65" right="20"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divSearch" taborder="2" left="0" top="247" height="70" cssclass="div_WF_Search" right="0" initvalueid="ivDivAccessibilityOn" accessibilitylabel="조회 영역">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" text="검색" left="0" top="20" width="57" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" accessibilitylabel="검색"/>
              <Combo id="cboSearchType" taborder="1" left="57" width="105" height="30" innerdataset="dsSearchCbo" codecolumn="codeColumn" datacolumn="dataColumn" index="0" text="제목+내용" readonly="false" top="20" value="0" initvalueid="ivCmbNormal" accessibilitylabel="제목+내용"/>
              <Edit id="edtSearchKeyword" taborder="2" left="170" top="20" width="503" height="30" initvalueid="ivEdtNormal" displaynulltext="검색어를 입력해 주세요." onkeydown="edtSearchKeyword" accessibilitylabel="검색어를 입력해 주세요"/>
              <Button id="btnSearch" taborder="3" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="20" onclick="divSearch_btnSearch_onclick" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="조회"/>
            </Layout>
            <Layout name="Layout0">
              <Edit id="edtSearchKeyword" left="20" top="93" height="60" displaynulltext="검색어를 입력해주세요." right="20" taborder="1"/>
              <Static id="sta00" left="793" top="100" width="57" height="30" visible="false" taborder="3"/>
              <Combo id="cboSearchType" left="20" top="23" height="60" visible="true" taborder="0" right="20"/>
              <Button id="btnSearch" width="164" right="20" taborder="2" height="60" bottom="20" cssclass="btn_WF_Search03"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divPageSummary" taborder="3" left="7" top="337" width="331" height="30" url="comm::comp_pageSummary.xfdl" visible="true" text="" initvalueid="ivDivAccessibilityOff" tabstop="true" accessibilitylabel="총 건수"/>
        <Grid id="grd01" taborder="4" left="0" top="376" height="439" autofittype="col" right="0" binddataset="dsNtcList" initvalueid="ivGrdAccessibilityOn" selecttype="cell" oncellclick="grd01_oncellclick" accessibilitylabel="공지사항 목록" onkeydown="grd01_onkeydown" readonly="true">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="40"/>
                <Column size="522"/>
                <Column size="106"/>
                <Column size="110"/>
                <Column size="72"/>
                <Column size="77"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="번호"/>
                <Cell col="1" text="제목"/>
                <Cell col="2" text="파일"/>
                <Cell col="3" text="등록일"/>
                <Cell col="4" text="조회수"/>
                <Cell col="5" text="공지여부" cssclass="LineNo"/>
              </Band>
              <Band id="body">
                <Cell text="expr:dataset.getRowCount() - (currow + 1) +1" displaytype="text" cursor="pointer" edittype="normal"/>
                <Cell col="1" text="bind:ntcMteTitlNm" cssclass="expr:key==&quot;1&quot;?&quot;cell_ImpNoti&quot;:&quot;&quot;" cursor="pointer" edittype="normal" displaytype="normal"/>
                <Cell col="2" text="expr:(atchFileId != undefined &amp;&amp; atchFileId != &quot;&quot;) ? &quot;url('theme://images/grd_WF_fileup.png')&quot;:&quot;&quot;" displaytype="imagecontrol" background="#ffffff" accessibilitylabel="expr:(atchFileId != undefined &amp;&amp; atchFileId != &quot;&quot;) ? &quot;있음&quot;:&quot;없음&quot;" edittype="normal"/>
                <Cell col="3" displaytype="date" text="bind:regDt" calendardateformat="yyyy.MM.dd " calendareditformat="yyyy.MM.dd " edittype="normal"/>
                <Cell col="4" text="bind:ntcMteInqCnt" displaytype="text" edittype="normal"/>
                <Cell col="5" displaytype="text" text="bind:ntcMteScCd" cssclass="LineNo" edittype="normal"/>
              </Band>
            </Format>
            <Format id="format00">
              <Columns>
                <Column size="598"/>
              </Columns>
              <Rows>
                <Row size="50"/>
                <Row size="60"/>
              </Rows>
              <Band id="body">
                <Cell text="bind:ntcMteTitlNm" autosizerow="limitmin" cssclass="cell_ImpNoti" wordWrap="char"/>
                <Cell row="1" text="bind:regDt" displaytype="date" calendardateformat="yyyy.MM.dd " calendareditformat="yyyy.MM.dd " textAlign="left" cssclass="cell_Line"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Div id="divPaginator" taborder="5" left="0" top="836" height="30" right="0" url="comm::comp_paginator.xfdl" dsPage="dsPage" pageViewSize="100" initvalueid="ivDivAccessibilityOff" tabstop="true"/>
        <Button id="btnAdd" taborder="6" text="등록" top="895" height="40" width="120" cssclass="btn_WF_Action" right="0" onclick="btnAdd_onclick" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="등록"/>
      </Layout>
      <Layout name="Layout0" width="640" height="1910" mobileorientation="landscape" type="default" screenid="mobile,tablet">
        <Div id="divTitle" height="65" left="0" top="340" right="0" taborder="0"/>
        <Div id="divSearch" left="20" top="465" right="20" formscrolltype="none" height="260" taborder="1" cssclass="div_WF_Search"/>
        <Grid id="grd01" left="20" top="845" right="20" cssclass="grd_WF_Mobile2" formatid="format00" taborder="4" autofittype="col" height="858" autosizingtype="row" extendsizetype="row" scrollbarsize="1"/>
        <Div id="divPageSummary" left="20" top="785" width="331" height="40" taborder="2" text=""/>
        <Div id="divPaginator" left="20" top="1763" right="20" taborder="5" height="80"/>
        <Div id="div02_00" height="250" left="20" top="40" right="20" taborder="6"/>
        <Button id="btnAdd" cssclass="btn_WF_Crud" top="785" width="108" height="60" right="-210" taborder="3" visible="false"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    원클릭교육비 > 공지사항 목록
*  @FileName 	ews_oclsm00_m00.xfdl 
*  @Creator 	김지영
*  @CreateDate 	2023.01.12 
*  @Desction    공지사항
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.01.12            김지영                   최초 생성 
* 2023.04.22            류찬욱                   수정 
*******************************************************************************
*/
 
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	// cbo 인덱스 세팅
	this.divSearch.form.cboSearchType.set_index(0);
	
	if(nexacro.trim(this.smfGetSessionValue("mnrMngAuthCd")) == ""){
		this.btnAdd.set_visible(false);
	}else{
		this.btnAdd.set_visible(true);
	}
	
	// 파라메터 세팅
	this.pv_params = this.smfGetFormParams();
	
	if(!this.smfIsNull(this.pv_params.dsSearchParam)){
		e.id = "search";
		this.dsSearch.loadXML(this.pv_params.dsSearchParam);
	}
	
	if(!this.smfIsNull(this.pv_params.dsPagingParam)){
		e.id = "search";
		this.dsPageInfo.loadXML(this.pv_params.dsPagingParam);
		if(this.dsPageInfo.getConstColIndex("initIsUsePageInfo") < 0){
			this.dsPageInfo.addConstColumn("initIsUsePageInfo","Y");
		} else {
			this.dsPageInfo.setConstColumn("initIsUsePageInfo","Y");
		}
	}
	
	this.fnSearch(this.divSearch.form.btnSearch, e);
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(obj, e)
{	
	//this.dsSearch.setColumn(0, "searchKeyword", this.divSearch.form.edtSearchKeyword.value);
	//this.dsSearch.setColumn(0, "searchType", this.divSearch.form.cboSearchType.value);
	
	if((e)&&(e.id == "onload" )){
		this.divPageSummary.form.cboPageSize.set_value(10);
	}else{
		this.divPageSummary.form.cboPageSize.set_value(this.dsPageInfo.getColumn(0, 'pageSize'));
	}
	
	var cnt = this.divPageSummary.form.fnGetInitPageSize();
	this.dsPageInfo.setColumn(0, 'pageSize', cnt);
	
 	// 서비스 객체 생성
	this.smfSearchService("listNtc")
		// 페이징 처리
		.paginator(this.grd01, this.divPaginator, this.divPageSummary, this.dsPageInfo, obj, e)
		.run()	// 실행
		// 콜백
		.callback(function(callbackParams){		
			if(callbackParams.errors) return;
			
			this.divPageSummary.form.fnDisplayTotalText(this.dsPageInfo.getColumn(0, "totalCount"));
			
			//검색 결과가 없는 경우 페이징 숨김
			if(this.dsNtcList.getRowCount() == 0){	
				this.divPaginator.set_visible(false);
			}else{
				this.divPaginator.set_visible(true);
			}
			
			this.smfResetScroll(this);
			
		});	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description '조회' 버튼 클릭
*/
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearch(obj, e);
	trace(this.dsSearch.saveXML());
};

/**
 * @description 그리드 셀클릭 (제목클릭)
*/
this.grd01_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var nRow = e.row;
	
	if(e.col == 0 || e.col == 1){
		//파라미터 변수 세팅 (조회 조건 값)
		var objDs = obj.getBindDataset();
		var ntcMteId = objDs.getColumn(nRow, "ntcMteId");	// 공지사항ID
		var params = { "pafrBbsId": ntcMteId
					 , "dsSearchParam": this.dsSearch.saveXML()
					 , dataset : this.dsNtcList.saveXML()
					 , "dsPagingParam": this.dsPageInfo.saveXML()
					 , "csrfKey" : this.dsCsrfKey.getColumn(0, "csrfKey")
					 };
		
		this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm00_s00_01.xfdl", params);	// 상세화면 이동
	}
};


/**
 * @description '등록' 버튼 클릭
*/
this.btnAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	if(nexacro.trim(this.smfGetSessionValue("mnrMngAuthCd")) == ""){ // 관리자가 아닐 경우
		return;
	}
		var params = {"csrfKey" : this.dsCsrfKey.getColumn(0, "csrfKey")
		};

	this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm00_s00.xfdl",params);		// 등록화면 이동
};

/**
 * @description 검색 시
*/
this.edtSearchKeyword = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode == 13){
		this.dsSearch.setColumn(0, "searchKeyword", this.divSearch.form.edtSearchKeyword.value);
		this.divSearch.form.btnSearch.click();
	}
};
this.grd01_onkeydown = function(obj:nexacro.Grid,e:nexacro.KeyEventInfo)
{
	if(e.keycode == 13){
		this.grd01_oncellclick();
	}
};
]]></Script>
    <Objects>
      <Dataset id="dsSearch">
        <ColumnInfo>
          <Column id="searchKeyword" type="STRING" size="256" description="검색어"/>
          <Column id="searchType" type="STRING" size="256" description="검색구분"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsService">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256"/>
          <Column id="outDatasets" type="STRING" size="256"/>
          <Column id="asynctp" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listNtc</Col>
            <Col id="url">/ews_ocl_sm00_001.do</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsPageInfo=dsPageInfo</Col>
            <Col id="outDatasets">dsNtcList=dsNtcList dsPageInfo=dsPageInfo dsCsrfKey=dsCsrfKey</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsNtcList" useclientlayout="true">
        <ColumnInfo>
          <Column id="ntcMteId" type="STRING" size="256" description="공지사항Id"/>
          <Column id="ntcMteTitlNm" type="STRING" size="256" description="공지사항제목명"/>
          <Column id="ntcMteCn" type="STRING" size="256" description="공지사항내용"/>
          <Column id="ntcMteScCd" type="STRING" size="256" description="공지사항구분코드"/>
          <Column id="atchFileId" type="STRING" size="256" description="첨부파일Id"/>
          <Column id="regDt" type="STRING" size="256" description="등록일시"/>
          <Column id="ntcMteInqCnt" type="STRING" size="256" description="공지사항조회수"/>
          <Column id="rgtrId" type="STRING" size="256" description="등록자Id"/>
          <Column id="mdfrId" type="STRING" size="256" description="수정자Id"/>
          <Column id="mdfcnDt" type="STRING" size="256" description="수정일시"/>
          <Column id="ntcMteTitlBoldValue" type="STRING" size="256"/>
          <Column id="ntcMteTitlColorValue" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSearchCbo">
        <ColumnInfo>
          <Column id="codeColumn" type="STRING" size="256"/>
          <Column id="dataColumn" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="dataColumn">제목+내용</Col>
            <Col id="codeColumn">0</Col>
          </Row>
          <Row>
            <Col id="dataColumn">제목</Col>
            <Col id="codeColumn">1</Col>
          </Row>
          <Row>
            <Col id="dataColumn">내용</Col>
            <Col id="codeColumn">2</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsPageInfo" useclientlayout="true">
        <ColumnInfo>
          <Column id="pageIndex" type="STRING" size="256"/>
          <Column id="pageSize" type="STRING" size="256"/>
          <Column id="totalCount" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="pageSize"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsCsrfKey" useclientlayout="true">
        <ColumnInfo>
          <Column id="csrfKey" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.cboSearchType" propid="value" datasetid="dsSearch" columnid="searchType"/>
      <BindItem id="item1" compid="divSearch.form.edtSearchKeyword" propid="value" datasetid="dsSearch" columnid="searchKeyword"/>
    </Bind>
  </Form>
</FDL>
