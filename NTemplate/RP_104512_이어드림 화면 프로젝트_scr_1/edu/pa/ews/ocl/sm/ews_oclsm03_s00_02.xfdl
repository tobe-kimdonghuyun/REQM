    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    원클릭교육비 > 자료실 > 자료실 상세
*  @FileName 	ews_oclsm03_s00_01.xfdl 
*  @Creator 	김지영
*  @CreateDate 	2023.01.27
*  @Desction    자료실 상세보기/ 수정 / 삭제
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.01.27            김지영                   최초 생성 
* 2023.03.27            류찬욱                   수정 
*******************************************************************************
*/ 

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.dataId = "";	// 자료실ID
this.dsSearchParam;
this.dsPagingParam;
 
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	//파라미터 세팅
	this.pv_params = this.smfGetFormParams();
	
	if(!this.smfIsNull(this.pv_params)){	// param 데이터가 있으면
		this.dataId = this.pv_params.dataId;
		this.dsSearchParam = this.pv_params.dsSearchParam;
		this.dsPagingParam = this.pv_params.dsPagingParam;
		
		//=======================================
		// 업로드관련 초기설정을 한다.
		//=======================================
		// 업로드시 저장위치등을 판별할 정보 세팅(대문자 : 시스템코드(2)+"."+서브시스템코드(3)+"."+대분류코드(3))
		this.div00.form.divFileUpload.UPLOAD_CreateComplete = this.fnEventUploadCreateComplete;  // 필요한 경우만 세팅
		this.div00.form.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;        // 필요한 경우만 세팅(세팅권장)
		this.div00.form.divFileUpload.UPLOAD_OnError        = this.fnEventUploadError;           // 필요한 경우만 세팅(세팅권장)
		this.div00.form.divFileUpload.UPLOAD_AfterAddFile   = this.fnEventUploadAfterAddFile;
		this.div00.form.divFileUpload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)
		this.div00.form.divFileUpload.form.RaonkUpload.addEventHandler("RAONKUPLOAD_AfterDeleteFile", this.fnEventUploadAfterDeleteFile, false);
		
		this.fnSearch(this.dataId);
	}
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(dataId)
{
	this.dsSearch.setColumn(0, "dataId", dataId);
	
	// 서비스 객체 생성
	this.smfSearchService("selectOneData")
	.run()	// 실행
	// 콜백
	.callback(function(callbackParams){		
		if(callbackParams.errors) return;
		
		// 첨부파일 조회
		this.fnListFileInfo();
		
		// 자료실 내용 세팅
		this.div00.form.txtDataCn.set_value(this.dsDataDtl.getColumn(0, "dataCn"));
		// 첨부파일 셋팅 코드 추가
		var sFileRefrnId = this.dsDataDtl.getColumn(0, "atchFileId");
			if(!this.smfIsNull(sFileRefrnId)){
				this.fnListFileInfo(sFileRefrnId);
			}
			
		// 첨부파일 셋팅(사용자화면)
		if(!this.smfIsNull(sFileRefrnId)){
			this.fnGetFileInfo(sFileRefrnId);
		}
		
		// 데이터 세팅
		if(this.dsDataDtl.getColumn(0, "nextDataTitlNm") == null){
			this.div00_00.form.edtNextTitl.set_value("다음 글이 없습니다.");
			this.div00_00.form.btnNextData.set_enable(false);
		}else{
			this.div00_00.form.btnNextData.set_enable(true);
		}
		if(this.dsDataDtl.getColumn(0, "preDataTitlNm") == null){
			this.div00_00.form.edtPreTitl.set_value("이전 글이 없습니다.");
			this.div00_00.form.btnPreData.set_enable(false);
		}else{
			this.div00_00.form.btnPreData.set_enable(true);
		}
		
		this.dsDataDtl.setColumn(0, "nextDataTitlNm", this.smfDispLongText(this.div00_00.form.edtNextTitl, this.dsDataDtl.getColumn(0, "nextDataTitlNm")));
		this.dsDataDtl.setColumn(0, "dataTitlNm", this.smfDispLongText(this.div00_00.form.edtTitl, this.dsDataDtl.getColumn(0, "dataTitlNm")));
		this.dsDataDtl.setColumn(0, "preDataTitlNm", this.smfDispLongText(this.div00_00.form.edtPreTitl, this.dsDataDtl.getColumn(0, "preDataTitlNm")));
		
		this.smfResetScroll(this);
		
	});	
}


this.fnModi = function(dataId)
{	
	this.smfSaveService("updateData")
		// (권장) 데이터 존재 필수
		.requireExistsData([this.dsDataDtl, this.dsOutFileinfo])
		// 데이터 변경 필수
		.requireModifredData([this.dsDataDtl, this.dsOutFileinfo])
		.run() //실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.smfAlert(this.smfAfterServiceMessage(), this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm03_m00.xfdl"));
	})
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
};

/**
 * raonkupload가 화면을 생성된 이후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @return : N/A
 */
this.fnEventUploadCreateComplete = function(obj,paramObj)
{
};

/**
 * raonkupload가 파일을upload한 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @param : objResultDataset
 * @return : N/A
 */
this.fnEventUploadComplete = function(obj,paramObj,objResultDataset)
{
	// 업로드 성공 후, newfile에 있는 파일들을 webfile로 옮긴다.
	this.div00.form.divFileUpload.form.fnSetUploadCompleteState(obj,paramObj);
	if(objResultDataset != null){
		this.dsDataDtl.setColumn(0, "atchFileId", objResultDataset.getColumn(0,"fileRefrnId"));
		for(var i = 0; i < objResultDataset.getRowCount(); i++){
			var row = this.dsOutFileinfo.addRow();
			this.dsOutFileinfo.copyRow(row, objResultDataset, i);
			this.dsOutFileinfo.setColumn(row, 'useYn', 'Y');
		}
	}
};

/**
 * raonkupload가 파일을upload실패 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @return : N/A
 */
this.fnEventUploadError = function(obj,paramObj)
{
};

/**
 * raonkupload가 파일을 추가 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @param : sCustomValue
 * @param : sFileName
 * @param : nFileSize
 * @return : N/A
 */
this.fnEventUploadAfterAddFile = function(obj,paramObj,sCustomValue,sFileName,nFileSize)
{
	this.div00.form.divFileUpload.form.fnFileUpload();
};

/**
 * raonkupload가 파일을 삭제 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @param : sCustomValue
 * @param : sFileName
 * @param : nFileSize
 * @return : N/A
 */
this.fnEventUploadAfterDeleteFile = function(obj, paramObj)
{
 	var fileNm = paramObj.userdata.strKey;
 	var formThis = this.parent.parent.parent.parent.parent;

	var row = formThis.dsOutFileinfo.findRow('atchFileGuid', fileNm);
	if (row != -1){
		formThis.dsOutFileinfo.setColumn(row, 'useYn', 'N');
	}
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * KUpload를 생성시 지정할 property값을 지정
 * @param  : N/A
 * @return : N/A
 */
this.fnSetRaonProp = function()
{
	// 설정할 property
	var objAddRaonProps = {
							MaxOneFileSize			: '10MB'									// 파일당 최대 사이즈
							,ExtensionAllowOrLimit	: '1'										// 설정값이 "0" 이면 설정한 파일 확장자명만 "제한"으로 설정되며, "1"로 설정시 "허용"으로 설정
							,ExtensionArr           : 'pdf,png,jpg,jpeg,PDF,PNG,JPG,JPEG'		// 제한 또는 허용할 확장자 (,)로 구분
							,DisableAlertMessage	: {
								DisableDeleteConfirm: "1" 										// "1"로 설정시 파일 삭제시 confirm창 비활성.
							}
							,ButtonBarEdit			: "add,remove,remove_all,download,download_all"
							,UseDbclickOpen			: '1'										// 더블클릭으로 파일열기 0: 사용안함 1:사용
							};
	return objAddRaonProps;
}

/**
 * 파일 조회
 * @param : N/A
 * @param : N/A
 */
this.fnListFileInfo = function(){
console.log("☆★☆★☆★"+ this.dsOutFileinfo.saveXML());

	// 업로드 초기화
	this.div00.form.divFileUpload.form.fnResetUpload();
	
	for (var i = 0; i < this.dsOutFileinfo.getRowCount(); i++) {
		var handlerCode       = "PA.EWS.OCL";
		var atchFileSn        = this.dsOutFileinfo.getColumn(i, "fileRefrnId");
		var fileSize          = this.dsOutFileinfo.getColumn(i, "atchFileMg"); 
		var backendFilename   = this.dsOutFileinfo.getColumn(i, "atchFileGuid");
		var frontendFilename  = this.dsOutFileinfo.getColumn(i, "atchFileNm");
		var fileId            = this.dsOutFileinfo.getColumn(i, "fileId");
		if(this.isNotNil(atchFileSn)){
			this.div00.form.divFileUpload.form.fnAddUploadedFile(handlerCode, atchFileSn, fileSize, backendFilename, frontendFilename, fileId);
		}
	}
};

this.fnGetFileInfo = function (sFileRefrnId)
{
	// 업로드 초기화
	this.transaction("fn_filesearch"
		,"baseUrl::/cm_cmc_file_upload_001.do"
		,""
		,"dsOutFileinfo=atchFileinfo" 
		,"fileRefrnId='"+sFileRefrnId+"'"
		,this.btnUpload_FileSearch_callback
		,false // 동기
	);

	if(this.dsOutFileinfo.rowcount > 1){
		var addHeight = (this.dsOutFileinfo.rowcount - 1)*30;
		this.div00.form.divFileDown.set_height(parseInt(this.div00.form.divFileDown.height) + parseInt(addHeight));
	}
	
	for (var i = 0; i < this.dsOutFileinfo.rowcount; i++) {
		var responseCustomValue = "";
		var sDownloadPath = "";
		var handlerCode       = "PA.EWS.OCL";
		var fileSn            = this.dsOutFileinfo.getColumn(i,"fileRefrnId");
		var fileId            = this.dsOutFileinfo.getColumn(i,"fileId");
		var fileSize          = this.dsOutFileinfo.getColumn(i,"atchFileMg");
		var backendFilename   = this.dsOutFileinfo.getColumn(i,"atchFileGuid");
		var filename  = this.dsOutFileinfo.getColumn(i,"atchFileNm");
		var sFileEncryptYn    = "N";
		var sPrivInfoFiltYn   = "N";
		var sFileSaveStg      = this.dsOutFileinfo.getColumn(i,"fileSaveStg");
		var sFileInfSaveYn    = "Y";
		this.div00.form.divFileDown.form.fnAddUploadedFile(handlerCode, fileSn, fileSize, backendFilename, filename, fileId
												, sDownloadPath, sFileEncryptYn, sPrivInfoFiltYn, sFileSaveStg, sFileInfSaveYn);	
	}
};

this.btnUpload_FileSearch_callback = function()
{
	for (var i = 0; i < this.dsOutFileinfo.rowcount; i++) {
		var responseCustomValue = "";
		var sDownloadPath = "";
		var handlerCode       = "PA.EWS.OCL";
		var fileSn            = this.dsOutFileinfo.getColumn(i,"fileRefrnId");
		var fileId            = this.dsOutFileinfo.getColumn(i,"fileId");
		var fileSize          = this.dsOutFileinfo.getColumn(i,"atchFileMg");
		var backendFilename   = this.dsOutFileinfo.getColumn(i,"atchFileGuid");
		var forntendFilename  = this.dsOutFileinfo.getColumn(i,"atchFileNm");
		var sFileEncryptYn    = this.dsOutFileinfo.getColumn(i,"fileEncryptYn");
		var sPrivInfoFiltYn   = this.dsOutFileinfo.getColumn(i,"privInfoFiltYn");
		var sFileSaveStg      = this.dsOutFileinfo.getColumn(i,"fileSaveStg");
		var sFileInfSaveYn    = this.dsOutFileinfo.getColumn(i,"fileInfSaveYn");
		this.div00.form.divFileDown.form.fnAddUploadedFile(handlerCode, fileSn, fileSize, backendFilename, forntendFilename, fileId
												, sDownloadPath, sFileEncryptYn, sPrivInfoFiltYn, sFileSaveStg, sFileInfSaveYn);
	}
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 목록 버튼 클릭
*/
this.btnList_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var params = { "dsSearchParam": this.dsSearchParam,
				   "dsPagingParam":this.dsPagingParam
				 };
	this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm03_m00.xfdl", params);	// 목록화면 이동
};


/**
 * @description 수정 버튼 클릭
*/
this.btnModi_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	dataId = this.dsSearch.getColumn(0, "dataId");
	
	if (this.dsOutFileinfo.findRow('useYn', 'Y') == -1)	{
		this.dsDataDtl.setColumn(0, "atchFileId", null);
	}
	
	this.fnModi(dataId);
};

/**
 * @description 다음글 버튼 클릭
*/
this.btnNext = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(!this.smfIsNull(this.dsDataDtl.getColumn(0, "nextDataId"))){
		this.fnSearch(this.dsDataDtl.getColumn(0, "nextDataId"));
	}
};

/**
 * @description 이전글 버튼 클릭
*/
this.btnPre = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(!this.smfIsNull(this.dsDataDtl.getColumn(0, "preDataId"))){
		this.fnSearch(this.dsDataDtl.getColumn(0, "preDataId"));
	}
};


]]></Script>
