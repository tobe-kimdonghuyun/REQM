    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    원클릭교육비 > 자주묻는 질문 > 자주묻는 질문 상세
*  @FileName 	ews_oclsm01_s00_01.xfdl 
*  @Creator 	류찬욱
*  @CreateDate 	2023.03.28
*  @Desction    자주묻는 질문 상세보기 / 삭제
******************* 소스 수정 이력 *******************************************
*  date          		Modifier                Description
********************************************************************************
* 2023.03.28            류찬욱                   최초 생성 
********************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.qnaId = "";
this.dsSearchParam;
this.dsPagingParam;
this.lock;
this.newPswd="";

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	//파라미터 세팅
	this.pv_params = this.smfGetFormParams();
	
	if(!this.smfIsNull(this.pv_params)){	// param 데이터가 있으면
		this.qnaId = this.pv_params.qnaId;
		this.qnaLvl = this.pv_params.qnaLvl;
		this.dsSearchParam = this.pv_params.dsSearchParam;
		this.dsPagingParam = this.pv_params.dsPagingParam;
		this.csrfKey = this.pv_params.csrfKey;
		this.lock = this.pv_params.lock;
		if(!this.smfIsNull(this.pv_params.newPswd)) {
			this.newPswd = this.pv_params.newPswd;
		}
		
		if(nexacro.trim(this.smfGetSessionValue("mnrMngAuthCd")) == ""){
		
			this.btnAsk.set_visible(false);
			
			if(this.qnaLvl != "0" ){
				this.btnAdd00_00.set_visible(false);
				this.btnAdd00.set_visible(false);
			}
			
		}else{
			this.btnAsk.set_visible(true);
			this.btnAdd00_00.set_visible(true);
			this.btnAdd00.set_visible(true);
		}
		
		//=======================================
		// 업로드관련 초기설정을 한다.
		//=======================================
		// 업로드시 저장위치등을 판별할 정보 세팅(대문자 : 시스템코드(2)+"."+서브시스템코드(3)+"."+대분류코드(3))
		this.div00.form.divFileDownload.UPLOAD_CreateComplete = this.fnEventUploadCreateComplete;  // 필요한 경우만 세팅
		this.div00.form.divFileDownload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)
		//this.fnSearch(this.qnaId);
	}
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnEventUploadCreateComplete = function()
{
	this.fnSearch(this.qnaId);
}


this.fnSearch = function(qnaId)
{
	this.dsSearch.setColumn(0, "qnaId", qnaId);
	this.dsSearch.setColumn(0, "lock", this.lock);
	this.dsSearch.setColumn(0, "newPswd", this.newPswd);
	
	// 서비스 객체 생성
	this.smfSearchService("selectOneQna")
	.run()	// 실행
	// 콜백
	.callback(function(callbackParams){
		if(callbackParams.errors) {
			var params = { "qnaId": qnaId
				 , "dsSearchParam": this.dsSearchParam
				 , "dsPagingParam": this.dsPagingParam
				 };
				 
			if(callbackParams.reason == -99){
				this.smfAlert(callbackParams.message);
			}
			this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm02_m00.xfdl", params);
			return;
		}
		
		if( this.dsQnaDtl.getColumn(0, "qnaScCd") == "8" ){
			this.div00.form.edt00_01.set_value("신청");
		} else if( this.dsQnaDtl.getColumn(0, "qnaScCd") == "9" ){
			this.div00.form.edt00_01.set_value("소득·재산 조사");
		} else if( this.dsQnaDtl.getColumn(0, "qnaScCd") == "10" ){
			this.div00.form.edt00_01.set_value("대상자선정");
		} else if( this.dsQnaDtl.getColumn(0, "qnaScCd") == "11" ){
			this.div00.form.edt00_01.set_value("교육비지원");
		} else if( this.dsQnaDtl.getColumn(0, "qnaScCd") == "12" ){
			this.div00.form.edt00_01.set_value("이의신청");
		}
		
		// 자주묻는 질문 내용 세팅
		this.div00.form.txt00.set_value(this.dsQnaDtl.getColumn(0, "qnaCn"));

		// 첨부파일 셋팅 코드 추가
		var sFileRefrnId = this.dsQnaDtl.getColumn(0, "atchFileId");

		// 첨부파일 셋팅(사용자화면)
		if(!this.smfIsNull(sFileRefrnId)){
			this.fnGetFileInfo(sFileRefrnId);
		} else {
			this.div00.form.divFileDownload.form.fnResetUpload();
		}
		
		// 데이터 세팅
		if(this.dsQnaDtl.getColumn(0, "nextQnaTitlNm") == null){
			this.div00_00.form.edtNextTitl.set_value("다음 글이 없습니다.");
			this.div00_00.form.btnNext.set_enable(false);
		}else{
			this.div00_00.form.btnNext.set_enable(true);
		}
		if(this.dsQnaDtl.getColumn(0, "preQnaTitlNm") == null){
			this.div00_00.form.edtPreTitl.set_value("이전 글이 없습니다.");
			this.div00_00.form.btnPre.set_enable(false);
		}else{
			this.div00_00.form.btnPre.set_enable(true);
		}
		
		
		if(nexacro.trim(this.smfGetSessionValue("mnrMngAuthCd")) == ""){
		
			this.btnAsk.set_visible(false);
			
			if( this.dsQnaDtl.getColumn(0, "qnaLvl") == "0" ){
				this.btnAdd00_00.set_visible(true);
				this.btnAdd00.set_visible(true);
			}else{
				this.btnAdd00_00.set_visible(false);
				this.btnAdd00.set_visible(false);
			}
			
			if( this.dsQnaDtl.getColumn(0, "ntcPstYn") == "Y" ){
				this.btnAdd00_00.set_visible(false);
				this.btnAdd00.set_visible(false);
			}
		}else{
			this.btnAsk.set_visible(true);
			this.btnAdd00_00.set_visible(true);
			this.btnAdd00.set_visible(true);
		}
		
		this.dsQnaDtl.setColumn(0, "qnaTitlNm2", this.dsQnaDtl.getColumn(0, "qnaTitlNm"));
		this.dsQnaDtl.setColumn(0, "qnaTitlNm", this.smfDispLongText(this.div00.form.edt00, this.dsQnaDtl.getColumn(0, "qnaTitlNm")));
		this.dsQnaDtl.setColumn(0, "nextQnaTitlNm", this.smfDispLongText(this.div00_00.form.edtNextTitl, this.dsQnaDtl.getColumn(0, "nextQnaTitlNm")));
		this.dsQnaDtl.setColumn(0, "qnaTitlNm2", this.smfDispLongText(this.div00_00.form.edtTitl, this.dsQnaDtl.getColumn(0, "qnaTitlNm2")));
		this.dsQnaDtl.setColumn(0, "preQnaTitlNm", this.smfDispLongText(this.div00_00.form.edtPreTitl, this.dsQnaDtl.getColumn(0, "preQnaTitlNm")));
		
		this.smfResetScroll(this);

	});	
}

this.fnDel = function(qnaId)
{
	//this.dsSearch.getColumn(0, "qnaId");
	
	if( this.dsQnaDtl.getColumn(0, "qnaLvl") == "0" )
		this.dsSearch.setColumn(0, "qnaId", this.dsQnaDtl.getColumn(0, "upQnaId"));
	// 서비스 객체 생성
	this.smfDeleteService("deleteQna")
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.smfAlert(this.smfAfterServiceMessage(), this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm02_m00.xfdl"));
		})
};

this.fnDelPwd = function(qnaId)
{
	//this.dsSearch.getColumn(0, "qnaId");
	
	if( this.dsQnaDtl.getColumn(0, "qnaLvl") == "0" )
		this.dsSearch.setColumn(0, "qnaId", this.dsQnaDtl.getColumn(0, "upQnaId"));
	// 서비스 객체 생성
	this.smfDeleteService("deleteQnaPwd")
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) {
				var params = { "qnaId": qnaId
				 , "dsSearchParam": this.dsSearchParam
				 , "dsPagingParam": this.dsPagingParam
				 };
				 
				if(callbackParams.reason == -99){
					this.smfAlert(callbackParams.message);
				}
				return;
			}
			this.smfAlert(this.smfAfterServiceMessage(), this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm02_m00.xfdl"));
		})
};


this.fnChkPawd = function(oldPswd, newPswd, sqlStr)
{
	var qnaId = this.dsQnaDtl.getColumn(0, "qnaId");	// 자주묻는 질문ID
	var params = { "qnaId": qnaId
			 , "dsSearchParam": this.dsSearchParam
			 , "dsPagingParam": this.dsPagingParam
			 , "lock": this.lock
			 , "newPswd": newPswd
			 };
	
	this.dsPawd.setColumn(0, "oldPswd", oldPswd);
	this.dsPawd.setColumn(0, "newPswd", newPswd);
	
			
	if(nexacro.trim(this.smfGetSessionValue("mnrMngAuthCd")) == ""){
		
		// 서비스 객체 생성
		this.smfSearchService("selectPawdQna")
		.run()	// 실행
		// 콜백
		.callback(function(callbackParams){		
			if(callbackParams.errors) return;
			trace("---------------"+this.dsPawd.saveXML());

			if(this.dsPawd.getColumn(0, "chkPawdYn") == "Y"){
				if(sqlStr == "update"){
					this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm02_s00_02.xfdl", params);	// 상세화면 이동
				} else if(sqlStr == "delete"){
					this.fnDelPwd();
				}
			}else{
				this.smfAlert("비밀번호가 틀립니다.")
				return false;
			}
			
		});
		
		
	} else {
		if(sqlStr == "update"){
			this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm02_s00_02.xfdl", params);	// 상세화면 이동
		} else if(sqlStr == "delete"){
			this.fnDel();
		}
	}
	
}

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
};


 /**
 * @description 학교찾기 콜백
 */
this.fnOclsmPop = function(e, sender){

	
	// 그외 다른 정보를 trace()로 표시(개발용)
	var sLog = "";
	var qnaId = "";
	var chkPawdYn = "";
	var qnaLvl = "";
	
	if(e.row)
	{
		for(var sKey in e.row)
		{
			var sValue = e.row[sKey];
			sLog += sKey + ":["+sValue+"]\n";
			
			this.trace("sValue :"+sValue);
			//alert(sValue[0]);
			if(sKey == "qnaId")
				qnaId = sValue;
				
			if(sKey == "chkPawdYn")
				chkPawdYn = sValue;
		}
	}
	
	
	
	this.trace("sLog :"+sLog);
	this.trace("qnaId :"+qnaId);
	
	if( chkPawdYn == "N" ){
		this.smfAlert("패스워드가 틀립니다.");
		return false;
	}
	
	//var qnaId = objDs.getColumn(e.row, "qnaId");
	
	this.fnSearch(qnaId);

};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

this.fnEventDownloadComplete = function(obj,paramObj)
{
	trace("========== fnEventDownloadComplete");
}

this.fnGetFileInfo = function (sFileRefrnId)
{
	// 업로드 초기화
	this.transaction("fn_filesearch"
		,"baseUrl::/cm_cmc_file_upload_001.do"
		,""
		,"dsOutFileinfo=atchFileinfo" 
		,"fileRefrnId='"+sFileRefrnId+"'"
		,""//this.btnUpload_FileSearch_callback
		,false // 동기
	);

	for (var i = 0; i < this.dsOutFileinfo.rowcount; i++) {
		var handlerCode       = "PA.EWS.OCL";
		var fileSn = this.dsOutFileinfo.getColumn(i,"fileRefrnId");
		var fileId = this.dsOutFileinfo.getColumn(i,"fileId");
		var fileSize = this.dsOutFileinfo.getColumn(i,"atchFileMg");
		var backendFilename = this.dsOutFileinfo.getColumn(i,"atchFileGuid");
		var frontendFilename = this.dsOutFileinfo.getColumn(i,"atchFileNm");
		this.div00.form.divFileDownload.form.fnAddUploadedFile(handlerCode, fileSn, fileSize, backendFilename, frontendFilename , fileId);
	}
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.btnModi_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
	//파라미터 변수 세팅 (조회 조건 값)
	var oldPswd = this.dsQnaDtl.getColumn(0, "qnaPswd");
	var newPswd = this.div00.form.edt00_01_00.value;

	if(nexacro.trim(this.smfGetSessionValue("mnrMngAuthCd")) == ""){
		if( newPswd == "" || newPswd == "undefined" || newPswd == null){
			this.smfAlert("비밀번호를 입력하세요.");
			return false;
		}
	}
	
	this.fnChkPawd(oldPswd, newPswd, "update");
	
};

/**
 * @description 삭제 버튼 클릭
*/
this.btnDel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//파라미터 변수 세팅 (조회 조건 값)
	var oldPswd = this.dsQnaDtl.getColumn(0, "qnaPswd");
	var newPswd = this.div00.form.edt00_01_00.value;
	
	if(nexacro.trim(this.smfGetSessionValue("mnrMngAuthCd")) == ""){
		if( newPswd == "" || newPswd == "undefined" || newPswd == null){
			this.smfAlert("비밀번호를 입력하세요.");
			return false;
		}
	}
	
	for(var i = 0; i< this.dsOutFileinfo.getRowCount(); i++){
		this.dsOutFileinfo.setColumn(i, 'useYn', 'N');
	}
	
	this.fnChkPawd(oldPswd, newPswd, "delete");
};

/**
 * @description '답변' 버튼 클릭
*/
this.btnAsk_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//if (session == null)	// 세션이 없으면 (관리자가 아니면)
	//{
		var params = { "qnaId": this.qnaId
						,"ntcYn":this.dsQnaDtl.getColumn(0, "ntcYn")
						, "csrfKey":this.csrfKey 
		};
	//}
	
	this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm02_s00.xfdl", params);		// 등록화면 이동
};
/**
 * @description 다음글 버튼 클릭
*/
this.btnNextNtc = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(!this.smfIsNull(this.dsQnaDtl.getColumn(0, "nextQnaId"))){
		
		if( nexacro.trim(this.smfGetSessionValue("mnrMngAuthCd")) != "" || this.dsQnaDtl.getColumn(0, "nextLock") == "Y" ){
			this.fnSearch(this.dsQnaDtl.getColumn(0, "nextQnaId"));
		}else{
			
			// 팝업을 동작에 필요한 파라메터 지정
			var popupParams = {
				callback: this.fnOclsmPop, // 콜백함수 지정
				sender: obj, // sender 지정

				// 팝업 전달 파라메터 지정
				params: {
					// 처리타입 지정
					procType: 'search',
					// 파라메터 전달 
					qnaId: this.dsQnaDtl.getColumn(0, "nextQnaId"),
					qnaLvl: this.dsQnaDtl.getColumn(0, "nextLvl")
				},
			};
			
			// 모달팝업 실행
			this.smfDialog("_auto", "pa_ews_ocl_sm::ews_oclsm02_p01.xfdl", popupParams);
		}
	}
};

/**
 * @description 이전글 버튼 클릭
*/
this.btnPreNtc = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(!this.smfIsNull(this.dsQnaDtl.getColumn(0, "preQnaId"))){
		
		if( nexacro.trim(this.smfGetSessionValue("mnrMngAuthCd")) != "" || this.dsQnaDtl.getColumn(0, "preLock") == "Y" ){
			this.fnSearch(this.dsQnaDtl.getColumn(0, "preQnaId"));
		}else{		
			// 팝업을 동작에 필요한 파라메터 지정
			var popupParams = {
				callback: this.fnOclsmPop, // 콜백함수 지정
				sender: obj, // sender 지정

				// 팝업 전달 파라메터 지정
				params: {
					// 처리타입 지정
					procType: 'search',
					// 파라메터 전달 
					qnaId: this.dsQnaDtl.getColumn(0, "preQnaId"),
					qnaLvl: this.dsQnaDtl.getColumn(0, "preLvl")
				},
			};
			
			// 모달팝업 실행
			this.smfDialog("_auto", "pa_ews_ocl_sm::ews_oclsm02_p01.xfdl", popupParams);
		}
	}
};

this.btnDeleteAll_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divFileDownload.form.fnDownloadAll();
};

this.btnQnaList_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var params = { "dsSearchParam": this.dsSearchParam,
				   "dsPagingParam":this.dsPagingParam
				 };
	this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm02_m00.xfdl", params);	// 목록화면 이동
};
]]></Script>
