          <Column id="rgtrId" type="STRING" size="256" description="수정자Id"/>
          <Column id="regDt" type="STRING" size="256" description="수정일시"/>
          <Column id="preNtcMteId" type="STRING" size="256"/>
          <Column id="preNtcMteTitlNm" type="STRING" size="256"/>
          <Column id="preRegDt" type="STRING" size="256"/>
          <Column id="nextNtcMteId" type="STRING" size="256"/>
          <Column id="nextNtcMteTitlNm" type="STRING" size="256"/>
          <Column id="nextRegDt" type="STRING" size="256"/>
          <Column id="sCnt" type="STRING" size="256" description="게시글수"/>
