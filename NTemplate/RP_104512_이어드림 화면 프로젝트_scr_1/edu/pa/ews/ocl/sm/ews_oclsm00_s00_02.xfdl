          <Column id="ntcMteId" type="STRING" size="256"/>
          <Column id="fileRefrnId" type="STRING" size="256"/>
          <Column id="popupId" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256"/>
          <Column id="outDatasets" type="STRING" size="256"/>
          <Column id="asynctp" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsNtcDtl=dsNtcDtl dsOutFileinfo=dsOutFileinfo dsPopup=dsPopup</Col>
            <Col id="url">/ews_ocl_sm00_002.do</Col>
            <Col id="id">selectOneNtc</Col>
          </Row>
          <Row>
            <Col id="id">deleteNtc</Col>
            <Col id="url">/ews_ocl_sm00_005.do</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsNtcDtl=dsNtcDtl dsOutFileinfo=dsOutFileinfo dsPopup=dsPopup</Col>
            <Col id="outDatasets"/>
          </Row>
          <Row>
            <Col id="id">updateNtc</Col>
            <Col id="url">/ews_ocl_sm00_004.do</Col>
            <Col id="inDatasets">dsNtcDtl=dsNtcDtl dsOutFileinfo=dsOutFileinfo dsPopup=dsPopup dsCsrfKey=dsCsrfKey</Col>
            <Col id="outDatasets">dsCsrfKey=dsCsrfKey</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsOutFileinfo" useclientlayout="true">
        <ColumnInfo>
          <Column id="fileRefrnId" type="STRING" size="256" description="파일SEQ ID"/>
          <Column id="fileId" type="STRING" size="256" description="파일 아이디"/>
          <Column id="suc" type="STRING" size="256"/>
          <Column id="atchFileNm" type="STRING" size="256" description="파일명"/>
          <Column id="atchFileGuid" type="STRING" size="256" description="파일 GUID"/>
          <Column id="atchFileMg" type="STRING" size="256"/>
          <Column id="fileExtsnNm" type="STRING" size="256" description="파일확장자"/>
          <Column id="minTypeNm" type="STRING" size="256" description="파일의 mime type"/>
          <Column id="fileCoursNm" type="STRING" size="256" description="서버파일저장위치"/>
          <Column id="fileObjKey" type="STRING" size="256"/>
          <Column id="fileEncryptYn" type="STRING" size="256"/>
          <Column id="fileSaveStg" type="STRING" size="256"/>
          <Column id="chk" type="STRING" size="256"/>
          <Column id="fileGubunCd" type="STRING" size="256"/>
          <Column id="useYn" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsPopup" useclientlayout="true">
        <ColumnInfo>
