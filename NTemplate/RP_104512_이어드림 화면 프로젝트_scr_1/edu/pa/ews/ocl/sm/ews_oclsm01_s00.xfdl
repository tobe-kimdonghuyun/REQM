    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    원클릭교육비 > 자주묻는 질문
*  @FileName 	ews_oclsm01_s00_01.xfdl 
*  @Creator 	김지영
*  @CreateDate 	2023.01.20
*  @Desction    자주묻는 질문 글 등록
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.01.20            김지영                   최초 생성 
* 2023.03.23            류찬욱                   수정 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);

	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	this.fnValidateMain();

	this.div00.form.cboFaqCd.set_index(0);
	
	this.fnDate();
	
	//파라미터 세팅
	this.pv_params = this.smfGetFormParams();
	
	if(!this.smfIsNull(this.pv_params)){	// param 데이터가 있으면
		this.dsCsrfKey.setColumn(0, "csrfKey",this.pv_params.csrfKey);
	}
	
	//=======================================
	// 업로드관련 초기설정을 한다.
	//=======================================
	// 업로드시 저장위치등을 판별할 정보 세팅(대문자 : 시스템코드(2)+"."+서브시스템코드(3)+"."+대분류코드(3))
	this.div00.form.divFileUpload.UPLOAD_CreateComplete = this.fnEventUploadCreateComplete;  // 필요한 경우만 세팅
	this.div00.form.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;        // 필요한 경우만 세팅(세팅권장)
	this.div00.form.divFileUpload.UPLOAD_OnError        = this.fnEventUploadError;           // 필요한 경우만 세팅(세팅권장)
	this.div00.form.divFileUpload.UPLOAD_AfterAddFile   = this.fnEventUploadAfterAddFile;
 	this.div00.form.divFileUpload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)
	this.div00.form.divFileUpload.form.RaonkUpload.addEventHandler("RAONKUPLOAD_AfterDeleteFile", this.fnEventUploadAfterDeleteFile, false);
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSave = function()
{	
	// 서비스 객체 생성
	this.smfSaveService("saveFaq")
	// 데이터 존재 필수
	.requireExistsData(this.dsFaqDtl)
	// 데이터 검증
	.validateForm(this.div00)
	
	.run()	// 실행
	
	// 콜백
	.callback(function(callbackParams){		
		if(callbackParams.errors) {
			trace(JSON.stringify(callbackParams));
			if(callbackParams.reason == -99){
				this.smfAlert(callbackParams.message);
			}
			this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm01_m00.xfdl", params);
			return;
		}	
		
		// 저장이 완료되었습니다.
		// 재조회
		this.smfAlert(this.smfAfterServiceMessage(), this.back());
	});	

};

/**
 * @description 유효성체크서비스
 */
 this.fnValidateMain = function ()
 {
 	this.smfValidateService("validateMain", {
			url : "/ews_ocl_sm01_000.do",
		})
		.mappingRulesetToForm(this.div00, "saveFaqDtl")
		.callback(function(callbackParams) {
			if (this.dsFaqDtlValid.getRowCount() > 1)
			{
				this.dsFaqDtlValid.deleteRow(this.dsFaqDtlValid.getRowCount()-1);
			}
		})
		.run();
 };

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
};

/**
 * raonkupload가 화면을 생성된 이후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @return : N/A
 */
this.fnEventUploadCreateComplete = function(obj,paramObj)
{
};

/**
 * raonkupload가 파일을upload한 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @param : objResultDataset
 * @return : N/A
 */
this.fnEventUploadComplete = function(obj,paramObj,objResultDataset)
{
	// 업로드 성공 후, newfile에 있는 파일들을 webfile로 옮긴다.
	this.div00.form.divFileUpload.form.fnSetUploadCompleteState(obj,paramObj);
	if(objResultDataset != null){
		this.dsFaqDtl.setColumn(0, "atchFileId", objResultDataset.getColumn(0,"fileRefrnId"));
		for(var i = 0; i < objResultDataset.getRowCount(); i++){
			var row = this.dsOutFileinfo.addRow();
			this.dsOutFileinfo.copyRow(row, objResultDataset, i);
			this.dsOutFileinfo.setColumn(row, 'useYn', 'Y');
		}
	}
};

/**
 * raonkupload가 파일을upload실패 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @return : N/A
 */
this.fnEventUploadError = function(obj,paramObj)
{
};

/**
 * raonkupload가 파일을 추가 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @param : sCustomValue
 * @param : sFileName
 * @param : nFileSize
 * @return : N/A
 */
this.fnEventUploadAfterAddFile = function(obj,paramObj,sCustomValue,sFileName,nFileSize)
{
	this.div00.form.divFileUpload.form.fnFileUpload();
};

/**
 * raonkupload가 파일을 삭제 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @param : sCustomValue
 * @param : sFileName
 * @param : nFileSize
 * @return : N/A
 */
this.fnEventUploadAfterDeleteFile = function(obj, paramObj)
{
 	var fileNm = paramObj.userdata.strKey;
 	var formThis = this.parent.parent.parent.parent.parent;

	var row = formThis.dsOutFileinfo.findRow('atchFileGuid', fileNm);
	if (row != -1){
		formThis.dsOutFileinfo.setColumn(row, 'useYn', 'N');
	}
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 this.back = function ()
 {
 	this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm01_m00.xfdl");	// 목록화면 이동
 };
 
 this.fnDate = function ()
{
	// 작성일 세팅
	var objDate = new nexacro.Date();
	var yyyy = objDate.getFullYear();	// 현재 년도
	var mm = objDate.getMonth();	//현재 월
	var dd = objDate.getDate();		// 현재 일
	var month = mm+1
	
	if(dd < 10){
		dd = 0 + "" + dd
	}
	if(month < 10){
		month = 0 + "" + month
	}
	
	this.div00.form.edtRegDt.set_value(yyyy + "." + month + "." + dd);
};

/**
 * KUpload를 생성시 지정할 property값을 지정
 * @param  : N/A
 * @return : N/A
 */
this.fnSetRaonProp = function()
{
	// 설정할 property
	var objAddRaonProps = {
							MaxOneFileSize			: '10MB'									// 파일당 최대 사이즈
							,ExtensionAllowOrLimit	: '1'										// 설정값이 "0" 이면 설정한 파일 확장자명만 "제한"으로 설정되며, "1"로 설정시 "허용"으로 설정
							,ExtensionArr           : 'pdf,png,jpg,jpeg,PDF,PNG,JPG,JPEG'		// 제한 또는 허용할 확장자 (,)로 구분
							,DisableAlertMessage	: {
								DisableDeleteConfirm: "1" 										// "1"로 설정시 파일 삭제시 confirm창 비활성.
							}
							,ButtonBarEdit			: "add,remove,remove_all,download,download_all"
							,UseDbclickOpen			: '1'										// 더블클릭으로 파일열기 0: 사용안함 1:사용
							};
	return objAddRaonProps;
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 목록 버튼 클릭
*/
this.btnList_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.back();
};

/**
 * @description 저장 버튼 클릭
*/
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (this.dsOutFileinfo.findRow('useYn', 'Y') == -1)	{
		this.dsFaqDtl.setColumn(0, "atchFileId", null);
	}
	
	this.fnSave();
};
]]></Script>
    <Objects>
      <Dataset id="dsFaqDtl" useclientlayout="true">
        <ColumnInfo>
