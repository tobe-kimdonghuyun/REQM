          <Column id="faqTitlNm" type="STRING" size="256" description="faq제목명"/>
          <Column id="faqCn" type="STRING" size="256" description="faq내용"/>
          <Column id="faqScCd" type="STRING" size="256" description="faq구분코드"/>
          <Column id="atchFileId" type="STRING" size="256" description="파일참조"/>
          <Column id="mdfrId" type="STRING" size="256" description="수정자ID"/>
          <Column id="mdfcnDt" type="STRING" size="256" description="수정일시"/>
          <Column id="faqInqCnt" type="STRING" size="256" description="faq조회수"/>
          <Column id="rgtrId" type="STRING" size="256" description="수정자Id"/>
          <Column id="regDt" type="STRING" size="256" description="수정일시"/>
          <Column id="prefaqId" type="STRING" size="256"/>
          <Column id="prefaqTitlNm" type="STRING" size="256"/>
          <Column id="preRegDt" type="STRING" size="256"/>
          <Column id="nextfaqId" type="STRING" size="256"/>
          <Column id="nextfaqTitlNm" type="STRING" size="256"/>
          <Column id="nextRegDt" type="STRING" size="256"/>
          <Column id="sCnt" type="STRING" size="256" description="게시글수"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="faqId" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256"/>
          <Column id="outDatasets" type="STRING" size="256"/>
          <Column id="asynctp" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="url">/ews_ocl_sm01_003.do</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsFaqDtl=dsFaqDtl dsOutFileinfo=dsOutFileinfo dsCsrfKey=dsCsrfKey</Col>
            <Col id="outDatasets">dsCsrfKey=dsCsrfKey</Col>
            <Col id="id">saveFaq</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsOutFileinfo" useclientlayout="true">
        <ColumnInfo>
          <Column id="fileRefrnId" type="STRING" size="256" description="파일SEQ ID"/>
          <Column id="fileId" type="STRING" size="256" description="파일 아이디"/>
          <Column id="suc" type="STRING" size="256"/>
          <Column id="atchFileNm" type="STRING" size="256" description="파일명"/>
          <Column id="atchFileGuid" type="STRING" size="256" description="파일 GUID"/>
          <Column id="atchFileMg" type="STRING" size="256"/>
          <Column id="fileExtsnNm" type="STRING" size="256" description="파일확장자"/>
          <Column id="minTypeNm" type="STRING" size="256" description="파일의 mime type"/>
          <Column id="fileCoursNm" type="STRING" size="256" description="서버파일저장위치"/>
          <Column id="fileObjKey" type="STRING" size="256"/>
          <Column id="fileEncryptYn" type="STRING" size="256"/>
          <Column id="fileSaveStg" type="STRING" size="256"/>
          <Column id="chk" type="STRING" size="256"/>
          <Column id="fileGubunCd" type="STRING" size="256"/>
          <Column id="useYn" type="STRING" size="256"/>
        </ColumnInfo>
