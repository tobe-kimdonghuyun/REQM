    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    원클릭교육비 > 질의응답
*  @FileName 	ews_oclsm02_m00.xfdl 
*  @Creator 	김지영
*  @CreateDate 	2023.01.25
*  @Desction    질의응답 목록
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.01.26            김지영                   최초 생성 
* 2023.03.28            류찬욱                   수정 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
//this.session = "";

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
 	this.smfInitForm(obj);
	
	//cbo 인덱스 세팅
	this.divSearch.form.cboSearchType.set_index(0);
	this.divSearch.form.cboSearchType00.set_index(0);
	
	// 파라메터 세팅
	this.pv_params = this.smfGetFormParams();
	
	if(!this.smfIsNull(this.pv_params.dsSearchParam)){
		e.id = "search";
		this.dsSearch.loadXML(this.pv_params.dsSearchParam);
	}
	
	if(!this.smfIsNull(this.pv_params.dsPagingParam)){
		e.id = "search";
		this.dsPageInfo.loadXML(this.pv_params.dsPagingParam);
		if(this.dsPageInfo.getConstColIndex("initIsUsePageInfo") < 0){
			this.dsPageInfo.addConstColumn("initIsUsePageInfo","Y");
		} else {
			this.dsPageInfo.setConstColumn("initIsUsePageInfo","Y");
		}
	}

 	this.fnSearch(this.divSearch.form.btnSearch, e);
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(obj, e)
{	
	
	if((e)&&(e.id == "onload" )){
		this.divPageSummary.form.cboPageSize.set_value(10);
	}else{
		this.divPageSummary.form.cboPageSize.set_value(this.dsPageInfo.getColumn(0, 'pageSize'));
	}
	
	var cnt = this.divPageSummary.form.fnGetInitPageSize();
	this.dsPageInfo.setColumn(0, 'pageSize', cnt);
	
 	// 서비스 객체 생성
	this.smfSearchService("listQna")
		// 페이징 처리
		.paginator(this.grd01, this.divPaginator, this.divPageSummary, this.dsPageInfo, obj, e)
		.run()	// 실행
		// 콜백
		.callback(function(callbackParams){		
			if(callbackParams.errors) return;
			
			// this.smfSetSessionValue("csrfKey", this.dsCsrfKey.getColumn(0, "csrfKey"));
			
			if (this.dsSearch.getColumn(0, 'searchType') == '4'){
				this.fnSetNoSearch();
			}
			
			this.divPageSummary.form.fnDisplayTotalText(this.dsPageInfo.getColumn(0, "totalCount"));
			
			//검색 결과가 없는 경우 페이징 숨김
			if(this.dsQnaList.getRowCount() == 0){	
				this.divPaginator.set_visible(false);
			}else{
				this.divPaginator.set_visible(true);
			}
			
			this.smfResetScroll(this);
			
		});	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
};


 /**
 * @description 콜백
 */
this.fnOclsmPop = function(e, sender){

	
	// 그외 다른 정보를 trace()로 표시(개발용)
	var sLog = "";
	var qnaId = "";
	var chkPawdYn = "";
	var qnaLvl = "";
	var newPswd = "";
	
	if(e.row)
	{
		for(var sKey in e.row)
		{
			var sValue = e.row[sKey];
			sLog += sKey + ":["+sValue+"]\n";
			
			//this.trace("sValue :"+sValue);
			//alert(sValue[0]);
			if(sKey == "qnaId")
				qnaId = sValue;
				
			if(sKey == "chkPawdYn")
				chkPawdYn = sValue;
				
			if(sKey == "qnaLvl")
				qnaLvl = sValue;
				
			if(sKey == "newPswd")
				newPswd = sValue;
		}
	}
	
	/* 웹취약성 조치 
	if( chkPawdYn == "N" ){
		this.smfAlert("패스워드가 틀립니다.");
		return false;
	}*/
	
	
	//this.trace("sLog :"+sLog);
	//this.trace("qnaId :"+qnaId);
	//var qnaId = objDs.getColumn(e.row, "qnaId");
	
	
	var params = { "qnaId": qnaId
				 , "qnaLvl": qnaLvl
				 , "dsSearchParam": this.dsSearch.saveXML()
				 , "dsPagingParam": this.dsPageInfo.saveXML()
				 , "lock": "N"
				 , "newPswd" : newPswd
				 , "csrfKey" : this.dsCsrfKey.getColumn(0, "csrfKey")
				 };
	
	this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm02_s00_01.xfdl", params);	// 상세화면 이동
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnSetNoSearch = function(){
	var keyword = this.dsSearch.getColumn(0, 'searchKeyword');
	this.dsQnaList.filter(this.smfIsNull(keyword) ? '' : "qnaId ==" + keyword);
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 조회 버튼 클릭
*/
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearch(obj, e);
};

/**
 * @description 그리드 셀클릭 (제목클릭)
*/
this.grd01_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{	
	var nRow = e.row;
	
	if(e.col == 0 || e.col == 1 || e.col == 2){
		//파라미터 변수 세팅 (조회 조건 값)
		var objDs = obj.getBindDataset();
		var qnaId = objDs.getColumn(e.row, "qnaId");
		var qnaLvl = objDs.getColumn(e.row, "qnaLvl");
		var lock = objDs.getColumn(e.row, "lock");
		
		//if(objDs.getColumn(e.row, "qnaLvl") != "0"){
			//this.smfAlert("답변의 답변은 허용하지 않습니다.");
		//	return false;
		//}

		if( nexacro.trim(this.smfGetSessionValue("mnrMngAuthCd")) == "" && objDs.getColumn(e.row, "lock") == "N" ){
		
			// 팝업을 동작에 필요한 파라메터 지정
			var popupParams = {
				callback: this.fnOclsmPop, // 콜백함수 지정
				sender: obj, // sender 지정

				// 팝업 전달 파라메터 지정
				params: {
					// 처리타입 지정
					procType: 'search',

					// 파라메터 전달 
					qnaId: qnaId,
					qnaLvl: qnaLvl
				},
			};
			
			
			// 모달팝업 실행
			this.smfDialog("_auto", "pa_ews_ocl_sm::ews_oclsm02_p01.xfdl", popupParams);
		
		} else {
		
			var params = { "qnaId": qnaId
				 , "qnaLvl": qnaLvl
				 , "lock": lock
				 , "dsSearchParam": this.dsSearch.saveXML()
				 , "dsPagingParam": this.dsPageInfo.saveXML()
				 , "csrfKey" : this.dsCsrfKey.getColumn(0, "csrfKey")
				 };
	
			this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm02_s00_01.xfdl", params);	// 상세화면 이동
		
		}
		
	}
};


/**
 * @description '등록' 버튼 클릭
*/
this.btnAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//if (session == null)	// 세션이 없으면 (관리자가 아니면)
	//{
		var params = { "sqlAction": this.dsSearch.setColumn(0, "sqlAction", "Q")	// 일반사용자 일 때
					  , "dsSearchParam": this.dsSearch.saveXML()
					  , "qnaId" : ""
					  , "csrfKey" : this.dsCsrfKey.getColumn(0, "csrfKey")
		};
	//}
	
	this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm02_s00.xfdl", params);		// 등록화면 이동
};

/**
 * @description 검색 시
*/
this.divSearch_edtSearchKeyword_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode == 13){
		this.dsSearch.setColumn(0, "searchKeyword", this.divSearch.form.edtSearchKeyword.value);
		this.divSearch.form.btnSearch.click();
	}
};
this.divSearch_cboSearchType_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	
};
]]></Script>
    <Objects>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="searchKeyword" type="STRING" size="256"/>
          <Column id="searchType" type="STRING" size="256"/>
          <Column id="searchCondition" type="STRING" size="256"/>
          <Column id="sqlAction" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256"/>
          <Column id="outDatasets" type="STRING" size="256"/>
          <Column id="asynctp" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="url">/ews_ocl_sm02_001.do</Col>
            <Col id="id">listQna</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsPageInfo=dsPageInfo</Col>
            <Col id="outDatasets">dsQnaList=dsQnaList dsPageInfo=dsPageInfo dsCsrfKey=dsCsrfKey</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsQnaList" useclientlayout="true">
        <ColumnInfo>
          <Column id="rn" type="STRING" size="256"/>
          <Column id="qnaId" type="STRING" size="256" description="질의응답Id"/>
          <Column id="treeItemYn" type="STRING" size="256"/>
          <Column id="qnaTitlNm" type="STRING" size="256" description="공지사항제목명"/>
          <Column id="lock" type="STRING" size="256"/>
          <Column id="qnaScCd" type="STRING" size="256" description="질의응답 구분코드"/>
          <Column id="atchFileId" type="STRING" size="256" description="첨부파일Id"/>
          <Column id="regDt" type="STRING" size="256" description="등록일시"/>
          <Column id="qnaInqCnt" type="STRING" size="256" description="공지사항조회수"/>
          <Column id="rgtrId" type="STRING" size="256" description="등록자Id"/>
          <Column id="mdfrId" type="STRING" size="256" description="수정자Id"/>
          <Column id="mdfcnDt" type="STRING" size="256" description="수정일시"/>
          <Column id="rgtrIpAddr" type="STRING" size="256" description="등록자IP주소"/>
          <Column id="ntcYn" type="STRING" size="256" description="공지여부"/>
          <Column id="qnaPrgeScCd" type="STRING" size="256" description="QA담당자구분코드"/>
          <Column id="ntcPstYn" type="STRING" size="256" description="공지게시여부"/>
          <Column id="qnaRgtrNm" type="STRING" size="256" description="QA등록자명"/>
          <Column id="upQnaId" type="STRING" size="256" description="상위Qaid"/>
          <Column id="qnaLvl" type="STRING" size="256" description="QA레벨"/>
          <Column id="qnaPhseValue" type="STRING" size="256" description="QA단계값"/>
          <Column id="htmlYn" type="STRING" size="256" description="html여부"/>
          <Column id="qnaKwNm" type="STRING" size="256" description="QA키워드명"/>
          <Column id="qnaScCodeNm" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSearchCbo">
        <ColumnInfo>
          <Column id="codeColumn" type="STRING" size="256"/>
          <Column id="dataColumn" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="dataColumn">제목+내용</Col>
            <Col id="codeColumn">0</Col>
          </Row>
          <Row>
            <Col id="dataColumn">제목</Col>
            <Col id="codeColumn">1</Col>
          </Row>
          <Row>
            <Col id="dataColumn">내용</Col>
            <Col id="codeColumn">2</Col>
          </Row>
