        <Grid id="grd01" taborder="4" left="0" top="376" height="439" autofittype="col" right="0" binddataset="dsDataList" initvalueid="ivGrdAccessibilityOn" selecttype="cell" oncellclick="grd01_oncellclick" accessibilitylabel="자료실 목록" readonly="true">
