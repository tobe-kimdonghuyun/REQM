              <Combo id="cboSearchType" taborder="2" left="174" width="105" height="30" innerdataset="dsSearchCbo" codecolumn="codeColumn" datacolumn="dataColumn" index="-1" text="" readonly="false" top="20" value="0" initvalueid="ivCmbNormal" accessibilitylabel="제목+내용 "/>
              <Edit id="edtSearchKeyword" taborder="3" left="287" top="20" width="503" height="30" initvalueid="ivEdtNormal" onkeydown="divSearch_edtSearchKeyword_onkeydown" displaynulltext="검색어를 입력해 주세요." accessibilitylabel="검색어를 입력해 주세요"/>
              <Button id="btnSearch" taborder="4" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="20" onclick="divSearch_btnSearch_onclick" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="조회"/>
