                <Cell col="3" cssclass="imptYn==&quot;Y&quot; ? &quot;cell_bgGray&quot;:&quot;&quot;" text="expr:(atchFileId != undefined &amp;&amp; atchFileId != &quot;&quot;) ? &quot;url('theme://images/grd_WF_fileup.png')&quot;:&quot;&quot;" displaytype="imagecontrol" accessibilitylabel="expr:(atchFileId != undefined &amp;&amp; atchFileId != &quot;&quot;) ? &quot;있음&quot;:&quot;없음&quot;" edittype="normal"/>
                <Cell col="4" displaytype="date" text="bind:regDt" calendardateformat="yyyy.MM.dd " calendareditformat="yyyy.MM.dd" edittype="normal"/>
                <Cell col="5" text="bind:dataInqCnt" displaytype="text" edittype="normal"/>
              </Band>
