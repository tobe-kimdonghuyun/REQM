    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    원클릭교육비 > 자주묻는 질문 > 자주묻는 질문 상세
*  @FileName 	ews_oclsm01_s00_01.xfdl 
*  @Creator 	류찬욱
*  @CreateDate 	2023.03.28
*  @Desction    자주묻는 질문 상세보기 / 삭제
******************* 소스 수정 이력 *******************************************
*  date          		Modifier                Description
********************************************************************************
* 2023.03.28            류찬욱                   최초 생성 
********************************************************************************
*/
 
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.faqId = "";	// 게시판ID
this.dsSearchParam;
this.dataset;
this.dsPagingParam;
 
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	//파라미터 세팅
	this.pv_params = this.smfGetFormParams();
	
	if(nexacro.trim(this.smfGetSessionValue("mnrMngAuthCd")) == ""){
		this.btnDel.set_visible(false);
		this.btnModi.set_visible(false);
	}else{
		this.btnDel.set_visible(true);
		this.btnModi.set_visible(true);
	}
	
	if(!this.smfIsNull(this.pv_params)){	// param 데이터가 있으면
		this.faqId = this.pv_params.faqId;
		this.dsSearchParam = this.pv_params.dsSearchParam;
		this.dsPagingParam = this.pv_params.dsPagingParam;
		
		//=======================================
		// 업로드관련 초기설정을 한다.
		//=======================================
		// 업로드시 저장위치등을 판별할 정보 세팅(대문자 : 시스템코드(2)+"."+서브시스템코드(3)+"."+대분류코드(3))
		this.div00.form.divFileDownload.UPLOAD_CreateComplete = this.fnEventUploadCreateComplete;  // 필요한 경우만 세팅
		this.div00.form.divFileDownload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)
		//this.fnSearch(this.faqId);
	}
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnEventUploadCreateComplete = function()
{
	this.fnSearch(this.faqId);
}


this.fnSearch = function(faqId)
{
	this.dsSearch.setColumn(0, "faqId", faqId);
	
	// 서비스 객체 생성
	this.smfSearchService("selectOneFaq")
	.run()	// 실행
	// 콜백
	.callback(function(callbackParams){		
		if(callbackParams.errors) return;
		
		if( this.dsFaqDtl.getColumn(0, "faqScCd") == "1" ){
			this.div00.form.edt00_01.set_value("신청");
		} else if( this.dsFaqDtl.getColumn(0, "faqScCd") == "2" ){
			this.div00.form.edt00_01.set_value("대상자 선정 및 지원");
		} else if( this.dsFaqDtl.getColumn(0, "faqScCd") == "3" ){
			this.div00.form.edt00_01.set_value("이의신청");
		} else if( this.dsFaqDtl.getColumn(0, "faqScCd") == "4" ){
			this.div00.form.edt00_01.set_value("학교·교육청 담당자를 위한 질문과 답변");
		} else if( this.dsFaqDtl.getColumn(0, "faqScCd") == "5" ){
			this.div00.form.edt00_01.set_value("소득·재산 조사");
		}
		
		// 자주묻는 질문 내용 세팅
		this.div00.form.txt00.set_value(this.dsFaqDtl.getColumn(0, "faqCn"));

		// 첨부파일 셋팅 코드 추가
		var sFileRefrnId = this.dsFaqDtl.getColumn(0, "atchFileId");

		// 첨부파일 셋팅(사용자화면)
		if(!this.smfIsNull(sFileRefrnId)){
			this.fnGetFileInfo(sFileRefrnId);
		} else {
			this.div00.form.divFileDownload.form.fnResetUpload();
		}
		
		// 데이터 세팅
		if(this.dsFaqDtl.getColumn(0, "nextFaqTitlNm") == null){
			this.div00_00.form.edtNextTitl.set_value("다음 글이 없습니다.");
			this.div00_00.form.btnNextNtc.set_enable(false);
		}else{
			this.div00_00.form.btnNextNtc.set_enable(true);
		}
		if(this.dsFaqDtl.getColumn(0, "preFaqTitlNm") == null){
			this.div00_00.form.edtPreTitl.set_value("이전 글이 없습니다.");
			this.div00_00.form.btnPreNtc.set_enable(false);
		}else{
			this.div00_00.form.btnPreNtc.set_enable(true);	
		}

		this.dsFaqDtl.setColumn(0, "faqTitlNm2", this.dsFaqDtl.getColumn(0, "faqTitlNm"));
		this.dsFaqDtl.setColumn(0, "faqTitlNm", this.smfDispLongText(this.div00.form.edt00, this.dsFaqDtl.getColumn(0, "faqTitlNm")));
		this.dsFaqDtl.setColumn(0, "nextFaqTitlNm", this.smfDispLongText(this.div00_00.form.edtNextTitl, this.dsFaqDtl.getColumn(0, "nextFaqTitlNm")));
		this.dsFaqDtl.setColumn(0, "faqTitlNm2", this.smfDispLongText(this.div00_00.form.edtTitl, this.dsFaqDtl.getColumn(0, "faqTitlNm2")));
		this.dsFaqDtl.setColumn(0, "preFaqTitlNm", this.smfDispLongText(this.div00_00.form.edtPreTitl, this.dsFaqDtl.getColumn(0, "preFaqTitlNm")));
		
		this.smfResetScroll(this);
		
	});	
}

this.fnDel = function(pafrBbsId)
{
	if(nexacro.trim(this.smfGetSessionValue("mnrMngAuthCd")) == ""){ // 관리자가 아닐 경우
		return;
	}
	
	this.dsSearch.getColumn(0, "faqId");
	
	// 서비스 객체 생성
	this.smfDeleteService("deleteFaq")
		.run()
		.callback(function(callbackParams){
			this.smfAlert(this.smfAfterServiceMessage(), this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm01_m00.xfdl"));
		})
};


/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

this.fnEventDownloadComplete = function(obj,paramObj)
{
	trace("========== fnEventDownloadComplete");
}

this.fnGetFileInfo = function (sFileRefrnId)
{
	// 업로드 초기화
	this.transaction("fn_filesearch"
		,"baseUrl::/cm_cmc_file_upload_001.do"
		,""
		,"dsOutFileinfo=atchFileinfo" 
		,"fileRefrnId='"+sFileRefrnId+"'"
		,""//this.btnUpload_FileSearch_callback
		,false // 동기
	);

	for (var i = 0; i < this.dsOutFileinfo.rowcount; i++) {
		var handlerCode       = "PA.EWS.OCL";
		var fileSn = this.dsOutFileinfo.getColumn(i,"fileRefrnId");
		var fileId = this.dsOutFileinfo.getColumn(i,"fileId");
		var fileSize = this.dsOutFileinfo.getColumn(i,"atchFileMg");
		var backendFilename = this.dsOutFileinfo.getColumn(i,"atchFileGuid");
		var frontendFilename = this.dsOutFileinfo.getColumn(i,"atchFileNm");
		this.div00.form.divFileDownload.form.fnAddUploadedFile(handlerCode, fileSn, fileSize, backendFilename, frontendFilename , fileId);
	}
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 목록 버튼 클릭
*/
this.btnNtcList_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var params = { "dsSearchParam": this.dsSearchParam ,
				   "dsPagingParam":this.dsPagingParam
				 };
	this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm01_m00.xfdl", params);	// 목록화면 이동
};


this.btnModi_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(nexacro.trim(this.smfGetSessionValue("mnrMngAuthCd")) == ""){ // 관리자가 아닐 경우
		return;
	}
	
	//파라미터 변수 세팅 (조회 조건 값)
	var faqId = this.dsFaqDtl.getColumn(0, "faqId");	// 자주묻는 질문ID
	var params = { "faqId": faqId
				 , "dsSearchParam": this.dsSearchParam
				 , dataset : this.dsFaqDtl.saveXML()
				 , "dsPagingParam": this.dsPagingParam
				 };

	this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm01_s00_02.xfdl", params);	// 상세화면 이동
};

/**
 * @description 삭제 버튼 클릭
*/
this.btnDel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(nexacro.trim(this.smfGetSessionValue("mnrMngAuthCd")) == ""){ // 관리자가 아닐 경우
		return;
	}
	
	for(var i = 0; i< this.dsOutFileinfo.getRowCount(); i++){
		this.dsOutFileinfo.setColumn(i, 'useYn', 'N');
	}
	this.fnDel();
};





/**
 * @description 다음글 버튼 클릭
*/
this.btnNextNtc = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(!this.smfIsNull(this.dsFaqDtl.getColumn(0, "nextFaqId"))){
		this.fnSearch(this.dsFaqDtl.getColumn(0, "nextFaqId"));
	}
};

/**
 * @description 이전글 버튼 클릭
*/
this.btnPreNtc = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(!this.smfIsNull(this.dsFaqDtl.getColumn(0, "preFaqId"))){
		this.fnSearch(this.dsFaqDtl.getColumn(0, "preFaqId"));
	}
};

this.btnDeleteAll_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divFileDownload.form.fnDownloadAll();
};
]]></Script>
