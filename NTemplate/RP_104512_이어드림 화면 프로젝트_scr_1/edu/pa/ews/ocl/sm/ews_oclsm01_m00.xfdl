        <Div id="divPaginator" taborder="5" left="0" top="836" height="30" right="0" url="comm::comp_paginator.xfdl" dsPage="dsPage" pageViewSize="100" initvalueid="ivDivAccessibilityOff" tabstop="true" text=""/>
        <Button id="btnAdd" taborder="6" text="등록" top="895" height="40" width="120" cssclass="btn_WF_Action" right="0" onclick="btnAdd_onclick" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="등록"/>
      </Layout>
      <Layout name="Layout0" width="640" height="1950" mobileorientation="landscape" type="default" screenid="mobile,tablet">
        <Div id="divTitle" height="65" left="0" top="340" right="0" taborder="0"/>
        <Div id="divSearch" left="20" top="445" right="20" formscrolltype="none" height="320" taborder="1" cssclass="div_WF_Search"/>
        <Button id="btnAdd" top="825" width="108" height="60" right="-138" cssclass="btn_WF_Crud" text="등록" taborder="3" visible="false"/>
        <Grid id="grd01" left="20" top="885" right="20" cssclass="grd_WF_Mobile2" formatid="format00" taborder="4" autofittype="col" height="858" autosizingtype="row" extendsizetype="row" scrollbarsize="1"/>
        <Div id="divPageSummary" left="20" top="825" width="331" height="40" taborder="2"/>
        <Div id="divPaginator" left="20" top="1803" right="20" taborder="5" height="80"/>
        <Div id="div02_00" height="250" left="20" top="40" right="20"/>
