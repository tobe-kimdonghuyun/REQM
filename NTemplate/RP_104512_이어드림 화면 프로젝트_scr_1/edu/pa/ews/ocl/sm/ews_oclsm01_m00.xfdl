              <Combo id="cboSearchType00" taborder="1" left="60" width="105" height="30" innerdataset="dsCbo2" codecolumn="codeColumn" datacolumn="dataColumn" index="0" text="전체" readonly="false" top="20" value="0" initvalueid="ivCmbNormal" accessibilitylabel="전체"/>
              <Combo id="cboSearchType" taborder="2" left="174" width="105" height="30" innerdataset="dsSearchCbo" codecolumn="codeColumn" datacolumn="dataColumn" index="0" text="제목+내용" readonly="false" top="20" value="0" initvalueid="ivCmbNormal" accessibilitylabel="제목+내용"/>
              <Edit id="edtSearchKeyword" taborder="3" left="287" top="20" width="503" height="30" initvalueid="ivEdtNormal" onkeydown="edtSearchKeyword" displaynulltext="검색어를 입력해 주세요." accessibilitylabel="검색어를 입력해 주세요"/>
              <Button id="btnSearch" taborder="4" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="20" onclick="divSearch_btnSearch_onclick" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="조회"/>
            </Layout>
            <Layout name="Layout0">
