/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 목록 버튼 클릭
*/
this.btnNtcList_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var params = { "dsSearchParam": this.dsSearchParam ,
				   "dsPagingParam":this.dsPagingParam
				 };
	this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm00_m00.xfdl", params);	// 목록화면 이동
};


this.btnModi_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(nexacro.trim(this.smfGetSessionValue("mnrMngAuthCd")) == ""){ // 관리자가 아닐 경우
		return;
	}
	
	//파라미터 변수 세팅 (조회 조건 값)
	var ntcMteId = this.dsNtcDtl.getColumn(0, "ntcMteId");	// 공지사항ID
	var params = { "pafrBbsId": ntcMteId
				 , "dsSearchParam": this.dsSearchParam
				 , dataset : this.dsNtcDtl.saveXML()
				 , "dsPagingParam": this.dsPagingParam
				 , "csrfKey" : this.pv_params.csrfKey
				 };
	
	this.smfSetWorkPage("pa_ews_ocl_sm::ews_oclsm00_s00_02.xfdl", params);	// 상세화면 이동
};

/**
 * @description 삭제 버튼 클릭
*/
this.btnDel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(nexacro.trim(this.smfGetSessionValue("mnrMngAuthCd")) == ""){ // 관리자가 아닐 경우
		return;
	}
	
	for(var i = 0; i< this.dsOutFileinfo.getRowCount(); i++){
		this.dsOutFileinfo.setColumn(i, 'useYn', 'N');
	}
	this.fnDel();
};



/**
 * @description 다음글 버튼 클릭
*/
this.btnNextNtc = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(!this.smfIsNull(this.dsNtcDtl.getColumn(0, "nextNtcMteId"))){
		this.fnSearch(this.dsNtcDtl.getColumn(0, "nextNtcMteId"));
	}
};

/**
 * @description 이전글 버튼 클릭
*/
this.btnPreNtc = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(!this.smfIsNull(this.dsNtcDtl.getColumn(0, "preNtcMteId"))){
		this.fnSearch(this.dsNtcDtl.getColumn(0, "preNtcMteId"));
	}
};

this.btnDeleteAll_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divFileDownload.form.fnDownloadAll();
};
