    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육급여·교육비지원 수혜현황 조회 간편인증 로그인 화면
*  @FileName 	ews_oclsu02_p01.xfdl 
*  @Creator 	류찬욱
*  @CreateDate 	2023.04.07 
*  @Desction    교육급여·교육비지원 수혜현황 조회 간편인증 로그인 화면
******************* 소스 수정 이력 *******************************************
*  date          		Modifier                Description
********************************************************************************
* 2023.04.07            류찬욱                   최초 생성 
********************************************************************************
*/
  
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.linkNo;	// link넘버

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	
	//파라미터 세팅
	this.pv_params = this.smfGetPopupParams();

	if(!this.smfIsNull(this.pv_params)){	// param 데이터가 있으면
		this.linkNo = this.pv_params.linkNo;
		
		// onload시 이미지 텍스트 내용 세팅
		if(this.linkNo == '600'){
			this.imgTitle.set_text("수혜현황 조회 간편인증");
		}
	}
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 팝업 CALLBACK
 */
this.fnPopupCallback = function(e, sender){
	trace("====> fnPopupCallback");
};


/**
 * 간편인증 CALLBACK
 */
this.fnLoginCallback = function(e, sender){
	//trace("====> fnLoginCallback");
	this.dsSearch.setColumn(0, "jwt", e.data);
	this.fnSearch();
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

this.fnSearch = function(obj, e)
{	
 	// 서비스 객체 생성
	this.smfSearchService("listToken")
		.run()	// 실행
		// 콜백
		.callback(function(callbackParams){		
			if(callbackParams.errors) return;
			
			//trace(this.dsResult.saveXML());
			
			var popupParams = {
				sender: obj
				, callback: this.fnPopupCallback
				, params: {
					procType: 'search',
					linkNo: this.linkNo,
					cddcOrgCd: this.pv_params.cddcOrgCd,
					cddcOrgCdNm: this.pv_params.cddcOrgCdNm,
					parentName: this.dsResult.getColumn(0, "name"),
					parentBirth: this.dsResult.getColumn(0, "birthday")
					
				},
			};
			
			var sLgnTypCd = "LG005";  // 로그인 유형코드
			this.smfSendLoginLog(this, sLgnTypCd);
			
			this.smfDialog("_auto", "pa_ews_ocl_su::ews_oclsu02_p02.xfdl", popupParams);	// 학생조회 화면 이동
			
		});	
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 
 /************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 로그인 버튼 클릭
 */
this.btnLogin = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	var objParam = {objForm:this, popupcallback :this.fnLoginCallback , openType: "ssn", actionType: "instl" };
	this.smfExecSimpleAuth(objParam);
	
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="div01.form.div00.form.rdo01" propid="value" datasetid="dsPopup" columnid="crtDt"/>
    </Bind>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256"/>
          <Column id="outDatasets" type="STRING" size="256"/>
          <Column id="asynctp" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listToken</Col>
            <Col id="url">/ews_ocl_su_token.do</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResult=dsResult</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="jwt" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsResult" useclientlayout="true">
        <ColumnInfo>
          <Column id="name" type="STRING" size="256"/>
          <Column id="birthday" type="STRING" size="256"/>
          <Column id="ssn1" type="STRING" size="256"/>
          <Column id="ssn2" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
  </Form>
