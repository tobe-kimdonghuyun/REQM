/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(obj, e)
{	
	this.dsSearch.copyRow(0, this.dsSearchTest, 0);
 	// 서비스 객체 생성
	this.smfSearchService("listSendApiFile")
		// 데이터 존재 필수
		.requireExistsData(this.dsSearchTest)
		.run()	// 실행
		// 콜백
		.callback(function(callbackParams){		
			if(callbackParams.errors) {
				if(callbackParams.reason == -99){
					this.smfAlert(callbackParams.message);
				}
				return;
			}
						
			//if (this.linkNo == '600')
			//if (this.dsResult.getColumn(0, "result") == "SUCCESS")
			//{
			//	this.alert(this.dsResult.getColumn(0, "appErrorCode") + ":" + this.dsResult.getColumn(0, "appErrorMsg"));
			//}
			
			if (this.dsResult.getColumn(0, "appErrorCode") == "SUCCESS") {
				this.smfAlert("신청이 완료되었습니다.\n해당 사업과 관련된 질의는 교육청, 학교에 문의하여 주시기 바랍니다.\n감사합니다.");
			}
			else {
				// this.alert(this.dsResult.getColumn(0, "appErrorCode") + ":" + this.dsResult.getColumn(0, "appErrorMsg"));
				if(this.dsResult.getColumn(0, "appErrorMsg") == "CM-CMC-0005") {
					this.smfAlert("제주특별자치도교육청의 경우, 초등학교/중학교/고등학교만 신청가능합니다.\n그 외 시도는 현재 신청하실 수 없습니다.");
				}
				else {
					this.smfAlert(this.dsResult.getColumn(0, "appErrorCode") + ":" + this.dsResult.getColumn(0, "appErrorMsg"));
				}
			}
			
			this.btn01.click();
			
		});	
};
 
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var procType = "none";
	
	var popupParams = {
		callback : this.fnPopupCallback, // 콜백함수 지정
		sender : obj, // sender 지정
		// 팝업 전달 파라메터 지정
		params : {
			// 처리타입 지정
			procType	: procType
		},
	};
	
	this.smfDialog("_auto", "commpop::commpop_rdn_zip.xfdl", popupParams);
};


this.btnUpload2_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objDiv = obj._divObj;
	objDiv.form.fnFileUpload();
	//this.div02.form.divFileUpload2.form.fnFileUpload();
};


this.div00_cbo01_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	var str = "";
	var cnt = 0;
	
	for(var i=0; i<this.dsEv002List.rowcount; i++){
		if( obj.value == this.dsEv002List.getColumn(i, "sprtBizCd") )
		{
			if( str == "" )
				str = str + this.dsEv002List.getColumn(i, "sprtBizItmCd");
			else
				str = str + "," + this.dsEv002List.getColumn(i, "sprtBizItmCd");
		}
	}
	
	this.dsSearchTest.setColumn(0, "sprtBizCd", obj.value);
	this.dsSearchTest.setColumn(0, "sprtBizItmCd", str);
	
	this.dsEv003Filter.deleteAll();
	this.dsOutEditInfo.deleteAll();
	
	for(var i=0; i<this.dsEv003List.rowcount; i++){
		
		if(obj.value == this.dsEv003List.getColumn(i, "sprtBizCd"))
		{
			this.dsEv003Filter.addRow();
			this.dsEv003Filter.copyRow(cnt, this.dsEv003List, i);
			cnt++;
		}
	}
	
	
	this.fnClearDiv();
	this.fnCreateDiv();
	
};
 /************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 'X' 버튼 클릭
 */
this.div01_btn01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.opener.opener.close();
	this.opener.close();
	this.close(false);
};


// KUpload를 생성시 지정할 property값을 지정
this.fnSetRaonProp = function()
{
	//  Property의 자세한 설명은 
	//  \12 나이스개발센터\17. 도입SW\01. 나이스클라우드\분리-06.파일 업로드 관리(RAON K Upload 2018)\raonkupload\sdk\index.html 참조 

	//var objNewBtnText = '{"btn_remove" : "파일제거1", "btn_remove_All" : "전체파일제거1","btn_add":"FileOpen"}';

	// 설정할 property
	var objAddRaonProps = {
							   AllowedZeroFileSize   : "1"        // 0byte 파일의 업로드를 허용 할지 설정합니다.(기본값은 "0" 허용안함이고, "1"로 설정시 허용입니다.)
							//,   ExtensionAllowOrLimit : "0"        // 업로드 할 파일 확장자를 허용 또는 제한 설정("0":지정된 확장자를 제한(선택 금지) , "1":지정된 확장자만 허용(선택가능))
							//,   ExtensionArr          : "txt,gif"  // 제한 및 허용할 확장자명을 ",(콤마)"로 구분하여 설정
							//, LanguageExtendObject : objNewBtnText
	                      };

	return objAddRaonProps;
}


/**
 * 조회 버튼 클릭
 */
this.btnSearch = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 필수 값 체크
	if(this.div00.form.edtPhon.value == null || this.div00.form.edtPhon.value == "" || this.div00.form.edtPhon.value == "undefined"){
		this.smfAlert("신청인의 전화번호를 입력하세요.");
		return false;
	}
	
	if(this.div00.form.cbo01.value == null || this.div00.form.cbo01.value == "" || this.div00.form.cbo01.value == "undefined"){
		this.smfAlert("학생과의 관계를 선택하세요.");
		return false;
	}

	if(this.div01.form.edtGrd.value == null || this.div01.form.edtGrd.value == "" || this.div01.form.edtGrd.value == "undefined"){
		this.smfAlert("학생의 학년 정보를 입력하세요.");
		return false;
	}
	
	if(this.div01.form.edtClsNm.value == null || this.div01.form.edtClsNm.value == "" || this.div01.form.edtClsNm.value == "undefined"){
		this.smfAlert("학생의 반 정보를 입력하세요.");
		return false;
	}

	if(this.div01.form.edtClsNo.value == null || this.div01.form.edtClsNo.value == "" || this.div01.form.edtClsNo.value == "undefined"){
		this.smfAlert("학생의 번호 정보를 입력하세요.");
		return false;
	}
	
	//특수학교일 경우 학교급 선택
	if(this.pv_params.shlKndScCd == '05'){
		if(this.div01.form.cboShlCrseScCd.value == null || this.div01.form.cboShlCrseScCd.value == "" || this.div01.form.cboShlCrseScCd.value == "undefined"){
			this.smfAlert("학교급을 선택하세요.");
			return false;
		}
	}
	
	// 년도, 월
	var objDate = new Date();
	var year = objDate.getFullYear();	// 현재 년도
	/* 학년도로 수정(2025.02.26) */
	var month = objDate.getMonth();
	if(month == '0' || month == '1') {
		year = year - 1;
	}
	this.dsSearchTest.setColumn(0, "ayr", year);
	
	var objDiv = this.div02.form;
	var sType;
	var etcCn;
	//var cnt = 0;
	var cnt;
	var uploadCnt = 0;
	var filterCnt = 0;
	var etcCnt = 0;
	var rowCnt = 0;
	
	if(this.dsOutEditInfo.rowcount > 0){
		this.dsOutEditInfo.deleteAll();
		
		for(var i = this.dsOutFileinfo.rowcount - 1; i >= 0 ; i--){
		
			sType = this.dsOutFileinfo.getColumn(i, "reqsInptMthCd");
			
			if(sType == "10"){
				this.dsOutFileinfo.deleteRow(i);
			}
		}
	}
	
	
	cnt = this.dsOutFileinfo.rowcount;
	
	for(var i=0; i<this.dsEv003Filter.rowcount; i++){
	
		sType = this.dsEv003Filter.getColumn(i, "reqsInptMthCd");
		
		if(sType == "10"){
			//if(this.dsEv003Filter.getColumn(i, "reqsItmCd"))
			this.dsOutEditInfo.addRow();
			this.dsOutEditInfo.copyRow(cnt, this.dsEv003Filter, i);
			
			this.dsOutFileinfo.addRow();
			this.dsOutFileinfo.copyRow(cnt, this.dsEv003Filter, i);
			this.dsOutFileinfo.setColumn(cnt, "reqsInptMthCd", sType);
			this.dsOutFileinfo.setColumn(cnt, "etcCn", this.div02.form["sEdit" + i].value);
			cnt++;
		}
		
	}
	
	for(var i=0; i<this.dsOutFileinfo.rowcount; i++){
	
		sType = this.dsOutFileinfo.getColumn(i, "reqsInptMthCd");
		etcCn = this.dsOutFileinfo.getColumn(i, "etcCn");		
		
		if(sType == "10"){
			rowCnt++;
			if(etcCn == null || etcCn == "" || etcCn == "undefined"){
				etcCnt++;
				break;
			}
		} else if(sType == "20"){
			uploadCnt++;
		} else {
			this.smfAlert("파일업로드를 하지 않았습니다.");
			break;
		}
		
	}
	
	if(etcCnt > 0){
		// this.alert(rowCnt + "번째 추가 정보의 입력값을 입력하세요.");
		this.smfAlert(rowCnt + "번째 추가 정보의 입력값을 입력하세요.");
		return false;
	}
	
	for(var i=0; i<this.dsEv003Filter.rowcount; i++){
		
		sType = this.dsEv003Filter.getColumn(i, "reqsInptMthCd");
		
		if(sType == "20")
		{
			filterCnt++;
		}
	}
	
	/* 첨부파일 필수 체크 제외
	if( filterCnt != uploadCnt ){
		this.alert(uploadCnt + 	1 + "번째 파일업로드를 하지 않았습니다.");
		return false;
	}
	*/
	
	//trace("dsOutFileinfo=="+this.dsOutFileinfo.saveXML());
	//return false;
	this.fnSearch();
};

//특수학교 학교급
this.div01_cboShlCrseScCd_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
		
	this.dsSearchTest.setColumn(0, "shlCrseScCd", obj.value);
	
};
