          <Column id="schorCmpCmptnYn" type="STRING" size="256"/>
          <Column id="schorFlctnScCd" type="STRING" size="256" description="학적변동구분코드"/>
          <Column id="stuRrno" type="STRING" size="256" description="학생주민등록번호"/>
