        <Button id="btn01" taborder="10" top="10" width="36" height="36" cssclass="btn_WF_SurvPopClose" initvalueid="ivBtnAccessibilityButton" right="10" onclick="div01_btn01_onclick" accessibilitylabel="팝업닫기"/>
        <Static id="Static99_00_00_00_00_00_00_00_00" taborder="11" left="20" top="808" height="50" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta00" taborder="12" text="&lt;fc v='#f45151'&gt;&lt;fs v='10'&gt;※ 파일 추가 후 &lt;b v='true'&gt;&lt;u v='true&gt;파일업로드 버튼을 반드시 클릭&lt;/u&gt;&lt;/b&gt;하여 주시기 바랍니다.&lt;/fs&gt;&lt;/fc&gt;" left="189" top="583" width="480" height="22" cssclass="sta_WF_GTxt01" initvalueid="ivStcAccessibilityOn" usedecorate="true" textAlign="right" verticalAlign="bottom" accessibilitylabel="파일 추가 후 파일 업로드 버튼을 반드시 클릭항 주시기 바랍니다."/>
