 * @param : e
 * @param : sender
 */
this.fnPopupCallback = function(e, sender){
	this.div00.form.edtZipCd.set_value(e.zipCd);
	this.div00.form.edtRoadNmAddr.set_value(e.roadNmAddr);
	this.div00.form.edtRoadNmDtl.set_value(e.roadNmDtl);
}


/**
 * raonkupload가 화면을 생성된 이후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @return : N/A
 */
this.fnEventUploadCreateComplete = function(obj,paramObj)
{
};

/**
 * raonkupload가 파일을upload한 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @param : objResultDataset
 * @return : N/A
 */
this.fnEventUploadComplete = function(obj,paramObj,objResultDataset)
{
	// 업로드 성공 후, newfile에 있는 파일들을 webfile로 옮긴다.
	//var objDiv = obj._divObj;
	//objDiv.form.fnSetUploadCompleteState(obj,paramObj);
	//obj.parent.id
	var objDiv = obj.parent.parent;
	var sCode = objDiv.code;
	objDiv.form.fnSetUploadCompleteState(obj,paramObj);
	if(objResultDataset != null){
		//this.dsNtcDtl.setColumn(0, "atchFileId", objResultDataset.getColumn(0,"fileRefrnId"));
		for(var i = 0; i < objResultDataset.getRowCount(); i++){
			var row = this.dsOutFileinfo.addRow();
			this.dsOutFileinfo.copyRow(row, objResultDataset, i);
			this.dsOutFileinfo.setColumn(row, 'reqsItmCd', sCode);
			this.dsOutFileinfo.setColumn(row, "reqsInptMthCd", "20");
		}
	}
};

