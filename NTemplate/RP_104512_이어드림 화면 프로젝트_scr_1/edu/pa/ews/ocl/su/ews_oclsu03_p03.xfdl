    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    시도교육청별 지원사업신청
*  @FileName 	ews_oclsu03_p03.xfdl 
*  @Creator 	류찬욱
*  @CreateDate 	2023.05.07 
*  @Desction    시도교육청별 지원사업신청
******************* 소스 수정 이력 *******************************************
*  date          		Modifier                Description
********************************************************************************
* 2023.05.07            류찬욱                   최초 생성 
********************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.pv_params;
this.cddcOrgCd;
this.shlKndScCd;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitPopup(this);

	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	
	if(!this.smfIsNull(this.pv_params)){
	
		this.div00.form.edtName.set_value(this.pv_params.apsNm);
		this.div01.form.stuNm.set_value(this.pv_params.stuNm);
		this.div01.form.stuRrno.set_value(this.pv_params.stuRrno);
		this.div01.form.kornOrgNm.set_value(this.pv_params.kornOrgNm);
		
		this.dsResult.copyData(this.pv_params.dsResult);
		this.dsEv001List.copyData(this.pv_params.dsEv001List);
		this.dsEv002List.copyData(this.pv_params.dsEv002List);
		this.dsEv003List.copyData(this.pv_params.dsEv003List);
		
		this.cddcOrgCd = this.pv_params.cddcOrgCd;
		
		this.dsSearchTest.setColumn(0, "shlCd", this.pv_params.orgCd);
		this.dsSearchTest.setColumn(0, "shlNm", this.pv_params.kornOrgNm);
		this.dsSearchTest.setColumn(0, "stuNm", this.pv_params.stuNm);
		this.dsSearchTest.setColumn(0, "stuRrno", this.pv_params.stuRrno);
		this.dsSearchTest.setColumn(0, "invlInfoGthAgreYn", this.pv_params.invlInfoGthAgreYn);
		this.dsSearchTest.setColumn(0, "cddcCd", this.cddcOrgCd.substring(0,3));
		this.dsSearchTest.setColumn(0, "shlCrseScCd", this.pv_params.shlCrseScCd);
		
		this.div03.form.cbo01.set_index(0);
		
		// 공통코드의 코드구분
		this.smfCodeList("code", [this.dsApsFamRelCd])
			.run()
			.callback(function(callbackParams){
				if(callbackParams.errors) return;
				console.log(this.dsHnfTypCd.saveXML());
				console.log(this.dsEccHnfStsScCd.saveXML());
			});
	
		var str = "";
		var cnt = 0;
		
		for(var i=0; i<this.dsEv002List.rowcount; i++){
			if( this.div03.form.cbo01.value == this.dsEv002List.getColumn(i, "sprtBizCd") )
			{
				if( str == "" )
					str = str + this.dsEv002List.getColumn(i, "sprtBizItmCd");
				else
					str = str + "," + this.dsEv002List.getColumn(i, "sprtBizItmCd");
			}
		}
		
		this.dsSearchTest.setColumn(0, "sprtBizCd", this.div03.form.cbo01.value);
		this.dsSearchTest.setColumn(0, "sprtBizItmCd", str);
		
		for(var i=0; i<this.dsEv003List.rowcount; i++){
			if(this.div03.form.cbo01.value == this.dsEv003List.getColumn(i, "sprtBizCd"))
			{
				this.dsEv003Filter.addRow();
				this.dsEv003Filter.copyRow(cnt, this.dsEv003List, i);
				cnt++;
			}
		}
		
		//trace("this.dsEv003Filter:"+this.dsEv003Filter.saveXML());

		this.fnClearDiv();
		this.fnCreateDiv();
		
		//특수학교일 경우 학교급 선택
		if(this.pv_params.shlKndScCd == '05'){			
			this.div01.form.staShlCrseScCd.set_visible(true);
			this.div01.form.cboShlCrseScCd.set_visible(true);			
			
			this.div01.form.staShlCrseScCd.set_enable(true);
			this.div01.form.cboShlCrseScCd.set_enable(true);	
			
			this.div01.form.cboShlCrseScCd.index = 0;
		}
	}	

};


this.fnClearDiv = function()
{
	var objComps = this.div02.form.components;
	
	for(var i=objComps.length-1;i>=0;i--)
	{
		objComps[i].destroy();
		
		if(objComps[i] instanceof nexacro.Div)
			objComps[i].form.fnResetUpload();
	}
	

}

this.fnCreateDiv = function()
{
	var objParentDiv = this.div02.form;
	var sType = "";
	var nLeft = 0;
	var nTop = 0;
	var nWidth = 0;
	var nHeight = 0;
	var cnt = 0;
	
	//this.div02.set_height(3 + (this.dsEv003Filter.rowcount * 40));
	//this.smfResetScroll(this);
	
	for(var i=0; i<this.dsEv003Filter.rowcount; i++)
	{
		sType = this.dsEv003Filter.getColumn(i, "reqsInptMthCd");
		cnt = i * 40;
		if(sType=="20")
		{
			// title Static을 생성
			var sTitleStaticId = "staTitle" + i;
			var objtitleStatic = objParentDiv[sTitleStaticId];
			
			if(!objtitleStatic)
			{
				nLeft = 0;
				nTop = cnt;
				nWidth = 120;
				nHeight = 42;
				objtitleStatic = new Static();
				objtitleStatic.init(sTitleStaticId,nLeft,nTop,nWidth,nHeight, null, null);
				objParentDiv.addChild(sTitleStaticId,objtitleStatic);				
				objtitleStatic.show();
				
			}
			objtitleStatic.set_text("* " + this.dsEv003Filter.getColumn(i, "reqsItmNm"));
			
			if( i == 0 )
				objtitleStatic.set_cssclass("sta_WF_EssentialTop");
			else
				objtitleStatic.set_cssclass("sta_WF_Essential");
			
			
			objtitleStatic.set_initvalueid("ivStcAccessibilityOn");
			
			// 배경 Static을 생성
			var sbgStaticId = "staBg" + i;

			var objbgStatic = objParentDiv[sbgStaticId];
			
			if(!objbgStatic)
			{
				nLeft = 120;
				nTop = cnt;
				nWidth = 520;
				nHeight = 42;
				objbgStatic = new Static();
				objbgStatic.init(sbgStaticId,nLeft,nTop,nWidth,nHeight);
				objParentDiv.addChild(sbgStaticId,objbgStatic);
				
				objbgStatic.show();
				
			}
			objbgStatic.set_text("");
			
			if( i == 0 )
				objbgStatic.set_cssclass("sta_WF_Input02Top");
			else
				objbgStatic.set_cssclass("sta_WF_Input02");
			
			//objbgStatic.set_cssclass("sta_WF_Input02Top");
			objbgStatic.set_initvalueid("ivStcAccessibilityOff");
			// fileupload div를 생성
			var sFileUploadDivId = "divFileUpload" + i;
			var objFileUploadDiv = objParentDiv[sFileUploadDivId];
			
			if(!objFileUploadDiv)
			{
				nLeft = 124;
				nTop = 6 + cnt;
				nWidth = 395;
				nHeight = 30;
				objFileUploadDiv = new Div();
				objFileUploadDiv.init(sFileUploadDivId,nLeft,nTop,nWidth,nHeight);
				objParentDiv.addChild(sFileUploadDivId,objFileUploadDiv);
				
				objFileUploadDiv.show();
				
			}
			objFileUploadDiv.set_text("div02");
			//objFileUploadDiv.set_cssclass("주민등록등본");
			objFileUploadDiv.set_url("comm::comm_fileAdd2.xfdl");
			
			objFileUploadDiv.Mode="upload";
			objFileUploadDiv.uploadLocation="PA.EWS.OCL"; 
			objFileUploadDiv.code=this.dsEv003Filter.getColumn(i, "reqsItmCd"); 
			objFileUploadDiv.addProp="fnSetRaonProp"; 
			objFileUploadDiv.privInfoFiltYn="Y"; 
			objFileUploadDiv.fileEncryptYn="Y"; 
			objFileUploadDiv.fileSaveStg="SV";
			objFileUploadDiv.fileInfSaveYn="Y";
			objFileUploadDiv.form.fnSetEssential(true);
			objFileUploadDiv.set_initvalueid("ivEdtReadOnly");
			
			objFileUploadDiv.UPLOAD_CreateComplete = this.fnEventUploadCreateComplete;  // 필요한 경우만 세팅
			objFileUploadDiv.UPLOAD_UploadComplete = this.fnEventUploadComplete;        // 필요한 경우만 세팅(세팅권장)
			objFileUploadDiv.UPLOAD_OnError        = this.fnEventUploadError;           // 필요한 경우만 세팅(세팅권장)
			objFileUploadDiv.UPLOAD_AfterAddFile   = this.fnEventUploadAfterAddFile;     
			objFileUploadDiv.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)
			
			// 파일업로드 버튼을 생성
			var sFileUploadBtn = "btnFileUpload" + i;
			var objBtnUpload = objParentDiv[sFileUploadBtn];
			
			if(!objBtnUpload)
			{
				nLeft = 525;
				nTop = 5 + cnt;
				nWidth = 113;
				nHeight = 30;
				objBtnUpload = new Button();
				objBtnUpload.init(sFileUploadBtn,nLeft,nTop,nWidth,nHeight);
				objParentDiv.addChild(sFileUploadBtn,objBtnUpload);
				
				objBtnUpload.show();
				
			}
			
			objBtnUpload.set_text("파일업로드");
			objBtnUpload.set_cssclass("btn_WF_FileUpload");
			objBtnUpload.set_initvalueid("ivBtnAccessibilityButton");
			
			objBtnUpload._divObj = objFileUploadDiv;
			objBtnUpload.addEventHandler("onclick",this.btnUpload2_onclick,this);
		}
		else
		{
			// title Static을 생성
			var sTitleStaticId = "staTitle" + i;
			var objtitleStatic = objParentDiv[sTitleStaticId];
			
			if(!objtitleStatic)
			{
				nLeft = 0;
				nTop = cnt;
				nWidth = 120;
				nHeight = 42;
				objtitleStatic = new Static();
				objtitleStatic.init(sTitleStaticId,nLeft,nTop,nWidth,nHeight, null, null);
				objParentDiv.addChild(sTitleStaticId,objtitleStatic);				
				objtitleStatic.show();
				
			}
			objtitleStatic.set_text("* " + this.dsEv003Filter.getColumn(i, "reqsItmNm"));
			
			if( i == 0 )
				objtitleStatic.set_cssclass("sta_WF_EssentialTop");
			else
				objtitleStatic.set_cssclass("sta_WF_Essential");
				
			//objtitleStatic.set_cssclass("sta_WF_EssentialTop");
			objtitleStatic.set_initvalueid("ivStcAccessibilityOn");
			
			// 배경 Static을 생성
			var sbgStaticId = "staBg" + i;

			var objbgStatic = objParentDiv[sbgStaticId];
			
			if(!objbgStatic)
			{
				nLeft = 120;
				nTop = cnt;
				nWidth = 520;
				nHeight = 42;
				objbgStatic = new Static();
				objbgStatic.init(sbgStaticId,nLeft,nTop,nWidth,nHeight);
				objParentDiv.addChild(sbgStaticId,objbgStatic);
				
				objbgStatic.show();
				
			}
			objbgStatic.set_text("");
			
			if( i == 0 )
				objbgStatic.set_cssclass("sta_WF_Input02Top");
			else
				objbgStatic.set_cssclass("sta_WF_Input02");
				
			//objbgStatic.set_cssclass("sta_WF_Input02Top");
			objbgStatic.set_initvalueid("ivStcAccessibilityOff");
			
			
			
			// EDIT 생성
			var sEdit = "sEdit" + i;
			var objEdit = objParentDiv[sEdit];
			
			if(!objEdit)
			{
				nLeft = 125;
				nTop = 5 + cnt;
				nWidth = 515;
				nHeight = 30;
				objEdit = new Edit();
				objEdit.init(sEdit,nLeft,nTop,nWidth,nHeight);
				objParentDiv.addChild(sEdit,objEdit);
				
				objEdit.show();
				
			}
			
			objEdit.set_value("");
			objEdit.set_maxlength(100);
			objEdit.set_cssclass("essential");
			objEdit.set_initvalueid("ivEdtEssential");
		}
	}
	
	this.div02.form.resetScroll();

}

