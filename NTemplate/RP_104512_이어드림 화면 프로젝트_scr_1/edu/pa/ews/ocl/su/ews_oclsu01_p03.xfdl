    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육비 신청 대상여부 조회 > 대상여부 팝업
*  @FileName 	ews_oclsu01_p03.xfdl 
*  @Creator 	류찬욱
*  @CreateDate 	2023.04.07 
*  @Desction    교육비 신청 대상여부 조회
******************* 소스 수정 이력 *******************************************
*  date          		Modifier                Description
********************************************************************************
* 2023.04.07            류찬욱                   최초 생성 
********************************************************************************
*/
  
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.pv_params;
fv_years = '';	// 현재 년도
stuNames = '';	// 학생 이름

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitPopup(this);

	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	
	var objDate = new Date();
	var year = objDate.getFullYear();	// 현재 년도
	
	fv_years = year;
	fv_years_minus = year - 1;
	
	if(!this.smfIsNull(this.pv_params)){
		stuNames = this.pv_params.name;
		this.dsResult.copyData(this.pv_params.dsResult);
		
		if(this.dsResult.getColumn(0, "rltCd") == "0"){
			this.div01.form.div00.form.sta00.set_text(stuNames + " 학생은 \n <fc v='#397be0'>" + fv_years + "학년도 교육비 지원을 신청하셔야 합니다.</fc>");
			this.div01.form.div00.form.sta02.set_text("※ 시도 교육청 교육비 지원 기준에 근거한 <fc v='#397be0'>심사결과에 따라 교육비지원 여부 결정</fc>\n\n교육비 지원 신청을 희망하는 경우 <fc v='#397be0'>인터넷 또는 방문 신청</fc>바랍니다.");
		}else if(this.dsResult.getColumn(0, "rltCd") == "1"){
			//this.div01.form.div00.form.sta00.set_text(stuNames + " 의 학부모가 아니므로 확인이 불가능합니다.");
			this.div01.form.div00.form.sta00.set_text("교육비 지원 신청대상 여부 확인은\n<fc v='#397be0'>교육비 지원의 신청인만 가능</fc>합니다.");
			this.div01.form.div00.form.sta02.set_text("교육비 지원 <fc v='#397be0'>신청인 정보를 수정하실 경우, 교육비 지원 재신청 필요</fc>");
		}else if(this.dsResult.getColumn(0, "rltCd") == "2"){
			this.div01.form.div00.form.sta00.set_text(stuNames + " 학생은 \n <fc v='#397be0'>" + fv_years + "학년도 교육비 지원 신청 간주자입니다.</fc>");
			//this.div01.form.div00.form.sta02.set_text(fv_years_minus + "년도에 지원을 받지 않으신분은 해당 학교로 문의하시기 바랍니다.");
			this.div01.form.div00.form.sta02.set_text("※ 교육비지원 별도 신청을 하지 않아도 되나,\n<fc v='#397be0'>학생의 법적자격이나 소득 변동이 있을 경우 재신청</fc>하시기 바랍니다.\n\n※ 시도 교육청 교육비 지원 기준에 근거한 <fc v='#397be0'>심사결과에 따라 교육비지원 여부 결정</fc>\n\n교육비 지원 신청을 희망하는 경우 <fc v='#397be0'>인터넷 또는 방문 신청</fc>바랍니다.");
		}
		
	}
	// 신청 대상일 때 0
	//this.div01.form.div00.form.sta00.set_text(stuNames + "학생은 " + fv_years + "학년도 초중고 교육비 지원 사업을 신청해야 합니다.");

	// 대상자의 학부모가 아닐 때 1
	// {0}의 학부모가 아니므로 확인이 불가능합니다. 신청대상여부조회는 해당 학생의 학부모님만 가능합니다.
	//this.smfAlert('LI155', [stuNames + '의 학부모가 아니므로 확인이 불가능합니다. 신청대상여부조회는 해당 학생의 학부모님만 가능합니다.']);
	
	// 신청 대상이 아닐 때
	//this.div01.form.div00.form.sta00.set_text(stuNames + "학생은 " + fv_years + "학년도 초중고 교육비 지원 사업 대상자가 아닙니다.");	
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

 /************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 'X' 버튼 클릭
 */
this.div01_btn01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.opener.opener.close();
	this.opener.close();	
	this.close(false);
};
]]></Script>
  </Form>
</FDL>
