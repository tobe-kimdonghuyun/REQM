          <Column id="dddepNm" type="STRING" size="256"/>
          <Column id="gveRdmScCd" type="STRING" size="256"/>
          <Column id="gveRdmScNm" type="STRING" size="256"/>
          <Column id="sprtOcrnAmt" type="STRING" size="256"/>
          <Column id="rduYn" type="STRING" size="256"/>
          <Column id="crtYmd" type="STRING" size="256"/>
          <Column id="gveYmd" type="STRING" size="256"/>
          <Column id="shlDdlnYn" type="STRING" size="256"/>
          <Column id="ofcdcDdlnYn" type="STRING" size="256"/>
          <Column id="rmkMteCn" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsListGveHstr" useclientlayout="true">
        <ColumnInfo>
          <Column id="ayr" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="cddcCdNm" type="STRING" size="256"/>
          <Column id="shlNm" type="STRING" size="256"/>
          <Column id="grd" type="STRING" size="256"/>
          <Column id="sprtItmNm" type="STRING" size="256"/>
          <Column id="qtrScNm" type="STRING" size="256"/>
          <Column id="gveRdmScNm" type="STRING" size="256"/>
          <Column id="crtYmd" type="STRING" size="256"/>
          <Column id="frstCrtAmt" type="STRING" size="256"/>
          <Column id="dpcnRcbfAmt" type="STRING" size="256"/>
          <Column id="sprtOcrnAmt" type="STRING" size="256"/>
          <Column id="stlmPrcsStsNm" type="STRING" size="256"/>
          <Column id="gveYmd" type="STRING" size="256"/>
          <Column id="fnncInstNm" type="STRING" size="256"/>
