    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육급여·교육비지원 수혜현황확인
*  @FileName 	ews_oclsu02_p03.xfdl 
*  @Creator 	류찬욱
*  @CreateDate 	2023.04.07 
*  @Desction    교육급여·교육비지원 수혜현황확인 결과조회
******************* 소스 수정 이력 *******************************************
*  date          		Modifier                Description
********************************************************************************
* 2023.04.07            류찬욱                   최초 생성 
********************************************************************************
*/
  
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.pv_params;
fv_years = '';	// 현재 년도
stuNames = '';	// 학생 이름

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitPopup(this);

	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	var amt1 = 0;
	var amt2 = 0;
	var sprtAplyItmNm;
	var sprtItmNm;
	
	if(!this.smfIsNull(this.pv_params)){
		stuNames = this.pv_params.name;
		this.dsObjrStdnt.copyData(this.pv_params.dsObjrStdnt);
		this.dsListGveHstr.copyData(this.pv_params.dsListGveHstr);
		
		for( var i=0; i<this.dsObjrStdnt.rowcount; i++ ){
			//this.dsGrd.addRow();
			this.dsGrdView.addRow();
			//this.dsGrd.copyRow(i, this.dsObjrStdnt, i);
			this.dsGrdView.copyRow(i, this.dsObjrStdnt, i);
			this.dsGrdView.setColumn(i, "buissness", "교육비");
			
			amt1 = Number(amt1) + Number(this.dsObjrStdnt.getColumn(i, "sprtOcrnAmt"));
			
			if( this.dsObjrStdnt.getColumn(i, "sprtAplyItmNm") != "undefined" ){
				if( i == 0 )
					sprtAplyItmNm = this.dsObjrStdnt.getColumn(i, "sprtAplyItmNm");
				else
					sprtAplyItmNm += "," + this.dsObjrStdnt.getColumn(i, "sprtAplyItmNm");
			}
		}
		
		if( this.dsObjrStdnt.rowcount > 0 ){
			this.dsGrd.addRow();
			this.dsGrd.copyRow(0, this.dsObjrStdnt, 0);
			this.dsGrd.setColumn(0, "shlNm", "교육비");
			this.dsGrd.setColumn(0, "sprtAplyItmNm", sprtAplyItmNm);
			this.dsGrd.setColumn(0, "sprtOcrnAmt", amt1);
		}
		
		var cntJ = 0;
		
		for( var j=0; j<this.dsListGveHstr.rowcount; j++ ){
			if( Number(this.dsListGveHstr.getColumn(j, "sprtOcrnAmt")) > 0 ){
				this.dsGrdView.addRow();
				this.dsGrdView.copyRow(this.dsObjrStdnt.rowcount + cntJ, this.dsListGveHstr, j);
				this.dsGrdView.setColumn(this.dsObjrStdnt.rowcount + cntJ, "buissness", "교육급여");
				this.dsGrdView.setColumn(this.dsObjrStdnt.rowcount + cntJ, "sprtAplyItmNm", this.dsListGveHstr.getColumn(j, "sprtItmNm"));
				
				amt2 = Number(amt2) + Number(this.dsListGveHstr.getColumn(j, "sprtOcrnAmt"));
				
				cntJ++;
			}
				
			if( this.dsListGveHstr.getColumn(j, "sprtItmNm") != "undefined" ){
				if( j == 0 )
					sprtItmNm = this.dsListGveHstr.getColumn(j, "sprtItmNm");
				else
					sprtItmNm += "," + this.dsListGveHstr.getColumn(j, "sprtItmNm");
			}
		}
		
		if( this.dsListGveHstr.rowcount > 0 &&  Number(amt2) > 0 ){
			this.dsGrd.addRow();
			this.dsGrd.setColumn(1, "stuNm", this.dsGrd.getColumn(0, "stuNm"));
			this.dsGrd.setColumn(1, "shlNm", "교육급여");
			this.dsGrd.setColumn(1, "sprtAplyItmNm", sprtItmNm);
			this.dsGrd.setColumn(1, "sprtOcrnAmt", amt2);
		}
		
		//for( var k=this.dsGrdView.rowcount - 1; k > -1; k-- ){
		//	if( this.dsGrdView.getColumn(k, "sprtOcrnAmt") == 0 || this.dsGrdView.getColumn(k, "sprtOcrnAmt") == "undefined" )
		//		this.dsGrdView.deleteRow(k);
		//}
		
		this.dsGrdView.set_filterstr("sprtOcrnAmt!='0'");
			
	}
	
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

 /************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 'X' 버튼 클릭
 */
this.div01_btn01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.opener.opener.close();
	this.opener.close();
	this.close(false);
};

this.imgTitle_onclick = function(obj:nexacro.ImageViewer,e:nexacro.ClickEventInfo)
{
	
};
]]></Script>
