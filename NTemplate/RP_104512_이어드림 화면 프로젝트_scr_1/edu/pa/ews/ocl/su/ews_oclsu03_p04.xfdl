    <Script type="xscript5.1"><![CDATA[// 화면 로딩 
this.pas_mmscs03_p02_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);	
	
	//파라미터 세팅
	this.pv_params = this.smfGetPopupParams();
	
	if(!this.smfIsNull(this.pv_params)){	// param 데이터가 있으면
		//this.div00.form.label00_00.set_text(this.pv_params.cddcOrgCdNm + this.div00.form.label00_00.text);
		trace(this.div00.form.grd00.getCellValue('0', '0'));
		trace(this.div00.form.grd00.getCellText('0', '0'));
		trace(this.div00.form.grd00.getCellValue('0', '10'));
		trace(this.div00.form.grd00.getCellText('0', '10'));
		
		
		this.div00.form.grd00.setCellProperty('body', '0', 'text', '<b v="true">'+this.pv_params.cddcOrgCdNm+'</b>'+this.div00.form.grd00.getCellText('0', '0'));
		
		this.div00.form.grd00.setCellProperty('body', '10', 'text', this.pv_params.cddcOrgCdNm+this.div00.form.grd00.getCellText('0', '10'));
	}
};

// 확인
this.div00_btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};

]]></Script>
