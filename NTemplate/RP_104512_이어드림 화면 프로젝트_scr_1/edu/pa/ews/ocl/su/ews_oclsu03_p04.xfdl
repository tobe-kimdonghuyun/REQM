<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="ews_oclsu01_p04" width="660" height="670" titletext="개인정보 수집·이용에 동의 팝업" cssclass="frm_Pop_bgTrsprt" onload="pas_mmscs03_p02_onload">
    <Layouts>
      <Layout height="670" width="660" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="div00" taborder="1" left="0" top="0" width="660" height="670" cssclass="div_Pop_shadowBox_C" initvalueid="ivDivAccessibilityOff" text="">
          <Layouts>
            <Layout>
              <Button id="btnClose" taborder="6" text="확인" left="250" top="592" height="50" cssclass="btn_WF_Action" width="160" initvalueid="ivBtnAccessibilityButton" onclick="div00_btnClose_onclick" accessibilitylabel="확인"/>
              <Grid id="grd00" taborder="0" left="10" top="12" width="640" height="570" binddataset="ds00" cssclass="grd_WF_MainNt" autofittype="col" cellclickbound="cell" enableevent="false" enable="false" accessibilitylabel="다자녀 가정 교육비 지원을 위한 개인정보 수집·이용 동의서">
                <Formats>
                  <Format id="default">
                    <Columns>
                      <Column size="764"/>
                    </Columns>
                    <Rows>
                      <Row size="31" band="head"/>
                      <Row size="68"/>
                      <Row size="24"/>
                      <Row size="142"/>
                      <Row size="46"/>
                      <Row size="46"/>
                      <Row size="27"/>
                      <Row size="35"/>
                      <Row size="24"/>
                      <Row size="47"/>
                      <Row size="45"/>
                      <Row size="24"/>
                    </Rows>
                    <Band id="head">
                      <Cell text="&lt;fs v='14'&gt;&lt;fc v='black'&gt;&lt;b v='true'&gt;다자녀 가정 교육비 지원&lt;/b&gt;을 위한 개인정보 수집·이용 동의서&lt;/fc&gt;&lt;/fs&gt;" displaytype="decoratetext"/>
                    </Band>
                    <Band id="body">
                      <Cell text="&lt;b v='true'&gt;(교육지원청) 및 대상 학교&lt;/b&gt;는 &lt;b v='true'&gt;다자녀 가정 교육비 지원&lt;/b&gt;과 관련하여&#13;&#10;아래와 같이 개인정보를 수집·이용하고자 합니다. 내용을 자세히 읽으신 후 동의 여부를&#13;&#10;결정하여 주십시오." displaytype="decoratetext" textAlign="left"/>
                      <Cell row="1" text="&lt;b v='true'&gt;▶개인정보(고유식별번호 포함) 수집·이용 내역&lt;/b&gt;" displaytype="decoratetext" textAlign="left"/>
                      <Cell row="2"/>
                      <Cell row="3" text="※ 위의 개인정보 수집·이용에 대한 동의를 거부할 권리가 있습니다.그러나 동의를 거부할 &#13;&#10;경우 다자녀 가정 교육비 지원이 불가합니다."/>
                      <Cell row="4" text="※ 수집하는 가족관계 사항 등은 다자녀 가정 교육비 지원 적합 여부 확인 용도로만 사용되며,&#13;&#10;정보 주체 동의 없이 다른 목적으로 사용하거나 제3자에게 제공되지 않습니다."/>
                      <Cell row="5" text="☞ 위와 같이 개인정보를 수집·이용하는데 동의하십니까?"/>
                      <Cell row="6"/>
                      <Cell row="7" text="※ 만 14세 미만 학생의 경우 보호자(법정대리인)의 동의가 필요합니다."/>
                      <Cell row="8" text="    년   월    일" textAlign="center"/>
                      <Cell row="9" text="보호자(법정대리인)           (서명 또는 인)" textAlign="center"/>
                      <Cell row="10" text="(교육지원청) 및 대상 학교장 귀중"/>
                    </Band>
                  </Format>
                </Formats>
              </Grid>
              <Grid id="grd01" taborder="1" left="27" top="142" width="583" height="129" binddataset="ds01" autofittype="col" enable="false" enableevent="false" cellclickbound="cell" cssclass="grd_WF_MainNt" accessibilitylabel="개인정보(고유식별번호 포함) 수집·이용 내역">
                <Formats>
                  <Format id="default">
                    <Columns>
                      <Column size="281"/>
                      <Column size="149"/>
                      <Column size="144"/>
                    </Columns>
                    <Rows>
                      <Row size="24" band="head"/>
                      <Row size="101"/>
                    </Rows>
                    <Band id="head">
                      <Cell text="&lt;fs v='11'&gt;&lt;fc v='balck'&gt;&lt;b v='true'&gt;항목&lt;/b&gt;&lt;/fc&gt;&lt;/fs&gt;" displaytype="decoratetext" textAlign="center"/>
                      <Cell col="1" text="&lt;fs v='11'&gt;&lt;fc v='balck'&gt;&lt;b v='true'&gt;수집ㆍ이용 목적&lt;/b&gt;&lt;/fc&gt;&lt;/fs&gt;" displaytype="decoratetext" textAlign="center"/>
                      <Cell col="2" text="&lt;fs v='11'&gt;&lt;fc v='balck'&gt;&lt;b v='true'&gt;보유ㆍ이용 기간&lt;/b&gt;&lt;/fc&gt;&lt;/fs&gt;" displaytype="decoratetext" textAlign="center"/>
                    </Band>
                    <Band id="body">
                      <Cell text="&lt;fs v='11'&gt;&lt;fc v='balck'&gt;&lt;b v='true'&gt;학생: &lt;/fc&gt;&lt;fc v='blue'&gt;성명, 생년월일, 학교명, 학교급, 학년,&#13;&#10;반, 번호, 가족관계&lt;/fc&gt;&#13;&#10;&#13;&#10;&lt;fc v='black'&gt;신청인: &lt;/fc&gt;&lt;fc v='blue'&gt;성명, 휴대전화번호, 학생과의 관계&lt;/b&gt;&lt;/fc&gt;&lt;/fs&gt;" displaytype="decoratetext" textAlign="left"/>
                      <Cell col="1" text="&lt;fs v='11'&gt;&lt;fc v='balck'&gt;&lt;b v='true'&gt;다자녀 가정&#13;&#10;교육비 지원&#13;&#10;사업 운영&lt;/b&gt;&lt;/fc&gt;&lt;/fs&gt;" textAlign="center" displaytype="decoratetext"/>
                      <Cell col="2" text="&lt;fs v='11'&gt;&lt;fc v='balck'&gt;&lt;b v='true'&gt;해당 학생 고등학교&#13;&#10;졸업까지&lt;/b&gt;&lt;/fc&gt;&lt;/fs&gt;" textAlign="center" displaytype="decoratetext"/>
                    </Band>
                  </Format>
                </Formats>
              </Grid>
              <Static id="sta00" taborder="2" text="동의" left="370" top="399" width="60" height="29" border="1px solid, 0px none, 1px solid, 1px solid" textAlign="center" accessibilitylabel="동의"/>
              <Static id="sta00_00" taborder="3" left="430" top="399" width="60" height="29" border="1px solid" textAlign="center"/>
              <Static id="sta00_01" taborder="4" text="미동의" left="510" top="398" width="60" height="29" border="1px solid, 0px none, 1px solid, 1px solid" textAlign="center" accessibilitylabel="미동의"/>
              <Static id="sta00_00_00" taborder="5" left="570" top="398" width="60" height="29" border="1px solid" textAlign="center"/>
            </Layout>
            <Layout name="Layout0">
              <Button id="btnClose" left="60" height="80" cssclass="btn_WF_popup" right="60" bottom="50"/>
