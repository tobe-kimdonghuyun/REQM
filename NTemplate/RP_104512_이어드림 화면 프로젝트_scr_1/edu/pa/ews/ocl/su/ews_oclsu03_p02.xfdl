    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    학생정보입력 화면
*  @FileName 	ews_oclsu01_p02.xfdl 
*  @Creator 	류찬욱
*  @CreateDate 	2023.04.07 
*  @Desction    시도교육청별 지원사업신청 학생정보입력
******************* 소스 수정 이력 *******************************************
*  date          		Modifier                Description
********************************************************************************
* 2023.04.07            류찬욱                   최초 생성 
********************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.linkNo;	// link넘버
var parentName;
var parentBirth;
this.cddcOrgCd;
this.cddcOrgCdNm;
this.orgCd;
this.kornOrgNm;
this.shlKndScCd;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	
	//파라미터 세팅
	this.pv_params = this.smfGetPopupParams();
	this.shlKndScCd = this.pv_params.shlKndScCd;
	
	if(!this.smfIsNull(this.pv_params)){	// param 데이터가 있으면
		this.linkNo = this.pv_params.linkNo;
		parentName = this.pv_params.parentName;
		parentBirth = this.pv_params.parentBirth;
		this.cddcOrgCd = this.pv_params.cddcOrgCd;
		this.cddcOrgCdNm = this.pv_params.cddcOrgCdNm;
		this.shlKndScCd = this.pv_params.shlKndScCd;	
		
		if(this.smfIsNull(parentName) || this.smfIsNull(parentBirth)) {
			this.smfAlert("잘못된 경로로 접근하였습니다.");
			this.close(false);
		}
		
		this.dsSearch.setColumn(0, "hsrFlnm", parentName);
		this.dsSearch.setColumn(0, "mohhRrno", parentBirth);
		this.dsSearch.setColumn(0, "cddcCd", this.cddcOrgCd.substring(0,3));
		
	}
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 팝업 CALLBACK
 */
this.fnPopupCallback = function(e, sender){
};


 /**
 * @description 학교찾기 콜백
 */
this.fnCommpopSchool = function(e, sender){

	if(sender == this.btnFdSch){
		this.edtKornOrgNm.set_value(e.row.kornOrgNm);
		this.orgCd		=	e.row.orgCd;
		this.kornOrgNm	=	e.row.kornOrgNm;	
		this.shlKndScCd  =	e.row.shlKndScCd;		
	}
	
	// 그외 다른 정보를 trace()로 표시(개발용)
	 /**
	var sLog = "";
	if(e.row)
	{
		for(var sKey in e.row)
		{
			var sValue = e.row[sKey];
			sLog += sKey + ":["+sValue+"]\n";
		}
	}
	
	this.trace("sLog :"+sLog);
	*/
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(obj, e)
{
	var invlInfoGthAgreYn;
	
	this.dsSearch.setColumn(0, "stuNm", this.edtName.value);
	this.dsSearch.setColumn(0, "stuRrno", this.edtBirth.value);
	
 	// 서비스 객체 생성
	this.smfSearchService("listSendApi")
		.run()	// 실행
		// 콜백
		.callback(function(callbackParams){		
			if(callbackParams.errors) return;
			
			if(this.CheckBox00_00_00.value)
				invlInfoGthAgreYn = "Y";
			else
				invlInfoGthAgreYn = "N";
				
			var popupParams = {
				sender: obj
				, callback: this.fnPopupCallback
				,
				params: {
					procType: 'search',
					dsResult: this.dsResult,
					dsEv001List: this.dsEv001List,
					dsEv002List: this.dsEv002List,
					dsEv003List: this.dsEv003List,
					linkNo: this.linkNo,
					cddcOrgCd: this.pv_params.cddcOrgCd,
					stuNm: this.edtName.value,
					stuRrno: this.edtBirth.value,
					apsNm: parentName,
					invlInfoGthAgreYn : invlInfoGthAgreYn,
					orgCd : this.orgCd,
					kornOrgNm : this.kornOrgNm,				
					shlKndScCd : this.shlKndScCd
				},
				titlebar : false,
			};			

			//if (this.linkNo == '600')
			if (this.dsResult.getColumn(0, "appErrorCode") == "SUCCESS")
			{
				this.smfDialog("_auto", "pa_ews_ocl_su::ews_oclsu03_p03.xfdl", popupParams)	// 조회결과 화면 이동
			} else {
				this.smfAlert("선택하신 시도에는 등록된 지원사업이 없습니다.");
				this.opener.close();
				this.close();
			}
			
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 조회 버튼 클릭
 */
this.btnSearch = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var birth = this.edtBirth.value;
	
	if(this.edtName.value == null || this.edtName.value == "" || this.edtName.value == "undefined"){
		this.smfAlert("학생명을 입력하세요.");
		return false;
	}

	if(birth == null || birth == "" || birth == "undefined"){
		this.smfAlert("학생 생년월일을 입력하세요.");
		return false;
	}
	
	if(birth.length != 6){
		this.smfAlert("생년월일은 6자리입니다.");
		return false;
	}

	if(this.edtKornOrgNm.value == null || this.edtKornOrgNm.value == "" || this.edtKornOrgNm.value == "undefined"){
		this.smfAlert("학교찾기 버튼을 클릭해서 학교명을 입력하세요.");
		return false;
	}
	
	/*
	if( this.rdo01.value == null || this.rdo01.value == "" || this.rdo01.value == "undefined" ){
		this.smfAlert("성별을 선택하세요.");
		return false;
	}
	*/
	
	if(!this.CheckBox00_00_00.value){
		this.smfAlert("개인정보 처리에 동의하셔야 합니다.");
		return false;
	}
	
	this.fnSearch();
};



/**
* btnPopup_onclick : modal popup open
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
*/
this.btnFdSch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	/**
	if(obj == this.btnFdSch){
		var kornOrgNm = this.edtKornOrgNm.value;
	}
	*/
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: this.fnCommpopSchool, // 콜백함수 지정
		sender: obj, // sender 지정

		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: 'search',

			// 파라메터 전달 
			//kornOrgNm: this.pv_params.cddcOrgCdNm,
			cddcOrgCd: this.pv_params.cddcOrgCd
		},
	};

	// 모달팝업 실행
	this.smfDialog("_auto", "commpop::commpop_school.xfdl", popupParams);
};

this.div01_btnFdSch00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var popupParams = {
			sender: obj
			, callback: this.fnPopupCallback
			, titlebar:false  // 타이틀바를 표시하지 않는다.
			, params: {
				procType: 'search',
				linkNo: this.linkNo,
				cddcOrgCd: this.pv_params.cddcOrgCd,
				cddcOrgCdNm: this.pv_params.cddcOrgCdNm
			},
		};
	
	this.smfDialog("_auto", "pa_ews_ocl_su::ews_oclsu03_p04.xfdl", popupParams);
};
this.rdo01_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	
};
]]></Script>
    <Objects>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="hsrFlnm" type="STRING" size="256"/>
          <Column id="mohhRrno" type="STRING" size="256"/>
          <Column id="stuNm" type="STRING" size="256"/>
          <Column id="stuRrno" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256"/>
          <Column id="outDatasets" type="STRING" size="256"/>
          <Column id="asynctp" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listSendApi</Col>
            <Col id="url">/ews_ocl_su03_p02.do</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResult=dsResult dsEv001List=dsEv001List dsEv002List=dsEv002List dsEv003List=dsEv003List</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsResult" useclientlayout="true">
        <ColumnInfo>
          <Column id="appErrorCode" type="STRING" size="256"/>
          <Column id="appErrorMsg" type="STRING" size="256"/>
          <Column id="rltCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsEv001List" useclientlayout="true">
        <ColumnInfo>
          <Column id="sprtBizCd" type="STRING" size="256"/>
          <Column id="sprtBizNm" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsEv002List" useclientlayout="true">
        <ColumnInfo>
          <Column id="sprtBizItmCd" type="STRING" size="256"/>
          <Column id="sprtBizItmNm" type="STRING" size="256"/>
          <Column id="sprtBizCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsEv003List" useclientlayout="true">
        <ColumnInfo>
          <Column id="reqsItmCd" type="STRING" size="256"/>
          <Column id="reqsItmNm" type="STRING" size="256"/>
          <Column id="reqsInptMthCd" type="STRING" size="256"/>
          <Column id="sprtBizCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="rdo01" propid="value" datasetid="dsPopup" columnid="crtDt"/>
    </Bind>
  </Form>
</FDL>
