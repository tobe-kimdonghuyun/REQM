        <Edit id="edtBirth" taborder="5" left="176" top="340" width="348" height="50" text="성명을 입력하세요" initvalueid="ivEdtNormal" cssclass="edi_Login_Normal" displaynulltext="생년월일 6자리를 입력하세요" maxlength="6" inputtype="number" accessibilitylabel="생년월일 6자리를 입력하세요"/>
        <Button id="btnFdSch" taborder="6" text="학교찾기" top="401" height="50" width="76" fittocontents="width" cssclass="btn_WF_Custom" visible="true" initvalueid="ivBtnAccessibilityLink" accessibilitylabel="학교찾기 (레이어팝업)" onclick="btnFdSch_onclick" left="175"/>
