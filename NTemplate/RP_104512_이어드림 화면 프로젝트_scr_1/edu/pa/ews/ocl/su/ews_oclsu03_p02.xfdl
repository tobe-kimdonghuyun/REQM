        <Static id="Static99_00_00_00_00_01" taborder="12" left="0" top="94" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Button id="btnFdSch00" taborder="11" text="보기" top="576" height="30" width="76" fittocontents="width" cssclass="btn_WF_Custom" visible="true" initvalueid="ivBtnAccessibilityLink" accessibilitylabel="학교찾기 (레이어팝업)" left="438" onclick="div01_btnFdSch00_onclick"/>
