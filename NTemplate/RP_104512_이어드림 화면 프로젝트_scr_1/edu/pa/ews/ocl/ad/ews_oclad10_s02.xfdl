    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    교육비 원클릭 > 일정 상세
*  @FileName 	ews_oclad10_s02.xfdl 
*  @Creator 	류찬욱
*  @CreateDate 	2023.04.07
*  @Desction    일정 상세
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.04.07            류찬욱                   최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form, e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
		
	var pv_params = this.smfGetFormParams();
	this.dsSearch.setColumn(0, "fxId", pv_params.fxId);
		
	this.fnSearchList();
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function( svcid, errcd, errmsg ){
	if( errcd == -1 ) return;
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
	this.btnList.click()
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 상세 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchList = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("listView")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				this.smfAlert('PA066', ['상세정보 조회 '] );
				return;
			}
			
			this.div00.form.edtBgngDt.set_value(this.dsAaFx.getColumn(0, "fxBgngDt"));
			this.div00.form.edtEndDt.set_value(this.dsAaFx.getColumn(0, "fxEndDt"));
			this.div00.form.edtFxTitlNm.set_value(this.dsAaFx.getColumn(0, "fxTitlNm"));
			this.div00.form.txtNtcCn.set_value(this.dsAaFx.getColumn(0, "fxCn"));

		});
};

/**
 * 저장서비스
 * @param : N/A
 * @param : N/A
 */
this.fnDelete = function()
{
	// 서비스 객체 생성
	this.smfDeleteService("deleteView")
		// (권장) 데이터 존재 필수
		//.requireExistsData(this.dsAaFx)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				this.smfAlert('PA066', ['삭제 '] );
				return;
			}
			
			this.smfAlert('PA020', [], this.fnMessageCallback); // 삭제가 완료되었습니다.
			//this.fnSearchList();
			
		});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 삭제 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnDel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnDelete();
};

/**
 * 수정 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnUpdate_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var param = {
				procType : 'update'
			   ,dataset  : this.dsAaFx.saveXML()
		};
		 
	this.smfSetWorkPage("pa_ews_ocl_ad::ews_oclad10_s00.xfdl", param, false);
};

/**
 * 목록 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnNtcList_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var param = {
		};
		 
	this.smfSetWorkPage("pa_ews_ocl_ad::ews_oclad10_m00.xfdl", param, false);
};
]]></Script>
