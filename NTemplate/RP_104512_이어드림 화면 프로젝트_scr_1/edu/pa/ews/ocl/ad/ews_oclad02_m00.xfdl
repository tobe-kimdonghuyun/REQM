        <Button id="btnAdd" taborder="5" text="등록" top="625" height="40" width="120" cssclass="btn_WF_Action" right="0" initvalueid="ivBtnAccessibilityButton" onclick="btnAdd_onclick" accessibilitylabel="등록"/>
        <Div id="divPaginator" taborder="4" left="0" top="565" height="30" right="0" url="comm::comp_paginator.xfdl" dsPage="dsPage" pageViewSize="100" initvalueid="ivDivAccessibilityOn" tabstop="true" text=""/>
        <Static id="sta03" taborder="8" left="0" top="544" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Div id="divTotal" taborder="1" top="77" width="80" height="30" url="comm::comp_pageSummary2.xfdl" initvalueid="ivDivAccessibilityOn" left="150" text="" visible="false" accessibilitylabel="총 건수"/>
        <Button id="btnSearch" taborder="2" text="조회" left="1126" top="80" width="74" height="30" cssclass="btn_WF_Search03" onclick="btnSearch_onclick" visible="false" accessibilitylabel="조회"/>
