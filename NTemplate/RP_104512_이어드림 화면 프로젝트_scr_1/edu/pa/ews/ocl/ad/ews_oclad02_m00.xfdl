        <Div id="divTitle" taborder="0" left="0" top="70" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="팝업 관리" left="0" top="0" height="44" cssclass="img_WF_SubTit01" width="460" initvalueid="ivTitleAccessibilityOn" accessibilitylabel="팝업 관리"/>
            </Layout>
            <Layout name="Layout0">
              <ImageViewer id="imgTitle" left="20" top="0" height="65" right="20"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta01" taborder="7" left="0" top="114" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Grid id="grdMain" taborder="3" left="0" top="144" height="400" autofittype="col" right="0" binddataset="dsMain" initvalueid="ivGrdAccessibilityOn" selecttype="cell" oncellclick="grdMain_oncellclick" accessibilitylabel="팝업 관리 표" autoenter="none" tabstop="true" readonly="true">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="40"/>
                <Column size="251"/>
                <Column size="70"/>
                <Column size="95"/>
                <Column size="15"/>
                <Column size="95"/>
                <Column size="90"/>
                <Column size="70"/>
                <Column size="70"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="번호"/>
                <Cell col="1" text="팝업명"/>
                <Cell col="2" text="유형"/>
                <Cell col="3" colspan="3" text="게시기간"/>
                <Cell col="6" text="비고"/>
                <Cell col="7" colspan="2" text="수정/삭제"/>
              </Band>
              <Band id="body">
                <Cell text="bind:rn" displaytype="normal" textAlign="center" edittype="normal"/>
                <Cell col="1" text="bind:popupTitlNm" edittype="text"/>
                <Cell col="2" text="bind:useYn" textAlign="center" edittype="normal"/>
                <Cell col="3" text="bind:bgngYmd" textAlign="center" displaytype="mask" edittype="normal" calendardateformat="yyyy.MM.dd" calendareditformat="yyyy.MM.dd" maskeditformat="@@@@-@@-@@" maskedittype="string"/>
                <Cell col="4" text="~" displaytype="normal" textAlign="center" edittype="normal"/>
                <Cell col="5" text="bind:endYmd" textAlign="center" displaytype="mask" edittype="normal" calendardateformat="yyyy.MM.dd" calendareditformat="yyyy.MM.dd" maskeditformat="@@@@-@@-@@" maskedittype="string"/>
                <Cell col="6" displaytype="buttoncontrol" text="미리보기" edittype="button"/>
                <Cell col="7" displaytype="buttoncontrol" text="수정" edittype="button"/>
                <Cell col="8" displaytype="buttoncontrol" text="삭제" edittype="button"/>
              </Band>
            </Format>
            <Format id="format00">
              <Columns>
                <Column size="140"/>
                <Column size="463"/>
              </Columns>
              <Rows>
                <Row size="50"/>
                <Row size="50"/>
                <Row size="50"/>
                <Row size="50"/>
                <Row size="50"/>
                <Row size="50"/>
              </Rows>
              <Band id="body">
                <Cell text="번호" cssclass="cell_WF_Label"/>
                <Cell col="1" text="bind:번호"/>
                <Cell row="1" text="제목" cssclass="cell_WF_Label"/>
                <Cell row="1" col="1" text="bind:제목" autosizerow="limitmin" cssclass="cell_ImpNoti"/>
                <Cell row="2" text="첨부" cssclass="cell_WF_Label"/>
                <Cell row="2" col="1" cssclass="cell_NotiFile"/>
                <Cell row="3" text="작성일" cssclass="cell_WF_Label"/>
                <Cell row="3" col="1" text="bind:등록일"/>
                <Cell row="4" text="조회수" cssclass="cell_WF_Label"/>
                <Cell row="4" col="1" text="bind:조회수"/>
                <Cell row="5" text="공지여부" cssclass="cell_WF_Label, cell_WF_MiddleLine"/>
                <Cell row="5" col="1" text="bind:공지여부" cssclass="cell_WF_MiddleLine"/>
              </Band>
