    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">list</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsPageInfo=dsPageInfo</Col>
            <Col id="outDatasets">dsMain=dsMain dsPageInfo=dsPageInfo dsCsrfKey=dsCsrfKey</Col>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">R</Col>
            <Col id="bindingControls"/>
            <Col id="url">/ews_ocl_ad02_001.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
          <Row>
            <Col id="id">delete</Col>
            <Col id="inDatasets">dsMainSelect=dsMainSelect</Col>
            <Col id="outDatasets"/>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">D</Col>
            <Col id="bindingControls"/>
            <Col id="url">/ews_ocl_ad02_005.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="Column0" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true">
        <ColumnInfo>
          <Column id="rn" type="STRING" size="256"/>
          <Column id="popupId" type="STRING" size="256" description="팝업ID"/>
          <Column id="useYn" type="STRING" size="256" description="사용여부"/>
          <Column id="popupScrinNm" type="STRING" size="256" description="팝업화면명"/>
          <Column id="bgngYmd" type="STRING" size="256" description="시작일자"/>
          <Column id="endYmd" type="STRING" size="256" description="종료일자"/>
          <Column id="popupTitlNm" type="STRING" size="256" description="팝업제목명"/>
          <Column id="popupCn" type="STRING" size="256" description="팝업내용"/>
          <Column id="htmlYn" type="STRING" size="256" description="HTML여부"/>
          <Column id="lnkUrlAddr" type="STRING" size="256" description="링크URL주소"/>
          <Column id="popupSzWide" type="STRING" size="256" description="팝업크기넓이"/>
          <Column id="popupSzHg" type="STRING" size="256" description="팝업크기높이"/>
          <Column id="scrlYn" type="STRING" size="256" description="스크롤여부"/>
          <Column id="popupVrcCrdnt" type="STRING" size="256" description="팝업세로좌표"/>
          <Column id="popupHrzCrdnt" type="STRING" size="256" description="팝업가로좌표"/>
          <Column id="dataCrerId" type="STRING" size="256" description="자료생성자ID"/>
          <Column id="crtDt" type="STRING" size="256" description="생성일시"/>
          <Column id="rgtrId" type="STRING" size="256" description="등록자ID"/>
          <Column id="regDt" type="STRING" size="256" description="등록일시"/>
          <Column id="mdfrId" type="STRING" size="256" description="수정자ID"/>
          <Column id="mdfcnDt" type="STRING" size="256" description="수정일시"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsPageInfo" useclientlayout="true">
        <ColumnInfo>
          <Column id="pageIndex" type="STRING" size="256"/>
          <Column id="pageSize" type="STRING" size="256"/>
          <Column id="totalCount" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsMainSelect" useclientlayout="true">
        <ColumnInfo>
          <Column id="popupId" type="STRING" size="256" description="팝업ID"/>
          <Column id="useYn" type="STRING" size="256" description="사용여부"/>
          <Column id="popupScrinNm" type="STRING" size="256" description="팝업화면명"/>
          <Column id="bgngYmd" type="STRING" size="256" description="시작일자"/>
          <Column id="endYmd" type="STRING" size="256" description="종료일자"/>
          <Column id="popupTitlNm" type="STRING" size="256" description="팝업제목명"/>
          <Column id="popupCn" type="STRING" size="256" description="팝업내용"/>
          <Column id="htmlYn" type="STRING" size="256" description="HTML여부"/>
          <Column id="lnkUrlAddr" type="STRING" size="256" description="링크URL주소"/>
          <Column id="popupSzWide" type="STRING" size="256" description="팝업크기넓이"/>
          <Column id="popupSzHg" type="STRING" size="256" description="팝업크기높이"/>
          <Column id="scrlYn" type="STRING" size="256" description="스크롤여부"/>
          <Column id="popupVrcCrdnt" type="STRING" size="256" description="팝업세로좌표"/>
          <Column id="popupHrzCrdnt" type="STRING" size="256" description="팝업가로좌표"/>
          <Column id="dataCrerId" type="STRING" size="256" description="자료생성자ID"/>
          <Column id="crtDt" type="STRING" size="256" description="생성일시"/>
          <Column id="rgtrId" type="STRING" size="256" description="등록자ID"/>
          <Column id="regDt" type="STRING" size="256" description="등록일시"/>
          <Column id="mdfrId" type="STRING" size="256" description="수정자ID"/>
          <Column id="mdfcnDt" type="STRING" size="256" description="수정일시"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsCsrfKey" useclientlayout="true">
        <ColumnInfo>
          <Column id="csrfKey" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    교육비 원클릭 > 팝업 관리
*  @FileName 	ews_oclad02_m00.xfdl 
*  @Creator 	류찬욱
*  @CreateDate 	2023.05.06
*  @Desction    팝업 관리
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.05.06            류찬욱                   최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	this.fnSearchList(this.btnSearch, e);
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
};

/**
 * 팝업의 콜백함수
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchList = function(obj, e)
{
 	// 서비스 객체 생성
	this.smfSearchService("list")
		// 페이징처리
		.paginator(this.grdMain, this.divPaginator, this.divTotal, this.dsPageInfo, obj, e)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				this.smfAlert('PA066', ['조회 '] );
				return;
			}
		});
};

this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearchList(obj, e);
};

/**
 * 삭제서비스
 * @param : N/A
 * @param : N/A
 */
this.fnDelete = function()
{
 	// 서비스 객체 생성
	this.smfDeleteService("delete")
		// (권장) 데이터 존재 필수
		.requireExistsData(this.dsMain)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				this.smfAlert('PA066', ['삭제 '] );
				return;
			}
			
			this.smfAlert('PA020', [], this.fnMessageCallback); // 삭제가 완료되었습니다.
			this.fnSearchList();
		});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 등록 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	var param = {
			  procType : 'insert'
			, "csrfKey" : this.dsCsrfKey.getColumn(0, "csrfKey")
		};	 
		 
	this.smfSetWorkPage("pa_ews_ocl_ad::ews_oclad02_s00.xfdl", param, false);
};

/**
 * 그리드 셀 클릭 시
 * @param  : obj			- [object]Grid
 * @param  : e				- [string]GridClickEventInfo
 * @return : N/A
 */
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	// 임시 아이디 세션
	//this.smfSetUserId('admin');
	
	this.dsMainSelect.copyRow(0, this.dsMain, e.row);
	
	if (e.col == 6){ // 미리보기
		var popupParams = {
			callback: this.fnPopupCallback,
			sender: obj, // sender 지정
			params: {
				procType : 'search'
			   ,dataset : this.dsMainSelect.saveXML()
			},
			titlebar : false
		};

		this.smfDialog("_auto", "pa_ews_ocl_ad::ews_oclad02_p00.xfdl", popupParams);
		
	}else if (e.col == 7){ // 수정
		/* 웹취약점 수정 2024.10.11
		if (this.smfGetSessionValue("mnrId") != this.dsMain.getColumn(e.row, 'rgtrId')){
			this.smfAlert('LI155', ['등록자만 수정할 수 있습니다.'], this.fnMessageCallback);
			return;
		}*/
		
		var param = {
				procType : 'update'
			   , dataset  : this.dsMainSelect.saveXML()
			   , "csrfKey" : this.dsCsrfKey.getColumn(0, "csrfKey")
			};
		 
		this.smfSetWorkPage("pa_ews_ocl_ad::ews_oclad02_s00.xfdl", param, false);
		
	}else if (e.col == 8){ // 삭제
		if (this.smfGetSessionValue("mnrId") != this.dsMain.getColumn(e.row, 'rgtrId')){
			this.smfAlert('LI155', ['등록자만 삭제할 수 있습니다.'], this.fnMessageCallback);
			return;
		}
		
		this.fnDelete(obj, e);
	}
};

]]></Script>
  </Form>
</FDL>
