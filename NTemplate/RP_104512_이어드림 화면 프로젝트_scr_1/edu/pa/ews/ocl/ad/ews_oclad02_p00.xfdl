              <Static id="sta00" taborder="0" text="알려드립니다" left="40" top="30" width="250" height="57" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_BlueCautionL_M"/>
              <CheckBox id="chkOpen" taborder="2" text="오늘하루 이 창 보지않음" left="227" width="283" height="40" value="true" initvalueid="ivChkNormal" cssclass="chk_WF_CloseBlue_M" bottom="39"/>
              <Button id="btnClose" taborder="3" top="40" width="36" height="36" cssclass="btn_WF_SurvPopClose" initvalueid="ivBtnAccessibilityButton" right="30"/>
