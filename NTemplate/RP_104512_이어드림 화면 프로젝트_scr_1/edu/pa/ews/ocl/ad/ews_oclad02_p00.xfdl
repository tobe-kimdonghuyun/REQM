              <CheckBox id="chkOpen" taborder="2" text="오늘하루 이 창 보지않음" width="193" height="24" cssclass="chk_WF_CloseBlue" initvalueid="ivChkNormal" right="27" top="div00:15" accessibilitylabel="오늘하루 이 창 보지않음"/>
