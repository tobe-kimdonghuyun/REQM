        <Static id="sta03" taborder="24" left="0" top="184" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta04" taborder="25" left="0" top="244" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Button id="btn04" taborder="4" left="447" top="144" width="150" height="40" cssclass="btn_WF_Tab_Line" initvalueid="ivBtnAccessibilityLink" text="일단위 총괄통계" onclick="Button_onclick" scCd="54" accessibilitylabel="일단위 총괄통계"/>
        <Button id="btnSearch" taborder="13" text="조회" left="986" top="219" width="74" height="30" cssclass="btn_WF_Search03" onclick="btnSearch_onclick" accessibilitylabel="조회"/>
        <Button id="btn00_01" taborder="14" text="액셀내려받기" left="1073" top="214" width="126" height="30" cssclass="btn_WF_Excel03" onclick="btnExport_onclick" accessibilitylabel="엑셀내려받기"/>
        <Calendar id="calStart" taborder="6" left="597" top="214" width="118" height="30" initvalueid="ivCalNormal" readonly="false" dateformat="yyyy.MM.dd" editformat="yyyy.MM.dd" accessibilitylabel="시작일 선택"/>
        <Static id="sta01_00_00_00" taborder="8" text="시" left="760" top="219" width="20" height="20" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" textAlign="center"/>
        <Edit id="edtStart" taborder="7" left="720" top="214" width="40" height="30" initvalueid="ivEdtNormal" text="2022-11-24" accessibilitylabel="시작시간 입력"/>
        <Calendar id="calEnd" taborder="10" left="797" top="214" width="118" height="30" initvalueid="ivCalNormal" readonly="false" dateformat="yyyy.MM.dd" editformat="yyyy.MM.dd" displayinvalidtext="invalid value" accessibilityrole="edit" accessibilitylabel="종료일 선택"/>
        <Edit id="edtEnd" taborder="11" left="920" top="214" width="40" height="30" initvalueid="ivEdtNormal" text="2022-11-24" accessibilitylabel="종료시간입력"/>
        <Static id="sta01_00_00_00_00" taborder="12" text="시" left="960" top="219" width="20" height="20" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" textAlign="center"/>
        <Static id="sta01" taborder="16" text="검색된 방문자 수:" left="829" top="650" width="111" height="26" cssclass="sta_WF_Black14" fittocontents="width" initvalueid="ivStcAccessibilityOn" accessibilitylabel="검색된 방문자 수"/>
        <Static id="staSearchCount" taborder="17" text="0 명" left="940" top="650" width="60" height="26" cssclass="sta_WF_Blue14"/>
        <Static id="sta02_00" taborder="18" text="/ 전체 방문자 수:" left="1002" top="650" width="111" height="26" cssclass="sta_WF_Black14" fittocontents="width" initvalueid="ivStcAccessibilityOn" accessibilitylabel="전체 방문자 수"/>
        <Static id="staTatal" taborder="19" text="0 명" top="651" height="25" cssclass="sta_WF_Red14" width="80" left="1114"/>
        <Div id="divPaginator" taborder="20" left="0" top="679" height="60" right="0" url="comm::comp_paginator.xfdl" dsPage="dsPage" pageViewSize="100" initvalueid="ivDivAccessibilityOn" tabstop="true" text=""/>
        <Grid id="grd01" taborder="15" top="254" height="385" autofittype="col" binddataset="dsCtgr" initvalueid="ivGrdAccessibilityOn" selecttype="cell" oncellclick="grd01_oncellclick" left="0" right="0" accessibilitylabel="접속통계목록" readonly="true">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="80"/>
                <Column size="250"/>
                <Column size="120"/>
                <Column size="120"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="선택"/>
                <Cell col="1" text="접속날짜"/>
                <Cell col="2" text="접속시간"/>
                <Cell col="3" text="접속자수"/>
              </Band>
              <Band id="body">
                <Cell text="bind:rnum" displaytype="normal" textAlign="center" edittype="normal"/>
                <Cell col="1" text="bind:cntnYmd" calendardateformat="yyyy-MM-dd" displaytype="date" textAlign="center" edittype="normal"/>
                <Cell col="2" text="bind:cntnHr" textAlign="center" edittype="normal"/>
                <Cell col="3" calendardateformat="yyyy-MM-dd " textAlign="center" expr="cntnNocs + &quot;명&quot;" edittype="normal"/>
              </Band>
            </Format>
            <Format id="format02">
              <Columns>
                <Column size="80"/>
                <Column size="250"/>
                <Column size="120"/>
                <Column size="120"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="NO."/>
                <Cell col="1" text="날짜"/>
                <Cell col="2" text="구분"/>
                <Cell col="3" text="이용자수(건)"/>
              </Band>
              <Band id="body">
                <Cell text="bind:num" displaytype="normal" textAlign="center"/>
                <Cell col="1" text="bind:cntnYmd" calendardateformat="yyyy-MM-dd" displaytype="date" textAlign="center"/>
                <Cell col="2" text="bind:name" textAlign="center"/>
                <Cell col="3" calendardateformat="yyyy-MM-dd " textAlign="center" expr="dayCnt + &quot;명&quot;"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Div id="divTotal" taborder="5" top="214" width="80" height="30" url="comm::comp_pageSummary2.xfdl" initvalueid="ivDivAccessibilityOn" left="10" text="" visible="false" accessibilitylabel="총 건수"/>
        <Div id="div00" taborder="21" text="div00" left="0" top="756" width="1199" height="354" url="comm::comp_chart.xfdl" visible="false"/>
        <Static id="sta01_00_00_00_01" taborder="9" text="~" left="sta01_00_00_00:0" top="219" width="10" height="20" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" textAlign="center"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsCtgr"/>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listData</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsPageInfo=dsPageInfo</Col>
            <Col id="outDatasets">dsMapCnt=dsMapCnt dsCtgr=dsCtgr dsTest=dsTest dsPageInfo=dsPageInfo</Col>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">R</Col>
            <Col id="bindingControls"/>
            <Col id="url">/ews_ocl_ad04_001.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="scCd" type="STRING" size="256"/>
          <Column id="calStart" type="STRING" size="256"/>
          <Column id="edtStart" type="STRING" size="256"/>
          <Column id="calEnd" type="STRING" size="256"/>
          <Column id="edtEnd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsPageInfo" useclientlayout="true">
        <ColumnInfo>
          <Column id="pageIndex" type="STRING" size="256"/>
          <Column id="pageSize" type="STRING" size="256"/>
          <Column id="totalCount" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsMapCnt"/>
      <Dataset id="dsTest" useclientlayout="true">
        <ColumnInfo>
          <Column id="cntnYmd" type="STRING" size="256"/>
          <Column id="chatA1" type="STRING" size="256"/>
          <Column id="chatA2" type="STRING" size="256"/>
          <Column id="chatA3" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    교육비 원클릭 > 접속통계
*  @FileName 	ews_oclad04_m00.xfdl 
*  @Creator 	류찬욱
*  @CreateDate 	2023.04.20
*  @Desction    접속통계
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.04.20            류찬욱                   최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * include 영역
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	//this.smfInitForm(obj);
	
	this.dsSearch.setColumn(0, 'scCd', 51);
	
	//현재 년도 입력
	var today = new Date();
	this.calStart.set_value(today);
	this.calEnd.set_value(today);
	
	this.edtStart.set_value(today.getHours());
	this.edtEnd.set_value(today.getHours());
	
	//this.fnSearchList();
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchList = function(obj, e)
{
 	// 서비스 객체 생성
	this.smfSearchService("listData")	//서비스 아이디 추가
		// 페이징 처리
		.paginator(this.grd01, this.divPaginator, this.divTotal, this.dsPageInfo, obj, e)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				this.smfAlert('PA066', ['조회 '] );
				return;
			}
			
			this.staSearchCount.set_text( this.dsMapCnt.getColumn(0, "curCnt") + "명");
			this.staTatal.set_text(this.dsMapCnt.getColumn(0, "totCnt") + "명");
			
			//trace(this.dsTest.saveXML());
			
			if(this.dsSearch.getColumn(0, 'scCd') == "54"){
				this.div00.set_visible(true);
				this.grd01.set_formatid("format02");
				this.edtStart.set_visible(false);
				this.sta01_00_00_00.set_visible(false);
				this.edtEnd.set_visible(false);
				this.sta01_00_00_00_00.set_visible(false);
				this.calEnd.set_left(870);
				this.sta01_00_00_00_01.set_left(850);
				this.calStart.set_left(720);
				
				this.btn00_onclick();
			}else{
				this.dsTest.clearData();
				this.div00.set_visible(false);
				this.grd01.set_formatid("default");
				this.edtStart.set_visible(true);
				this.sta01_00_00_00.set_visible(true);
				this.edtEnd.set_visible(true);
				this.sta01_00_00_00_00.set_visible(true);
				this.calEnd.set_left(797);
				this.sta01_00_00_00_01.set_left(780);
				this.calStart.set_left(597);
			}
			
			this.smfResetScroll(this);
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 구분(방문자수, 대상여부 조회수, 복지로 바로가기수, 일단위 총괄통계) 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.Button_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.btn01.set_cssclass('btn_WF_Tab_Line');
	this.btn02.set_cssclass('btn_WF_Tab_Line');
	this.btn03.set_cssclass('btn_WF_Tab_Line');
	this.btn04.set_cssclass('btn_WF_Tab_Line');
	
	obj.set_cssclass('btn_WF_Tab_LineS');
	this.dsSearch.setColumn(0, 'scCd', obj.scCd);
	
	this.fnSearchList(obj, e);
};

/**
 * 조회 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearchList(obj, e);
};


/**
 * 엑셀내려받기 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnExport_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var filename = "";
	
	if(	this.dsSearch.getColumn(0, 'scCd')	==	"51" ){
		filename = "방문자수";
	} else if(	this.dsSearch.getColumn(0, 'scCd')	==	"52" ){
		filename = "대상여부조회수";
	} else if(	this.dsSearch.getColumn(0, 'scCd')	==	"53" ){
		filename = "복지로바로가기수";
	} else if(	this.dsSearch.getColumn(0, 'scCd')	==	"54" ){
		filename = "일단위총괄통계";
	}
	
	var objOption = {
						objGrid : this.grd01
					,   sheetname : "Sheet1"
					,   filename : filename + "Export"
					};
	
	this.smfExcelExport(objOption);
};


 
this.btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var chartConfig = { title:"일단위총괄통계",
                        x_axis: { columnid:"cntnYmd",text: "일별"},
				        series:[
								{type:"line" ,columnid:"chatA1",text:"방문자수"			,linewidth:3,point:false}
						       ,{type:"line" ,columnid:"chatA2",text:"대상여부조회수"		,linewidth:3,point:false}
						       ,{type:"line" ,columnid:"chatA3",text:"복지로바로가기수"	,linewidth:3,point:false}
							   ]
					  };

	var objChartConfigResult = this.div00.form.fnGetChartConfig(chartConfig,this.dsTest);
	this.div00.form.fnRender(objChartConfigResult);
};


]]></Script>
    <Bind>
      <BindItem id="item4" compid="calStart" propid="value" datasetid="dsSearch" columnid="calStart"/>
      <BindItem id="item5" compid="edtStart" propid="value" datasetid="dsSearch" columnid="edtStart"/>
      <BindItem id="item6" compid="calEnd" propid="value" datasetid="dsSearch" columnid="calEnd"/>
      <BindItem id="item7" compid="edtEnd" propid="value" datasetid="dsSearch" columnid="edtEnd"/>
    </Bind>
  </Form>
</FDL>
