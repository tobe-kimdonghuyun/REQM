        <Static id="sta02" taborder="23" left="0" top="114" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Button id="btn01" taborder="1" text="방문자수" left="0" top="144" width="117" height="40" cssclass="btn_WF_Tab_LineS" initvalueid="ivBtnAccessibilityLink" onclick="Button_onclick" scCd="51" accessibilitylabel="방문자수"/>
        <Button id="btn02" taborder="2" left="117" top="144" width="160" height="40" cssclass="btn_WF_Tab_Line" initvalueid="ivBtnAccessibilityLink" text="대상여부 조회수" onclick="Button_onclick" scCd="52" accessibilitylabel="대상여부 조회수"/>
