        <Grid id="grd00_01" taborder="20" left="0" top="2225" height="320" autosizingtype="none" autofittype="col" fillareatype="allrow" cssclass="grd_WF_Gray" initvalueid="ivGrdAccessibilityOn" right="5" accessibilitylabel="구분표">
