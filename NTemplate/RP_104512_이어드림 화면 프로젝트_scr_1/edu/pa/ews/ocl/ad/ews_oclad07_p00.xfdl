              <Band id="body">
                <Cell text="① 차상위 자활 대상자" textAlign="left"/>
                <Cell col="1" displaytype="normal" text="국민기초생활보장법에 따라 자활 사업 참가하는 자" textAlign="left"/>
                <Cell row="1" text="② 차상위 본인 부담 경감 대상자" textAlign="left"/>
                <Cell row="1" col="1" displaytype="normal" text="국민건강보호법 시행령에 따라 본인 부담을 경감 받는 자" textAlign="left"/>
                <Cell row="2" text="③ 차상위 장애 수당 대상자" textAlign="left"/>
                <Cell row="2" col="1" displaytype="normal" text="장애인복지법에 따라 장애(아동)수당을 받는 자" textAlign="left"/>
                <Cell row="3" text="④ 차상위 장애 연금 대상자" textAlign="left"/>
                <Cell row="3" col="1" displaytype="normal" text="장애인연금법에 따라 장애 연금을 받는 자" textAlign="left"/>
                <Cell row="4" text="⑤ 차상위계층확인서발급 대상자 가구" textAlign="left"/>
                <Cell row="4" col="1" displaytype="normal" text="지자체에서 우선돌봄 차상위 계층으로 지정된 가구" textAlign="left"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
