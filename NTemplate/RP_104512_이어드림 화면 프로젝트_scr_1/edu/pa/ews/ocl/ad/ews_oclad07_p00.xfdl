          <Column id="etcSprtScopeCn" type="STRING" size="256"/>
          <Column id="txtCntn" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsEduGrd02" useclientlayout="true">
