    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    교육비 원클릭 > 시'도교육청별지원기준
*  @FileName 	ews_oclad07_m00.xfdl 
*  @Creator 	류찬욱
*  @CreateDate 	2023.04.27
*  @Desction    시'도교육청별지원기준
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.04.27            류찬욱                   최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	var pv_params = this.smfGetPopupParams();
	var str = "<fc v='#2b72de'>" + pv_params.name + "</fc>교육비 지원기준 안내"
	
	this.div00.form.sta00.set_text(str);
	
	this.dsSearch.loadXML(pv_params.dataset);
	//this.trace(this.dsSearch.saveXML());
	this.fnSearchList();
	
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 
/**
 * 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchList = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("listPop")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				this.smfAlert('PA066', ['팝업 정보를 가져오던 '] );
				return;
			}
			
			this.Static01.set_text(this.div00_00.form.cboCode.text);
			
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 닫기 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		   - [string]ClickEventInfo
 * @return : N/A
 */
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close();
};

this.sta00_02_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="Static01" propid="text" datasetid="dsEtcCntn" columnid="edufSprtCn"/>
      <BindItem id="item1" compid="Static02" propid="text" datasetid="dsEtcCntn" columnid="etcSprtTrgtCn"/>
      <BindItem id="item2" compid="Static03" propid="text" datasetid="dsEtcCntn" columnid="etcSprtScopeCn"/>
    </Bind>
  </Form>
</FDL>
