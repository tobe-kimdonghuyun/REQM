<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="ews_oclad10_m00" width="1200" height="1103" titletext="일정관리" onload="fnOnload">
    <Layouts>
      <Layout height="1103" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="70" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="일정 관리" left="0" top="0" height="44" cssclass="img_WF_SubTit01" width="195" initvalueid="ivTitleAccessibilityOn" accessibilitylabel="일정관리"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta1" taborder="7" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
        <Static id="sta2" taborder="8" left="0" top="114" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
        <Static id="yearText" taborder="2" left="545" top="144" width="111" height="30" cssclass="sta_WF_Tit20B" textAlign="center" initvalueid="ivStcAccessibilityOn"/>
        <Button id="btnBefore" taborder="1" height="30" cssclass="btn_WF_PageL" left="37.58%" top="144" onclick="btnBefore_onclick" initvalueid="ivBtnAccessibilityButton" right="yearText:26" accessibilitylabel="이전"/>
        <Button id="btnNext" taborder="3" height="30" cssclass="btn_WF_PageR" left="yearText:26" top="144" onclick="btnNext_onclick" width="50" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="다음"/>
        <Combo id="cboMonth" taborder="4" height="30" innerdataset="dsMonth" codecolumn="num" datacolumn="month" value="1" index="0" top="144" text="1월" width="80" left="btnNext:10" onitemchanged="cboMonth_onitemchanged" accessibilitylabel="월 선택" accessibilityaction="알트 + 아래쪽 방향키로 리스트 아이템 목록을 활성화하여 가상커서를 해제한 후 컨트롤 + 상하 방향키로 아이템을 이동합니다. 엔터 키를 이용하여 아이템을 선택합니다. 탭 키 로 다음으로 이동합니다."/>
        <Static id="sta3" taborder="9" left="0" top="174" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Grid id="grdGrid" taborder="5" left="0" binddataset="dsAaFxList" autofittype="col" top="194" height="839" right="0" cssclass="grd_WF_WeekList" initvalueid="ivGrdAccessibilityOn" scrolltype="both" scrollbartype="auto" selecttype="cell" oncellclick="grdGrid_oncellclick" accessibilitylabel="일정표" readonly="true">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="260"/>
                <Column size="260"/>
                <Column size="260"/>
                <Column size="260"/>
                <Column size="260"/>
                <Column size="260"/>
                <Column size="260"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
                <Row size="120"/>
              </Rows>
              <Band id="head">
                <Cell text="일요일" cssclass="cell_Font_Red" edittype="normal"/>
                <Cell col="1" text="월요일" edittype="normal"/>
                <Cell col="2" text="화요일" edittype="normal"/>
                <Cell col="3" text="수요일" edittype="normal"/>
                <Cell col="4" text="목요일" edittype="normal"/>
                <Cell col="5" text="금요일" edittype="normal"/>
                <Cell col="6" text="토요일" cssclass="LineNo,cell_Font_Blue" edittype="normal"/>
              </Band>
              <Band id="body">
                <Cell cssclass="cell_WF_Sunday" text="bind:day1" edittype="normal"/>
                <Cell col="1" text="bind:day2" cssclass="cell_WF_day" edittype="normal"/>
                <Cell col="2" text="bind:day3" cssclass="cell_WF_day" edittype="normal"/>
                <Cell col="3" text="bind:day4" cssclass="cell_WF_day" edittype="normal"/>
                <Cell col="4" text="bind:day5" cssclass="cell_WF_day" edittype="normal"/>
                <Cell col="5" text="bind:day6" cssclass="cell_WF_day" edittype="normal"/>
                <Cell col="6" text="bind:day7" cssclass="cell_WF_Saturday" edittype="normal"/>
                <Cell row="1" text="bind:event1" cssclass="cell_Font_Red" displaytype="decoratetext" cursor="pointer" textAlign="right" edittype="normal"/>
                <Cell row="1" col="1" text="bind:event2" cursor="pointer" displaytype="decoratetext" textAlign="right" edittype="normal"/>
                <Cell row="1" col="2" text="bind:event3" cursor="pointer" displaytype="decoratetext" textAlign="right" edittype="normal"/>
                <Cell row="1" col="3" text="bind:event4" cursor="pointer" displaytype="decoratetext" textAlign="right" edittype="normal"/>
                <Cell row="1" col="4" text="bind:event5" cursor="pointer" displaytype="decoratetext" textAlign="right" edittype="normal"/>
                <Cell row="1" col="5" text="bind:event6" cursor="pointer" displaytype="decoratetext" textAlign="right" edittype="normal"/>
                <Cell row="1" col="6" text="bind:event7" cursor="pointer" displaytype="decoratetext" cssclass="cell_Font_Blue" textAlign="right" edittype="normal"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="btnSave" taborder="6" text="일정 추가" top="1063" height="40" width="120" cssclass="btn_WF_Action" right="0" onclick="btnSave_onclick" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="일정 추가"/>
        <Static id="Static99_00_00_00_00_00_00_00_00" taborder="10" left="0" top="1033" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
