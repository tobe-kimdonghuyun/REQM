        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    교육비 원클릭 > 일정 관리
*  @FileName 	ews_oclad10_m00.xfdl 
*  @Creator 	류찬욱
*  @CreateDate 	2023.04.06
*  @Desction    일정 등록/수정
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.04.06            류찬욱                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_years;
 
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(this);
	
	// 년도, 월
	var objDate = new Date();
	var nn = new Date();
	var year = objDate.getFullYear();	// 현재 년도
	var month = objDate.getMonth();	// 현재 월
	fv_years = year;
	this.yearText.set_text(year+"년");
	this.cboMonth.set_index(month);
	
	this.dsSearch.setColumn(0, "year", year);
	this.fnSearchList();
	
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/**
 * 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchList = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("listData")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				this.smfAlert('PA066', ['조회 '] );
				return;
			}
		});
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
 this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
	
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/


 /************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// '<'버튼
this.btnBefore_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsAaFxList.reset();
	this.yearText.set_text(--fv_years+"년");
	this.dsSearch.setColumn(0, "year", fv_years);
	this.fnSearchList();
};

// '>'버튼
this.btnNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsAaFxList.reset();
	this.yearText.set_text(++fv_years+"년");
	this.dsSearch.setColumn(0, "year", fv_years);
	this.fnSearchList();
};

this.cboMonth_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.dsAaFxList.reset();
	this.dsSearch.setColumn(0, "month", this.cboMonth.value);
	this.fnSearchList();
};

// 일정추가 버튼 클릭
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var param = {
			procType : 'insert'
		};
		 
	this.smfSetWorkPage("pa_ews_ocl_ad::ews_oclad10_s00.xfdl", param, false);
};

this.grdGrid_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{

	//trace(this.grdGrid.getCellValue(e.row, e.cell));
	//trace(e.row +":"+ e.cell);
	//trace(this.grdGrid.getCellPropertyValue(e.row, e.cell, "fxId1"));
	//trace(this.dsAaFxList.getColumn(e.row, "fxId" + (e.cell - 6)));
	
	//this.dsAaFxListSelect.copyRow(0, this.dsAaFxList, e.row);
	//this.trace(this.dsAaFxListSelect.saveXML());
	var fxId = this.dsAaFxList.getColumn(e.row, "fxId" + (e.cell - 6));
	
	if( fxId == "" || fxId == "undefined" || fxId == null ){
		this.smfAlert("상세 정보가 존재하지 않습니다.");
		return false;
	}
	
	var param = {
				procType : 'view'
			   ,fxId:fxId
			};
		 
		this.smfSetWorkPage("pa_ews_ocl_ad::ews_oclad10_s02.xfdl", param, false);
};
]]></Script>
    <Bind>
      <BindItem id="item1" compid="cboMonth" propid="value" datasetid="dsSearch" columnid="month"/>
    </Bind>
  </Form>
</FDL>
