<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="ews_oclad01_m00" width="1200" height="703" titletext="QnA통계 리스트" onload="fnOnload">
    <Layouts>
      <Layout height="703" width="1200" screenid="ScreenDeskTop">
        <Static id="Static99_00_00_00_00" taborder="10" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Div id="divTitle" taborder="0" left="0" top="70" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="질의응답 통계" left="0" top="0" height="44" cssclass="img_WF_SubTit01" width="460" initvalueid="ivTitleAccessibilityOn" accessibilitylabel="질의응답 통계"/>
            </Layout>
            <Layout name="Layout0">
              <ImageViewer id="imgTitle" left="20" top="0" height="65" right="20"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="Static99_00_00_00_00_01" taborder="11" left="0" top="114" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Grid id="grd01" taborder="8" left="0" top="182" height="439" autofittype="col" right="0" binddataset="dsPopSet" initvalueid="ivGrdAccessibilityOn" selecttype="cell" oncellclick="grd01_oncellclick" accessibilitylabel="질의응답 목록" readonly="true">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="40"/>
                <Column size="101"/>
                <Column size="85"/>
                <Column size="85"/>
                <Column size="85"/>
                <Column size="85"/>
                <Column size="300"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="번호"/>
                <Cell col="1" text="질의날짜"/>
                <Cell col="2" text="질의"/>
                <Cell col="3" text="답변 완료"/>
                <Cell col="4" text="미답변"/>
                <Cell col="5" text="응답률"/>
                <Cell col="6" text="미답변 게시물 번호"/>
              </Band>
              <Band id="body">
                <Cell text="bind:rn" displaytype="normal" textAlign="center" edittype="normal"/>
                <Cell col="1" displaytype="normal" text="bind:regDtm" textAlign="center" edittype="normal"/>
                <Cell col="2" displaytype="normal" text="bind:totCnt" textAlign="center" edittype="normal"/>
                <Cell col="3" displaytype="normal" calendardateformat="yyyy-MM-dd " text="bind:answCnt" textAlign="center" edittype="normal"/>
                <Cell col="4" displaytype="normal" cssclass="LineNo" text="bind:ansrpCnt" textAlign="center" edittype="normal"/>
                <Cell col="5" displaytype="normal" text="bind:rspnsRat" textAlign="center" edittype="normal"/>
                <Cell col="6" displaytype="normal" text="bind:qnaId" edittype="normal"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="Static99_00_00_00_00_00_00_00_00" taborder="14" left="0" top="673" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Div id="divPaginator" taborder="9" left="0" top="643" height="30" right="0" url="comm::comp_paginator.xfdl" dsPage="dsPage" pageViewSize="100" initvalueid="ivDivAccessibilityOn" tabstop="true"/>
        <Static id="Static99_00_00_00_00_00_00_00" taborder="13" left="0" top="622" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_01_00" taborder="12" left="0" top="174" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Button id="btnExel" taborder="7" text="액셀내려받기" left="1074" top="144" width="126" height="30" cssclass="btn_WF_Excel03" onclick="btnExport_onclick" accessibilitylabel="엑셀 내려받기"/>
        <Button id="btnSearch" taborder="6" text="조회" left="990" top="144" height="30" cssclass="btn_WF_Search03" right="btnExel:8" onclick="btnSearch_onclick" accessibilitylabel="조회"/>
        <Calendar id="calStart" taborder="2" left="705" top="144" width="130" height="30" dateformat="yyyy-MM-dd" readonly="false" initvalueid="ivCalNormal" displayinvalidtext="invalid value" accessibilitylabel="시작일 선택"/>
        <Calendar id="calEnd" taborder="5" left="850" top="144" width="130" height="30" dateformat="yyyy-MM-dd" readonly="false" initvalueid="ivCalNormal" displayinvalidtext="invalid value" accessibilitylabel="종료일 선택"/>
        <Static id="Static65" taborder="4" text="~" left="835" top="144" width="15" height="30" cssclass="sta_WF_AC"/>
        <Static id="Static66" taborder="3" left="835" top="144" width="15" height="30" cssclass="sta_WF_GSize" visible="false"/>
        <Div id="divTotal" taborder="1" top="144" width="80" height="30" url="comm::comp_pageSummary2.xfdl" initvalueid="ivDivAccessibilityOn" left="10" text="" visible="false" accessibilitylabel="총 건수"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsPopSet"/>
      <Dataset id="dsPageInfo">
        <ColumnInfo>
          <Column id="pageIndex" type="STRING" size="256"/>
          <Column id="pageSize" type="STRING" size="256"/>
          <Column id="totalCount" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listData</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsPageInfo=dsPageInfo</Col>
            <Col id="outDatasets">dsPopSet=dsPopSet dsPageInfo=dsPageInfo</Col>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">R</Col>
            <Col id="bindingControls"/>
            <Col id="url">/ews_ocl_ad05_001.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="calStart" type="STRING" size="256"/>
          <Column id="calEnd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    교육비 원클릭 > Q&A통계
*  @FileName 	ews_oclad05_m00.xfdl 
*  @Creator 	류찬욱
*  @CreateDate 	2023.04.23
*  @Desction    Q&A통계
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.04.23            류찬욱                   최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * include 영역
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{	
	//현재 년도 입력
	var today = new Date();
	
	this.calStart.set_value(today);
	this.calEnd.set_value(today);
	
	//this.fnSearchList();
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchList = function(obj, e)
{

trace(this.dsSearch.saveXML());
 	// 서비스 객체 생성
	this.smfSearchService("listData")	//서비스 아이디 추가
		// 페이징 처리
		.paginator(this.grd01, this.divPaginator, this.divTotal, this.dsPageInfo, obj, e)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				this.smfAlert('PA066', ['조회 '] );
				return;
			}
			
			this.dsPopSet.addColumn("no");
			
			for(var i=0; i<this.dsPopSet.rowcount; i++){
				this.dsPopSet.setColumn(i, "no", this.dsPopSet.rowcount - this.dsPopSet.getColumn(i, "rn") + 1);
			}
			
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 조회 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearchList(obj, e);
};


/**
 * 엑셀내려받기 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnExport_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objOption = {
						objGrid : this.grd01
					,   sheetname : "Sheet1"
					,   filename : "질의응답 통계Export"
					};
	
	this.smfExcelExport(objOption);
};
]]></Script>
    <Bind>
      <BindItem id="item1" compid="calStart" propid="value" datasetid="dsSearch" columnid="calStart"/>
      <BindItem id="item0" compid="calEnd" propid="value" datasetid="dsSearch" columnid="calEnd"/>
    </Bind>
  </Form>
</FDL>
