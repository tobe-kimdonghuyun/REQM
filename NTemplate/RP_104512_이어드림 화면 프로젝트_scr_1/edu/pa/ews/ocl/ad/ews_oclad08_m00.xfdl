<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="ews_oclad08_m00" width="1200" height="653" titletext="화면열람관리" onload="fnOnload">
    <Layouts>
      <Layout height="653" width="1200" screenid="ScreenDeskTop">
        <Static id="Static99_00_00_00_00" taborder="3" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Div id="divTitle" taborder="0" left="0" top="70" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="화면열람 관리" left="0" top="0" height="44" cssclass="img_WF_SubTit01" width="460" initvalueid="ivTitleAccessibilityOn" accessibilitylabel="화면열람 관리"/>
            </Layout>
            <Layout name="Layout0">
              <ImageViewer id="imgTitle" left="20" top="0" height="65" right="20"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="Static99_00_00_00_00_01" taborder="4" left="0" top="114" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Grid id="grd01" taborder="1" left="0" top="144" height="439" autofittype="col" right="0" binddataset="dsPopSet" initvalueid="ivGrdAccessibilityOn" selecttype="cell" oncellclick="grd01_oncellclick" autosizingtype="none" accessibilitylabel="화면열람 관리목록">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="40"/>
                <Column size="300"/>
                <Column size="120"/>
                <Column size="10"/>
                <Column size="120"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="60"/>
                <Row size="60"/>
              </Rows>
              <Band id="head">
                <Cell text="번호"/>
                <Cell col="1" text="구분"/>
                <Cell col="2" colspan="3" text="일자"/>
              </Band>
              <Band id="body">
                <Cell text="1" displaytype="normal" textAlign="center" edittype="normal"/>
                <Cell col="1" cssclass="expr:key==&quot;1&quot;?&quot;cell_ImpNoti&quot;:&quot;&quot;" text="교육비 신청 대상여부 조회기간" textAlign="center" edittype="normal"/>
                <Cell col="2" displaytype="editcontrol" calendardateformat="yyyy-MM-dd " text="bind:applyStart" edittype="normal" textAlign="center"/>
                <Cell col="3" text="~" displaytype="normal" textAlign="center"/>
                <Cell col="4" displaytype="editcontrol" text="bind:applyEnd" edittype="normal" textAlign="center"/>
                <Cell row="1" text="2" textAlign="center" edittype="normal"/>
                <Cell row="1" col="1" cssclass="expr:key==&quot;1&quot;?&quot;cell_ImpNoti&quot;:&quot;&quot;" text="지원안내 열람 &#13;&#10;상담센터 안내 열람&#13;&#10;Q&amp;A 게시글 작성 열람" textAlign="center" edittype="normal"/>
                <Cell row="1" col="2" displaytype="editcontrol" calendardateformat="yyyy-MM-dd " text="bind:openStart" edittype="normal" imagestretch="none" textAlign="center"/>
                <Cell row="1" col="3" text="~" displaytype="normal" textAlign="center"/>
                <Cell row="1" col="4" displaytype="editcontrol" text="bind:openEnd" edittype="normal" textAlign="center"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="Static99_00_00_00_00_00_00_00_00" taborder="5" left="0" top="583" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Button id="btnSave" taborder="2" text="저장" top="613" height="40" width="120" cssclass="btn_WF_Action" right="0" initvalueid="ivBtnAccessibilityButton" onclick="btnSave_onclick" accessibilitylabel="저장"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsPopSet"/>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listData</Col>
            <Col id="inDatasets"/>
            <Col id="outDatasets">dsPopSet=dsPopSet</Col>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">R</Col>
            <Col id="bindingControls"/>
            <Col id="url">/ews_ocl_ad08_001.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
          <Row>
            <Col id="id">save</Col>
            <Col id="inDatasets">dsPopSetList=dsPopSetList:U</Col>
            <Col id="outDatasets"/>
            <Col id="svctp">U</Col>
            <Col id="url">/pas_ocl_ad08_002.do</Col>
            <Col id="callback">fnTransCallback</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsPopSetList">
        <ColumnInfo>
          <Column id="lwprtGrpCd" type="STRING" size="256"/>
          <Column id="referMteCn" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="lwprtGrpCd">47</Col>
          </Row>
          <Row>
            <Col id="lwprtGrpCd">48</Col>
          </Row>
          <Row>
            <Col id="lwprtGrpCd">49</Col>
          </Row>
          <Row>
            <Col id="lwprtGrpCd">50</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    교육비 원클릭 >화면열람관리
*  @FileName 	ews_oclad08_m00.xfdl 
*  @Creator 	류찬욱
*  @CreateDate 	2023.03.24
*  @Desction   화면열람관리
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.03.24            류찬욱                   최초 생성 
*******************************************************************************
*/ 
/************************************************************************************************
 * include 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.fnSearchList();
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchList = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("listData")	//서비스 아이디 추가
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				this.smfAlert('PA066', ['조회 '] );
				return;
			}
			
		});
};

/**
 * 저장서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSave = function()
{
	// 서비스 객체 생성
	this.smfSaveService("save")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				this.smfAlert('PA066', ['저장 '] );
				return;
			}
			
			this.smfAlert('CM002', [], this.fnMessageCallback); // 저장이 완료되었습니다.
			//this.fnSearchList();
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

/**
 * 저장 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsPopSetList.setColumn(0, "referMteCn", this.dsPopSet.getColumn(0, "applyStart"));
	this.dsPopSetList.setColumn(1, "referMteCn", this.dsPopSet.getColumn(0, "applyEnd"));
	this.dsPopSetList.setColumn(2, "referMteCn", this.dsPopSet.getColumn(0, "openStart"));
	this.dsPopSetList.setColumn(3, "referMteCn", this.dsPopSet.getColumn(0, "openEnd"));
	
	this.fnSave();
};
]]></Script>
  </Form>
</FDL>
