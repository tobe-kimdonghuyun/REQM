        <Button id="btnSave" taborder="2" text="저장" top="301" height="40" width="120" cssclass="btn_WF_Action" right="0" onclick="btnPswdInit_onclick" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="저장"/>
        <Static id="Static99_00_00_00_00" taborder="3" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01" taborder="4" left="0" top="112" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_00_00_00" taborder="5" left="0" top="271" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    교육비 원클릭 > 관리자관리
*  @FileName 	ews_oclad09_m00.xfdl 
*  @Creator 	류찬욱
*  @CreateDate 	2023.04.07
*  @Desction    관리자관리
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.04.07            류찬욱                   최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form, e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	this.dsSearch.setColumn(0, 'mnrId', this.smfGetSessionValue("mnrId"));
	 
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function( svcid, errcd, errmsg ){
	if( errcd == -1 ) return;	
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/**
 * 비밀번호 변경 서비스
 * @param : N/A
 * @param : N/A
 */
this.fnInitPswd = function()
{
	var pswdYn = this.dsNtcDtl.getColumn(0, "pswdYn");
	var chgPswd = this.dsSearch.getColumn(0, "chgPswd");
	var chgPswdCnf = this.dsSearch.getColumn(0, "chgPswdCnf");
	
	var str = this.smfStr(chgPswd).trim();
	var objRegExp = /[`~!@+_#$%^&*|\\\'\":;\/?]/gi;
	var objRegExp2 = /[0-9]/gi;
	
	if( pswdYn == "N" ){
		this.smfAlert("기존비밀번호 확인이 맞지 않습니다. 다시 입력하세요.");
		return false;
	}
	
	if( chgPswdCnf != chgPswd ){
		this.smfAlert("비밀번호 확인이 맞지 않습니다. 다시 입력하세요.");
		this.div00.form.edtChgPswdCnf.set_value("");
		return false;
	}
	
	if( chgPswd == "" || chgPswd == "undefined" | chgPswd == null || chgPswd.length < 8 ){
		this.smfAlert("비밀번호는 8자리 이상이여야 합니다.");
		return false;
	}
	
	if(!objRegExp.test(str)){
		this.smfAlert("비밀번호는 특수기호가 포함되어야 합니다.");
		return false;
	}
	
	if(!objRegExp2.test(chgPswd)){
		this.smfAlert("비밀번호는 숫자가 포함되어야 합니다.");
		return false;
	}
	
	// 서비스 객체 생성
	this.smfSaveService("savePswd")
		// (권장) 데이터 존재 필수
		.requireExistsData(this.dsSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				if(callbackParams.reason == -99){
					this.smfAlert(callbackParams.message);
					return;
				}
				this.smfAlert('PA066', ['비밀번호 변경 '] );
				return;
			}	
				
			this.smfAlert('CM002', [], this.fnMessageCallback); // 저장이 완료되었습니다.
			//this.fnSearchList();
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 /**
 * 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchList = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				this.smfAlert('PA066', ['기존비밀번호 정보를 가져오던 '] );
				return;
			}
			
			if(this.dsNtcDtl.rowcount < 1){
				this.smfAlert("로그인 된 관리자 정보를 확인할 수 없습니다. 재 로그인해 주시기 바랍니다.");
				return false;
			}
			
			this.fnInitPswd();
		});
};

/**
 * 저장 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnPswdInit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearchList();
};
]]></Script>
    <Objects>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="mngPswd" type="STRING" size="256"/>
          <Column id="chgPswd" type="STRING" size="256"/>
          <Column id="chgPswdCnf" type="STRING" size="256"/>
          <Column id="mnrId" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsNtcDtl" useclientlayout="true">
        <ColumnInfo>
          <Column id="pswdYn" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">list</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsNtcDtl=dsNtcDtl</Col>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">R</Col>
            <Col id="bindingControls"/>
            <Col id="url">/ews_ocl_ad09_002.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
          <Row>
            <Col id="id">savePswd</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets"/>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">U</Col>
            <Col id="bindingControls"/>
            <Col id="url">/ews_ocl_ad09_003.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="div00.form.edtMngPswd" propid="value" datasetid="dsSearch" columnid="mngPswd"/>
      <BindItem id="item1" compid="div00.form.edtChgPswd" propid="value" datasetid="dsSearch" columnid="chgPswd"/>
      <BindItem id="item2" compid="div00.form.edtChgPswdCnf" propid="value" datasetid="dsSearch" columnid="chgPswdCnf"/>
    </Bind>
  </Form>
</FDL>
