              <Edit id="edtMngPswd" taborder="2" left="200" top="7" width="880" height="30" initvalueid="ivEdtNormal" text="2022-11-24" password="true" accessibilitylabel="기존 비밀번호 입력칸"/>
              <Edit id="edtChgPswdCnf" taborder="8" left="199" top="92" width="881" height="30" initvalueid="ivEdtNormal" text="2022-11-24" password="true" accessibilitylabel="비밀번호 확인 칸"/>
              <Static id="sta00_00_00" taborder="3" left="0" top="43" height="43" cssclass="sta_WF_Input02" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta02" taborder="4" left="0" top="43" height="43" cssclass="sta_WF_Input01" initvalueid="ivStcAccessibilityOn" width="190" text="비밀번호" accessibilitylabel="비밀번호 "/>
              <Edit id="edtChgPswd" taborder="5" left="199" top="49" width="881" height="30" initvalueid="ivEdtNormal" text="2022-11-24" password="true" accessibilitylabel="비밀번호 입력 칸"/>
            </Layout>
