<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="ews_oclad06_m00" width="1200" height="935" titletext="상담센터 연락처관리" onload="fnOnload">
    <Layouts>
      <Layout height="935" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="70" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="상담센터 연락처관리" left="0" top="0" height="44" cssclass="img_WF_SubTit01" width="430" initvalueid="ivTitleAccessibilityOn" accessibilitylabel="상담센터 연락처 관리"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnSave" taborder="3" text="저장" top="895" height="40" width="120" cssclass="btn_WF_Crud" right="0" initvalueid="ivBtnAccessibilityButton" onclick="btnSave_onclick" accessibilitylabel="저장"/>
        <Static id="sta00" taborder="4" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta01" taborder="5" left="0" top="114" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta02" taborder="6" left="0" top="865" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Grid id="grdMain" taborder="1" left="0" top="144" width="1200" height="719" binddataset="dsMain" accessibilitylabel="연락처 관리 목록" readonly="false">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="280"/>
                <Column size="120"/>
                <Column size="800"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="지역"/>
                <Cell col="1" text="순서"/>
                <Cell col="2" text="연락처"/>
              </Band>
              <Band id="body">
                <Cell text="bind:lwprtGrpCdNm" edittype="normal"/>
                <Cell col="1" text="bind:scrinSeqNo" textAlign="center" edittype="normal"/>
                <Cell col="2" text="bind:referMteCn" displaytype="editcontrol" edittype="text" editmaxlength="300"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="btnPreView" taborder="2" text="미리보기" top="895" height="40" width="120" right="btnSave:8" initvalueid="ivBtnAccessibilityButton" onclick="btnPreView_onclick" accessibilitylabel="미리보기"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    교육비 원클릭 > 상담센터 연락처관리
*  @FileName 	ews_oclad06_m00.xfdl 
*  @Creator 	류찬욱
*  @CreateDate 	2023.04.10
*  @Desction    상담센터 연락처관리
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.04.10            류찬욱                   최초 생성 
*******************************************************************************
*/ 
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
		url : "/ews_ocl_ad06_000.do",
		})
		.mappingRulesetToDataset(this.dsMainValid, "save")
		.callback(function(callbackParams) {
		})
		.run()
	;
	
	this.fnSearchList();
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
};

/**
 * 팝업의 콜백함수
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchList = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				this.smfAlert('PA066', ['조회 '] );
				return;
			}
		});
};

/**
 * 저장서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSave = function()
{
	// 서비스 객체 생성
	this.smfSaveService("save")
		// (권장) 데이터 존재 필수
		.requireExistsData(this.dsMain)
		// 데이터 변경 필수
		.requireModifredData(this.dsMain)
		// 데이터 검증
		.validateGrid(this.grdMain, this.dsMainValid)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				this.smfAlert('PA066', ['저장 '] );
				return;
			}
			
			this.smfAlert('CM002', [], this.fnMessageCallback); // 저장이 완료되었습니다.
			this.fnSearchList();
		});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 저장 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	this.fnSave();
};

/**
 * 미리보기 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnPreView_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var popupParams = {
		callback: this.fnPopupCallback,
		sender: obj, // sender 지정
		params: {
			procType : 'search'
		},
		titlebar : false
	};

	this.smfDialog("_auto", "pa_ews_ocl_ad::ews_oclad06_p00.xfdl", popupParams);
};
]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">list</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsMain=dsMain</Col>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">R</Col>
            <Col id="bindingControls"/>
            <Col id="url">/ews_ocl_ad06_001.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
          <Row>
            <Col id="id">save</Col>
            <Col id="inDatasets">dsMain=dsMain:U</Col>
            <Col id="outDatasets"/>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">U</Col>
            <Col id="bindingControls"/>
            <Col id="url">/ews_ocl_ad06_002.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="Column0" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true" oncolumnchanged="dsMain_oncolumnchanged">
        <ColumnInfo>
          <Column id="lwprtGrpCd" type="STRING" size="256" description="하위그룹코드"/>
          <Column id="upGrpCd" type="STRING" size="256" description="상위그룹코드"/>
          <Column id="lwprtGrpCdNm" type="STRING" size="256" description="하위그룹코드명"/>
          <Column id="useYn" type="STRING" size="256" description="사용여부"/>
          <Column id="scrinSeqNo" type="STRING" size="256" description="화면순서번호"/>
          <Column id="referMteCn" type="STRING" size="256" description="참고사항내용"/>
          <Column id="rgtrId" type="STRING" size="256" description="등록자"/>
          <Column id="regDt" type="STRING" size="256" description="등록일시"/>
          <Column id="mdfrId" type="STRING" size="256" description="수정자"/>
          <Column id="mdfcnDt" type="STRING" size="256" description="수정일시"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsMainValid" useclientlayout="true">
        <ColumnInfo>
          <Column id="lwprtGrpCd" type="STRING" size="256" description="하위그룹코드"/>
          <Column id="upGrpCd" type="STRING" size="256" description="상위그룹코드"/>
          <Column id="lwprtGrpCdNm" type="STRING" size="256" description="하위그룹코드명"/>
          <Column id="useYn" type="STRING" size="256" description="사용여부"/>
          <Column id="scrinSeqNo" type="STRING" size="256" description="화면순서번호"/>
          <Column id="referMteCn" type="STRING" size="256" description="참고사항내용"/>
          <Column id="rgtrId" type="STRING" size="256" description="등록자"/>
          <Column id="regDt" type="STRING" size="256" description="등록일시"/>
          <Column id="mdfrId" type="STRING" size="256" description="수정자"/>
          <Column id="mdfcnDt" type="STRING" size="256" description="수정일시"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
  </Form>
</FDL>
