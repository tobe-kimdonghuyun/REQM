<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="ews_oclad00_m00" width="1200" height="705" titletext="카테고리 관리" onload="fnOnload">
    <Layouts>
      <Layout height="705" width="1200" screenid="ScreenDeskTop">
        <Static id="sta01" taborder="12" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Div id="divTitle" taborder="0" left="0" top="70" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="카테고리 관리" left="0" top="0" height="44" cssclass="img_WF_SubTit01" width="460" initvalueid="ivTitleAccessibilityOn" accessibilitylabel="카테고리 관리"/>
            </Layout>
            <Layout name="Layout0">
              <ImageViewer id="imgTitle" left="20" top="0" height="65" right="20"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta02" taborder="16" left="0" top="114" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta05" taborder="15" left="0" top="635" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Button id="btnDel" taborder="11" text="삭제" top="665" height="40" width="120" cssclass="btn_WF_Crud" initvalueid="ivBtnAccessibilityButton" right="0" onclick="btnDel_onclick" accessibilitylabel="삭제"/>
        <Button id="btnSave" taborder="10" text="저장" top="665" height="40" cssclass="btn_WF_Crud" right="btnDel:8" width="120" onclick="btnSave_onclick" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="저장"/>
        <Button id="btnAdd" taborder="9" text="등록" top="665" height="40" initvalueid="ivBtnAccessibilityButton" right="btnSave:8" width="120" onclick="btnAdd_onclick" accessibilitylabel="등록"/>
        <Button id="btnFaq" taborder="1" text="자주묻는 질문" left="0" top="144" width="165" height="40" cssclass="btn_WF_Tab_LineS" initvalueid="ivBtnAccessibilityLink" onclick="Button_onclick" searchGrpCd="1" accessibilitylabel="자주묻는 질문"/>
        <Button id="btnQna" taborder="2" left="btnFaq:-1" top="144" width="132" height="40" cssclass="btn_WF_Tab_Line" initvalueid="ivBtnAccessibilityLink" text="질의응답" onclick="Button_onclick" searchGrpCd="3" accessibilitylabel="질의응답"/>
        <Button id="btnData" taborder="3" left="btnQna:-1" top="144" width="117" height="40" cssclass="btn_WF_Tab_Line" initvalueid="ivBtnAccessibilityLink" text="자료실" onclick="Button_onclick" searchGrpCd="2" accessibilitylabel="자료실"/>
        <Grid id="grdMain" taborder="8" left="0" top="254" autofittype="col" right="0" binddataset="dsMain" selecttype="cell" oncellclick="grd01_oncellclick" initvalueid="ivGrdAccessibilityOn" height="381" accessibilitylabel="카테고리 관리표">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="50"/>
                <Column size="500"/>
                <Column size="124"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="선택"/>
                <Cell col="1" text="카테고리명"/>
                <Cell col="2" text="사용여부"/>
                <Cell col="3" text="순서"/>
              </Band>
              <Band id="body">
                <Cell displaytype="expr:cnt != 0 ? 'none' : 'checkboxcontrol'" edittype="checkbox" calendartype="spin" text="bind:_chk"/>
                <Cell col="1" displaytype="editcontrol" edittype="text" text="bind:lwprtGrpCdNm" editmaxlength="25"/>
                <Cell col="2" displaytype="combocontrol" edittype="combo" text="bind:useYn" combodataset="dsUse" combodatacol="data" combocodecol="code"/>
                <Cell col="3" displaytype="editcontrol" text="bind:scrinSeqNo" calendardateformat="yyyy-MM-dd " edittype="text" editinputtype="digit" editmaxlength="3"/>
              </Band>
            </Format>
            <Format id="format00">
              <Columns>
                <Column size="140"/>
                <Column size="463"/>
              </Columns>
              <Rows>
                <Row size="50"/>
                <Row size="50"/>
                <Row size="50"/>
                <Row size="50"/>
                <Row size="50"/>
                <Row size="50"/>
              </Rows>
              <Band id="body">
                <Cell text="번호" cssclass="cell_WF_Label"/>
                <Cell col="1" text="bind:번호"/>
                <Cell row="1" text="제목" cssclass="cell_WF_Label"/>
                <Cell row="1" col="1" text="bind:제목" autosizerow="limitmin" cssclass="cell_ImpNoti"/>
                <Cell row="2" text="첨부" cssclass="cell_WF_Label"/>
                <Cell row="2" col="1" cssclass="cell_NotiFile"/>
                <Cell row="3" text="작성일" cssclass="cell_WF_Label"/>
                <Cell row="3" col="1" text="bind:등록일"/>
                <Cell row="4" text="조회수" cssclass="cell_WF_Label"/>
                <Cell row="4" col="1" text="bind:조회수"/>
                <Cell row="5" text="공지여부" cssclass="cell_WF_Label, cell_WF_MiddleLine"/>
                <Cell row="5" col="1" text="bind:공지여부" cssclass="cell_WF_MiddleLine"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="sta03" taborder="13" left="0" top="184" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta00" taborder="4" text="* 사용중인 카테고리는 삭제할 수 없습니다." left="0" top="214" width="321" height="26" cssclass="sta_WF_Black14" fittocontents="width" initvalueid="ivStcAccessibilityOn" accessibilitylabel="사용중인 카테고리는 삭제할 수 없습니다."/>
        <Button id="btnSearch" taborder="7" text="조회" top="214" width="74" height="30" cssclass="btn_WF_Search03" right="0" onclick="btnSearch_onclick" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="조회"/>
        <Static id="sta04" taborder="14" left="0" top="244" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Edit id="edtSearchKeyword" taborder="6" top="214" height="30" text="우리날" right="btnSearch:6" width="260" initvalueid="ivEdtNormal" maxlength="10" accessibilitylabel="입력창"/>
        <Combo id="cboSearchCondition" taborder="5" height="30" value="0" text="카테고리명" top="214" right="edtSearchKeyword:6" width="154" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" index="0" initvalueid="ivCmbNormal" accessibilitylabel="카테고리명 ">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row>
                <Col id="codecolumn">0</Col>
                <Col id="datacolumn">카테고리명</Col>
              </Row>
            </Rows>
          </Dataset>
        </Combo>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">list</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsMain=dsMain</Col>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">R</Col>
            <Col id="bindingControls"/>
            <Col id="url">/ews_ocl_ad00_001.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
          <Row>
            <Col id="id">save</Col>
            <Col id="inDatasets">dsMain=dsMain:U</Col>
            <Col id="outDatasets"/>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">U</Col>
            <Col id="bindingControls"/>
            <Col id="url">/ews_ocl_ad00_002.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
          <Row>
            <Col id="id">delete</Col>
            <Col id="inDatasets">dsMain=dsMain:U</Col>
            <Col id="outDatasets"/>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">D</Col>
            <Col id="bindingControls"/>
            <Col id="url">/ews_ocl_ad00_003.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="searchGrpCd" type="STRING" size="256"/>
          <Column id="searchCondition" type="STRING" size="256"/>
          <Column id="searchKeyword" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true">
        <ColumnInfo>
          <Column id="_chk" type="STRING" size="256"/>
          <Column id="upGrpCd" type="STRING" size="256" description="상위그룹코드"/>
          <Column id="upGrpCdNm" type="STRING" size="256" description="상위그룹코드명"/>
          <Column id="lwprtGrpCd" type="STRING" size="256" description="하위그룹코드"/>
          <Column id="lwprtGrpCdNm" type="STRING" size="256" description="하위그룹코드명"/>
          <Column id="useYn" type="STRING" size="256" description="사용여부"/>
          <Column id="scrinSeqNo" type="STRING" size="256" description="화면순서번호"/>
          <Column id="referMteCn" type="STRING" size="256" description="참고사항내용"/>
          <Column id="cnt" type="STRING" size="256" description="카테고리수"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsUse" useclientlayout="true">
        <ColumnInfo>
          <Column id="code" type="STRING" size="256"/>
          <Column id="data" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="code">Y</Col>
            <Col id="data">사용</Col>
          </Row>
          <Row>
            <Col id="code">N</Col>
            <Col id="data">미사용</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsMainValid" useclientlayout="true">
        <ColumnInfo>
          <Column id="_chk" type="STRING" size="256"/>
          <Column id="upGrpCd" type="STRING" size="256" description="상위그룹코드"/>
          <Column id="upGrpCdNm" type="STRING" size="256" description="상위그룹코드명"/>
          <Column id="lwprtGrpCd" type="STRING" size="256" description="하위그룹코드"/>
          <Column id="lwprtGrpCdNm" type="STRING" size="256" description="하위그룹코드명"/>
          <Column id="useYn" type="STRING" size="256" description="사용여부"/>
          <Column id="scrinSeqNo" type="STRING" size="256" description="화면순서번호"/>
          <Column id="referMteCn" type="STRING" size="256" description="참고사항내용"/>
          <Column id="cnt" type="STRING" size="256" description="카테고리수"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    교육비 원클릭 > 카테고리 관리
*  @FileName 	ews_oclad00_m00.xfdl 
*  @Creator 	류찬욱
*  @CreateDate 	2023.04.30
*  @Desction    카테고리 관리
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.04.30            류찬욱                   최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	this.dsSearch.setColumn(0, 'searchGrpCd', 1);
	this.dsSearch.setColumn(0, 'searchCondition', 0);
	
	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
		url : "/ews_ocl_ad00_000.do",
		})
		.mappingRulesetToDataset(this.dsMainValid, "save")
		.callback(function(callbackParams) {
		})
		.run()
	;
	
	this.fnSearchList();
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchList = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				this.smfAlert('PA066', ['조회 '] );
				return;
			}
		});
};

/**
 * 저장서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSave = function()
{
	// 서비스 객체 생성
	this.smfSaveService("save")
		// (권장) 데이터 존재 필수
		.requireExistsData(this.dsMain)
		// 데이터 변경 필수
		.requireModifredData(this.dsMain)
		// 데이터 검증
		//.validateGrid(this.grdMain, this.dsMainValid)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				this.smfAlert('PA066', ['저장 '] );
				return;
			}
			
			this.smfAlert('CM002', [], this.fnMessageCallback); // 저장이 완료되었습니다.
			this.fnSearchList();
		});
};

/**
 * 삭제서비스
 * @param : N/A
 * @param : N/A
 */
this.fnDelete = function()
{
	// 서비스 객체 생성
	this.smfDeleteService("delete")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
		
			if(callbackParams.errors){
				this.smfAlert('PA066', ['삭제 '] );
				return;
			}
			
			this.fnSearchList();
		});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 구분(자주묻는 질문, 질의응답, 자료실) 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.Button_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.btnFaq.set_cssclass('btn_WF_Tab_Line');
	this.btnQna.set_cssclass('btn_WF_Tab_Line');
	this.btnData.set_cssclass('btn_WF_Tab_Line');
	obj.set_cssclass('btn_WF_Tab_LineS');
	
	this.dsSearch.setColumn(0, 'searchGrpCd', obj.searchGrpCd);
	this.fnSearchList();
};

/**
 * 조회 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearchList();
};

/**
 * 등록 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var row = this.dsMain.addRow();
	this.dsMain.setColumn(row, 'upGrpCd', this.dsSearch.getColumn(0, 'searchGrpCd'));
	this.dsMain.setColumn(row, 'useYn', 'Y');
	this.dsMain.setColumn(row, 'scrinSeqNo', +this.dsMain.getMax('scrinSeqNo') + 1);
	this.dsMain.setColumn(row, 'cnt', 0);
};

/**
 * 저장 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSave();
};

/**
 * 삭제 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnDel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var rowCnt = this.dsMain.getCaseCount('_chk == 1');
	if (rowCnt == 0 ){
		this.smfAlert('CM012', [], this.fnMessageCallback); //삭제할 자료를 먼저 선택하여 주십시오.
		return;
	}
	this.fnDelete();
};]]></Script>
    <Bind>
      <BindItem id="item2" compid="edtSearchKeyword" propid="value" datasetid="dsSearch" columnid="searchKeyword"/>
      <BindItem id="item3" compid="cboSearchCondition" propid="value" datasetid="dsSearch" columnid="searchCondition"/>
    </Bind>
  </Form>
</FDL>
