<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="ews_oclad01_m00" width="1200" height="663" titletext="관리자 등록/수정/삭제" onload="fnOnload">
    <Layouts>
      <Layout height="663" width="1200" screenid="ScreenDeskTop">
        <Static id="sta01" taborder="9" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Div id="divTitle" taborder="0" left="0" top="70" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="관리자 관리" left="0" top="0" height="44" cssclass="img_WF_SubTit01" width="460" initvalueid="ivTitleAccessibilityOn" accessibilitylabel="관리자 관리"/>
            </Layout>
            <Layout name="Layout0">
              <ImageViewer id="imgTitle" left="20" top="0" height="65" right="20"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta02" taborder="10" left="0" top="114" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Combo id="cboSearchCondition" taborder="1" left="772" width="150" height="30" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" value="0" index="0" top="145" initvalueid="ivCmbNormal" text="관리자명" accessibilitylabel="관리자명">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row>
                <Col id="codecolumn">0</Col>
                <Col id="datacolumn">관리자명</Col>
              </Row>
            </Rows>
          </Dataset>
        </Combo>
        <Button id="btnSearch" taborder="3" text="조회" top="145" height="30" cssclass="btn_WF_Search03" right="0" width="74" initvalueid="ivBtnAccessibilityButton" onclick="btnSearch_onclick" accessibilitylabel="조회"/>
        <Edit id="edtSearchKeyword" taborder="2" top="145" height="30" text="NEIS 업무시스템" left="cboSearchCondition:8" width="188" initvalueid="ivEdtNormal" maxlength="10" accessibilitylabel="입력창"/>
        <Grid id="grdMain" taborder="4" left="0" top="185" height="439" autofittype="col" right="0" binddataset="dsMain" initvalueid="ivGrdAccessibilityOn" selecttype="cell" accessibilitylabel="관리자 관리표">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="40"/>
                <Column size="251"/>
                <Column size="187"/>
                <Column size="71"/>
                <Column size="112"/>
                <Column size="169"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="선택"/>
                <Cell col="1" text="아이디"/>
                <Cell col="2" text="관리자명"/>
                <Cell col="3" text="사용여부"/>
                <Cell col="4" text="권한"/>
                <Cell col="5" text="시도" cssclass="LineNo"/>
              </Band>
              <Band id="body">
                <Cell text="bind:_chk" displaytype="checkboxcontrol" edittype="checkbox"/>
                <Cell col="1" text="bind:mnrId" editmaxlength="20" editinputtype="alpha,digit,english,number" editinputfilter="comma,dot,sign,space,symbol" edittype="expr:dataset.getRowType(currow) == 2 ? 'text' : 'none'" displaytype="expr:dataset.getRowType(currow) == 2 ? 'editcontrol' : 'normal'"/>
                <Cell col="2" text="bind:mnrNm" displaytype="editcontrol" editmaxlength="6" edittype="text"/>
                <Cell col="3" displaytype="combocontrol" text="bind:useYn" calendardateformat="yyyy-MM-dd " edittype="combo" combodataset="dsUse" combodatacol="data" combocodecol="code"/>
                <Cell col="4" text="bind:mnrMngAuthCd" displaytype="combocontrol" edittype="combo" combodataset="dsMnrMngAuthCd" combodatacol="lwprtGrpCdNm" combocodecol="lwprtGrpCd"/>
                <Cell col="5" displaytype="expr:mnrMngAuthCd == 23 ? 'combocontrol' : 'none'" text="bind:ctpvCd" cssclass="LineNo" combodataset="dsCtpvCd" combodatacol="lwprtGrpCdNm" combocodecol="lwprtGrpCd" edittype="expr:mnrMngAuthCd == 23 ? 'combo' : 'none'"/>
              </Band>
            </Format>
            <Format id="format00">
              <Columns>
                <Column size="140"/>
                <Column size="463"/>
              </Columns>
              <Rows>
                <Row size="50"/>
                <Row size="50"/>
                <Row size="50"/>
                <Row size="50"/>
                <Row size="50"/>
                <Row size="50"/>
              </Rows>
              <Band id="body">
                <Cell text="번호" cssclass="cell_WF_Label"/>
                <Cell col="1" text="bind:번호"/>
                <Cell row="1" text="제목" cssclass="cell_WF_Label"/>
                <Cell row="1" col="1" text="bind:제목" autosizerow="limitmin" cssclass="cell_ImpNoti"/>
                <Cell row="2" text="첨부" cssclass="cell_WF_Label"/>
                <Cell row="2" col="1" cssclass="cell_NotiFile"/>
                <Cell row="3" text="작성일" cssclass="cell_WF_Label"/>
                <Cell row="3" col="1" text="bind:등록일"/>
                <Cell row="4" text="조회수" cssclass="cell_WF_Label"/>
                <Cell row="4" col="1" text="bind:조회수"/>
                <Cell row="5" text="공지여부" cssclass="cell_WF_Label, cell_WF_MiddleLine"/>
                <Cell row="5" col="1" text="bind:공지여부" cssclass="cell_WF_MiddleLine"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="sta03" taborder="11" left="0" top="176" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta04" taborder="12" left="0" top="593" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Button id="btnPswdInit" taborder="8" text="비밀번호 초기화" top="623" height="40" width="150" cssclass="btn_WF_Crud" right="0" initvalueid="ivBtnAccessibilityButton" onclick="btnPswdInit_onclick" accessibilitylabel="비밀번호 초기화"/>
        <Button id="btnSave" taborder="7" text="저장" top="623" height="40" width="120" cssclass="btn_WF_Crud" right="btnPswdInit:8" initvalueid="ivBtnAccessibilityButton" onclick="btnSave_onclick" accessibilitylabel="저장"/>
        <Button id="btnAdd" taborder="6" text="등록" top="623" height="40" width="120" right="btnSave:10" initvalueid="ivBtnAccessibilityButton" onclick="btnAdd_onclick" accessibilitylabel="등록"/>
        <Static id="sta00" taborder="5" text="*초기 비밀번호는 &quot;1111&quot;로 설정됩니다. 신규등록자는 초기비밀번호로 설정됩니다." left="0" top="624" height="26" fittocontents="none" initvalueid="ivStcAccessibilityOn" width="690" cssclass="sta_WF_Black14" accessibilitylabel="초기 비밀번호는 '1111'로 설정됩니다. 신규등록자는 초기비밀번호로 설정됩니다."/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">list</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsMain=dsMain dsMnrMngAuthCd=dsMnrMngAuthCd dsCtpvCd=dsCtpvCd</Col>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">R</Col>
            <Col id="bindingControls"/>
            <Col id="url">/ews_ocl_ad01_001.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
          <Row>
            <Col id="id">save</Col>
            <Col id="inDatasets">dsMain=dsMain:U</Col>
            <Col id="outDatasets"/>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">U</Col>
            <Col id="bindingControls"/>
            <Col id="url">/ews_ocl_ad01_002.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
          <Row>
            <Col id="id">savePswd</Col>
            <Col id="inDatasets">dsMain=dsMain:U</Col>
            <Col id="outDatasets"/>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">D</Col>
            <Col id="bindingControls"/>
            <Col id="url">/ews_ocl_ad01_003.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="searchCondition" type="STRING" size="256"/>
          <Column id="searchKeyword" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true" oncolumnchanged="dsMain_oncolumnchanged">
        <ColumnInfo>
          <Column id="_chk" type="STRING" size="256"/>
          <Column id="mnrSn" type="STRING" size="256" description="관리자일련번호"/>
          <Column id="mnrId" type="STRING" size="256" description="관리자ID"/>
          <Column id="mnrNm" type="STRING" size="256" description="관리자명"/>
          <Column id="useYn" type="STRING" size="256" description="사용여부"/>
          <Column id="referMteCn" type="STRING" size="256" description="참고사항내용"/>
          <Column id="mnrMngAuthCd" type="STRING" size="256" description="관리자관리권한코드"/>
          <Column id="ctpvCd" type="STRING" size="256" description="시도코드"/>
          <Column id="mnrMngAuthNm" type="STRING" size="256" description="관리자관리권한명"/>
          <Column id="ctpvNm" type="STRING" size="256" description="시도명"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsMnrMngAuthCd" useclientlayout="true">
        <ColumnInfo>
          <Column id="lwprtGrpCd" type="STRING" size="256"/>
          <Column id="lwprtGrpCdNm" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsCtpvCd" useclientlayout="true">
        <ColumnInfo>
          <Column id="lwprtGrpCd" type="STRING" size="256"/>
          <Column id="lwprtGrpCdNm" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsMainValid" useclientlayout="true">
        <ColumnInfo>
          <Column id="_chk" type="STRING" size="256"/>
          <Column id="mnrSn" type="STRING" size="256" description="관리자일련번호"/>
          <Column id="mnrId" type="STRING" size="256" description="관리자ID"/>
          <Column id="mnrNm" type="STRING" size="256" description="관리자명"/>
          <Column id="useYn" type="STRING" size="256" description="사용여부"/>
          <Column id="referMteCn" type="STRING" size="256" description="참고사항내용"/>
          <Column id="mnrMngAuthCd" type="STRING" size="256" description="관리자관리권한코드"/>
          <Column id="ctpvCd" type="STRING" size="256" description="시도코드"/>
          <Column id="mnrMngAuthNm" type="STRING" size="256" description="관리자관리권한명"/>
          <Column id="ctpvNm" type="STRING" size="256" description="시도명"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsUse" useclientlayout="true">
        <ColumnInfo>
          <Column id="code" type="STRING" size="256"/>
          <Column id="data" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="code">Y</Col>
            <Col id="data">사용</Col>
          </Row>
          <Row>
            <Col id="code">N</Col>
            <Col id="data">미사용</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    교육비 원클릭 > 관리자 관리
*  @FileName 	ews_oclad01_m00.xfdl 
*  @Creator 	류찬욱
*  @CreateDate 	2023.04.30
*  @Desction    관리자 관리
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.04.30            류찬욱                   최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
  
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	this.dsSearch.setColumn(0, 'searchCondition', 0);
	
	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
		url : "/ews_ocl_ad01_000.do",
		})
		.mappingRulesetToDataset(this.dsMainValid, "save")
		.callback(function(callbackParams) {
		})
		.run()
	;
	
	this.fnSearchList();
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchList = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});
};

/**
 * 저장서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSave = function()
{
	// 서비스 객체 생성
	this.smfSaveService("save")
		// (권장) 데이터 존재 필수
		.requireExistsData(this.dsMain)
		// 데이터 변경 필수
		.requireModifredData(this.dsMain)
		// 데이터 검증
		.validateGrid(this.grdMain, this.dsMainValid)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.smfAlert('CM002', [], this.fnMessageCallback); // 저장이 완료되었습니다.
			this.fnSearchList();
		});
};

/**
 * 비밀번호 초기화 서비스
 * @param : N/A
 * @param : N/A
 */
this.fnInitPswd = function()
{
	// 서비스 객체 생성
	this.smfSaveService("savePswd")
		.messagePrefix("선택한 관리자 비밀번호를 초기화")
		// (권장) 데이터 존재 필수
		.requireExistsData(this.dsMain)
		// 데이터 변경 필수
		//.requireModifredData(this.dsMain)
		// 데이터 검증
		//.validateGrid(this.grdMain, this.dsMainValid)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.smfAlert('LI155', ['초기화 되었습니다.'], this.fnMessageCallback);
			this.fnSearchList();
		});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 조회 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearchList();
};

/**
 * 등록 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var row = this.dsMain.addRow();
	this.dsMain.setColumn(row, 'useYn', 'Y');
	this.dsMain.setColumn(row, 'mnrMngAuthCd', this.dsMnrMngAuthCd.getColumn(0, 'lwprtGrpCd'));
};

/**
 * 저장 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	for(var i = 0; i < this.dsMain.getRowCount(); i++){
		if (this.smfIsNull(this.dsMain.getColumn(i, 'mnrId'))){
			this.smfAlert('CM006', ['아이디'], this.fnMessageCallback); // {0}은(는) 필수 입력입니다.
			return;
		}
		
		if (this.smfIsNull(this.dsMain.getColumn(i, 'mnrNm'))){
			this.smfAlert('CM006', ['관리자명'], this.fnMessageCallback); // {0}은(는) 필수 입력입니다.
			return;
		}
		
		if (this.dsMain.getColumn(i, 'mnrId').length < 8){
			this.smfAlert('CM021', ['아이디', '8자리'], this.fnMessageCallback); // {0} 은(는) {1} 보다 커야 합니다.
			return;
		}
		
		var special_pattern = /[0-9]/gi;
		if (!special_pattern.test(this.dsMain.getColumn(i, 'mnrId'))){
			this.smfAlert('LI155', ['관리자 아이디에 숫자가 포함되어야 합니다.'], this.fnMessageCallback);
			return;
		}
		
		special_pattern = /[ㄱ-ㅎ|ㅏ-ㅣ|가-힣]/gi;
		if (special_pattern.test(this.dsMain.getColumn(i, 'mnrId'))){
			this.smfAlert('LI155', ['관리자 아이디에 한글이 포함되면 안됩니다.'], this.fnMessageCallback);
			return;
		}
	}
	
	this.fnSave();
};

/**
 * 비밀번호 초기화 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.btnPswdInit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var rowCnt = this.dsMain.getCaseCount('_chk == 1');
	if (rowCnt == 0 ){
		this.smfAlert('CM022', ['관리자'], this.fnMessageCallback); // {0}을(를) 선택하여 주십시오.
		return;
	}
	this.fnInitPswd();
};

/**
 * ds 컬럼 값 변경 시
 * @param  : obj			- [object]NormalDataset
 * @param  : e				- [string]DSColChangeEventInfo
 * @return : N/A
 */
this.dsMain_oncolumnchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	if (e.col == 6){
		if (e.newvalue == 23){
			obj.setColumn(e.row, 'ctpvCd', this.dsCtpvCd.getColumn(0, 'lwprtGrpCd'));
		}else{
			obj.setColumn(e.row, 'ctpvCd', null);
		}
	}
};]]></Script>
    <Bind>
      <BindItem id="item0" compid="edtSearchKeyword" propid="value" datasetid="dsSearch" columnid="searchKeyword"/>
      <BindItem id="item1" compid="cboSearchCondition" propid="value" datasetid="dsSearch" columnid="searchCondition"/>
    </Bind>
  </Form>
</FDL>
