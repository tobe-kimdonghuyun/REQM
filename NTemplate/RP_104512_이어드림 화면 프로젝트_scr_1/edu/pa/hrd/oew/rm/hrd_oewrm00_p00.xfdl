<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmTemp01" width="800" height="890" titletext="계약제교원인력풀-전자근로계약서-사전동의서-개인정보 수집,이용에 관한 동의서" onload="form_onload" canlayoutchange="btnCancel_onclick" accessibilitylabel="개인정보수집이용에 관한 그룹박스">
    <Layouts>
      <Layout height="890" width="800" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00" taborder="1" left="18" top="17" height="65" cssclass="sta_WF_Black14" text="본인은 계약제인력풀 채용에 있어 &lt;b v='true'&gt;교육공무원법&lt;/b&gt; 제32조 및 제10조의 4에 의거 결격사유 해당 여부를 조회 할 필요가 있다는 것과 개인정보 수집 목적 등 아래 사항을 이해하였으며, 이를 위해 &lt;b v='true'&gt;개인정보 보호법&lt;/b&gt; 제15조에 따라 OOO교육청 및 결격사유 조회 기관에 제공하는데 동의 합니다." usedecorate="true" right="10" initvalueid="ivStcAccessibilityOn"/>
        <Div id="div00" taborder="2" left="20" height="331" cssclass="div_WF_InfoBOX" right="20" top="114" initvalueid="ivDivAccessibilityOn">
          <Layouts>
            <Layout>
              <Static id="sta01" taborder="0" text="수집·이용에 관한 사항" left="29" top="31" width="220" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta02" taborder="1" left="29" top="65" width="200" height="21" cssclass="sta_WF_Black14" text="가. 수집·이용 목적" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta03" taborder="2" left="29" top="96" height="49" cssclass="sta_WF_InfoTxt" text="「교육공무원법」제32조 및 제10조 4에 따른기간제교원 임용에 관한 결격사유 조회 기간에 제공하는데 &#13;&#10;동의합니다. " wordWrap="char" right="25" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta04" taborder="3" left="29" top="164" width="200" height="21" cssclass="sta_WF_Black14" text="나. 보유기간" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta05" taborder="4" left="29" top="198" height="19" cssclass="sta_WF_InfoTxt" text="수집된 개인정보는 「공공기록물 관리에 관한 법률」에 따라 보유 폐기됩니다." wordWrap="char" right="25" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta06" taborder="5" left="29" top="240" width="200" height="21" cssclass="sta_WF_Black14" text="다. 수집항목" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta07" taborder="6" left="29" top="276" height="19" cssclass="sta_WF_InfoTxt" text="고유식별정보(주민등록번호), 성명, 주소, 등록기준지" wordWrap="char" right="25" initvalueid="ivStcAccessibilityOn"/>
              <Static id="staGd06" taborder="7" left="0" top="35" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="35" text="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staGd07" taborder="8" top="35" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="35" text="30" right="0" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="div01" taborder="3" left="20" height="262" cssclass="div_WF_InfoBOX01" right="20" top="484" text="" initvalueid="ivDivAccessibilityOn" accessibilitylabel="이용 및 정보 동의에 관한 그룹박스">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" text="수집·이용 동의" left="29" top="11" width="220" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta01" taborder="1" left="29" top="45" width="510" height="21" cssclass="sta_WF_Black14" text="본인은 위 목적으로 본인의 개인정보를 수집하는 것에 동의합니다." usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta03" taborder="2" text="고유식별 정보동의" left="28" top="99" width="220" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta04" taborder="3" left="28" top="133" height="41" cssclass="sta_WF_Black14" text="본인은 OOOO교육청 및 교육지원청, 관할 각급학교가 위 목적으로 다음과 같은 본인의 고유 식별정보를 &#13;&#10;수집·이용하는 것에 동의합니다." usedecorate="true" right="30" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta05" taborder="4" left="29" top="188" height="19" cssclass="sta_WF_InfoTxt" text="고유식별정보 : 주민등록번호(주민등록번호 법령근거 : 개인정보 보호법 제24조)" wordWrap="char" right="27" initvalueid="ivStcAccessibilityOn"/>
              <Radio id="popupRdo00" taborder="5" top="219" width="144" height="25" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" rowcount="-1" value="1" text="동의" index="0" right="30" initvalueid="ivRdoNormal">
                <Dataset id="innerdataset">
                  <ColumnInfo>
                    <Column id="codecolumn" size="256"/>
                    <Column id="datacolumn" size="256"/>
                  </ColumnInfo>
                  <Rows>
                    <Row>
                      <Col id="codecolumn">01</Col>
                      <Col id="datacolumn">동의</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">02</Col>
                      <Col id="datacolumn">미동의</Col>
                    </Row>
                  </Rows>
                </Dataset>
              </Radio>
              <Static id="sta02" taborder="6" left="30" top="83" height="1" cssclass="sta_WF_SectionLine" right="30" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta01" taborder="4" left="48" top="771" height="25" cssclass="sta_WF_Black14" text="본인은 개인정보 수집이용에 대한 내용을 충분히 안내 받았음을 확인합니다. &#13;&#10;" usedecorate="true" right="50" initvalueid="ivStcAccessibilityOn"/>
        <Button id="btnCancel" taborder="5" text="취소" left="34.38%" width="120" height="40" cssclass="btn_WF_ActionLine" top="830" initvalueid="ivBtnAccessibilityButton" onclick="btnCancel_onclick"/>
        <Button id="btnConfirm" taborder="6" text="확인" width="120" height="40" cssclass="btn_WF_Action" left="btnCancel:10" top="830" initvalueid="ivBtnAccessibilityButton" onclick="btnConfirm_onclick"/>
        <Static id="staGd08" taborder="7" left="20" top="746" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd09" taborder="8" left="20" top="800" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd10" taborder="9" left="20" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" bottom="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Objects/>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-계약제교원인력풀-전자근로계약서-사전동의서- 상세 팝업1
*  @MenuPath    pa_hrd_oew_rm
*  @FileName 	pa_hrd_oewrm00_p00.xfdl
*  @Creator 	
*  @CreateDate 	2022.9.14
*  @Desction    계약제교원인력풀-전자근로계약서-사전동의서- 개인정보 수집, 이용 팝업1
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.9.14    	 	         최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// default 초기처리를 한다.
	
	this.smfInitPopup(obj);
	// 파라메터 셋
	this.pv_params = this.smfGetPopupParams();
	
	// 부모화면으로부터 받은 동의여부 초기값 설정 
	this.div01.form.popupRdo00.set_value(this.pv_params.agreeValue); 
	
	// 팝업 타이틀변경
	this.smfUpdatePopupTitle("개인정보 수집 이용 동의서");
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 
//동의여부 선택 여부
this.fnRadioChoice = function(){
	// opener Res
	this.smfSendResponseToOpener({
		"agreeValue": this.div01.form.popupRdo00.value
	});
	this.close(true);
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 확인버튼 클릭	
 */
this.btnConfirm_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnRadioChoice();
	
};
/**
 * 취소버튼 클릭
 */
this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};
]]></Script>
  </Form>
</FDL>
