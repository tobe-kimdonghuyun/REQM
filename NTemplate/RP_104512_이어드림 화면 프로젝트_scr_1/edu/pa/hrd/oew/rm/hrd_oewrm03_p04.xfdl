    <Objects/>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-계약제교원인력풀-경력합산신청-대학학력-학력 팝업
*  @MenuPath    pa_hrd_oew_rm
*  @FileName 	pa_hrd_oewrm03_p04.xfdl
*  @Creator 	
*  @CreateDate 	2022.09.14
*  @Desction    온라인통합채용-계약제교원인력풀-경력합산신청-대학학력-학력 팝업
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.09.14    
*******************************************************************************
*/

include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitPopup(this);
	// 파라메터 셋
	this.pv_params = this.smfGetPopupParams();
	// 팝업 타이틀 변경
	this.smfUpdatePopupTitle("대학학력");

};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid, errcd, errmsg){

}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.divContent04_btnContent01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSendResponseToOpener
	({
		"eduGrade" : this.divContent00.form.cboContent00.text, //학위구분
		"schName" : this.divContent00.form.edtContent01.value, // 학교명
		"schType" : this.divContent00.form.cboContent01.text, // 학교구분
		"transSdt" : this.divContent00.form.rdoContent00.text, // 편입여부
		"transSdtGrade" : this.divContent00.form.edtContent01_00.value,  // 편입 학년
		"studyBegin" : this.divContent01.form.calContent00.text, // 수학 시작 일자
		"studyEnd" : this.divContent01.form.calContent01.text, // 수학 종료 일자
		//"studyExceptTerm" : // 수학제외기간
		//"studyAcknowledgeTerm" : // 수학인정기간
		"major" : this.divContent00.form.edtContent00.value, // 전공학과
		"attachFl" : this.divContent03.form.div01.form.divFileContent00.form.edtFile.value, //증빙자료
	});
	this.close(true);
};
]]></Script>
