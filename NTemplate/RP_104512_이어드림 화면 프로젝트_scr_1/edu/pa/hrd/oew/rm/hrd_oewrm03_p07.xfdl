<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="formMain" width="800" height="410" titletext="계약제교원인력풀-경력합산신청-자격면허(교원자격) 팝업" onload="formMain_onload">
    <Layouts>
      <Layout height="410" width="800" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divMain00" taborder="1" left="20" height="95" top="20" text="" cssclass="div_WF_Detail" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="sta01" taborder="0" left="120" height="42" cssclass="sta_WF_Input02Top" top="0" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta00" taborder="1" left="0" width="120" height="42" cssclass="sta_WF_Input01Top" text="자격번호" top="0" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtLscNb" taborder="2" left="125" top="6" height="30" right="390" initvalueid="ivEdtNormal" text="제 19-0843749호" value="제 19-0843749호"/>
              <Button id="btnValidate" taborder="3" text="교원자격검증" left="376" top="6" width="96" height="30" cssclass="btn_WF_Custom" initvalueid="ivBtnAccessibilityButton"/>
              <CheckBox id="chk00" taborder="4" text="검증이 안되는 경우" left="600" top="52" height="30" right="0" initvalueid="ivChkNormal" value="false" onchanged="divMain00_chk00_onchanged" falsevalue="false" truevalue="true"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divMain01" taborder="2" text="div00" left="20" top="divMain00:0" height="226" right="20" cssclass="div_WF_Detail" visible="false">
          <Layouts>
            <Layout>
              <Static id="sta44_01" taborder="0" left="130" height="42" cssclass="sta_WF_Input02Top" top="0" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta05" taborder="1" left="130" height="42" cssclass="sta_WF_Input02" top="41" initvalueid="ivStcAccessibilityOff" width="250"/>
              <Static id="sta07" taborder="2" left="500" height="42" cssclass="sta_WF_Input02" top="41" initvalueid="ivStcAccessibilityOff" width="260"/>
              <Static id="sta09" taborder="3" left="130" height="42" cssclass="sta_WF_Input02" top="82" initvalueid="ivStcAccessibilityOff" right="0"/>
              <Static id="sta11" taborder="4" left="130" height="42" cssclass="sta_WF_Input02" top="123" initvalueid="ivStcAccessibilityOff" right="0"/>
              <Static id="sta13" taborder="5" left="130" height="42" cssclass="sta_WF_Input02" top="164" initvalueid="ivStcAccessibilityOff" right="0"/>
              <Static id="sta00" taborder="6" left="0" width="130" height="42" cssclass="sta_WF_Input01Top" text="교원자격증(종별)" top="0" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
              <Edit id="edtLscClf" taborder="7" left="135" top="6" height="30" initvalueid="ivEdtNormal" value="정교사" text="정교사" width="240" cssclass="essential"/>
              <Static id="sta02" taborder="8" left="380" width="120" height="42" cssclass="sta_WF_Input01Top" text="교원자격증(급별)" top="0" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
              <Edit id="edtLscGrd" taborder="9" left="505" top="6" height="30" initvalueid="ivEdtNormal" value="1급" text="1급" width="240" cssclass="essential"/>
              <Static id="sta04" taborder="10" left="0" width="130" height="42" cssclass="sta_WF_Input01" text="발급기관명(정교사 2급 기준)" top="41" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
              <Edit id="edtLscOrg" taborder="11" left="135" top="47" height="30" initvalueid="ivEdtNormal" value="서울시 교육청" text="서울시 교육청" width="240" cssclass="essential"/>
              <Static id="sta06" taborder="12" left="380" width="120" height="42" cssclass="sta_WF_Input01" text="표시과목" top="41" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtLscSbj" taborder="13" left="505" top="47" height="30" initvalueid="ivEdtNormal" value="수학" text="수학" width="240"/>
              <Static id="sta08" taborder="14" left="0" width="130" height="42" cssclass="sta_WF_Input01" text="발급일자" top="82" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn"/>
              <Calendar id="calContent00" taborder="15" left="135" top="88" width="130" height="30" dateformat="yyyy.MM.dd" initvalueid="ivCalNormal" editformat="yyyy.MM.dd"/>
              <Static id="sta10" taborder="16" left="0" width="130" height="42" cssclass="sta_WF_Input01" text="증명자료" top="123" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn"/>
              <Div id="divAttachFl" taborder="17" left="135" top="129" height="33" background="green" url="comm::comm_fileAdd2.xfdl" initvalueid="ivDivAccessibilityOff" right="89"/>
              <Static id="sta12" taborder="18" left="0" width="130" height="42" cssclass="sta_WF_Input01" text="비고내용" top="164" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtContent00" taborder="19" left="135" top="170" height="30" right="5" initvalueid="ivEdtNormal" value="비고내용" text="비고내용" onchanged="divMain01_edtContent00_onchanged"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnCancel" taborder="3" text="취소" height="30" width="50" left="43.25%" fittocontents="width" cssclass="btn_WF_Custom" initvalueid="ivBtnAccessibilityButton" top="359" onclick="btnCancel_onclick"/>
        <Button id="btnRegist" taborder="4" text="등록" height="30" width="50" fittocontents="width" left="btnCancel:8" initvalueid="ivBtnAccessibilityButton" top="359" onclick="btnRegist_onclick"/>
      </Layout>
    </Layouts>
    <Objects/>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-계약제교원인력풀-경력합산신청-자격면허(교원자격)정보 팝업
*  @MenuPath    pa_hrd_oew_rm
*  @FileName 	pa_hrd_oewrm03_p07.xfdl
*  @Creator 	
*  @CreateDate 	2022.9.14
*  @Desction    온라인통합채용-계약제교원인력풀-경력합산신청-자격면허(교원자격)정보 팝업
************** 소스 수정 이력 ***********************************************
*  date                Modifier            Description
*******************************************************************************
*  2022.9.14    	 	최지원             최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

	// default 초기처리를 한다.
	this.smfInitPopup(obj);

	// 파라메터 셋
	this.pv_params = this.smfGetPopupParams();
	
	// 팝업 타이틀 변경
	this.smfUpdatePopupTitle("자격면허(교원자격)정보");
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 
 /************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 
 /************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/**
 * 체크박스 선택 시
 */
this.divMain00_chk00_onchanged = function(obj:nexacro.CheckBox,e:nexacro.CheckBoxChangedEventInfo)
{
	
	if (obj.value === 'true')
	{
		this.divMain01.set_visible(true);
	} else 
	{
		this.divMain01.set_visible(false);
	}
	
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 /**
 * 확인버튼 클릭	
 */
this.btnRegist_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 입력값 부모창 전달
	this.smfSendResponseToOpener({
	
		"lisenceClassify" : this.divMain01.form.edtLscClf.value, // 자격종별
		//"취득일자" : 
		"lisenceGrade" : this.divMain01.form.edtLscGrd.value, // 자격급별
		"permissionOrg" : this.divMain01.form.edtLscOrg.value, // 발급기관
		"lisenceNo" : this.divMain00.form.edtLscNb.value, // 자격증번호
		"lisenceSubject" : this.divMain01.form.edtLscSbj.value, // 표시과목
		"attachFl" : this.divMain01.form.divAttachFl.form.edtFile.value, // 증빙 자료
		//"비고내용" : 
	});
	this.close(true);
};

/**
 * 취소버튼 클릭
 */
this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};

]]></Script>
  </Form>
</FDL>
