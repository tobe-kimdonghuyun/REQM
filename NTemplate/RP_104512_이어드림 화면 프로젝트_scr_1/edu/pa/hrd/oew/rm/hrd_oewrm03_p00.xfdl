          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle00" taborder="0" text="형집행일수" left="0" top="20" height="30" cssclass="img_WF_SubTit04" width="95" initvalueid="ivTitleAccessibilityOn"/>
              <Button id="btnContent00" taborder="1" text="추가" top="20" height="30" cssclass="btn_WF_Write" initvalueid="ivBtnAccessibilityButton" width="71" left="241" onclick="divContent02_btnContent00_onclick"/>
