    <Objects/>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-계약제교원인력풀-경력합산신청-군복무경력 팝업
*  @MenuPath    pa_hrd_oew_rm
*  @FileName 	pa_hrd_oewrm03_p00.xfdl
*  @Creator 	
*  @CreateDate 	2022.09.14
*  @Desction    온라인통합채용-계약제교원인력풀-경력합산신청-군복무경력 팝업
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.09.14    	
*******************************************************************************
*/

include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitPopup(this);
	// 파라메터 셋
	this.pv_params = this.smfGetPopupParams();
	// 팝업 타이틀 변경
	this.smfUpdatePopupTitle("군복무경력");
	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid, errcd, errmsg){

}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 등록 버튼 클릭
 */
this.divContent04_btnContent01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
	// 입력값 부모창 전달
	this.smfSendResponseToOpener({
	
		"militaryType" : this.divContent00.form.cboContent00.text, // 군별
		"serviceType" : this.divContent00.form.cboContent01.text, // 복무기간
		"obligation" : this.divContent00.form.rdoContent00.text, //의무복무여부		
		"rank" : this.divContent00.form.cboContent02.text, // 계급
		"periodService" : this.divContent01.form.calContent01.text + " ~ " + this.divContent01.form.calContent00.text, // 복무기간
		"executionDate" : this.divContent02.form.grdContent00.text, // 형집행일수
		//"walkOutDate" : this.divContent02.form.grdContent01.text, // 복무이탈기간
		//"realPeriodService" : this, // 실복무기간
		"attachFl" : this.divContent03.form.divFileContent00.form.edtFile.value // 증빙자료
	});
	
	this.close(true);

};

/**
 *  취소 버튼 클릭
 */
this.divContent04_btnContent00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};
]]></Script>
  </Form>
