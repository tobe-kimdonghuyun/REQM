              <Static id="staContent00" taborder="2" left="0" width="120" height="83" cssclass="sta_WF_Input01Top" text="복무기간" top="20" initvalueid="ivStcAccessibilityOn"/>
              <Static id="staContent01" taborder="3" left="119" height="42" cssclass="sta_WF_Input01TopRight_Box" text="부터" top="20" width="320" initvalueid="ivStcAccessibilityOn"/>
