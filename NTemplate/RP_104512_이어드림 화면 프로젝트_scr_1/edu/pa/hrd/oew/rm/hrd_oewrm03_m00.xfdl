	this.dsGraduInfo.setColumn(idx, 'minStudy', e.minStudy); // 최저 수업년한
	this.dsGraduInfo.setColumn(idx, 'nightClassYN', e.nightClassYN); // 계절.야간 여부
	this.dsGraduInfo.setColumn(idx, 'ownDate', e.ownDate); // 학위 취득일
	this.dsGraduInfo.setColumn(idx, 'studyBegin', e.studyBegin); // 수업 시작 일자
	this.dsGraduInfo.setColumn(idx, 'studyEnd', e.studyEnd); // 수업 종료 일자
	//this.dsGraduInfo.setColumn(idx, 'studyExceptDate', e.studyExceptDate); // 수업 제외 기간
	//this.dsGraduInfo.setColumn(idx, 'studyAcknowlDate', e.studyAcknowlDate); // 수업 인정 기간
	this.dsGraduInfo.setColumn(idx, 'attachFl', e.attachFl); // 증빙 자료
};

