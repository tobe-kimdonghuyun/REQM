 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){

}

// 군복무경력 추가 팝업 콜백
this.fnAdd00Callback = function(e, sender)
{
	//this.smfAlert("응답결과 ==>"+e);
	var idx = this.dsArmyCareer.addRow(); //로우 추가
	this.dsArmyCareer.setColumn(idx, 'militaryType', e.militaryType); //군별
	this.dsArmyCareer.setColumn(idx, 'serviceType', e.serviceType); // 복무형태
	this.dsArmyCareer.setColumn(idx, 'obligation', e.obligation); // 의무복무
	this.dsArmyCareer.setColumn(idx, 'rank', e.rank); // 계급
	this.dsArmyCareer.setColumn(idx, 'periodService', e.periodService); // 복무기간
	this.dsArmyCareer.setColumn(idx, 'executionDate', e.executionDate); // 형집행일수
	this.dsArmyCareer.setColumn(idx, 'walkOutDate', e.walkOutDate); // 이탈일수
	this.dsArmyCareer.setColumn(idx, 'attachFl', e.attachFl); // 증빙자료
};

// 교원경력 추가 팝업 콜백
this.fnAdd01Callback = function(e, sender)
{
	var idx = this.dsTeachCareer.addRow(); // 로우 추가
	this.dsTeachCareer.setColumn(idx, 'teachCareerClassify', e.teachCareerClassify); //교원 경력 구분
	this.dsTeachCareer.setColumn(idx, 'orgName', e.orgName); // 기관명
	this.dsTeachCareer.setColumn(idx, 'occupType', e.occupType); //직종
	this.dsTeachCareer.setColumn(idx, 'position', e.position); // 직급
	this.dsTeachCareer.setColumn(idx, 'careerBegin', e.careerBegin); // 시작일자
	this.dsTeachCareer.setColumn(idx, 'careerEnd', e.careerEnd); // 종료일자
	this.dsTeachCareer.setColumn(idx, 'retireYN', e.retireYN); // 정년퇴직 여부
	this.dsTeachCareer.setColumn(idx, 'payByHour', e.payByHour); // 시간제 여부
	this.dsTeachCareer.setColumn(idx, 'payByHourTime', e.payByHourTime); // 시간
	//this.dsTeachCareer.setColumn(idx, '제외일수', e.제외일수);
	//this.dsTeachCareer.setColumn(idx, '경력인정기간', e.경력인정기간);
	this.dsTeachCareer.setColumn(idx, 'attachFl', e.attachFl); // 증빙자료
	
};

// 교원외공무원경력 추가 팝업 콜백
this.fnAdd02Callback = function(e, sender){

	var idx = this.dsCivilCareer.addRow(); // 로우 추가
	
	this.dsCivilCareer.setColumn(idx, 'careerType', e.careerType); // 공무원경력구분
	this.dsCivilCareer.setColumn(idx, 'orgName', e.orgName); // 기관명
	this.dsCivilCareer.setColumn(idx, 'occupType', e.occupType); // 직종
	this.dsCivilCareer.setColumn(idx, 'position', e.position); // 직급(직위)
	this.dsCivilCareer.setColumn(idx, 'careerBegin', e.careerBegin); // 시작일자
	this.dsCivilCareer.setColumn(idx, 'careerEnd', e.careerEnd); // 종료 일자
	this.dsCivilCareer.setColumn(idx, 'retireYN', e.retireYN); // 정년퇴직여부
	this.dsCivilCareer.setColumn(idx, 'payByHourYN', e.payByHourYN); // 시간제 여부
	this.dsCivilCareer.setColumn(idx, 'payByHourTime', e.payByHourTime); // 시간
	//this.dsCivilCareer.setColumn(idx, '경력제외일수', e.경력제외일수);
	//this.dsCivilCareer.setColumn(idx, '경력인정기간', e.경력인정기간);
	this.dsCivilCareer.setColumn(idx, 'attachFl', e.attachFl); // 증빙자료
};

// 유사경력 추가 팝업 콜백
this.fnAdd03Callback = function(e, sender){

	var idx = this.dsSimilCareer.addRow(); //로우 추가
