	this.dsAddEdu.setColumn(idx, 'schName', e.schName); // 학교명
	this.dsAddEdu.setColumn(idx, 'schType', e.schType); // 학교 구분
	this.dsAddEdu.setColumn(idx, 'ownDate', e.ownDate); // 취득일자
	this.dsAddEdu.setColumn(idx, 'attachFl', e.attachFl); // 증빙 자료
	this.dsAddEdu.setColumn(idx, 'etc', e.etc); // 비고 내용
	
};

// 대학원정보 추가 팝업 콜백
this.fnAdd06Callback = function(e, sender){

	var idx = this.dsGraduInfo.addRow(); // 로우 추가
