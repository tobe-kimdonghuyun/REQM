	this.dsUniverInfo.setColumn(idx, 'transSdt', e.transSdt); // 편입 여부
	this.dsUniverInfo.setColumn(idx, 'transSdtGrade', e.transSdtGrade); // 편입학년
	this.dsUniverInfo.setColumn(idx, 'studyBegin', e.studyBegin); // 수강 시작 일자
	this.dsUniverInfo.setColumn(idx, 'studyEnd', e.studyEnd); // 수강 종료 일자
	//this.dsUniverInfo.setColumn(idx, 'studyExceptTerm', e.studyExceptTerm); // 수학 제외 기간
	//this.dsUniverInfo.setColumn(idx, 'studyAcknowledgeTerm', e.studyAcknowledgeTerm); // 수학 인정기간
	this.dsUniverInfo.setColumn(idx, 'major', e.major); // 전공학과
	this.dsUniverInfo.setColumn(idx, 'attachFl', e.attachFl); // 증빙자료

};

// 대학학력-추가학력 추가 팝업 콜백
this.fnAdd05Callback = function(e, sender){

	var idx = this.dsAddEdu.addRow(); // 로우 추가
