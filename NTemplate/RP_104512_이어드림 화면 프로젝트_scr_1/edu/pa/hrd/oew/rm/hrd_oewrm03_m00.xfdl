	//this.dsLisenInfo.setColumn(idx, '발급일자', e.발급일자); // 발급일자
	this.dsLisenInfo.setColumn(idx, 'lisenceClassify', e.lisenceClassify); // 자격종별
	this.dsLisenInfo.setColumn(idx, 'lisenceSubject', e.lisenceSubject); // 표시과목
	this.dsLisenInfo.setColumn(idx, 'permissionOrg', e.permissionOrg); // 발급기관
	this.dsLisenInfo.setColumn(idx, 'lisenceNo', e.lisenceNo); // 자격번호
	this.dsLisenInfo.setColumn(idx, 'attachFl', e.attachFl); // 증빙자료
	//this.dsLisenInfo.setColumn(idx, '비고내용', e.비고내용);
	
};

