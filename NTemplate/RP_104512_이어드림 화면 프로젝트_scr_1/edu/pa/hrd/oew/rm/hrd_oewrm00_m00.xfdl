<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="formMain" width="1200" height="780" titletext="계약제교원인력풀-전자근로계약서-사전동의서" onload="formMain_onload">
    <Layouts>
      <Layout height="780" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="70" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle00" taborder="0" text="전자근로계약서" left="0" top="0" height="44" cssclass="img_WF_SubTit01" initvalueid="ivTitleAccessibilityOn" right="970" tabstop="false"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staSubText3" taborder="1" left="0" top="134" height="26" cssclass="sta_WF_Black14" text="※ 아래의 내용을 읽으시고 동의하셔야 접수가 가능합니다." initvalueid="ivStcAccessibilityOn" fittocontents="none" right="820"/>
        <Div id="divContent00" taborder="2" left="0" height="466" cssclass="div_WF_InfoBOX" top="185" text="" initvalueid="ivDivAccessibilityOff" right="0">
          <Layouts>
            <Layout>
              <Div id="div00_00_00_00" taborder="0" left="30" height="382" cssclass="div_WF_InfoBOX" top="30" text="" initvalueid="ivDivAccessibilityOn" right="30" accessibilitylabel="개인정보 수집 및 이용에 관한 그룹박스">
                <Layouts>
                  <Layout>
                    <Static id="sta01" taborder="0" text="[개인정보 수집 및 이용에 관한 동의]" left="29" top="21" width="240" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn" usedecorate="false"/>
                    <Static id="sta00_00_01_01" taborder="1" left="30" top="61" height="307" text="가. 개인정보의 수집 및 이용 목적&#13;&#10;   ○ 계약제교원 채용자에 대해 신규채용절차에 따라 결격사유확인, 호봉합산신청, 전자근로계약체결하기 위함입니다.&#13;&#10;&#13;&#10;나. 수집하려는 개인정보의 항목&#13;&#10;   ○ 인사기록 호봉 산정 및 전자근로계약서 서명을 위해 아래와 같은 개인정보를 수집합니다.&#13;&#10;   ○ 성명, 주민등록번호, 전임경력, 병역, 학력, 교원자격 정보 호봉합산신청 및 전자근로계약 서명에 필요한 사항을 수집합니다.&#13;&#10;   ※ 주민등록번호는 「아동청소년의성보호에관한법률시행령」  제39조(민감정보 및 고유식별정보의 처리), 「소득세법」 제166조(주민등록 전산정보자료 등의 이용)에 &#13;&#10;      근거하여 처리합니다.&#13;&#10;&#13;&#10; &lt;b v='true'&gt;&lt;fs v='12'&gt;다. 개인정보의 보유 기간&#13;&#10;   ○ 수집한 개인정보는 근로기준법 제42조에 의해 3년 기간 동안 보유합니다. &lt;/fs&gt;&lt;/b&gt;&#13;&#10;&#13;&#10;라. 동의를 거부할 권리 및 동의 거부에 따른 제약사항&#13;&#10;   ○ 위 사항에 대하여 동의를 거부할 권리가 있으며 동의거부 시에는 본 사이트에서 제공하는 온라인 호봉합산신청서 제출 서비스를 이용할 수 없습니다.&#13;&#10;" wordWrap="char" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" verticalAlign="top" right="30" usedecorate="true"/>
                  </Layout>
                </Layouts>
              </Div>
              <CheckBox id="chkVal00" taborder="1" text="동의합니다." left="1060" top="422" width="110" height="30" initvalueid="ivChkNormal" onclick="divContent00_chkVal00_onclick"/>
              <Static id="staGd05" taborder="2" left="46" top="412" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="933" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staGd12" taborder="3" left="45" top="445" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="79" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnNext00" taborder="3" text="다음" left="534" top="690" width="130" height="40" cssclass="btn_WF_Action" initvalueid="ivBtnAccessibilityButton" onclick="btnNext00_onclick"/>
        <Static id="staGd00" taborder="4" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd01" taborder="5" left="31" top="114" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="879" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd03" taborder="6" left="30" top="650" height="40" cssclass="sta_GD_Size" text="40" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="610" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd12" taborder="7" left="0" height="50" cssclass="sta_GD_Size" text="50" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" top="730"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256" description="시도교육청코드"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-계약제교원인력풀-전자근로계약서-사전동의서
*  @MenuPath    pa_hrd_oew_rm
*  @FileName 	pa_hrd_oewrm00_m00.xfdl
*  @Creator 	최지원
*  @CreateDate 	2022.08.09
*  @Desction    온라인통합채용-계약제교원인력풀-전자근로계약서- 사전동의서
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.08.09    	최지원 	        최초 생성 
********************************************************************************/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	
	// Form의 default 초기처리를 한다.
	this.smfInitForm(this);

	// 시도 교육청 코드 SET
	this.dsSearch.setColumn(0, 'cddcCd', this.smfGetCddcCode());
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){

}

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 전체 체크 여부
this.fnIsAllChecked = function()
{
	this.divContent00.form.chkVal.set_value(
		this.divContent00.form.chkVal00.value && this.divContent00.form.chkVal01.value)
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// 전체 선택
this.divContent00_chkVal_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	this.divContent00.form.chkVal00.set_value(obj.value);
	this.divContent00.form.chkVal01.set_value(obj.value);
};

// 개인정보 수집 및 이용에 관한 동의
this.divContent00_chkVal00_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	this.fnIsAllChecked();
};

// 고유식별정보 수집 동의
this.divContent00_chkVal01_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	this.fnIsAllChecked();
};


// 다음 단계
this.btnNext00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 조건
	if( !this.divContent00.form.chkVal00.value  ) {
		this.divContent00.form.chkVal00.setFocus();
		this.smfAlert('개인정보 수집 및 이용에 대한 동의 후 진행 가능 합니다.');
		return false;
	}
	// PARAM
	var params = {
		// 시도교육청 코드
		cddcCd : this.dsSearch.getColumn(0, "cddcCd"),
	};
	this.smfSetWorkPage("pa_hrd_oew_rm::hrd_oewrm01_m00.xfdl", params);
};
]]></Script>
  </Form>
</FDL>
