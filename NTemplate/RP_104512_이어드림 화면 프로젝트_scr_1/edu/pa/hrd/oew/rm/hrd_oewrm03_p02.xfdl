    <Objects/>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-계약제교원인력풀-경력합산신청-교원외공무원경력 팝업
*  @MenuPath    pa_hrd_oew_rm
*  @FileName 	pa_hrd_oewrm03_p02.xfdl
*  @Creator 	
*  @CreateDate 	2022.09.14
*  @Desction    온라인통합채용-계약제교원인력풀-경력합산신청-교원외공무원경력 팝업
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.09.14    	
*******************************************************************************
*/

include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitPopup(this);
	// 파라메터 셋
	this.pv_params = this.smfGetPopupParams();
	// 팝업 타이틀 변경
	this.smfUpdatePopupTitle("교원외 공무원경력");

};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid, errcd, errmsg){

}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
//등록 버튼 클릭
this.divContent04_btnContent01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSendResponseToOpener
	({
		"careerType" : this.divContent00.form.cboContent00.text, // 공무원경력
		"orgName" : this.divContent00.form.edtContent00.value, // 기관명
		"occupType" : this.divContent00.form.cboContent01.text, // 직종
		"position" : this.divContent00.form.edtContent01.value, // 직급(쥑위)
		"careerBegin" : this.divContent01.form.calContent00.text, // 경력 시작일자
		"careerEnd" : this.divContent01.form.calContent01.text, // 경력 종료일자
		"retireYN" : this.divContent01.form.chkContent00.value, // 정년퇴직여부
		"payByHourYN" : this.divContent01.form.rdoContent00.text, // 시간제 여부
		"payByHourTime" : this.divContent01.form.edtContent00.value, // 시간
		//"경력제외일수" :
		//"경력인정기간" :
		"attachFl" : this.divContent03.form.div01.form.divFileContent00.form.edtFile.value //증빙자료
	});
	
	this.close(true);
};
]]></Script>
