    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-계약제교원인력풀-경력합산신청-대학학력-추가학력 팝업
*  @MenuPath    pa_hrd_oew_rm
*  @FileName 	pa_hrd_oewrm03_p05.xfdl
*  @Creator 	
*  @CreateDate 	2022.09.14
*  @Desction    온라인통합채용-계약제교원인력풀-경력합산신청-대학학력-추가학력 팝업
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.09.14
*******************************************************************************
*/

include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 초기화
this.formMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitPopup(this);
	// 파라메터 셋
	this.pv_params = this.smfGetPopupParams();
	// 팝업 타이틀 변경
	this.smfUpdatePopupTitle("대학학력(추가학력)");

};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 콜백
this.fnTransCallback = function(svcid, errcd, errmsg){

}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.divContent01_btnContent01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSendResponseToOpener
	({
		"grade" : this.divContent00.form.cboContent00_00.text, // 독학학위제
		"schName" : this.divContent00.form.edtContent00.value, // 학교명
		"schType" : this.divContent00.form.cboContent00.text, // 학교구분
		"ownDate" : this.divContent00.form.calContent00.text, // 취득일자
		"attachFl" : this.divContent00.form.divFileContent00.form.edtFile.value, // 증빙자료
		"etc" : this.divContent00.form.edtContent00_00.value, // 비고
	});
	this.close(true);

};
]]></Script>
