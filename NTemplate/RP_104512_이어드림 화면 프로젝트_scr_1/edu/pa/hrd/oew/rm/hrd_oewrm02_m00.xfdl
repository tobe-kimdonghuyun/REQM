                    <Button id="btnDetail02" taborder="1" text="상세 내역" top="15" height="30" fittocontents="width" cssclass="btn_WF_Function" visible="true" width="81" right="30" initvalueid="ivBtnAccessibilityButton" onclick="btnModal02_onclick"/>
