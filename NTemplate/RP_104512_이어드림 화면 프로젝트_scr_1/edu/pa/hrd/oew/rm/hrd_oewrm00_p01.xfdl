              <Row>
                <Col id="codecolumn">02</Col>
                <Col id="datacolumn">미동의</Col>
              </Row>
            </Rows>
          </Dataset>
        </Radio>
        <Button id="btnCancel" taborder="10" text="취소" left="34.25%" width="120" height="40" cssclass="btn_WF_ActionLine" top="590" initvalueid="ivBtnAccessibilityButton" onclick="btnCancel_onclick"/>
        <Button id="btnConfirm" taborder="11" text="확인" width="120" height="40" cssclass="btn_WF_Action" left="btnCancel:10" top="590" initvalueid="ivBtnAccessibilityButton" onclick="btnConfirm_onclick"/>
        <Static id="staGd00" taborder="12" left="20" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd22" taborder="13" left="20" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" bottom="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd02" taborder="14" left="20" top="90" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd14" taborder="15" left="20" top="355" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd21" taborder="16" left="20" top="550" height="40" cssclass="sta_GD_Size" text="40" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd08" taborder="17" left="21" top="222" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="19" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Objects/>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-계약제교원인력풀-전자근로계약서-사전동의서- 상세 팝업3
*  @MenuPath    pa_hrd_oew_rm
*  @FileName 	pa_hrd_oewrm00_p01.xfdl
*  @Creator 	
*  @CreateDate 	2022.9.14
*  @Desction    계약제교원인력풀-전자근로계약서-사전동의서- 행정정보 공동이용 팝업2
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.9.14    	 	         최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// default 초기처리를 한다.
	this.smfInitPopup(obj);
	// 파라메터 셋
	this.pv_params = this.smfGetPopupParams();
	// 부모화면으로부터 받은 동의여부 초기값 설정 
	this.popupRdo00.set_value(this.pv_params.agreeValue); 
	
	// 팝업 타이틀변경
	this.smfUpdatePopupTitle("행정정보 공동이용 동의서");
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
//동의여부 선택 여부
this.fnRadioChoice = function(){
	// opener Res
	this.smfSendResponseToOpener({
		"agreeValue": this.popupRdo00.value
	});
	this.close(true);
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 확인버튼 클릭	
 */
this.btnConfirm_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnRadioChoice();
	
};
/**
 * 취소버튼 클릭
 */
this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};
]]></Script>
  </Form>
</FDL>
