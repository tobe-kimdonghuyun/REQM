<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="popupForm" width="800" height="650" titletext="계약제교원인력풀-전자근로계약서-사전동의서-행정정보 공동이용 동의서" onload="form_onload" canlayoutchange="btnCancel_onclick">
    <Layouts>
      <Layout height="650" width="800" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <ImageViewer id="imgTitle00" taborder="1" text="행정정보 공동이용 사전동의서" left="20" top="16" width="232" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="staContent00" taborder="2" text="가. 이용기관 명칭" left="19" top="69" width="220" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divContent00" taborder="3" left="20" height="78" cssclass="div_WF_InfoBOX" right="20" top="99" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staContent00" taborder="0" left="24" top="14" height="49" cssclass="sta_WF_Black14" text="○○○교육청" wordWrap="char" right="20" initvalueid="ivStcAccessibilityOn" onclick="div00_sta00_00_01_01_onclick"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staContent01" taborder="4" text="나. 수집·이용 목적" left="19" top="203" width="220" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divContent01" taborder="5" left="20" height="78" cssclass="div_WF_InfoBOX" right="20" top="232" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staContent00" taborder="0" left="24" top="12" cssclass="sta_WF_Black14" wordWrap="char" right="20" initvalueid="ivStcAccessibilityOn" onclick="div00_sta00_00_01_01_onclick" height="49"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staContent02" taborder="6" text="다. 공동이용 행정정보" left="19" top="336" width="220" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divContent03" taborder="7" left="20" height="78" cssclass="div_WF_InfoBOX" right="20" top="365" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staContent00" taborder="0" left="24" top="12" cssclass="sta_WF_Black14" text="" wordWrap="char" right="20" initvalueid="ivStcAccessibilityOn" onclick="div00_sta00_00_01_01_onclick" height="49"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staContent03" taborder="8" left="18" top="461" height="45" cssclass="sta_WF_Black14" text="위의 개인정보 제공에 대한 동의를 거부할 권리가 있습니다. &#13;&#10;&lt;b v='true'&gt;동의를 거부할 경우 지원서 작성에  제한을 받을 수 있습니다.&lt;/b&gt;" usedecorate="true" right="80" initvalueid="ivStcAccessibilityOn"/>
        <Radio id="popupRdo00" taborder="9" top="524" width="137" height="33" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" rowcount="-1" value="01" text="동의" index="0" right="26" initvalueid="ivRdoNormal">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row>
                <Col id="codecolumn">01</Col>
