<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmMain" width="1200" height="468" titletext="계약제교원인력풀-전자근로계약서" onload="frmMain_onload">
    <Layouts>
      <Layout height="468" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="70" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle00" taborder="0" text="전자근로계약서" left="0" top="0" height="44" cssclass="img_WF_SubTit01" width="220" initvalueid="ivTitleAccessibilityOn" onclick="divTitle_imgTitle00_onclick"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staGd00" taborder="1" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGd01" taborder="2" left="0" top="113" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Div id="divLicenceInfo" taborder="3" left="0" top="144" height="324" right="0" cssclass="div_WF_Detail" initvalueid="ivDivAccessibilityOff" text="">
          <Layouts>
            <Layout>
              <Grid id="grdLicence" taborder="0" left="0" top="1" height="319" autofittype="col" right="0" binddataset="dsList" selecttype="cell" initvalueid="ivGrdAccessibilityOn" autoenter="select" autosizingtype="row" extendsizetype="row" nodatatext="등록 자료가 없습니다." oncellclick="divLicenceInfo_grdLicence_oncellclick" accessibilitylabel="근로계약서목록">
                <Formats>
                  <Format id="default">
                    <Columns>
                      <Column size="198"/>
                      <Column size="443"/>
                      <Column size="121"/>
                      <Column size="121"/>
                      <Column size="150"/>
                      <Column size="116"/>
                    </Columns>
                    <Rows>
                      <Row size="36" band="head"/>
                      <Row size="40"/>
                    </Rows>
                    <Band id="head">
                      <Cell text="계약기간"/>
                      <Cell col="1" text="기관명"/>
                      <Cell col="2" colspan="2" text="전자서명"/>
                      <Cell col="4" text="근로계약서"/>
                      <Cell col="5" text="진행상태"/>
                    </Band>
                    <Band id="body">
                      <Cell text="bind:cttYmd" textAlign="center" wordWrap="char" padding="10px 10px"/>
                      <Cell col="1" textAlign="center" wordWrap="char" text="bind:instNm" padding="10px 10px"/>
                      <Cell col="2" textAlign="center" wordWrap="char" displaytype="expr:lbrCtrbStsCd == '30' ? 'buttoncontrol' : 'none'" edittype="expr:lbrCtrbStsCd == '30' ? 'button' : 'none'" text="expr:lbrCtrbStsCd == '30' ? '직접 서명' : ''" padding="10px 10px"/>
                      <Cell col="3" textAlign="center" wordWrap="char" displaytype="expr:lbrCtrbStsCd == '30' ? 'buttoncontrol' : 'none'" edittype="expr:lbrCtrbStsCd == '30' ? 'button' : 'none'" text="expr:lbrCtrbStsCd == '30' ? '인증서 서명' : ''" padding="10px 10px"/>
                      <Cell col="4" textAlign="center" wordWrap="char" displaytype="buttoncontrol" edittype="button" text="계약서파일보기" padding="10px 10px"/>
                      <Cell col="5" calendardateformat="yyyy-MM-dd " textAlign="center" wordWrap="char" text="bind:lbrCtrbStsNm" padding="10px 10px"/>
                    </Band>
                  </Format>
                </Formats>
              </Grid>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divPdfViewer" taborder="4" left="670" top="50" width="82" height="66" url="comm::comp_pdfviewer.xfdl"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-계약제교원인력풀-전자근로계약서
*  @MenuPath    pa_hrd_oew_rm
*  @FileName 	pa_hrd_oewrm01_m00.xfdl
*  @Creator 	
*  @CreateDate 	2022.9.16
*  @Desction    계약제교원인력풀-전자근로계약서리스트 화면
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.09.16    	 	        최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs"
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);
	var sCddcCd = this.smfGetCddcCode();
	this.dsSearch.setColumn(0, "ctrsTchRrno"     , nexacro.base64Decode(this.smfGetSessionValue('userRrno')));
	this.dsSearch.setColumn(0, "cddcScCd"        , sCddcCd.slice(0,3));
	this.dsSearch.setColumn(0, "onlEmpmnExamScCd", this.smfGetAppoExamScCd());

	// 내역조회 
	this.fnSearchList("S");
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){

};

// 사인 완료 후 저장
this.fnPdfCallback = function(sData)
{
	this.smfSaveService("saveContract")
		.showConfirm(false)
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			// 내역조회 
			this.dsSearch.setColumn(0,"searchKey", "");
			this.fnSearchList("R");
	});	
};

this.fnPopupCallback = function(e, sender){
};

//인증서 성공 후 저장 
this.fnContractCoprCertSignResult = function(resultYn){
	if(resultYn == "Y"){
		this.fnSearchDetail( this.dsList.rowposition , "01" ); 
	}
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
// 근로계약서 목록 검색
//searchGb : R:재조회 , S: 처음조회
this.fnSearchList = function(searchGb)
{
	this.dsSearch.setColumn(0,"searchGb", searchGb);
	
	this.dsList.clearData();
	this.smfSearchService('listContract') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			var signMthCd = this.dsSignMth.getColumn(0,"signMthCd");
			//근로계약서 사인방법에 따른 표시 
			if(searchGb == "S"){
				if(signMthCd == "02"){  //직접 1
					this.divLicenceInfo.form.grdLicence.setRealColSize( "body", "3" , 0);
				}else if(signMthCd == "03"){ //인증서
					this.divLicenceInfo.form.grdLicence.setRealColSize( "body", "2" , 0);
				}else if(signMthCd == "X"){ //서명요청 없음 
					this.divLicenceInfo.form.grdLicence.setRealColSize( "body", "2" , 0);
					this.divLicenceInfo.form.grdLicence.setRealColSize( "body", "3" , 0);
				}
			}else{
				if(signMthCd == "X"){ //서명요청 없음 
					this.divLicenceInfo.form.grdLicence.setRealColSize( "body", "2" , 0);
					this.divLicenceInfo.form.grdLicence.setRealColSize( "body", "3" , 0);
				}
			}
	});
};

//근로계약서 상세 조회 
//sSignMthCd : (01: 인증서 서명 , 02 : 직접서명, 03 : 계약서 파일보기 )
this.fnSearchDetail = function(nRow , sSignMthCd)
{
	var sCddcCd = this.smfGetCddcCode();
	this.dsSearch.setColumn(0, "cddcScCd"     , sCddcCd.slice(0,3)); // 시도교육청 앞 3자리 = 시도교육청 구분코드
	this.dsSearch.setColumn(0, "cddcCd"       , sCddcCd); // 선택 시도교육청코드
	this.dsSearch.setColumn(0, "searchKey"    , this.dsList.getColumn(nRow, "searchKey"));
	this.dsSearch.setColumn(0, "instCd"       , this.dsList.getColumn(nRow, "instCd"));
	this.dsSearch.setColumn(0, "lbrCtrbOtlId" , this.dsList.getColumn(nRow, "lbrCtrbOtlId"));
	this.dsSearch.setColumn(0, "lbrCtrbSn"    , this.dsList.getColumn(nRow, "lbrCtrbSn"));
	this.dsSearch.setColumn(0, "signMthCd"    , sSignMthCd);
	
	if(sSignMthCd == "01"){ //인증서 서명일 경우 
		this.dsSearch.setColumn(0, "signWdsFileCn"   , this.dsSignMth.getColumn(0,"signWdsFileCn"));
		this.dsSearch.setColumn(0, "signWdsFileNm"   , this.dsSignMth.getColumn(0,"signWdsFileNm"));
	}
	
	this.smfSearchService('listContractDetail') 
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		if(this.dsResult.rowcount > 0 ){
			this.dsSearch.setColumn(0, "fileName", this.dsResult.getColumn(0,"atchFileGuid") );

			if( sSignMthCd == "02" ){ //직접서명 
				var sOrgPath     = this.dsResult.getColumn(0,"copyPath"); 
				var sResultPath  = "/edufile/temp/cm/pdfviewer/" + this.dsSearch.getColumn(0,"searchKey") + "/" + this.dsResult.getColumn(0,"atchFileGuid") ; 
				var popupParams = {
					callback: this.fnPopupCallback, // 콜백함수 지정
					sender: obj, // sender 지정
					params: {
						// 처리타입 지정(필수)
						   procType: "none" 
						,  viewtype   : "sign"                     // 표시 종류 ("view","sign")
						,  orgPath    : sOrgPath                   // 원본PDF 경로(orgPath)
						,  resultPath : sResultPath                // 사인이 추가된 결과PDF를 저장할 경로(resultPath)
						,  signWidth  : "2"                        // 사인의 넓이(signWidth)
						,  posText    : "SIGN"                     // 서명을 날인할 위치Text(posText)
						,  title      : ""                         // 팝업의 타이틀(title)
						,  callback   : this.fnPdfCallback         // callback함수
						,  objForm    : this                       // callback이 있는 Form Object
					},
				};
				// 모달팝업 실행
				this.smfDialog("_auto", "comm::comm_pdfviewerPopup.xfdl", popupParams,null,null,1200,900);
			}else if(sSignMthCd == "01" ){ //인증서 서명 
				this.fnPdfCallback();
			}else{
				//조회
				var sOrgPath = this.dsResult.getColumn(0,"copyPath");
				var popupParams = {
						callback: this.fnPopupCallback, // 콜백함수 지정
						sender: obj, // sender 지정
						// 팝업 전달 파라메터 지정
						params: {
							procType: "none"  
							// 파라메터 전달
							,  viewtype : "view"               // 표시 종류 ("view","sign")
							,  path     : sOrgPath             // PDF파일경로(path)
							,  download : "false"              // 다운기능 사용여부(사용:"true",미사용:"false"(default))
							,  print    : "false"              // 인쇄기능 사용여부(사용:"true",미사용:"false"(default))
							,  annot    : "false"              // 주석기능 사용여부(사용:"true",미사용:"false"(default))
							,  title    : "PFD 뷰어"          // 팝업의 타이틀(title)
						},
					};
					// 모달팝업 실행
					this.smfDialog("_auto", "comm::comm_pdfviewerPopup.xfdl", popupParams,null,null,1200,900);
			}
		}
	});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.divLicenceInfo_grdLicence_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{	
	//진행상태 코드 
	var lbrCtrbStsCd = this.dsList.getColumn(e.row, "lbrCtrbStsCd");
	if(  (lbrCtrbStsCd < 40 &&  ( e.cell == "2" || e.cell == "3" ))  ||  e.cell == "4" ){
	
		if (e.cell == "2" ){ //직접서명 
			this.fnSearchDetail(e.row , "02"); 
		}else if( e.cell == "3" ){ //인증서서명
			this.fnContractCoprCertSign();
		}else{  //계약서파일보기 
			this.fnSearchDetail(e.row , "03"); 
		}	
	}
};]]></Script>
    <Objects>
      <Dataset id="dsList" useclientlayout="true">
        <ColumnInfo>
          <Column id="cttBgngYmd" type="STRING" size="256" description="계약시작일자"/>
          <Column id="cttEndYmd" type="STRING" size="256" description="계약종료일자"/>
          <Column id="lbrCtrbStsNm" type="STRING" size="256"/>
          <Column id="cttYmd" type="STRING" size="256" description="계약기간"/>
          <Column id="lbrCtrbWrtFileRefrnId" type="STRING" size="256" description="근로계약서작성파일참조ID"/>
          <Column id="lbrCtrbSignFileRefrnId" type="STRING" size="256" description="근로계약서서명파일참조ID"/>
          <Column id="lbrCtrbFileRefrnId" type="STRING" size="256" description="근로계약서파일참조ID"/>
          <Column id="searchKey" type="STRING" size="256"/>
          <Column id="instNm" type="STRING" size="256"/>
          <Column id="lbrCtrbStsCd" type="STRING" size="256"/>
          <Column id="instCd" type="STRING" size="256"/>
          <Column id="lbrCtrbOtlId" type="STRING" size="256"/>
          <Column id="lbrCtrbSn" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsOutFileinfo">
        <ColumnInfo>
          <Column id="fileRefrnId" type="STRING" size="256" description="파일SEQ ID"/>
          <Column id="fileId" type="STRING" size="256" description="파일 아이디"/>
          <Column id="suc" type="STRING" size="256"/>
          <Column id="atchFileNm" type="STRING" size="256" description="파일명"/>
          <Column id="atchFileGuid" type="STRING" size="256" description="파일 GUID"/>
          <Column id="atchFileMg" type="STRING" size="256"/>
          <Column id="fileExtsnNm" type="STRING" size="256" description="파일확장자"/>
          <Column id="minTypeNm" type="STRING" size="256" description="파일의 mime type"/>
          <Column id="fileCoursNm" type="STRING" size="256" description="서버파일저장위치"/>
          <Column id="fileObjKey" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listContract</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsList=dsList dsSignMth=dsSignMth</Col>
            <Col id="url">ore_oew_rm33_001.do</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="id">listContractDetail</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResult=dsResult</Col>
            <Col id="url">ore_oew_rm33_002.do</Col>
          </Row>
          <Row>
            <Col id="id">saveContract</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="url">ore_oew_rm33_003.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="false" updatecontrol="false">
        <ColumnInfo>
          <Column id="cddcScCd" type="STRING" size="256" description="접속시도교육청 구분코드"/>
          <Column id="ctrsTchRrno" type="STRING" size="256" description="주민번호"/>
          <Column id="searchKey" type="STRING" size="256"/>
          <Column id="onlEmpmnExamScCd" type="STRING" size="256"/>
          <Column id="instCd" type="STRING" size="256"/>
          <Column id="lbrCtrbOtlId" type="STRING" size="256"/>
          <Column id="lbrCtrbSn" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="fileName" type="STRING" size="256"/>
          <Column id="searchGb" type="STRING" size="256"/>
          <Column id="signMthCd" type="STRING" size="256"/>
          <Column id="signWdsFileCn" type="BLOB" size="256"/>
          <Column id="signWdsFileNm" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="ctrsTchRrno">[Xi8lbYkBez7mC3funBjB3g==</Col>
            <Col id="cddcScCd">K10</Col>
            <Col id="onlEmpmnExamScCd"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsResult" useclientlayout="true">
        <ColumnInfo>
          <Column id="fileRefrnId" type="string" size="256"/>
          <Column id="fileId" type="string" size="256"/>
          <Column id="suc" type="string" size="256"/>
          <Column id="atchFileNm" type="string" size="256"/>
          <Column id="atchFileGuid" type="string" size="256"/>
          <Column id="atchFileMg" type="string" size="256"/>
          <Column id="fileExtsnNm" type="string" size="256"/>
          <Column id="minTypeNm" type="string" size="256"/>
          <Column id="fileCoursNm" type="string" size="256"/>
          <Column id="fileObjKey" type="string" size="256"/>
          <Column id="fileEncryptYn" type="string" size="256"/>
          <Column id="fileSaveStg" type="string" size="256"/>
          <Column id="copyPath" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSignMth" useclientlayout="true">
        <ColumnInfo>
          <Column id="signMthCd" type="STRING" size="256"/>
          <Column id="signWdsFileCn" type="BLOB" size="256"/>
          <Column id="signWdsFileNm" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
  </Form>
</FDL>
