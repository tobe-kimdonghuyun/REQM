    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-계약제교원인력풀-자격면허(교원자격)정보 팝업
*  @MenuPath    pa_hrd_oew_ap
*  @FileName 	pa_hrd_oewap02_p03.xfdl
*  @Creator 	
*  @CreateDate 	2022.8.30
*  @Desction    온라인통합채용-계약제교원인력풀-자격면허(교원자격)정보 팝업
************** 소스 수정 이력 ***********************************************
*  date                Modifier            Description
*******************************************************************************
*  2022.8.30    	 	최지원             최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

	// default 초기처리를 한다.
	this.smfInitPopup(obj);

	// 파라메터 셋
	this.pv_params = this.smfGetPopupParams();
	
	// 팝업 타이틀 변경
	this.smfUpdatePopupTitle("자격면허(교원자격)정보");
	
	// 공통코드 조회
	// dsIndctSbjtCd : 표시과목코드 dsTchQlfAsortScCd 교원자격종별구분코드 dsLsgByScCd자격급별구분코드
	this.smfCodeList("code", [this.dsIndctSbjtCd, this.dsTchQlfAsortScCd, this.dsLsgByScCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		}).run();
	
	// 파일 업로드
	this.divMain02.form.divFileContent.UPLOAD_UploadComplete  = this.fnFileUploadCompleteCallback;
	this.divMain02.form.divFileContent.UPLOAD_OnError         = this.fnFileUploadErrorCallback;
	this.divMain02.form.divFileContent.UPLOAD_AfterAddFile    = this.fnFileUploadChangeCallback;     
	this.divMain02.form.divFileContent.UPLOAD_Form            = this;

};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 파일 업로드 성공 콜백
this.fnFileUploadCompleteCallback = function(obj, paramObj, objResultDataset)
{
	this.divMain02.form.divFileContent.form.fnSetUploadCompleteState(obj,paramObj);
	this.dsMain.setColumn(0, "fileRefrnId", objResultDataset.getColumn(0, "fileRefrnId"));
	this.dsMain.setColumn(0, "atchFileNm", objResultDataset.getColumn(0, "atchFileNm"));
	// 23.07.19 싱글파일 처리. fileRefrnId 하나에 하나의 파일만 업로드, 업로드 변경할 때 새로운 fileRefrnId 생성을 위해 fnResetUpload 
	this.divMain02.form.divFileContent.form.fnResetUpload();
	// 23.07.19 리셋으로 인해 파일명 미표시되는 것 set
	this.divMain02.form.divFileContent.form.edtFile.set_value(this.dsMain.getColumn(0, "atchFileNm"));
};

// 파일 업로드 실패 콜백
this.fnFileUploadErrorCallback = function(obj, paramObj)
{
	//this.smfAlert('파일 업로드에 실패 하였습니다.');
};

// 파일 업로드 변경 콜백
this.fnFileUploadChangeCallback = function(obj, paramObj, sCustomValue, sFileName, nFileSize)
{
	this.divMain02.form.divFileContent.form.fnFileUpload();	
};
 
 /************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 
 /************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/**
 * 체크박스 선택 시
 */
this.divMain00_chk00_onchanged = function(obj:nexacro.CheckBox,e:nexacro.CheckBoxChangedEventInfo)
{
	if (this.dsMain.getColumn(0, "tchQlfVrfcYn") == "Y")
	{

		this.smfConfirm("직접입력을 선택하면 미검증 상태로 변경됩니다. \n 직접입력하시겠습니까?", function(result) 
		{
			if (result.confirmResult)
			{
					this.divMain00.form.chk00.set_value("N");
					this.dsMain.setColumn(0, "tchQlfVrfcYn", "N");
					/*this.divMain00.form.btnValidate.set_enable(true);*/
					this.divMain02.set_enable(true);
					this.divMain02.form.edtLscNo.set_enable(true);
					this.divMain02.form.cboTchQlfAsortScCd.set_enable(true);
					this.divMain02.form.cboLsgByScCd.set_enable(true);
					this.divMain02.form.cboIndctSbjtCd.set_enable(true);
					this.divMain02.form.edtLscOrg.set_enable(true);
					this.divMain02.form.divFileContent.set_enable(true);
					this.divMain00.form.sta02.set_text("미검증");
					return;
			} else {		
				this.divMain00.form.chk00.set_value("Y");
				return;
			}
		});
	} else if (obj.value == "N") {
		this.divMain02.set_enable(true);
		this.divMain02.form.edtLscNo.set_enable(true);
		this.divMain02.form.cboTchQlfAsortScCd.set_enable(true);
		this.divMain02.form.cboLsgByScCd.set_enable(true);
		this.divMain02.form.cboIndctSbjtCd.set_enable(true);
		this.divMain02.form.edtLscOrg.set_enable(true);
		this.divMain02.form.divFileContent.set_enable(true);
		this.divMain00.form.sta02.set_text("미검증");
		this.dsMain.setColumn(0, "tchQlfVrfcYn", "N");
		return;
	}  
	
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 /**
 * 교원자격검증 버튼
 */
this.divMain00_btnValidate_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 교원자격 param set (Test code)
	var cddcCd = this.smfGetCddcCode();
	this.dsCtrNo.setColumn(0, "cddcCd", cddcCd.slice(0,3));	
 	this.dsCtrNo.setColumn(0, "tchQlflCtrNo" , this.divMain00.form.edtLscNo.value);
 	this.dsCtrNo.setColumn(0, "flNm"         , this.pv_params.flNm);	
	this.dsCtrNo.setColumn(0, "applpRrno"    , this.pv_params.brdt.substring(2));
// 	console.log(this.dsCtrNo.getColumn(0, 'tchQlflCtrNo'));
// 	console.log(this.dsCtrNo.getColumn(0, 'cddcCd'));
// 	console.log(this.dsCtrNo.getColumn(0, 'flNm'));
// 	console.log(this.dsCtrNo.getColumn(0, 'applpRrno'));
	// 자격번호 
	if(this.smfIsNull(this.divMain00.form.edtLscNo.value)){
		this.divMain00.form.edtLscNo.setFocus();
		this.smfAlert("자격번호를 입력하세요.");
		return;
	}
	
	// 교원자격 검증 API
	this.smfSearchService('selectApi') 
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
				if(this.dsChk.rowcount > 0){
					this.smfAlert("자격면허검증이 완료되었습니다.");
					this.divMain02.set_enable(false);
					this.divMain02.form.cboTchQlfAsortScCd.set_value(this.dsChk.getColumn(0,"tchQlfAsortScCd"));
					this.divMain02.form.cboLsgByScCd.set_value(this.dsChk.getColumn(0,"lsgByScCd"));
					this.divMain02.form.cboIndctSbjtCd.set_value(this.dsChk.getColumn(0,"indctSbjtCd"));
					this.divMain02.form.edtLscOrg.set_value(this.dsChk.getColumn(0,"tchQlfInstCdNm"));
					/*this.divMain02.form.edtLscNo.set_enable(false);*/
					this.divMain02.form.edtLscNo.set_value(this.divMain00.form.edtLscNo.value);
					this.divMain00.form.chk00.set_enable(true);
					this.divMain00.form.chk00.set_value("Y");
					this.divMain00.form.sta02.set_text("검증완료");
					this.dsMain.setColumn(0, "tchQlfVrfcYn", "Y");
					this.dsMain.setColumn(0, "fileRefrnId", null);
					this.dsMain.setColumn(0, "atchFileNm", null);
					this.divMain02.form.divFileContent.form.edtFile.set_value();
				}else{
					this.smfAlert("자격번호를 다시한번 확인 바랍니다.\n직접입력 체크 후 수동입력이 가능합니다.");
					this.divMain02.form.edtLscNo.set_value(this.divMain00.form.edtLscNo.value);
					this.divMain00.form.chk00.set_enable(true);
					this.dsMain.setColumn(0, "tchQlfVrfcYn", "N");
					this.divMain00.form.sta02.set_text("미검증");
				}
		
	});	
	this.dsChk.clearData();
};
 
 /**
 * 확인버튼 클릭	
 */
this.btnRegist_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.dsMain.getColumn(0, "tchQlfVrfcYn") == "N" && this.divMain00.form.chk00.value == "Y") {
		this.divMain00.form.chk00.setFocus();
		this.smfAlert("교원자격 미검증 상태로 직접입력을 체크해주세요.");
		return;
	}
	// 자격번호
	if(this.smfIsNull(this.divMain02.form.edtLscNo.value)) 
	{
		this.divMain00.form.edtLscNo.setFocus();
		this.smfAlert('자격번호를 입력하세요');
		return;
	}
	// 교원자격(종별)
	if (this.smfIsNull(this.divMain02.form.cboTchQlfAsortScCd.value)) 
	{
		this.divMain02.form.cboTchQlfAsortScCd.setFocus();		
		this.smfAlert('교원자격(종별)을 입력하세요');
		this.divMain00.form.chk00.set_enable(true);
		return;
	}
	// 교원자격(급별)
	if(this.smfIsNull(this.divMain02.form.cboLsgByScCd.value)) 
	{
		this.divMain02.form.cboLsgByScCd.setFocus();
		this.smfAlert('교원자격(급별)을 입력하세요');
		return;
	}
	
	// 발급기관명
	if(this.smfIsNull(this.divMain02.form.edtLscOrg.value)) 
	{
		this.divMain02.form.edtLscOrg.setFocus();
		this.smfAlert('발급기관명을 입력하세요');
		return;
	}
	
	if(this.dsMain.getColumn(0, "tchQlfVrfcYn") != "Y") {
		// 증명자료 
		if( this.smfIsNull(this.dsMain.getColumn(0, "fileRefrnId")))
		{ 
			this.divMain02.form.divFileContent.setFocus();
			this.smfAlert('교원자격 증명자료가 필요합니다.');
			return;
		} 
	}
	

		


	// 입력값 부모창 전달 
	this.smfSendResponseToOpener({
	"tchQlfAsortScCd"	 	: this.divMain02.form.cboTchQlfAsortScCd.value, 	// 자격종별코드 
	"tchQlfAsortScCdNm" 	: this.divMain02.form.cboTchQlfAsortScCd.text, 		// 자격종별명칭
	"lsgByScCd" 			: this.divMain02.form.cboLsgByScCd.value, 			// 자격급별 
	"lsgByScCdNm" 			: this.divMain02.form.cboLsgByScCd.text, 			// 자격급별명칭	
	"issuInstNm" 			: this.divMain02.form.edtLscOrg.value, 				// 발급기관 
	"qlflLseNo" 			: this.divMain02.form.edtLscNo.value,			 	// 자격증번호
	"indctSbjtCd" 			: this.divMain02.form.cboIndctSbjtCd.value, 		// 표시과목 
	"indctSbjtCdNm" 		: this.divMain02.form.cboIndctSbjtCd.text, 			// 표시과목명
	"tchQlfVrfcYn" 			: this.dsMain.getColumn(0, "tchQlfVrfcYn"), 		// 검증체크
	"fileRefrnId" 			: this.dsMain.getColumn(0, "fileRefrnId"), 			// 파일참조ID
	"atchFileNm" 			: this.dsMain.getColumn(0, "atchFileNm"), 			// 첨부파일명
	"flagAdd"				: "Y"
	});

	this.close(true);
};

/**
 * 취소버튼 클릭
 */
this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};


// 검증 완료 후 자격번호 변경 시 
this.divMain00_edtLscNo_onchanged = function(obj:nexacro.Edit,e:nexacro.ChangeEventInfo)
{
	this.dsMain.setColumn(0, "tchQlfVrfcYn", "N");
	this.divMain00.form.sta02.set_text("미검증");
	this.divMain02.form.edtLscNo.set_value(this.divMain00.form.edtLscNo.value);
	this.divMain02.form.cboTchQlfAsortScCd.set_value();
	this.divMain02.form.cboLsgByScCd.set_value();
	this.divMain02.form.cboIndctSbjtCd.set_value();
	this.divMain02.form.edtLscOrg.set_value();
	return;
};
]]></Script>
  </Form>
</FDL>
