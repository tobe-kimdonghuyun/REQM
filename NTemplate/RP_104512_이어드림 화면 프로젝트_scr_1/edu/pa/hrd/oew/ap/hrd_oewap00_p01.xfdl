<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="popupForm" width="800" height="650" titletext="계약제교원인력풀-취업대상자 연계검증 활용 동의서" onload="popupForm_onload" canlayoutchange="btnCancel_onclick">
    <Layouts>
      <Layout height="650" width="800" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <ImageViewer id="imgTitle00" taborder="1" text="취업대상자 연계검증 활용 동의서" left="20" top="16" width="260" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="staSubTit00" taborder="2" text="가. 수집·이용 항목" left="19" top="69" width="140" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
        <Div id="div00" taborder="3" left="20" height="78" cssclass="div_WF_InfoBOX" right="20" top="99" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staContents00" taborder="0" left="24" top="14" height="49" cssclass="sta_WF_Black14" text="성명, 성별, 생년월일, 나이, 이메일, 연락처, 특이사항, 자격증, 희망지역, 시간강사, 희망여부, 현(전)근무기관, 계약만료일, 직명, 주소, 학력, 경력, 성적, 채용 등록정보" wordWrap="char" right="20" initvalueid="ivStcAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staSubTit01" taborder="4" text="나. 수집·이용 목적" left="19" top="203" width="140" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
        <Div id="div00_00" taborder="5" left="20" height="78" cssclass="div_WF_InfoBOX" right="20" top="232" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staContents01" taborder="0" left="24" top="12" cssclass="sta_WF_Black14" text="온라인 교원 채용 등재 및 호봉확정을 위한 경력, 자격, 최종학력 확인" wordWrap="char" right="20" initvalueid="ivStcAccessibilityOn" height="49"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staSubTit02" taborder="6" text="다. 보유기간" left="19" top="336" width="140" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
        <Div id="div00_00_00" taborder="7" left="20" height="78" cssclass="div_WF_InfoBOX" right="20" top="365" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staContents02" taborder="0" left="24" top="12" cssclass="sta_WF_Black14" text="채용연도 이듬해 1월1일부터 3년간 또는 본인의 채용 등록 취소 요청 전까지 보유" wordWrap="char" right="20" initvalueid="ivStcAccessibilityOn" height="49"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staContents03" taborder="8" left="18" top="461" height="45" cssclass="sta_WF_Black14" text="위의 개인정보 제공에 대한 동의를 거부할 권리가 있습니다. &#13;&#10;그러나 &lt;b v='true'&gt;동의를 거부할 경우 원활한 계약제교원 인력풀 등록에 제한을 받을 수 있습니다.&lt;/b&gt;" usedecorate="true" right="80" initvalueid="ivStcAccessibilityOn"/>
        <Radio id="popupRdo00" taborder="9" top="524" width="137" height="33" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" rowcount="-1" value="01" text="동의" index="0" right="26" initvalueid="ivRdoNormal">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row>
                <Col id="codecolumn">01</Col>
                <Col id="datacolumn">동의</Col>
              </Row>
              <Row>
                <Col id="codecolumn">02</Col>
                <Col id="datacolumn">미동의</Col>
              </Row>
            </Rows>
          </Dataset>
        </Radio>
        <Button id="btnCancel" taborder="10" text="취소" left="34.50%" width="120" height="40" cssclass="btn_WF_ActionLine" top="590" initvalueid="ivBtnAccessibilityButton" onclick="btnCancel_onclick"/>
        <Button id="btnConfirm" taborder="11" text="확인" width="120" height="40" cssclass="btn_WF_Action" left="btnCancel:10" top="590" initvalueid="ivBtnAccessibilityButton" onclick="btnConfirm_onclick"/>
      </Layout>
    </Layouts>
    <Objects/>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-계약제교원인력풀-지원서 작성 동의서 상세 팝업2
*  @MenuPath    pa_hrd_oew_ap
*  @FileName 	pa_hrd_oewap00_p01.xfdl
*  @Creator 	최지원
*  @CreateDate 	2022.08.10
*  @Desction    온라인통합채용-계약제교원인력풀-취업대상자 연계검증 활용 내역 팝업
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
******************************************************************************* 
*  2022.08.10		최지원             최초 생성
*******************************************************************************
*/

include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 
this.pv_params;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.popupForm_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// default 초기처리를 한다.
	this.smfInitPopup(obj);
	
	
	// 파라미터 셋
	this.pv_params = this.smfGetPopupParams();

	// 전달받은 파라메터 설정
	this.popupRdo00.set_value(this.pv_params.agreeValue);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
//동의여부 선택 여부
this.fnRadioChoice = function(){
	// opener Res
	this.smfSendResponseToOpener({
		"agreeValue": this.popupRdo00.value
	});
	this.close(true);
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 확인버튼 클릭	
 */
this.btnConfirm_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnRadioChoice();
	
};
/**
 * 취소버튼 클릭
 */
this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};
]]></Script>
  </Form>
</FDL>
