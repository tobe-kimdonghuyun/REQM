/**
 * 다음 버튼 클릭
 */
this.btnNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var saveYn = this.dsResultMnplReqs.getColumn(0, "saveYn");
	var prePage = this.pv_params.prePage;
	var aprvSts = this.pv_params.aprvSts;
	// 미 저장시 (신규)
	if ( saveYn == 'N' && prePage != 'Y')
	{
		if(aprvSts == '3')
		{
			this.smfAlert("재신청은 저장 후 다음 단계로 이동 가능 합니다.");
			return;
		}  
		
		this.smfAlert("지원서 저장 후 다음 단계로 이동 가능 합니다. ");
		return;
		
	}
	// 저장 후 다음 (신규)
	if(saveYn == 'Y' && prePage != 'Y'){
		// params
		var params = {		
			cddcCd			:this.pv_params.cddcCd,  							// 시도교육청코드(10자리)
			mnplSgScCd		:this.pv_params.mnplSgScCd, 						// 학교급구분코드
			mnplSgScCdNm	:this.pv_params.mnplSgScCdNm,						// 학교급구분명칭
			mnplOtlNm		:this.pv_params.mnplOtlNm,							// 인력풀개요명
			mnplOtlId		:this.pv_params.mnplOtlId,							// 인력풀개요ID:
			hopPlwkCnt		:this.pv_params.hopPlwkCnt,							// 희망근무지수
			hopSbjtCnt		:this.pv_params.hopSbjtCnt,							// 희망과목수
			onslLtoiNeedYn	:this.pv_params.onslLtoiNeedYn,		 				// 자기소개서 필요 여부
			tchQlfEsntlYn	:this.pv_params.tchQlfEsntlYn,						// 교원자격필수 여부
			mnplReqsId		:this.dsResultMnplReqs.getColumn(0, "mnplReqsId"), 	// 인력풀신청서ID
			mnplReqsId2 	:this.dsResultMnplReqs.getColumn(0, "mnplReqsId2"),  // 반려된 인력풀 신청서ID
			mnplIdntyDofdcCd:this.dsResultMnplReqs.getColumn(0, "mnplIdntyDofdcCd") // 인력풀확인지원청코드
			
		};
		this.smfSetWorkPage("pa_hrd_oew_ap::hrd_oewap02_m01.xfdl", params);
	}
	// 수정화면 & 미저장 
	if (saveYn == 'N' && prePage == 'Y')
	{	
		this.smfConfirm("저장하지 않은 정보는 변경되지 않습니다. \n다음 단계로 이동 하시겠습니까?", function(result){
	
			if(result.confirmResult){
			
				// params
				var params = {		
					cddcCd			:this.pv_params.cddcCd,  							// 시도교육청코드(10자리)
					mnplSgScCd		:this.pv_params.mnplSgScCd, 						// 학교급구분코드
					mnplSgScCdNm	:this.pv_params.mnplSgScCdNm,						// 학교급구분명칭
					mnplOtlNm		:this.pv_params.mnplOtlNm,							// 인력풀개요명
					mnplOtlId		:this.pv_params.mnplOtlId,							// 인력풀개요ID:
					hopPlwkCnt		:this.pv_params.hopPlwkCnt,							// 희망근무지수
					hopSbjtCnt		:this.pv_params.hopSbjtCnt,							// 희망과목수
					onslLtoiNeedYn	:this.pv_params.onslLtoiNeedYn,		 				// 자기소개서 필요 여부
					tchQlfEsntlYn	:this.pv_params.tchQlfEsntlYn,						// 교원자격필수 여부
					mnplReqsId		:this.dsSearch.getColumn(0, "mnplReqsId"), 	// 인력풀신청서ID	
					mnplIdntyDofdcCd:this.dsResultMnplReqs.getColumn(0, "mnplIdntyDofdcCd") // 인력풀확인지원청코드
				};
			
				this.smfSetWorkPage("pa_hrd_oew_ap::hrd_oewap02_m01.xfdl", params);
			
			}
		});
	} 
	// 수정화면 & 저장
	if(prePage == 'Y' && saveYn == 'Y') {
			
		// params
		var params = {		
			cddcCd			:this.pv_params.cddcCd,  							// 시도교육청코드(10자리)
			mnplSgScCd		:this.pv_params.mnplSgScCd, 						// 학교급구분코드
			mnplSgScCdNm	:this.pv_params.mnplSgScCdNm,						// 학교급구분명칭
			mnplOtlNm		:this.pv_params.mnplOtlNm,							// 인력풀개요명
			mnplOtlId		:this.pv_params.mnplOtlId,							// 인력풀개요ID:
			hopPlwkCnt		:this.pv_params.hopPlwkCnt,							// 희망근무지수
			hopSbjtCnt		:this.pv_params.hopSbjtCnt,							// 희망과목수
			onslLtoiNeedYn	:this.pv_params.onslLtoiNeedYn,		 				// 자기소개서 필요 여부	
			tchQlfEsntlYn	:this.pv_params.tchQlfEsntlYn,						// 교원자격필수 여부
			mnplReqsId		:this.dsSearch.getColumn(0, "mnplReqsId"), 	// 인력풀신청서ID			
			mnplIdntyDofdcCd:this.dsResultMnplReqs.getColumn(0, "mnplIdntyDofdcCd") // 인력풀확인지원청코드
		};
	
		this.smfSetWorkPage("pa_hrd_oew_ap::hrd_oewap02_m01.xfdl", params);
	

	}
};

/**
 * 저장버튼 클릭
 */
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
	// 인력풀 신청서 기본 정보 set
	this.fnSetSaveMnplReqs();
	/*console.log(this.dsResultMnplReqs.getColumn(0, 'mnplReqsId'));*/
	// 필수 체크 
	if(this.smfIsNull(this.dsResultMnplReqs.getColumn(0, "sxdsScCd")))
	{
		this.divMainInfo00.form.rdoSxdsScCd.setFocus();
		this.smfAlert('성별은 필수입니다.'); 
		return false;	
	}
	// 필수 체크 
	if(this.smfIsNull(this.dsResultMnplReqs.getColumn(0, "apstPhotoFileNm")))
	{
		this.divMainInfo00.form.btnPicture.setFocus();
		this.smfAlert('사진은 필수입니다.'); 
		return false;	
	}
	
	if(this.smfIsNull(this.dsResultMnplReqs.getColumn(0, "emlAddr")))
	{
		this.divMainInfo00.form.edtEmlAddr.setFocus();
		this.smfAlert('이메일은 필수입니다.'); 
		return false;	
	}
	if(this.smfIsNull(this.dsResultMnplReqs.getColumn(0, "emgCnctTelno")))
	{
		this.divMainInfo00.form.edtPhoneNo00.setFocus();
		this.smfAlert('비상연락처는 필수입니다.'); 
		return false;	
	}
	if(this.smfIsNull(this.dsResultMnplReqs.getColumn(0, "dmclRoadNmDtlAddr")))
	{
		this.divMainInfo00.form.edtAddressDetail00.setFocus();
		this.smfAlert('주소는 필수입니다.'); 
		return false;	
	}
	
	// 기본정보 validate  
	this.smfUpdateValidateToComponent("required",this.divMainInfo00.form.img);					 //사진
	this.smfUpdateValidateToComponent("required",this.divMainInfo00.form.rdoSxdsScCd); 		  	 // 성별
	this.smfUpdateValidateToComponent("required,email",this.divMainInfo00.form.edtEmlAddr); 	 //이메일
 	this.smfUpdateValidateToComponent("required",this.divMainInfo00.form.edtPhoneNo00); 		 //비상연락처1
	this.smfUpdateValidateToComponent("required",this.divMainInfo00.form.edtPhoneNo01); 		 //비상연락처2
	this.smfUpdateValidateToComponent("required",this.divMainInfo00.form.edtPhoneNo02); 		 //비상연락처3
	this.smfUpdateValidateToComponent("required",this.divMainInfo00.form.edtPostCode00);  		 //우편번호
	this.smfUpdateValidateToComponent("required",this.divMainInfo00.form.edtAddress00);  		 //주소
	this.smfUpdateValidateToComponent("required",this.divMainInfo00.form.edtAddressDetail00);  	 //주소상세
	
	// 교원자격정보 필요여부에 따른 필수 체크 
	var tchEsn = this.pv_params.tchQlfEsntlYn;
	var tchRow = this.dsTchQlfInfo.getRowCount();
	if(tchEsn == 'Y' && tchRow == 0)
	{
		this.divLscInfo00.form.btnLscAdd.setFocus();
		this.smfAlert("교원자격정보 입력은 필수입니다."); 
		return false;		
	}
	
	// [첨부파일] 첨부파일 업로드 체크
	var fileCount = this.divEtcFile.form.divEtcFileContent.form.fnGetTotalFileCount();
	
	this.smfConfirm("저장 하시겠습니까?", function(result){
		if(result.confirmResult){
			// 첨부파일의 유무 상관없이 업로드 처리(업로드카운트 0이면 null로 참조ID set)
			if (fileCount == 0)
			{
				this.dsResultMnplReqs.setColumn(0, "etcFileRefrnId", null);
			}
				this.divEtcFile.form.divEtcFileContent.form.fnFileUpload();
		}
	});
		
};

 // RAONK  옵션
this.fnSetRaonProp = function()
{
	var objAddRaonProps = {
		  MaxTotalFileCount 	: "5"	//업로드 할 최대 파일 개수 제한값을 설정합니다.
		, MaxOneFileSize 		: "3MB"	//업로드할 때 파일당 용량제한을 설정합니다.
		, MaxTotalFileSize 		: "15MB"
		, UseAlertEvent 		: "0"				// alert 이벤트 비활성  
		, Duplication 			: "1"
	};						  
	return objAddRaonProps;
};
/**
 * 사진업로드 raonk 옵션
 */
this.fnSetRaonPropImg = function()
{
	var objAddRaonProps = {
		ExtensionAllowOrLimit	: "1"        // 업로드 할 파일 확장자를 허용 또는 제한 설정("0":지정된 확장자를 제한(선택 금지) , "1":지정된 확장자만 허용(선택가능))
		, ExtensionArr          : "gif,jpg,png,jpeg" 
		, MaxTotalFileCount 	: "1"	//업로드 할 최대 파일 개수 제한값을 설정합니다.
		, MaxOneFileSize 		: "1024KB"	//업로드할 때 파일당 용량제한을 설정합니다.
	};						  
	return objAddRaonProps;
};

