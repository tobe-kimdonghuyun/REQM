      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-계약제교원인력풀-지원서 작성
*  @MenuPath    pa_hrd_oew_ap
*  @FileName 	pa_hrd_oewap02_m00.xfdl
*  @Creator 	
*  @CreateDate 	2022.08.30
*  @Desction    온라인통합채용-계약제교원인력풀-지원서 작성 step 1
************** 소스 수정 이력 ***********************************************
*  date             	Modifier            Description
*******************************************************************************
*  2022.08.30    	 	최지원              최초 생성 
*******************************************************************************
*/
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 //파라미터
this.apstFlnm;
this.brdt;
this.mblTelno;
this.userDtcNo;
var tchQlfEsntlYn;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form 초기화
	this.smfInitForm(this);
 	
 	// 파라메터 세팅
 	this.pv_params = this.smfGetFormParams();
// 	var logInfo = this.pv_params.dsLogInfo;
// 	this.dsLogInfo.loadJSON(logInfo);
	
	// 주민번호로 로그인의 경우 brdt check & set
	this.brdt = this.smfGetSessionValue('brdt');
	if(this.smfIsNull(this.brdt)){
		 this.brdt = this.applpRrnoToBrdt(nexacro.base64Decode(this.smfGetSessionValue('userRrno')));
	}	
	// 인력풀 개요명, id
	var mnplOtlId = this.pv_params.mnplOtlId;
	// 시도교육청
	var cddcCd = this.smfGetCddcCode();
	this.apstFlnm = this.smfGetSessionValue('userNm');		// 지원자성명
	this.userDtcNo = this.smfGetSessionValue('userDtcNo');	// 사용자Ci
	this.mblTelno = this.smfGetSessionValue('mblTelNo');	// 휴대폰번호
// 	trace("사용자Ci \n" + this.userDtcNo );
// 	trace("mblTelno \n" + this.mblTelno );
// 	trace("apstFlnm \n" + this.apstFlnm );
// 	trace("brdt \n" + this.brdt);
	// 학교급구분 코드, 구분명
	var mnplSgScCd = this.pv_params.mnplSgScCd;
	var sMblNm = this.mblTelno.split("-");
	// (테스트)이름. 생년월일, 휴대폰 set
	this.dsResultMnplReqs.setColumn(0, 'brdt', 		  this.brdt);
	this.dsResultMnplReqs.setColumn(0, 'apstFlnm',    this.apstFlnm);
	this.dsResultMnplReqs.setColumn(0, 'mblTelno00',  sMblNm[0]);
	this.dsResultMnplReqs.setColumn(0, 'mblTelno01',  sMblNm[1]);
	this.dsResultMnplReqs.setColumn(0, 'mblTelno02',  sMblNm[2]);
	
	// 개요명, 학교급구분 set
	this.divSearch.form.staSubInfo00.set_text(this.pv_params.mnplOtlNm);
	this.divSearch.form.staSubInfo01.set_text(this.pv_params.mnplSgScCdNm);
	
	// 저장여부 set
	this.dsResultMnplReqs.setColumn(0, "saveYn", 'N');

	// 최초 작성이 아닐 시 
	var prePage = this.pv_params.prePage;
	var aprvSts = this.pv_params.aprvSts;
	
	if (prePage == 'Y' || aprvSts =='3')
	{
		this.dsSearch.setColumn(0, 'mnplReqsId', this.pv_params.mnplReqsId);
		this.dsSearch.setColumn(0, 'pafrUserId', this.userDtcNo);
		
		// 지원서 조회
		this.smfSearchService("selectMnplReqs")
		// 데이터 존재 필수
		.requireExistsData(this.dsSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams)
		{
			if(callbackParams.errors) {
				return;
			}	
			this.dsResultMnplReqs.setColumn(0, 'saveYn', 'N');
			// 사진 set (413 error : request entity too large 해결 )
			if(!this.smfIsNull(this.dsResultMnplReqs.getColumn(0,"apstPhotoFileCn"))){
				this.divMainInfo00.form.img.set_image(this.dsResultMnplReqs.getColumn(0, "apstPhotoFileCn"));
				this.divMainInfo00.form.img.set_stretch('fit');
				this.divMainInfo00.form.img.set_text('');
				this.dsResultMnplReqs.setColumn(0, "apstPhotoFileCn", "");
			}else{
				this.divMainInfo00.form.img.set_image("");
			}
			this.divOnslLtoi.form.divOnslLtoiFile.form.edtFile.set_value(this.dsResultMnplReqs.getColumn(0, "atchFileNm"));
			if(this.dsResultMnplReqs.getColumn(0,"etcFileRefrnId") != null){
				// 업로드 초기화
				this.divEtcFile.form.divEtcFileContent.form.fnResetUpload();
				var sFileSn = this.dsResultMnplReqs.getColumn(0,"etcFileRefrnId") ;
				this.transaction("fn_filesearch" // serviceId
							,"baseUrl::/cm_cmc_file_upload_001.do" // url
							,"" // inDataset
							,"dsFileinfo=atchFileinfo" // outDataset
							,"fileRefrnId='"+sFileSn+"'"
							,"" // callbackFunction
							,false );

				for (var j = 0; j < this.dsFileinfo.rowcount; j++) {
						var responseCustomValue = "";
						var sDownloadUrl       = "";   // 
						var sPrivInfoFiltYn    = "";   // 항목 관리안함
						var sFileInfSaveYn     = "Y";  // 업무에 맞게 개발자가 세팅(Y/N)
						var sHandlerCode       = "PA.HRD.OEW"; 
						var sFileSn            = this.dsFileinfo.getColumn(j,"fileRefrnId"   );
						var sFileSeq           = this.dsFileinfo.getColumn(j,"fileId"        );
						var sFileSize          = this.dsFileinfo.getColumn(j,"atchFileMg"    );
						var sBackendFilename   = this.dsFileinfo.getColumn(j,"atchFileGuid"  );
						var sForntendFilename  = this.dsFileinfo.getColumn(j,"atchFileNm"    );
						var sFileEncryptYn     = this.dsFileinfo.getColumn(j,"fileEncryptYn" );
						var sFileSaveStg       = this.dsFileinfo.getColumn(j,"fileSaveStg"   );
						this.divEtcFile.form.divEtcFileContent.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sForntendFilename, sFileSeq, sDownloadUrl,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn );			
				}		
			}

		});	
	} 
	
	// 희망근무지수
	var hopPlwkCnt = this.pv_params.hopPlwkCnt;
	// 희망과목수
	var hopSbjtCnt = this.pv_params.hopSbjtCnt;
	// 자기소개서 필요 여부
	var onslLtoiNeedYn = this.pv_params.onslLtoiNeedYn;
	// 교원자격필수 여부
	var tchQlfEsntlYn = this.pv_params.tchQlfEsntlYn;
	
	// 자기 소개서 div 표시 여부
	if (onslLtoiNeedYn == 'N') {
		this.divOnslLtoi.set_height(0);
		this.divOnslLtoi.set_visible(false);
	}
	
	// 파일 업로드 초기화(자기소개서)
	this.divOnslLtoi.form.divOnslLtoiFile.UPLOAD_UploadComplete  = this.fnEventUploadComplete;
	this.divOnslLtoi.form.divOnslLtoiFile.UPLOAD_OnError         = this.fnEventUploadError;
	this.divOnslLtoi.form.divOnslLtoiFile.UPLOAD_AfterAddFile    = this.fnEventUploadAfterAddFile;     
	this.divOnslLtoi.form.divOnslLtoiFile.UPLOAD_Form            = this;
	// 파일 업로드 초기화(기타첨부파일)
	this.divEtcFile.form.divEtcFileContent.UPLOAD_UploadComplete = this.fnEventUploadComplete;        // 필요한 경우만 세팅(세팅권장)
	this.divEtcFile.form.divEtcFileContent.UPLOAD_OnError        = this.fnEventUploadError;           // 필요한 경우만 세팅(세팅권장)
	this.divEtcFile.form.divEtcFileContent.UPLOAD_AfterAddFile   = this.fnEventUploadAfterAddFile;     
	this.divEtcFile.form.divEtcFileContent.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)
	// 파일 업로드 초기화(지원자사진)
	this.divFileUpload.UPLOAD_UploadComplete  = this.fnEventUploadComplete;
	this.divFileUpload.UPLOAD_OnError         = this.fnEventUploadError;
	this.divFileUpload.UPLOAD_AfterAddFile    = this.fnEventUploadAfterAddFile;     
	this.divFileUpload.UPLOAD_Form            = this;

};

