// 	}

	// 비상연락처
	var emgCnctTelno1 = this.dsResultMnplReqs.getColumn(0, "emgCnctTelno0");	
	var emgCnctTelno2 = this.dsResultMnplReqs.getColumn(0, "emgCnctTelno1");	
	var emgCnctTelno3 = this.dsResultMnplReqs.getColumn(0, "emgCnctTelno2");
	var emgCnctTelno = [emgCnctTelno1, emgCnctTelno2, emgCnctTelno3].join("-"); 
	if ( emgCnctTelno == "--" ){
		emgCnctTelno = "";
	}  
	
	// 휴대전화 
	var mblTelno00 = this.dsResultMnplReqs.getColumn(0, "mblTelno00");	
	var mblTelno01 = this.dsResultMnplReqs.getColumn(0, "mblTelno01");	
	var mblTelno02 = this.dsResultMnplReqs.getColumn(0, "mblTelno02");
	var sMblTelno = [mblTelno00, mblTelno01, mblTelno02].join("-"); 
	if ( sMblTelno == "--" ){
		sMblTelno = "";
	}
	// 휴대폰
	this.dsResultMnplReqs.setColumn(0, 'mblTelno', sMblTelno);
	
	// 성별
	this.dsResultMnplReqs.setColumn(0, 'sxdsScCd', this.divMainInfo00.form.rdoSxdsScCd.value);
	/*trace("sxdsScCd" + this.dsResultMnplReqs.getColumn(0, 'sxdsScCd'));*/
	// 시도교육청코드
	var cddcCd = this.smfGetCddcCode();
	this.dsResultMnplReqs.setColumn(0, 'cddcScCd', cddcCd.slice(0, 3));
	// 계약제인력풀신청서 Id 3= 반려:재신청 
	if (this.pv_params.aprvSts == '3' && this.dsResultMnplReqs.getColumn(0, "saveYn") == 'N')
	{		
		this.dsResultMnplReqs.setColumn(0, "mnplReqsId", null);
		this.dsResultMnplReqs.setColumn(0, "mnplReqsId2", this.pv_params.mnplReqsId);
	} else if(this.pv_params.prePage == 'Y')
	{	
		this.dsResultMnplReqs.setColumn(0, 'mnplReqsId', this.pv_params.mnplReqsId);
	}
	// 인력풀개요 Id
	this.dsResultMnplReqs.setColumn(0, 'mnplOtlId', this.pv_params.mnplOtlId);
	// 인력풀 개요명
	this.dsResultMnplReqs.setColumn(0, 'mnplOtlNm', this.pv_params.mnplOtlNm);
	// 학교급구분코드
	this.dsResultMnplReqs.setColumn(0,'mnplSgScCd',  this.pv_params.mnplSgScCd);
 	// 대국민 사용자 Id -- (사용자ci 값으로 이용)
 	this.dsResultMnplReqs.setColumn(0, 'pafrUserId', this.userDtcNo);
	/*trace("userDtcNo \n" + this.dsResultMnplReqs.getColumn(0, 'pafrUserId'));*/
	// 비상연락처
	this.dsResultMnplReqs.setColumn(0, 'emgCnctTelno', emgCnctTelno);
	// 교원자격 소지여부
	var cnt = this.dsTchQlfInfo.getRowCount();
	// 교원자격 존재 여부 체크 
 	if (cnt > 0)
 	{
 		this.dsResultMnplReqs.setColumn(0, 'tchQlflPosYn', "Y");
 	} else {
		this.dsResultMnplReqs.setColumn(0, 'tchQlflPosYn', "N");
	}
	
 }
