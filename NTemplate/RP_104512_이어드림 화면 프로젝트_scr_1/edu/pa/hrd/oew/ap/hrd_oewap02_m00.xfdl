 */
this.fnAddCommBtn = function (dsList:nexacro.NormalDataset)
{
	var cnt = dsList.getRowCount();
	if(cnt > 4)
	{
	this.smfAlert('최대 5개까지만 추가할 수 있습니다.')
	return false;
	}
	return true;
};
 
