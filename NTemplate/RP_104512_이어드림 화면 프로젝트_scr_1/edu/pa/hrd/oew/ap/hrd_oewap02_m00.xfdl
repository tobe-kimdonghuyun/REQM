// 사진이미지 콜백
this.fnPopupCallback = function(e, sender){

	trace("====>fnPopupCallback");
	var sImageType       = "";
	var sImageFileName   = "";   // 선택된 파일이름
	var sImageDataBase64 = "";
	var sImageDataBase64Reduce = "";
	
	if(e.imageInfo)
	{
		sImageType       = e.imageInfo.imageType;   // 이미지 타입(image/png)
		sImageFileName   = e.imageInfo.imageFileName;   // 파일이름(test.png)
		// 사진파일 특수 문자 확인 
		var fileExtension = sImageFileName.substring(sImageFileName.lastIndexOf(".")); // 파일 확장자 
		var fileName = sImageFileName.split(fileExtension); // 파일명. 확장자 분리 
		/*var fileName = sImageFileName.split(/.png|.PNG|.jpg|.JPG|.JPEG|.jpeg|.bmp|.BMP/);*/
		var sMatch = fileName[0].match(/[\.\/\,\~\!\@\#\$\%\^\&\(\)\+\-\']/); // 파일명 특수문자 확인
		if ( sMatch != null)
		{
			this.smfAlert("사진 파일 이름에 특수 문자가 있습니다.");
			return;
		}
		sImageDataBase64 = e.imageInfo.imageDataBase64;  // BASE64의 이미지 파일
		sImageDataBase64Reduce = 	e.imageInfo.imageDataBase64Reduce; // BASE64의 이미지 파일(품질축소)

		if(!this.smfIsNull(sImageDataBase64))
		{
			this.divMainInfo00.form.img._imagetype = sImageType; 
			this.divMainInfo00.form.img._imagename = sImageFileName; 
			// 이미지 용량 작은 데이터 SET
			if(sImageDataBase64.length > sImageDataBase64Reduce.length){
				this.divMainInfo00.form.img.set_image(sImageDataBase64Reduce);
			}else{
				this.divMainInfo00.form.img.set_image(sImageDataBase64);
			}
			this.divMainInfo00.form.img.set_text("");
			
		}
	}
	var sBase64Data = this.divMainInfo00.form.img.image;
	this.divFileUpload.form.fnResetUpload();
	this.divFileUpload.form.fnFileUploadWithBase64(sBase64Data, sImageFileName);
};

