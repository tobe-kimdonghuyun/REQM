/**
 * 그리드 헤더클릭 공통
 */
this.grd_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var columnName = obj.getCellProperty("body",e.cell,"text");
	/*console.log(columnName);*/
	if ("bind:_chk" == columnName){
		// 체크박스전체클릭
		this.smfToggleChkHeader(obj, e); 
	}
};

/**
 * 삭제 버튼 (그리드 공통)
 */
this.fnDeleteComBtn = function(dsList:nexacro.NormalDataset)
{

	// 데이터셋 로우카운트 
	var cnt = dsList.getRowCount();
	// 데이터 없을경우
	if(cnt < 1){
		this.smfAlert("삭제 대상이 없습니다.");
		return;
	}
	// 체크박스 ON ARRAY 
	var chkIdxArray = dsList.extractRows("_chk == 1");
	if(this.isNil(chkIdxArray)){ 
		this.smfAlert("삭제 대상을 선택하세요. ");
		return;
	}
	// 확인 메시지 출력
	this.smfConfirm("삭제 하시겠습니까?", function(result){
		if(result.confirmResult){
			// 데이터삭제
			dsList.deleteMultiRows(chkIdxArray);
		}
	});	
	
}
