<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmMain" width="800" height="317" titletext="계약제교원인력풀-학력정보 팝업" onload="frmMain_onload">
    <Layouts>
      <Layout height="317" width="800" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divMain00" taborder="1" left="20" height="103" top="20" text="" cssclass="div_WF_Detail" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="sta01" taborder="0" left="120" height="42" cssclass="sta_WF_Input02Top" top="0" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta03" taborder="1" left="120" height="42" cssclass="sta_WF_Input02" top="41" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta00" taborder="2" left="0" width="120" height="42" cssclass="sta_WF_Input01Top" text="학위" top="0" initvalueid="ivStcAccessibilityOn"/>
              <Combo id="cboDegree" taborder="3" text="" left="125" top="6" width="240" height="32" innerdataset="dsDgriCd" codecolumn="unyCdValue" datacolumn="unyCdValueNm" index="-1" initvalueid="ivCmbNormal" displaynulltext="-선택-" accessibilitylabel="학위" cssclass="essential"/>
              <Static id="sta02" taborder="4" left="0" width="120" height="42" cssclass="sta_WF_Input01" text="학교명" top="41" initvalueid="ivStcEssential"/>
              <Edit id="edtSchNm" taborder="5" left="125" top="47" height="30" initvalueid="ivEdtEssential" text="강원대학교" width="240" cssclass="essential" maxlength="50" accessibilitylabel="대학교명"/>
              <Static id="staGD00" taborder="6" left="0" top="83" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divMain01" taborder="2" left="20" height="144" top="divMain00:0" text="" cssclass="div_WF_Detail" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="sta03" taborder="0" left="119" height="42" cssclass="sta_WF_Input_RtLine" top="41" width="320" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta04" taborder="1" left="440" height="42" cssclass="sta_WF_Input02" top="41" initvalueid="ivStcAccessibilityOff" width="320"/>
              <Static id="sta06" taborder="2" left="120" height="42" cssclass="sta_WF_Input02" top="82" right="0" initvalueid="ivStcAccessibilityOff" text=""/>
              <Static id="sta00" taborder="3" left="0" width="120" height="83" cssclass="sta_WF_Input01Top" text="재학기간" top="0" initvalueid="ivStcEssential"/>
              <Static id="sta01" taborder="4" left="120" height="42" cssclass="sta_WF_Input01Top" text="입학년월" top="0" width="318" initvalueid="ivStcEssential" border="1px solid #333333,0px none,1px solid #d6d9e1,1px solid #d6d9e1"/>
              <Calendar id="cal00" taborder="5" left="125" top="48" width="140" height="29" dateformat="yyyy.MM" initvalueid="ivCalEssential" editformat="yyyy.MM" cssclass="essential" type="normal" canchange="cal_canchange"/>
              <Static id="sta02" taborder="6" left="438" height="42" cssclass="sta_WF_Input01Top" text="졸업년월" top="0" width="322" initvalueid="ivStcEssential" border="1px solid #333333,0px none,1px solid #d6d9e1,1px solid #d6d9e1"/>
              <Calendar id="cal01" taborder="7" left="445" top="48" width="140" height="29" dateformat="yyyy.MM" initvalueid="ivCalEssential" editformat="yyyy.MM" cssclass="essential" canchange="cal_canchange" onchanged="divMain01_cal01_onchanged"/>
              <Static id="sta05" taborder="8" left="0" width="120" height="42" cssclass="sta_WF_Input01" text="증명자료" top="82" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
              <Div id="divFileContent" taborder="9" left="125" top="88" width="420" height="30" url="comm::comm_fileAdd2.xfdl" Mode="upload" uploadLocation="PA.HRD.OEW" addProp="fnSetRaonProp" privInfoFiltYn="N" fileEncryptYn="N" fileSaveStg="SV" initvalueid="ivDivAccessibilityOff" cssclass="essential" text=""/>
              <Static id="staGD00" taborder="10" left="0" top="124" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnCancel" taborder="3" text="취소" height="30" width="50" left="43.25%" fittocontents="width" cssclass="btn_WF_Custom" initvalueid="ivBtnAccessibilityButton" top="267" onclick="btnCancel_onclick"/>
        <Button id="btnRegist" taborder="4" text="적용" height="30" width="50" fittocontents="width" left="btnCancel:8" initvalueid="ivBtnAccessibilityButton" top="267" onclick="btnRegist_onclick"/>
        <Static id="staGD00" taborder="5" left="20" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGD01" taborder="6" left="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" height="20" initvalueid="ivStcAccessibilityOff" top="297"/>
        <Static id="staGD02" taborder="7" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGD03" taborder="8" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsDgriCd" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="FirstCode" type="STRING" size="30" value="" datapath=""/>
          <ConstColumn id="ClfCdValue" type="STRING" size="30" value="DGRI_CD"/>
          <ConstColumn id="FilterExpr" type="STRING" size="30" value=""/>
          <ConstColumn id="UnyCdGrpId" type="STRING" size="30" value=""/>
          <ConstColumn id="BfrClfCdValue" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd1Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd2Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd3Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd4Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd5Value" type="STRING" size="30" value=""/>
          <Column id="pgeId" type="STRING" size="256"/>
          <Column id="clfCdValue" type="STRING" size="30"/>
          <Column id="clfCdValueNm" type="STRING" size="120"/>
          <Column id="clfCdUseYn" type="STRING" size="150"/>
          <Column id="unyCdValue" type="STRING" size="10"/>
          <Column id="unyCdValueNm" type="STRING" size="30"/>
          <Column id="userDfnCd1Value" type="STRING" size="100"/>
          <Column id="userDfnCd2Value" type="STRING" size="100"/>
          <Column id="userDfnCd3Value" type="STRING" size="100"/>
          <Column id="userDfnCd4Value" type="STRING" size="100"/>
          <Column id="userDfnCd5Value" type="STRING" size="100"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true">
        <ColumnInfo>
          <Column id="fileRefrnId" type="STRING" size="256"/>
          <Column id="atchFileNm" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsOutFileinfo">
        <ColumnInfo>
          <Column id="fileRefrnId" type="STRING" size="256" description="파일SEQ ID"/>
          <Column id="fileId" type="STRING" size="256" description="파일 아이디"/>
          <Column id="suc" type="STRING" size="256"/>
          <Column id="atchFileNm" type="STRING" size="256" description="파일명"/>
          <Column id="atchFileGuid" type="STRING" size="256" description="파일 GUID"/>
          <Column id="atchFileMg" type="STRING" size="256"/>
          <Column id="fileExtsnNm" type="STRING" size="256" description="파일확장자"/>
          <Column id="minTypeNm" type="STRING" size="256" description="파일의 mime type"/>
          <Column id="fileCoursNm" type="STRING" size="256" description="서버파일저장위치"/>
          <Column id="fileObjKey" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsDateTime" useclientlayout="true">
        <ColumnInfo>
          <Column id="mm" type="STRING" size="256"/>
          <Column id="dd" type="STRING" size="256"/>
          <Column id="hhmmss" type="STRING" size="256"/>
          <Column id="yyyymmdd" type="STRING" size="256"/>
          <Column id="yyyy" type="STRING" size="256"/>
          <Column id="hhmmsssss" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">selectDate</Col>
            <Col id="outDatasets">dsDateTime=dsDateTime</Col>
            <Col id="url">cmc_fcm_dt01_001.do</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-계약제교원인력풀-학력정보 팝업
*  @MenuPath    pa_hrd_oew_ap
*  @FileName 	pa_hrd_oewap02_p00.xfdl
*  @Creator 	
*  @CreateDate 	2022.8.30
*  @Desction    온라인통합채용-계약제교원인력풀-학력정보 팝업
************** 소스 수정 이력 ***********************************************
*  date                Modifier            Description
*******************************************************************************
*  2022.8.30    	 	최지원             최초 생성 
********************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

	// default 초기처리를 한다.
	this.smfInitPopup(obj);

	// 파라메터 셋
	this.pv_params = this.smfGetPopupParams();
	// 팝업 타이틀 변경
	this.smfUpdatePopupTitle("학력정보");
		
	// 공통코드 조회
	// dsDgriCd : 학위코드  
	this.smfCodeList("code", [this.dsDgriCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		}).run();
	this.fnSearchDate();
	
	// 파일 업로드
	this.divMain01.form.divFileContent.UPLOAD_UploadComplete  = this.fnFileUploadCompleteCallback;
	this.divMain01.form.divFileContent.UPLOAD_OnError         = this.fnFileUploadErrorCallback;
	this.divMain01.form.divFileContent.UPLOAD_AfterAddFile    = this.fnFileUploadChangeCallback;     
	this.divMain01.form.divFileContent.UPLOAD_Form            = this;
	
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 // 파일 업로드 성공 콜백
this.fnFileUploadCompleteCallback = function(obj, paramObj, objResultDataset)
{
	// 업로드 성공 후, newfile에 있는 파일들을 webfile로 옮긴다.
	this.divMain01.form.divFileContent.form.fnSetUploadCompleteState(obj,paramObj);	
	
	// 업로드한 file을 가져오는 법
	if(objResultDataset)
	{
		trace("====업로드한 결과 데이터셋 ========== \n"+objResultDataset.saveXML());
		
		var sFileRefrnId = objResultDataset.getColumn(0,"fileRefrnId");
		trace("업로드결과 데이터셋의 첫번째 row의 fileRefrnId=["+sFileRefrnId+"]");
		this.dsMain.setColumn(0, "fileRefrnId", objResultDataset.getColumn(0, "fileRefrnId"));
		this.dsMain.setColumn(0, "atchFileNm", objResultDataset.getColumn(0, "atchFileNm"));
	}
	// 23.07.19 싱글파일 처리. fileRefrnId 하나에 하나의 파일만 업로드, 업로드 변경할 때 새로운 fileRefrnId 생성을 위해 fnResetUpload 
	this.divMain01.form.divFileContent.form.fnResetUpload();
	// 23.07.19 if문에 포함시키면 리셋으로 인해 파일명 표시 안됨
	this.divMain01.form.divFileContent.form.edtFile.set_value(this.dsMain.getColumn(0, "atchFileNm"));
	
};

// 파일 업로드 실패 콜백
this.fnFileUploadErrorCallback = function(obj, paramObj)
{
	//this.smfAlert('파일 업로드에 실패 하였습니다.');
};

// 파일 업로드 변경 콜백
this.fnFileUploadChangeCallback = function(obj, paramObj, sCustomValue, sFileName, nFileSize)
{
	this.divMain01.form.divFileContent.form.fnFileUpload();	
};
 /************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 /**
 *현재 일자 검색
 */
this.fnSearchDate = function(obj, e)
{	
	// 서비스 객체 생성
	this.smfSearchService("selectDate")
		// 실행
		.run()
		
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;

		});
}
 
 /************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 기간 설정 
this.dateFromTo = function()
{	
	var fromMonth = this.divMain01.form.cal00.value.substring(0, 6);
	var toMonth = this.divMain01.form.cal01.value.substring(0, 6);
	var nMonth = this.dsDateTime.getColumn(0, 'yyyymmdd');
	var month = nMonth.substring(0, 6);

	//미래 날짜 입력 불가
	if ( fromMonth > month || toMonth > month )
	{	
		return false;
	}	
	return true;
};

// 캘린더 미래 일자 변경
 this.cal_canchange = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{
	var yy = e.postvalue.substring(0, 2);
	if ( !(yy == 19 || yy == 20) ) {
		obj.set_value(null);
		this.smfAlert("입력이 불가한 날짜입니다.");
		return false;
	}
	
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 확인버튼 클릭	
 */
this.btnRegist_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 학위
	if (this.smfIsNull(this.divMain00.form.cboDegree.value))
	{
		this.divMain00.form.cboDegree.setFocus();
		this.smfAlert('학위를 입력하세요.');
		return;
	}
	// 대학교명
	if( this.smfIsNull(this.divMain00.form.edtSchNm.value) )
	{ 
		this.divMain00.form.edtSchNm.setFocus();
		this.smfAlert('대학교명을 입력하세요.');
		return;
	} 
	
	// 재학기간입력 확인
	if (this.smfIsNull(this.divMain01.form.cal00.value) || this.smfIsNull(this.divMain01.form.cal01.value))
	{
		this.divMain01.form.cal00.setFocus();
		this.smfAlert("재학기간은 필수입니다.", function(){});
		return;	
	} else if (this.divMain01.form.cal00.value > this.divMain01.form.cal01.value) {
		this.divMain01.form.cal01.setFocus();
		this.smfAlert('입학년월이 졸업년월보다 이전이여야 합니다.')
		return;
	}  else if(!this.dateFromTo()) { // 현재월 이후 선택 시
		this.divMain01.form.cal00.setFocus();
		this.smfAlert("재학기간은 미래 일자를 입력 할 수 없습니다.");
		return;
		
	}

	// 증명자료 
	if( this.smfIsNull(this.dsMain.getColumn(0, "fileRefrnId")))
	{ 
		this.divMain01.form.divFileContent.setFocus();
		this.smfAlert('증명자료는 필수입니다.');
		return;
	} 
	
	

	// 입력값 부모창 전달
	this.smfSendResponseToOpener({
		
		"dgriCd"		: this.divMain00.form.cboDegree.value, // 학위코드
		"dgriCdNm" 		: this.divMain00.form.cboDegree.text, // 학위명
		"shlNm" 		: this.divMain00.form.edtSchNm.value, // 학교명
		"etrcYm" 		: this.divMain01.form.cal00.value.slice(0,6), // 입학년월
		"grdtnYm" 		: this.divMain01.form.cal01.value.slice(0,6), // 졸업년월
		"fileRefrnId" 	: this.dsMain.getColumn(0, "fileRefrnId"), // 첨부파일id
		"atchFileNm" 	: this.dsMain.getColumn(0, "atchFileNm"), // 파일명
		"flagAdd"		: "Y"
		});
	this.close(true);
	
};

/**
 * 취소버튼 클릭
 */
this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};

]]></Script>
  </Form>
</FDL>
