    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-계약제교원인력풀-경력정보 팝업
*  @MenuPath    pa_hrd_oew_ap
*  @FileName 	pa_hrd_oewap02_p02.xfdl
*  @Creator 	
*  @CreateDate 	2022.8.30
*  @Desction    온라인통합채용-계약제교원인력풀-경력정보 팝업
************** 소스 수정 이력 ***********************************************
*  date                Modifier            Description
*******************************************************************************
*  2022.8.30    	 	최지원             최초 생성 
*******************************************************************************
*/


/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

	// default 초기처리를 한다.
	this.smfInitPopup(obj);

	// 파라메터 셋
	this.pv_params = this.smfGetPopupParams();
	// 팝업 타이틀 변경
	this.smfUpdatePopupTitle("경력정보");
		
	// 공통코드 조회
	// dsWkpcCd : 근무처구분코드 
	this.smfCodeList("code", [this.dsWkpcCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		}).run();
		
	// 파일 업로드
	this.divMain00.form.divFileContent.UPLOAD_UploadComplete  = this.fnFileUploadCompleteCallback;
	this.divMain00.form.divFileContent.UPLOAD_OnError         = this.fnFileUploadErrorCallback;
	this.divMain00.form.divFileContent.UPLOAD_AfterAddFile    = this.fnFileUploadChangeCallback;     
	this.divMain00.form.divFileContent.UPLOAD_Form            = this;

};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 파일 업로드 성공 콜백
this.fnFileUploadCompleteCallback = function(obj, paramObj, objResultDataset)
{

	this.divMain00.form.divFileContent.form.fnSetUploadCompleteState(obj,paramObj);
	this.dsMain.setColumn(0, "fileRefrnId", objResultDataset.getColumn(0, "fileRefrnId"));
	this.dsMain.setColumn(0, "atchFileNm", objResultDataset.getColumn(0, "atchFileNm"));
	//23.07.19 싱글파일 처리. fileRefrnId 하나에 하나의 파일만 업로드, 업로드 변경할 때 새로운 fileRefrnId 생성을 위해 fnResetUpload 
	this.divMain00.form.divFileContent.form.fnResetUpload();
	// 23.07.19 리셋으로 인해 파일명 미표시되는 것 set
	this.divMain00.form.divFileContent.form.edtFile.set_value(this.dsMain.getColumn(0, "atchFileNm"));
};

// 파일 업로드 실패 콜백
this.fnFileUploadErrorCallback = function(obj, paramObj)
{
	//this.smfAlert('파일 업로드에 실패하였습니다.');
};

// 파일 업로드 변경 콜백
this.fnFileUploadChangeCallback = function(obj, paramObj, sCustomValue, sFileName, nFileSize)
{
	this.divMain00.form.divFileContent.form.fnFileUpload();	
};
 /************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 
 /************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 // 캘린더 미래 일자 변경
 this.cal_canchange = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{
	var yy = e.postvalue.substring(0, 2);
	if ( !(yy == 19 || yy == 20) ) {
		obj.set_value(null);
		this.smfAlert("입력이 불가한 날짜입니다.");
		return false;
	}
	//오늘 이후 선택 안됨
	if ( e.postvalue > this.smfToday() )
	{
		this.smfAlert("미래 일자를 입력할 수 없습니다.");
		return false;
	}	
};
// 기간 설정 alert
this.div00_cal01_canchange = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{	
	var fromDate = new Date();
	var toDate = new Date();
	var calDate;
	var day = 1000*60*60*24;
	
	fromDate.setFullYear(this.div00.form.cal00.getYear());
	fromDate.setMonth(this.div00.form.cal00.getMonth()-1);
	fromDate.setDate(this.div00.form.cal00.getDay());
	
	toDate.setFullYear(this.div00.form.cal01.getYear());
	toDate.setMonth(this.div00.form.cal01.getMonth()-1);
	toDate.setDate(this.div00.form.cal01.getDay());
	
	calDate = (fromDate.getTime()-toDate.getTime())/day;
	
	
	//졸업일자가 입학일자보다 이전이면 안됨
	/*console.log(calDate);*/
	if (calDate > 0 )
	{	
		this.smfAlert("시작일자가 종료일자보다 이전이여야 합니다.", function(){
		this.div00.form.cal01.set_value(null);
		});
		return;
	}	
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 확인버튼 클릭	
 */
this.btnRegist_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 근무기관
	if (this.smfIsNull(this.divMain.form.edtWorkInstNm.value))
	{
		this.divMain.form.edtWorkInstNm.setFocus();
		this.smfAlert('근무기관을 입력하세요');
		return;
	}

	// 주별수업시수 (담당업무에서는 사용하지 않을 수 있음.)
// 	if(this.smfIsNull(this.divMain.form.edt02.value))
// 	{
// 		this.divMain.form.edt02.setFocus();
// 		this.smfAlert('주별수업시수 입력하세요');
// 		return;
// 	}	
	// 근무기간 입력 확인
	if (this.smfIsNull(this.div00.form.cal00.value) || this.smfIsNull(this.div00.form.cal01.value))
	{
		this.div00.form.cal00.setFocus();
		this.smfAlert("근무기간을 입력하세요.", function(){});
		return;
	} else if (this.div00.form.cal00.value > this.div00.form.cal01.value) 
	{
		this.div00.form.cal01.setFocus();
		this.smfAlert('시작년월이 종료년월보다 이전이여야 합니다.');
		return;
	}

	// 증명자료 
	if( this.smfIsNull(this.dsMain.getColumn(0, "fileRefrnId")))
	{ 
		this.divMain00.form.divFileContent.setFocus();
		this.smfAlert('경력확인서는 필수입니다.');
		return;
	} 
	
	// 입력값 부모창 전달
	this.smfSendResponseToOpener({
	
		"workInstNm" 	: this.divMain.form.edtWorkInstNm.value, 	// 근무기관
		"wkpcCdNm" 		: this.divMain.form.rdoWkpcCd.text, 		// 근무처구분
		"wkpcCd" 		: this.divMain.form.rdoWkpcCd.value,  		//근무처구분 코드
		"carrBgngYmd" 	: this.div00.form.cal00.value, 				// 시작일자
		"carrEndYmd" 	: this.div00.form.cal01.value, 				// 종료일자
		"jbpsNm" 		: this.divMain.form.edtJbpsNm.value, 		// 담당업무
		"chrgeSbjtNm" 	: this.divMain.form.edt01.value, 			// 담당과목
		"wlyItrtHcnt" 	: this.divMain.form.edt02.value, 			// 주별주업시수
		"fileRefrnId" 	: this.dsMain.getColumn(0, "fileRefrnId"), 	// 파일참조ID
		"atchFileNm" 	: this.dsMain.getColumn(0, "atchFileNm"), 	// 첨부파일명
		"flagAdd"		: "Y"
	});
	this.close(true);
};

/**
 * 취소버튼 클릭
 */
this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};

]]></Script>
  </Form>
</FDL>
