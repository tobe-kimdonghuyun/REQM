 /************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function (){
	
	// 서비스 객체 생성
	this.smfSearchService("selectHopWork")	
 		// 실행
 		.run()	
		// 콜백
		.callback(function(callbackParams){
 			if(callbackParams.errors) return;
			// 희망과목, 희망근무지 
			var hopSbjtCnt =  this.dsResultHopWork.getColumn(0, "hopSbjtCnt"); // 희망과목수
			var hopPlwkCnt =  this.dsResultHopWork.getColumn(0, "hopPlwkCnt"); // 희망근무지수;
			var mnplSgScCd = this.dsResultHopWork.getColumn(0, "mnplSgScCd");  // 학교급구분
			var onslLtoiNeedYn = this.dsResultHopWork.getColumn(0, "onslLtoiNeedYn"); // 자기소개필요여부
			var tchQlfEsntlYn = this.dsResultHopWork.getColumn(0, "tchQlfEsntlYn"); // 교원자격필수여부
			// 학교급구분에 상세과목화면 표시 
			this.fnSetMnplSgScInfo(mnplSgScCd, hopSbjtCnt);	
			// 희망근무지 수에 따른 화면 표시
			this.fnSetHopPlwkCnt(hopPlwkCnt);

			// 선택계약제 조회 set
			var ctrsCnt = this.dsCtrsCd.getRowCount();
			if (ctrsCnt != 0)
			{
				for(i = 0; i < ctrsCnt; i++){
					var ctrsNo = this.dsCtrsCd.getColumn(i, "ctrsScCd");
					var ctrsName = "chkCtrsCd0" + ctrsNo;
					this.divContents00.form.components[ctrsName].set_value(ctrsNo);
				}
			}
			this.dsCtrsCd.clearData();
			
			// 개요에서 선택된 계약직이외는 enable false처리
			var mnplCtwkScCdCnt = this.dsMnplCtwkScCd.getRowCount();
			if (mnplCtwkScCdCnt != 0)
			{
				this.divContents00.form.components["chkCtrsCd01"].set_enable(false);
				this.divContents00.form.components["chkCtrsCd02"].set_enable(false);
				this.divContents00.form.components["chkCtrsCd03"].set_enable(false);
				this.divContents00.form.components["chkCtrsCd04"].set_enable(false);
				this.divContents00.form.components["chkCtrsCd05"].set_enable(false);
				for(i = 0; i < mnplCtwkScCdCnt; i++){
					var mnplCtwkScCd = this.dsMnplCtwkScCd.getColumn(i, "mnplCtwkScCd");
					var mnplCtwkScName = "chkCtrsCd0" + mnplCtwkScCd;
					this.divContents00.form.components[mnplCtwkScName].set_enable(true);
				}
			}
			
			this.dsMnplCtwkScCd.clearData();
			
			// 희망근무 날짜 조회 set
			this.divContents00.form.calBeginDate.set_value(this.dsResultHopWork.getColumn(0, "hopWorkBgngYmd"));
			this.divContents00.form.calEndDate.set_value(this.dsResultHopWork.getColumn(0, "hopWorkEndYmd"));
			if (this.dsResultHopWork.getColumn(0, "hopWorkEndYmd") == "99991231")
			{
				this.divContents00.form.calEndDate.set_value(null);
			}
			
			// 희망근무 시간  조회set
			var bgngTime = this.dsResultHopWork.getColumn(0, "hopWorkBgngHm");
			if (!this.smfIsNull(bgngTime))
			{
				this.divContents00.form.cbo00.set_value(bgngTime.substring(0, 2));
				this.divContents00.form.cbo01.set_value(bgngTime.substring(2));
			}
			var endTime = this.dsResultHopWork.getColumn(0, "hopWorkEndHm");
			if (!this.smfIsNull(endTime)){
				this.divContents00.form.cbo02.set_value(endTime.substring(0, 2));
				this.divContents00.form.cbo03.set_value(endTime.substring(2));
			}
			
			// 희망과목 조회 set
			var sbjtCnt = this.dsHopSbjt.getRowCount();
			if (sbjtCnt != 0)
			{
				for(i = 0; i < sbjtCnt; i++){
					var sbjtCd = this.dsHopSbjt.getColumn(i, "hopSbjtCd");
					var rnkNo = this.dsHopSbjt.getColumn(i, "hopSbjtPriorRnk");
					var sbjtName = "cboSel0" + i;
					var rnkNoName = "cboSel0" + rnkNo;
					if (mnplSgScCd == "1")  // 1, 4, 5
					{	
						this.divContents01.form.div00.form.components[sbjtName].set_enable(true);
						this.divContents01.form.div00.form.components[sbjtName].set_value(sbjtCd);
						this.divContents01.form.div00.form.components[rnkNoName].set_enable(true);
					}						
					
					if (mnplSgScCd == "4")  // 1, 4, 5
					{
						this.divContents01.form.div01.form.components[sbjtName].set_enable(true);
						this.divContents01.form.div01.form.components[sbjtName].set_value(sbjtCd);
						this.divContents01.form.div01.form.components[rnkNoName].set_enable(true);
					} 
					
					if (mnplSgScCd == "5")  // 1, 4, 5
					{
						this.divContents01.form.div02.form.components[sbjtName].set_enable(true);
						this.divContents01.form.div02.form.components[sbjtName].set_value(sbjtCd);
						this.divContents01.form.div02.form.components[rnkNoName].set_enable(true);
					} 
				}
			}
			// 희망근무지 조회 set
			var zoneCnt = this.dsHopPlwkZone.getRowCount();
			if (zoneCnt != 0)
			{
				for(i = 0; i <= zoneCnt; i++){
					var zoneName = "div0" + i;
					this.divContents02.form.components[zoneName].form.btnLocal00.set_enable(true);
					this.divContents02.form.components[zoneName].form.edtSetLocal00.set_value(this.dsHopPlwkZone.getColumn(i, "zoneNm"));
					/*this.divContents02.form.components["div0" + (i + 1)].form.btnLocal00.set_enable(true);*/
				}
			
			}		

 		});	
};

// 신청서 저장
this.fnSaveMnplDtl = function (){
	// 서비스 객체 생성
	this.smfSaveService("saveMnplDtl")
	
	// 실행
	.run()
	
	// 콜백
	.callback(function(callbackParams
	){
		if(callbackParams.errors) return;

		// 저장이 완료되었습니다.
		this.smfAlert('저장 되었습니다.',  function(){});
	});
};
/**
 *	신청취소
 */
this.fnDeleteMnplReqs = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfConfirm('인력풀 작성을 취소하시겠습니까?\n확인을 누르시면 작성된 정보는 삭제됩니다.', function(result)
	{
		if(result.confirmResult)
		{	
			// 서비스 객체 생성 
			this.smfDeleteService("deleteMnplReqs")
			.showConfirm(false)
			// 데이터 존재 필수
			.requireExistsData(this.dsSearch)
			// 실행
			.run()
			// 콜백
			.callback(function(callbackParams)
			{
				if(callbackParams.errors) return;
				this.smfAlert("삭제되었습니다.");
			});
			var params = {};
			// 동의서 화면으로 
			this.smfSetWorkPage("pa_hrd_oew_ap::hrd_oewap00_m00.xfdl", params);
				
		}
	});
	
};

 /************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 // 희망근무시간 set
this.fnSetHopWork = function ()
{
	// 희망근무시간 
	var hopWorkBgngHm = this.dsHopDateTime.getColumn(0, "beginHour") + this.dsHopDateTime.getColumn(0, "beginMin");
	var hopWorkEndHm = this.dsHopDateTime.getColumn(0, "endHour") + this.dsHopDateTime.getColumn(0, "endMin");
	// 희망근무시간 null 체크
	if (!this.smfIsNull(this.divContents00.form.cbo00.value) && !this.smfIsNull(this.divContents00.form.cbo01.value)
		&&  !this.smfIsNull(this.divContents00.form.cbo02.value) && !this.smfIsNull(this.divContents00.form.cbo03.value))
	{
		this.dsHopDateTime.setColumn(0, "hopWorkBgngHm", hopWorkBgngHm);
		this.dsHopDateTime.setColumn(0, "hopWorkEndHm", hopWorkEndHm);
	} else {
		this.dsHopDateTime.setColumn(0, "hopWorkBgngHm", null);
		this.dsHopDateTime.setColumn(0, "hopWorkEndHm", null);
	}
	
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// 학교급구분 set
this.fnSetMnplSgScInfo = function (mnplSgScCd, hopSbjtCnt)
{
	// 학교급구분에 따른 상세과목 화면처리
	// 상세과목 미표시
	if (mnplSgScCd == '2' || mnplSgScCd == '3'){
		this.divContents01.set_height(0);
	
	// 상세과목 표시
	} else {
		// 학교급구분 코드에 따른 희망과목 표시 처리
		this.divContents01.set_height(102);
		
		// 중등
		if( mnplSgScCd == '1') { 
			this.divContents01.set_visible(true);
			this.divContents01.form.div00.set_visible(true);
			
			// 희망과목수에 따른 화면 동적처리
			if (hopSbjtCnt == '1') {
				this.divContents01.form.div00.form.edt00.set_visible(true);
				this.divContents01.form.div00.form.cboSel00.set_visible(true);
			} else if (hopSbjtCnt == '2') {
				this.divContents01.form.div00.form.edt00.set_visible(true);
				this.divContents01.form.div00.form.cboSel00.set_visible(true);
				this.divContents01.form.div00.form.edt01.set_visible(true);
				this.divContents01.form.div00.form.cboSel01.set_visible(true);				
			}  else if (hopSbjtCnt == '3') {
				this.divContents01.form.div00.form.edt00.set_visible(true);
				this.divContents01.form.div00.form.cboSel00.set_visible(true);
				this.divContents01.form.div00.form.edt01.set_visible(true);
				this.divContents01.form.div00.form.cboSel01.set_visible(true);
				this.divContents01.form.div00.form.edt02.set_visible(true);
				this.divContents01.form.div00.form.cboSel02.set_visible(true);	
			}  else if (hopSbjtCnt == '4') {
				this.divContents01.form.div00.form.edt00.set_visible(true);
				this.divContents01.form.div00.form.cboSel00.set_visible(true);
				this.divContents01.form.div00.form.edt01.set_visible(true);
				this.divContents01.form.div00.form.cboSel01.set_visible(true);
				this.divContents01.form.div00.form.edt02.set_visible(true);
				this.divContents01.form.div00.form.cboSel02.set_visible(true);
				this.divContents01.form.div00.form.edt03.set_visible(true);
				this.divContents01.form.div00.form.cboSel03.set_visible(true);	
			}  else if (hopSbjtCnt == '5') {
				this.divContents01.form.div00.form.edt00.set_visible(true);
				this.divContents01.form.div00.form.cboSel00.set_visible(true);
				this.divContents01.form.div00.form.edt01.set_visible(true);
				this.divContents01.form.div00.form.cboSel01.set_visible(true);
				this.divContents01.form.div00.form.edt02.set_visible(true);
				this.divContents01.form.div00.form.cboSel02.set_visible(true);
				this.divContents01.form.div00.form.edt03.set_visible(true);
				this.divContents01.form.div00.form.cboSel03.set_visible(true);
				this.divContents01.form.div00.form.edt04.set_visible(true);
				this.divContents01.form.div00.form.cboSel04.set_visible(true);	
			}
		// 특수
		} else if (mnplSgScCd == '4') { 
			this.dsHopSbjtCd.filter("unyCdValue=='10090'|| unyCdValue=='20001' || unyCdValue=='20002' || unyCdValue=='20003' || unyCdValue=='20004'");
			this.divContents01.set_visible(true);
			this.divContents01.form.div01.set_visible(true);
			// 희망과목수에 따른 화면 동적처리
			if (hopSbjtCnt == '1') {
				this.divContents01.form.div01.form.edt00.set_visible(true);
				this.divContents01.form.div01.form.cboSel00.set_visible(true);
			} else if (hopSbjtCnt == '2') {
				this.divContents01.form.div01.form.edt00.set_visible(true);
				this.divContents01.form.div01.form.cboSel00.set_visible(true);
				this.divContents01.form.div01.form.edt01.set_visible(true);
				this.divContents01.form.div01.form.cboSel01.set_visible(true);				
			}  else if (hopSbjtCnt == '3') {
				this.divContents01.form.div01.form.edt00.set_visible(true);
				this.divContents01.form.div01.form.cboSel00.set_visible(true);
				this.divContents01.form.div01.form.edt01.set_visible(true);
				this.divContents01.form.div01.form.cboSel01.set_visible(true);
				this.divContents01.form.div01.form.edt02.set_visible(true);
				this.divContents01.form.div01.form.cboSel02.set_visible(true);	
			}  else if (hopSbjtCnt == '4') {
				this.divContents01.form.div01.form.edt00.set_visible(true);
				this.divContents01.form.div01.form.cboSel00.set_visible(true);
				this.divContents01.form.div01.form.edt01.set_visible(true);
				this.divContents01.form.div01.form.cboSel01.set_visible(true);
				this.divContents01.form.div01.form.edt02.set_visible(true);
				this.divContents01.form.div01.form.cboSel02.set_visible(true);
				this.divContents01.form.div01.form.edt03.set_visible(true);
				this.divContents01.form.div01.form.cboSel03.set_visible(true);	
			}  else if (hopSbjtCnt == '5') {
				this.divContents01.form.div01.form.edt00.set_visible(true);
				this.divContents01.form.div01.form.cboSel00.set_visible(true);
				this.divContents01.form.div01.form.edt01.set_visible(true);
				this.divContents01.form.div01.form.cboSel01.set_visible(true);
				this.divContents01.form.div01.form.edt02.set_visible(true);
				this.divContents01.form.div01.form.cboSel02.set_visible(true);
				this.divContents01.form.div01.form.edt03.set_visible(true);
				this.divContents01.form.div01.form.cboSel03.set_visible(true);
				this.divContents01.form.div01.form.edt04.set_visible(true);
				this.divContents01.form.div01.form.cboSel04.set_visible(true);	
			}
		// 비교과
		} else if (mnplSgScCd == '5') { 
			this.dsHopSbjtCd.filter("unyCdValue=='30001'|| unyCdValue=='30002' || unyCdValue=='30003' || unyCdValue=='30004'");
			this.divContents01.set_visible(true);
			this.divContents01.form.div02.set_visible(true);
			// 희망과목수에 따른 화명 동적처리
			if (hopSbjtCnt == '1') {
				this.divContents01.form.div02.form.edt00.set_visible(true);
				this.divContents01.form.div02.form.cboSel00.set_visible(true);
			} else if (hopSbjtCnt == '2') {
				this.divContents01.form.div02.form.edt00.set_visible(true);
				this.divContents01.form.div02.form.cboSel00.set_visible(true);
				this.divContents01.form.div02.form.edt01.set_visible(true);
				this.divContents01.form.div02.form.cboSel01.set_visible(true);				
			}  else if (hopSbjtCnt == '3') {
				this.divContents01.form.div02.form.edt00.set_visible(true);
				this.divContents01.form.div02.form.cboSel00.set_visible(true);
				this.divContents01.form.div02.form.edt01.set_visible(true);
				this.divContents01.form.div02.form.cboSel01.set_visible(true);
				this.divContents01.form.div02.form.edt02.set_visible(true);
				this.divContents01.form.div02.form.cboSel02.set_visible(true);	
			}  else if (hopSbjtCnt >= '4') {
				this.divContents01.form.div02.form.edt00.set_visible(true);
				this.divContents01.form.div02.form.cboSel00.set_visible(true);
				this.divContents01.form.div02.form.edt01.set_visible(true);
				this.divContents01.form.div02.form.cboSel01.set_visible(true);
				this.divContents01.form.div02.form.edt02.set_visible(true);
				this.divContents01.form.div02.form.cboSel02.set_visible(true);
				this.divContents01.form.div02.form.edt03.set_visible(true);
				this.divContents01.form.div02.form.cboSel03.set_visible(true);	
			}
		}
	}
};


// 희망과목 콤보 공통
this.cbo_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{

	if(obj.id=='cboSel00' && null != obj.value) {
	
		if (obj.value == this.dsHopSbjt.getColumn(1, "hopSbjtCd") || obj.value == this.dsHopSbjt.getColumn(2, "hopSbjtCd")
			|| obj.value == this.dsHopSbjt.getColumn(3, "hopSbjtCd") || obj.value == this.dsHopSbjt.getColumn(4, "hopSbjtCd"))
		{
			this.smfAlert("중복된 과목입니다.");
			return obj.set_value(null);
		}

		if (this.dsHopSbjt.getRowCount() == 0) {
			this.dsHopSbjt.addRow();
			this.dsHopSbjt.setColumn(0, "hopSbjtCd", obj.value);
			this.dsHopSbjt.setColumn(0, "hopSbjtPriorRnk", 1);
			this.divContents01.form.div00.form.cboSel01.set_enable(true);
			this.divContents01.form.div01.form.cboSel01.set_enable(true);
			this.divContents01.form.div02.form.cboSel01.set_enable(true);	
		} else {	
			this.dsHopSbjt.setColumn(0, "hopSbjtCd", obj.value);
			this.dsHopSbjt.setColumn(0, "hopSbjtPriorRnk", 1);
		}
		
	} else if (obj.id=='cboSel01' && null != obj.value) {
		if (obj.value == this.dsHopSbjt.getColumn(0, "hopSbjtCd") || obj.value == this.dsHopSbjt.getColumn(2, "hopSbjtCd")
			|| obj.value == this.dsHopSbjt.getColumn(3, "hopSbjtCd") || obj.value == this.dsHopSbjt.getColumn(4, "hopSbjtCd"))
		{
			this.smfAlert("중복된 과목입니다.");
			return obj.set_value(null);
		}

		if (this.dsHopSbjt.getRowCount() == 1){
			this.dsHopSbjt.addRow();
			this.dsHopSbjt.setColumn(1, "hopSbjtCd", obj.value);
			this.dsHopSbjt.setColumn(1, "hopSbjtPriorRnk", 2);
			this.divContents01.form.div00.form.cboSel02.set_enable(true);
			this.divContents01.form.div01.form.cboSel02.set_enable(true);
			this.divContents01.form.div02.form.cboSel02.set_enable(true);
		} else{
			this.dsHopSbjt.setColumn(1, "hopSbjtCd", obj.value);
			this.dsHopSbjt.setColumn(1, "hopSbjtPriorRnk", 2);
		}

	} else if (obj.id=='cboSel02' && null != obj.value) {
		if (obj.value == this.dsHopSbjt.getColumn(0, "hopSbjtCd") || obj.value == this.dsHopSbjt.getColumn(1, "hopSbjtCd")
			|| obj.value == this.dsHopSbjt.getColumn(3, "hopSbjtCd") || obj.value == this.dsHopSbjt.getColumn(4, "hopSbjtCd"))
		{
			this.smfAlert("중복된 과목입니다.");
			return obj.set_value(null);
		}
	
		if (this.dsHopSbjt.getRowCount() == 2) {
			this.dsHopSbjt.addRow();
			this.dsHopSbjt.setColumn(2, "hopSbjtCd", obj.value);
			this.dsHopSbjt.setColumn(2, "hopSbjtPriorRnk", 3);
			this.divContents01.form.div00.form.cboSel03.set_enable(true);
			this.divContents01.form.div01.form.cboSel03.set_enable(true);
			this.divContents01.form.div02.form.cboSel03.set_enable(true);
		} else {
			this.dsHopSbjt.setColumn(2, "hopSbjtCd", obj.value);
			this.dsHopSbjt.setColumn(2, "hopSbjtPriorRnk", 3);
		}
		
	} else if (obj.id=='cboSel03' && null != obj.value) {	
		if (obj.value == this.dsHopSbjt.getColumn(0, "hopSbjtCd") || obj.value == this.dsHopSbjt.getColumn(1, "hopSbjtCd")
			|| obj.value == this.dsHopSbjt.getColumn(2, "hopSbjtCd") || obj.value == this.dsHopSbjt.getColumn(4, "hopSbjtCd"))
		{
			this.smfAlert("중복된 과목입니다.");
			return obj.set_value(null);
		}
		if (this.dsHopSbjt.getRowCount() == 3) {
			this.dsHopSbjt.addRow();
			this.dsHopSbjt.setColumn(3, "hopSbjtCd", obj.value);
			this.dsHopSbjt.setColumn(3, "hopSbjtPriorRnk", 4);
			this.divContents01.form.div00.form.cboSel04.set_enable(true);
			this.divContents01.form.div01.form.cboSel04.set_enable(true);
		} else {
			this.dsHopSbjt.setColumn(3, "hopSbjtCd", obj.value);
			this.dsHopSbjt.setColumn(3, "hopSbjtPriorRnk", 4);
		}
			
	} else if (obj.id=='cboSel04' && null != obj.value){
		if (obj.value == this.dsHopSbjt.getColumn(0, "hopSbjtCd") || obj.value == this.dsHopSbjt.getColumn(1, "hopSbjtCd")
			|| obj.value == this.dsHopSbjt.getColumn(2, "hopSbjtCd") || obj.value == this.dsHopSbjt.getColumn(3, "hopSbjtCd"))
		{
			this.smfAlert("중복된 과목입니다.");
			return obj.set_value(null);
		}
		
		if (this.dsHopSbjt.getRowCount() == 4) {
			this.dsHopSbjt.addRow();
			this.dsHopSbjt.setColumn(4, "hopSbjtCd", obj.value);
			this.dsHopSbjt.setColumn(4, "hopSbjtPriorRnk", 5);
		} else {
			this.dsHopSbjt.setColumn(4, "hopSbjtCd", obj.value);
			this.dsHopSbjt.setColumn(4, "hopSbjtPriorRnk", 5);
		}	
	}
};

// 희망근무지 수 set
this.fnSetHopPlwkCnt = function (hopPlwkCnt)
{
	// 희망근무지 수에 따른 화면 동적처리
	if (hopPlwkCnt == '1'){
		this.divContents02.set_height(82);
		this.divContents02.form.div00.set_visible(true);
		
	} else if (hopPlwkCnt == '2'){
		this.divContents02.set_height(123);	
		this.divContents02.form.div00.set_visible(true);
		this.divContents02.form.div01.set_visible(true);
		
	} else if (hopPlwkCnt == '3'){
		this.divContents02.set_height(164);
		this.divContents02.form.div00.set_visible(true);
		this.divContents02.form.div01.set_visible(true);
		this.divContents02.form.div02.set_visible(true);
		
	} else if (hopPlwkCnt == '4'){
		this.divContents02.set_height(205);
		this.divContents02.form.div00.set_visible(true);
		this.divContents02.form.div01.set_visible(true);
		this.divContents02.form.div02.set_visible(true);
		this.divContents02.form.div03.set_visible(true);
		
	} else if (hopPlwkCnt == '5'){
		this.divContents02.set_height(246);
		this.divContents02.form.div00.set_visible(true);
		this.divContents02.form.div01.set_visible(true);
		this.divContents02.form.div02.set_visible(true);
		this.divContents02.form.div03.set_visible(true);
		this.divContents02.form.div04.set_visible(true);
		
	} else if (hopPlwkCnt == '6'){
		this.divContents02.set_height(287);
		this.divContents02.form.div00.set_visible(true);
		this.divContents02.form.div01.set_visible(true);
		this.divContents02.form.div02.set_visible(true);
		this.divContents02.form.div03.set_visible(true);
		this.divContents02.form.div04.set_visible(true);
		this.divContents02.form.div05.set_visible(true);
		
	} else if (hopPlwkCnt == '7'){
		this.divContents02.set_height(328);
		this.divContents02.form.div00.set_visible(true);
		this.divContents02.form.div01.set_visible(true);
		this.divContents02.form.div02.set_visible(true);
		this.divContents02.form.div03.set_visible(true);
		this.divContents02.form.div04.set_visible(true);
		this.divContents02.form.div05.set_visible(true);
		this.divContents02.form.div06.set_visible(true);
	}
	this.resetScroll(this);
};

 
