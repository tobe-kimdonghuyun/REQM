        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-계약제교원인력풀-인력풀 신청서 작성
*  @MenuPath    pa_hrd_oew_ap
*  @FileName 	pa_hrd_oewap02_m01.xfdl
*  @Creator 	
*  @CreateDate 	2022.8.11
*  @Desction    온라인통합채용-계약제교원인력풀-인력풀신청서작성 step 2
************** 소스 수정 이력 ***********************************************
*  date                Modifier            Description
*******************************************************************************
*  2022.8.11    	 	최지원             최초 생성 
********************************************************************************/
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.userDtcNo;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form 초기화
	this.smfInitForm(this);
 	
 	// 파라메터 세팅
	this.userDtcNo = this.smfGetSessionValue('userDtcNo');
 	this.pv_params = this.smfGetFormParams();
	var cddcCd = this.smfGetCddcCode();
	
	var mnplSgScCd = this.pv_params.mnplSgScCd;
	var mnplOtlId = this.pv_params.mnplOtlId;
	var mnplReqsId = this.pv_params.mnplReqsId;
	this.dsHopDateTime.setColumn(0,"mnplReqsId", this.pv_params.mnplReqsId);
	
	this.dsSearch.setColumn(0, 'mnplReqsId', this.pv_params.mnplReqsId);
	this.dsSearch.setColumn(0, 'pafrUserId', this.userDtcNo);
	this.dsSearch.setColumn(0, 'mnplReqsId2', this.pv_params.mnplReqsId2);
	this.dsHopDateTime.setColumn(0, 'mnplIdntyDofdcCd', this.pv_params.mnplIdntyDofdcCd);
	this.dsCddcScCd.setColumn(0, 'cddcScCd', cddcCd.substring(0, 3));

	// 개요명, 학교급구분 set
	this.divSearch.form.staSubInfo00.set_text(this.pv_params.mnplOtlNm);
	this.divSearch.form.staSubInfo01.set_text(this.pv_params.mnplSgScCdNm);
	
	// 조회
	this.fnSearch();
	
	// 공통코드
	// dsCtrsScCd : 계약제구분, dsHopSbjtCd : 희망과목코드, dsHrCd : 시간 
	this.smfCodeList("code", [this.dsCtrsScCd, this.dsHopSbjtCd, this.dsHrCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		
		})		
		.run();

};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 this.fnTransCallback  = function(svcid,errcd,errmsg) {

};

/**
 * 희망근무지 1 팝업 콜백
 */
this.fnSelectLocal00ModalCallback = function(e, sender)
{	
	if (e.zoneCd == this.dsHopPlwkZone.getColumn(1, "hopPlwkZoneCd") || e.zoneCd == this.dsHopPlwkZone.getColumn(1, "hopPlwkZoneCd")
		|| e.zoneCd == this.dsHopPlwkZone.getColumn(2, "hopPlwkZoneCd") || e.zoneCd == this.dsHopPlwkZone.getColumn(4, "hopPlwkZoneCd")
		|| e.zoneCd == this.dsHopPlwkZone.getColumn(5, "hopPlwkZoneCd") || e.zoneCd == this.dsHopPlwkZone.getColumn(6, "hopPlwkZoneCd"))
	{
		this.smfAlert("중복된 지역입니다.");
		return;
	}
	//this.smfAlert("응답결과 ==>"+e); 
	if(this.dsHopPlwkZone.getRowCount() == 0){
		var idx = this.dsHopPlwkZone.addRow(); //로우 추가
			// 버튼 사용 여부 
		this.divContents02.form.div01.form.btnLocal00.set_enable(true);
		this.divContents02.form.div01.form.edtSetLocal00.set_enable(true);
		this.divContents02.form.div00.form.edtSetLocal00.set_value(e.zoneNm);// 팝업 선택 지역 
		this.dsHopPlwkZone.setColumn(0, 'hopPlwkPriorRnk', 1);		// 희망근무지우선순위
		this.dsHopPlwkZone.setColumn(0, 'dofdcCd', e.dofdcCd);		// 교육지원청코드
		this.dsHopPlwkZone.setColumn(0, 'hopPlwkZoneCd', e.zoneCd);			// 구역코드
		this.dsHopDateTime.setColumn(0, 'mnplIdntyDofdcCd', e.dofdcCd);  // 인력풀확인교육지원청코드
		
	} else {
		this.divContents02.form.div00.form.edtSetLocal00.set_value(e.zoneNm);// 팝업 선택 지역 
		this.dsHopPlwkZone.setColumn(0, 'hopPlwkPriorRnk', 1);		// 희망근무지우선순위
		this.dsHopPlwkZone.setColumn(0, 'dofdcCd', e.dofdcCd);		// 교육지원청코드
		this.dsHopPlwkZone.setColumn(0, 'hopPlwkZoneCd', e.zoneCd);			// 구역코드
		this.dsHopDateTime.setColumn(0, 'mnplIdntyDofdcCd', e.dofdcCd);  // 인력풀확인교육지원청코드
	}
};

