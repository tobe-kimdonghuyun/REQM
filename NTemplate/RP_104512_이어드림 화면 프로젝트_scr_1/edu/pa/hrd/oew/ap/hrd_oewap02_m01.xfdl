/**
 * 이전 버튼 클릭
 */
this.btnPrev00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (this.dsResultSave.getColumn(0, "resultSave") != "Y")
	{
		this.smfConfirm("저장하지 않은 정보는 변경되지 않습니다. \n이전 단계로 이동 하시겠습니까?", function(result) {
		if(result.confirmResult){
			var prePage = 'Y'
			var params = {
				cddcCd			:this.pv_params.cddcCd,  						// 시도교육청코드(10자리)
				mnplSgScCd		:this.pv_params.mnplSgScCd, 					// 학교급구분코드
				mnplSgScCdNm	:this.pv_params.mnplSgScCdNm,					// 학교급구분명칭
				mnplOtlNm		:this.pv_params.mnplOtlNm,						// 인력풀개요명
				mnplOtlId		:this.pv_params.mnplOtlId,						// 인력풀개요ID:
				mnplReqsId		:this.dsSearch.getColumn(0, "mnplReqsId"),		// 인력풀신청서ID
				hopPlwkCnt		:this.pv_params.hopPlwkCnt,						// 희망근무지수
				hopSbjtCnt		:this.pv_params.hopSbjtCnt,						// 희망과목수
				onslLtoiNeedYn	:this.pv_params.onslLtoiNeedYn,					// 자기소개서 필요여부
				tchQlfEsntlYn	:this.pv_params.tchQlfEsntlYn,					// 교원자격필수 여부
				prePage			:prePage										// 이전화면표시
				};
			this.smfSetWorkPage("pa_hrd_oew_ap::hrd_oewap02_m00.xfdl", params);
			} else return;
		});
	} else if (this.dsResultSave.getColumn(0, "resultSave") == "Y")
	{
		var prePage = 'Y'
		var params = {
			cddcCd			:this.pv_params.cddcCd,  						// 시도교육청코드(10자리)
			mnplSgScCd		:this.pv_params.mnplSgScCd, 					// 학교급구분코드
			mnplSgScCdNm	:this.pv_params.mnplSgScCdNm,					// 학교급구분명칭
			mnplOtlNm		:this.pv_params.mnplOtlNm,						// 인력풀개요명
			mnplOtlId		:this.pv_params.mnplOtlId,						// 인력풀개요ID:
			mnplReqsId		:this.dsSearch.getColumn(0, "mnplReqsId"),		// 인력풀신청서ID
			hopPlwkCnt		:this.pv_params.hopPlwkCnt,						// 희망근무지수
			hopSbjtCnt		:this.pv_params.hopSbjtCnt,						// 희망과목수
			onslLtoiNeedYn	:this.pv_params.onslLtoiNeedYn,					// 자기소개서 필요여부
			tchQlfEsntlYn	:this.pv_params.tchQlfEsntlYn,					// 교원자격필수 여부
			prePage			:prePage										// 이전화면표시
			};
		this.smfSetWorkPage("pa_hrd_oew_ap::hrd_oewap02_m00.xfdl", params);
	}
	
};


/**
 * 인력풀 신청 클릭
 */
this.btnCandi00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsCtrsCd.clearData();
	this.fnSetCtrsCd();
	// 계약제구분 체크 여부
	var isCtrsScCdchck = "N";
	// 계약제구분
	var rowcnt = this.dsCtrsCd.getRowCount();
	for(i = 0; i < rowcnt; i++){
		var ctrsScCd = this.dsCtrsCd.getColumn(i, "ctrsScCd")
		if (ctrsScCd > "0"){
			isCtrsScCdchck = "Y";
			break;
		}
	}
	// 계약제 필수 체크
	if (isCtrsScCdchck != "Y") 
	{
		this.smfAlert('계약제 구분은 필수 선택입니다.');
		return;
	}
	
	if(this.divContents00.form.calBeginDate.value > this.divContents00.form.calEndDate.value) {
		this.smfAlert('시작일자는 종료일자보다 이전이어야 합니다.')
		return;
	}
	
	// 희망과목 -- 조건1: 학교급구분코드 조건 중등
	if (this.dsResultHopWork.getColumn(0, "mnplSgScCd") == '1')
	{
		if (this.smfIsNull(this.divContents01.form.div00.form.cboSel00.value))
		{
			this.smfAlert('희망 과목을 입력하세요.')
			return;
		}
	}
	// 희망과목 특수
	if (this.dsResultHopWork.getColumn(0, "mnplSgScCd") == '4')
	{
		if (this.smfIsNull(this.divContents01.form.div01.form.cboSel00.value))
		{
			this.smfAlert('희망 과목을 입력하세요.')
			return;
		}
	}
	// 희망과목 비교과
	if (this.dsResultHopWork.getColumn(0, "mnplSgScCd") == '5')
	{
		if (this.smfIsNull(this.divContents01.form.div02.form.cboSel00.value))
		{
			this.smfAlert('희망 과목을 입력하세요.')
			return;
		}
	}
	
	// 희망근무지 -- 
	if (this.smfIsNull(this.divContents02.form.div00.form.edtSetLocal00.value))
	{
		this.smfAlert('희망근무지를 하나 이상 입력하세요.')
		return;
	}
	
	// 희망근무시간 
	this.fnSetHopWork();
	
	this.smfConfirm('계약제교원인력풀을 신청하시겠습니까? ', function(result)
	{
		if(result.confirmResult)
		{	
			this.dsRetrns.setColumn(0, "mnplReqsId", this.pv_params.mnplReqsId);
			this.dsRetrns.setColumn(0, "cddcScCd", this.smfGetCddcCode().substring(0, 3));
			this.dsRetrns.setColumn(0, "pafrUserId", this.userDtcNo);
			// 인력풀 신청 버튼 set_enable
			this.div00.form.btnCandi00.set_enable(false);
			this.smfSearchService("selectRetrnsYn")
				.showConfirm(false)
				// 실행
				.run()
				// 콜백
				.callback(function(callbackParams){
				
				if(callbackParams.errors) return;
				
				if(this.dsResultRetrnsYn.getColumn(0, "resultRetrnsYn") === 'N'){
					this.smfAlert("계약제 인력풀이 전송중입니다.");		
					return;
				}
				
				// 서비스 객체 생성
				this.smfSaveService("saveMnplDtl")
					.showConfirm(false)
					// 실행
					.run()
					// 콜백
					.callback(function(callbackParams)
					{
					if(callbackParams.errors) return;
					
					if (this.dsResultTrns.getColumn(0, 'esbRsltCd') != 'SUCC')
					{
						this.smfAlert('인력풀 신청서 전송에 실패했습니다.');
						this.smfSetWorkPage("pa_hrd_oew_ap::hrd_oewap03_m00.xfdl");
						return;
					}
					// 저장이 완료되었습니다.
					this.smfAlert('신청이 완료되었습니다.',  function()
					{
						// param
						var params = 
						{
							mnplSgScCdNm	: this.pv_params.mnplSgScCdNm,					// 학교급구분명칭
							mnplOtlNm		: this.pv_params.mnplOtlNm,						// 인력풀개요명   
							mnplReqsId		: this.pv_params.mnplReqsId						// 인력풀신청서ID	
							
						};
						this.smfSetWorkPage("pa_hrd_oew_ap::hrd_oewap02_m02.xfdl", params);
					});
					
				});
				
			});
		
		}
	});
	
};

