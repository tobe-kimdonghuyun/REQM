// 계약제 인력풀 저장 
this.div00_btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsCtrsCd.clearData();
	this.fnSetCtrsCd();
	// 계약제구분 체크 여부
	var isCtrsScCdchck = "N";
	// 계약제구분
	var rowcnt = this.dsCtrsCd.getRowCount();
	for(i = 0; i < rowcnt; i++){
		var ctrsScCd = this.dsCtrsCd.getColumn(i, "ctrsScCd")
		if (ctrsScCd > "0"){
			isCtrsScCdchck = "Y";
			break;
		}
	}
	// 계약제 필수 체크
	if (isCtrsScCdchck != "Y") 
	{
		this.smfAlert('계약제 구분은 필수 선택입니다.');
		return;
	}
	
	if(this.divContents00.form.calBeginDate.value > this.divContents00.form.calEndDate.value) {
		this.smfAlert('시작일자는 종료일자보다 이전이어야 합니다.')
		return;
	}
	
	// 희망과목 -- 조건1: 학교급구분코드 조건 중등
	if (this.dsResultHopWork.getColumn(0, "mnplSgScCd") == '1')
	{
		if (this.smfIsNull(this.divContents01.form.div00.form.cboSel00.value))
		{
			this.smfAlert('희망 과목을 입력하세요.')
			return;
		}
	}
	// 희망과목 특수
	if (this.dsResultHopWork.getColumn(0, "mnplSgScCd") == '4')
	{
		if (this.smfIsNull(this.divContents01.form.div01.form.cboSel00.value))
		{
			this.smfAlert('희망 과목을 입력하세요.')
			return;
		}
	}
	// 희망과목 비교과
	if (this.dsResultHopWork.getColumn(0, "mnplSgScCd") == '5')
	{
		if (this.smfIsNull(this.divContents01.form.div02.form.cboSel00.value))
		{
			this.smfAlert('희망 과목을 입력하세요.')
			return;
		}
	}
	
	// 희망근무지 -- 
	if (this.smfIsNull(this.divContents02.form.div00.form.edtSetLocal00.value))
	{
		this.smfAlert('희망근무지를 하나 이상 입력하세요.')
		return;
	}
	// 희망근무시간 
	this.fnSetHopWork();
	
	this.smfConfirm('계약제교원인력풀을 저장하시겠습니까? ', function(result)
	{
		if(result.confirmResult)
		{
			// 서비스 객체 생성
			this.smfSaveService("saveTempMnplDtl")
				.showConfirm(false)
				// 실행
				.run()
				// 콜백
				.callback(function(callbackParams){
				
				if (this.dsResultSave.getColumn(0, "resultSave") != "Y")
				{
					this.smfAlert("인력풀 저장에 실패했습니다.");
					return;
				}
				this.smfAlert("인력풀이 저장되었습니다.");
				});
		}
		
	});
};
/**
* 계약제구분코드 
*/
this.fnSetCtrsCd = function ()
{
	var ctrsName;
	var ctrsScCd;  //components[ctrsName]
	for(var i = 0; i < 5; i++){
		var ctrsNo = i + 1;
		ctrsName = "chkCtrsCd0" + ctrsNo;
		ctrsScCd = this.divContents00.form.components[ctrsName].isChecked();
		if (ctrsScCd == true)
		{
			var nRow = this.dsCtrsCd.addRow();
			this.dsCtrsCd.setColumn(nRow, "ctrsScCd", ctrsNo)
		}
	}
};
/**
* 선택 근무지 초기화
*/
this.divContents02_btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	/*this.smfConfirm("선택한 근무지를 초기화 하시겠습니까?", function() {});*/
	var objId;
	var rowCnt = this.dsHopPlwkZone.rowcount;
	var zoneCd;
	for (var i = 1; i <= rowCnt; i++) {
		objId = "div0" + i;
		zoneCd = this.divContents02.form.components[objId].form.edtSetLocal00.value;
		 this.divContents02.form.components[objId].form.edtSetLocal00.set_value(null);
		 this.divContents02.form.components[objId].form.btnLocal00.set_enable(false);
	}
	this.divContents02.form.div00.form.edtSetLocal00.set_value(null);
	this.dsHopPlwkZone.clearData();
};
/**
* 상세과목 초기화
*/
this.divContents01_btn01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divContents01.form.div00.form.cboSel00.set_value(null);
	this.divContents01.form.div00.form.cboSel01.set_value(null);
	this.divContents01.form.div00.form.cboSel02.set_value(null);
	this.divContents01.form.div00.form.cboSel03.set_value(null);
