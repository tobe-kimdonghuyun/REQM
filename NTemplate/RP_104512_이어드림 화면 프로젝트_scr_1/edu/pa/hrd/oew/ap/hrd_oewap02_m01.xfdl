          <Column id="chkCtrsCd05" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsMnplCtwkScCd" useclientlayout="true">
        <ColumnInfo>
          <Column id="mnplCtwkScCd" type="STRING" size="256" description="계약제구분코드"/>
        </ColumnInfo>
