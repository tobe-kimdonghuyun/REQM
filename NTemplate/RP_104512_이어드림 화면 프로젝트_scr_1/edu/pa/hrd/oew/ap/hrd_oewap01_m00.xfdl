      </Dataset>
      <Dataset id="dsChkAplcn" useclientlayout="true">
        <ColumnInfo>
          <Column id="mnplOtlId" type="STRING" size="256" description="인력풀개요ID"/>
          <Column id="mnplSgScCd" type="STRING" size="256" description="학교급구분코드"/>
          <Column id="apstFlnm" type="STRING" size="256" description="지원자성명"/>
          <Column id="brdt" type="STRING" size="256" description="생년월일"/>
          <Column id="mblTelno" type="STRING" size="256" description="휴대전화"/>
