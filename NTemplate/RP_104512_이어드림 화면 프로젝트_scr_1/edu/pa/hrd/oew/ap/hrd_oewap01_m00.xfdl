<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmMain" width="1200" height="944" titletext="계약제교원인력풀-인력풀 신청" onload="frmMain_onload" accessibilityrole="none">
    <Layouts>
      <Layout height="944" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="70" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff" minwidth="">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="인력풀신청" left="0" top="0" height="44" cssclass="img_WF_SubTit01" width="185" initvalueid="ivTitleAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divSearch" taborder="1" left="0" top="144" height="70" cssclass="div_WF_Search" right="0" initvalueid="ivDivAccessibilityOff" minwidth="">
          <Layouts>
            <Layout>
              <Static id="staGrade" taborder="0" text="학교급구분" left="0" top="20" width="94" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Radio id="rdoMnplSgScCd" taborder="1" left="156" top="20" width="649" height="30" codecolumn="unyCdValue" datacolumn="unyCdValueNm" text="" index="-1" direction="horizontal" readonly="false" initvalueid="ivRdoEssential" rowcount="-1" onitemchanged="divSearch_rdoMnplSgScCd_onitemchanged" innerdataset="dsMnplSgScCd"/>
              <Button id="btnSearch" taborder="2" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="20" onclick="divSearch_btnSearch_onclick" initvalueid="ivBtnAccessibilityButton" accessibilitydescription="조회"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divList" taborder="2" left="0" top="divSearch:0" height="650" right="0" cssclass="div_WF_Detail" minwidth="" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgSubTitle00" taborder="0" text="인력풀 리스트" left="0" top="20" width="122" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
              <Grid id="grdList" taborder="1" left="0" top="70" height="570" right="0" binddataset="dsMnplList" autofittype="col" selecttype="cell" initvalueid="ivGrdAccessibilityOn" autosizingtype="none" showselection="false" cellclickbound="control" oncellclick="divList_grdList_oncellclick" accessibilitylabel="신청목록">
                <Formats>
                  <Format id="default">
                    <Columns>
                      <Column size="50"/>
                      <Column size="416"/>
                      <Column size="120"/>
                      <Column size="181"/>
                      <Column size="111"/>
                      <Column size="123"/>
                      <Column size="111"/>
                      <Column size="85"/>
                    </Columns>
                    <Rows>
                      <Row size="31" band="head"/>
                      <Row size="31" band="head"/>
                      <Row size="40"/>
                    </Rows>
                    <Band id="head">
                      <Cell rowspan="2" text="NO"/>
                      <Cell col="1" rowspan="2" text="인력풀개요명"/>
                      <Cell col="2" rowspan="2" text="학교급구분"/>
                      <Cell col="3" rowspan="2" text="신청기간"/>
                      <Cell col="4" rowspan="2" text="신청제약사항/&#13;&#10;상한생년월일"/>
                      <Cell col="5" rowspan="2" text="신청제약사항/&#13;&#10;명예퇴직예외여부"/>
                      <Cell col="6" rowspan="2" text="신청제약사항/&#13;&#10;교원자격필수여부"/>
                      <Cell col="7" rowspan="2" maskeditpostfixtext="expr:년" text="신청버튼"/>
                    </Band>
                    <Band id="body">
                      <Cell text="expr:currow+1" textAlign="center"/>
                      <Cell col="1" text="bind:mnplOtlNm" textAlign="left"/>
                      <Cell col="2" text="bind:mnplSgScCdNm" textAlign="center"/>
                      <Cell col="3" displaytype="normal" calendareditformat="yyyy.MM.dd" border="1px solid #dddfe3,1px solid #f6f7f8" suppressalign="first" edittype="none" text="bind:fromto" maskeditformat="####.##.##~####.##.##" textAlign="center"/>
                      <Cell col="4" border="1px solid #dddfe3,1px solid #f6f7f8" text="bind:aplyUltBrdt" displaytype="date" edittype="none" calendardateformat="yyyy.MM.dd " calendareditformat="yyyy.MM.dd" maskeditclipmode="excludespace" textAlign="center" calendardisplayinvalidtype="none" calendardisplaynulltype="expr:제한없음" expr="[aplyUltBrdt]&lt;00000101?&quot;제한없음&quot;: [aplyUltBrdt]"/>
                      <Cell col="5" text="bind:honorRteeExcpYn" displaytype="normal" edittype="none" maskeditformat="####.##.##" calendardateformat="yyyy.MM.dd" calendareditformat="yyyy.MM.dd" border="1px solid #dddfe3,1px solid #f6f7f8" maskeditclipmode="excludespace" calendardisplayinvalidtype="none" maskeditlimitbymask="none" maskedittype="string" maskeditmaskchar="_" textAlign="center" expr="[honorRteeExcpYn]  =='Y' ?'미포함': '포함'"/>
                      <Cell col="6" text="bind:tchQlfEsntlYn" expr="[tchQlfEsntlYn]=='Y'?'필수':'제한없음'" textAlign="center"/>
                      <Cell col="7" displaytype="buttoncontrol" edittype="button" text="신청하기" imagestretch="none" background="0" padding="5px" textAlign="center"/>
                    </Band>
                  </Format>
                </Formats>
              </Grid>
              <Static id="staText01" taborder="2" left="135" top="20" width="550" height="30" cssclass="sta_WF_Red14" text="※ 학교급 구분을 선택 후 조회하시기 바랍니다 ." initvalueid="ivStcAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staText01" taborder="3" left="0" top="864" width="550" height="30" cssclass="sta_WF_Red14" text="※ 작성할 지원서 기준으로 학교급 구분별 계약제 인력풀을 신청하시면 됩니다." initvalueid="ivStcAccessibilityOn"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsMnplList" useclientlayout="true">
        <ColumnInfo>
          <Column id="NO" type="STRING" size="256"/>
          <Column id="mnplSgScCd" type="STRING" size="256" description="학교급구분코드"/>
          <Column id="mnplSgScCdNm" type="STRING" size="256" description="학교급구분명"/>
          <Column id="mnplOtlNm" type="STRING" size="256" description="인력풀개요명" sumtext=""/>
          <Column id="rcptBgngYmd" type="STRING" size="256" description="접수시작일자"/>
          <Column id="rcptEndYmd" type="STRING" size="256" description="접수종료일자"/>
          <Column id="regDt" type="STRING" size="256" description="등록일" sumtext=""/>
          <Column id="cddcScCd" type="STRING" size="256" description="시도교육청구분코드" sumtext=""/>
