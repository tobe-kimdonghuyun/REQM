          <Column id="pageIndex" type="INT" size="256"/>
          <Column id="pageSize" type="INT" size="256"/>
          <Column id="totalCount" type="INT" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">list</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsMnplList=dsMnplList</Col>
            <Col id="url">hrd_oew_ap01_000.do</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="id">selectDate</Col>
            <Col id="outDatasets">dsDateTime=dsDateTime</Col>
            <Col id="url">cmc_fcm_dt01_001.do</Col>
          </Row>
          <Row>
            <Col id="id">selectAplcnYn</Col>
            <Col id="inDatasets">dsChkAplcn=dsChkAplcn</Col>
            <Col id="outDatasets">dsAplcnYn=dsAplcnYn</Col>
            <Col id="url">hrd_oew_ap01_001.do</Col>
          </Row>
          <Row>
            <Col id="id">selectEmpmnYn</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResultEmpmn=dsResultEmpmn</Col>
            <Col id="url">hrd_oew_ap01_002.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="mnplSgScCd" type="STRING" size="256" description="학교급구분코드"/>
          <Column id="cddcScCd" type="STRING" size="256" description="시도교육청코드3자리"/>
          <Column id="cddcCd" type="STRING" size="256" description="시도교육청코드10자리"/>
          <Column id="pafrUserId" type="STRING" size="256"/>
          <Column id="mnplOtlId" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
