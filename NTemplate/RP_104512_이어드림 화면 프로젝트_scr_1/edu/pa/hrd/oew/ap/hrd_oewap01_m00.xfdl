      </Dataset>
      <Dataset id="dsLogInfo">
        <ColumnInfo>
          <Column id="brdt" type="STRING" size="256" description="생년월일"/>
          <Column id="apstFlnm" type="STRING" size="256" description="지원자성명"/>
          <Column id="mblTelno00" type="STRING" size="256"/>
          <Column id="mblTelno01" type="STRING" size="256"/>
          <Column id="mblTelno02" type="STRING" size="256"/>
