    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-계약제교원인력풀-인력풀 신청
*  @MenuPath    pa_hrd_oew_ap
*  @FileName 	pa_hrd_oewap01_m00.xfdl
*  @Creator 	최지원
*  @CreateDate 	2022.08.10
*  @Desction    온라인통합채용-계약제교원인력풀-인력풀 신청
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.08.10		최지원             최초 생성
*******************************************************************************
*/
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 //파라미터
this.apstFlnm;
this.brdt;
this.mblTelno;
this.userDtcNo; 
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);	
	
	// 주민번호로 로그인의 경우 brdt check & set
/*	var applpRrno     = nexacro.base64Decode(this.smfGetSessionValue('userRrno'));  // 주민번호*/
// 	if (this.smfIsNull(this.smfGetSessionValue('brdt')))
// 	{
// 		this.brdt     = this.applpRrnoToBrdt(nexacro.base64Decode(this.smfGetSessionValue('userRrno')));           // 생년월일
// 	} 
// 	
// 	this.brdt	  = this.smfGetSessionValue('brdt');
// 	trace(brdt);
	brdt = this.smfGetSessionValue('brdt');
	this.brdt = this.smfGetSessionValue('brdt');
	if(this.smfIsNull(brdt)){
		 brdt = this.applpRrnoToBrdt(nexacro.base64Decode(this.smfGetSessionValue('userRrno')));
	}
	if(this.smfIsNull(this.brdt)){
		 this.brdt = this.applpRrnoToBrdt(nexacro.base64Decode(this.smfGetSessionValue('userRrno')));
	}
	
	/*	trace(brdt);*/
	// 파라메터 세팅
 	this.pv_params = this.smfGetFormParams();
	this.userDtcNo = this.smfGetSessionValue('userDtcNo');
	// 세션 정보 set
	this.apstFlnm  = this.smfGetSessionValue('userNm');
	this.mblTelno  = this.smfGetSessionValue('mblTelNo');
	this.userDtcNo = this.smfGetSessionValue('userDtcNo');
// 	this.dsLogInfo.setColumn(0, 'brdt', 	this.brdt);
// 	this.dsLogInfo.setColumn(0, 'apstFlnm', this.apstFlnm);
// 	this.dsLogInfo.setColumn(0, 'mblTelno', this.mblTelno);
// 	var logInfo = this.pv_params.dsLoginInfo;
// 	this.dsLogInfo.loadJSON(logInfo);
	
	// 시도교육청code set
	var cddcCd = this.smfGetCddcCode();
	this.dsSearch.setColumn(0, 'cddcCd', cddcCd);
	this.dsSearch.setColumn(0, 'pafrUserId', this.userDtcNo);
// 	// 생년월일(지원서작성에서 신청상한 생년월일 조건을 위해 set) --  <delete>
// 	var brdt = parseInt(this.dsLogInfo.getColumn(0, "brdt"));
	
// 	// 	휴대전화 -- (미사용)
// 	var mblTelno00 = this.mblTelno.substr(0,3);
// 	var mblTelno01 = this.mblTelno.substr(4,4);
// 	var mblTelno02 = this.mblTelno.substr(9,4);
// 	this.dsLogInfo.setColumn(0, 'mblTelno00', mblTelno00);
// 	this.dsLogInfo.setColumn(0, 'mblTelno01', mblTelno01);
// 	this.dsLogInfo.setColumn(0, 'mblTelno02', mblTelno02);
	
	// 신청가능여부 Y/N
	this.dsSearch.setColumn(0, 'apstFlnm', this.apstFlnm);
	this.dsSearch.setColumn(0, 'brdt	', this.brdt);
	this.dsSearch.setColumn(0, 'mblTelno', this.mblTelno);
	// 채용여부 Y/N
// 	this.dsSearchEmpmn.setColumn(0, 'apstFlnm', this.dsLogInfo.getColumn(0, 'apstFlnm'));
// 	this.dsSearchEmpmn.setColumn(0, 'brdt', 	this.dsLogInfo.getColumn(0, 'brdt'));
// 	this.dsSearchEmpmn.setColumn(0, 'mblTelno', this.dsLogInfo.getColumn(0, 'mblTelno'));
	
	// 공통코드
	// dsMnplSgScCd : 학교급구분 
	this.smfCodeList("code", [this.dsMnplSgScCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		})		
		.run();
	this.fnSearch();
	this.fnSearchDate();
	 // 채용여부 조회
	this.smfSearchService("selectEmpmnYn")	
 		// 실행 
 		.run()	
		// 콜백
		.callback(function(callbackParams){
 			if(callbackParams.errors) return;
// 			if ("Y" == this.dsResultEmpmn.getColumn(0, 'mnplEmpmnYn'))
// 			{
// 				this.divList.form.grdList.set_enable(false);
// 				this.smfAlert("채용 상태 중으로 신청할 수 없습니다.");
// 				return;
// 			}
 		});	
};


/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 // 인력풀 신청서 리스트 조회 서비스 
 this.fnSearch = function(){

		// 서비스 객체 생성
	this.smfSearchService("list")
		
		// 데이터 존재 필수(검색 조건)
		.requireExistsData(this.dsSearch)

		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});
}

/**
 *현재 일자 검색
 */
this.fnSearchDate = function(obj, e)
{	
	// 서비스 객체 생성
	this.smfSearchService("selectDate")
		// 실행
		.run()
		
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;

		});
}

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 조회 버튼 클릭 시
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	this.fnSearch();
	this.fnSearchDate();
	 // 서비스 객체 생성
	 // 채용여부 조회
	this.smfSearchService("selectEmpmnYn")	
 		// 실행
 		.run()	
		// 콜백
		.callback(function(callbackParams){
 			if(callbackParams.errors) return;
// 			if ("Y" == this.dsResultEmpmn.getColumn(0, 'mnplEmpmnYn'))
// 			{
// 				this.divList.form.grdList.set_enable(false);
// 				this.smfAlert("채용 상태 중으로 신청할 수 없습니다.");
// 				return;
// 			}
 		});	
};


/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// 학교급구분 라디오 선택시 
this.divSearch_rdoMnplSgScCd_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	// 학교급구분코드 set
	var mnplSgScCd = this.divSearch.form.rdoMnplSgScCd.value;
	this.dsSearch.setColumn(0, "mnplSgScCd", mnplSgScCd);
	
};

// 그리드에서 신청하기 버튼 클릭
this.divList_grdList_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	
	// 클릭한 셀을 구한다
	var nRow = e.row;
	var nCell = e.cell;
	
	// 신청 가능 여부 조회 set
	this.dsChkAplcn.setColumn(0, "mnplOtlId", this.dsMnplList.getColumn(nRow, "mnplOtlId"));
	this.dsChkAplcn.setColumn(0, "mnplSgScCd", this.dsMnplList.getColumn(nRow, "mnplSgScCd"));
	this.dsChkAplcn.setColumn(0, 'pafrUserId', this.userDtcNo);
	// 신청하기 버튼 
	if(nCell == 7 ){
		if ("Y" == this.dsResultEmpmn.getColumn(0, 'mnplEmpmnYn'))
		{
			this.divList.form.grdList.set_enable(false);
			this.smfAlert("채용 상태 중으로 신청할 수 없습니다.");
			return;
		}
		
		// 신청기간
		var today = parseInt(this.dsDateTime.getColumn(0, "yyyymmdd"));
		// 신청시작일
		var beginDay = parseInt(this.dsMnplList.getColumn(nRow, "rcptBgngYmd"));
		// 신청종료일
		var endDay = parseInt(this.dsMnplList.getColumn(nRow, "rcptEndYmd"));

		// 지원서 신청가능 기간 체크
		if (beginDay <= today && today <= endDay){
			// 신청가능의 경우 신청상한생년월일 체크+
			var limitAge = this.dsMnplList.getColumn(nRow, "aplyUltBrdt");	
			// 상한 데이터가 있을 경우
			if(limitAge != ""){
				var limit = parseInt(limitAge.substr(0,8));
				var nBrdt = this.dsLogInfo.getColumn(0, "brdt");		
				// 상한 체크
// 				if ( nBrdt < limit){
// 					this.smfAlert("신청 상한 생년월일을 확인하세요.", function(){});
// 					return;
// 				}
				// 상한 체크 오류로 인한 변수 바꿔서 상한 체크로 수정
				if ( this.brdt < limit){
					this.smfAlert("신청 상한 생년월일을 확인하세요.", function(){});
					return;
				}
			}	
		// 신청기간이 아님		
		} else {
			this.smfAlert("지원서 신청 기한이 아닙니다.", function(){});
			return;
		}
		// 서비스 객체 생성
		this.smfSearchService("selectAplcnYn")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			if ("Y" != this.dsAplcnYn.getColumn(0, 'aplcnYn'))
			{
				this.smfAlert("작성중 또는 신청 및 승인된 인력풀이 존재합니다.");
				return;
			}
			// 신청가능 = (기간 OK + 상한 OK)
			var params = {
				mnplSgScCd		:this.dsMnplList.getColumn(nRow, "mnplSgScCd"),					// 학교급구분코드
				mnplSgScCdNm	:this.dsMnplList.getColumn(nRow, "mnplSgScCdNm"),				// 학교급구분명칭
				mnplOtlNm		:this.dsMnplList.getColumn(nRow, "mnplOtlNm"),					// 인력풀개요명
				mnplOtlId		:this.dsMnplList.getColumn(nRow, "mnplOtlId"),					// 인력풀개요ID
				hopPlwkCnt		:this.dsMnplList.getColumn(nRow, "hopPlwkCnt"),					// 희망근무지수
				hopSbjtCnt		:this.dsMnplList.getColumn(nRow, "hopSbjtCnt"),					// 희망과목수
				onslLtoiNeedYn	:this.dsMnplList.getColumn(nRow, "onslLtoiNeedYn"),				// 자기소개서 필요 여부
				tchQlfEsntlYn	:this.dsMnplList.getColumn(nRow, "tchQlfEsntlYn"),				// 교원자격필수 여부
				"dsLogInfo"		:this.dsLogInfo.saveJSON()										// 로그인 정보
				
			};
			
			// 지원서 작성으로 이동		
			this.smfSetWorkPage("pa_hrd_oew_ap::hrd_oewap02_m00.xfdl", params); 	
		});
		
		
	}
};]]></Script>
  </Form>
</FDL>
