              <Static id="sta06" taborder="9" left="0" width="120" height="42" cssclass="sta_WF_Input01" text="연수이수시간" top="82" initvalueid="ivStcAccessibilityOn" onclick="Static45_onclick"/>
              <Edit id="edtTrnTime" taborder="10" left="125" top="88" height="30" initvalueid="ivEdtNormal" text="30" width="140" textAlign="center" maxlength="4" inputtype="digit" cssclass="essential"/>
              <Static id="sta00_01" taborder="11" text="시간" left="275" top="88" width="30" height="30" cssclass="sta_WF_Label" initvalueid="ivStcAccessibilityOn"/>
