 /************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 조회버튼 클릭
 */
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var str = this.divSearch.form.cal00.value;
	var end = this.divSearch.form.cal01.value;
	if(str > end && end != "" ){
		this.smfAlert("시작일자는 종료일자보다 이전이어야 합니다.");
		return false;
	}
	this.dsSearch.setColumn(0, 'pafrUserId', this.userDtcNo);
	this.fnSearch();
	this.fnSearchDate();
	
// 	// 채용여부에 따른 그리드 사용 여부 set
// 	if(this.dsResultEmpmn.getColumn(0, 'mnplEmpmnYn') == "Y"){
// 		this.divAdmit.form.grdAdmit.set_enable(false);
// 		this.smfAlert('채용 상태 중으로 신청 및 변경이 불가합니다.');
// 	}
};
/**
 * 캘린더 변경 시 -- 시작일자
 */
this.divSearch_cal00_onchanged = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{
	this.dsSearch.setColumn(0, "strDate", this.divSearch.form.cal00.value.substring(0, 8));

};
/**
 * 캘린더 변경 시 -- 종료일자
 */
this.divSearch_cal01_onchanged = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{
	this.dsSearch.setColumn(0, "endDate", this.divSearch.form.cal01.value.substring(0, 8));

	
};
/**
 * 학교급구분 콤보 변경 시
 */
this.divSearch_cbo00_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.dsSearch.setColumn(0,"mnplSgScCd", obj.value);

};

/**
 * 그리드 셀 클릭 시
 */
this.divAdmit_grdAdmit_oncellclick = function(obj:nexacro.Button,e:nexacro.GridClickEventInfo)
{
	// 클릭한 셀을 구한다
	var nRow = e.row;
	var nCell = e.cell;
	// 승인상태(N : 임시저장(미신청) 0: 연계오류(재전송) 1 : 신청완료 2 : 승인 3: 반려 4 : 승인취소(등재취소))
	var sVal = this.dsResultMnplAplyPnsta.getColumn(nRow, "mnplAprvStsCd");
	// 신청기간
	var bgngYmd = parseInt(this.dsResultMnplAplyPnsta.getColumn(nRow, "rcptBgngYmd"));
	var endYmd = parseInt(this.dsResultMnplAplyPnsta.getColumn(nRow, "rcptEndYmd"));
	var today = parseInt(this.dsDateTime.getColumn(0, 'yyyymmdd'));
	// 수정 여부
	var prePage = 'Y';
	// 반려상태 
	var aprvSts = '3';
	// 재신청 가능 여부 조회 set
	this.dsChkReaplcn.setColumn(0, "mnplOtlId", this.dsResultMnplAplyPnsta.getColumn(nRow, "mnplOtlId"));
	this.dsChkReaplcn.setColumn(0, "mnplSgScCd", this.dsResultMnplAplyPnsta.getColumn(nRow, "mnplSgScCd"));
	this.dsChkReaplcn.setColumn(0, "pafrUserId", this.userDtcNo);
	
	// 버튼 클릭
	if(nCell == 7)
	{ 
//      // 2024.01.23 채용중 상태의 사용자도 재신청할 수 있게끔 채용여부 체크로직 삭제 요청
// 		// 채용여부에 따른 그리드 사용 여부 set
// 		if(this.dsResultEmpmn.getColumn(0, 'mnplEmpmnYn') == "Y"){
// 			this.divAdmit.form.grdAdmit.set_enable(false);
// 			this.smfAlert('채용 상태 중으로 신청 및 변경이 불가합니다.');
// 			return;
// 		}
		// 신청기한 (가능)
		if(bgngYmd <= today && endYmd >= today) 
		{
			// 재전송 일때 
			if (sVal == '0')
			{
				this.smfConfirm("인력풀 신청서를 재전송하시겠습니까?", function (result)
				{
					if(result.confirmResult){
						this.dsRetrns.setColumn(0, "mnplReqsId", this.dsResultMnplAplyPnsta.getColumn(nRow, "mnplReqsId"));
						this.dsRetrns.setColumn(0, "cddcScCd", this.smfGetCddcCode().substring(0, 3));
						this.dsRetrns.setColumn(0, "pafrUserId", this.userDtcNo);
						// 서비스 객체 생성
						this.smfSearchService("selectRetrnsYn")
						// 실행
						.run()	
						// 콜백
						.callback(function(callbackParams){
							if(callbackParams.errors) return;
							if(this.dsResultRetrnsYn.getColumn(0, "resultRetrnsYn") == 'N') {
								this.smfAlert("계약제인력풀 전송중입니다.");
								return;
							}
							
							// 서비스 객체 생성
							this.smfSaveService("saveRetrns")
							// 메세지 표시(미출력)
							.showConfirm(false)
							// 실행
							.run()	
							// 콜백
							.callback(function(callbackParams){
								if(callbackParams.errors) return;
								
								if ('SUCC' != this.dsResultRetrns.getColumn(0, "esbRsltCd"))
								{
									this.smfAlert("인력풀 신청에 실패했습니다.");
									this.fnSearch();
									return;
								}
								this.smfAlert("인력풀 신청이 완료되었습니다.");	
								this.fnSearch();				
							});
						});
						
					}
				});
			}
			// 미신청 상태 (작성중)
			if (sVal == 'N') 
			{
				var params = {
					prePage 		: prePage, 
					mnplReqsId 		: this.dsResultMnplAplyPnsta.getColumn(nRow, "mnplReqsId"),
					mnplOtlNm 		: this.dsResultMnplAplyPnsta.getColumn(nRow, "mnplOtlNm"),
					mnplSgScCdNm 	: this.dsResultMnplAplyPnsta.getColumn(nRow, "mnplSgScCdNm"),
					hopPlwkCnt 		: this.dsResultMnplAplyPnsta.getColumn(nRow, "hopPlwkCnt"),
					hopSbjtCnt 		: this.dsResultMnplAplyPnsta.getColumn(nRow, "hopSbjtCnt"),
					onslLtoiNeedYn 	: this.dsResultMnplAplyPnsta.getColumn(nRow, "onslLtoiNeedYn"),
					tchQlfEsntlYn	: this.dsResultMnplAplyPnsta.getColumn(nRow, "tchQlfEsntlYn")
			};
			// 지원서 작성화면으로
			this.smfSetWorkPage("pa_hrd_oew_ap::hrd_oewap02_m00.xfdl", params);
			// 반려상태 (재신청)
			} else if(sVal == '3') {
				
				// 서비스 객체 생성
				this.smfSearchService("selectReaplcn")	
					// 실행
					.run()	
					// 콜백
					.callback(function(callbackParams){
						if(callbackParams.errors) return;
						// 신청가능 여부 확인
						if ("Y" != this.dsReaplcnYn.getColumn(0, "reaplcnYn"))
						{
							this.smfAlert("작성중 또는 신청 및 승인된 인력풀이 존재합니다.");
							return;
						}
						var params = {
							aprvSts 		: aprvSts,
							mnplReqsId 		: this.dsResultMnplAplyPnsta.getColumn(nRow, "mnplReqsId"),
							mnplOtlId 		: this.dsResultMnplAplyPnsta.getColumn(nRow, "mnplOtlId"),
							mnplOtlNm 		: this.dsResultMnplAplyPnsta.getColumn(nRow, "mnplOtlNm"),
							mnplSgScCd 		: this.dsResultMnplAplyPnsta.getColumn(nRow, "mnplSgScCd"),
							mnplSgScCdNm 	: this.dsResultMnplAplyPnsta.getColumn(nRow, "mnplSgScCdNm"),
							hopPlwkCnt 		: this.dsResultMnplAplyPnsta.getColumn(nRow, "hopPlwkCnt"),
							hopSbjtCnt 		: this.dsResultMnplAplyPnsta.getColumn(nRow, "hopSbjtCnt"),
							onslLtoiNeedYn 	: this.dsResultMnplAplyPnsta.getColumn(nRow, "onslLtoiNeedYn"),
							tchQlfEsntlYn	: this.dsResultMnplAplyPnsta.getColumn(nRow, "tchQlfEsntlYn")
						};
						// 지원서 작성화면으로
						this.smfSetWorkPage("pa_hrd_oew_ap::hrd_oewap02_m00.xfdl", params);
						});	
					
				
			// 승인상태
			} else if (sVal == '2')
			{
				this.smfConfirm('인력풀에 정보등재를 취소하시겠습니까? ', function(result)
				{
					if(result.confirmResult)
					{	
						// 승인 취소 버튼 
						this.dsSearch.setColumn(0, "mnplReqsId", this.dsResultMnplAplyPnsta.getColumn(nRow, "mnplReqsId"));
						this.dsResultMnplAplyPnsta.setColumn(nRow, "mnplAprvStsCd", '4');
						this.dsResultMnplAplyPnsta.setColumn(nRow, "mnplAprvStsCdNm", '승인취소');
						// 서비스 생성
						this.smfSaveService("saveAprvSts")
							// 메세지 표시 선택
							.showConfirm(false)
							.run()
							.callback(function(callbackParams){
							
							if(callbackParams.errors){
								return;
							}
							this.smfAlert("인력풀 등재가 취소되었습니다.");
						});
							
					}
					this.fnSearch();
				});
				
			}
		} else {
			this.smfAlert('신청기간이 아닙니다.')
			return;
		}

	} 	
};

]]></Script>
  </Form>
</FDL>
