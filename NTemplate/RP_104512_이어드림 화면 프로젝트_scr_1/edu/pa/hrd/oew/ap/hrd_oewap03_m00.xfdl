              <Static id="sta01" taborder="2" text="~" left="228" top="20" width="15" height="30" textAlign="center" initvalueid="ivStcAccessibilityOn" accessibilitylabel="부터"/>
              <Calendar id="cal01" taborder="3" left="243" top="20" width="140" height="30" cssclass="essential" initvalueid="ivCalEssential" dateformat="yyyy.MM.dd " editformat="yyyy.MM.dd " onchanged="divSearch_cal01_onchanged"/>
              <Static id="sta02" taborder="4" text="학교급구분" left="383" top="20" width="103" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" font="16px/normal &quot;Noto Sans KR&quot;,&quot;NotoSansKR-Regular&quot;,&quot;Malgun Gothic&quot;,&quot;Arial&quot;,&quot;MS PGothic&quot;" textAlign="left"/>
              <Combo id="cbo00" taborder="5" left="486" top="20" width="170" height="30" value="0" index="0" innerdataset="dsMnplSgScCd" codecolumn="unyCdValue" datacolumn="unyCdValueNm" text="" onitemchanged="divSearch_cbo00_onitemchanged" initvalueid="ivCmbNormal"/>
              <Button id="btnSearch" taborder="6" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="30" onclick="divSearch_btnSearch_onclick" initvalueid="ivBtnAccessibilityButton"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divAdmit" taborder="3" text="div00" left="0" top="254" height="550" right="0" cssclass="div_WF_Detail" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="img00" taborder="0" text="인력풀 신청내역" left="0" top="20" width="137" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
              <Grid id="grdAdmit" taborder="1" left="0" top="60" height="490" right="0" binddataset="dsResultMnplAplyPnsta" autofittype="col" selecttype="cell" initvalueid="ivGrdAccessibilityOn" oncellclick="divAdmit_grdAdmit_oncellclick" accessibilitylabel="지원내역목록">
                <Formats>
                  <Format id="default">
                    <Columns>
                      <Column size="30"/>
                      <Column size="298"/>
                      <Column size="80"/>
                      <Column size="80"/>
                      <Column size="114"/>
                      <Column size="100"/>
                      <Column size="65"/>
                      <Column size="85"/>
                      <Column size="80"/>
                      <Column size="261"/>
                    </Columns>
                    <Rows>
                      <Row size="36" band="head"/>
                      <Row size="40"/>
                    </Rows>
                    <Band id="head">
                      <Cell text="NO"/>
                      <Cell col="1" text="개요명"/>
                      <Cell col="2" text="학교급구분"/>
                      <Cell col="3" text="계약제구분"/>
                      <Cell col="4" text="희망과목"/>
                      <Cell col="5" text="신청서제출일자"/>
                      <Cell col="6" colspan="2" text="승인상태"/>
                      <Cell col="8" text="확인일자"/>
                      <Cell col="9" text="반려사유"/>
                    </Band>
                    <Band id="body">
                      <Cell text="expr:currow +1"/>
                      <Cell col="1" text="bind:mnplOtlNm" textAlign="left" wordWrap="char"/>
                      <Cell col="2" text="bind:mnplSgScCdNm" textAlign="center" wordWrap="char"/>
                      <Cell col="3" text="bind:ctrsScCdNm" textAlign="center" wordWrap="char"/>
                      <Cell col="4" text="bind:listHopSbjtCd" autosizerow="default" textAlign="center" controlautosizingtype="height" wordWrap="char"/>
                      <Cell col="5" text="bind:reqsSbmsnYmd" textAlign="center" displaytype="date" calendardateformat="yyyy.MM.dd" calendareditformat="yyyy.MM.dd" calendardisplaynulltype="none"/>
                      <Cell col="6" text="bind:mnplAprvStsCdNm" textAlign="center" expr="[mnplAprvStsCd]=='N'?&quot;작성중&quot;:([mnplAprvStsCd]=='0'?&quot;신청대기&quot;:([mnplAprvStsCd]=='1'?&quot;신청&quot;:[mnplAprvStsCdNm]))"/>
                      <Cell col="7" edittype="none" text="bind:mnplAprvStsCd" accessibilityrole="button" padding="7px" expr="[mnplAprvStsCd]=='N'?&quot;수정&quot;:([mnplAprvStsCd]=='3'?&quot;재신청&quot;:([mnplAprvStsCd]=='2'?&quot;승인취소&quot;:([mnplAprvStsCd]=='0'?&quot;재전송&quot;:'none')))" displaytype="expr:[mnplAprvStsCd]=='1'?'none':([mnplAprvStsCd]=='4'?'none':'buttoncontrol')" textAlign="center"/>
                      <Cell col="8" text="bind:idntyYmd" textAlign="center" displaytype="date" calendardateformat="yyyy.MM.dd" calendareditformat="yyyy.MM.dd" calendardisplaynulltype="none" expr="[idntyYmd] != null?[idntyYmd]:&quot;미확인&quot;"/>
                      <Cell col="9" text="bind:rjctRsnCn" textAlign="center" wordWrap="char"/>
                    </Band>
                  </Format>
                </Formats>
              </Grid>
              <Static id="staGD00" taborder="2" left="0" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" right="0" initvalueid="ivStcAccessibilityOff" visible="false"/>
