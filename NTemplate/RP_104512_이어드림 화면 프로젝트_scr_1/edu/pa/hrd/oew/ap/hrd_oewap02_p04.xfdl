<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmMain" width="740" height="296" titletext="계약제교원인력풀-국가기술자격정보 팝업" onload="frmMain_onload">
    <Layouts>
      <Layout height="296" width="740" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divMain" taborder="1" left="20" height="225" top="20" text="" cssclass="div_WF_Detail" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="sta01" taborder="0" left="120" height="42" cssclass="sta_WF_Input02Top" top="0" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta03" taborder="1" left="120" height="42" cssclass="sta_WF_Input02" top="41" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta05" taborder="2" left="120" height="42" cssclass="sta_WF_Input02" top="82" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta07" taborder="3" left="120" height="42" cssclass="sta_WF_Input02" top="123" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta09" taborder="4" left="120" height="42" cssclass="sta_WF_Input02" top="163" right="0" initvalueid="ivStcAccessibilityOff" text=""/>
              <Static id="sta00" taborder="5" left="0" width="120" height="42" cssclass="sta_WF_Input01Top" text="발급기관명" top="0" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edt00" taborder="6" left="124" top="6" height="30" initvalueid="ivEdtNormal" text="한국산업인력공단" maxlength="50" accessibilitylabel="발급기관명" width="300" cssclass="essential"/>
              <Static id="sta02" taborder="7" left="0" width="120" height="42" cssclass="sta_WF_Input01" text="자격증명" top="41" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edt01" taborder="8" left="125" top="47" height="30" initvalueid="ivEdtNormal" text="정보처리기사" maxlength="50" accessibilitylabel="자격증명" width="300" cssclass="essential"/>
              <Static id="sta04" taborder="9" left="0" width="120" height="42" cssclass="sta_WF_Input01" text="자격증번호" top="82" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edt02" taborder="10" left="125" top="88" height="30" initvalueid="ivEdtNormal" text="제 OOOO호" maxlength="30" accessibilitylabel="자격증번호" width="300" cssclass="essential"/>
              <Static id="sta06" taborder="11" left="0" width="120" height="42" cssclass="sta_WF_Input01" text="취득일자" top="123" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn"/>
              <Calendar id="cal00" taborder="12" left="125" top="129" height="30" initvalueid="ivCalNormal" dateformat="yyyy.MM.dd" editformat="yyyy.MM.dd" accessibilitylabel="취득일자" width="130" canchange="cal_canchange" cssclass="essential"/>
              <Static id="sta08" taborder="13" left="0" width="120" height="42" cssclass="sta_WF_Input01" text="증명자료" top="163" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn"/>
              <Div id="divFileContent" taborder="14" left="125" top="169" width="420" height="30" url="comm::comm_fileAdd2.xfdl" Mode="upload" uploadLocation="PA.HRD.OEW" addProp="fnSetRaonProp" privInfoFiltYn="N" fileEncryptYn="N" fileSaveStg="SV" accessibilitylabel="증명자료" initvalueid="ivDivAccessibilityOff"/>
              <Static id="staGD00" taborder="15" left="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" top="205" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnCancel" taborder="2" text="취소" height="30" width="50" left="43.25%" fittocontents="width" cssclass="btn_WF_Custom" initvalueid="ivBtnAccessibilityButton" top="246" onclick="btnCancel_onclick"/>
        <Button id="btnRegist" taborder="3" text="적용" height="30" width="50" fittocontents="width" left="btnCancel:8" initvalueid="ivBtnAccessibilityButton" top="246" onclick="btnRegist_onclick"/>
        <Static id="staGD00" taborder="4" left="20" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta01" taborder="5" left="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff" top="276" height="20"/>
        <Static id="sta02" taborder="6" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta03" taborder="7" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsMain" useclientlayout="true">
        <ColumnInfo>
          <Column id="fileRefrnId" type="STRING" size="256"/>
          <Column id="atchFileNm" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-계약제교원인력풀-국가기술자격정보 팝업
*  @MenuPath    pa_hrd_oew_ap
*  @FileName 	pa_hrd_oewap02_p04.xfdl
*  @Creator 	
*  @CreateDate 	2022.8.18
*  @Desction    온라인통합채용-계약제교원인력풀-국가기술자격정보 팝업
************** 소스 수정 이력 ***********************************************
*  date                Modifier            Description
*******************************************************************************
*  2022.8.18    	 	최지원             최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

	// default 초기처리를 한다.
	this.smfInitPopup(obj);

	// 파라메터 셋
	this.pv_params = this.smfGetPopupParams();
	// 팝업 타이틀 변경
	this.smfUpdatePopupTitle("국가기술자격정보");
	
	// 파일 업로드
	this.divMain.form.divFileContent.UPLOAD_UploadComplete  = this.fnFileUploadCompleteCallback;
	this.divMain.form.divFileContent.UPLOAD_OnError         = this.fnFileUploadErrorCallback;
	this.divMain.form.divFileContent.UPLOAD_AfterAddFile    = this.fnFileUploadChangeCallback;     
	this.divMain.form.divFileContent.UPLOAD_Form            = this;
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 파일 업로드 성공 콜백
this.fnFileUploadCompleteCallback = function(obj, paramObj, objResultDataset)
{
	this.divMain.form.divFileContent.form.fnSetUploadCompleteState(obj,paramObj);
	this.dsMain.setColumn(0, "fileRefrnId", objResultDataset.getColumn(0, "fileRefrnId"));
	this.dsMain.setColumn(0, "atchFileNm", objResultDataset.getColumn(0, "atchFileNm"));
	// 23.07.19 싱글파일 처리. fileRefrnId 하나에 하나의 파일만 업로드, 업로드 변경할 때 새로운 fileRefrnId 생성을 위해 fnResetUpload 
	this.divMain.form.divFileContent.form.fnResetUpload();
	// 23.07.19 리셋으로 인해 파일명 미표시되는 것 set
	this.divMain.form.divFileContent.form.edtFile.set_value(this.dsMain.getColumn(0, "atchFileNm"));

};

// 파일 업로드 실패 콜백
this.fnFileUploadErrorCallback = function(obj, paramObj)
{
	//this.smfAlert('파일 업로드에 실패하였습니다.');
};

// 파일 업로드 변경 콜백
this.fnFileUploadChangeCallback = function(obj, paramObj, sCustomValue, sFileName, nFileSize)
{
	this.divMain.form.divFileContent.form.fnFileUpload();	
};
 /************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 
 /************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 // 캘린더 미래 일자 변경
 this.cal_canchange = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{
	var yy = e.postvalue.substring(0, 2);
	if ( !(yy == 19 || yy == 20) ) {
		obj.set_value(null);
		this.smfAlert("입력이 불가한 날짜입니다.");
		return false;
	}

	//오늘 이후 선택 안됨
	if ( e.postvalue > this.smfToday() )
	{
		this.smfAlert("미래 일자를 입력할 수 없습니다.");
		return false;
	}	
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 /**
 * 확인버튼 클릭	
 */
this.btnRegist_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	if (this.smfIsNull(this.divMain.form.edt00.value)) 
	{
		this.divMain.form.edt00.setFocus();
		this.smfAlert('발급기관명을 입력하세요');
		return;
	}
		
	if(this.smfIsNull(this.divMain.form.edt01.value))
	{
		this.divMain.form.edt01.setFocus();
		this.smfAlert('자격증명을 입력하세요');
		return;
	}
	
	if(this.smfIsNull(this.divMain.form.edt02.value)) 
	{
		this.divMain.form.edt02.setFocus();
		this.smfAlert('자격증번호을 입력하세요');
		return;
	}
	
	if(this.smfIsNull(this.divMain.form.cal00.value))
	{
		this.divMain.form.cal00.setFocus();
		this.smfAlert('취득일자를 입력하세요');
		return;
	}	

	// 증명자료 
	if( this.smfIsNull(this.dsMain.getColumn(0, "fileRefrnId")))
	{ 
		this.divMain.form.divFileContent.setFocus();
		this.smfAlert('증명자료는 필수입니다.');
		return;
	} 


	// 입력값 부모창 전달
	this.smfSendResponseToOpener({
		"issuInstNm" 	: this.divMain.form.edt00.value, // 발급기관명
		"qlflNm" 		: this.divMain.form.edt01.value, // 자격증명
		"qlflNo" 		: this.divMain.form.edt02.value, // 자격증번호
		"acqsYmd" 		: this.divMain.form.cal00.value, // 취득일자
		"fileRefrnId" 	: this.dsMain.getColumn(0, "fileRefrnId"), // 파일참조ID
		"atchFileNm" 	: this.dsMain.getColumn(0, "atchFileNm"), // 첨부파일명
		"flagAdd"		: "Y"
	});
	this.close(true);
};

/**
 * 취소버튼 클릭
 */
this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};

]]></Script>
  </Form>
</FDL>
