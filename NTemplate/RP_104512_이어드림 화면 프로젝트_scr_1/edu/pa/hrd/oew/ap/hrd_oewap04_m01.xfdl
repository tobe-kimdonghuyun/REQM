// 파일 업로드 성공 콜백
this.fnFileUploadCompleteCallback = function(obj, paramObj, objResultDataset)
{
	var target = obj.parent.parent.id;
	switch(target){
		// 지원자사진
		case 'divFileUpload' : 
			this.divFileUpload.form.fnSetUploadCompleteState(obj,paramObj);
			this.dsResultMnplReqsBase.setColumn(0, "photoRefrnId", objResultDataset.getColumn(0, "fileRefrnId"));
			this.dsResultMnplReqsBase.setColumn(0, "apstPhotoFileNm", objResultDataset.getColumn(0, "atchFileNm"));

		break;
	
		// 자기소개서
		case 'divOnslLtoiFile' : 
			this.divOnslLtoi.form.divOnslLtoiFile.form.fnSetUploadCompleteState(obj,paramObj);
			this.dsResultMnplReqsBase.setColumn(0, "onslLtoiFileRefrnId", objResultDataset.getColumn(0, "fileRefrnId"));
			this.dsResultMnplReqsBase.setColumn(0, "atchFileNm", objResultDataset.getColumn(0, "atchFileNm"));
			// 23.07.19 싱글파일 처리. fileRefrnId 하나에 하나의 파일만 업로드, 업로드 변경할 때 새로운 fileRefrnId 생성을 위해 fnResetUpload 
			this.divOnslLtoi.form.divOnslLtoiFile.form.fnResetUpload();
			// 23.07.19 리셋으로 인해 파일명 미표시되는 것 set
			this.divOnslLtoi.form.divOnslLtoiFile.form.edtFile.set_value(this.dsResultMnplReqsBase.getColumn(0, "atchFileNm"));
		break;
		// 기타첨부파일
		case 'divEtcFileContent' : 
		
		// 업로드 성공 후, newfile에 있는 파일들을 webfile로 옮긴다.
		this.divEtcFile.form.divEtcFileContent.form.fnSetUploadCompleteState(obj,paramObj);	
		
		// 업로드한 file을 가져오는 법(샘플 가이드)
		if(objResultDataset)
		{
			trace("====업로드한 결과 데이터셋 ========== \n"+objResultDataset.saveXML());
			
			var sFileRefrnId = objResultDataset.getColumn(0,"fileRefrnId");
			
			trace("업로드결과 데이터셋의 첫번째 row의 fileRefrnId=["+sFileRefrnId+"]");
			// 테스트를 위해 아래의 sFileRefrnId를 세팅
			if(!this.smfIsNull(sFileRefrnId))
			{
				this.dsResultMnplReqsBase.setColumn(0, 'etcFileRefrnId', sFileRefrnId)
			}	
			
		}
		// 인력풀 신청서 save
		// 서비스 객체 생성 
		this.smfSaveService("saveMnplReqsBase")
			// 메세지 표시 여부
			.showConfirm(false)
			// validate
			.validateForm(this.divMainInfo)
			// 실행
			.run()
			// 콜백
			.callback(function(callbackParams){	
				if(callbackParams.errors) return;
				// params
					// 저장이 완료되었습니다.
					this.smfAlert('기본정보가 수정 되었습니다.',  function(){
			
					});
			});
		break;	
		}	
		
}

// 파일 업로드 실패 콜백-- 
this.fnFileUploadErrorCallback = function(obj, paramObj)
{
	//this.smfAlert('파일 업로드에 실패 하였습니다.');
};


