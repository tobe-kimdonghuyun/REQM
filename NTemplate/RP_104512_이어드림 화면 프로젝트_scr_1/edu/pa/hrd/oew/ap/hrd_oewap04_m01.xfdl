/**
 * 탭 변경 시 
 */ 
this.tab00_canchange = function(obj:nexacro.Tab,e:nexacro.TabIndexChangeEventInfo)
{
	// Tab에 변경이 일어나면 Confirm하며, 변경요청버튼 미클릭 시에도 데이터 미삭제.
	if(obj.tabindex == 0){
		var canChange = this.smfChangingTabConfirm(obj, e, this.dsAcbgInfo, 
													"변경요청을 하지 않았습니다. \n탭 이동을 하시겠습니까?");
		return canChange;

	}else if(obj.tabindex == 1){
		var canChange = this.smfChangingTabConfirm(obj, e, this.dsTraiInfo, 
													"변경요청을 하지 않았습니다. \n탭 이동을 하시겠습니까?");
		return canChange;

	}else if(obj.tabindex == 2){
		var canChange = this.smfChangingTabConfirm(obj, e, this.dsCarrInfo, 
													"변경요청을 하지 않았습니다. \n탭 이동을 하시겠습니까?");
		return canChange;

	}else if(obj.tabindex == 3){
		var canChange = this.smfChangingTabConfirm(obj, e, this.dsTchQlfInfo, 
													"변경요청을 하지 않았습니다. \n탭 이동을 하시겠습니까?");
		return canChange;

	}else if(obj.tabindex == 4){
		var canChange = this.smfChangingTabConfirm(obj, e, this.dsQlflInfo, 
													"변경요청을 하지 않았습니다. \n탭 이동을 하시겠습니까?");
		return canChange;

	}
	
}; 
/**
 * 다운로드 버튼 (탭 공통)
 */ 
this.divSubInfo_tabSubInfo_school_btnDown00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 오브젝트 아이디 
	var target = obj.id;
	/*console.log(target);*/
	switch(target) {
	// 학력정보 첨부파일 일괄 다운로드
	case 'btnDown00' : 
		this.fnDownloadBtn(this.dsAcbgInfo);
		break;
	// 연수정보 첨부파일 일괄 다운로드
	case 'btnDown01':
		this.fnDownloadBtn(this.dsTraiInfo);
		break;
	// 경력정보 첨부파일 일괄 다운로드
	case 'btnDown02' : 
		this.fnDownloadBtn(this.dsCarrInfo);
		break;
	// 교원자격정보 첨부파일 일괄 다운로드
	case 'btnDown03':
		this.fnDownloadBtn(this.dsTchQlfInfo);
		break;	
	// 국가기술자격정보 첨부파일 일괄 다운로드
	case 'btnDown04':
		this.fnDownloadBtn(this.dsQlflInfo);
		break;	
	}
};

/**
 * 추가 버튼 (탭 공통)
 */
this.fnAddCommBtn = function (dsList:nexacro.NormalDataset)
{
	var cnt = dsList.getRowCount();
	if(cnt > 4)
	{
	this.smfAlert('최대 5개까지만 추가할 수 있습니다.')
	return false;
	}

	return true;
};
/**
 * 삭제 버튼 (탭 공통)
 */
this.fnDeleteComBtn = function(dsList:nexacro.NormalDataset)
{
	// 데이터셋 로우카운트 
	var cnt = dsList.getRowCount();
	// 데이터 없을경우
	if(cnt < 1){
		this.smfAlert("삭제 요청 대상이 없습니다.");
		return;
	}
	// 체크박스 ON ARRAY 
	var chkIdxArray = dsList.extractRows("_chk == 1");
/*	console.log(chkIdxArray);*/
	if(this.isNil(chkIdxArray)){ 
		this.smfAlert("삭제 요청 대상을 선택하세요. ");
		return;
	}
	// 데이터셋 값 확인
	for(var i = 0; i  < cnt ; i++){
		var chk = dsList.getColumn(i, "_chk");				// 체크박스
		/*console.log(chk);*/
		var aprv = dsList.getColumn(i, "mnplAprvScCd");		// 승인구분코드
		/*console.log(aprv);*/
		var delYn = dsList.getColumn(i, "delYn");			// 삭제여부(논리삭제)
		/*console.log(delYn);*/
		// 삭제 프로세스 
		if (chk == 1)
		{
			// 신청 상태는 삭제 불가
			if (aprv == '1')
			{
				this.smfAlert('신청상태에서는 삭제를 할 수 없습니다.', function (){});
				return;
			}
			if (delYn == null)
			{
				// 메모리 삭제
				if (aprv == null)
				{
					// 확인 메시지 출력
					this.smfConfirm("삭제하시겠습니까?", function(result){
						if(result.confirmResult){
							// 데이터삭제
							/*dsList.deleteMultiRows(chkIdxArray);*/
							dsList.deleteRow(dsList.rowposition);
						}
					});		
				}				
			}
			// 논리삭제 요청 
			if (delYn == 'N')
			{
				// 승인상태는 null,  적용구분은 DEL로 변경
				dsList.setColumn(i, "aplcnScCd", "DEL");
				dsList.setColumn(i, "mnplAprvScCd", null);
				dsList.setColumn(i, "delYn", 'Y')
			}
		}	
  	}
}

