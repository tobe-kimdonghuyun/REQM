 /************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 /**
  * 조회 서비스 
  */
this.fnSearch = function()
 {
	// 서비스 객체 생성
	this.smfSearchService("selectMnplReqs")
 		// 실행
 		.run()
		// 콜백
		.callback(function(callbackParams){
		
 			if(callbackParams.errors) return;
			// 희망근무 시간 set
			var bgngTime = this.dsResultMnplReqsBase.getColumn(0, "hopWorkBgngHm");
			this.divContractInfo.form.cboTime00.set_value(bgngTime.substring(0, 2));
			this.divContractInfo.form.cboTime01.set_value(bgngTime.substring(2));
			var endTime = this.dsResultMnplReqsBase.getColumn(0, "hopWorkEndHm");
			this.divContractInfo.form.cboTime02.set_value(endTime.substring(0, 2));
			this.divContractInfo.form.cboTime03.set_value(endTime.substring(2));
			// 사진 set (413 error : request entity too large 해결 )
			if(!this.smfIsNull(this.dsResultMnplReqsBase.getColumn(0,"apstPhotoFileCn"))){
				this.divMainInfo.form.img00.set_image(this.dsResultMnplReqsBase.getColumn(0, "apstPhotoFileCn"));
				this.divMainInfo.form.img00.set_stretch('fit');
				this.divMainInfo.form.img00.set_text('');
				this.dsResultMnplReqsBase.setColumn(0, "apstPhotoFileCn", "");
			}else{
				this.divMainInfo.form.img00.set_image("");
			}

			var atchFileNm = this.dsResultMnplReqsBase.getColumn(0, "atchFileNm");
			this.divOnslLtoi.form.divOnslLtoiFile.form.edtFile.set_value(atchFileNm);
			// 자기소개서 파일 set
			if(this.dsResultMnplReqsBase.getColumn(0,"onslLtoiFileRefrnId") != null){
				var sFileSn = this.dsResultMnplReqsBase.getColumn(0,"onslLtoiFileRefrnId");
				this.transaction("fn_filesearch" // serviceId
							,"baseUrl::/cm_cmc_file_upload_001.do" // url
							,"" // inDataset
							,"dsData=atchFileinfo" // outDataset
							,"fileRefrnId='"+sFileSn+"'"
							,"" // callbackFunction
							,false );
				for( var i=0; i < this.dsData.rowcount; i++ ){
						var responseCustomValue = "";
						var sDownloadUrl       = "";   // 
						var sPrivInfoFiltYn    = "";   // 항목 관리안함
						var sFileInfSaveYn     = "Y";  // 업무에 맞게 개발자가 세팅(Y/N)
						var sHandlerCode       = "PA.HRD.OEW"; 
						var sFileSn            = this.dsData.getColumn(i,"fileRefrnId"   );
						var sFileSeq           = this.dsData.getColumn(i,"fileId"        );
						var sFileSize          = this.dsData.getColumn(i,"atchFileMg"    );
						var sBackendFilename   = this.dsData.getColumn(i,"atchFileGuid"  );
						var sForntendFilename  = this.dsData.getColumn(i,"atchFileNm"    );
						var sFileEncryptYn     = this.dsData.getColumn(i,"fileEncryptYn" );
						/*var sPrivInfoFiltYn    = this.dsData.getColumn(i,"privInfoFiltYn");*/
						var sFileSaveStg       = this.dsData.getColumn(i,"fileSaveStg"   );
						/*var sFileInfSaveYn     = this.dsData.getColumn(i,"fileInfSaveYn" );*/
						this.divOnslLtoi.form.divOnslLtoiFile.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sForntendFilename, sFileSeq, sDownloadUrl,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn );
				}
			}
			// 기타 첨부 파일 set
			if(this.dsResultMnplReqsBase.getColumn(0,"etcFileRefrnId") != null){
				var sFileSn = this.dsResultMnplReqsBase.getColumn(0,"etcFileRefrnId");
				// 업로드 초기화
				this.divEtcFile.form.divEtcFileContent.form.fnResetUpload();
				this.transaction("fn_filesearch" // serviceId
							,"baseUrl::/cm_cmc_file_upload_001.do" // url
							,"" // inDataset
							,"dsFileinfo=atchFileinfo" // outDataset
							,"fileRefrnId='"+sFileSn+"'"
							,"" // callbackFunction
							,false );
							
				for (var j = 0; j < this.dsFileinfo.rowcount; j++) {
						var responseCustomValue = "";
						var sDownloadUrl       = "";   // 
						var sPrivInfoFiltYn    = "";   // 항목 관리안함
						var sFileInfSaveYn     = "Y";  // 업무에 맞게 개발자가 세팅(Y/N)
						var sHandlerCode       = "PA.HRD.OEW"; 
						var sFileSn            = this.dsFileinfo.getColumn(j,"fileRefrnId"   );
						var sFileSeq           = this.dsFileinfo.getColumn(j,"fileId"        );
						var sFileSize          = this.dsFileinfo.getColumn(j,"atchFileMg"    );
						var sBackendFilename   = this.dsFileinfo.getColumn(j,"atchFileGuid"  );
						var sForntendFilename  = this.dsFileinfo.getColumn(j,"atchFileNm"    );
						var sFileEncryptYn     = this.dsFileinfo.getColumn(j,"fileEncryptYn" );
						/*var sPrivInfoFiltYn    = this.dsFileinfo.getColumn(j,"privInfoFiltYn");*/
						var sFileSaveStg       = this.dsFileinfo.getColumn(j,"fileSaveStg"   );
						/*var sFileInfSaveYn     = this.dsFileinfo.getColumn(j,"fileInfSaveYn" );*/
						this.divEtcFile.form.divEtcFileContent.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sForntendFilename, sFileSeq, sDownloadUrl,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn );			
				 }

			}
			/*this.fnBtnAddDwnld();*/
 		});	
};
