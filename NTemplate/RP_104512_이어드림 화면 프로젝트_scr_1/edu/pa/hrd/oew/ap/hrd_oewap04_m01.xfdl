    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-계약제교원인력풀-인력풀 정보변경
*  @MenuPath    pa_hrd_oew_ap
*  @FileName 	pa_hrd_oewap04_m01.xfdl
*  @Creator 	
*  @CreateDate 	2022.8.18
*  @Desction    온라인통합채용-계약제교원인력풀-인력풀 정보변경 상세화면
************** 소스 수정 이력 ***********************************************
*  date                Modifier            Description
*******************************************************************************
*  2022.8.18    	 	최지원             최초 생성 
********************************************************************************/
include "lib::ore_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
//파라미터
this.apstFlnm;
this.brdt;
this.mblTelno;
this.userDtcNo;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form 초기화
	this.smfInitForm(this);
	
 	// 파라메터 세팅
 	this.pv_params = this.smfGetFormParams();
	// 시도교육청코드
	var cddcCd = this.smfGetCddcCode();
	this.userDtcNo = this.smfGetSessionValue('userDtcNo');
	this.dsCddcScCd.setColumn(0, 'cddcScCd', cddcCd.slice(0, 3));
	this.dsSearch.setColumn(0, "mnplReqsId", this.pv_params.mnplReqsId);
	this.dsSearch.setColumn(0, 'pafrUserId', this.userDtcNo);
	
	// 주민번호로 로그인의 경우 brdt check & set
	this.brdt = this.smfGetSessionValue('brdt');
	if(this.smfIsNull(this.brdt)){
		 this.brdt = this.applpRrnoToBrdt(nexacro.base64Decode(this.smfGetSessionValue('userRrno')));
	}	
	this.apstFlnm = this.smfGetSessionValue('userNm');
	//  페이지를 조회한다.
	this.fnSearch();	
	// 공통코드
	// dsHrCd : 시간 
	this.smfCodeList("code", [this.dsHrCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		})		
		.run();
	
	// 파일 업로드 (자기소개서)
	this.divOnslLtoi.form.divOnslLtoiFile.UPLOAD_UploadComplete  = this.fnFileUploadCompleteCallback;
	this.divOnslLtoi.form.divOnslLtoiFile.UPLOAD_OnError         = this.fnFileUploadErrorCallback;
	this.divOnslLtoi.form.divOnslLtoiFile.UPLOAD_AfterAddFile    = this.fnFileUploadChangeCallback;     
	this.divOnslLtoi.form.divOnslLtoiFile.UPLOAD_Form            = this;
	// 파일 업로드 초기화 (기타첨부파일)
	this.divEtcFile.form.divEtcFileContent.UPLOAD_UploadComplete  = this.fnFileUploadCompleteCallback;
	this.divEtcFile.form.divEtcFileContent.UPLOAD_OnError         = this.fnFileUploadErrorCallback;
	this.divEtcFile.form.divEtcFileContent.UPLOAD_AfterAddFile    = this.fnFileUploadChangeCallback;     
	this.divEtcFile.form.divEtcFileContent.UPLOAD_Form            = this;
	// 파일 업로드 초기화(지원자사진)
	this.divFileUpload.UPLOAD_UploadComplete  = this.fnFileUploadCompleteCallback;
	this.divFileUpload.UPLOAD_OnError         = this.fnFileUploadErrorCallback;
	this.divFileUpload.UPLOAD_AfterAddFile    = this.fnFileUploadChangeCallback;     
	this.divFileUpload.UPLOAD_Form            = this;

	//=======================================
	// 다운로드관련 초기설정을 한다.
	//=======================================
// 	this.divFileDownload.UPLOAD_DownloadComplete = this.fnEventDownloadComplete;  // 필요한 경우만 세팅
// 	this.divFileDownload.UPLOAD_Form             = this;                          // 위의 함수가 존재하는 Form (보통은 this)
};


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 this.fnTransCallback  = function(svcid,errcd,errmsg) {

};

// 사진이미지 콜백
this.fnPopupCallback = function(e, sender){

	trace("====>fnPopupCallback");
	var sImageType       = "";
	var sImageFileName   = "";   // 선택된 파일이름
	var sImageDataBase64 = "";
	var sImageDataBase64Reduce = "";
	
	if(e.imageInfo)
	{
		sImageType       = e.imageInfo.imageType;   // 이미지 타입(image/png)
		sImageFileName   = e.imageInfo.imageFileName;   // 파일이름(test.png)
		// 사진파일 특수 문자 확인 
		var fileExtension = sImageFileName.substring(sImageFileName.lastIndexOf(".")); // 파일 확장자 
		var fileName = sImageFileName.split(fileExtension); // 파일명. 확장자 분리 
		/*var fileName = sImageFileName.split(/.png|.PNG|.jpg|.JPG|.JPEG|.jpeg|.bmp|.BMP/);*/
		var sMatch = fileName[0].match(/[\.\/\,\~\!\@\#\$\%\^\&\(\)\+\-\']/); // 파일명 특수문자 확인
		if ( sMatch != null)
		{
			this.smfAlert("사진 파일 이름에 특수 문자가 있습니다.");
			return;
		}
		sImageDataBase64 = e.imageInfo.imageDataBase64;  // BASE64의 이미지 파일
		sImageDataBase64Reduce = 	e.imageInfo.imageDataBase64Reduce; // BASE64의 이미지 파일(품질축소)

		if(!this.smfIsNull(sImageDataBase64))
		{
			this.divMainInfo.form.img00._imagetype = sImageType; 
			this.divMainInfo.form.img00._imagename = sImageFileName; 
			// 이미지 용량 작은 데이터 SET
			if(sImageDataBase64.length > sImageDataBase64Reduce.length){
				this.divMainInfo.form.img00.set_image(sImageDataBase64Reduce);
			}else{
				this.divMainInfo.form.img00.set_image(sImageDataBase64);
			}
			this.divMainInfo.form.img00.set_text("");
			
		}
	}
	var sBase64Data = this.divMainInfo.form.img00.image;
	this.divFileUpload.form.fnResetUpload();
	this.divFileUpload.form.fnFileUploadWithBase64(sBase64Data, sImageFileName);
};

