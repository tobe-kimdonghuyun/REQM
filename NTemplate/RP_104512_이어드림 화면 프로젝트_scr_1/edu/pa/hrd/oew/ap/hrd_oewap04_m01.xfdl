/**
 * 파일 일괄 다운로드 버튼 (공통)
 */
this.fnDownloadBtn = function(dsList:nexacro.NormalDataset)
{
	// 데이터셋 로우카운트 
	var cnt = dsList.rowcount;
	/*console.log(cnt)*/;
	// 데이터 없을경우
	if(cnt < 1){
		this.smfAlert("다운로드 대상이 없습니다.");
		return;
	}
	
	// 체크박스 ON ARRAY 
	var chkIdxArray = dsList.extractRows("_chk == 1");
	/*console.log(chkIdxArray);*/
	if(this.isNil(chkIdxArray)){ 
		this.smfAlert("다운로드 대상을 선택하세요. ");
		return;
	}
	
	// 업로드 초기화 
	this.divFileUpload.form.fnResetUpload(); 
	
	// 데이터셋 값 확인
	// 체크 로우 확인
	for(var j=0; j < chkIdxArray.length; j++){
		// 체크로우 참조아이디 확인
		if(dsList.getColumn(chkIdxArray[j],"fileRefrnId") != null)
		{
			// 파일참조아이디
			var sFileSn = dsList.getColumn(chkIdxArray[j],"fileRefrnId");
			/*console.log(sFileSn);*/
	
			this.transaction("fn_filesearch" // serviceId
						,"baseUrl::/cm_cmc_file_upload_001.do" // url
						,"" // inDataset
						,"dsAcbgFile=atchFileinfo" // outDataset
						,"fileRefrnId='"+sFileSn+"'"
						,""// callbackFunction
						,false);
						
			for( var i=0; i < this.dsAcbgFile.rowcount; i++ ){
			/*console.log(i+"##");*/
					var responseCustomValue = "";
					var sDownloadUrl       = "";   // 
					var sPrivInfoFiltYn    = "";   // 항목 관리안함
					var sFileInfSaveYn     = "Y";  // 업무에 맞게 개발자가 세팅(Y/N)
					var sHandlerCode       = "PA.HRD.OEW"; 
					var sFileSn            = this.dsAcbgFile.getColumn(0,"fileRefrnId"   );
					var sFileSeq           = this.dsAcbgFile.getColumn(0,"fileId"        );
					var sFileSize          = this.dsAcbgFile.getColumn(0,"atchFileMg"    );
					var sBackendFilename   = this.dsAcbgFile.getColumn(0,"atchFileGuid"  );
					var sForntendFilename  = this.dsAcbgFile.getColumn(0,"atchFileNm"    );
					var sFileEncryptYn     = this.dsAcbgFile.getColumn(0,"fileEncryptYn" );
					var sFileSaveStg       = this.dsAcbgFile.getColumn(0,"fileSaveStg"   );
					this.divFileUpload.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sForntendFilename, sFileSeq, sDownloadUrl,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn );					
			}
		}
	}
	this.divFileUpload.form.fnFileDownload();
};


