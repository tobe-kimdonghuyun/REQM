 // RAONK  옵션(일괄다운로드 옵션)
this.fnSetRaonProp = function()
{				 
	var objAddRaonProps = {
		  MaxTotalFileCount : "5"	//업로드 할 최대 파일 개수 제한값을 설정합니다.
		, MaxOneFileSize : "3MB"	//업로드할 때 파일당 용량제한을 설정합니다.
		, MaxTotalFileSize : "15MB"
		, AllowDuplicationFile   : "1"   // 파일 추가 시 중복 파일 허용 여부를 설정합니다.
										 // (기본값은 '0'으로 중복 허용을 안합니다.)
		, DownloadMulti : "1"             // 웹표준 모드에서 2개이상의 파일을 다운로드 할때 개별파일로 다운받을지를설정합니다.
										 // (기본값은 "0" : 멀티파일을 zip으로 다운로드 , "1" : 멀티파일을 개별파일로 다운로드)  
		, UseAlertEvent : "0"			// alert 이벤트 비활성  
		, Duplication : "1"
	};	
	return objAddRaonProps;
};
