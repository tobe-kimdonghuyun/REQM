/**
*	기본정보저장 버튼
*/
this.btnModifyBase_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	// 비상연락처
	var emgCnctTelno1 = this.dsResultMnplReqsBase.getColumn(0, "emgCnctTelno0");	
	var emgCnctTelno2 = this.dsResultMnplReqsBase.getColumn(0, "emgCnctTelno1");	
	var emgCnctTelno3 = this.dsResultMnplReqsBase.getColumn(0, "emgCnctTelno2");
	var emgCnctTelno = [emgCnctTelno1, emgCnctTelno2, emgCnctTelno3].join("-"); 
	if ( emgCnctTelno == "--" ){
		emgCnctTelno = "";
	}  
	this.dsResultMnplReqsBase.setColumn(0, 'emgCnctTelno', emgCnctTelno);
		// 휴대전화 
	var mblTelno00 = this.dsResultMnplReqsBase.getColumn(0, "mblTelno00");	
	var mblTelno01 = this.dsResultMnplReqsBase.getColumn(0, "mblTelno01");	
	var mblTelno02 = this.dsResultMnplReqsBase.getColumn(0, "mblTelno02");
	var mblTelno = [mblTelno00, mblTelno01, mblTelno02].join("-"); 
	if ( mblTelno == "--" ){
		mblTelno = "";
	}
	// 휴대폰
	this.dsResultMnplReqsBase.setColumn(0, 'mblTelno', mblTelno);
	// 기본정보 validate  
	this.smfUpdateValidateToComponent("required",this.divMainInfo.form.img00); // 사진
	this.smfUpdateValidateToComponent("required",this.divMainInfo.form.rdoSxdsScCd); // 성별구분코드
	this.smfUpdateValidateToComponent("required",this.divMainInfo.form.edtPhone00); // 비상연락처1
	this.smfUpdateValidateToComponent("required",this.divMainInfo.form.edtPhoneNo01); // 비상연락처2
	this.smfUpdateValidateToComponent("required",this.divMainInfo.form.edtPhoneNo02); // 비상연락처3
	this.smfUpdateValidateToComponent("required,email",this.divMainInfo.form.edtEmlAddr); //이메일
	this.smfUpdateValidateToComponent("required",this.divMainInfo.form.edtDmclRoadNmZip);  //우편번호
	this.smfUpdateValidateToComponent("required",this.divMainInfo.form.edtDmclRoadNmAddr);  //주소
	this.smfUpdateValidateToComponent("required",this.divMainInfo.form.edtDmclRoadNmDtlAddr);  //주소상세

// 	if(this.divMainInfo.form.img00._image){
// 	// 사진
// 	var objImg = this.divMainInfo.form.img00._image
// 	// canvas에 이미지를 옮긴다.
// 	var canvas = document.createElement('canvas');
// 	var ctx = canvas.getContext('2d');
// 	canvas.width = objImg._orgwidth;
// 	canvas.height = objImg._orgheight;
// 	ctx.drawImage(objImg._img_elem.handle,0,0);
// 	// base64데이터를 추출한다.
// 	var base64 = canvas.toDataURL('image/*');	
// 	// base64데이터만 추출("data:image/png,base64,"를 삭제한 순수한 base64부분)
// 	var strOnlyBase64 = base64.replace(/^data:image\/[a-z]+;base64,/,"");
// 	// 사진파일
// 	this.dsResultMnplReqsBase.setColumn(0, 'apstPhotoFileCn', strOnlyBase64 );
// 	}   

	// 시도교육청코드
	var cddcCd = this.smfGetCddcCode();
	this.dsResultMnplReqsBase.setColumn(0, 'cddcScCd', cddcCd.slice(0, 3));
	this.dsResultMnplReqsBase.setColumn(0, 'pafrUserId', this.userDtcNo); // 사용자CI
	// [첨부파일] 첨부파일 업로드 체크
	var fileCount = this.divEtcFile.form.divEtcFileContent.form.fnGetTotalFileCount();
	
	this.smfConfirm("저장 하시겠습니까?", function(result){
	// 첨부파일의 유무 상관없이 업로드 처리(업로드카운트 0이면 null로 참조ID set)
		if(result.confirmResult){
			if (fileCount == 0)
			{
				this.dsResultMnplReqsBase.setColumn(0, "etcFileRefrnId", null);
			} this.divEtcFile.form.divEtcFileContent.form.fnFileUpload();
		}
	});
	
};

