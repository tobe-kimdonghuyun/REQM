          <Formats>
            <Format id="default">
              <Columns>
                <Column size="150"/>
                <Column size="400"/>
                <Column size="250"/>
                <Column size="250"/>
              </Columns>
              <Rows>
                <Row size="60" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="날짜&#13;&#10;*필수 입력"/>
                <Cell col="1" text="급간식종류 (최대 글자길이 : 100)&#13;&#10;*필수 입력&#13;&#10;*한줄에 한개씩 입력. 행추가하여 최대 5개까지 입력 가능"/>
                <Cell col="2" text="단가 (최대 단가 : 99,999)&#13;&#10;*급간식종류 없이 단가 입력 불가"/>
                <Cell col="3" text="거래처명 (최대 글자길이 : 50)&#13;&#10;*급간식종류 없이 거래처명 입력 불가"/>
              </Band>
              <Band id="body">
                <Cell textAlign="center" text="bind:mlsnYmd" cssclass="expr:nathoYn == &quot;Y&quot; ?  &quot;cell_WF_Red&quot;  : &quot;&quot;"/>
                <Cell col="1" text="bind:mlsnNm"/>
                <Cell col="2" textAlign="right" text="bind:mlsnUtp" displaytype="number"/>
                <Cell col="3" text="bind:comyNm"/>
