              <Rows>
                <Row size="40" band="head"/>
                <Row size="60" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell colspan="4" color="#d32850" text="  *시트명(Sheet1)을 변경하지 마세요. 변경시 업로드 되지 않습니다." textAlign="right" background="#fffa70"/>
                <Cell row="1" text="날짜&#13;&#10;[필수입력]&#13;&#10;*공휴일은 빨간글씨로 표시됩니다." color="#0700ea"/>
                <Cell row="1" col="1" text="급간식종류 (최대 글자길이 : 100)&#13;&#10;[필수입력]&#13;&#10;*한줄에 한개씩 입력. 행추가하여 최대 5개까지 입력 가능" color="#0700ea"/>
                <Cell row="1" col="2" text="단가 (최대 단가 : 99,999)&#13;&#10;*급간식종류 없이 단가 입력 불가"/>
                <Cell row="1" col="3" text="거래처명 (최대 글자길이 : 50)&#13;&#10;*급간식종류 없이 거래처명 입력 불가"/>
              </Band>
              <Band id="body">
                <Cell textAlign="center" text="bind:nathoYmd" cssclass="expr:nathoYn == &quot;Y&quot; ?  &quot;cell_WF_Red&quot;  : &quot;&quot;"/>
                <Cell col="1" text="bind:mlsnNm"/>
                <Cell col="2" textAlign="right" text="bind:mlsnUtp" displaytype="number"/>
