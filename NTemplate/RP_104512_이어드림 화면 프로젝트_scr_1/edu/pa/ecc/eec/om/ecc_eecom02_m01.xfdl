        </Div>
        <Div id="divSearch" taborder="1" left="0" top="144" height="70" cssclass="div_WF_Search" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staSyr" taborder="0" text="*학년도" left="0" top="20" width="75" height="30" cssclass="sta_WF_Essential01" initvalueid="ivStcEssential" accessibilitylabel="학년도"/>
              <Combo id="cboAyr" taborder="1" left="75" width="130" height="30" innerdataset="dsAyr" codecolumn="code" datacolumn="value" index="-1" text="선택" top="20" value="ALL" initvalueid="ivCmbEssential" onitemchanged="divSearch_cboAyr_onitemchanged" cssclass="essential" accessibilitylabel="학년도 구분"/>
              <Static id="staSem" taborder="2" text="*돌봄학기" left="205" top="20" width="88" height="30" cssclass="sta_WF_Essential01" initvalueid="ivStcEssential" accessibilitylabel="돌봄학기"/>
              <Combo id="cboSem" taborder="3" left="293" width="130" height="30" innerdataset="dsEccSem" codecolumn="code" datacolumn="value" index="-1" text="선택" top="20" value="ALL" initvalueid="ivCmbEssential" onitemchanged="divSearch_cboSem_onitemchanged" cssclass="essential" accessibilitylabel="돌봄학기 구분"/>
              <Static id="staSc" taborder="4" text="*돌봄구분" left="423" top="20" width="88" height="30" cssclass="sta_WF_Essential01" initvalueid="ivStcEssential" accessibilitylabel="돌봄구분"/>
              <Combo id="cboSc" taborder="5" left="511" width="130" height="30" innerdataset="dsEccScCd" codecolumn="code" datacolumn="value" index="-1" text="선택" top="20" value="ALL" initvalueid="ivCmbEssential" onitemchanged="divSearch_cboSc_onitemchanged" cssclass="essential" accessibilitylabel="돌봄구분"/>
              <Static id="staClr" taborder="6" text="*교실" left="641" top="20" width="62" height="30" cssclass="sta_WF_Essential01" initvalueid="ivStcEssential" accessibilitylabel="교실"/>
              <Combo id="cboClr" taborder="7" left="703" width="130" height="30" innerdataset="dsEccNm" codecolumn="code" datacolumn="value" index="-1" text="선택" top="20" value="ALL" initvalueid="ivCmbEssential" onitemchanged="divSearch_cboClr_onitemchanged" cssclass="essential" accessibilitylabel="교실 구분"/>
              <Static id="staYmdh" taborder="8" text="*조회 월" left="833" top="20" width="82" height="30" cssclass="sta_WF_Essential01" initvalueid="ivStcEssential" accessibilitylabel="조회 월"/>
              <Combo id="cboClr00" taborder="9" left="915" width="130" height="30" innerdataset="dsMm" codecolumn="code" datacolumn="value" index="-1" text="선택" top="20" value="ALL" initvalueid="ivCmbEssential" onitemchanged="divSearch_cboClr_onitemchanged" cssclass="essential" accessibilitylabel="조회 월 구분"/>
              <Button id="btnSearch" taborder="10" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="20" onclick="fnSearch" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="조회"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staCn" taborder="2" text="1인당 월 총 금액 :      0원" left="0" top="238" width="500" height="26" cssclass="sta_WF_Total" fittocontents="width" initvalueid="ivStcAccessibilityOn" accessibilitylabel="1인당 월 총 금액: 0원"/>
        <Button id="btnStuPtclrMte" taborder="3" text="학생 특이사항" top="234" height="30" width="107" cssclass="btn_WF_Custom" right="84" initvalueid="ivBtnAccessibilityButton" onclick="btnStuPtclrMte_onclick" accessibilitylabel="학생 특이사항"/>
        <Button id="btnDelete" taborder="4" text="전체삭제" top="234" height="30" cssclass="btn_WF_Crud" width="76" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="전체삭제" right="0" onclick="fnDelete"/>
        <Button id="btnDownload" taborder="5" text="양식 내려받기" top="234" height="30" cssclass="btn_WF_Excel03" width="126" right="322" onclick="btnDownload_onclick" visible="false" initvalueid="ivBtnAccessibilityDown" accessibilitylabel="양식 내려받기"/>
        <Button id="btnUpload" taborder="6" text="자료 올리기" top="234" height="30" cssclass="btn_WF_Excel03" width="115" right="199" visible="false" onclick="btnUpload_onclick" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="자료 올리기"/>
        <Grid id="grdMain" taborder="7" left="0" top="274" autofittype="col" right="0" binddataset="dsMain" selecttype="cell" oncellclick="grdMain_oncellclick" bottom="20" cellsizingtype="both" autosizingtype="row" extendsizetype="row" initvalueid="ivGrdAccessibilityOn" accessibilitylabel="급간식 메뉴관리 표">
