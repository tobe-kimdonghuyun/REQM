              </Band>
              <Band id="body">
                <Cell text="bind:dfkMon" cssclass="expr:zz == &quot;-1&quot; ? &quot;cell_WF_BgColorLitsky cell_WF_NavyCnt cell_WF_Pointer&quot; : (zz == &quot;0&quot; ? &quot;cell_WF_BgColorTrssky cell_WF_Right&quot; : &quot;cell_WF_Left&quot;)" wordWrap="char" autosizerow="limitmin"/>
                <Cell col="1" text="bind:dfkTue" cssclass="expr:zz == &quot;-1&quot; ? &quot;cell_WF_BgColorLitsky cell_WF_NavyCnt cell_WF_Pointer&quot; : (zz == &quot;0&quot; ? &quot;cell_WF_BgColorTrssky cell_WF_Right&quot; : &quot;cell_WF_Left&quot;)" wordWrap="char" autosizerow="limitmin"/>
                <Cell col="2" text="bind:dfkWed" cssclass="expr:zz == &quot;-1&quot; ? &quot;cell_WF_BgColorLitsky cell_WF_NavyCnt cell_WF_Pointer&quot; : (zz == &quot;0&quot; ? &quot;cell_WF_BgColorTrssky cell_WF_Right&quot; : &quot;cell_WF_Left&quot;)" wordWrap="char" autosizerow="limitmin"/>
                <Cell col="3" text="bind:dfkThu" cssclass="expr:zz == &quot;-1&quot; ? &quot;cell_WF_BgColorLitsky cell_WF_NavyCnt cell_WF_Pointer&quot; : (zz == &quot;0&quot; ? &quot;cell_WF_BgColorTrssky cell_WF_Right&quot; : &quot;cell_WF_Left&quot;)" wordWrap="char" autosizerow="limitmin"/>
                <Cell col="4" text="bind:dfkFri" cssclass="expr:zz == &quot;-1&quot; ? &quot;cell_WF_BgColorLitsky cell_WF_NavyCnt cell_WF_Pointer&quot; : (zz == &quot;0&quot; ? &quot;cell_WF_BgColorTrssky cell_WF_Right&quot; : &quot;cell_WF_Left&quot;)" wordWrap="char" autosizerow="limitmin"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Grid id="grdMainExel00" taborder="8" left="100" top="320" autofittype="col" right="15" binddataset="dsListUpMth" selecttype="cell" initvalueid="ivGrdAccessibilityOn" bottom="245" visible="false" accessibilitylabel="메뉴관리 표">
          <Formats>
