          <Column id="stuInvlNo" type="STRING" size="256" description="학생개인번호"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsRsMsg" useclientlayout="true">
        <ColumnInfo>
          <Column id="rsMsg" type="STRING" size="256" description="저장 리턴값(나이스에서 BusinessException 발생한경우 메세지 찍어줄 값 넘어옴. 발생 안했으면 ok 넘어옴)"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  출결관리
*  @MenuPath    초등돌봄교실 > 출결관리
*  @FileName 	ecc_eecom03_m01.xfdl 
*  @Creator 	이혜진
*  @CreateDate 	2022.10.19
*  @Desction    초등돌봄교실(돌봄인력서비스) 출결관리
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.10.19            이혜진                   최초 생성 
*******************************************************************************
*/ 

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::ecc_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
//●그리드 내 콤보(출석여부, 급간식, 퇴실시각)은 고정값이라 데이터셋에 하드코딩되어있음. 
this.fv_onLoadYn = true; //초기세팅여부 (화면 load시에만 첫번째 값으로 세팅하기)



/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 /*
 * 화면 load시
 * 
 * 조회조건 초기값 세팅
 * 1. 사용자정보세팅 (주민번호, 시도코드, 접속시도코드, 사용자id, 학교코드-전담사로 등록되어있는 학교코드)
 * 2. 학년도 세팅 = 현재년도-1~현재년도+1 
 * 3. 일자 세팅 = 현재날짜
 * 4. 돌봄학기 -> 돌봄구분 -> 교실명 세팅
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitForm(obj);
	this.staCn.set_text("                                                                                                              "); 
	
	//●1. 사용자정보세팅
	this.eccfSetHnfInfo("selectHnfInfoForSession", this.dsSearch, ""); 
};


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
			
	switch(svcid) {	
	
		//●사용자정보세팅 콜백
		case "selectHnfInfoForSession" : 
			if ( errcd == -100 ) {//오류메시지 확인용
				this.smfAlert("errcd : "+errcd);
				this.alert(errmsg);
			}	
	
			//2. 학년도 세팅 
			this.eccCmbSetAyr(this.dsAyr, "code", "value", 1, 1);
			//현재년도로 디폴트 값 세팅
			this.divSearch.form.cboAyr.set_index(0);
				
			//3. 일자 세팅(현재 날짜)
			this.dsSearch.setColumn(0, "ymd", this.dsSearch.getColumn(0, "ayr") +""+ this.smfToday().dateFormat("MMdd"));
			
			//4. 돌봄학기 콤보 세팅
			this.divSearch_cboAyr_onitemchanged();			
			break;		
	
	
	
		//●돌봄학기콤보 세팅 콜백
		case "selectEccSem" : 
			//에러처리
			if ( errcd == -100 ) {
				this.smfAlert("errcd : "+errcd);
				this.alert(errmsg);
			}
			
			//onload시 콤보 초기세팅
			if(this.fv_onLoadYn){
				this.divSearch.form.cboSem.set_index(0);
			}
			
			//선택된 돌봄구분이 없으면 세팅
			if(this.smfIsNull(this.divSearch.form.cboSem.text)){ 
				this.divSearch.form.cboSem.set_index(0);
			}
			
			//돌봄구분콤보 세팅
			this.divSearch_cboSem_onitemchanged();
			break;
		
		
		//●돌봄구분콤보 세팅 콜백
		case "selectEccScCd" :
			//에러처리
			if ( errcd == -100 ) {
				this.smfAlert("errcd : "+errcd);
				this.alert(errmsg);
			}
			
			//onload시 콤보 초기세팅
			if(this.fv_onLoadYn){
				this.divSearch.form.cboSc.set_index(0);
			}
			
			//선택된 돌봄구분이 없으면 세팅
			if(this.smfIsNull(this.divSearch.form.cboSc.text)){ 
				this.divSearch.form.cboSc.set_index(0);
			}			
			
			//교실콤보 세팅	
			this.divSearch_cboSc_onitemchanged();
			break;
		
		
		//●교실콤보 세팅 콜백
		case "selectEccEccNm" :
			//에러처리
			if ( errcd == -100 ) {
				this.smfAlert("errcd : "+errcd);
				this.alert(errmsg);
			}
			
			//onload시 콤보 초기세팅
			if(this.fv_onLoadYn){
				this.divSearch.form.cboClr.set_index(0);	
				this.fv_onLoadYn = false;
			}
			
			//선택된 돌봄구분이 없으면 세팅
			if(this.smfIsNull(this.divSearch.form.cboClr.text)){ 
				this.divSearch.form.cboClr.set_index(0);
			}	
			
			//데이터 초기화
			this.divSearch_cboClr_onitemchanged();
			break;		
	}		
};



/**
 * 팝업의 콜백함수
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	this.fnSearch();
};



/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
	
};


/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 조회 버튼 클릭 - 1. 돌봄교실 개설여부, 해당 출결일의 일지 결재상태코드 조회
 * 1. 돌봄교실 개설여부(개설된게 없으면 돌봄 서비스기간이 아님. 화면 비활성화 할거임), 해당 출결일의 일지 결재상태코드 조회
 * 2. 출결관리 내역 조회
 */
 this.fnSearchDirYnCk = function()
{
	//일자 체크
    if(nexacro.toNumber(this.dsSearch.getColumn(0, "ymd")) > nexacro.toNumber(this.smfToday())){
	  this.smfAlert('PA064', ["출결은 오늘 날짜까지만 작성할 수"], this.fnMessageCallback ); //{0} 있습니다.
      return;
    }
	
	
	
	
	//나이스에서 조회할때 돌봄교실개설여부조회(결재상태포함)-1 할지, 출결관리조회할지-2 분기탈 구분자 세팅
	this.dsSearch.setColumn(0, "flagAtteSuch", "1");
	this.dsSearch.setColumn(0, "flagAtteUp", "");//저장 삭제 전주복사일경우, 나이스에 보낼 데이터셋 추가하려고 만든 구분자-자바단에서 사용
	
	//●호출
	this.dsList.clearData();
	this.smfSearchService("listAtteInfoDirCk")
		// 데이터 검증
		.validateForm(this.divSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){//에러
				return;
			}
			
			//●조회된 내역이 없으면 개설된 돌봄교실이 없는거임. 돌봄교실 없으면 빠꾸
			if(this.dsList.rowcount < 1){ 
				this.smfAlert('PA057', ["돌봄 서비스기간이 아닙니", "\n(개설된 돌봄교실이 없습니다)"], this.fnMessageCallback ); //{0}다. \n{1}
				this.dsMain.clearData();
				return;		
				
			//●조회된 내역이 있으면			
			}else{
				//2.출결관리 내역 조회
				this.fnSearch();					
			}			
		});	
}





/**
 * 조회 버튼 클릭 - 2. 출결관리 내역 조회
 * 1. 돌봄교실 개설여부(개설된게 없으면 돌봄 서비스기간이 아님. 화면 비활성화 할거임), 해당 출결일의 일지 결재상태코드 조회
 * 2. 출결관리 내역 조회
 */
 this.fnSearch = function()
{
	//나이스에서 조회할때 돌봄교실개설여부조회(결재상태포함)-1 할지, 출결관리조회할지-2 분기탈 구분자 세팅
	this.dsSearch.setColumn(0, "flagAtteSuch", "2");

	//●호출
	this.dsMain.clearData();
	this.smfSearchService("list")
		// 데이터 검증
		.validateForm(this.divSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){//에러처리
				return;
			}	
			this.sta04_01.set_text(this.dsMain.rowcount); //total찍기
			
			//●1. 그리드 활성화 설정
			var rsAtrzStsCd = this.dsList.getColumn(0, "rsAtrzStsCd"); //결재상태체크
			var mlsnYn = this.dsList.getColumn(0, "mlsnYn"); //급간식여부
			this.cboMlsv.set_enable(true); //일괄적용에 있는 급간식여부
			this.chkLves.set_enable(true); //일괄적용에 있는 징수여부
			this.staCn.set_text(""); 
			
			//1. 결재 = N  급간식 = Y  -- 전부 활성화
			if(rsAtrzStsCd == "N" && mlsnYn == "Y"){
				this.grdMain.setCellProperty( "Body", 5, "edittype", "combo"); 		//출석여부
				this.grdMain.setCellProperty( "Body", 6, "edittype", "combo");		//급간식
				this.grdMain.setCellProperty( "Body", 7, "edittype", "checkbox");	//징수여부
				this.grdMain.setCellProperty( "Body", 8, "edittype", "combo");		//퇴실시
				this.grdMain.setCellProperty( "Body", 9, "edittype", "combo");		//퇴실분
				this.grdMain.setCellProperty( "Body", 10, "edittype", "text");		//귀가동반자
				this.grdMain.setCellProperty( "Body", 11, "edittype", "text");		//특이사항
				
			//2. 결재 = N 급간식 = N  -- 급간식콤보, 징수여부 비활성화 / 나머지 활성화
			}else if(rsAtrzStsCd == "N" && mlsnYn == "N"){
				this.grdMain.setCellProperty( "Body", 5, "edittype", "combo"); 	//출석여부
				this.grdMain.setCellProperty( "Body", 6, "edittype", "none");	//급간식
				this.grdMain.setCellProperty( "Body", 7, "edittype", "none");	//징수여부
				this.grdMain.setCellProperty( "Body", 8, "edittype", "combo");	//퇴실시
				this.grdMain.setCellProperty( "Body", 9, "edittype", "combo");	//퇴실분
				this.grdMain.setCellProperty( "Body", 10, "edittype", "text");	//귀가동반자
				this.grdMain.setCellProperty( "Body", 11, "edittype", "text");	//특이사항		
				this.staCn.set_text("급간식을 하지 않는 교실입니다."); 	
				
			//3. 결재 = Y  급간식 = Y  -- 징수여부만 활성화 / 나머지 비활성화
			}else if(rsAtrzStsCd == "Y" && mlsnYn == "Y"){
				this.grdMain.setCellProperty( "Body", 5, "edittype", "none"); 		//출석여부
				this.grdMain.setCellProperty( "Body", 6, "edittype", "none");		//급간식
				this.grdMain.setCellProperty( "Body", 7, "edittype", "checkbox");	//징수여부
				this.grdMain.setCellProperty( "Body", 8, "edittype", "none");		//퇴실시
				this.grdMain.setCellProperty( "Body", 9, "edittype", "none");		//퇴실분
				this.grdMain.setCellProperty( "Body", 10, "edittype", "none");		//귀가동반자
				this.grdMain.setCellProperty( "Body", 11, "edittype", "none");		//특이사항			
				
			//4. 결재 = Y  급간식 = N  -- 전부 비활성화	
			}else if(rsAtrzStsCd == "Y" && mlsnYn == "N"){			
				this.grdMain.setCellProperty( "Body", 5, "edittype", "none"); 	//출석여부
				this.grdMain.setCellProperty( "Body", 6, "edittype", "none");	//급간식
				this.grdMain.setCellProperty( "Body", 7, "edittype", "none");	//징수여부
				this.grdMain.setCellProperty( "Body", 8, "edittype", "none");	//퇴실시
				this.grdMain.setCellProperty( "Body", 9, "edittype", "none");	//퇴실분
				this.grdMain.setCellProperty( "Body", 10, "edittype", "none");	//귀가동반자
				this.grdMain.setCellProperty( "Body", 11, "edittype", "none");	//특이사항			
				this.staCn.set_text("급간식을 하지 않는 교실입니다."); 	
			}
			
			
			//●2. 버튼 활성화 세팅
			//●2-1 조회된 값 있으면 활성화
			var dsMainCnt = this.dsMain.rowcount;
			if(dsMainCnt > 0){ 
				this.btnSave.set_enable(true); 		//저장
				
				
				//●2-1-1 상신중, 완결된 일지의 결출정보는 비활성화
				if(rsAtrzStsCd == "Y"){
					this.btnAplcn.set_enable(false); 	//일괄적용
					this.cboAtte.set_enable(false); 	//출결여부
					this.cboMlsv.set_enable(false); 	//급간식여부
					this.chkLves.set_enable(false); 	//징수
					this.cboHh.set_enable(false); 		//시
					this.cboMm.set_enable(false); 		//분
					this.btnDelete.set_enable(false); 	//삭제
					this.staCn.set_text("결재중 및 완결된 일지의 출결사항이므로 변경이 불가능합니다."); 	
					this.btnCopy.set_enable(false); 	//전주복사
					this.btnCopyAca.set_enable(false);	//교무출결정보 적용 
				
				//●2-1-2 상신중, 완결된 일지의 결출정보 아니면 활성화 	
				}else{
					this.btnAplcn.set_enable(true); 	//일괄적용
					this.cboAtte.set_enable(true); 		//출결여부
					this.cboMlsv.set_enable(true); 		//급간식여부
					this.chkLves.set_enable(true); 		//징수
					this.cboHh.set_enable(true); 		//시
					this.cboMm.set_enable(true); 		//분
					this.btnDelete.set_enable(true); 	//삭제
					this.btnCopy.set_enable(true); 		//전주복사
					this.btnCopyAca.set_enable(true);	//교무출결정보 적용 
					this.cboAtte.set_index(0); 			//출결여부
					this.cboMlsv.set_index(0); 			//급간식여부
					this.cboHh.set_index(0); 			//시
					this.cboMm.set_index(0); 			//분					
				}
				
				//퇴실시각이 null일때 빈값 넣어주기 (그리드에서 콤보가 선택으로 맞춰지게 하기 위해)
				
				this.dsMain.set_updatecontrol(false);//데이터셋 rowtype 수정으로 변경되지 않도록 꺼놓기
				this.dsMain.set_enableevent(false);//속도 향상을 위해 이벤트 꺼놓기
				for(var i=0; i<dsMainCnt ; i++){
					this.smfIsNull(this.dsMain.getColumn(i, "eccHh")) ? this.dsMain.setColumn(i, "eccHh", "") : "" ;
					this.smfIsNull(this.dsMain.getColumn(i, "eccMm")) ? this.dsMain.setColumn(i, "eccMm", "") : "" ;		
				}	
				this.dsMain.set_enableevent(true);//속도 향상을 위해 이벤트 꺼놓기
				this.dsMain.set_updatecontrol(true);
				
			//●2-2 조회된 내역이 없으면 전부 비활성화
			}else{
				this.btnSave.set_enable(false); 	//저장
				this.btnAplcn.set_enable(false); 	//일괄적용
				this.cboAtte.set_enable(false); 	//출결여부
				this.cboMlsv.set_enable(false); 	//급간식여부
				this.chkLves.set_enable(false); 	//징수
				this.cboHh.set_enable(false); 		//시
				this.cboMm.set_enable(false); 		//분
				this.btnDelete.set_enable(false); 	//삭제
				this.staCn.set_text("조회된 내역이 없습니다."); 
				this.btnCopy.set_enable(false); 	//전주복사		
				this.btnCopyAca.set_enable(false);	//교무출결정보 적용 
			}//2-2 조회된 내역이 없으면 전부 비활성화 if 끝	
			
			
			//급간식 안하는 교실은 급간식여부=N으로 세팅
			if(mlsnYn=="N"){
				this.cboMlsv.set_value('N'); //일괄적용에 있는 급간식여부
				this.cboMlsv.set_enable(false); //일괄적용에 있는 급간식여부
				this.chkLves.set_enable(false); //일괄적용에 있는 징수여부				
				//그리드 급간식여부
				this.dsMain.set_enableevent(false); //속도향상을 위해 이벤트 꺼놓기
				for(var i=0; i<this.dsMain.rowcount; i++){
					this.dsMain.setColumn(i, "mlsnYn", "N");
				}
				this.dsMain.set_enableevent(true); //속도향상을 위해 이벤트 꺼놓기
			}			
		});//콜백 끝		
}



/*
 * "저장" 버튼(btnSave)에서 click 이벤트 발생 시 호출.
 * 
 */
this.fnSave = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//●필수 값 체크	
	this.dsMain.set_enableevent(false); //속도향상을 위해 이벤트 꺼놓기
	for(var i=0; i<this.dsMain.rowcount; i++){
		if(this.dsMain.getRowType(i) == "2" || this.dsMain.getRowType(i) == "4"){
			
			//출결여부
			if(this.smfIsNull(this.dsMain.getColumn(i, "eccAtteScCd"))){
				this.smfAlert("CM006", ["["+ (i+1) +"행] 출결여부"], this.fnMessageCallback); // {0}은(는) 필수 입력입니다.
				return;						
			}
			//급간식
			if(this.smfIsNull(this.dsMain.getColumn(i, "mlsnYn"))){
				this.smfAlert("CM006", ["["+ (i+1) +"행] 급간식"], this.fnMessageCallback); // {0}은(는) 필수 입력입니다.
				return;			
			}			
			
			//출결여부가 출석이면 퇴실시각 체크
			if(this.dsMain.getColumn(i, "eccAtteScCd") == "01"){
				if(this.smfIsNull(this.dsMain.getColumn(i, "eccHh")) || this.smfIsNull(this.dsMain.getColumn(i, "eccMm"))){
				this.smfAlert("CM006", ["["+ (i+1) +"행] 퇴실시각"], this.fnMessageCallback); // {0}은(는) 필수 입력입니다.
				return;			
				}
				
			//출결여부가 결석인데 퇴실시각 입력했으면 퇴실시각 없애기. 급간식N으로 세팅하기
			}else if(this.dsMain.getColumn(i, "eccAtteScCd") == "02"){
				if(!this.smfIsNull(this.dsMain.getColumn(i, "eccHh")) || !this.smfIsNull(this.dsMain.getColumn(i, "eccMm"))){
					this.dsMain.setColumn(i, "eccHh", "");
					this.dsMain.setColumn(i, "eccMm", "");
					this.dsMain.setColumn(i, "mlsnYn", "N");
				}
				this.dsMain.setColumn(i, "cmhmTgprNm", "");	//귀가동행인명 없애기
			}
			
			//나이스에서 저장인지 삭제인지 구분하는 구분자 세팅. 소스 재활용하려고 이짓햇즘
			this.dsMain.setColumn(i, "sts", "u");

		}//getRowType if 끝
	}//●필수 값 체크 for 끝
	this.dsMain.set_enableevent(true); //속도향상을 위해 이벤트 꺼놓기
	
	this.dsSearch.setColumn(0, "flagAtteUp", "U"); //저장 삭제 전주복사일경우, 나이스에 보낼 데이터셋 추가하려고 만든 구분자-자바단에서 사용
	
	
	//●호출
	this.smfSaveService("save")
		// 데이터 변경 필수 
		.requireModifredData(this.dsMain)
		//메세지
		.messagePrefix(["저장"]) //{} 하시겠습니까?
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
				this.dsSearch.setColumn(0, "flagAtteUp", "");//구분자 초기화
				
				//저장 리턴값(나이스에서 BusinessException 발생한경우 메세지 찍어줄 값 넘어옴. 발생 안했으면 ok 넘어옴)
				if(!this.smfIsNull(this.dsRsMsg.getColumn(0, "rsMsg"))){
					var rsMsg = this.dsRsMsg.getColumn(0, "rsMsg");
					if(rsMsg != "ok"){
						this.smfAlert('PA057', [ rsMsg, "" ], this.fnMessageCallback ); //{0}다.{1}
					}else{
						this.smfAlert('CM002', [], this.fnMessageCallback ); // 저장이 완료되었습니다.
						this.fnSearch();
					}
				}				
		});	
};




/*
 * "삭제" 버튼(btnSave)에서 click 이벤트 발생 시 호출.
 * 
 */
this.fnDelete = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//●체크박스 선택 여부 확인
	var arrChk = this.dsMain.extractRows('chk==1');
	if(arrChk == '-1' || arrChk.length < 1){
		//선택된 {0}이(가) 없습니다. {0}을(를) 선택하여 주십시오.
		this.smfAlert('CM013', ['행']);	  
		return;
	}else{
		this.dsSearch.setColumn(0, "flagAtteUp", "D"); //저장 삭제 전주복사일경우, 나이스에 보낼 데이터셋 추가하려고 만든 구분자-자바단에서 사용
	}
	
	
	//●나이스에서 저장인지 삭제인지 구분하는 구분자 세팅. 소스 재활용하려고 이짓햇즘
	this.dsMain.set_enableevent(false); //속도향상을 위해 이벤트 꺼놓기
	for(var i=0; i<arrChk.length; i++){
		this.dsMain.setColumn(arrChk[i], "sts", "d");
	}
	this.dsMain.set_enableevent(true); //속도향상을 위해 이벤트 꺼놓기
	
	
 	//●호출
	this.smfDeleteService("delete")
		.messagePrefix(["삭제"]) //{} 하시겠습니까?
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.dsSearch.setColumn(0, "flagAtteUp", "");
			this.smfAlert('CM201', ['삭제'], this.fnMessageCallback ); // {0} 하였습니다.
			this.fnSearch();
		});			
};



/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 /*
 * "전주복사" 버튼(btnCopy)에서 click 이벤트 발생 시 호출.
 * 전 주 해당 요일의 출결정보(출결여부,급간식,퇴실시각,귀가동반자)를 복사
 * 1. 동일한 요일에 작성된 내역을 복사한다(최대 3주까지 조회해서 가장 최근껄로 가저온다)
 * 2. ECCSECOM002LT(돌봄교실별출석내역)에서 기존 출결 정보 뽑고, 여기에 없으면 ECCSECCR001MT(돌봄교실신청기본), ECCSECCM001MT(돌봄교실기본)에서 교실정보와 해당 교실에 배정된 학생정보를 뽑는다
 */
this.btnCopy_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//●체크박스 선택 여부 확인
	var arrChk = this.dsMain.extractRows('chk==1');
	if(arrChk == '-1' || arrChk.length < 1){
		//선택된 {0}이(가) 없습니다. {0}을(를) 선택하여 주십시오.
		this.smfAlert('CM013', ['행']);	  
		return;
	}


	//●파라미터 세팅
	//1. 7일전 일자 세팅
	var bf7 = this.smfAddDate(this.dsSearch.getColumn(0, "ymd"), -7);
	this.dsSearch.setColumn(0, "bf7Ymd", bf7);
	
	//2.신청번호 세팅 : 조회조건 파라미터 값이 신청번호 빼고 다 똑같음. 그래서 신청번호 in조건으로 조회할거임(asis는 건건이 조회했음)
	var aplyNoList = "";
	for(var i=0 ; i < arrChk.length ; i++){
		aplyNoList += this.dsMain.getColumn(arrChk[i], "aplyNo") + ",";
	}
	this.dsBfWeekParam.setColumn(0, "aplyNo", aplyNoList);
	
	//3. 나머지 세팅
	this.dsBfWeekParam.setColumn(0, "shlCd", this.dsMain.getColumn(0, "shlCd"));  //학교코드
	this.dsBfWeekParam.setColumn(0, "ayr", this.dsMain.getColumn(0, "ayr")); //학년도
	this.dsBfWeekParam.setColumn(0, "eccSem", this.dsMain.getColumn(0, "eccSem")); //초등돌봄교실학기
	this.dsBfWeekParam.setColumn(0, "eccScCd", this.dsMain.getColumn(0, "eccScCd")); //초등돌봄교실구분코드	
	
	this.dsSearch.setColumn(0, "flagAtteUp", "C"); //저장 삭제 전주복사일경우, 나이스에 보낼 데이터셋 추가하려고 만든 구분자-자바단에서 사용
	
	
	//●전 주 내용 조회해오기 호출
	this.smfSaveService("executeBfWeekCopy")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
				this.dsSearch.setColumn(0, "flagAtteUp", "");
			
				//●복사 - dsMain의 aplyNo(신청번호)와 dsBfWeek의 aplyNo(신청번호)가 같은애를 찾아서 복사한다 
				//1. dsBfWeek의 aplyNo(신청번호)가 dsMain의 몇번째 로우에 있는지 찾는다
				//2. dsMain의 해당 로우에 dsBfWeek의 값을 넣는다
				
				//준비
				var dsBfWeekCnt = this.dsBfWeek.rowcount;
				var dsMainCtn = this.dsMain.rowcount;
				var aplyNoRowIndex = ""; 	//dsBfWeek의 aplyNo(신청번호)가 dsMain의 몇번째 로우에 있는지 찾는다
				
				this.dsMain.set_enableevent(false); //속도향상을 위해 이벤트 꺼놓기
				for(var m=0 ; m<dsMainCtn ; m++){					
					for(var i=0 ; i<dsBfWeekCnt ; i++){
						
						//1. dsBfWeek의 aplyNo(신청번호)가 dsMain의 몇번째 로우에 있는지 찾는다
						aplyNoRowIndex = this.dsMain.findRow("aplyNo", this.dsBfWeek.getColumn(i, "aplyNo"));
						
						var eccHh = this.dsBfWeek.getColumn(i, "stuCmhmHm");
						var eccMm = this.dsBfWeek.getColumn(i, "stuCmhmHm");
						if(!this.smfIsNull(eccHh) && !this.smfIsNull(eccMm)){
							//2. dsMain의 해당 로우에 dsBfWeek의 값을 넣는다
							this.dsMain.setColumn(aplyNoRowIndex, "eccAtteScCd", this.dsBfWeek.getColumn(i, "eccAtteScCd")); //출결구분
							this.dsMain.setColumn(aplyNoRowIndex, "mlsnYn", this.dsBfWeek.getColumn(i, "mlsnYn")); // 급간식여부
							this.dsMain.setColumn(aplyNoRowIndex, "lvesYn", this.dsBfWeek.getColumn(i, "lvesYn")); // 징수여부
							this.dsMain.setColumn(aplyNoRowIndex, "eccHh", eccHh.slice(0, 2));//퇴실시각 시
							this.dsMain.setColumn(aplyNoRowIndex, "eccMm", eccHh.slice(2, 4));//퇴실시간 분
							this.dsMain.setColumn(aplyNoRowIndex, "cmhmTgprNm", this.dsBfWeek.getColumn(i, "cmhmTgprNm")); // 귀가동반자
							this.dsMain.setColumn(aplyNoRowIndex, "atteRsnCn", this.dsBfWeek.getColumn(i, "atteRsnCn")); // 특이사항(출결사유내용)
						}
					}//dsBfWeekCnt for문 끝				
				}//dsMainCtn for문 끝
				this.dsMain.set_enableevent(true); //속도향상을 위해 이벤트 꺼놓기
				
				this.smfAlert('PA058', ['전 주 출결정보를 복사하였습니다.\n내용 확인 후 저장'], this.fnMessageCallback ); // {0}해주세요.
		});	//콜백 끝	
};


/*
 * "교무출결정보 적용" 버튼(btnLevy)에서 click 이벤트 발생 시 호출.
 * 
 */
this.btnCopyAca_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//●체크박스 선택 여부 확인
	var arrChk = this.dsMain.extractRows('chk==1');
	if(arrChk == '-1' || arrChk.length < 1){
		//선택된 {0}이(가) 없습니다. {0}을(를) 선택하여 주십시오.
		this.smfAlert('CM013', ['행']);	  
		return;
	}	
	
	//●조회할 파라미터 세팅

	//●파라미터 세팅	
	//1.학생개인번호 in조건으로 세팅
	var noList = "";
	var stuInvlNoVnNo = "";
	for(var i=0 ; i < arrChk.length ; i++){
		var stuInvlNoVn = this.dsMain.getColumn(arrChk[i], "stuInvlNo");
		if(!this.smfIsNull(stuInvlNoVn)){
			noList += stuInvlNoVn + ",";	
				
		}else{
			stuInvlNoVnNo = arrChk[i];	
		}		
	}

	if(!this.smfIsNull(stuInvlNoVnNo)){
		this.smfAlert('PA003', ["["+(stuInvlNoVnNo+1)+"번째 행]학적 정보가 없어 교무출결정보를 적용할 수"], this.fnMessageCallback ); // {0} 없습니다.
		return;
	}
	
	this.dsParamAtteAcaInfo.setColumn(0, "stuInvlNo", noList);
	
	//2. 나머지 세팅
	this.dsParamAtteAcaInfo.setColumn(0, "shlCd", this.dsMain.getColumn(0, "shlCd"));  //학교코드
	this.dsParamAtteAcaInfo.setColumn(0, "ayr", this.dsMain.getColumn(0, "ayr")); //학년도
	this.dsParamAtteAcaInfo.setColumn(0, "eccSem", this.dsMain.getColumn(0, "eccSem")); //초등돌봄교실학기
	this.dsParamAtteAcaInfo.setColumn(0, "eccScCd", this.dsMain.getColumn(0, "eccScCd")); //초등돌봄교실구분코드	
	this.dsParamAtteAcaInfo.setColumn(0, "clrSeqNo", this.dsMain.getColumn(0, "clrSeqNo")); //교실순서번호	
	this.dsParamAtteAcaInfo.setColumn(0, "atteYmd", this.dsSearch.getColumn(0, "ymd")); //일자	
	this.dsSearch.setColumn(0, "flagAtteA", "A"); //나이스에 보낼 데이터셋 추가하려고 만든 구분자-자바단에서 사용	
	

	//●교무정보 조회해오기
	this.smfSearchService("listAtteAcaInfo")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
				this.dsSearch.setColumn(0, "flagAtteA", ""); //나이스에 보낼 데이터셋 추가하려고 만든 구분자-자바단에서 사용	
			
				//●복사 - dsMain의 aplyNo(신청번호)와 dsListAtteAcaInfo aplyNo(신청번호)가 같은애를 찾아서 복사한다 
				//1. dsListAtteAcaInfo aplyNo(신청번호)가 dsMain의 몇번째 로우에 있는지 찾는다
				//2. dsMain의 해당 로우에 dsListAtteAcaInfo 값을 넣는다
				
				//준비
				var dsBfWeekCnt = this.dsListAtteAcaInfo.rowcount;
				var dsMainCtn = this.dsMain.rowcount;
				var aplyNoRowIndex = ""; 	//dsListAtteAcaInfo aplyNo(신청번호)가 dsMain의 몇번째 로우에 있는지 찾는다
				var regYn = "";
				
				//●조회된 내역이 있으면 복사
				if(dsBfWeekCnt > 0){
					this.dsMain.set_enableevent(false); //속도향상을 위해 이벤트 꺼놓기
					for(var m=0 ; m<dsMainCtn ; m++){					
						for(var i=0 ; i<dsBfWeekCnt ; i++){
							
							//1. dsListAtteAcaInfo의 aplyNo(신청번호)가 dsList의 몇번째 로우에 있는지 찾는다
							aplyNoRowIndex = this.dsMain.findRow("aplyNo", this.dsListAtteAcaInfo.getColumn(i, "aplyNo"));
							regYn = this.dsListAtteAcaInfo.getColumn(i, "regYn");
							
							if(!this.smfIsNull(regYn) && regYn=="N"){
								//2. dsList의 해당 로우에 dsListAtteAcaInfo의 값을 넣는다. 결석한 자료만
								this.dsMain.setColumn(aplyNoRowIndex, "eccAtteScCd", this.dsListAtteAcaInfo.getColumn(i, "eccAtteScCd")); //출결구분
								this.dsMain.setColumn(aplyNoRowIndex, "mlsnYn", "N"); // 급간식여부
								this.dsMain.setColumn(aplyNoRowIndex, "eccAtteScCd", "02"); // 출결코드
								this.dsMain.setColumn(aplyNoRowIndex, "eccHh", ""); // 퇴실시
								this.dsMain.setColumn(aplyNoRowIndex, "eccMm", ""); // 퇴실분
								
								// 특이사항(출결사유내용) 60byte로 자르기
								var atteRsnCn = this.dsListAtteAcaInfo.getColumn(i, "atteRsnCn");
								if(!this.smfIsNull(atteRsnCn)){
									if(atteRsnCn.length > 20){
										atteRsnCn = atteRsnCn.substr(0, 20);
									}
								}
								this.dsMain.setColumn(aplyNoRowIndex, "atteRsnCn", atteRsnCn); // 특이사항(출결사유내용)									

							} //regYn if문 끝
						}//dsBfWeekCnt for문 끝				
					}//dsMainCtn for문 끝
					this.dsMain.set_enableevent(true); //속도향상을 위해 이벤트 꺼놓기
					this.smfAlert('PA058', ['교무출결정보를 적용하였습니다.\n내용 확인 후 저장'], this.fnMessageCallback ); // {0}해주세요.
					
				}else{
					this.smfAlert('PA003', ['조회된 교무출결정보가'], this.fnMessageCallback ); // {0} 없습니다.
				}//●조회된 내역이 있으면 복사 if문 끝
		});//●교무정보 조회해오기 콜백 끝		
};





/*
 * "일괄적용" 버튼(btnLevy)에서 click 이벤트 발생 시 호출.
 * 설정한 애들만 복사. 단 퇴실시 퇴실분은 결석일때 설정 안한것도 세팅
 */
this.btnAplcn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//●체크박스 선택 여부 확인
	var arrChk = this.dsMain.extractRows('chk==1');
	if(arrChk == '-1' || arrChk.length < 1){
		//선택된 {0}이(가) 없습니다. {0}을(를) 선택하여 주십시오.
		this.smfAlert('CM013', ['대상자']);	  
		return;
	}


	//일괄적용 설정한 값
	var cmbRegYn = this.cboAtte.value; //출결여부
	var cmbMlsnYn = this.cboMlsv.value; //급간식
	var cbxLves = this.chkLves.value; //징수여부
	var cmbHh = this.cboHh.value; //퇴실 시
	var cmbMm = this.cboMm.value; //퇴실 분	

	var dsMainCnt = this.dsMain.rowcount;
	
	this.dsMain.set_enableevent(false); //속도향상을 위해 이벤트 꺼놓기	
	for(var i=0; i<arrChk.length; i++){
		if(!this.smfIsNull(cmbRegYn)){
			this.dsMain.setColumn(arrChk[i], "eccAtteScCd", cmbRegYn );	//출결여부
		}
		if(!this.smfIsNull(cmbMlsnYn)){
			this.dsMain.setColumn(arrChk[i], "mlsnYn", cmbMlsnYn); 		//급간식
		}	
		if(!this.smfIsNull(cmbHh) || cmbRegYn == "02"){
			this.dsMain.setColumn(arrChk[i], "eccHh", cmbHh); 			//퇴실시
		}	
		if(!this.smfIsNull(cmbMm) || cmbRegYn == "02"){
			this.dsMain.setColumn(arrChk[i], "eccMm", cmbMm); 			//퇴실분
		}	
		this.dsMain.setColumn(arrChk[i], "lvesYn", this.chkLves.value); //징수여부
		
		if(cmbRegYn == "02"){ //결석일때 귀가동반자 초기화
			this.dsMain.setColumn(arrChk[i], "cmhmTgprNm", "");
		}
	}
	this.dsMain.set_enableevent(true); //속도향상을 위해 이벤트 꺼놓기
};




/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 /**
 * 학년도 콤보 변경시 -
 * [돌봄학기 콤보 세팅]
 * @param : N/A
 * @return : N/A
 */
this.divSearch_cboAyr_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.eccComboSet("selectEccSem", this.dsSearch, this.dsEccSem, this.fnMessageCallback, "2");
};



 /**
 * 돌봄학기 콤보 변경시 -
 * [돌봄구분 콤보 세팅]
 * @param : N/A
 * @return : N/A
 */
this.divSearch_cboSem_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.eccComboSet("selectEccScCd", this.dsSearch, this.dsEccScCd, this.fnMessageCallback, "3");
};



 /**
 * 돌봄구분 콤보 변경시 -
 * [교실 콤보 세팅]
 * @param : N/A
 * @return : N/A
 */
this.divSearch_cboSc_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.eccComboSet("selectEccEccNm", this.dsSearch, this.dsEccNm, this.fnMessageCallback, "4");	
};


 /**
 * 교실 콤보 변경
 * @param : N/A
 * @return : N/A
 */
this.divSearch_cboClr_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	//total 초기화
	this.staCn.set_text("                                                                                                              "); 
	this.sta04_01.set_text("0"); //total찍기
	this.dsMain.clearData();
	
	
	//학년도랑 일자이랑 맞추기
	var ayr = this.dsSearch.getColumn(0, "ayr"); //학년도
	var ymdYy = (this.dsSearch.getColumn(0, "ymd")).substr(0, 4); //일자의 년도
	var ymdMm = (this.dsSearch.getColumn(0, "ymd")).substr(4, 2); //일자의 월
	var ymdMmDd = (this.dsSearch.getColumn(0, "ymd")).substr(4, 4); //일자의 월일
	
	//●년월의 년도랑 학년도랑 같지 않으면 학년도랑 년월 맞추기
	if(ayr != ymdYy && ymdMm > 02){
		this.dsSearch.setColumn(0, "ymd", ayr +""+ ymdMmDd);
	}
	
	//●1월 2월은 전년도 세팅	
	if(ymdMm < 03){
		this.dsSearch.setColumn(0, "ymd", (nexacro.toNumber(ayr)+1) +""+ ymdMmDd);
	}		
};



 /**
 * 일자 변경시
 * @param : N/A
 * @return : N/A
 */
this.divSearch_calYm_onchanged = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{
	//total 초기화
	this.staCn.set_text("                                                                                                              "); 
	this.sta04_01.set_text("0"); //total찍기
	this.dsMain.clearData();	
};



/**
 * @description 그리드 체크박스 헤드 클릭
*/
this.grdInsrList_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	//체크박스 전체 선택 
	this.smfSetGridCheckAll(obj, e, function (ds, nRow){
		var a = ds;
	});		
};


/**
 * @description 일자에서 엔터 눌렀을때 조회
*/
this.divSearch_calYm_onkeydown = function(obj:nexacro.Calendar,e:nexacro.KeyEventInfo)
{
	if(e.keycode == "13"){
		
		this.fnSearchDirYnCk();
	}
};


/**
 * @description 출석 콤보 변경시
 * 출석(01)일땐 섭취(Y) / 결석(02)일땐 미섭취(N)로 자동 세팅
*/
this.cboAtte_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	//급간식을 안하는 교실
	if(this.dsList.getColumn(0, "mlsnYn") == "N"){
		this.cboMlsv.set_value('N');
		this.cboMlsv.set_enable(false);
		
		//출석
		if(this.cboAtte.value == '01'){
			this.cboHh.set_enable(true);
			this.cboMm.set_enable(true);
			
		//결석	
		}else if(this.cboAtte.value == '02'){
			this.cboHh.set_index(0);
			this.cboMm.set_index(0);
			this.cboHh.set_enable(false);
			this.cboMm.set_enable(false);			
		}
		
	//급간식을 하는 교실	
	}else{
		//출석
		if(this.cboAtte.value == '01'){
			this.cboMlsv.set_value('Y');
			this.cboMlsv.set_enable(true);
			this.cboHh.set_enable(true);
			this.cboMm.set_enable(true);
			
		//결석	
		}else if(this.cboAtte.value == '02'){
			this.cboMlsv.set_value('N');
			this.cboHh.set_index(0);
			this.cboMm.set_index(0);
			
			this.cboMlsv.set_enable(false);
			this.cboHh.set_enable(false);
			this.cboMm.set_enable(false);			
		}	
	}
};


/*
 * 콤보 박스에서 selection-change 이벤트 발생 시 호출.
 * ComboBox Item을 선택하여 선택된 값이 저장된 후에 발생하는 이벤트.
 * 결석(02)일땐 미섭취(N)로 자동 세팅
 */
this.cboMlsv_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	if(this.cboAtte.value == '02'){
		this.cboMlsv.set_value('N');
	}	
};



/*
 * 그리드 출결여부, 급간식, 퇴실시각 변경시
 * 출결여부가 결석일경우 - 급간식, 퇴실시각 세팅
 */
this.dsMain_oncolumnchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	if(e.columnid=="eccAtteScCd" || e.columnid=="mlsnYn" || e.columnid=="eccHh" || e.columnid=="eccMm"){
		if(this.dsMain.getColumn(e.row, "eccAtteScCd") == "02"){
			this.dsMain.setColumn(e.row, "mlsnYn", "N");
			this.dsMain.setColumn(e.row, "eccHh", "");
			this.dsMain.setColumn(e.row, "eccMm", "");
			this.dsMain.setColumn(e.row, "cmhmTgprNm", "");
		}
	}
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.cboAyr" propid="value" datasetid="dsSearch" columnid="ayr"/>
      <BindItem id="item1" compid="divSearch.form.cboSem" propid="value" datasetid="dsSearch" columnid="eccSem"/>
      <BindItem id="item2" compid="divSearch.form.cboSc" propid="value" datasetid="dsSearch" columnid="eccScCd"/>
      <BindItem id="item3" compid="divSearch.form.cboClr" propid="value" datasetid="dsSearch" columnid="clrSeqNo"/>
      <BindItem id="item4" compid="divSearch.form.calYm" propid="value" datasetid="dsSearch" columnid="ymd"/>
    </Bind>
  </Form>
</FDL>
