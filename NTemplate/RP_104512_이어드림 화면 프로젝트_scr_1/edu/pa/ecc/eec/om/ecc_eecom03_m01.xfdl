        <Grid id="grdMain" taborder="16" left="0" top="304" autofittype="col" right="0" selecttype="cell" binddataset="dsMain" onheadclick="grdInsrList_onheadclick" autosizingtype="row" cellsizingtype="both" extendsizetype="row" autoenter="select" initvalueid="ivGrdAccessibilityOn" bottom="0" accessibilitylabel="출결관리: 학년, 반, 번호, 성명, 출결여부, 급간식, 징수여부, 퇴실시각, 귀가동행인, 특이사항 정보">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="48"/>
                <Column size="55"/>
                <Column size="55"/>
                <Column size="55"/>
                <Column size="100"/>
                <Column size="100"/>
                <Column size="100"/>
                <Column size="70"/>
                <Column size="100"/>
                <Column size="100"/>
                <Column size="100"/>
                <Column size="200"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell displaytype="checkboxcontrol"/>
                <Cell col="1" text="학년"/>
                <Cell col="2" text="반"/>
                <Cell col="3" text="번호"/>
                <Cell col="4" text="성명"/>
                <Cell col="5" text="출결여부"/>
                <Cell col="6" text="급간식"/>
                <Cell col="7" text="징수여부"/>
                <Cell col="8" colspan="2" text="퇴실시각"/>
                <Cell col="10" text="귀가동행인"/>
                <Cell col="11" text="특이사항" cssclass="LineNo"/>
              </Band>
              <Band id="body">
                <Cell displaytype="checkboxcontrol" edittype="checkbox" text="bind:chk" cursor="pointer"/>
                <Cell col="1" text="bind:grd" textAlign="center" wordWrap="char" autosizerow="limitmin"/>
                <Cell col="2" text="bind:clsNm" wordWrap="char" autosizerow="limitmin"/>
                <Cell col="3" text="bind:clsNo" textAlign="center" wordWrap="char" autosizerow="limitmin"/>
                <Cell col="4" text="bind:stuFlnm" wordWrap="char" autosizerow="limitmin"/>
                <Cell col="5" displaytype="combocontrol" edittype="combo" text="bind:eccAtteScCd" wordWrap="char" combodataset="dsEccAtteScCdGrid" combocodecol="code" combodatacol="value" comboautoselect="true" cursor="pointer" autosizerow="limitmin"/>
                <Cell col="6" displaytype="combocontrol" edittype="combo" text="bind:mlsnYn" wordWrap="char" combodataset="dsMlsnGrid" combocodecol="code" combodatacol="value" comboautoselect="true" cursor="pointer" autosizerow="limitmin"/>
                <Cell col="7" displaytype="checkboxcontrol" edittype="checkbox" text="bind:lvesYn" wordWrap="char" checkboxfalsevalue="N" checkboxtruevalue="Y" cursor="pointer" autosizerow="limitmin"/>
                <Cell col="8" displaytype="combocontrol" edittype="combo" text="bind:eccHh" wordWrap="char" combodataset="dsEccHhGrid" combocodecol="code" combodatacol="value" comboautoselect="true" cursor="pointer" autosizerow="limitmin" combodisplaynulltext="선택"/>
                <Cell col="9" displaytype="combocontrol" edittype="combo" text="bind:eccMm" wordWrap="char" combodataset="dsEccMmGrid" combocodecol="code" combodatacol="value" comboautoselect="true" cursor="pointer" autosizerow="limitmin" combodisplaynulltext="선택"/>
                <Cell col="10" text="bind:cmhmTgprNm" wordWrap="char" editautoselect="true" editmaxlength="10" cursor="progress" autosizerow="limitmin"/>
                <Cell col="11" text="bind:atteRsnCn" wordWrap="char" editautoselect="true" editmaxlength="20" cursor="progress" autosizerow="limitmin" cssclass="LineNo"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
