    <Script type="xscript5.1"><![CDATA[/**
*  보존식관리
*  @MenuPath    초등돌봄교실 > 보존식관리
*  @FileName 	ecc_eecom07_m01.xfdl 
*  @Creator 	이혜진
*  @CreateDate 	2022.10.20
*  @Desction    초등돌봄교실(돌봄인력서비스) 보존식관리
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.10.20            이혜진                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::ecc_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_onLoadYn = true; //초기세팅여부 (화면 load시에만 첫번째 값으로 세팅하기)
this.fv_nxtAyr = ""; //조회월이 01월 02월 일 경우 조회할때 조회년월 파라미터를 차년도로 설정

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 /*
 * 화면 load시
 * 
 * 조회조건 초기값 세팅
 * 1. 사용자정보세팅 (주민번호, 시도코드, 접속시도코드, 사용자id, 학교코드-전담사로 등록되어있는 학교코드)
 * 2. 학년도 세팅 = 현재년도-1~현재년도+1 
 * 3. 년월 세팅 = 현재날짜
 * 4. 돌봄학기 -> 돌봄구분 -> 교실명 세팅
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitForm(obj);

	//●1. 사용자정보세팅
	this.eccfSetHnfInfo("selectHnfInfoForSession", this.dsSearch, ""); 
};


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
			
	switch(svcid) {	
	
		//●사용자정보세팅 콜백
		case "selectHnfInfoForSession" : 
			if ( errcd == -100 ) {//오류메시지 확인용
				this.smfAlert("errcd : "+errcd);
				this.alert(errmsg);
			}

			//●2. 학년도 세팅 
			this.eccCmbSetAyr(this.dsAyr, "code", "value", 1, 1);
			//현재년도로 디폴트 값 세팅
			this.divSearch.form.cboAyr.set_index(0);
			
			
			//●3. 년월 세팅(현재 월) - 월은 고정이므로 콤보에 하드코딩함
			this.dsSearch.setColumn(0, "mm", this.smfToday().dateFormat("MM"));
			
			
			//조회월이 01월 02월 일 경우 조회할때 조회년월 파라미터를 차년도로 설정
			this.fnNxtAyr();
			
			
			//●4. 돌봄학기 콤보 세팅
			this.divSearch_cboAyr_onitemchanged();	
			break;			
	
	
		//●돌봄학기콤보 세팅 콜백
		case "selectEccSem" : 
			//에러처리
			if ( errcd == -100 ) {
				this.smfAlert("errcd : "+errcd);
				this.alert(errmsg);
			}
			
			//onload시 콤보 초기세팅
			if(this.fv_onLoadYn){
				this.divSearch.form.cboSem.set_index(0);
			}
			
			//선택된 돌봄구분이 없으면 세팅
			if(this.smfIsNull(this.divSearch.form.cboSem.text)){ 
				this.divSearch.form.cboSem.set_index(0);
			}
			
			this.divSearch_cboClr00_onitemchanged();
			break;
	}
};



/**
 * 팝업의 콜백함수
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){

	this.fnSearch();
};



/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
	
};


/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 조회 버튼 클릭
 * 
 */
 this.fnSearch = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsMain.clearData();
	
	//년월 세팅
	this.dsSearch.setColumn(0, "mlsnYmd", this.fv_nxtAyr + "" + (this.dsSearch.getColumn(0, "mm")) );
	
	this.smfSearchService("list")
		// 데이터 검증
		.validateForm(this.divSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){//에러
				return;
			}
		});
}



/**
 * 삭제 버튼 클릭
 * 
 */
this.btnDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var arrChk = this.dsMain.extractRows('chk==1');
	
	//체크박스 선택 여부 확인
	if(arrChk == '-1' || arrChk.length < 1){
		//선택된 {0}이(가) 없습니다. {0}을(를) 선택하여 주십시오.
		this.smfAlert('CM013', ['행']);	  
		return;
	}else{
		this.dsSearch.setColumn(0, "flagPfd", "D");
	}
	
 	// 서비스 객체 생성
	this.smfDeleteService("delete")
		.messagePrefix(["삭제"]) //{} 하시겠습니까?
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.smfAlert('CM201', ['삭제'], this.fnMessageCallback ); // {0} 하였습니다.
			this.fnSearch();
		});		
};



/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * 보존식등록 팝업 호출
 * 
 */
this.doPop = function(popupParams)
{
	this.smfDialog("_auto", "pa_ecc_eec_om::ecc_eecom07_p01.xfdl", popupParams);	
}





/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 /**
 * 학년도 콤보 변경시 -
 * [돌봄학기 콤보 세팅]
 * @param : N/A
 * @return : N/A
 */
this.divSearch_cboAyr_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.eccComboSet("selectEccSem", this.dsSearch, this.dsEccSem, this.fnMessageCallback, "2");
};




 /**
 * 조회월 변경시
 * [돌봄학기 콤보 세팅]
 * @param : N/A
 * @return : N/A
 */
this.divSearch_cboClr00_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	//조회월이 01월 02월 일 경우 조회할때 조회년월 파라미터를 차년도로 설정
	this.fnNxtAyr();
};



/*
 * 조회월이 01월 02월 일 경우 조회할때 조회년월 파라미터를 차년도로 설정
 */
this.fnNxtAyr = function()
{
	if(this.dsSearch.getColumn(0, "mm") > 02){
		this.fv_nxtAyr = this.dsSearch.getColumn(0, "ayr");
		
	}else{
		this.fv_nxtAyr = nexacro.toNumber(this.dsSearch.getColumn(0, "ayr"))+1;
	}	
};




/**
 * 등록 버튼 클릭 - 보존식등록 팝업 호출
 * @param : N/A
 * @return : N/A
 */
this.btnIssuAply_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
		//●팝업에 보낼 데이터 세팅
		var popupParams = {
								callback: this.fnPopupCallback
							  , sender	: obj // sender 지정
							  , params	: {
												dsSearch : this.dsSearch		
											  , mlsnYmd	 : ( this.fv_nxtAyr + "" + this.dsSearch.getColumn(0, "mm") )	
											  , flag	 : "insert"	
											  , procType : "search"
										  } 
						   };		
		
		//●팝업호출
		this.doPop(popupParams)	
};



/**
 * 그리드의 기준교실명 클릭 - 보존식등록 팝업 호출
 * @param : N/A
 * @return : N/A
 */
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if(this.grdMain.getBindCellIndex("body", "eccNm") == e.col){
	
		//●팝업에 보낼 데이터 세팅
		this.dsMainPop.copyRow(0, this.dsMain, e.row);
		var popupParams = {
								callback: this.fnPopupCallback
							  , sender	: obj // sender 지정
							  , params	: {
												dsSearch : this.dsSearch		
											  , dsPfdList: this.dsMainPop
											  , flag	 : "update"	
											  , procType : "search"
										  } 
						   };		
		
		//●팝업호출
		this.doPop(popupParams)			
	}
};


/**
 * @description 그리드 체크박스 헤드 클릭
*/
this.grdMain_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	//체크박스 전체 선택 
	this.smfSetGridCheckAll(obj, e, function (ds, nRow){
				var a = ds;
			});	
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.cboAyr" propid="value" datasetid="dsSearch" columnid="ayr"/>
      <BindItem id="item1" compid="divSearch.form.cboSem" propid="value" datasetid="dsSearch" columnid="eccSem"/>
      <BindItem id="item2" compid="divSearch.form.cboClr00" propid="value" datasetid="dsSearch" columnid="mm"/>
    </Bind>
  </Form>
</FDL>
