                <Cell col="5" text="bind:pfdCllnDt" textAlign="center" wordWrap="char" displaytype="date" calendardateformat="yyyy.MM.dd HH:mm" calendareditformat="yyyy.MM.dd HH:mm" autosizerow="limitmin"/>
                <Cell col="6" text="bind:pfdDscdDt" textAlign="center" wordWrap="char" displaytype="date" calendardateformat="yyyy.MM.dd HH:mm" calendareditformat="yyyy.MM.dd HH:mm" autosizerow="limitmin"/>
                <Cell col="7" text="bind:userNm" textAlign="center" wordWrap="char" autosizerow="limitmin"/>
                <Cell col="8" text="bind:pfdEtcCn" wordWrap="char" autosizerow="limitmin" cssclass="LineNo"/>
              </Band>
            </Format>
