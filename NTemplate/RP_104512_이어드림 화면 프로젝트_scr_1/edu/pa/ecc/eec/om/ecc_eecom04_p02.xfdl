<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="ecc_eecom04_p02" width="800" height="540" titletext="프로그램 검색" nHeight="754" onload="fnOnload">
    <Layouts>
      <Layout height="540" width="800" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divTitle" taborder="1" left="20" top="15" height="54" text="" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="프로그램 검색" left="0" top="0" height="54" cssclass="img_WF_SubTit01" width="200" initvalueid="ivTitleAccessibilityOn" accessibilitylabel="프로그램 검색"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divSearch" taborder="2" left="20" top="94" height="50" cssclass="div_WF_Search" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staHnfTyp" taborder="0" text="프로그램명" left="0" top="10" width="94" height="30" cssclass="sta_WF_Essential01" initvalueid="ivStcEssential" accessibilitylabel="프로그램명"/>
              <Edit id="edtNm" taborder="1" left="94" top="10" height="30" text="우리날" width="195" initvalueid="ivEdtEssential" cssclass="essential" maxlength="10" autoselect="true" onkeydown="divSearch_edtNm_onkeydown" accessibilitylabel="프로그램명"/>
              <Button id="btnSearch" taborder="2" text="조회" top="10" width="74" height="30" cssclass="btn_WF_Search03" right="10" initvalueid="ivBtnAccessibilityButton" onclick="fnSearch" accessibilitylabel="조회"/>
            </Layout>
          </Layouts>
        </Div>
        <Grid id="grdMain" taborder="3" left="20" top="154" autofittype="col" right="20" selecttype="cell" initvalueid="ivGrdAccessibilityOn" binddataset="dsList" oncellclick="grd01_oncellclick" bottom="70" autosizingtype="row" cellsizingtype="both" extendsizetype="row" oncelldblclick="grdMain_oncelldblclick" accessibilitylabel="프로그램 검색: 프로그램명, 프로그램 설명, 강사명, 생년월일, 선택">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="150"/>
                <Column size="150"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="50"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="프로그램명"/>
                <Cell col="1" text="프로그램설명"/>
                <Cell col="2" text="강사명"/>
                <Cell col="3" text="생년월일"/>
                <Cell col="4" text="선택"/>
              </Band>
              <Band id="body">
                <Cell text="bind:eccPgmNm" wordWrap="char" autosizerow="limitmin"/>
                <Cell col="1" text="bind:eccPgmEpl" wordWrap="char" autosizerow="limitmin"/>
                <Cell col="2" text="bind:hnfFlnm" textAlign="center" wordWrap="char" autosizerow="limitmin"/>
                <Cell col="3" text="bind:birth" textAlign="center" wordWrap="char" displaytype="date" calendardateformat="yy.MM.dd" calendareditformat="yy.MM.dd" autosizerow="limitmin"/>
                <Cell col="4" displaytype="buttoncontrol" edittype="button" text="bind:btn" cssclass="cell_WF_PointBtn01" autosizerow="limitmin"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="btnClose" taborder="4" text="닫기" onclick="btn_close_onclick" cssclass="btn_WF_Custom" left="375" width="50" height="30" escapebutton="true" hotkey="ALT+C" initvalueid="ivBtnAccessibilityButton" bottom="20" accessibilitylabel="닫기"/>
        <Static id="sta00" taborder="5" left="20" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta01" taborder="6" left="20" top="64" height="30" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta01_00" taborder="7" left="20" top="144" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta02" taborder="8" left="20" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff" bottom="50"/>
        <Static id="sta03" taborder="9" left="20" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff" bottom="0"/>
        <Static id="sta04" taborder="10" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="20" right="780" height="100.00%"/>
        <Static id="sta05" taborder="11" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="20" right="0" height="100%"/>
      </Layout>
      <Layout name="Layout0" screenid="mobile" width="640" height="1024" mobileorientation="portrait" type="default"/>
    </Layouts>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">list</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsList=dsList</Col>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">R</Col>
            <Col id="bindingControls"/>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
            <Col id="url">/ecc_cmn_cm01_005.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="shlCd" type="STRING" size="256" description="학교코드"/>
          <Column id="ayr" type="STRING" size="256" description="학년도"/>
          <Column id="eccPgmNm" type="STRING" size="256" description="프로그램명"/>
          <Column id="cddcCd" type="STRING" size="256" description="시도교육청코드"/>
          <Column id="hnfRrno" type="STRING" size="256" description="인력주민등록번호"/>
          <Column id="cntnCtpvScCd" type="STRING" size="256" description="접속시도코드"/>
          <Column id="userId" type="STRING" size="256" description="사용자id"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="shlCd"/>
            <Col id="ayr"/>
            <Col id="eccPgmNm"/>
            <Col id="cddcCd"/>
            <Col id="hnfRrno"/>
            <Col id="cntnCtpvScCd"/>
            <Col id="userId"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsList" useclientlayout="true">
        <ColumnInfo>
          <Column id="shlCd" type="STRING" size="256" description="학교코드"/>
          <Column id="ayr" type="STRING" size="256" description="학년도"/>
          <Column id="pgmSeqNo" type="STRING" size="256" description="프로그램순서번호"/>
          <Column id="eccPgmNm" type="STRING" size="256" description="프로그램명"/>
          <Column id="cmpnsGrtsScCd" type="STRING" size="256" description="유상무상구분코드- 무상(01), 유상(02)"/>
          <Column id="operMbyScCd" type="STRING" size="256" description="운영주체구분코드- 전담사(01), 협약(02), 교원(03), 강사(04), 기타(05)"/>
          <Column id="eccHnfIdfNo" type="STRING" size="256" description="인력식별번호"/>
          <Column id="eccPgmEpl" type="STRING" size="256" description="프로그램설명"/>
          <Column id="mdfrId" type="STRING" size="256" description="수정자id"/>
          <Column id="mdfcnDt" type="STRING" size="256" description="수정일지"/>
          <Column id="hnfFlnm" type="STRING" size="256" description="성명"/>
          <Column id="hnfRrno" type="STRING" size="256" description="주민등록번호"/>
          <Column id="birth" type="STRING" size="256" description="생년월일"/>
          <Column id="houTelno" type="STRING" size="256" description="전화번호"/>
          <Column id="invlMblTelno" type="STRING" size="256" description="휴대전화"/>
          <Column id="eccHnfStsScCd" type="STRING" size="256" description="인력상태구분코드"/>
          <Column id="eccHffcScCd" type="STRING" size="256" description="재직구분코드"/>
          <Column id="btn" type="STRING" size="256" description="그리드 버튼"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsRs" useclientlayout="true">
        <ColumnInfo>
          <Column id="shlCd" type="STRING" size="256" description="학교코드"/>
          <Column id="ayr" type="STRING" size="256" description="학년도"/>
          <Column id="pgmSeqNo" type="STRING" size="256" description="프로그램순서번호"/>
          <Column id="eccPgmNm" type="STRING" size="256" description="프로그램명"/>
          <Column id="cmpnsGrtsScCd" type="STRING" size="256" description="유상무상구분코드- 무상(01), 유상(02)"/>
          <Column id="operMbyScCd" type="STRING" size="256" description="운영주체구분코드- 전담사(01), 협약(02), 교원(03), 강사(04), 기타(05)"/>
          <Column id="eccHnfIdfNo" type="STRING" size="256" description="인력식별번호"/>
          <Column id="eccPgmEpl" type="STRING" size="256" description="프로그램설명"/>
          <Column id="mdfrId" type="STRING" size="256" description="수정자id"/>
          <Column id="mdfcnDt" type="STRING" size="256" description="수정일지"/>
          <Column id="hnfFlnm" type="STRING" size="256" description="성명"/>
          <Column id="hnfRrno" type="STRING" size="256" description="주민등록번호"/>
          <Column id="birth" type="STRING" size="256" description="생년월일"/>
          <Column id="houTelno" type="STRING" size="256" description="전화번호"/>
          <Column id="invlMblTelno" type="STRING" size="256" description="휴대전화"/>
          <Column id="eccHnfStsScCd" type="STRING" size="256" description="인력상태구분코드"/>
          <Column id="eccHffcScCd" type="STRING" size="256" description="재직구분코드"/>
          <Column id="btn" type="STRING" size="256" description="그리드 버튼"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  프로그램 검색
*  @MenuPath    초등돌봄교실 > 프로그램 검색
*  @FileName 	ecc_eecom07_p01.xfdl 
*  @Creator 	이혜진
*  @CreateDate 	2022.11.09
*  @Desction    초등돌봄교실(돌봄인력서비스) 프로그램 검색
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.11.09            이혜진                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::ecc_script.xjs"


/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 
 /*
 * 화면 load시
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	
	//1. 부모창에서 넘어온값 세팅
	var initValue = this.smfGetPopupParams(); //부모창에서 넘어온 값	 	
	
	//학교코드
	if(this.smfIsNull(initValue.shlCd)){
		this.smfAlert("CM006", ["shlCd(학교코드)"], this.fnMessageCallback); // {0}은(는) 필수 입력입니다.
		return;				
	}else{
		this.dsSearch.setColumn(0, "shlCd", initValue.shlCd);
	}
	
	//학년도
	if(this.smfIsNull(initValue.ayr)){
		this.smfAlert("CM006", ["ayr(학년도)"], this.fnMessageCallback); // {0}은(는) 필수 입력입니다.
		return;				
	}else{
		this.dsSearch.setColumn(0, "ayr", initValue.ayr);
	}
	
	//접속시도코드
	if(this.smfIsNull(initValue.cntnCtpvScCd)){
		this.smfAlert("CM006", ["cntnCtpvScCd(접속시도코드)"], this.fnMessageCallback); // {0}은(는) 필수 입력입니다.
		return;				
	}else{
		this.dsSearch.setColumn(0, "cntnCtpvScCd", initValue.cntnCtpvScCd);
	}	
	
	//프로그램명
	if(!this.smfIsNull(initValue.eccPgmNm)){
		this.dsSearch.setColumn(0, "eccPgmNm", initValue.eccPgmNm);
	}
	
	
	this.divSearch.form.edtNm.setFocus();
	
	//2.조회
	this.fnSearch();
};




/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
			
	switch(svcid) {	
	
	
	
	}
}



/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
	
};


/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 /**
 * 조회버튼 클릭
 * @param : N/A
 * @return : N/A
 */
  this.fnSearch = function()
{
	//프로그램명 검색한거 두번 조회해야 값이 들어감 왜그러지. 강제로 세팅하기
	this.dsSearch.setColumn(0, "eccPgmNm", this.divSearch.form.edtNm.value); 


	//호출
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){//에러
				return;
			}	
			
			//조회된 데이터가 1개이면 자동선택하고 팝업 닫기
			if(this.dsList.rowcount === 1){				
				this.dsRs.copyRow(0, this.dsList, this.dsList.rowposition);
				this.smfSendResponseToOpener({
					"row": this.smfRowToObject(this.dsRs)
				});
				this.close(true);				
			}			
			
			
	});	//콜백 끝		
}



 /************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 /**
 * 선택버튼 클릭
 * @param : N/A
 * @return : N/A
 */
this.grd01_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if(this.grdMain.getBindCellIndex("body", "btn") == e.col){
	
		this.dsRs.copyRow(0, this.dsList, this.dsList.rowposition);
		this.smfSendResponseToOpener({
			"row": this.smfRowToObject(this.dsRs)
		});
		this.close(true);
	}
};

 
/*
* 셀 더블클릭
*/
this.grdMain_oncelldblclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	this.dsRs.copyRow(0, this.dsList, this.dsList.rowposition);
	this.smfSendResponseToOpener({
		"row": this.smfRowToObject(this.dsRs)
	});
	this.close(true);	
};

 

 /**
 * 프로그램명 검색에서 엔터키 누르면 조회하기
 * @param : N/A
 * @return : N/A
 */
this.divSearch_edtNm_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode == "13"){
		this.fnSearch();
	}
};



 /**
 * 닫기버튼 클릭
 * @param : N/A
 * @return : N/A
 */
this.btn_close_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close();
};


]]></Script>
    <Bind>
      <BindItem id="item1" compid="divSearch.form.edtNm" propid="value" datasetid="dsSearch" columnid="eccPgmNm"/>
    </Bind>
  </Form>
</FDL>
