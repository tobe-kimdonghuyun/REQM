        <Combo id="cboClas" taborder="15" left="560" width="380" height="30" innerdataset="dsClassListCbo" codecolumn="clsFilt" datacolumn="careDiaryTitlNm" index="0" top="274" initvalueid="ivCmbEssential" accessibilitylabel="일지목록 구분" cssclass="essential" onitemchanged="cboClas_onitemchanged"/>
      </Layout>
