    <Script type="xscript5.1"><![CDATA[/**
*  일지관리  
*  @MenuPath    초등돌봄교실 > 일지관리
*  @FileName 	ecc_eecom04_m01.xfdl 
*  @Creator 	이혜진
*  @CreateDate 	2022.11.09
*  @Desction    초등돌봄교실(돌봄인력서비스) 일지관리
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.11.09            이혜진                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::ecc_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_onLoadYn = true; //초기세팅여부 (화면 load시에만 첫번째 값으로 세팅하기)
this.fv_nxtAyr = ""; //조회월이 01월 02월 일 경우 조회할때 조회년월 파라미터를 차년도로 설정

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 /*
 * 화면 load시
 * 
 * 조회조건 초기값 세팅
 * 1. 사용자정보세팅 (주민번호, 시도코드, 접속시도코드, 사용자id, 학교코드-전담사로 등록되어있는 학교코드)
 * 2. 학년도 세팅 = 현재년도-1~현재년도+1 
 * 3. 월 세팅(현재 월) - 월은 고정이므로 하드코딩함 dsMm 
 * 4. 등록버튼 옆 일자 세팅
 * 5. 일괄생성일 세팅 - 1일~현재날짜	
 * 6. 돌봄학기세팅 -> 돌봄구분 세팅
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitForm(obj);

	//●1. 사용자정보세팅
	this.eccfSetHnfInfo("selectHnfInfoForSession", this.dsSearch, ""); 
};


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
			
	switch(svcid) {	
	
		//●사용자정보세팅 콜백
		case "selectHnfInfoForSession" : 
			if ( errcd == -100 ) {//오류메시지 확인용
				this.smfAlert("errcd : "+errcd);
				this.alert(errmsg);
			}	
	
			//2. 학년도 세팅 
			this.eccCmbSetAyr(this.dsAyr, "code", "value", 1, 1);
			this.divSearch.form.cboAyr.set_index(0); //현재년도로 디폴트 값 세팅
				
				
			//3. 월 세팅(현재 월) - 월은 고정이므로 하드코딩함 dsMm 
			this.dsSearch.setColumn(0, "mm", this.smfToday().dateFormat("MM"));
			
			//조회월이 01월 02월 일 경우 조회할때 조회년월 파라미터를 차년도로 설정
			this.fnNxtAyr();
			
			//4. 등록버튼 옆 일자 세팅
			if(this.dsSearch.getColumn(0, "mm") > 02){
				this.dsSearch.setColumn(0, "dairyYmd", this.smfToday().dateFormat("yyyyMMdd"));
			}else{ //조회월 01월 02월이면 차년도 세팅
				this.dsSearch.setColumn(0, "dairyYmd", nexacro.toNumber(this.smfToday().dateFormat("yyyy"))+1 + "" + this.smfToday().dateFormat("MMdd"));
			}				
			
			//5. 일괄생성일 세팅 - 1일~현재날짜	
			this.dsSearch.setColumn(0, "dairyYmdS", this.fv_nxtAyr + "" + this.dsSearch.getColumn(0, "mm")+"01");
			this.dsSearch.setColumn(0, "dairyYmdE", this.fv_nxtAyr + "" + this.smfToday().dateFormat("MMdd"));
			
			//6. 돌봄학기 콤보 세팅
			this.divSearch_cboAyr_onitemchanged();			
			break;		
	
	
	
		//●돌봄학기콤보 세팅 콜백
		case "selectEccSem" : 
			//에러처리
			if ( errcd == -100 ) {
				this.smfAlert("errcd : "+errcd);
				this.alert(errmsg);
			}
			
			//onload시 콤보 초기세팅
			if(this.fv_onLoadYn){
				this.divSearch.form.cboSem.set_index(0);
			}
			
			//선택된 돌봄구분이 없으면 세팅
			if(this.smfIsNull(this.divSearch.form.cboSem.text)){ 
				this.divSearch.form.cboSem.set_index(0);
			}
			
			//돌봄구분콤보 세팅
			this.divSearch_cboSem_onitemchanged();
			break;
		
		
		//●돌봄구분콤보 세팅 콜백
		case "selectEccScCd" :
			//에러처리
			if ( errcd == -100 ) {
				this.smfAlert("errcd : "+errcd);
				this.alert(errmsg);
			}
			
			//돌봄구분콤보에 전체 추가
			this.dsEccScCd.insertRow(0);
			this.dsEccScCd.setColumn(0, "code", "");
			this.dsEccScCd.setColumn(0, "value", "전체");
			
			//onload시 콤보 초기세팅
			if(this.fv_onLoadYn){
				this.divSearch.form.cboSc.set_index(0);
			}
			
			//선택된 돌봄구분이 없으면 세팅
			if(this.smfIsNull(this.divSearch.form.cboSc.text)){ 
				this.divSearch.form.cboSc.set_index(0);
			}			
			
			//데이터 초기화
			this.divSearch_cboSc_onitemchanged();
			break;
	}	
};



/**
 * 일지등록 팝업 콜백
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	this.dsSearch.setColumn(0, "flagDiary", "");
	this.fnSearch();
};





/**
 * 일지상세 팝업 콜백
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupDtlCallback = function(e, sender){
	this.dsSearch.setColumn(0, "flagDiary", "");
	this.fnSearch();
};






/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
	
};




/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 조회 버튼 클릭
 * 교실내역, 일지목록 조회
 */
this.fnSearch = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	//조회년월 세팅
	this.dsSearch.setColumn(0, "mlsnYmd", (this.fv_nxtAyr + "" + this.dsSearch.getColumn(0, "mm")));
	
	
	//●호출
	this.dsMainDiary.filter("");
	this.dsMainClass.clearData();
	this.dsMainDiary.clearData();
	this.smfSearchService("list")
		// 데이터 검증
		.validateForm(this.divSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){//에러
				return;
			}	
			
			//●조회건수 찍기
			this.sta04_01.set_text(this.dsMainClass.rowcount); 
			this.sta04_01_00.set_text(this.dsMainDiary.rowcount); 		
			

			//●돌봄일지 교실선택 콤보 세팅
			this.dsClassListCbo.clearData();
			
			//1. dsListClass 데이터셋에서 교실명 classArr에 담기
			var classArr = [];
			for(var i=0; i<this.dsMainDiary.rowcount; i++){
				classArr[i] = this.dsMainDiary.getColumn(i, "clsFilt");
			}
			
			var setCh = new Set(classArr); //중복값 제거 
			
			//2. 교실 선택 콤보 세팅
			this.dsClassListCbo.addRow();
			this.dsClassListCbo.setColumn(0, "clsFilt", "전체"); //0번째에는 전체 넣기
			this.dsClassListCbo.setColumn(0, "careDiaryTitlNm", "전체");
			
			var i = 1;			
			for(var clsFilt of setCh){ //교실명 담기
				this.dsClassListCbo.addRow();
				this.dsClassListCbo.setColumn(i, "clsFilt", clsFilt);
				this.dsClassListCbo.setColumn(i, "careDiaryTitlNm", (this.dsMainDiary.getColumn(this.dsMainDiary.findRow("clsFilt", clsFilt), "careDiaryTitlNm") ));
				i++;
			}
			this.cboClas.set_index(0);			
		});		
}




/*
 * "삭제" 버튼(btnDelete)에서 click 이벤트 발생 시 호출.
 * 일지목록 삭제
 */
this.btnDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsMainDiaryDel.clearData();

	//●체크박스 선택 여부 확인
	var arrChk = this.dsMainDiary.extractRows('chk==1');
	if(arrChk == '-1' || arrChk.length < 1){
		//선택된 {0}이(가) 없습니다. {0}을(를) 선택하여 주십시오.
		this.smfAlert('CM013', ['행']);	  
		return;
	}
	
	
	//● 벨리데이션 체크
	var userId = this.smfGetSessionValue("userId"); //접속자 id
	var delMsg = "";
	var ckRow = "";	
	for(var i=0 ; i<arrChk.length ; i++){
	
		//결재 상태값이 [결재코드   1 =상신(진행)  , 4 =완결 ]이  아니면 삭제 못하게 하기
		if(this.dsMainDiary.getColumn(arrChk[i], "atrzStsCd")=="1" || this.dsMainDiary.getColumn(arrChk[i], "atrzStsCd")=="4"){
			this.smfAlert('PA003', ["[" + (arrChk[i]+1) + "행] 결재 진행중 또는 결재완료인 일지는 삭제할 수"], this.fnMessageCallback ); //{0} 없습니다.
			return;
		}
		
		//본인 일지 아니면 안내매세지 찍기
		if(this.dsMainDiary.getColumn(arrChk[i], "wterId") != userId){
			ckRow += (arrChk[i]+1)+"번째 행  ";
			delMsg = "\n본인이 작성하지 않은 일지가 선택되었습니다.\n";
		}		
		
		//삭제할 데이터 담기(필터링 걸려서 안보이는 애들은 삭제 안되게 하려고 데이터셋 따로 만듦)
		this.dsMainDiaryDel.addRow();
		this.dsMainDiaryDel.copyRow(this.dsMainDiaryDel.rowcount-1, this.dsMainDiary, arrChk[i]);
	}
	
	this.dsSearch.setColumn(0, "flagDiary", "D"); //삭제(D), 등록버튼(P) 일 경우 나이스에 보낼 데이터셋 추가하려고 만든 구분자-자바단에서 사용
	
	//● 호출
	this.smfDeleteService("delete")
		.messagePrefix([ ckRow + delMsg +"삭제" ]) //삭제 하시겠습니까?
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.smfAlert('CM201', ['삭제'], this.fnMessageCallback ); // {0} 하였습니다.
			this.dsSearch.setColumn(0, "flagDiary", "");
			this.fnSearch();
		});		
};




/*
 * "등록" 버튼(btnAdd)에서 click 이벤트 발생 시 호출.
 * 일지등록 팝업 호출
 * 1. 팝업 호출 전 일지작성 중복체크
 * 2. 팝업호출
 */
this.btnIssuAply_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	//●벨리데이션 체크	
	var arrChk = this.dsMainClass.extractRows('chk==1');
	if(arrChk == '-1' || arrChk.length < 1){
		//선택된 {0}이(가) 없습니다. {0}을(를) 선택하여 주십시오.
		this.smfAlert('CM013', ['교실내역']);	  
		return;
	}
	
	if(this.dsSearch.getColumn(0, "dairyYmd") > this.smfToday().dateFormat("yyyyMMdd")){
		this.smfAlert('PA064', ["일지는 오늘 날짜까지만 작성할 수"], this.fnMessageCallback ); //{0} 있습니다.
		return;	
	}
	
	
	
	//●체크한  row 복사하기.
	this.dsPopParam.clearData();
	this.dsDiaryCk.clearData();	
	
	for(var i =0; i < arrChk.length; i++){
		this.dsPopParam.addRow();
		this.dsPopParam.copyRow(this.dsPopParam.rowcount-1, this.dsMainClass, arrChk[i]);
	}
	
	this.dsSearch.setColumn(0, "flagDiary", "P"); //삭제(D), 등록버튼(P) 일 경우 나이스에 보낼 데이터셋 추가하려고 만든 구분자-자바단에서 사용
	
	//● 1. 팝업 호출 전 일지작성 중복체크
	this.smfDeleteService("executeDiaryCk")
		//메세지 안찍기
		.showConfirm(false)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			var str = "";
		  	var str2 = "";
		  	var str3 = "";			

			for(var i=0 ; i<this.dsDiaryCk.rowcount; i++){
				if(this.dsDiaryCk.getColumn(i, "diarycnt") > 0){
					str = str + this.dsDiaryCk.getColumn(i, "eccScCodeNm")+":"+this.dsDiaryCk.getColumn(i, "eccNm")+",";
				}
				if(this.dsDiaryCk.getColumn(i, "cnt") == 0){
					str2 = str2 + this.dsDiaryCk.getColumn(i, "eccScCodeNm")+":"+this.dsDiaryCk.getColumn(i, "eccNm")+",";
				}
				if(this.dsDiaryCk.getColumn(i, "atendcnt") == 0){
					str3 = str3 + this.dsDiaryCk.getColumn(i, "eccScCodeNm")+":"+this.dsDiaryCk.getColumn(i, "eccNm")+",";
				}
			}
			
			if(str2.length > 0){
				str2 = str2.substring(0, (str2.length -1));
				this.smfAlert('PA057', [str2 +" 는(은)\n돌봄 기간이 아닙니",""], this.fnMessageCallback ); //{0}다. {1}
				return false;
			}
				   
				   
			if(str3.length > 0){
				str3 = str3.substring(0, (str3.length -1));
				this.smfAlert('PA058', [str3 +" 는(은)\n출석 정보가 없습니다.\n[초등돌봄 > 돌봄운영관리 > 출결관리] 화면에서\n출석 정보를 먼저 입력"], this.fnMessageCallback ); //{0}해주세요.
				return false;
			}
				   
				   
			if(str.length > 0){
				str = str.substring(0, (str.length -1));
				this.smfAlert('PA058', [str+" 는(은)\n이미 작성한 일지가 존재합니다.\n우측의 [일지목록]을 확인"], this.fnMessageCallback ); //{0}해주세요.
				return false;
			}else{
				//2. 팝업호출
				this.fnDoPop();
			}					
		});			
};








/*
 * 일괄생성 (일괄생성 버튼 클릭)
 */
this.btnPrdAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//●필수값 체크
	var dairyYmdS = this.dsSearch.getColumn(0, "dairyYmdS");
	var dairyYmdE = this.dsSearch.getColumn(0, "dairyYmdE");
	
	if(this.smfIsNull(dairyYmdS)){
		this.smfAlert('CM006', ["일괄생성 시작일"], this.fnMessageCallback ); //{0}은(는) 필수 입력입니다.
		return;	
	}
	if(this.smfIsNull(dairyYmdE)){
		this.smfAlert('CM006', ["일괄생성 종료일"], this.fnMessageCallback ); //{0}은(는) 필수 입력입니다.
		return;	
	}
	
	if(dairyYmdS > dairyYmdE){
		this.smfAlert('PA062', ["시작일자가 종료일자보다 "], this.fnMessageCallback ); //{0}큽니다.
		return;	
	}
	
	
	//●체크박스 선택 여부 확인
	var arrChk = this.dsMainClass.extractRows('chk==1');
	if(arrChk == '-1' || arrChk.length < 1){
		//선택된 {0}이(가) 없습니다. {0}을(를) 선택하여 주십시오.
		this.smfAlert('CM013', ['교실내역']);	  
		return;
	}	
	
	
	//자바단에서 나이스에 보낼 데이터셋 추가하기 위한 구분자 세팅
	this.dsSearch.setColumn(0, "flagDiary", "BND");
	this.dsSearch.setColumn(0, "wterNm", this.smfGetSessionValue("userNm")); //작성자명 세팅
	this.dsSearch.setColumn(0, "wterId", this.dsSearch.getColumn(0, "userId")); //작성자Id 세팅
	
	
	//●일괄등록 호출
	this.smfSaveService("save")
		.messagePrefix(["일괄생성"]) //{} 하시겠습니까?
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.dsSearch.setColumn(0, "flagDiary", "");//구분자 초기화
			
			//일괄생성 리턴값(나이스에서 BusinessException 발생한경우 메세지 찍어줄 값 넘어옴. 발생 안했으면 ok 넘어옴)
			if(!this.smfIsNull(this.dsRsMsg.getColumn(0, "rsMsg"))){
				var rsMsg = this.dsRsMsg.getColumn(0, "rsMsg");
				if(rsMsg != "ok"){
					this.smfAlert('PA057', [ rsMsg, "" ], this.fnMessageCallback ); //{0}다.{1}
					this.fnSearch();
				}else{
					this.fnSearch();
				}
			}
		});		
	
	
};






/*
 * 일지등록 팝업 호출 (등록버튼 클릭)
 */
this.fnDoPop = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//●팝업에 보낼 데이터 세팅
	var popupParams = {
							callback: this.fnPopupCallback
						  , sender	: obj // sender 지정
						  , params	: {
											dsPopParam : this.dsPopParam
										  , dsSearch   : this.dsSearch		
										  , eccSemNm   : this.divSearch.form.cboSem.text //돌봄학기명
										  , procType   : "search"
									  } 
					   };		
		
	//●팝업호출
	this.smfDialog("_auto", "pa_ecc_eec_om::ecc_eecom04_p01.xfdl", popupParams, null ,null, 1120, 900);	//팝업이 너무 커서 사이즈 넣기. 안넣으면 스크롤 안생기고 아랫부분 짤림
};



/*
 * 일지목록 그리드에서 돌봄교실 클릭시
 * 일지상세 팝업 호출
 */
this.grdDiary_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{	
	if(this.grdDiary.getBindCellIndex("body", "careDiaryTitlNm") == e.col){
		//●팝업에 보낼 데이터 세팅
		this.dsMainDiaryPopParam.copyRow(0, this.dsMainDiary, this.dsMainDiary.rowposition);
		var popupParams = {
								callback: this.fnPopupDtlCallback
							  , sender	: obj // sender 지정
							  , params	: {
												dsSearch   : this.dsSearch		
											  , dsListDiaryPopParam  : this.dsMainDiaryPopParam
											  , procType   : "search"
										  } 
						   };		
			
		//●팝업호출
		this.smfDialog("_auto", "pa_ecc_eec_om::ecc_eecom04_p04.xfdl", popupParams, null ,null, 1120, 900);	//팝업이 너무 커서 사이즈 넣기. 안넣으면 스크롤 안생기고 아랫부분 짤림
	}
};
 
 
 
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 /**
 * 학년도 콤보 변경시 -
 * [돌봄학기 콤보 세팅]
 * @param : N/A
 * @return : N/A
 */
this.divSearch_cboAyr_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.eccComboSet("selectEccSem", this.dsSearch, this.dsEccSem, this.fnMessageCallback, "2");
};



 /**
 * 돌봄학기 콤보 변경시 -
 * [돌봄구분 콤보 세팅]
 * @param : N/A
 * @return : N/A
 */
this.divSearch_cboSem_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.eccComboSet("selectEccScCd", this.dsSearch, this.dsEccScCd, this.fnMessageCallback, "3");
};



 /**
 * 돌봄구분 콤보 변경시 
 * @param : N/A
 * @return : N/A
 */
this.divSearch_cboSc_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.divSearch_cboClr00_onitemchanged();
};




/**
 * @description 조회월 변경시
*/
this.divSearch_cboClr00_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	//그리드 초기화
	this.dsMainClass.clearData();
	this.dsMainDiary.clearData();
	
	
	//조회월이 01월 02월 일 경우 조회할때 조회년월 파라미터를 차년도로 설정
	this.fnNxtAyr();
	

	//일괄생성일 세팅 - 1일~현재날짜	
	this.dsSearch.setColumn(0, "dairyYmdS", this.fv_nxtAyr +""+ this.dsSearch.getColumn(0, "mm")+"01");
	this.dsSearch.setColumn(0, "dairyYmdE", this.fv_nxtAyr +""+this.dsSearch.getColumn(0, "mm")+this.smfToday().dateFormat("dd"));
	
	
	//일지등록일 일자 세팅 : 조회년월을 현재 월로 설정하였으면 오늘일자 세팅, 다른 월을 설정하였으면 01일로 세팅
	var ayrMm = this.fv_nxtAyr + "" + this.dsSearch.getColumn(0, "mm"); //년월
	if(ayrMm == this.smfToday().dateFormat("yyyyMM")){
		this.dsSearch.setColumn(0, "dairyYmd", this.smfToday().dateFormat("yyyyMMdd"));		
	}else{
		this.dsSearch.setColumn(0, "dairyYmd", ayrMm + "" + "01"); 
	}	
};



/*
 * 조회월이 01월 02월 일 경우 조회할때 조회년월 파라미터를 차년도로 설정
 */
this.fnNxtAyr = function()
{
	if(this.dsSearch.getColumn(0, "mm") > 02){
		this.fv_nxtAyr = this.dsSearch.getColumn(0, "ayr");
		
	}else{
		this.fv_nxtAyr = nexacro.toNumber(this.dsSearch.getColumn(0, "ayr"))+1;
	}	
};


/**
 * @description 교실내역, 일지목록 그리드 체크박스 헤드 클릭
*/
this.grd_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	//체크박스 전체 선택 
	this.smfSetGridCheckAll(obj, e, function (ds, nRow){
		var a = ds;
	});			
};


/**
 * @description 일지목록 교실선택 콤보 변경시
*/
this.cboClas_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	var clsFilt = this.cboClas.value;
	
	if(clsFilt == "전체"){
		this.dsMainDiary.filter("");
		
	}else{
		this.dsMainDiary.filter("clsFilt == " + clsFilt);
	}	
	
	//조회건수 찍기
	this.sta04_01_00.set_text(this.dsMainDiary.rowcount); 	
};
]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">list</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsMainClass=dsMainClass dsMainDiary=dsMainDiary</Col>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">R</Col>
            <Col id="bindingControls"/>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
            <Col id="url">/ecc_eec_om04_001.do</Col>
          </Row>
          <Row>
            <Col id="id">delete</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsMainClass=dsMainClass:U dsMainDiary=dsMainDiaryDel</Col>
            <Col id="url">/ecc_eec_om04_002.do</Col>
          </Row>
          <Row>
            <Col id="id">executeDiaryCk</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsPopParam=dsPopParam</Col>
            <Col id="outDatasets">dsDiaryCk=dsList</Col>
            <Col id="url">/ecc_eec_om04_003.do</Col>
          </Row>
          <Row>
            <Col id="id">save</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsMainClass=dsMainClass:U</Col>
            <Col id="url">/ecc_eec_om04_008.do</Col>
            <Col id="outDatasets">dsRsMsg=dsRsMsg</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="shlCd" type="STRING" size="256" description="학교코드-세션instCd"/>
          <Column id="ayr" type="STRING" size="256" description="학년도"/>
          <Column id="eccSem" type="STRING" size="256" description="돌봄학기"/>
          <Column id="eccScCd" type="STRING" size="256" description="돌봄구분"/>
          <Column id="clrSeqNo" type="STRING" size="256" description="교실순서번호"/>
          <Column id="mlsnYmd" type="STRING" size="256" description="조회년월"/>
          <Column id="dairyYmd" type="STRING" size="256" description="일지 등록일(교실내역 그리드에서 등록버튼 옆)"/>
          <Column id="mm" type="STRING" size="256" description="조회월"/>
          <Column id="flagDiary" type="STRING" size="256" description="삭제, 등록버튼일 경우 나이스에 보낼 데이터셋 추가하려고 만든 구분자-자바단에서 사용"/>
          <Column id="dairyYmdS" type="STRING" size="256" description="일괄생성 시작일"/>
          <Column id="dairyYmdE" type="STRING" size="256" description="일괄생성 종료일"/>
          <Column id="wterNm" type="STRING" size="256" description="작성자명"/>
          <Column id="wterId" type="STRING" size="256" description="작성자id"/>
          <Column id="userId" type="STRING" size="256" description="사용자id"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsMainValid" useclientlayout="true">
        <ColumnInfo>
          <Column id="messageId" type="STRING" size="256" prop="NONE"/>
          <Column id="messageType" type="STRING" size="256"/>
          <Column id="messageCn" type="STRING" size="256"/>
          <Column id="businessCode" type="STRING" size="256" prop="NONE"/>
          <Column id="useYn" type="STRING" size="256" prop="NONE"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="messageId"/>
            <Col id="messageType">title:메시지타입,required,minlength:2,maxlength:100</Col>
            <Col id="messageCn">title:메시지내용,required,minlength:2,maxlength:100</Col>
            <Col id="businessCode">title:메세지코드,required</Col>
            <Col id="useYn">title:사용여부,required</Col>
          </Row>
          <Row>
            <Col id="messageId">title:메세지아이디,required</Col>
            <Col id="messageType">=</Col>
