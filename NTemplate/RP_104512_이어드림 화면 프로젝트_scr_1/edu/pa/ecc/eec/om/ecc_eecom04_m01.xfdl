        <Static id="sta05" taborder="22" top="234" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" initvalueid="ivStcAccessibilityOff" left="530" bottom="0"/>
