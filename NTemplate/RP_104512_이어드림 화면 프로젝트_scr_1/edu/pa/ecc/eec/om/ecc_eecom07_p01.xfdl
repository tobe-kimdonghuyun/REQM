    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">list</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsListMlsnRegPopCk=dsListMlsnRegPopCk dsMain=dsList dsPfdList=dsPfdList</Col>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp"/>
            <Col id="bindingControls"/>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
            <Col id="url">/ecc_eec_om07_003.do</Col>
          </Row>
          <Row>
            <Col id="id">save</Col>
            <Col id="inDatasets">dsSearch=dsSearch  dsList=dsMain:U</Col>
            <Col id="url">/ecc_eec_om07_004.do</Col>
          </Row>
          <Row>
            <Col id="id">delete</Col>
            <Col id="url">/ecc_eec_om07_004.do</Col>
            <Col id="inDatasets">dsSearch=dsSearch  dsList=dsMain:U</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="shlCd" type="STRING" size="256" sumtext="" description="학교코드-세션instCd"/>
          <Column id="ayr" type="STRING" size="256" sumtext="" description="학년도"/>
          <Column id="eccSem" type="STRING" size="256" sumtext="" description="돌봄학기"/>
          <Column id="eccScCd" type="STRING" size="256" sumtext="" description="돌봄구분"/>
          <Column id="clrSeqNo" type="STRING" size="256" sumtext="" description="교실순서번호"/>
          <Column id="mlsnYmd" type="STRING" size="256" sumtext="" description="년월"/>
          <Column id="pfdCllnDt" type="STRING" size="256" sumtext="" description="채취일"/>
          <Column id="pfdDscdDt" type="STRING" size="256" sumtext="" description="폐기일"/>
          <Column id="pfdEtcCn" type="STRING" size="256" sumtext="" description="비고(특이사항)"/>
          <Column id="pfdCn" type="STRING" size="256" sumtext="" description="식단명(보존식내용)"/>
          <Column id="pfdSn" type="STRING" size="256" sumtext="" description="보존식일련번호"/>
          <Column id="flag" type="STRING" size="256" sumtext="" description="flag 자바단에서 update인지 insert인지 구분하는거"/>
          <Column id="inserMlsnYmd" type="STRING" size="256" sumtext="" description="년월-부모창에서 등록버튼 클릭해서 들어왔을때 처음에 보여주기용."/>
          <Column id="flagPfd" type="STRING" size="256" description="자바단에서 파라미터 가져오는대 사용할 flag"/>
          <Column id="modified" type="STRING" size="256" description="급간식내역 테이블 저장할지 말지 체크하는 변수"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsPageInfo">
        <ColumnInfo>
          <Column id="pageIndex" type="INT" size="256"/>
          <Column id="pageSize" type="INT" size="256"/>
          <Column id="totalCount" type="INT" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true" oncolumnchanged="dsMain_oncolumnchanged">
        <ColumnInfo>
          <Column id="shlCd" type="STRING" size="256" sumtext="" description="학교코드"/>
          <Column id="ayr" type="STRING" size="256" sumtext="" description="학년도"/>
          <Column id="eccSem" type="STRING" size="256" sumtext="" description="초등돌봄교실학기"/>
          <Column id="eccScCd" type="STRING" size="256" sumtext="" description="초등돌봄교실구분코드"/>
          <Column id="clrSeqNo" type="STRING" size="256" sumtext="" description="교실순서번호"/>
          <Column id="mlsnYmd" type="STRING" size="256" sumtext="" description="급간식일자"/>
          <Column id="mlsnSeqNo" type="STRING" size="256" sumtext="" description="급간식순서번호"/>
          <Column id="mlsnNm" type="STRING" size="256" sumtext="" description="급간식명"/>
          <Column id="mlsnUtp" type="STRING" size="256" sumtext="" description="급간식단가"/>
          <Column id="comyNm" type="STRING" size="256" sumtext="" description="업체명"/>
          <Column id="mdfrId" type="STRING" size="256" sumtext="" description="수정자ID"/>
          <Column id="mdfcnDt" type="STRING" size="256" sumtext="" description="수정일시"/>
          <Column id="sts" type="STRING" size="256" description="나이스 자바단에서 if문 타기 위한 변수(소스를 새로 안만들고 기존 소스 재활용 하기위해 이짓햇즘)"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsPfdList" useclientlayout="true">
        <ColumnInfo>
          <Column id="pfdSn" type="STRING" size="256" sumtext="" description="순번(보존식일련번호)"/>
          <Column id="pfdCn" type="STRING" size="256" sumtext="" description="식단명(보존식내용)"/>
          <Column id="pfdCllnDt" type="STRING" size="256" sumtext="" description="보존식채취일시"/>
          <Column id="pfdDscdDt" type="STRING" size="256" sumtext="" description="보존식폐기일시"/>
          <Column id="pfdCllnId" type="STRING" size="256" sumtext="" description="보존식채취ID"/>
          <Column id="pfdEtcCn" type="STRING" size="256" sumtext="" description="보존식기타내용"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsListMlsnRegPopCk" useclientlayout="true">
        <ColumnInfo>
          <Column id="shlCd" type="STRING" size="256" sumtext="" description="학교코드"/>
          <Column id="ayr" type="STRING" size="256" sumtext="" description="학년도"/>
          <Column id="eccSem" type="STRING" size="256" sumtext="" description="초등돌봄교실학기"/>
          <Column id="careDiaryYmd" type="STRING" size="256" sumtext="" description="돌봄일지일자"/>
          <Column id="careDiarySeqNo" type="STRING" size="256" sumtext="" description="돌봄일지순서번호"/>
          <Column id="eccScCd" type="STRING" size="256" sumtext="" description="초등돌봄교실구분코드"/>
          <Column id="clrSeqNo" type="STRING" size="256" sumtext="" description="교실순서번호"/>
          <Column id="mlsnOprtnScCd" type="STRING" size="256" sumtext="" description="급간식실시구분코드"/>
          <Column id="mdfrId" type="STRING" size="256" sumtext="" description="수정자ID"/>
          <Column id="mdfcnDt" type="STRING" size="256" sumtext="" description="수정일시"/>
