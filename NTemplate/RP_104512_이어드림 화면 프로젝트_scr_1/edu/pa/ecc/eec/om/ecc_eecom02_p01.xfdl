<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="ecc_eecom02_p01" width="800" height="550" titletext="급간식등록" onload="fnOnload" nHeight="754">
    <Layouts>
      <Layout height="550" width="800" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divTitle" taborder="1" left="0" top="15" height="54" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="급간식등록" left="20" top="0" height="54" cssclass="img_WF_SubTit01" width="165" initvalueid="ivTitleAccessibilityOn" accessibilitylabel="급간식 등록"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staCn" taborder="4" text="교실정보" left="20" top="134" width="480" height="26" fittocontents="width" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Tit14" accessibilitylabel="교실정보"/>
        <Grid id="grdMain" taborder="8" left="20" top="170" autofittype="col" right="20" binddataset="dsMain" selecttype="cell" initvalueid="ivGrdAccessibilityOn" bottom="70" cellsizingtype="both" autoenter="select" accessibilitylabel="급간식등록 : 순번, 급/간식종류, 단가, 거래처명 정보">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="50"/>
                <Column size="200"/>
                <Column size="80"/>
                <Column size="150"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="순번"/>
                <Cell col="1" text="*급/간식종류" cssclass="cell_WF_Red"/>
                <Cell col="2" text="단가"/>
                <Cell col="3" text="거래처명" cssclass="LineNo"/>
              </Band>
              <Band id="body">
                <Cell text="bind:mlsnSeqNo" textAlign="center"/>
                <Cell col="1" displaytype="editcontrol" edittype="text" text="bind:mlsnNm" wordWrap="char" editautoselect="true" editmaxlength="100"/>
                <Cell col="2" textAlign="right" displaytype="maskeditcontrol" edittype="mask" text="bind:mlsnUtp" maskeditautoselect="true" maskeditformat="!##,###" editmaxlength="5" maskeditlimitbymask="integer" maskedittype="number"/>
                <Cell col="3" displaytype="editcontrol" edittype="text" text="bind:comyNm" editautoselect="true" editmaxlength="50" cssclass="LineNo"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="sta00" taborder="10" left="20" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta01" taborder="11" left="20" top="64" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta02" taborder="13" left="20" top="160" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta03" taborder="14" left="20" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff" bottom="50"/>
        <Static id="sta06" taborder="17" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta05" taborder="16" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" initvalueid="ivStcAccessibilityOff"/>
        <Button id="btnClose" taborder="9" text="닫기" left="375" fittocontents="width" cssclass="btn_WF_Custom" initvalueid="ivBtnAccessibilityButton" height="30" onclick="btnClose_onclick" bottom="20" width="50" accessibilitylabel="닫기"/>
        <Button id="btnSave" taborder="2" text="저장" width="50" fittocontents="width" initvalueid="ivBtnAccessibilityButton" height="30" onclick="btnSave_onclick" top="94" right="73" accessibilitylabel="저장"/>
        <Static id="sta04" taborder="15" left="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" height="20" initvalueid="ivStcAccessibilityOff" bottom="0"/>
        <Static id="sta02_00" taborder="12" left="20" top="124" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Button id="btnDelete" taborder="3" text="삭제" top="94" height="30" cssclass="btn_WF_Crud" width="50" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="삭제" right="20" onclick="fnDelete"/>
        <Static id="staSum00" taborder="7" text="원" top="134" width="15" height="26" fittocontents="width" right="30" textAlign="right" initvalueid="ivStcAccessibilityOn" accessibilitylabel="원"/>
        <MaskEdit id="staSum" taborder="6" top="134" width="130" height="26" right="45" format="999,999,990" readonly="true" enable="false" initvalueid="ivMskReadOnly" accessibilitylabel="액 수"/>
        <Static id="staSum00_00" taborder="5" text="총 액  : " top="134" width="100" height="26" fittocontents="width" initvalueid="ivStcAccessibilityOn" right="177" textAlign="right" accessibilitylabel="총액"/>
        <Static id="staCn00" taborder="18" left="20" height="26" fittocontents="width" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Tit14" width="650" top="98" text="                                                                                                                          " color="#cc0000"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  급간식등록
*  @MenuPath    초등돌봄교실 급간식메뉴관리 > 그리드의 날짜 클릭 > 급간식등록 팝업
*  @FileName 	ecc_eecom02_p01.xfdl 
*  @Creator 	이혜진
*  @CreateDate 	2022.10.04
*  @Desction    초등돌봄교실(돌봄인력서비스) 급간식등록
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.10.04            이혜진                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::ecc_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/


/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);

	//부모창에서 넘어온 값 받기
	var initValue = this.smfGetPopupParams();
	this.dsSearch.copyData(initValue.dsSearch);
	this.dsSearch.setColumn(0, "mlsnYmd", initValue.date);


	//팝업 상단 타이틀 세팅
	this.staCn00.set_text("");
	var titleDate = initValue.date; //날짜
	var paramWeek = initValue.week; //요일
	var titleWeek = "";
	switch(paramWeek){
		case "dfkMon" : titleWeek = "월요일";
			break;

		case "dfkTue" : titleWeek = "화요일";
			break;

		case "dfkWed" : titleWeek = "수요일";
			break;

		case "dfkThu" : titleWeek = "목요일";
			break;
			
		case "dfkFri" : titleWeek = "금요일";
			break;
	}
	 
	var titleEccSem = initValue.eccSem; //학기명  
	var titleEccScNm = initValue.eccScNm; //돌봄구분 
	var titleEccNm = initValue.eccNm; //교실명 
	
	this.staCn.set_text(titleDate.substr(0, 4) +"년 " + titleDate.substr(4, 2) + "월 " + titleDate.substr(6, 2) + "일 " + titleWeek + " (" + titleEccSem + " - "+ titleEccScNm + " - " +  titleEccNm + ")");
	this.resetScroll();
	
	
	//조회
	this.fnSearch(); 
};


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};




/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 조회 버튼 클릭
 * 1. 일지 등록여부 - 있으면 수정, 삭제 안되게 막기용  dsListDirYnCk
 * 2. 보존식등록여부 조회 - 있으면 수정, 삭제 안되게 막기용 dsListPfdYnCk
 * 3. 급식 등록내역 조회  dsMain
 */
 this.fnSearch = function()
{
	this.dsListDirYnCk.clearData();
	this.dsListPfdYnCk.clearData();
	this.dsMain.clearData();
	
	//●조회
	this.smfSearchService("list")
		// 실행
		.run()
		// ●콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){//에러
				return;
			}else{//성공
				this.staCn00.set_text("");
				//●조회된 값이 5개 미만이면 입력하는 row 5개 세팅하기
				var rowCount = this.dsMain.rowcount; //조회해온 row 개수						
				
				//신규 row에 세팅 할 파라미터
				var shlCd = this.dsSearch.getColumn(0, "shlCd"); 		//학교
				var ayr = this.dsSearch.getColumn(0, "ayr"); 			//학년도
				var eccSem = this.dsSearch.getColumn(0, "eccSem");		//돌봄학기
				var eccScCd = this.dsSearch.getColumn(0, "eccScCd");	//교실구분
				var clrSeqNo = this.dsSearch.getColumn(0, "clrSeqNo"); 	//교실순번			
				var mlsnYmd = this.dsSearch.getColumn(0, "mlsnYmd");	//날짜			
				
				
				//세팅
				this.dsMain.set_enableevent(false); //속도향상을 위해 이벤트 꺼놓기
				this.dsMain.set_updatecontrol(false);
				if(rowCount < 5){
					for(var i=rowCount ; i<5 ; i++ ){
						this.dsMain.insertRow(i); //신규 row 추가
						var nRow = this.dsMain.rowcount -1 ; //신규 row index
						this.dsMain.setColumn(nRow, "shlCd", shlCd);
						this.dsMain.setColumn(nRow, "ayr", ayr);
						this.dsMain.setColumn(nRow, "eccSem", eccSem);
						this.dsMain.setColumn(nRow, "eccScCd", eccScCd);
						this.dsMain.setColumn(nRow, "clrSeqNo", clrSeqNo);
						this.dsMain.setColumn(nRow, "mlsnYmd", mlsnYmd);
						this.dsMain.setColumn(nRow, "mlsnSeqNo", nRow+1);
						this.dsMain.setColumn(nRow, "mlsnNm", ""); //급간식 명
						this.dsMain.setColumn(nRow, "mlsnUtp", ""); //급간식 단가
						this.dsMain.setColumn(nRow, "comyNm", ""); //거래처명
					}//for문 끝
				}//세팅 if문 끝			
				this.dsMain.set_enableevent(true);
				this.dsMain.set_updatecontrol(true);
			
				//●수정 가능여부 체크
				if(this.dsListPfdYnCk.rowcount > 0 ){
					this.staCn00.set_text("[보존식관리]화면에 등록되어 있어 급간식 내역을 수정할 수 없습니다 (보존식관리 화면에서는 수정 가능)");
					this.btnSave.set_enable(false);		//저장버튼 비활성화
					this.btnDelete.set_enable(false);	//삭제버튼 비활성화	
		
				}else if(this.dsListDirYnCk.rowcount > 0 && this.smfGetPopupParams().diaryDetailPop != "Y" ){ //diaryDetailPop = 일지상세화면에서 들어왔는지 여부. 일지상세화면에서 들어온건 수정할 수 있음
					this.staCn00.set_text("일지가 있는 날은 급간식 내역을 수정할 수 없습니다 (일지관리 화면에서는 수정 가능)");
					this.btnSave.set_enable(false);		//저장버튼 비활성화
					this.btnDelete.set_enable(false);	//삭제버튼 비활성화	
					
				}else{
					this.btnSave.set_enable(true);		//저장버튼 활성화
					this.btnDelete.set_enable(true);	//삭제버튼 활성화			
				}			
			
			
				//●단가 총액 세팅
				this.getSum(); 
				
			}//성공콜백 끝
		});
}


/**
 * 저장 버튼 클릭
 */
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.grdMain.updateToDataset();
	//●급간식명 없이 단가, 거래처명 입력했을 경우 빠꾸
	var mlsnCnt = 0; //입력된 급간식내역 개수
	this.dsMain.set_enableevent(false); //속도향상을 위해 꺼놓기
	this.dsMain.set_updatecontrol(false);	
	for(var i= 0 ; i<this.dsMain.rowcount ; i++ ){	 
		if(this.smfIsNull(this.dsMain.getColumn(i, "mlsnNm"))){
			if( (!this.smfIsNull(this.dsMain.getColumn(i, "mlsnUtp")) && nexacro.toNumber(this.dsMain.getColumn(i, "mlsnUtp")) > 0) || !this.smfIsNull(this.dsMain.getColumn(i, "comyNm")) ){
				this.smfAlert('PA003', ["("+ (i+1) + "번째 행)\n급/간식종류 없이\n단가, 거래처명을 입력 할 수"], this.fnMessageCallback ); //{0} 없습니다.
				return;					
			}
			mlsnCnt++; 
		}	
		//●나이스에서 쿼리 태울 구분자 세팅
		this.dsMain.setColumn(i, "sts", "i");
	}//for문 끝
	this.dsMain.set_enableevent(true); //속도향상을 위해 꺼놓기
	this.dsMain.set_updatecontrol(true);	
	

	//●입력된 급간식이 하나도 없으면 빠꾸	
	if(mlsnCnt==5){
		this.smfAlert('PA058', ["급간식 내역이 존재하지 않습니다.\n급간식 내역을 입력"], this.fnMessageCallback ); //{0}해주세요.
		return;
	}	
	
	//●나이스에서 쿼리 태울 구분자 세팅
	this.dsSearch.setColumn(0, "flag", "P"); 


	//●저장
	this.smfSaveService("save")
		// 데이터 변경 여부 체크
		.requireModifredData(this.dsMain)
		//{}하시겠습니까?
		.messagePrefix(["저장"])
		// 실행
		.run()
		// ●콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.smfAlert('CM201', ['저장'], this.fnMessageCallback ); // 저장 하였습니다.
			this.fnClosePopup(); //팝업창 닫기
		});	
};


/**
 * 삭제 버튼 클릭
 */
this.fnDelete = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//급간식 내역이 하나도 없으면 빠꾸 - 조회할때 무조건 5줄 만드는것 때문에 rowcount로 체크 안돼서 for문으로 체크
	var mlsnCnt = 0; //입력된 급간식 내역 개수
	for(var i= 0 ; i<this.dsMain.rowcount ; i++ ){	 
		if(this.smfIsNull(this.dsMain.getColumn(i, "mlsnNm"))){
			mlsnCnt++;
		}			
	}
	if(mlsnCnt==5){
		this.smfAlert('PA003', ["삭제할 내역이"], this.fnMessageCallback ); //{0} 없습니다.
		return;
	}	
	
	
	
	//나이스에서 쿼리 태울 구분자
	this.dsSearch.setColumn(0, "flag", "D");
	
 	// 서비스 객체 생성
	this.smfDeleteService("delete")
		.messagePrefix(["삭제"]) //{} 하시겠습니까?
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.smfAlert('CM201', ['삭제'], this.fnMessageCallback ); // {0} 하였습니다.
			this.fnClosePopup();
		});		
};



/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
* 부모 화면의 팝업 콜백 호출
* @param  : N/A
* @return : N/A
*/
this.fnClosePopup = function()
{
	this.smfSendResponseToOpener();
	
	this.close(true);
}



/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 그리드 단가 변경시 
 * 단가 총액 세팅
 */
this.dsMain_oncolumnchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	if(e.columnid == "mlsnUtp"){
		this.getSum();
	}
}



/**
 * 단가 총액 세팅
 */
this.getSum = function()
{
	var sum = 0;
	this.dsMain.set_enableevent(false); //속도향상을 위해 꺼놓기
	this.dsMain.set_updatecontrol(false);
	for(var i=0 ; i<this.dsMain.rowcount; i++){
		sum += nexacro.toNumber(this.nvl(this.dsMain.getColumn(i, "mlsnUtp") ,0));
	}
	this.dsMain.set_enableevent(true);
	this.dsMain.set_updatecontrol(true);		
	this.staSum.set_value(sum);
	this.resetScroll(); //이걸 써야 text 적용된다 왜그렇게 한거냐
};



/**
 * 닫기버튼
 */
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false); //팝업창 닫기
};]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
