  <Form id="ecc_eecmi02_p02" width="800" height="804" titletext="개인정보 수집동의" onload="frmTemp01_onload">
    <Layouts>
      <Layout height="804" width="800" screenid="ScreenDeskTop">
        <ImageViewer id="imgTitle00" taborder="0" text="개인정보의 수집·이용 동의서" left="20" top="16" width="410" height="30" initvalueid="ivTitleAccessibilityOn" cssclass="img_WF_SubTit04" accessibilitylabel="개인정보의 수집·이용 동의서"/>
        <Static id="staContent00_00" taborder="2" text="[개인정보의 수집․이용 목적]" left="20" top="117" width="295" height="20" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_InfoTit01" accessibilitylabel="개인정보의 수집.이용 목적"/>
        <Static id="staContent00_02" taborder="3" left="20" top="137" cssclass="sta_WF_Black14" text="초등돌봄교실 운영지원은 아래와 같은 목적으로 개인정보를 수집·이용합니다.&#13;&#10;1. 나이스 업무지원 초등돌봄교실 지원서비스 홈페이지 사용자 등록 및 정보관리&#13;&#10;  - 초등돌봄교실 인력 본인등록 및 소득 관리용&#13;&#10;  - 초등돌봄교실 인력 활동확인서 발급용" wordWrap="char" right="20" initvalueid="ivStcAccessibilityOn" onclick="div00_sta00_00_01_01_onclick" height="85" accessibilitylabel="초등돌봄교실 운영지원은 아래와 같은 목적으로 개인정보를 수집·이용합니다. 첫번째. 나이스 업무지원 초등돌봄교실 지원서비스 홈페이지 사용자 등록 및 정보관리. - 초등돌봄교실 인력 본인등록 및 소득 관리용. - 초등돌봄교실 인력 활동확인서 발급용"/>
        <Static id="staGd02_00_00" taborder="22" left="20" top="222" height="15" cssclass="sta_GD_Size" text="15" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" right="20"/>
        <Static id="staContent00" taborder="4" text="[수집하는 개인정보의 항목]" left="20" top="237" width="295" height="20" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_InfoTit01" accessibilitylabel="수집하는 개인정보의 항목"/>
        <Static id="staContent00_03" taborder="5" left="20" top="257" cssclass="sta_WF_Black14" text="초등돌봄교실 운영지원은 아래와 같이 개인정보를 수집하고 있습니다.&#13;&#10;1. 성명, 은행명, 계좌번호," wordWrap="char" right="20" initvalueid="ivStcAccessibilityOn" height="49" accessibilitylabel="초등돌봄교실 운영지원은 아래와 같이 개인정보를 수집하고 있습니다. 첫번째. 성명, 은행명, 계좌번호, 주민등록번호"/>
        <Static id="staGd07" taborder="23" left="20" top="306" height="15" cssclass="sta_GD_Size" text="15" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" right="20"/>
        <Static id="staContent00_00_00" taborder="7" text="[고유식별정보(주민등록번호) 수집 근거]" left="20" top="321" width="295" height="20" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_InfoTit01" accessibilitylabel="고유식별정보(주민등록번호) 수집 근거"/>
        <Static id="staContent00_04" taborder="8" left="20" top="341" cssclass="sta_WF_Black14" text="초등돌봄교실 운영지원은 아래 법률에 의거하여 고유식별정보(주민등록번호)의 경우 소득관리를 위한 목적으로 수집․이용할 수 있습니다.&#13;&#10;1. 소득세법 제21조(기타소득)&#13;&#10;2. 소득세법 제166조(주민등록 전산정보자료 등의 이용)" wordWrap="char" right="20" initvalueid="ivStcAccessibilityOn" onclick="div00_sta00_00_01_01_onclick" height="91" accessibilitylabel="초등돌봄교실 운영지원은 아래 법률에 의거하여 고유식별정보(주민등록번호)의 경우 소득관리를 위한 목적으로 수집.이용할 수 있습니다. 첫번째. 소득세법 제21조(기타소득). 두번째. 소득세법 제166조(주민등록 전산정보자료 등의 이용)"/>
        <Static id="staGd07_01" taborder="24" left="20" top="432" height="15" cssclass="sta_GD_Size" text="15" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" right="20"/>
        <Static id="staContent01" taborder="9" text="[개인정보의 처리 및 보유기간]" left="20" top="447" width="295" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn" accessibilitylabel="개인정보의 처리 및 보유기간"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_01" taborder="17" left="20" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_01_00_00_00" taborder="18" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_01_00_00_00_00" taborder="19" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staContent00_00_00_00_00" taborder="14" text="개인정보의 수집 및 이용목적에 동의하십니까?&#9;" left="20" top="714" height="20" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_InfoTit01" right="20" accessibilitylabel="개인정보의 수집 및 이용목적에 동의하십니까?"/>
        <Static id="staGd07_01_00" taborder="25" left="20" top="614" height="15" cssclass="sta_GD_Size" text="15" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" right="20"/>
        <Static id="staContent00_00_00_00" taborder="12" text="[개인정보 수집․이용에 대한 동의를 거부할 권리]" left="20" top="629" height="20" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_InfoTit01" right="20" accessibilitylabel="개인정보 수집.이용에 대한 동의를 거부할 권리"/>
        <Static id="staContent00_04_02" taborder="13" left="20" top="649" cssclass="sta_WF_Black14" text="귀하가 초등돌봄교실 운영지원에 해당의 정보를 제공하기 원하지 않을 경우 귀하는 고유식별정보를 포함한 개인정보의 수집․이용에 대한 동의를 거부할 수 있으며, 동의 거부시에는 초등돌봄교실 운영지원 이용이 제한됩니다." wordWrap="char" right="20" initvalueid="ivStcAccessibilityOn" onclick="div00_sta00_00_01_01_onclick" height="50" accessibilitylabel="귀하가 초등돌봄교실 운영지원에 해당의 정보를 제공하기 원하지 않을 경우 귀하는 고유식별정보를 포함한 개인정보의 수집.이용에 대한 동의를 거부할 수 있으며, 동의 거부시에는 초등돌봄교실 운영지원 이용이 제한됩니다."/>
        <Static id="staGd07_00_00" taborder="26" left="20" top="699" height="15" cssclass="sta_GD_Size" text="15" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" right="20"/>
        <Static id="Static99_00_00_00_00_01_00_00_01_00_01_00_00" taborder="27" left="20" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff" top="734"/>
        <Static id="Static99_00_00_00_00_01_00_00_01_00_01_00_01" taborder="28" left="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff" height="20" bottom="0"/>
        <Static id="staGd01" taborder="20" left="20" top="42" height="15" cssclass="sta_GD_Size" text="15" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" right="20"/>
        <Button id="btnAgree" taborder="15" text="동의" width="70" height="30" initvalueid="ivBtnAccessibilityButton" onclick="btnAgree_onclick" bottom="20" right="402" accessibilitylabel="동의"/>
        <Button id="btnClose" taborder="16" text="동의안함" right="329" width="70" initvalueid="ivBtnAccessibilityButton" cssclass="btn_WF_Custom" onclick="btnClose_onclick" height="30" bottom="20" accessibilitylabel="동의안함"/>
        <Static id="staContent00_01" taborder="1" left="20" top="57" cssclass="sta_WF_Black14" text="초등돌봄교실 운영지원은 다음과 같은 이유로 귀하의 개인정보를 수집․이용합니다. 아래의 개인정보 수집·이용에 대한 내용을 자세히 읽어 보신 후 동의 여부를 결정하여 주시기 바랍니다." wordWrap="char" right="20" initvalueid="ivStcAccessibilityOn" onclick="div00_sta00_00_01_01_onclick" height="45" accessibilitylabel="초등돌봄교실 운영지원은 다음과 같은 이유로 귀하의 개인정보를 수집 이용합니다. 아래의 개인정보 수집·이용에 대한 내용을 자세히 읽어 보신 후 동의 여부를 결정하여 주시기 바랍니다."/>
        <Static id="staGd07_00" taborder="21" left="20" top="102" height="15" cssclass="sta_GD_Size" text="15" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" right="20"/>
        <ImageViewer id="imgTitle00_00" taborder="10" text="초등돌봄교실 운영지원은 귀하의 경력인정을 위하여 해당 내역을 준영구기간동안 보유합니다.&#13;&#10;단, 귀하의 개인정보는 원칙적으로 개인정보의 수집 및 이용목적이 달성되거나, &#13;&#10;귀하가 초등돌봄교실 지원서비스에서 기본정보를 삭제할 경우 즉시 파기됩니다." left="20" top="467" height="80" initvalueid="ivTitleAccessibilityOn" cssclass="img_WF_SubTit04" right="20" accessibilitylabel="초등돌봄교실 운영지원은 귀하의 경력인정을 위하여 해당 내역을 준 영구기간동안 보유합니다. 단, 귀하의 개인정보는 원칙적으로 개인정보의 수집 및 이용목적이 달성되거나, 귀하가 초등돌봄교실 지원서비스에서 기본정보를 삭제할 경우 즉시 파기됩니다."/>
        <Static id="staContent00_04_01" taborder="11" left="20" top="552" cssclass="sta_WF_Black14" text="그리고 다음의 사유에 해당하는 경우에 해당 사유 종료시까지 개인정보를 처리·보유합니다.&#13;&#10;1) 관계 법령 위반에 따른 수사·조사 등이 진행중인 경우에는 해당 수사·조사 종료시까지&#13;&#10;2) 홈페이지 이용에 따른 채권·채무관계 잔존시에는 해당 채권·채무관계 정산시까지" wordWrap="char" right="20" initvalueid="ivStcAccessibilityOn" onclick="div00_sta00_00_01_01_onclick" height="62" accessibilitylabel="그리고 다음의 사유에 해당하는 경우에 해당 사유 종료시까지 개인정보를 처리·보유합니다. 첫번째. 관계 법령 위반에 따른 수사·조사 등이 진행중인 경우에는 해당 수사·조사 종료시까지. 두번째. 홈페이지 이용에 따른 채권·채무관계 잔존시에는 해당 채권·채무관계 정산시까지"/>
        <ImageViewer id="imgTitle00_00_00" taborder="6" text="주민등록번호" left="179" top="276" height="31" initvalueid="ivTitleAccessibilityOn" cssclass="img_WF_SubTit04" right="451"/>
      </Layout>
