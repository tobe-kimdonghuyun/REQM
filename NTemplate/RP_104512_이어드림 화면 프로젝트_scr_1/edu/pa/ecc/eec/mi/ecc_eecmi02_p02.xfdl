    <Script type="xscript5.1"><![CDATA[/**
*  개인정보 수집동의
*  @MenuPath    초등돌봄교실 > 내정보관리 > 본인인증 버튼 > 개인정보 수집동의
*  @FileName 	ecc_eecmi02_p02.xfdl 
*  @Creator 	이혜진
*  @CreateDate 	2022.07.25
*  @Desction    초등돌봄교실(돌봄인력서비스) 내정보관리 > 개인정보 수집동의
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.07.25            이혜진                   최초 생성 
*******************************************************************************
*/ 

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/


/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/



/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
/*
 * 화면 load
 */
this.frmTemp01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
};



/*
 * 동의 버튼
 * 문자인증 팝업호출
 */
this.btnAgree_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSendResponseToOpener({
		"data": "Y"
	});
	this.close(true);	
};



/*
 * 동의 안함 버튼
 * 팝업 닫기
 */
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSendResponseToOpener({
		"data": "N"
	});
	this.close(true);	
};
]]></Script>
  </Form>
</FDL>
