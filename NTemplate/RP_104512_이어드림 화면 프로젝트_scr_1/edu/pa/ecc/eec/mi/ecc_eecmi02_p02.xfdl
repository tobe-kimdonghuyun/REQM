          <Column id="applpRrno" type="STRING" size="256" description="" sumtext="주민번호"/>
          <Column id="applpBrdt" type="STRING" size="256" description="" sumtext="생년월일 YYYYMMDD"/>
          <Column id="userDtcNo" type="STRING" size="256" description="" sumtext="사용자CI"/>
        </ColumnInfo>
