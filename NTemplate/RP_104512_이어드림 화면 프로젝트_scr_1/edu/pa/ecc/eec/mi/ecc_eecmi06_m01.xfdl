<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="ecc_eecmi06_m01" width="1280" height="745" titletext="첨부파일연계테스트" onload="fnOnload">
    <Layouts>
      <Layout height="745" width="1280" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="70" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="첨부파일테스트" left="0" top="0" height="44" cssclass="img_WF_SubTit01" width="229" initvalueid="ivTitleAccessibilityOn" accessibilitylabel="첨부파일테스트"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divBaseInfo" taborder="1" left="0" top="189" height="42" cssclass="div_WF_Detail" right="0">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="2" left="0" cssclass="sta_WF_Input02" top="0" right="0" initvalueid="ivStcAccessibilityOff" bottom="0"/>
              <Static id="staNm" taborder="0" left="0" width="189" height="42" cssclass="sta_WF_Essential" text="*학교코드" top="0" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn" accessibilitylabel="학교코드"/>
              <Edit id="edtNm" taborder="1" left="193" top="6" height="30" text="우리날" width="396" initvalueid="ivEdtEssential" cssclass="essential" autoselect="true" accessibilitylabel="학교코드 입력"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divAddInfo" taborder="2" left="0" height="42" top="336" text="" cssclass="div_WF_Detail" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="1" left="0" height="42" cssclass="sta_WF_Input02" top="0" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staBankNm" taborder="0" left="0" width="189" height="42" cssclass="sta_WF_Essential" text="*파일명" top="0" initvalueid="ivStcAccessibilityOn" accessibilitylabel="파일명"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnSave" taborder="3" text="첨부파일다운" top="408" height="40" width="120" right="0" onclick="btnSave_onclick" accessibilitylabel="첨부파일다운"/>
        <Edit id="edtNm" taborder="4" left="193" top="342" height="30" text="우리날" width="396" initvalueid="ivEdtEssential" cssclass="essential" autoselect="true" accessibilitylabel="파일 첨부"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  첨부파일테스트
*  @MenuPath    초등돌봄교실 > 첨부파일테스트
*  @FileName 	ecc_eecmi06_m01.xfdl 
*  @Creator 	이혜진
*  @CreateDate 	2023.01.05 
*  @Desction    초등돌봄교실(돌봄인력서비스) 첨부파일테스트
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.01.05            이혜진                   최초 생성 
*******************************************************************************
*/

this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);	
};


this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSaveService("save")

		// 실행
		.run()
		
		.callback(function(callbackParams){
			if(callbackParams.errors) return;

			this.smfAlert('완료');
		});	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
		
	switch(svcid) {	
		case "save" : 
			//오류메시지 확인용 
			if ( errcd == -100 ) {
				this.smfAlert("errcd : "+errcd);
				this.alert(errmsg);
			}
			break;
	}
};]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">save</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets"/>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">S</Col>
            <Col id="bindingControls"/>
            <Col id="url">/ecc_cmn_cm99_111.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="s" type="STRING" size="256"/>
          <Column id="f" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="divBaseInfo.form.edtNm" propid="value" datasetid="dsSearch" columnid="s"/>
      <BindItem id="item1" compid="edtNm" propid="value" datasetid="dsSearch" columnid="f"/>
    </Bind>
  </Form>
</FDL>
