      <Layout height="777" width="1280" screenid="ScreenDeskTop">
        <Static id="sta00" taborder="4" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Div id="divTitle" taborder="0" left="0" top="sta00:0" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="신청관리" left="0" top="0" height="44" cssclass="img_WF_SubTit01" width="137" initvalueid="ivTitleAccessibilityOn" accessibilitylabel="신청관리"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta01" taborder="5" left="0" top="divTitle:0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Div id="divSearch" taborder="1" left="0" top="sta01:0" height="70" cssclass="div_WF_Search" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staHnfTyp" taborder="0" text="돌봄인력유형" left="0" top="20" width="113" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" accessibilitylabel="돌봄인력유형"/>
              <Combo id="cboHnfTyp" taborder="1" left="staHnfTyp:0" width="160" height="30" innerdataset="dsEccHnfTypCd" codecolumn="unyCdValue" datacolumn="unyCdValueNm" index="-1" text="" readonly="false" top="20" value="ALL" initvalueid="ivCmbNormal" accessibilitylabel="돌봄인력유형 구분"/>
              <Static id="staAprvSts" taborder="2" text="승인상태" left="cboHnfTyp:0" top="20" width="85" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" accessibilitylabel="승인상태"/>
              <Combo id="cboAprvSts" taborder="3" left="staAprvSts:0" width="124" height="30" innerdataset="dsEccHnfStsScCd" codecolumn="unyCdValue" datacolumn="unyCdValueNm" index="-1" text="전체" readonly="false" top="20" value="ALL" initvalueid="ivCmbNormal" accessibilitylabel="승인상태 구분"/>
              <Button id="btnSearch" taborder="4" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="20" initvalueid="ivBtnAccessibilityButton" onclick="divSearch_btnSearch_onclick" accessibilitylabel="조회"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta02" taborder="6" left="0" top="divSearch:0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Grid id="grdMain" taborder="2" left="0" top="sta02:0" autofittype="col" right="0" binddataset="dsMain" selecttype="cell" initvalueid="ivGrdAccessibilityOn" oncellclick="grdMain_oncellclick" height="439" accessibilitylabel="신청관리 : 순번, 전담여부, 학교명, 학교소재지, 돌봄인력유형, 승인상태, 재직상태, 신청취소 등 정보">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="40"/>
                <Column size="40"/>
                <Column size="140"/>
                <Column size="200"/>
                <Column size="100"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="40" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="순번"/>
                <Cell col="1" text="전담여부"/>
                <Cell col="2" text="학교명"/>
                <Cell col="3" text="학교소재지"/>
                <Cell col="4" text="돌봄인력유형"/>
                <Cell col="5" text="승인상태" cssclass="LineNo"/>
                <Cell col="6" text="재직상태"/>
                <Cell col="7" text="신청취소"/>
              </Band>
              <Band id="body">
                <Cell displaytype="text" textAlign="center" text="expr:currow +1"/>
                <Cell col="1" displaytype="imagecontrol" text="expr:eccHffcScCd =='01' &amp;&amp;  eccHnfTypCd =='01' &amp;&amp; eccHnfStsScCd =='02' ? (  ecshgYn == 'Y' ? &quot;theme://images/rdo_WF_ItemS.png&quot; : &quot;theme://images/rdo_WF_Item.png&quot; ) :&quot;&quot;"/>
                <Cell col="2" textAlign="center" text="bind:shlNm"/>
                <Cell col="3" calendardateformat="yyyy-MM-dd " textAlign="center" text="bind:zoneCdNm"/>
                <Cell col="4" textAlign="center" text="bind:eccHnfTypNm"/>
                <Cell col="5" cssclass="LineNo" textAlign="center" text="bind:eccHnfStsScNm"/>
                <Cell col="6" textAlign="center" text="bind:eccHffcScCdNm"/>
                <Cell col="7" textAlign="center" displaytype="expr:eccHnfStsScCd == '01' ? 'buttoncontrol' : 'nomal'" edittype="expr:eccHnfStsScCd == '01' ? 'button' : 'nomal'" text="expr:eccHnfStsScCd == '01' ? '신청취소'  : ''"/>
