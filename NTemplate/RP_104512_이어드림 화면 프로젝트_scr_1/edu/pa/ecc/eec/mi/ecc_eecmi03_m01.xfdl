        <Static id="sta03" taborder="7" left="0" top="grdMain:0" cssclass="sta_GD_Size" text="32" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" height="32"/>
        <Button id="btnAply" taborder="3" text="신청하기" width="120" cssclass="btn_WF_ActionLine" initvalueid="ivBtnAccessibilityButton" height="40" top="grdMain:32" left="45.31%" onclick="btnAply_onclick" accessibilitylabel="신청하기"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  신청관리
*  @MenuPath    초등돌봄교실 > 신청관리
*  @FileName 	ecc_eecmi03_m01.xfdl 
*  @Creator 	김민성
*  @CreateDate 	2022.07.25
*  @Desction    초등돌봄교실(돌봄인력서비스) 신청관리
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.07.25            김민성                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::ecc_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_param;
this.fv_cddcCd;
this.fv_userId;
this.fv_cntnCtpvScCd;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	// 파라메터 세팅
	this.fv_param = this.smfGetFormParams();
	console.log(this.dsSearch.saveXML());
	       
	// 공통코드의 코드구분
	this.smfCodeList("code", [this.dsEccHnfTypCd, this.dsEccHnfStsScCd])
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			console.log(this.dsEccHnfTypCd.saveXML());
			console.log(this.dsEccHnfStsScCd.saveXML());
		})
	;
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
			
	switch(svcid) {	
		//================
		//  상세정보 저장
		//================
		case "code" : 
			//오류메시지 확인용 
			if ( errcd == -100 ) {
				this.smfAlert("errcd : "+errcd);
				this.alert(errmsg);
			}
			
			//세션정보 조회 및 셋팅(주민번호)
			this.eccfSetHnfInfo("selectHnfInfoForSession", this.dsSearch, ""); 
			
			break;			
			
		case "selectHnfInfoForSession" : 
			//오류메시지 확인용 
			if ( errcd == -100 ) {
				this.smfAlert("errcd : "+errcd);
				this.alert(errmsg);
			}
			this.divSearch.form.cboHnfTyp.set_index(0);
			this.divSearch.form.cboAprvSts.set_index(0);
			
			this.fnSearch();
			break;		
	}
	
		
		
			
};

/**
 * 팝업의 콜백함수
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	//console.log('22222222222222222222222222');
	this.fnSearch();
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 조회 서비스
 * @param : N/A
 * @return : N/A
 */
this.fnSearch = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("listAply") //조회
		// 데이터 검증
		.validateForm(this.divSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			console.log(this.dsMain.saveXML());
		});
};

/**
 * 신청취소 서비스
 * @param : N/A
 * @return : N/A
 */
this.fnAplyRtrcn = function()
{
 	// 서비스 객체 생성
	this.smfDeleteService("deleteAplyRtrcn")
		.messagePrefix(["신청취소"])
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.smfAlert('CM201', ['신청취소'], this.fnMessageCallback ); // {0} 하였습니다.
			this.fnSearch();
		});
};

/**
 * 전담여부처리 서비스
 * @param : N/A
 * @return : N/A
 */
this.fnEcshgYn = function()
{
		// 서비스 객체 생성
		this.smfSaveService("saveEcshgYn")
			// 실행
			.run()
			// 콜백
			.callback(function(callbackParams){
				if(callbackParams.errors) return;
				this.smfAlert('CM201', ['저장'], this.fnMessageCallback ); // {0} 하였습니다.
				
				//최초로 전담사 저장될때 화면 메뉴 다 보이게하기
				if(this.smfIsNull(this.dsSearch.getColumn(0, "shlCd"))){
					var menuForm = this.parent.parent.parent.parent.divTop.form;
					menuForm.dsMenu.copyData(menuForm.dsMenuCopy);				
				}
				//세션정보 셋팅
				this.eccfSetHnfInfo("selectHnfInfoForSession", this.dsSearch, ""); 	
			});
		
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
* 조회버튼
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
*/
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearch();
};

/**
* 신청하기 버튼
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
*/
this.btnAply_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//주민번호 없으면 빠꾸
	if(this.isNil(this.dsSearch.getColumn(0, "hnfRrno"))){
		this.smfAlert('PA058', ['주민등록번호가 없습니다.\n관리자에게 문의'], this.fnMessageCallback ); //{0}해주세요.
		return;
	}

	var strProcType = "";
	
	if(obj == this.btnAply){ // 등록버튼클릭
		strProcType = "insert";
	}
	
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: this.fnPopupCallback,
		sender: obj, // sender 지정

		params: {
			// 처리타입 지정
			cddcCd : this.dsSearch.getColumn(0,"cddcCd")
		   ,shlCd : ""
		   ,userId : this.dsSearch.getColumn(0,"userId")
		   ,cntnCtpvScCd : this.dsSearch.getColumn(0,"cntnCtpvScCd")
		   ,hnfRrno : this.dsSearch.getColumn(0,"hnfRrno") 
		   ,procType : strProcType
		},
	};

	this.smfDialog("_auto", "pa_ecc_eec_mi::ecc_eecmi04_p01.xfdl", popupParams);		
};

/**
* 그리드 셀 클릭
* @param  : obj		   - [object]Grid
* @param  : e		   - [string]GridClickEventInfo
* @return : N/A
*/
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if(e.col == 7){ //신청취소
		var eccHnfStsScCd=this.dsMain.getColumn(e.row, "eccHnfStsScCd");	
		if(eccHnfStsScCd =="01"){
			//this.dsMain.setColumn(e.row, "chk", 1);			
			//클릭한 row를 복사
			this.dsMainSend.clearData();			
			this.dsMainSend.addRow();
			this.dsMainSend.copyRow(0, this.dsMain, e.row);
			this.dsMainSend.setColumn(0, "cntnCtpvScCd", this.dsSearch.getColumn(0, "cntnCtpvScCd")); //접속시도코드
			this.dsMainSend.setColumn(0, "eccHnfStsScCd", "04"); //인력상태구분코드 - 신청취소(04)
			console.log(this.dsMainSend.saveXML());
						
			this.fnAplyRtrcn();
		}
	}else if(e.col ==1){ //전담여부선택
		var ecshgYn = this.dsMain.getColumn(e.row, "ecshgYn");
		var eccHnfTypCd = this.dsMain.getColumn(e.row, "eccHnfTypCd"); //초등돌봄교실인력유형 : 전담사 - 01, 보조인력 -02, 외부강사 -03, 기타 -04 
		var eccHnfStsScCd = this.dsMain.getColumn(e.row, "eccHnfStsScCd"); //초등돌봄교실인력상태구분코드 : 신청 -01, 승인-02, 반려-03, 신청취소-04
		var eccHffcScCd = this.dsMain.getColumn(e.row, "eccHffcScCd"); //초등돌봄교실재직구분코드 : 재직 -01, 퇴직-02, 전보-03
		if(eccHnfTypCd !="01" || eccHnfStsScCd !="02" || eccHffcScCd !="01"){
			return;
		}	

		//선택한 row를 복사
		this.dsMainSend.clearData();		
		this.dsMainSend.addRow();
		this.dsMainSend.copyRow(0, this.dsMain, e.row);
		console.log(this.dsMainSend.saveXML());
		
		this.fnEcshgYn();
	}
};]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listAply</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsPageInfo=dsPageInfo</Col>
            <Col id="outDatasets">dsMain=dsMain</Col>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">R</Col>
            <Col id="bindingControls"/>
            <Col id="url">/ecc_eec_mi03_001.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
          <Row>
            <Col id="id">deleteAplyRtrcn</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsMain=dsMainSend</Col>
            <Col id="outDatasets">dsMain=dsMain</Col>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">S</Col>
            <Col id="bindingControls"/>
            <Col id="url">/ecc_eec_mi03_002.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
          <Row>
            <Col id="id">saveEcshgYn</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsMain=dsMainSend</Col>
            <Col id="outDatasets">dsMain=dsMain</Col>
            <Col id="url">/ecc_eec_mi03_003.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="svctp">S</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="userId" type="STRING" size="256"/>
          <Column id="eccHnfTypCd" type="STRING" size="256"/>
          <Column id="eccHnfStsScCd" type="STRING" size="256"/>
          <Column id="cntnCtpvScCd" type="STRING" size="256" description="접속시도코드"/>
          <Column id="hnfRrno" type="STRING" size="256" description="주민등록번호"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="userId"/>
            <Col id="cddcCd"/>
            <Col id="eccHnfTypCd"/>
            <Col id="eccHnfStsScCd"/>
            <Col id="cntnCtpvScCd"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsMainValid" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcCd" type="string" size="256"/>
          <Column id="shlCd" type="string" size="256"/>
          <Column id="shlNm" type="string" size="256"/>
          <Column id="userId" type="string" size="256"/>
          <Column id="careHnfAplySeqNo" type="string" size="256"/>
          <Column id="eccHnfStsScCd" type="string" size="256"/>
          <Column id="eccHnfStsScNm" type="string" size="256"/>
          <Column id="hnfTypCd" type="string" size="256"/>
          <Column id="hnfTypNm" type="string" size="256"/>
          <Column id="eccHnfIdfNo" type="string" size="256"/>
