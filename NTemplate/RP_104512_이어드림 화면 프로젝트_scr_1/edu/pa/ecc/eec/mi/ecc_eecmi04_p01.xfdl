<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="ecc_eccmi04_p01" width="800" height="570" titletext="돌봄인력 신청" onload="fnOnload">
    <Layouts>
      <Layout height="570" width="800" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divTitle" taborder="1" left="20" top="15" height="54" text="" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="돌봄인력 신청" left="0" top="0" height="54" cssclass="img_WF_SubTit01" width="200" initvalueid="ivTitleAccessibilityOn" accessibilitylabel="돌봄인력 신청"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divSearch" taborder="2" left="20" top="94" height="70" cssclass="div_WF_Search" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staShlNm" taborder="0" text="*학교명" left="0" top="20" width="75" height="30" cssclass="sta_WF_Essential01" initvalueid="ivStcEssential" accessibilitylabel="학교명"/>
              <Button id="btnSearch" taborder="1" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="20" onclick="divSearch_btnSearch_onclick" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="조회"/>
              <Edit id="edtShlNm" taborder="2" left="75" top="20" width="250" height="30" initvalueid="ivEdtEssential" text="이화여자대학교사범대학부속초등학교" cssclass="essential" maxlength="50" autoselect="true" onkeydown="divSearch_edtShlNm_onkeydown" accessibilitylabel="학교명 입력"/>
            </Layout>
          </Layouts>
        </Div>
        <Grid id="grdMain" taborder="3" left="20" top="184" autofittype="col" right="20" binddataset="dsMain" selecttype="cell" initvalueid="ivGrdAccessibilityOn" bottom="70" oncellclick="grdMain_oncellclick" autoenter="select" accessibilitylabel="돌봄인력 신청: 순번, 학교명, 학교소재지, 돌봄인력유형, 신청 등 정보">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="40"/>
                <Column size="140"/>
                <Column size="200"/>
                <Column size="100"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="순번"/>
                <Cell col="1" text="학교명"/>
                <Cell col="2" text="학교소재지"/>
                <Cell col="3" text="*돌봄인력유형" cssclass="sta_WF_Searchtxt01" color="#d10053"/>
                <Cell col="4" text="신청" cssclass="LineNo"/>
              </Band>
              <Band id="body">
                <Cell textAlign="center" text="expr:currow +1"/>
                <Cell col="1" textAlign="left" text="bind:shlNm"/>
                <Cell col="2" calendardateformat="yyyy-MM-dd " textAlign="left" text="bind:zoneCdNm"/>
                <Cell col="3" textAlign="center" displaytype="combocontrol" edittype="combo" combodataset="dsEccHnfTypCd" combodatacol="unyCdValueNm" combocodecol="unyCdValue" text="bind:eccHnfTypCd"/>
                <Cell col="4" textAlign="center" displaytype="buttoncontrol" edittype="button" text="신청하기" cssclass="LineNo"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="btnClose" taborder="4" text="닫기" height="30" width="50" left="46.75%" fittocontents="width" initvalueid="ivBtnAccessibilityButton" cssclass="btn_pop_normal" onclick="btnClose_onclick" top="520" accessibilitylabel="닫기"/>
        <Static id="sta00" taborder="5" left="20" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta01" taborder="6" left="20" top="64" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta02" taborder="7" left="20" top="164" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta03" taborder="8" left="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" height="20" initvalueid="ivStcAccessibilityOff" top="500"/>
        <Static id="sta04" taborder="9" left="20" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff" top="550"/>
        <Static id="sta05" taborder="10" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta06" taborder="11" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  돌봄인력 신청
*  @MenuPath    초등돌봄교실 > 돌봄인력 신청
*  @FileName 	ecc_eecmi04_p01.xfdl 
*  @Creator 	김민성
*  @CreateDate 	2022.07.27
*  @Desction    초등돌봄교실(돌봄인력서비스) 내정보관리
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.07.27            김민성                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_param;
this.fv_popupParam;
this.fv_cddcCd;
this.fv_userId;
this.fv_cntnCtpvScCd;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	
	// 파라메터 세팅
	this.fv_param = this.smfGetFormParams();
	this.fv_popupParam = this.smfGetPopupParams();
	
	console.log(this.fv_popupParam);
	
	this.fv_cddcCd = this.fv_popupParam.cddcCd;
	this.fv_cntnCtpvScCd  =this.fv_popupParam.cntnCtpvScCd;
	this.fv_userId = this.fv_popupParam.userId;
	
	this.dsSearch.setColumn(0, "cddcCd", this.fv_cddcCd);
	this.dsSearch.setColumn(0, "userId", this.fv_userId);
	this.dsSearch.setColumn(0, "cntnCtpvScCd", this.fv_cntnCtpvScCd);
	this.dsSearch.setColumn(0, "hnfRrno", this.fv_popupParam.hnfRrno);
	
	
	this.smfValidateService("validateMain", {
			url: "/ecc_eec_mi04_000.do",
		})
		.mappingRulesetToForm(this.divSearch, "search") 
		.mappingRulesetToDataset(this.dsMainValid, "insert")
		.run()
		.callback(function(callbackParams){
		})
	;
	
	// 공통코드의 코드구분
	this.smfCodeList("code", [this.dsEccHnfTypCd])
		.run()
		.callback(function(callbackParams){
			this.dsEccHnfTypCd.setColumn(0,"unyCdValueNm","- 선택 -");
			this.dsEccHnfTypCd.setColumn(0,"unyCdValue","");
			if(callbackParams.errors) return;
			console.log(this.dsEccHnfTypCd.saveXML());
		})
	;
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 팝업의 콜백함수
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	this.fnSearch();
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
}
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 조회 서비스
 * @param : N/A
 * @return : N/A
 */
this.fnSearch = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("select")
		// 데이터 검증
		.validateForm(this.divSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			console.log(this.dsMain.saveXML());
		});
};

/**
 * 신청 서비스
 * @param : N/A
 * @return : N/A
 */
this.fnAply = function()
{
	console.log(this.dsMainSend.saveXML());
 	// 서비스 객체 생성
	this.smfSaveService("insert")
		.messagePrefix(["신청"])
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.smfAlert('CM201', ['신청'], this.fnMessageCallback ); // 신청 하였습니다.
			this.fnClosePopup();
		});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
* 부모 화면의 팝업 콜백 호출
* @param  : N/A
* @return : N/A
*/
this.fnClosePopup = function()
{
	this.smfSendResponseToOpener();
	
	this.close(true);
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
* 조회버튼
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
*/
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearch();
};

/**
* 그리드 셀 클릭 - 신청하기
* @param  : obj		   - [object]Grid
* @param  : e		   - [string]GridClickEventInfo
* @return : N/A
*/
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if(e.col == 4){ 
		//1. 돌봄인력유형 선택여부 체크
		if(this.isNil(this.dsMain.getColumn(e.row, "eccHnfTypCd"))){
			this.smfAlert('CM006', ['돌봄인력유형'], this.fnMessageCallback ); // {0}은(는) 필수 입력입니다.
			return;
		}
	
		//2. 클릭한 row를 복사
		this.dsMainSend.clearData();		
		this.dsMainSend.addRow();
		this.dsMainSend.copyRow(0, this.dsMain, e.row);
		this.dsMainSend.setColumn(0, "userId", this.fv_userId);			
		this.dsMainSend.setColumn(0, "cntnCtpvScCd", this.fv_cntnCtpvScCd);  //접속시도코드
		this.dsMainSend.setColumn(0, "hnfRrno", this.dsSearch.getColumn(0, "hnfRrno"));  //주민번호
		this.dsMainSend.setColumn(0, "userId", this.dsSearch.getColumn(0, "userId"));  //사용자아이디
		
		//3. 신청
		this.fnAply();
	}
};

/**
* 닫기버튼
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
*/
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};

/**
* 학교명 입력란 엔터키
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
*/
this.divSearch_edtShlNm_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode == 13){
		this.fnSearch();
	}
};]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">select</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsMain=dsMain</Col>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">R</Col>
            <Col id="bindingControls"/>
            <Col id="url">/ecc_eec_mi04_001.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
          <Row>
            <Col id="id">insert</Col>
            <Col id="inDatasets">dsMain=dsMainSend dsPageInfo=dsPageInfo</Col>
            <Col id="outDatasets"/>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">R</Col>
            <Col id="bindingControls"/>
            <Col id="url">/ecc_eec_mi04_002.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="kornOrgNm" type="STRING" size="256"/>
          <Column id="userId" type="STRING" size="256" description="사용자아이디"/>
          <Column id="cntnCtpvScCd" type="STRING" size="256" description="접속시도코드"/>
          <Column id="hnfRrno" type="STRING" size="256" description="주민등록번호"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsMainValid" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcCd" type="string" size="256"/>
          <Column id="shlCd" type="string" size="256"/>
          <Column id="shlNm" type="string" size="256"/>
          <Column id="eccHnfTypCd" type="string" size="256"/>
          <Column id="hnfTypNm" type="string" size="256"/>
          <Column id="chk" type="int" size="1"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsPageInfo">
        <ColumnInfo>
          <Column id="pageIndex" type="INT" size="256"/>
          <Column id="pageSize" type="INT" size="256"/>
          <Column id="totalCount" type="INT" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true">
        <ColumnInfo>
          <Column id="userId" type="STRING" size="256"/>
          <Column id="shlCd" type="STRING" size="256" sumtext="학교코드"/>
          <Column id="cddcCd" type="STRING" size="256" sumtext="시도교육청코드"/>
          <Column id="cddcOrgCdNm" type="STRING" size="256" sumtext="시도교육청조직명"/>
          <Column id="shlNm" type="STRING" size="256" sumtext="학교명"/>
          <Column id="shlKndScCd" type="STRING" size="256" sumtext="학교종류구분코드"/>
          <Column id="shlKndScCdNm" type="STRING" size="256" sumtext="학교종류구분코드명"/>
          <Column id="zoneCd" type="STRING" size="256" sumtext="구역코드"/>
          <Column id="zoneCdNm" type="STRING" size="256" sumtext="구역코드명"/>
          <Column id="eccHnfTypCd" type="STRING" size="256" sumtext="인력유형코드"/>
          <Column id="chk" type="INT" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsMainSend" useclientlayout="true">
        <ColumnInfo>
          <Column id="shlCd" type="STRING" size="256" sumtext="학교코드"/>
          <Column id="cddcCd" type="STRING" size="256" sumtext="시도교육청코드"/>
          <Column id="cddcOrgCdNm" type="STRING" size="256" sumtext="시도교육청조직명"/>
          <Column id="shlNm" type="STRING" size="256" sumtext="학교명"/>
          <Column id="shlKndScCd" type="STRING" size="256" sumtext="학교종류구분코드"/>
          <Column id="shlKndScCdNm" type="STRING" size="256" sumtext="학교종류구분코드명"/>
          <Column id="zoneCd" type="STRING" size="256" sumtext="구역코드"/>
          <Column id="zoneCdNm" type="STRING" size="256" sumtext="구역코드명"/>
          <Column id="eccHnfTypCd" type="STRING" size="256" sumtext="인력유형코드"/>
          <Column id="chk" type="INT" size="256"/>
          <Column id="cntnCtpvScCd" type="STRING" size="256" sumtext="접속시도코드"/>
          <Column id="hnfRrno" type="STRING" size="256" sumtext="주민번호"/>
          <Column id="userId" type="STRING" size="256" sumtext="사용자id"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsEccHnfTypCd" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="FirstCode" type="STRING" size="30" value="ALL" datapath=""/>
          <ConstColumn id="ClfCdValue" type="STRING" size="30" value="ECC_HNF_TYP_CD"/>
          <ConstColumn id="FilterExpr" type="STRING" size="30" value=""/>
          <ConstColumn id="UnyCdGrpId" type="STRING" size="30" value=""/>
          <ConstColumn id="BfrClfCdValue" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd1Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd2Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd3Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd4Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd5Value" type="STRING" size="30" value=""/>
          <Column id="pgeId" type="STRING" size="256"/>
          <Column id="clfCdValue" type="STRING" size="30"/>
          <Column id="clfCdValueNm" type="STRING" size="120"/>
          <Column id="clfCdUseYn" type="STRING" size="150"/>
          <Column id="unyCdValue" type="STRING" size="10"/>
          <Column id="unyCdValueNm" type="STRING" size="30"/>
          <Column id="userDfnCd1Value" type="STRING" size="100"/>
          <Column id="userDfnCd2Value" type="STRING" size="100"/>
          <Column id="userDfnCd3Value" type="STRING" size="100"/>
          <Column id="userDfnCd4Value" type="STRING" size="100"/>
          <Column id="userDfnCd5Value" type="STRING" size="100"/>
        </ColumnInfo>
      </Dataset>
