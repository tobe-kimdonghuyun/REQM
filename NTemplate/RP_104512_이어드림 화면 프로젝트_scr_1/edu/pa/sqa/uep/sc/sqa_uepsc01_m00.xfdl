<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmTemp01" width="1200" height="1340" titletext="안내사항" onload="frmTemp01_onload">
    <Layouts>
      <Layout height="1340" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="65" height="54" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="안내사항" left="0" top="0" height="54" cssclass="img_WF_SubTit01" width="140" initvalueid="ivTitleAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="div00" taborder="1" left="0" height="1203" cssclass="div_WF_InfoBOX" top="137" text="" initvalueid="ivDivAccessibilityOff" right="0" minwidth="1200" maxwidth="">
          <Layouts>
            <Layout>
              <ImageViewer id="imgSTitle01" taborder="0" text="검정고시출신자 대입전형자료 온라인 제공 추진 배경" left="30" top="30" width="410" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_00_01_01_00_01" taborder="1" left="40" top="73" height="23" text="대입원서 접수를 위해 검정고시 합격 및 성적 증명자료를 우편 또는 직접 방문하여 제출하고 있는 검정고시 출신자의 대입전형과정에서의 불편 해소" cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="40"/>
              <Static id="sta00_00_01_01_00_01_00" taborder="2" left="40" top="96" height="23" text="검정고시 출신자가 제출한 대입전형자료(합격 및 성적증명)를 받은 대학이, 해당 자료를 발급한 시도교육청에 재확인하는 업무 부담 경감 및 업무 효율화 도모" cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="40"/>
              <Static id="sta00_00_01_01_00_01_00_00" taborder="3" left="40" top="119" height="23" text="국민권익위원회의 검정고시 출신자 대입전형 간소화 방안 권고(`11.2.11. 및 `13.6.18.) 수용" cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="40"/>
              <ImageViewer id="imgSTitle02" taborder="4" text="검정고시출신자 대입전형자료 온라인 제공 기본방향" left="30" top="172" width="410" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_00_01_01_00_01_01" taborder="5" left="40" top="215" height="23" text="&lt;b v='true'&gt;※ 검정고시 출신 대입 지원자의 대입전형자료(합격 및 성적 증명) 제공을 지원하기 위한 &lt;/b&gt;" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="40"/>
              <Static id="sta00_00_01_01_00_01_00_00_00" taborder="6" left="40" top="238" height="23" text="초·중등교육법 및 동법 시행령 개정" cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="40"/>
              <Static id="sta00_00_01_01_00_01_00_00_00_00" taborder="7" left="40" top="261" height="23" text="나이스(NEIS, 교육행정정보시스템)에 해당 기능 추가 개발을 통한 사용자 편의성 제고" cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="40"/>
              <Static id="sta00_00_01_01_00_01_00_00_00_01" taborder="8" left="40" top="284" height="23" text="검정고시 출신 대입 지원자가 대국민서비스 화면에서 본인의 대입전형자료를 확인하고, 제공 동의를 원하는 자료 선택하여 신청 등 본인 관리 절차 지원을 통해 자료의 신뢰성 확보" cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="40"/>
              <ImageViewer id="imgSTitle03" taborder="9" text="검정고시 합격자의 대입전형자료 온라인 제공 세부사항" left="30" top="337" width="430" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00_00_01_01_00_01_00_00_00_02" taborder="10" left="40" top="380" height="23" text="제공 시기 : 매년 수시 및 정시 대입입학전형 기간" cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="40"/>
              <Static id="sta00_00_01_01_00_01_00_00_00_02_00" taborder="11" left="40" top="403" height="23" text="대상자 : 고졸 검정고시에 합격한 대학입학 지원자" cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="40"/>
              <Static id="sta00_00_01_01_00_01_00_00_00_02_00_00" taborder="12" left="40" top="426" height="23" text="온라인제공 신청기간" cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="40"/>
              <Static id="sta00_00_01_01_00_01_00_00_00_02_00_00_00" taborder="13" left="70" top="449" height="23" text="- 수시전형 신청기간 : 2024. 9. 9.(월) ~ 2024. 12. 12.(목)" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" right="40" onclick="div00_sta00_00_01_01_00_01_00_00_00_02_00_00_00_onclick"/>
              <Static id="sta00_00_01_01_00_01_00_00_00_02_00_00_00_00" taborder="14" left="70" top="472" height="23" text="- 정시전형 신청기간 : 2024. 12. 31.(화) ~ 2025. 2. 28.(금)" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" right="40" onclick="div00_sta00_00_01_01_00_01_00_00_00_02_00_00_00_00_onclick"/>
              <Static id="sta00_00_01_01_00_01_01_00" taborder="15" left="70" top="495" height="23" text="※ 지원 대학의 원서접수 기간 종료 전까지 신청을 완료하여야 함." cssclass="sta_WF_Red14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="40"/>
              <Static id="sta00_00_01_01_00_01_00_00_00_02_00_01" taborder="16" left="40" top="518" height="23" text="제공자료 항목 : 고졸 검정고시 합격증명 및 성적증명 자료" cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="40"/>
              <Static id="sta00_00_01_01_00_01_00_00_00_02_00_01_00" taborder="17" left="40" top="541" height="23" text="제공자료 범위 : 최근 9개년도 자료 (2016년 1회차 ~ 2024년 2회차)" cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="40"/>
              <Static id="sta00_00_01_01_00_01_00_00_00_02_00_00_00_01" taborder="18" left="70" top="568" height="23" text="- 수시전형의 경우 2024년도 1회차 시험까지의 자료만 제공" cssclass="sta_WF_Red14" initvalueid="ivStcAccessibilityOn" right="40"/>
              <Static id="sta00_00_01_01_00_01_01_00_00" taborder="19" left="70" top="591" height="46" text="※ 2024년 2회차 시험 합격자에 대한 학력 조회기간과 수시전형 기간 중복 때문.&#13;&#10;(관련규정-초·중등교육법 시행규칙 39조 8항)" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="40"/>
              <Static id="sta00_00_01_01_00_01_00_00_00_02_00_00_00_01_00" taborder="20" left="70" top="637" height="23" text="- 제공 대상 이외의 합격년도(회차) 자료는 직접 혹은 우편으로 지원 대학에 제출 필요" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" right="40"/>
              <ImageViewer id="imgSTitle04" taborder="21" text="검정고시 출신자 대입전형자료 온라인 제공 서비스 흐름도" left="30" top="690" width="449" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
              <ImageViewer id="img00" taborder="22" left="40" top="740" height="450" image="url('theme://images/img_guide.jpg')" width="700" initvalueid="ivImgAccessibilityOn" accessibilitylabel="대입검정고시 대입전형자료 온라인 제공 서비스 흐름도"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_01" taborder="23" left="30" top="53" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="Static99_00_00_00_00_01_00" taborder="24" left="30" top="142" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="Static99_00_00_00_00_01_01_00_00" taborder="25" left="30" top="307" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="Static99_00_00_00_00_01_01_00_00_00" taborder="26" left="30" top="660" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="Static99_00_00_00_00" taborder="2" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
