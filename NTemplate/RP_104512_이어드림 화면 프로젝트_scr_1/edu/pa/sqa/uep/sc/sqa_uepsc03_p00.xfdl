          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="inDatasets">dsParam=dsParam</Col>
            <Col id="outDatasets">dsBaseFieldMap=dsBaseFieldMap dsSubFieldList1=dsSubFieldList1  dsSubFieldList2=dsSubFieldList2</Col>
            <Col id="asynctp"/>
            <Col id="url">sqa_uep_sc03_002.do</Col>
            <Col id="id">selectDataList</Col>
          </Row>
          <Row>
            <Col id="id">saveData</Col>
            <Col id="inDatasets">dsParam=dsParam</Col>
            <Col id="url">sqa_uep_sc03_003.do</Col>
            <Col id="outDatasets">dsParam=dsParam</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsParam" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="passYr" type="STRING" size="256"/>
          <Column id="passTme" type="STRING" size="256"/>
          <Column id="dataSbmsnSn" type="STRING" size="256"/>
          <Column id="dataSbmsnYn" type="STRING" size="256"/>
          <Column id="dataIdntyYn" type="STRING" size="256"/>
          <Column id="jaeOeYn" type="STRING" size="256"/>
          <Column id="sbmsnYn" type="STRING" size="256"/>
          <Column id="tmpId" type="STRING" size="256"/>
          <Column id="statusNm" type="STRING" size="256"/>
          <Column id="message" type="STRING" size="256"/>
          <Column id="trprRrno" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSubFieldList2" useclientlayout="true">
        <ColumnInfo>
          <Column id="sqeChcEsntlScNm" type="STRING" size="256"/>
          <Column id="sqeSbjtNm" type="STRING" size="256"/>
          <Column id="sbjtScoreNm" type="STRING" size="256"/>
          <Column id="sbjtPassAnnYmd" type="STRING" size="256"/>
          <Column id="evlSmtotScoreNm" type="STRING" size="256"/>
          <Column id="evlAvrgScoreNm" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 대입전형자료제공 - 대입전형자료 확인 및 신청팝업
*  @FileName 	sqa_upesc03_p00.xfdl 
*  @Creator 	박가혜
*  @CreateDate 	2022.08.29
*  @Desction    대입전형자료 확인 및 신청 팝업
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.08.29          박가혜                 최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/




include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.fv_params;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frm01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitPopup(obj)

	this.fv_params = this.smfGetPopupParams();
	this.dsParam.addRow();
	this.fnInit();
	//this.smfResetScroll(obj)
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 화면 초기화
*/
this.fnInit = function(){

	this.divInfoClose.set_visible(false)

	// 파라미터 셋팅
	var passYr 		= this.fv_params.passYr
	var passTme 	= this.fv_params.passTme
	var dataSbmsnSn = this.fv_params.dataSbmsnSn //자료제출일련번호 dtaSbmtSno
	var dataIdntyYn = this.smfIsNull(this.fv_params.dataIdntyYn) ? "N" :  this.fv_params.dataIdntyYn; //제출확인여부 dtaCnfYn
	var dataSbmsnYn = this.smfIsNull(this.fv_params.dataSbmsnYn) ? "N" :  this.fv_params.dataSbmsnYn; //제출확인여부 dtaCnfYn
	var jeaOeYn 	= this.fv_params.jeaOeYn 		//요청제외자료Yn
	var sbmsnYn 	= this.fv_params.sbmsnYn			//자료제출여부 sbmsnYn
	var tmpId 		= this.fv_params.tmpId
	
		// 보여지는 컴포넌트 셋팅

	if(jeaOeYn == "N"){ 	//신청가능 (요청제외자료아님)
		this.chkDtaIdntyYn.set_visible(true)
		this.chkSbmsnYn.set_visible(true)
		this.divInfo.set_visible(true)
		this.divInfoClose.set_visible(false)
		this.btnAdd.set_visible(true)
		
		// 체크박스 셋팅
		this.chkDtaIdntyYn.set_value(dataIdntyYn)
		this.chkSbmsnYn.set_value(dataSbmsnYn);
		
	}else if(jeaOeYn == "Y"){  //신청 못함 (요청제외자료)

		this.chkDtaIdntyYn.set_visible(false)
		this.chkSbmsnYn.set_visible(false)
		this.divInfo.set_visible(false)
		this.divInfoClose.set_visible(true)
		this.divInfoClose.move(20, "chkSbmsnYn:14")
		this.btnAdd.set_visible(false)
	}

// 	if(this.fv_params.sbmsnYn == "Y"){  //확인 및 신청완료
// 		//this.chkDtaIdntyYn.set_enable(false)
// 		//this.chkSbmsnYn.set_enable(false)
// 		this.btnAdd.set_text("신청취소")
// 	}else { //신청취소 & 미신청
// 		//this.chkDtaIdntyYn.set_enable(true)
// 		//this.chkSbmsnYn.set_enable(true)
// 		this.btnAdd.set_text("신청")
// 	}

	
	
	this.fnSearch();

}
/**
 * @description 증명서 조회
*/
this.fnSearch = function(){
	
	this.dsParam.setColumn(0,"passYr",this.fv_params.passYr);
	this.dsParam.setColumn(0,"passTme",this.fv_params.passTme);
	this.dsParam.setColumn(0,"dataSbmsnSn",this.fv_params.dataSbmsnSn);
	this.dsParam.setColumn(0,"dataIdntyYn",this.fv_params.dataIdntyYn);
	this.dsParam.setColumn(0,"jaeOeYn",this.fv_params.jaeOeYn);
	this.dsParam.setColumn(0,"tmpId",this.fv_params.tmpId);
	
	this.dsParam.setColumn(0,"trprRrno",this.fv_params.trprRrno);
	this.dsParam.setColumn(0,"cddcCd",this.smfGetCddcCode());

	// 대입전형자료 조회
	this.smfSearchService("selectDataList")
		
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.fnListCallback();
			this.smfGrdResetHeight(this.Tab00.Tabpage2.form.div00.form.grdList) 
			//this.Tab00.Tabpage2.form.div00.form.staSidoNm01.set_
	});	
}
/**
 * @description 신청
*/
this.fnSave = function(dataIdntyYn, dataSbmsnYn, statusNm){
	this.dsParam.setColumn(0, "dataIdntyYn", dataIdntyYn)
	this.dsParam.setColumn(0, "dataSbmsnYn", dataSbmsnYn)
	this.dsParam.setColumn(0, "statusNm", statusNm)
	
	// 대입전형자료 조회
	this.smfSaveService("saveData")
		.messagePrefix("신청")
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			// 저장이 완료되었습니다.
			this.smfAlert('신청이 완료되었습니다', function(){
				this.smfSendResponseToOpener({
					"resp": "Y"
				});
				
				this.close(true);
			
			})
			 
			
	});	
	
}
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd == -1) return;
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 증명서 문구 세팅
*/
this.fnListCallback = function(){
	var edycNo = "제 " + this.dsBaseFieldMap.getColumn(0,"edycNo") +" 호"
	this.Tab00.Tabpage1.form.div00.form.staEdycNo00.set_text(edycNo)
	this.Tab00.Tabpage2.form.div00.form.staEdycNo01.set_text(edycNo)
	this.Tab00.Tabpage1.form.div00.form.edtEdycNo.set_text(edycNo)
	this.Tab00.Tabpage2.form.div00.form.edtEdycNo01.set_text(edycNo)
	
	this.Tab00.Tabpage1.form.div00.form.staProvd00.set_text("위 사람은 " + this.dsSubFieldList1.getColumn(0,"passAnnYmdNm")+" 고등학교졸업학력검정고시에 전과목 합격하였음을 증명합니다.")
	this.Tab00.Tabpage1.form.div00.form.staSidoNm.set_text(this.setSidoNm());
	this.Tab00.Tabpage2.form.div00.form.staSidoNm01.set_text(this.setSidoNm());
	this.Tab00.Tabpage1.form.div00.form.staToDayNm.set_text(this.parseDate(this.dsBaseFieldMap.getColumn(0,"toDayNm")));
	this.Tab00.Tabpage2.form.div00.form.staToDayNm01.set_text(this.parseDate(this.dsBaseFieldMap.getColumn(0,"toDayNm")));
}
/**
 * @description 시도위원장 명칭 
*/
this.setSidoNm = function(){
	
	var cddcOrgCd = this.dsBaseFieldMap.getColumn(0,"cddcOrgCd")
	var sidoCd = cddcOrgCd.replace("0000001","")
	var sidoNm = "";
	var text =" 검 정 고 시 위 원 회 위 원 장"
	if(sidoCd == "B10"){
			sidoNm = "서 울 특 별 시"+text;

		}else if(sidoCd == "C10"){
			sidoNm = "부 산 광 역 시"+text;

		}else if(sidoCd == "D10"){
			sidoNm = "대 구 광 역 시"+text;

		}else if(sidoCd == "E10"){
			sidoNm = "인 천 광 역 시"+text;

		}else if(sidoCd == "F10"){
			sidoNm = "광 주 광 역 시"+text;

		}else if(sidoCd == "G10"){
			sidoNm = "대 전 광 역 시"+text;

		}else if(sidoCd == "H10"){
			sidoNm = "울 산 광 역 시"+text;

		}else if(sidoCd == "I10"){
			sidoNm = "세 종 특 별 자 치 시"+text;

		}else if(sidoCd == "J10"){
			sidoNm = "경 기 도"+text;

		}else if(sidoCd == "K10"){
			sidoNm = "강 원 특 별 자 치 도"+text;

		}else if(sidoCd == "M10"){
			sidoNm = "충 청 북 도"+text;

		}else if(sidoCd == "N10"){
			sidoNm = "충 청 남 도"+text;

		}else if(sidoCd == "P10"){
			sidoNm = "전 라 북 도"+text;

		}else if(sidoCd == "Q10"){
			sidoNm = "전 라 남 도"+text;

		}else if(sidoCd == "R10"){
			sidoNm = "경 상 북 도"+text;

		}else if(sidoCd == "S10"){
			sidoNm = "경 상 남 도"+text;

		}else if(sidoCd == "T10"){
			sidoNm = "제 주 특 별 자 치 도"+text;
		}
		
		return sidoNm;
}
/**
 * @description 년월일에 한자리 수일때 0 빼기
*/
this.parseDate = function(value){

	if ( value == null || value == "" ) {
			return "";
		}
	var date = value.replaceAll(" ","");
	date = date.replaceAll("년","")
	date = date.replaceAll("월","")
	date = date.replaceAll("일","")

	if(date.length == 8){ // yyyyMMdd
		var tmp = date.substr(0,4) + "년 ";
		tmp += parseInt(date.substr(4,2)) + "월 ";
		tmp += parseInt(date.substr(6,2)) + "일";
		return tmp;
	}else if( date.length == 6 ){ // yyyyMM
		var tmp = date.substr(0,4) + "년 ";
		tmp += parseInt(date.substr(4,2)) + "월 ";
		return tmp;
	}else{
		return value;
	}
}



/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 신청버튼 클릭
*/

this.btnAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
	var dataIdntyYn = "N";
	var dataSbmsnYn = "N";
	var statusNm = "신청";
	
	if(this.chkDtaIdntyYn.value == "Y"){
		dataIdntyYn = "Y";
	}
	if(this.chkSbmsnYn.value == "Y"){
		dataSbmsnYn = "Y";
	}

	//저장인지 취소인지 구분
	if(dataSbmsnYn == "N"){
		statusNm = "신청취소";
	}
	
	//현재 등록취소상태 체크
	var tmpSbmsnYn = this.fv_params.sbmsnYn;
	
	if(dataIdntyYn == dataSbmsnYn){
	//이미 신청중이거나 신청취소일때 같은 작업 반복 못하게 막음
		if((tmpSbmsnYn == "Y" && dataSbmsnYn == "N") || (tmpSbmsnYn == "N" && dataSbmsnYn == "Y")){
			if(statusNm + " 하시겠습니까?"){
				this.fnSave(dataIdntyYn, dataSbmsnYn, statusNm);
			}
		}else if (tmpSbmsnYn == "Y" && dataSbmsnYn == "Y"){
			this.smfAlert("이미 신청완료 상태입니다.")
		}else{
			this.smfAlert("이미 신청취소 상태입니다.")
		}
	}else{
		this.smfAlert("하나만 체크하실 수 없습니다.")
	}
};
/**
 * @description 닫기버튼
*/
this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//닫기 버튼을 이용한 팝업종료의 파라미터는 false를 전달
	this.close(false);
};


]]></Script>
    <Bind>
      <BindItem id="item0" compid="Tab00.Tabpage1.form.div00.form.edtEdycNo" propid="value" datasetid="dsBaseFieldMap" columnid="edycNo"/>
      <BindItem id="item1" compid="Tab00.Tabpage1.form.div00.form.edt00_00_01_00" propid="value" datasetid="dsBaseFieldMap" columnid="kornFlnm"/>
      <BindItem id="item2" compid="Tab00.Tabpage1.form.div00.form.edt00_00_01_00_00" propid="value" datasetid="dsBaseFieldMap" columnid="trprRrno"/>
      <BindItem id="item4" compid="Tab00.Tabpage1.form.div00.form.staSidoNm" propid="text" datasetid="dsBaseFieldMap" columnid="sidoNm"/>
      <BindItem id="item5" compid="Tab00.Tabpage2.form.div00.form.edtEdycNo01" propid="value" datasetid="dsBaseFieldMap" columnid="edycNo"/>
      <BindItem id="item6" compid="Tab00.Tabpage2.form.div00.form.edt00_00_01_00" propid="value" datasetid="dsBaseFieldMap" columnid="kornFlnm"/>
      <BindItem id="item7" compid="Tab00.Tabpage2.form.div00.form.edt00_00_01_00_00" propid="value" datasetid="dsBaseFieldMap" columnid="trprRrno"/>
      <BindItem id="item8" compid="Tab00.Tabpage2.form.div00.form.staSidoNm01" propid="text" datasetid="dsBaseFieldMap" columnid="sidoNm"/>
      <BindItem id="item3" compid="Tab00.Tabpage2.form.div00.form.staToDayNm01" propid="text" datasetid="dsBaseFieldMap" columnid="toDayNm"/>
      <BindItem id="item9" compid="Tab00.Tabpage1.form.div00.form.edt00_00_01_00_00_00" propid="value" datasetid="dsBaseFieldMap" columnid="shlNm"/>
    </Bind>
  </Form>
</FDL>
