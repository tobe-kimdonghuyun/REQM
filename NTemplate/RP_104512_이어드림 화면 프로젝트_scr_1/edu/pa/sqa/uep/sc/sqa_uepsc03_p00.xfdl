                        <Grid id="grdList" taborder="13" left="20" top="387" binddataset="dsSubFieldList2" autofittype="col" initvalueid="ivGrdAccessibilityOn" selecttype="cell" autosizingtype="none" useselcolor="false" readonly="true" scrolltype="both" autosizebandtype="body" extendsizetype="none" width="878" bottom="200" accessibilitylabel="성적">
