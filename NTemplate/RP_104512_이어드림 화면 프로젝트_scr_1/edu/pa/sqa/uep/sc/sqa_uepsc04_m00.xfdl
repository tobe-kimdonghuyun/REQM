<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frm01" width="1200" height="860" titletext="대입전형자료 제출현황 조회" onload="frm01_onload">
    <Layouts>
      <Layout height="860" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="65" height="54" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="대입전형자료 제출현황 조회" left="0" top="0" height="54" cssclass="img_WF_SubTit01" width="380" initvalueid="ivTitleAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divSearch" taborder="1" left="0" top="144" height="70" initvalueid="ivDivAccessibilityOn" right="0" cssclass="div_WF_Search" accessibilitylabel="조회영역">
          <Layouts>
            <Layout>
              <Static id="Static00_01" taborder="0" text="대입학년도" left="0" top="20" width="94" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtCoaAyr" taborder="1" left="94" top="20" width="159" height="30" initvalueid="ivEdtReadOnly" accessibilitylabel="대입학년도" readonly="true"/>
              <Static id="Static00_01_00" taborder="2" text="모집구분" left="253" top="20" width="81" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtCoaRcritScCd" taborder="3" left="334" top="20" width="260" height="30" initvalueid="ivEdtReadOnly" accessibilitylabel="모집구분" readonly="true"/>
              <Button id="btnSearch" taborder="4" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="20" onclick="divSearch_btnSearch_onclick" initvalueid="ivBtnAccessibilityButton"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="Static00_00" left="0" top="326" width="101" height="42" text="기간명" taborder="4"/>
              <Combo id="cboSearchType00" left="20" top="378" height="60" right="20" taborder="5"/>
              <Static id="Static00_00_00" left="0" top="469" width="77" height="42" taborder="6"/>
              <Combo id="cboSearchType00_00" left="20" top="521" height="60" right="20" taborder="7"/>
              <Button id="btnSearch" width="164" right="20" height="60" bottom="40" taborder="8"/>
              <Static id="Static00" left="0" top="183" width="101" height="42" taborder="2"/>
              <Combo id="cboSearchType" left="20" top="235" height="60" right="20" text="" taborder="3"/>
              <Edit id="edtSearchKeyword" left="20" top="92" height="60" right="20" taborder="1"/>
              <Static id="Static00_01" left="0" top="40" width="149" height="42" taborder="0"/>
            </Layout>
          </Layouts>
        </Div>
        <Grid id="grdList" taborder="2" left="0" top="234" height="382" right="0" binddataset="dsDataList" autofittype="col" initvalueid="ivGrdAccessibilityOn" cellclickbound="control" oncellclick="grd00_oncellclick" visible="false" useselcolor="false" enable="true" selecttype="cell" accessibilitylabel="제출현황">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="68"/>
                <Column size="38"/>
                <Column size="124"/>
                <Column size="88"/>
                <Column size="80"/>
                <Column size="120"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="합격연도"/>
                <Cell col="1" text="회차"/>
                <Cell col="2" text="합격증번호"/>
                <Cell col="3" text="합격시도"/>
                <Cell col="4" text="제출일시"/>
                <Cell col="5" text="제공동의확인번호"/>
              </Band>
              <Band id="body">
                <Cell text="bind:passYr" textAlign="center"/>
                <Cell col="1" text="bind:passTme" textAlign="center"/>
                <Cell col="2" text="bind:edycNo" textAlign="center"/>
                <Cell col="3" text="bind:kornOrgNm" textAlign="center"/>
                <Cell col="4" text="bind:dataSbmsnDt" textAlign="center" cssclass="cell_WF_Red" color="#333333"/>
                <Cell col="5" text="bind:pvsnAgreCn" textAlign="center" displaytype="normal" edittype="readonly" color="#333333" cssclass="cell_WF_Red" font="&quot;normal 13px/normal &quot;Noto Sans KR&quot;,&quot;NotoSansKR-Regular&quot;,&quot;Malgun Gothic&quot;,&quot;Arial,MS PGothic&quot;"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Div id="div00_00" taborder="3" left="0" cssclass="div_WF_InfoBOX" right="0" top="686" height="174" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="sta00_00_01_01_00" taborder="0" left="29" top="28" height="23" cssclass="sta_WF_InfoTit" text="이용 전 확인해주세요." wordWrap="char" initvalueid="ivStcAccessibilityOn" width="220"/>
              <Static id="sta00_00_01_01" taborder="1" left="30" top="67" height="23" cssclass="sta_WF_InfoTxt_Black" text="[&lt;fc v='red'&gt;제공동의확인번호&lt;/fc&gt;]는 지원하는 대학의 원서접수시, 온라인 제출확인을 위해 &lt;fc v='red'&gt;필수적으로 작성(입력)해야하는 번호&lt;/fc&gt;입니다. &lt;fc v='red'&gt;반드시 숙지하시기 바랍니다.&lt;/fc&gt;" wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="30"/>
              <Static id="sta00_00_01_01_01" taborder="2" left="30" top="94" height="23" cssclass="sta_WF_InfoTxt_Black" text="본인에게 부여받은 [제공동의 확인번호]를 타인에게 유출시, 대입전형에 불이익을 받을 수 있습니다." wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="30"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00" taborder="3" left="0" top="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_01" taborder="4" left="30" top="51" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_00" taborder="5" left="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" bottom="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta99_00_00_00_00_01_01" taborder="6" left="0" top="30" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="30" text="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta99_00_00_00_00_01_01_00" taborder="7" top="30" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="30" text="30" right="0" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="Static99_00_00_00_00" taborder="4" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00" taborder="5" left="0" top="114" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_00" taborder="6" left="0" top="214" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_00_00_00" taborder="7" left="0" top="-353" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsDataList" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcOrgCd" type="STRING" size="256" description="시도교육청조직코드"/>
          <Column id="kornOrgNm" type="STRING" size="256"/>
          <Column id="passYr" type="STRING" size="256" description="합격연도"/>
          <Column id="passTme" type="STRING" size="256" description="합격회차"/>
          <Column id="edycNo" type="STRING" size="256" description="합격증번호"/>
          <Column id="dataSbmsnDt" type="STRING" size="256" description="자료제출일시"/>
          <Column id="pvsnAgreCn" type="STRING" size="256" description="자료제공구분코드"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsService" useclientlayout="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsDataList=dsDataList dsFinYnList=dsFinYnList dsSearch=dsSearch</Col>
            <Col id="asynctp"/>
            <Col id="url">sqa_uep_sc04_001.do</Col>
            <Col id="id">selectDataList</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="coaAyr" type="STRING" size="256"/>
          <Column id="coaRcritScCd" type="STRING" size="256"/>
          <Column id="trprRrno" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsFinYnList" useclientlayout="true">
        <ColumnInfo>
          <Column id="finYn" type="STRING" size="256"/>
          <Column id="finFromTo" type="STRING" size="256"/>
          <Column id="seleDataIdntyBgng" type="STRING" size="256" datapath="전형자료확인시작일자"/>
          <Column id="seleDataIdntyEnd" type="STRING" size="256" datapath="전형자료확인종료일자"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 대입전형자료제공 - 대입전형자료 제출현황 조회
*  @FileName 	sqa_upesc04_m00.xfdl 
*  @Creator 	박가혜
*  @CreateDate 	2022.09.01
*  @Desction    대입전형자료 확인 및 신청
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.09.01          박가혜                 최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/




include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.fv_param;
var finYn 		= "Y";
var finFromTo 	= "";
var coaAyr 		= "";
var coaRcritScCd 	= ""; 
var coaRcritScCdNm 	= "";

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frm01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);

	this.fv_param = this.smfGetFormParams();

	var menuId = this.fv_param.menu;
	
	if(this.UepChkLogin(menuId)){
		this.fnSearch();
	}

};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd == -1) return;
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 대입전형자료 확인 및 제출 자료 조회
*/
this.fnSearch = function(){

	this.dsSearch.addRow();
	this.dsSearch.setColumn(0,"cddcCd",this.smfGetCddcCode())
	
	// 대입전형자료 조회
	this.smfSearchService("selectDataList")
		
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.fnListCallback();
			
		});	
}
/**
 * @description 대입전형자료 확인 및 제출 자료 조회 callback
*/
this.fnListCallback = function(){
		//coaAyr = this.smfGetSessionValue("coaAyr")				//대입학년도
	//coaRcritScCd = this.smfGetSessionValue("coaRcritScCd")	//대입구분모집(정시,수시코드)
	
	coaAyr = this.dsSearch.getColumn(0,"coaAyr")				//대입학년도
	coaRcritScCd = this.dsSearch.getColumn(0,"coaRcritScCd")	//대입구분모집(정시,수시코드)
	
	if(coaRcritScCd == "1" || coaRcritScCd == "3"){
		coaRcritScCdNm = "정시"
	}else if(coaRcritScCd == "2" || coaRcritScCd == "4"){
		coaRcritScCdNm = "수시"
	}
	
	if(this.dsFinYnList != null && this.dsFinYnList != "undefined"){
		var idx = this.dsFinYnList.rowcount -1;
		if(this.dsFinYnList.getColumn(idx, "finYn") != null && this.dsFinYnList.getColumn(idx, "finYn") != "" && this.dsFinYnList.getColumn(idx, "finYn") != "undefined"){
			finYn = this.dsFinYnList.getColumn(idx, "finYn")
		}
		if(this.dsFinYnList.getColumn(idx, "finFromTo") != null && this.dsFinYnList.getColumn(idx, "finFromTo") != "" && this.dsFinYnList.getColumn(idx, "finFromTo") != "undefined"){
			finFromTo = this.dsFinYnList.getColumn(idx, "finFromTo")
		}	
	}
	
	//finYn = "N" //테스트용으로 "N"처리
	
	//신청기간 구분
	if(finYn == "Y"){
		this.divSearch.set_visible(false)
		this.grdList.set_visible(false)
		this.smfAlert("대입전형자료 확인 및 신청 \n( "+ finFromTo +" )기간이 아닙니다.\n해당 기간에만 이용하실 수 있습니다.",function(){
			var objFrame = this.getOwnerFrame();
			
			if(objFrame.form.divAll)
			{
				// Top 에 값을 세팅
				var sMainUrl = objFrame.form.fv_mainformUrl;
				
				// 메인URL로 이동한다.
				if(!this.smfIsNull(sMainUrl))
				{
					objFrame.form.fnSetMainpage(sMainUrl);	
				}
			}
		})
		return
	}else if(finYn == "N"){
		this.divSearch.set_visible(true)
		this.grdList.set_visible(true)
	}
	
	this.divSearch.form.edtCoaAyr.set_value(coaAyr)
	this.divSearch.form.edtCoaRcritScCd.set_value(coaRcritScCdNm)
	
	//this.grd00.setCellProperty("body",3,"displaytype","buttoncontrol");
	
}


/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 조회 버튼 클릭
*/
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearch();
};

]]></Script>
  </Form>
</FDL>
