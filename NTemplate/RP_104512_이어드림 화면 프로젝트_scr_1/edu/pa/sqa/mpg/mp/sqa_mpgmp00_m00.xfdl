    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 검정고시서비스 마이페이지
*  @FileName 	sqa_mpgmp00_m00.xfdl 
*  @Creator 	박가혜
*  @CreateDate 	2022.11.29
*  @Desction    마이페이지
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.11.29           박가혜                 최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/




include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.fv_param;
this.sEnfcYr;
this.sEnfcTme;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frm01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);
	// 파라메터 세팅
	this.fv_param = this.smfGetFormParams();
	this.fv_menuId = this.fv_param.menu;
	
	this.dsSearch.addRow();

	//로그인안되어잇을 경우 로그인확인
	if(this.smfIsNull(this.smfGetTrprRrno())) {
		this.ChkLogin();

	}else{
		
		this.fnMyPage(); 	//개인정보조회
		
	}	

};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 마이페이지 개인정보 조회
*/
this.fnMyPage = function(){

	this.dsSearch.addRow();
	
	this.dsSearch.setColumn(0, "trprRrno", this.smfGetTrprRrno());
	this.dsSearch.setColumn(0, "kornFlnm", this.smfGetKornFlnm());
	this.dsSearch.setColumn(0, "cddcCd", this.smfGetCddcCode());
	//대입전형조회
	this.fnSelectUepSc();
	
	//마이페이지 기본정보 조회, 교육부에서 인적인덱스 조회하여 과거 정보조회
	this.smfSearchService("select")
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			//개인정보 및 과거 정보 셋팅
			this.fnApplpInfoSet();
		});	
}


/**
 * @description 개인정보 및 검정고시 과거 내역 셋팅
*/
this.fnApplpInfoSet = function(){
	
	if(this.dsUserInfoHis.rowcount == 0 || this.dsUserInfoHis.rowcount == null){
			this.smfAlert("원서접수내역이 없거나 과거 합격정보가 없는 경우는 마이페이지에서 정보를 조회할 수 없습니다.",function(){
			var objFrame = this.getOwnerFrame();
			
			if(objFrame.form.divAll)
			{
				// Top 에 값을 세팅
				var sMainUrl = objFrame.form.fv_mainformUrl;
				
				// 메인URL로 이동한다.
				if(!this.smfIsNull(sMainUrl))
				{
					objFrame.form.fnSetMainpage(sMainUrl);	
				}
			}
		})
	}else{
		
		for(var i = 0; i < this.dsUserInfoHis.rowcount; i++){
			var rcgnPassYn = this.dsUserInfoHis.getColumn(i,"rcgnPassYn")  //검정합격
			var sbjtPassScValue = this.dsUserInfoHis.getColumn(i,"sbjtPassScValue") //과목합격
		
			if(rcgnPassYn == "Y"){
				this.dsUserInfoHis.setColumn(i,"passCd","검정합격")
			}
			else if(sbjtPassScValue == "Y"){
				this.dsUserInfoHis.setColumn(i,"passCd","과목합격")
			}
		}

		this.smfGrdResetHeight(this.divMain2.form.grdInfo) 
		this.smfResetScroll(this.divMain2.form.grdInfo)
	
		this.divMain1.form.edtKornFlnm.set_value(this.smfGetKornFlnm());
		this.divMain1.form.edtTrprRrno1.set_value(this.dsMyInfo.getColumn(0,"trprRrno").substring(0,6));
		this.divMain1.form.edtTrprRrno2.set_value(this.dsMyInfo.getColumn(0,"trprRrno").substring(6,7)+"******");

		//이메일
			this.divMain1.form.edtEmlAddr.set_value(this.smfIsNull(this.dsMyInfo.getColumn(0,"emlAddr")) ? " " : this.dsMyInfo.getColumn(0,"emlAddr"))
		//주소
		var zipCd = this.dsMyInfo.getColumn(0,"ihtRegRoadNmZip") == null ||  this.dsMyInfo.getColumn(0,"ihtRegRoadNmZip") == "" ? "" : this.dsMyInfo.getColumn(0,"ihtRegRoadNmZip");
		var rdnAddr = this.dsMyInfo.getColumn(0,"ihtRegRoadNmAddr") == null || this.dsMyInfo.getColumn(0,"ihtRegRoadNmAddr") == "" ? "" : this.dsMyInfo.getColumn(0,"ihtRegRoadNmAddr");
		this.divMain1.form.edtIhtRegRdnAddr.set_value(zipCd + " " + rdnAddr)
		//상세주소
		this.divMain1.form.edtIhtRegRdnDaddr.set_value(this.dsMyInfo.getColumn(0,"ihtRegRoadNmDaddr"))
		
		//전화번호
		var num = this.smfIsNull(this.dsMyInfo.getColumn(0, "claiTelno")) ? this.dsMyInfo.getColumn(0, "mblTelno") : this.dsMyInfo.getColumn(0, "mblTelno") +"/"+this.dsMyInfo.getColumn(0, "claiTelno");
		this.divMain1.form.edtMblTelno.set_value(num)

		this.dsUserInfoHis.setColumn(0,"chk",1)
		
		if(this.dsUserInfoHis.getColumn(0, "chk") == 1){
			//원서접수조회
			this.fnSelectOi(0);
		}else{

			//과거 접수정보 선택 시 빈 탭(tab01)보여줌
			this.fnNullTab();
		}
		
	}
	
}	

/**
 * @description 마이페이지 개인정보 조회
*/
this.fnSetDsSearch = function(row){
	
	this.dsSearch.clearData();
	this.dsSearch.addRow();
	
	var cddcCd = this.smfIsNull(this.dsUserInfoHis.getColumn(row, "cddcCd")) ? this.dsUserInfoHis.getColumn(row, "enfcCtpvCd") + "0000001" : this.dsUserInfoHis.getColumn(row, "cddcCd") ;
	
	this.dsSearch.setColumn(0, "enfcYr", this.dsUserInfoHis.getColumn(row,"enfcYr"));
	this.dsSearch.setColumn(0, "enfcTme", this.dsUserInfoHis.getColumn(row,"enfcTme"));
	this.dsSearch.setColumn(0, "sqeScCd", this.dsUserInfoHis.getColumn(row,"sqeScCd"));
	this.dsSearch.setColumn(0, "rcptNo", this.dsUserInfoHis.getColumn(row, "rcptNo"));
	this.dsSearch.setColumn(0, "trprRrno", this.smfGetTrprRrno());
	this.dsSearch.setColumn(0, "kornFlnm", this.dsUserInfoHis.getColumn(row, "kornFlnm"));
	this.dsSearch.setColumn(0, "sqeExmtNo", this.dsUserInfoHis.getColumn(row, "sqeExmtNo"));
	this.dsSearch.setColumn(0, "cddcCd", cddcCd);
}

/**
 * @description 원서조회
*/
this.fnSelectOi  = function(row){
	 this.smfResetScroll(this.divMain3.form.tab00.Tabpage1.form);
	 
	this.fnSetDsSearch(row);
	this.dsApplpInfo.clearData();
	
	this.dsSearch.setColumn(0, "menuId", "5000")
	//원서조회
	this.smfSearchService("selectEnfcYrChk")
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;

				this.sEnfcYr =  this.dsEnfcYrChk.getColumn(0,"enfcYr")
				this.sEnfcTme = this.dsEnfcYrChk.getColumn(0,"enfcTme")
				trace("현재 회차 : " + this.sEnfcYr + " : " + this.sEnfcTme )
				
				if((this.smfIsNull(this.sEnfcYr) && this.smfIsNull(this.sEnfcTme))){
					this.fnNullTab();
				}else if(this.sEnfcYr != this.dsSearch.getColumn(0,"enfcYr") || this.sEnfcTme != this.dsSearch.getColumn(0,"enfcTme")){
					this.fnNullTab();
				}else{
					this.divMain3.form.tab00.set_visible(true)
					this.divMain3.form.tab01.set_visible(false)
					this.fnSelectOiCallback();
				}
			
		});	

		

}
/**
 * @description 원서조회 callback
*/
this.fnSelectOiCallback = function(){
	this.tabPage = this.divMain3.form.tab00.Tabpage1.form;
	
	if(this.dsApplpInfo == null || this.dsApplpInfo.rowcount == 0){  //현재 접수 정보가 없음
		
			var msg = "접수자 정보가 존재하지 않습니다.\n온라인 접수인 경우 원서를 제출한 교육청이 맞는지 확인해주시기 바라며\n현장 접수인 경우에는 온라인 발급이 불가하오니 접수처로 문의바랍니다."
				if(this.divMain3.form.tab00.tabindex == 0){ //원서조회tab
					
							this.tabPage.imgSubTitle.set_visible(false)
							this.tabPage.divInfo.set_visible(true)
							this.tabPage.divInfo.form.staInfo.set_visible(true)
							this.tabPage.divInfo.form.staInfo.set_text(msg)
							
							this.tabPage.divMain1.set_visible(false)
							this.tabPage.divMain2.set_visible(false)
							this.tabPage.divMain3.set_visible(false)
							this.tabPage.divMain4.set_visible(false)
							this.tabPage.imgTitle01.set_visible(false)
							this.tabPage.imgTitle02.set_visible(false)
							this.tabPage.imgTitle03.set_visible(false)
							this.tabPage.imgTitle04.set_visible(false)
							this.smfResetScroll(this.tabPage) //div사이즈 최적화
					
					}else if(this.divMain3.form.tab00.tabindex == 1){ //원서출력tab
						this.divMain3.form.tab00.Tabpage2.form.imgSubTitle.set_visible(false)
						this.divMain3.form.tab00.Tabpage2.form.divApplpInfo.set_visible(false)
						this.divMain3.form.tab00.Tabpage2.form.divInfo.set_visible(true)
						this.divMain3.form.tab00.Tabpage2.form.divInfo.form.staInfo.set_text(msg)
						this.divMain3.form.tab00.Tabpage2.form.divReportViewer.set_visible(false)
						this.smfResetScroll(this.divMain3.form.tab00.Tabpage2.form) //div사이즈 최적화
					}
		
		
	}else{	
			
			if(this.dsApplpInfo.getColumn(0,"sbmsnYn") != "Y"){ 
					var msg = "원서 접수중인 지원자입니다. 원서를 제출후 조회하세요";
	
					if(this.divMain3.form.tab00.tabindex == 0){ //원서조회tab
					
							this.tabPage.imgSubTitle.set_visible(false)
							this.tabPage.divInfo.set_visible(true)
							this.tabPage.divInfo.form.staInfo.set_visible(true)
							this.tabPage.divInfo.form.staInfo.set_text(msg)
							
							this.tabPage.divMain1.set_visible(false)
							this.tabPage.divMain2.set_visible(false)
							this.tabPage.divMain3.set_visible(false)
							this.tabPage.divMain4.set_visible(false)
							this.tabPage.imgTitle01.set_visible(false)
							this.tabPage.imgTitle02.set_visible(false)
							this.tabPage.imgTitle03.set_visible(false)
							this.tabPage.imgTitle04.set_visible(false)
							this.smfResetScroll(this.tabPage) //div사이즈 최적화
					
					}else if(this.divMain3.form.tab00.tabindex == 1){ //원서출력tab
						this.divMain3.form.tab00.Tabpage2.form.imgSubTitle.set_visible(false)
						this.divMain3.form.tab00.Tabpage2.form.divApplpInfo.set_visible(false)
						this.divMain3.form.tab00.Tabpage2.form.divInfo.set_visible(true)
						this.divMain3.form.tab00.Tabpage2.form.divInfo.form.staInfo.set_text(msg)
						this.divMain3.form.tab00.Tabpage2.form.divReportViewer.set_visible(false)
						this.smfResetScroll(this.divMain3.form.tab00.Tabpage2.form) //div사이즈 최적화
					}
					

				}else{
				//원서 조회 가능할때
						if(this.divMain3.form.tab00.tabindex == 0){
						
							this.tabPage.imgSubTitle.set_visible(true)
							this.tabPage.divInfo.set_visible(false)
							this.tabPage.divInfo.form.staInfo.set_visible(false)
							
							this.tabPage.divMain1.set_visible(true)
							this.tabPage.divMain2.set_visible(true)
							this.tabPage.divMain3.set_visible(true)
							this.tabPage.divMain4.set_visible(true)
							this.tabPage.imgTitle01.set_visible(true)
							this.tabPage.imgTitle02.set_visible(true)
							this.tabPage.imgTitle03.set_visible(true)
							this.tabPage.imgTitle04.set_visible(true)
							this.smfResetScroll(this.tabPage) //div사이즈 최적화

							//원서조회
							this.smfSearchService("selectOarOi")
								// 실행
								.run()

								// 콜백
								.callback(function(callbackParams){
									if(callbackParams.errors) return;
									
									this.fnOarOiSetData();
									//this.fnOiPrint()
								});	
								
						}else if(this.divMain3.form.tab00.tabindex == 1){
						
							this.divMain3.form.tab00.Tabpage2.form.imgSubTitle.set_visible(true)
							this.divMain3.form.tab00.Tabpage2.form.divApplpInfo.set_visible(true)
							this.divMain3.form.tab00.Tabpage2.form.divInfo.set_visible(false)
							this.divMain3.form.tab00.Tabpage2.form.divReportViewer.set_visible(true)
							this.smfResetScroll(this.divMain3.form.tab00.Tabpage2.form) 
							//원서출력
							this.fnOiPrint();
						}
					
				}
	}


}
/**
 * @description 원서조회 후 데이터 셋팅
*/
this.fnOarOiSetData = function(){
	this.tabPage = this.divMain3.form.tab00.Tabpage1.form;
	this.tabPage.divInfo.set_visible(false)
	this.tabPage.divInfo.form.staInfo.set_visible(false)
	this.smfResetScroll(this.tabPage);
	
	
	var enfcYr = this.dsOneUserInfo.getColumn(0,"enfcYr");
	var enfcTme = this.dsOneUserInfo.getColumn(0,"enfcTme")
	var sqeExmtNo = this.dsOneUserInfo.getColumn(0, "sqeExmtNo")
	
	//서브타이틀
	this.tabPage.imgSubTitle.set_text(enfcYr + "년도 " + enfcTme + "회차 " + this.dsOneUserInfo.getColumn(0,"sqeScCdNm") + "접수내역 확인")
	
	//사진
	this.tabPage.divMain1.form.imgViewer.set_image("data:image/png;base64,"+this.dsOneUserInfo.getColumn(0,"photoFileCn"))
	if(this.dsOneUserInfo.getColumn(0,"photoFileCn") != "" && this.dsOneUserInfo.getColumn(0,"photoFileCn") != null){
		this.tabPage.divMain1.form.imgViewer.set_text("")
	}
	//수험번호
	if(sqeExmtNo != null && sqeExmtNo != ""){
		this.tabPage.divMain1.form.edtSqeExmtNo.set_value(sqeExmtNo)
	}else{
		this.tabPage.divMain1.form.edtSqeExmtNo.set_value("수험번호는 담당자가 부여한 후, 확인 가능합니다")
	}
	//주민등록번호
	var trprRrno = this.dsOneUserInfo.getColumn(0,"trprRrno")
	if(trprRrno.length > 0){
		this.tabPage.divMain1.form.edtTrprRrno1.set_value(trprRrno.substring(0,6))
		this.tabPage.divMain1.form.edtTrprRrno2.set_value(trprRrno.substring(6,13))
	}
	
	//주소
	var zipCd = this.dsOneUserInfo.getColumn(0,"ihtRegRoadNmZip")
	var rdnAddr = this.dsOneUserInfo.getColumn(0,"ihtRegRoadNmAddr")
	this.tabPage.divMain1.form.edtIhtRegRdnAddr.set_value(zipCd + " " + rdnAddr)
	this.tabPage.divMain1.form.edtIhtRegRdnDaddr.set_value(this.dsOneUserInfo.getColumn(0,"ihtRegRoadNmDaddr"))
	
	//장애여부
	var dltYn = this.dsOneUserInfo.getColumn(0,"dltYn")
	if(dltYn == "N"){ 
		this.tabPage.divMain1.form.edtDltYn.set_value("일반인")
	}else{
		this.tabPage.divMain1.form.edtDltYn.set_value("장애인")
	}
	
	//전화번호
	var mblTelno = this.dsOneUserInfo.getColumn(0, "mblTelno")
	var claiTelno = this.dsOneUserInfo.getColumn(0, "claiTelno")
	
	if(claiTelno == "" || claiTelno == null || claiTelno == "undefiend"){
		this.tabPage.divMain1.form.edtMblTelno.set_value(mblTelno)
	}else{
		this.tabPage.divMain1.form.edtMblTelno.set_value(mblTelno + " / " + claiTelno)
	}
	//재소구분
	var prsrScCd = this.dsOneUserInfo.getColumn(0, "prsrScCd")
	
	if(prsrScCd != "" || !this.smfIsNull(prsrScCd)){
		if(prsrScCd ==  0){
			this.tabPage.divMain1.form.edtPrsrScCd.set_value("일반인")
		}else if(prsrScCd == 1){
			this.tabPage.divMain1.form.edtPrsrScCd.set_value("교도소재소자")
		}else{
			this.tabPage.divMain1.form.edtPrsrScCd.set_value("소년원재소자")
		}
	}
	

	//제출일자
	var sbmsnYmd = this.dsOneUserInfo.getColumn(0, "sbmsnYmd")
	if(this.smfIsNull(sbmsnYmd)){
		this.tabPage.divMain1.form.edtSbmsnYmd.set_value("-")
	}else{
		this.tabPage.divMain1.form.edtSbmsnYmd.set_value(sbmsnYmd.substr(0, 4) + "-" + sbmsnYmd.substr(4, 2) + "-" + sbmsnYmd.substr(6, 2))
	}
	
	//subText

	
	//졸업,제적일자
	var grdtnExpelYmd = this.dsOneUserInfo.getColumn(0, "grdtnExpelYmd")
	if(this.smfIsNull(grdtnExpelYmd)){
		this.tabPage.divMain2.form.edtGrdtnExpelYmd.set_value("-")
	}else{
		this.tabPage.divMain2.form.edtGrdtnExpelYmd.set_value(grdtnExpelYmd.substr(0, 4) + "-" + grdtnExpelYmd.substr(4, 2) + "-" + grdtnExpelYmd.substr(6, 2))
	}
	
	//고사장		
	if(this.dsCancelChk.getColumn(0,"exmhChcYn") == "N" && this.smfToday() < this.dsCancelChk.getColumn(0,"exmhRlsYmd")){
		
		this.tabPage.divMain3.form.edtExmmScNm.set_value("고사장 발표 전")
		
	}else{
			this.tabPage.divMain3.form.edtExmmScNm.set_value(this.dsOneUserInfo.getColumn(0,"exmmScNm"))
	}
	
	//과목세팅
	this.sbjtUserInfo();

	this.smfResetScroll(this.tabPage.divMain4.form) //div사이즈 최적화
	
}


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
	에러코드 (0 : 정상, 0 보다 작으면 에러)
*/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 원서접수 데이터 중 과목 조회
*/
this.sbjtUserInfo = function(){

	if(this.dsAllUserInfo.rowcount > 0){
		for(var i = 0; i < this.dsAllUserInfo.rowcount; i++){
		
			var nTop = i * 41;
		
			var staStatic = new Static("staStatic"+i, 0, nTop, 190, 42, null, null)
			if(i == 0) {
				staStatic.set_cssclass("sta_WF_Input01Top")
			}else{
				staStatic.set_cssclass("sta_WF_Input01")
			}
			staStatic.set_initvalueid("ivStcAccessibilityOn")
			staStatic.set_text(this.dsAllUserInfo.getColumn(i, "sqeSbjtNoNm"))
			this.tabPage.divMain4.addChild(staStatic.name, staStatic)
			staStatic.show();
			
			var staStatic2 = new Static("staStatic1"+i, "staStatic"+i+":"+ 0, nTop, null, 42, 0, null)
			if(i == 0) {
				staStatic2.set_cssclass("sta_WF_Input02Top")
			}else{
				staStatic2.set_cssclass("sta_WF_Input02")
			}
			staStatic2.set_initvalueid("ivStcAccessibilityOff")
			this.tabPage.divMain4.addChild(staStatic2.name, staStatic2)
			staStatic2.show();
			
			var edtEdit = new Edit("edtEdit"+i, 195, nTop+6, null, 30, 105, null)
			edtEdit.set_cssclass("edi_WF_Input")
			edtEdit.set_initvalueid("ivEdtReadOnly")
			edtEdit.set_readonly(true)
			edtEdit.set_value(this.dsAllUserInfo.getColumn(i, "sbjtAplemScCdNm"))
			this.tabPage.divMain4.addChild(edtEdit.name, edtEdit)
			edtEdit.show();
		}
	}else{
		this.tabPage.divMain4.set_visible(false)
	} 
}
/**
 * @description 원서출력
*/
this.fnOiPrint = function(){

	this.tabPage = this.divMain3.form.tab00.Tabpage2.form;
	this.smfResetScroll(this.tabPage);

	this.smfSearchService("selectOiReport")
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			var enfcYr = this.dsOneUserInfo.getColumn(0,"enfcYr");
			var enfcTme = this.dsOneUserInfo.getColumn(0,"enfcTme")
			var sqeExmtNo = this.dsOneUserInfo.getColumn(0, "sqeExmtNo")
			//서브타이틀
			this.divMain3.form.tab00.Tabpage2.form.imgSubTitle.set_text(enfcYr + "년도 " + enfcTme + "회차 " + this.dsOneUserInfo.getColumn(0,"sqeScCdNm"))
			//접수번호
			this.divMain3.form.tab00.Tabpage2.form.divApplpInfo.form.edtRcptNo.set_value(this.dsOneUserInfo.getColumn(0, "rcptNo"));
			this.fnSetData();
		});	
}

/**
 * @description 원서report에 보낼 param 데이터 셋팅
*/
this.fnSetData = function(){
	
	//주민등록번호
	var trprRrno = this.dsOneUserInfo.getColumn(0,"trprRrno")
	if(trprRrno.length > 0){
		this.dsOneUserInfo.setColumn(0,"trprRrno",trprRrno.substring(0,6) + "-" + trprRrno.substring(6,13))
	}
	
	//주소
	var zipCd = this.dsOneUserInfo.getColumn(0,"ihtRegRoadNmZip")
	var rdnAddr = this.dsOneUserInfo.getColumn(0,"ihtRegRoadNmAddr")
	this.dsOneUserInfo.setColumn(0, "ihtRegRoadNm", zipCd + " " + rdnAddr)
	
	//장애여부
	var dltYn = this.dsOneUserInfo.getColumn(0,"dltYn")
	if(dltYn == "N"){ 
		this.dsOneUserInfo.setColumn(0,"dltYn","일반인")
	}else{
		this.dsOneUserInfo.setColumn(0,"dltYn","장애인")
	}
	

	//재소구분
	var prsrScCd = this.dsOneUserInfo.getColumn(0, "prsrScCd")
	
	if(prsrScCd != "" || !this.smfIsNull(prsrScCd)){
		if(prsrScCd ==  0){
			this.dsOneUserInfo.setColumn(0,"prsrScCdNm","일반인")
		}else if(prsrScCd == 1){
			this.dsOneUserInfo.setColumn(0,"prsrScCdNm","교도소재소자")
		}else{
			this.dsOneUserInfo.setColumn(0,"prsrScCdNm","소년원재소자")
		}
	}
	

	//제출일자
	var sbmsnYmd = this.dsOneUserInfo.getColumn(0, "sbmsnYmd")
	
	if(this.smfIsNull(sbmsnYmd)){
		this.dsOneUserInfo.setColumn(0,"sbmsnYmd","-")
	}else{
		var ymd = sbmsnYmd.substr(0, 4) + "-" + sbmsnYmd.substr(4, 2) + "-" + sbmsnYmd.substr(6, 2)
		this.dsOneUserInfo.setColumn(0,"sbmsnYmd", ymd)
	}
		
		//졸업제적일
	var grdtnExpelYmd = this.dsOneUserInfo.getColumn(0, "grdtnExpelYmd")
	
	if(this.smfIsNull(grdtnExpelYmd)){
		this.dsOneUserInfo.setColumn(0,"grdtnExpelYmd","-")
	}else{
		var ymd = grdtnExpelYmd.substr(0, 4) + "-" + grdtnExpelYmd.substr(4, 2) + "-" + grdtnExpelYmd.substr(6, 2)
		this.dsOneUserInfo.setColumn(0,"grdtnExpelYmd", ymd)
	}
	
	
	//고사장
	var cddc = this.smfGetCddcCode().substring(0,3)
	if(this.dsCancelChk.getColumn(0,"exmhChcYn") == "N" && this.smfToday() < this.dsCancelChk.getColumn(0,"exmhRlsYmd")){
		
		this.dsOneUserInfo.setColumn(0,"exmmScNm","고사장 발표 전")
	}else{
	
		this.dsOneUserInfo.setColumn(0,"exmmScNm",this.dsOneUserInfo.getColumn(0,"exmmScNm"))
		
	}
	
	this.fnSetOiReport();
	
}

/**
 * @description 원서출력 Oz 리포트 셋팅 (OZ Report)
*/
this.fnSetOiReport = function(){
	
	this.divMain3.form.tab00.Tabpage2.form.divReportViewer.set_url("");
	//var sSecurityYN     = this.chkSecurityYN.value     ?"Y":"N";   // 위변조방지 삽입
	//var sVoiceBarcodeYN = this.chkVoiceBarcodeYN.value ?"Y":"N";   // 보이스바코드 삽입
	//var sBrailleCodeYN  = this.chkBrailleCodeYN.value  ?"Y":"N";   // 점자문서 생성
	
	var sReportName  = "/edu/pa/sqa/oar/oi/sqa_oaroi00_r00.ozr";
	var subTitle = this.divMain3.form.tab00.Tabpage2.form.imgSubTitle.text
	var orgName = this.dsOneUserInfo.getColumn(0,"orgName")
	
	
	// 리포트를 생성하기 위한 옵션을 설정한다.
	var oOzOption = {
					    reports : [	
							{	
								// 기본데이터
								  displayname         : "원서출력"   // [필수] 멀티리포트시 Tree에 보여줄 이름
								, reportname : sReportName // [필수] 리포트명  "/jsonsample.ozr"
								
								// json연동형
								//  - Odi인 경우 지정안해도 됨
								//  - jsonDs/jsonDsName은 갯수가 같아야 됨
								, jsonDs     : [this.dsOneUserInfo,this.dsAllUserInfo]  // [선택] json으로 변환할 데이터셋
								, jsonDsName : ["dsOneUserInfo","dsAllUserInfo"]            // [선택] json으로 변환할 데이터의이름(ozr파일에서 지정된 값과 일치)
								, jsonParam  : ["subTitle="+subTitle,"orgName="+orgName]  // [선택] json이외에추가할 데이터(KEY=VALUE형태의 스트링(배열))
								
								
								// 추가/보안옵션
								, security     : "N"       // [선택] 위변조방지 삽입   ("Y"(default):표시,"N":비표시)
								, voiceBarcode : "N"   // [선택] 보이스바코드 삽입 ("Y"(default):표시,"N":비표시)
								, brailleCode  : "N"    // [선택] 점자문서 생성     ("Y":생성,"N"(default):미생성)
							}						
						]
	                };
					
	//리포트를 그린다.
		//this.smfReportView(this,"embedded",oOzOption,this.divMain3.form.tab00.Tabpage2.form.divReportViewer);            // Div로 표시
	this.divMain3.form.tab00.Tabpage2.form.divReportViewer.optionReport = oOzOption;
	this.divMain3.form.tab00.Tabpage2.form.divReportViewer.set_url("comm::comp_ozreport.xfdl");
	
}
/**
 * @description 수험표출력
*/
this.fnSelectOarEo = function(row){
	
	this.fnSetDsSearch(row);
	this.dsApplpInfo.clearData();
	this.dsSearch.setColumn(0,"menuId","6000")
	
	//수험표출력 전 조회
	this.smfSearchService("selectEnfcYrChk")
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
				this.sEnfcYr =  this.dsEnfcYrChk.getColumn(0,"enfcYr")
				this.sEnfcTme = this.dsEnfcYrChk.getColumn(0,"enfcTme")
				trace("현재 회차 : " + this.sEnfcYr + " : " + this.sEnfcTme )
				
				if(this.smfIsNull(this.sEnfcYr) && this.smfIsNull(this.sEnfcTme)){
					this.fnNullTab();
				}else if(this.sEnfcYr != this.dsSearch.getColumn(0,"enfcYr") || this.sEnfcTme != this.dsSearch.getColumn(0,"enfcTme")){
					this.fnNullTab();
				}else{
					this.divMain3.form.tab00.set_visible(true)
					this.divMain3.form.tab01.set_visible(false)
					this.fnOarEoSuccess();
				}
		});	
	
}

/**
 * @description 수험표출력 callback
*/
this.fnOarEoSuccess = function(){
	this.tabPage = this.divMain3.form.tab00.Tabpage4.form;
	this.tabPage.divInfo.set_visible(false)
	this.tabPage.divApplpInfo.set_visible(false)
	this.tabPage.divReportViewer.set_visible(false)
	this.tabPage.imgMainTitle.set_visible(false)
	
	if(this.dsApplpInfo == null || this.dsApplpInfo.rowcount == 0 || this.dsApplpInfo == "undefined"){
	
		this.tabPage.divInfo.form.staInfo.set_text("접수자 정보가 존재하지 않습니다.\n온라인 접수인 경우 원서를 제출한 교육청이 맞는지 확인해주시기 바라며\n현장 접수인 경우에는 온라인 발급이 불가하오니 접수처로 문의바랍니다.")
		this.tabPage.divInfo.set_visible(true)
		this.tabPage.divApplpInfo.set_visible(false)
		this.tabPage.divReportViewer.set_visible(false)
		this.tabPage.imgMainTitle.set_visible(false)
	}else if(this.dsApplpInfo.getColumn(0,"chulNo") == "N"){
		
		var vStartYear = this.dsEnfcYrChk.getColumn(0,"eiOtptBgngYmd").substring(0, 4);
		var vStartMonth = this.dsEnfcYrChk.getColumn(0,"eiOtptBgngYmd").substring(4, 6);
		var vStartDay = this.dsEnfcYrChk.getColumn(0,"eiOtptBgngYmd").substring(6, 8);
		var vEndYear = this.dsEnfcYrChk.getColumn(0,"eiOtptEndYmd").substring(0, 4);
		var vEndMonth = this.dsEnfcYrChk.getColumn(0,"eiOtptEndYmd").substring(4, 6);
		var vEndDay = this.dsEnfcYrChk.getColumn(0,"eiOtptEndYmd").substring(6, 8);
		
		this.tabPage.divInfo.form.staInfo.set_text("수험표 출력일이 아닙니다.\n출력일은 "+vStartYear+"년 "+vStartMonth+"월 "+vStartDay+"일 "+" ~ "+vEndYear+"년 "+vEndMonth+"월 "+vEndDay+"일 "+" 입니다.")
		this.tabPage.divInfo.set_visible(true)
		this.tabPage.divApplpInfo.set_visible(false)
		this.tabPage.divReportViewer.set_visible(false)
		
	}else{
	
		var enfcYr = this.dsApplpInfo.getColumn(0,"enfcYr")
		var enfcTme = this.dsApplpInfo.getColumn(0,"enfcTme")
		var sqeScCdNm = this.dsApplpInfo.getColumn(0,"sqeScCdNm")
		
		this.tabPage.imgMainTitle.set_text(enfcYr + "년도 " + enfcTme + "회차 " + sqeScCdNm + " 수험자 정보 ")
		
		//주민등록번호
		var trprRrno = this.dsApplpInfo.getColumn(0,"trprRrno")
		if(trprRrno.length > 0){
			this.tabPage.divApplpInfo.form.edtTrprRrno1.set_value(trprRrno.substring(0,6))
			this.tabPage.divApplpInfo.form.edtTrprRrno2.set_value(trprRrno.substring(6,13))
		}
	
			//고사장
		if(this.dsExamInfo.getColumn(0,"exmhChcYn") == "N" && this.smfToday() < this.dsExamInfo.getColumn(0,"exmhRlsYmd")){
		
			this.dsReportInfo.setColumn(0,"exmhNm","고사장 발표 전")
		}else{
			this.dsReportInfo.setColumn(0,"exmhNm",this.dsApplpInfo.getColumn(0,"exmmScNm"))
		}
		
		this.tabPage.divApplpInfo.form.edtKornFlnm.set_value(this.dsApplpInfo.getColumn(0,"kornFlnm"))
		this.tabPage.divApplpInfo.form.edtRcptNo.set_value(this.dsApplpInfo.getColumn(0,"rcptNo"))
		
		if(this.dsApplpInfo.getColumn(0,"sbmsnYn") == "Y"){ //제출완료
			if(this.dsApplpInfo.getColumn(0,"sqeExmtNo") == null ){
				
				this.tabPage.divInfo.form.staInfo.set_text("원서제출 후 담당자 처리중입니다. 수험번호 발부후 출력가능합니다.\n\n처리상황은 원서조회에서 확인가능합니다.")
				this.tabPage.divInfo.set_visible(true)
				this.tabPage.divApplpInfo.set_visible(false)
				this.tabPage.imgMainTitle.set_visible(false)
				this.tabPage.divReportViewer.set_visible(false)
			}else{
			
				if(this.dsApplpInfo.getColumn(0,"sqeExmtNo") == ""){
				
					this.tabPage.divInfo.form.staInfo.set_text("원서제출 후 담당자 처리중입니다. 수험번호 발부후 출력가능합니다.\n\n처리상황은 원서조회에서 확인가능합니다.")
					this.tabPage.divInfo.set_visible(true)
					this.tabPage.divApplpInfo.set_visible(false)
					this.tabPage.divReportViewer.set_visible(false)
					this.tabPage.imgMainTitle.set_visible(false)
				}else{
					this.tabPage.divInfo.set_visible(false)
					this.tabPage.divReportViewer.set_visible(true)
					this.tabPage.divApplpInfo.set_visible(true)
					this.tabPage.imgMainTitle.set_visible(true)

					this.smfSearchService("selectReport")
					// 실행
					.run()

					// 콜백
					.callback(function(callbackParams){
						if(callbackParams.errors) return;
						this.dsReportInfo.getColumn(0,"photoFileCn")
						this.fnSetEoReport();
					});
				}
			}

		}else{
			this.tabPage.divInfo.set_visible(true)
			this.tabPage.divInfo.form.staInfo.set_text("수험번호 발부후 출력가능합니다.\n\n처리상황은 원서조회에서 확인가능합니다.\n\n※ 현재상태: 미제출(제출 필요)")
			this.tabPage.imgMainTitle.set_visible(false)
			this.tabPage.divApplpInfo.set_visible(false)
			this.tabPage.imgMainTitle.set_visible(false)
			this.tabPage.divReportViewer.set_visible(false)
		}
	}
	this.smfResetScroll(this.tabPage);
}

/**
 * @description 수험표 출력 Oz 리포트 셋팅 (OZ Report)
*/
this.fnSetEoReport = function(){

	//var sSecurityYN     = this.chkSecurityYN.value     ?"Y":"N";   // 위변조방지 삽입
	//var sVoiceBarcodeYN = this.chkVoiceBarcodeYN.value ?"Y":"N";   // 보이스바코드 삽입
	//var sBrailleCodeYN  = this.chkBrailleCodeYN.value  ?"Y":"N";   // 점자문서 생성
	
	var enfcYr = this.dsApplpInfo.getColumn(0,"enfcYr")
	var enfcTme = this.dsApplpInfo.getColumn(0,"enfcTme")
	var sqeScCdNm = this.dsApplpInfo.getColumn(0,"sqeScCdNm")
	
	var sReportName  = "/edu/pa/sqa/oar/eo/sqa_oareo00_r00.ozr";
	var subTitle = enfcYr + "년도 제" + enfcTme + "회 " + sqeScCdNm + " 수험표 "
	
	var orgName = this.dsReportInfo.getColumn(0,"orgName")
	var trprRrno = this.dsReportInfo.getColumn(0,"trprRrno")
	
	this.dsReportInfo.setColumn(0,"examPremaCn", this.dsExamInfo.getColumn(0,"examPremaCn")) //유의사항
	this.dsReportInfo.setColumn(0,"atentMteCn", this.dsExamInfo.getColumn(0,"atentMteCn")) //시험준비물
	
	if(!this.smfIsNull(trprRrno)){
		this.dsReportInfo.setColumn(0,"trprRrno", trprRrno.substring(0,6)+"-"+trprRrno.substring(6,13))
	}
	
	
	// 리포트를 생성하기 위한 옵션을 설정한다.
	var oOzOption = {
					    reports : [	
							{	
								// 기본데이터
								  displayname         : "수험표출력"   // [필수] 멀티리포트시 Tree에 보여줄 이름
								, reportname : sReportName // [필수] 리포트명  "/jsonsample.ozr"
								
								// json연동형
								//  - Odi인 경우 지정안해도 됨
								//  - jsonDs/jsonDsName은 갯수가 같아야 됨
								, jsonDs     : [this.dsReportInfo,this.dsReportInfoSbjt]  // [선택] json으로 변환할 데이터셋
								, jsonDsName : ["dsReportInfo","dsReportInfoSbjt"]            // [선택] json으로 변환할 데이터의이름(ozr파일에서 지정된 값과 일치)
								, jsonParam  : ["subTitle="+subTitle,"orgName="+orgName]  // [선택] json이외에추가할 데이터(KEY=VALUE형태의 스트링(배열))
								
								
								// 추가/보안옵션
								, security     : "N"       // [선택] 위변조방지 삽입   ("Y"(default):표시,"N":비표시)
								, voiceBarcode : "N"   // [선택] 보이스바코드 삽입 ("Y"(default):표시,"N":비표시)
								, brailleCode  : "N"    // [선택] 점자문서 생성     ("Y":생성,"N"(default):미생성)
							}						
						]
	                };
					
	//리포트를 그린다.
		this.divMain3.form.tab00.Tabpage4.form.divReportViewer.optionReport = oOzOption;
		this.divMain3.form.tab00.Tabpage4.form.divReportViewer.set_url("comm::comp_ozreport.xfdl");
	
}
/**
 * @description 성적조회
*/
this.fnSelectAriSi = function(row){
	
	this.fnSetDsSearch(row);
	this.dsApplpInfo.clearData();
	this.dsSearch.setColumn(0,"menuId","7000")
	
	//성적조회
	this.smfSearchService("selectEnfcYrChk")
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.sEnfcYr =  this.dsEnfcYrChk.getColumn(0,"enfcYr")
				this.sEnfcTme = this.dsEnfcYrChk.getColumn(0,"enfcTme")
				trace("현재 회차 : " + this.sEnfcYr + " : " + this.sEnfcTme )
				
				if(this.smfIsNull(this.sEnfcYr) && this.smfIsNull(this.sEnfcTme)){
					this.fnNullTab();
				}else if(this.sEnfcYr != this.dsSearch.getColumn(0,"enfcYr") || this.sEnfcTme != this.dsSearch.getColumn(0,"enfcTme")){
					this.fnNullTab();
				}else{
					this.divMain3.form.tab00.set_visible(true)
					this.divMain3.form.tab01.set_visible(false)
					this.fnAriSiSuccess();
				}
			
		});	

}
/**
 * @description 성적조회 callback
*/
this.fnAriSiSuccess = function(){
	this.tabPage = this.divMain3.form.tab00.Tabpage5.form;
	
	this.tabPage.imgSubTitle.set_visible(false)
	this.tabPage.divInfo.set_visible(false)
	this.tabPage.divApplpInfo.set_visible(false)
	
	var screInqBgngYmdtm = this.smfTrim(this.dsEnfcYrChk.getColumn(0,"screInqBgngYmdtm"))
	var screInqEndYmdtm = this.smfTrim(this.dsEnfcYrChk.getColumn(0,"screInqEndYmdtm"))
	var screInqBgngYmd = this.smfTrim(this.dsEnfcYrChk.getColumn(0,"screInqBgngYmd"))
	var screInqBgngTm = this.smfTrim(this.dsEnfcYrChk.getColumn(0,"screInqBgngTm"))
	var screInqEndYmd = this.smfTrim(this.dsEnfcYrChk.getColumn(0,"screInqEndYmd"))
	var screInqEndTm = this.smfTrim(this.dsEnfcYrChk.getColumn(0,"screInqEndTm"))
	var toDateChar = this.smfTrim(this.dsEnfcYrChk.getColumn(0,"toDateChar"))
	
//	if(this.dsApplpInfo == null){
//		trace("입력 정보에 대한 온라인 접수 내역을 찾을 수 없습니다. \n\n※ 기합격자의 경우 접수 방식과 상관없이 정부24를 통해 증명서 발급이 가능합니다.");
//		this.tabPage.divApplpInfo.set_visible(false)
//		this.tabPage.grdAriSi.set_visible(false)
//		this.tabPage.divInfo.set_visible(true)
//		this.tabPage.divInfo.form.staInfo.set_text("입력 정보에 대한 온라인 접수 내역을 찾을 수 없습니다. \n\n※ 기합격자의 경우 접수 방식과 상관없이 정부24를 통해 증명서 발급이 가능합니다.")
//	}else{
		if(this.dsEnfcYrChk == null){

			this.tabPage.divApplpInfo.set_visible(false)
			this.tabPage.grdAriSi.set_visible(false)
			this.tabPage.divInfo.set_visible(true)
			this.tabPage.divInfo.form.staInfo.set_text("성적조회기간이 아닙니다. 시도담당자에게 문의 바랍니다! \n\n※ 기 합격자인 경우 정부24 온라인발급신청을 이용하세요.")
			
		}else{
			if(screInqBgngYmdtm.length != 10 && screInqEndYmdtm.length != 10){
			
				this.tabPage.divApplpInfo.set_visible(false)
				this.tabPage.grdAriSi.set_visible(false)
				this.tabPage.divInfo.set_visible(true)
				this.tabPage.divInfo.form.staInfo.set_text("성적조회기간이 잘못되어있습니다. 시도담당자에게 문의 바랍니다!!! \n\n ※ 기 합격자인 경우 정부24 온라인발급신청을 이용하세요.")
			
			}else if(screInqBgngYmdtm <= toDateChar && screInqEndYmdtm > toDateChar){
					
				if(this.dsApplpInfo.rowcount == 0){ //dsApplpInfo size가 0인경우 : 오프라인에도 정보가 없는 경우
					this.tabPage.divApplpInfo.set_visible(false)
					this.tabPage.grdAriSi.set_visible(false)
					this.tabPage.divInfo.set_visible(true)
					this.tabPage.divInfo.form.staInfo.set_text("입력 정보에 대한 사용자 정보가 없습니다. 다시 한번 확인 바랍니다.")

				}else{
				
					this.smfSearchService("selectAriSi")
					// 실행
					.run()

					// 콜백
					.callback(function(callbackParams){
						if(callbackParams.errors) return;
					
						this.divMain3.form.tab00.set_visible(true)
						this.divMain3.form.tab01.set_visible(false)
						this.divMain3.form.tab00.set_tabindex(3)
						
						this.tabPage.divApplpInfo.set_visible(true)
						this.tabPage.grdAriSi.set_visible(true)
						//this.tabPage.divInfo.set_visible(true)
					
						//title
						this.tabPage.imgSubTitle.set_visible(true)
						//this.tabPage.imgSubTitle.set_text(this.dsApplpInfo.getColumn(0,"enfcYr") + "년도 "+ this.dsApplpInfo.getColumn(0,"enfcTme") + "회차 "
						//+ this.dsAriSi.getColumn(0,"sqeScCdNm") + " 수험자 정보")
						this.tabPage.imgSubTitle.set_text(this.dsEnfcYrChk.getColumn(0,"enfcYr") + "년도 "+ this.dsEnfcYrChk.getColumn(0,"enfcTme")  + "회차 "
						+ this.dsAriSi.getColumn(0,"sqeScCdNm") + " 수험자 정보")
							
						//주민등록번호
						var trprRrno = this.dsAriSi.getColumn(0,"trprRrno")
						if(trprRrno.length > 0){
							this.tabPage.divApplpInfo.form.edtTrprRrno1.set_value(trprRrno.substring(0,6))
							this.tabPage.divApplpInfo.form.edtTrprRrno2.set_value(trprRrno.substring(6,7)+"******")
						}
						//성명
						this.tabPage.divApplpInfo.form.edtKornFlnm.set_value(this.dsAriSi.getColumn(0,"kornFlnm"))
						//접수번호
						this.tabPage.divApplpInfo.form.edtRcptNo.set_value(this.smfIsNull(this.dsApplpInfo.getColumn(0,"rcptNo"))?"":this.dsApplpInfo.getColumn(0,"rcptNo"))
						//합격구분
						this.tabPage.divApplpInfo.form.edtPassScCd.set_value(this.dsAriSi.getColumn(0,"passScCd"))
						
						this.smfGrdResetHeight(this.tabPage.grdAriSi) 
						this.smfResetScroll(this.tabPage.grdAriSi)
					});	
				}
				
				
				
				
			}else if(screInqBgngYmdtm > toDateChar || screInqEndYmdtm <= toDateChar){
				this.tabPage.divApplpInfo.set_visible(false)
				this.tabPage.divInfo.set_visible(true)
				this.tabPage.grdAriSi.set_visible(false)
				this.tabPage.divInfo.form.staInfo.set_text("성적조회기간이 아닙니다. 시도담당자에게 문의 바랍니다!!\n\n 성적조회기간 : " + this.dateFormat(screInqBgngYmd) + " " + screInqBgngTm + "시 ~ " +  this.dateFormat(screInqEndYmd) + " " + screInqEndTm + "시\n\n ※ 기 합격자인 경우 정부24 온라인발급신청을 이용하세요.")
			}else{

				this.tabPage.divApplpInfo.set_visible(false)
				this.tabPage.divInfo.set_visible(true)
				this.tabPage.grdAriSi.set_visible(false)
				this.tabPage.divInfo.form.staInfo.set_text("성적조회기간이 아닙니다. 시도담당자에게 문의 바랍니다!! \n\n※ 기 합격자인 경우 정부24 온라인발급신청을 이용하세요.")
			}
			
		}
//	}

	this.smfResetScroll(this.tabPage);
}

/////////////////////대입전형/////////
/**
 * @description 대입전형자료 확인 및 제출 자료 조회
*/
this.fnSelectUepSc = function(){
	this.dsUepSearch.addRow();
	this.dsUepSearch.setColumn(0,"cddcCd",this.smfGetCddcCode())
	
	// 대입전형자료 조회
	this.smfSearchService("selectDataList")
		
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.fnListCallback();
			
		});	
}
/**
 * @description 대입전형자료 확인 및 제출 자료 조회 callback
*/
this.fnListCallback = function(){
	var coaAyr = this.dsUepSearch.getColumn(0,"coaAyr")
	var coaRcritScCd = this.dsUepSearch.getColumn(0,"coaRcritScCd")
	var coaRcritScCdNm = "";
	var finYn = "";
	var finFromTo = "";
	
	if(coaRcritScCd == "1" || coaRcritScCd == "3"){
		coaRcritScCdNm = "정시"
	}else if(coaRcritScCd == "2" || coaRcritScCd == "4"){
		coaRcritScCdNm = "수시"
	}
	
	if(this.dsFinYnList != null && this.dsFinYnList != "undefined"){
		var idx = this.dsFinYnList.rowcount -1;
		if(this.dsFinYnList.getColumn(idx, "finYn") != null && this.dsFinYnList.getColumn(idx, "finYn") != "" && this.dsFinYnList.getColumn(idx, "finYn") != "undefined"){
			finYn = this.dsFinYnList.getColumn(idx, "finYn")
		}
		if(this.dsFinYnList.getColumn(idx, "finFromTo") != null && this.dsFinYnList.getColumn(idx, "finFromTo") != "" && this.dsFinYnList.getColumn(idx, "finFromTo") != "undefined"){
			finFromTo = this.dsFinYnList.getColumn(idx, "finFromTo")
		}	
	}
	
	//finYn = "N" //테스트용으로 "N"처리
	
	//신청기간 구분
	if(finYn == "Y"){ //신청기간아닐때 
		//this.divMain4.form.divSearch.set_visible(false)
		this.divMain4.form.divSearch.form.btnSearch.set_enable(false)
		this.divMain4.form.grdList.set_visible(false)
		this.divMain4.form.divInfo.set_visible(true)
		this.divMain4.form.divInfo.form.staInfo.set_text("대입전형자료 확인 및 신청( "+ finFromTo +" )기간이 아닙니다. 해당 기간에만 이용하실 수 있습니다.")
		return
	}else if(finYn == "N"){ //신청기간일때
		this.divMain4.form.divSearch.set_visible(true)
		this.divMain4.form.grdList.set_visible(true)
		this.divMain4.form.divInfo.set_visible(false)
	}

	this.divMain4.form.divSearch.form.edtCoaAyr.set_value(coaAyr)
	this.divMain4.form.divSearch.form.edtCoaRcritScCd.set_value(coaRcritScCdNm)
	
	//this.grd00.setCellProperty("body",3,"displaytype","buttoncontrol");
	
}

//과거 접수정보 선택 시 빈 탭(tab01)보여줌
this.fnNullTab = function(){

		//과거 접수정보 선택 시 빈 탭(tab01)보여줌
		this.divMain3.form.tab00.set_visible(false)
		this.divMain3.form.tab01.set_visible(true)
		var txt = "현재 접수 진행 중인 검정고시 접수 정보만 조회 가능합니다."
		this.divMain3.form.tab01.Tabpage1.form.divInfo.form.staInfo.set_text(txt)
		this.divMain3.form.tab01.Tabpage2.form.divInfo.form.staInfo.set_text(txt)
		this.divMain3.form.tab01.Tabpage4.form.divInfo.form.staInfo.set_text(txt)
		this.divMain3.form.tab01.Tabpage5.form.divInfo.form.staInfo.set_text(txt)
		this.smfResetScroll(this.divMain3.form.tab01.Tabpage1.form);
		this.smfResetScroll(this.divMain3.form.tab01.Tabpage2.form);
		this.smfResetScroll(this.divMain3.form.tab01.Tabpage4.form);
		this.smfResetScroll(this.divMain3.form.tab01.Tabpage5.form);
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.grdInfo_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	//checkBox하나만 선택되도록 하기
	for(var i = 0; i< this.dsUserInfoHis.rowcount; i++){
		if(i == e.row){
			this.dsUserInfoHis.setColumn(i,"chk",1)
		}else{
		
			this.dsUserInfoHis.setColumn(i,"chk",0)
		}
	}
	
	//선택 된 row중 현 회차 
	//if(this.dsUserInfoHis.getColumn(e.row, "chk") == 1 && (this.dsUserInfoHis.getColumn(e.row, "enfcYr") == this.sEnfcYr && this.dsUserInfoHis.getColumn(e.row, "enfcTme") == this.sEnfcTme)){ 

		this.divMain3.form.tab00.set_visible(true)
		this.divMain3.form.tab01.set_visible(false)
		
		if(this.divMain3.form.tab00.tabindex == 0){
			//원서접수확인
			this.fnSelectOi(e.row);
		}else if(this.divMain3.form.tab00.tabindex == 1){
			//원서접수출력
			this.fnSelectOi(e.row);
			this.fnOiPrint(e.row);
		}else if(this.divMain3.form.tab00.tabindex == 2){
			//수험표출력"
			this.fnSelectOarEo(e.row);
		}else if(this.divMain3.form.tab00.tabindex == 3){
			//성적조회
			this.fnSelectAriSi(e.row);
		}
	//}else{
	//과거 접수정보 선택 시 빈 탭(tab01)보여줌
	//	this.fnNullTab();
		
	//}
};


//탭변경시
this.tab_onchanged = function(obj:nexacro.Tab,e:nexacro.TabIndexChangeEventInfo)
{
	var row;
	for(var i = 0; i<this.dsUserInfoHis.rowcount; i++){
		if(this.dsUserInfoHis.getColumn(i, "chk") == 1 ){
			row = i
		}
	}
	
	//if(this.dsUserInfoHis.getColumn(row, "chk") == 1 && (this.dsUserInfoHis.getColumn(row, "enfcYr") == this.sEnfcYr && this.dsUserInfoHis.getColumn(row, "enfcTme") == this.sEnfcTme )){ 
	
		if(obj.tabindex == 0){
			//원서접수확인
			this.fnSelectOi(row);
		}else if(obj.tabindex == 1){
			//원서접수출력
			this.fnSelectOi(row);
		}else if(obj.tabindex == 2){
			//수험표출력"
			this.fnSelectOarEo(row);
		}else if(obj.tabindex == 3){
			//성적조회
			this.fnSelectAriSi(row);
		}
	
//	}else{
		//과거 접수정보 선택 시 빈 탭(tab01)보여줌
//		this.fnNullTab();
//	}
	
};

//대입전형자료 '조회'버튼 클릭 시
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSelectUepSc();
};

//대입전형자료에서 제공동의 클릭 시
this.grdUep_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	
	if(e.col == 5){
			var popupParams = {
						callback: this.fnPopupCallback,
						sender: obj,
						params: {
							procType: "search",
							passYr : this.dsDataList.getColumn(e.row,"passYr"),
							passTme : this.dsDataList.getColumn(e.row,"passTme")
					
						}
					};
					this.smfOpen("_auto", "pa_sqa_mpg_mp::sqa_mpgmp00_p00.xfdl", popupParams);
	}
};


this.tab01_onchanged = function(obj:nexacro.Tab,e:nexacro.TabIndexChangeEventInfo)
{
	var row;
	for(var i = 0; i<this.dsUserInfoHis.rowcount; i++){
		if(this.dsUserInfoHis.getColumn(i, "chk") == 1 ){
			row = i
		}
	}
	
	//if(this.dsUserInfoHis.getColumn(row, "chk") == 1 && (this.dsUserInfoHis.getColumn(row, "enfcYr") == this.sEnfcYr && this.dsUserInfoHis.getColumn(row, "enfcTme") == this.sEnfcTme)){ 
	
		if(obj.tabindex == 0){
			//원서접수확인
			this.fnSelectOi(row);
		}else if(obj.tabindex == 1){
			//원서접수출력
			this.fnSelectOi(row);
		}else if(obj.tabindex == 2){
			//수험표출력"
			this.fnSelectOarEo(row);
		}else if(obj.tabindex == 3){
			//성적조회
			this.fnSelectAriSi(row);
		}
	
	//}else{
		//과거 접수정보 선택 시 빈 탭(tab01)보여줌
	//	this.fnNullTab();
	//}
};
]]></Script>
