                    </Row>
                  </Rows>
                </Dataset>
              </Combo>
              <Static id="staDetaRcrit00" taborder="14" text="이력구분" left="cboWkCnScValue:0" top="51" width="96" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Combo id="cboHstrScCd" taborder="15" left="staDetaRcrit00:0" width="100" height="30" index="-1" top="51" initvalueid="ivCmbNormal" accessibilitylabel="조회조건" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" text="" value="" displaynulltext="전체">
                <Dataset id="innerdataset">
