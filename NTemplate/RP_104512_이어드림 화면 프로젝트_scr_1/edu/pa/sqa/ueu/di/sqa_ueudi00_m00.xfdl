              <Edit id="edtCoaRcritScNm" taborder="3" left="staCoaRcritScNm:0" width="135" height="30" top="11" initvalueid="ivEdtReadOnly" readonly="true" text="수시" accessibilitylabel="모집구분"/>
              <Static id="staDetaRcrit" taborder="4" text="세부모집시기" left="edtCoaRcritScNm:0" top="11" width="120" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Combo id="cboDetaRcrit" taborder="5" left="staDetaRcrit:0" width="200" height="30" innerdataset="dsDetaRcritPrd" codecolumn="detaRcritScValue" datacolumn="detaRcritScNm" index="-1" top="11" initvalueid="ivCmbNormal" accessibilitylabel="조회조건"/>
              <Static id="staCddcOrgCd" taborder="6" text="시도교육청" left="cboDetaRcrit:0" top="10" width="108" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" onclick="divSearch_staCddcOrgCd_onclick"/>
              <Combo id="cboCddcScCd" taborder="7" left="staCddcOrgCd:0" width="200" height="30" innerdataset="dsCddcScCd" codecolumn="unyCdValue" datacolumn="unyCdValueNm" index="-1" top="10" initvalueid="ivCmbNormal" accessibilitylabel="조회조건"/>
              <Static id="staRcptnPrd" taborder="8" text="수신기간" left="0" top="51" width="108" cssclass="sta_WF_Searchtxt01" height="30" initvalueid="ivStcAccessibilityOn"/>
