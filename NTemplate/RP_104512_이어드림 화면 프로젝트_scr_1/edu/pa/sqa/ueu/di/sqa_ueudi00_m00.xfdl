              <Static id="Static65" taborder="10" text="~" left="calBgngYmd:0" top="51" width="15" height="30" cssclass="sta_WF_AC" initvalueid="ivStcAccessibilityOn" accessibilitylabel="부터"/>
              <Calendar id="calEndYmd" taborder="11" left="Static65:0" top="51" width="150" height="30" dateformat="yyyy.MM.dd" readonly="false" initvalueid="ivCalNormal" editformat="yyyy.MM.dd"/>
              <Static id="staWkCnScValue" taborder="12" text="작업구분" left="calEndYmd:0" top="51" width="96" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Combo id="cboWkCnScValue" taborder="13" left="staWkCnScValue:0" width="100" height="30" index="-1" top="51" initvalueid="ivCmbNormal" accessibilitylabel="조회조건" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" text="전체" value="" displaynulltext="전체">
