    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    대입전형자료수신이력조회
*  @FileName 	sqa_ueudi00_m00.xfdl
*  @Creator 	bsw
*  @CreateDate 	2023.03.20
*  @Desction    대입전형-대학-대입전형자료수신이력조회
************** 소스 수정 이력 ***********************************************
*  date				Modifier				Description
*******************************************************************************
*  2023.03.20		bsw					최초 생성
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose, ontimer)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리
 */
this.sqa_ueudi00_m00_onload = function(obj,e) {

	// Div 초기화
	this.smfInitDiv(obj);

//  	// Grid Checkbox 활성화/활성화 제어
//  	this.smfUpdateRednerGridCheckbox(this.grdList, 0, this.fnRenderGridCheckbox);
//
//  	// 조회 입력창에서 'Ctrl' + 'Enter' 키 입력시 조회수행 이벤트 설정
//  	this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
//
//  	// 데이터 입력 창에서 'Ctrl' + 'Enter' 키 입력시 저장수행 이벤트 설정
//  	this.smfBindEnterKeyToSearch(this.dsList, this.btnSave);

	//초기화
	this.fnInit(obj);

	// 서버단에 설정한 유효성 검증 목록을 획득하여 설정
	this.fnSearchValidation();
	
	//공통코드 조회
	this.fnSerachCmmCd();
	
	// 검정고시대입 공통조회
	this.fnOnloadSearch(obj, ["dsDetaRcritPrd"]);
		
};

/**
 * @description 폼 닫기전 이벤트
 */
this.sqa_ueudi00_m00_onbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	// 	// 변경내역이 발생한 경우 종료전 confirm수행
// 	return this.smfCloseFormConfirm([this.dsRreqApst]);
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리

************************************************************************************************/
/**
 * @description 유효성 검증 목록 조회
*/
this.fnSearchValidation = function() {
	this.smfValidateService("validateMain", {
			url: "/sqa_ueu_di00_001.do",
		})
		.mappingRulesetToForm(this.divSearch, "search")					//조회Valid
		.run()
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;
		});
};

/**
 * @description 공통코드 조회
*/
 this.fnSerachCmmCd = function() {		
	this.smfCodeList("code", [this.dsCddcScCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.divSearch.form.cboCddcScCd.set_index(0);

		})
		.run()
	;
};

/**
 * @description 시도전형자료수신현황 조회
*/
this.fnSearch = function() {	
	this.dsDtl.clearData();
	this.smfSearchService("listCtpvRcptnHstrPnsta")
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;			
		});
};

/**
 * @description 시도별 수신이력 상세조회
*/
this.fnSearchDtl = function(callback) {		

	
	this.smfSearchService("listCtpvRcptnHstrDtl")
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;			
		});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 초기화
*/
 this.fnInit = function(obj) {
	//세션정보 세팅
	this.dsSearch.setColumn(0, "coaAyr", this.sqav_coaAyr);
	this.dsSearch.setColumn(0, "coaRcritScCd", this.sqav_coaRcritScCd);
	this.dsSearch.setColumn(0, "coaRcritScNm", this.sqav_coaRcritScNm);
	this.dsSearch.setColumn(0, "uvstOrgCd", this.sqav_uvstOrgCd);
	this.dsSearch.setColumn(0, "rcptnBgngYmd", this.smfAddDate(this.smfToday(), -7));			//일주일세팅
	this.dsSearch.setColumn(0, "rcptnEndYmd", this.smfToday());
};

/**
* @description 검정고시 대입전형 공통조회 콜백
*/
this.fnOnloadSearchCallback = function() {
	//세부모집시기의 조건 - 사용중인 것만 나오도록
	var today = this.smfToday();
	//this.dsDetaRcritPrd.set_filterstr(today + " >= detaRcritScBgngYmd  && " + today + " <= detaRcritScEndYmd");
	this.dsSearch.setColumn(0, 'detaRcritScValue', this.dsDetaRcritPrd.getColumn(0, 'detaRcritScValue'));
	this.dsDetaRcritPrd.setColumn(this.dsDetaRcritPrd.insertRow(0), "detaRcritScNm", "선택");
	this.divSearch.form.cboDetaRcrit.set_index(0);
};

/**
* @description 조회 valid(수신기간체크)
*/
this.fnSearchValid = function()
{
	var bgngYmd = this.divSearch.form.calBgngYmd.value;
	var endYmd = this.divSearch.form.calEndYmd.value;
	
	if(this.smfIsNull(bgngYmd)) {
		if(!this.smfIsNull(endYmd)) {
			this.smfAlert("수신종료일자를 입력하여 주시기 바랍니다.");
			return false;
		}
	}
	
	if(this.smfIsNull(endYmd)) {
		if(!this.smfIsNull(bgngYmd)) {
			this.smfAlert("수신시작일자를 입력하여 주시기 바랍니다.");
			return false;
		}
	}
		
	if(!this.smfIsNull(bgngYmd) && !this.smfIsNull(endYmd)) {
		if(bgngYmd > endYmd) {
			this.smfAlert("수신시작일자가 수신종료일자보다 클 수 없습니다.");
			return false;
		}
	} 	
	
	return true;
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
* @description 조회
*/
this.divSearch_btnSearch_onclick = function(obj,e) {
	if(!this.fnSearchValid()) return;
	this.fnSearch();
};

/**
* @description 상세조회
*/
this.grdCddc_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{	
	var ds = this.dsPnsta;
	var cddcOrgCd = ds.getColumn(ds.rowposition, "cddcOrgCd") //cddcOrgCd = "K10" 3자리
	this.dsSearch.setColumn(0, "chcCddcOrgCd", cddcOrgCd);
	
	this.fnSearchDtl();
};]]></Script>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.edtCoaAyr" propid="value" datasetid="dsSearch" columnid="coaAyr"/>
      <BindItem id="item1" compid="divSearch.form.edtCoaRcritScNm" propid="value" datasetid="dsSearch" columnid="coaRcritScNm"/>
      <BindItem id="item2" compid="divSearch.form.calBgngYmd" propid="value" datasetid="dsSearch" columnid="rcptnBgngYmd"/>
      <BindItem id="item3" compid="divSearch.form.calEndYmd" propid="value" datasetid="dsSearch" columnid="rcptnEndYmd"/>
      <BindItem id="item4" compid="divSearch.form.cboDetaRcrit" propid="value" datasetid="dsSearch" columnid="detaRcritScValue"/>
      <BindItem id="item5" compid="divSearch.form.cboHstrScCd" propid="value" datasetid="dsSearch" columnid="hstrScCd"/>
      <BindItem id="item6" compid="divSearch.form.cboHstrScCd" propid="text" datasetid="dsSearch" columnid="hstrScCd"/>
      <BindItem id="item7" compid="divSearch.form.cboWkCnScValue" propid="value" datasetid="dsSearch" columnid="wrkCnScValue"/>
      <BindItem id="item8" compid="divSearch.form.cboWkCnScValue" propid="text" datasetid="dsSearch" columnid="wrkCnScValue"/>
      <BindItem id="item9" compid="divSearch.form.cboCddcScCd" propid="value" datasetid="dsSearch" columnid="cddcOrgCd"/>
    </Bind>
  </Form>
</FDL>
