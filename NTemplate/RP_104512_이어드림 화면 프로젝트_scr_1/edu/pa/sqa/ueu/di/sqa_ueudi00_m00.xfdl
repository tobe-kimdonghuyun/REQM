        <Div id="divSearch" taborder="1" left="0" top="144" height="92" initvalueid="ivDivAccessibilityOn" cssclass="div_WF_Search" text="" right="0" accessibilitylabel="조회영역">
          <Layouts>
            <Layout>
              <Static id="staCoaAyr" taborder="0" text="대입학년도" left="0" top="11" width="108" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtCoaAyr" taborder="1" left="staCoaAyr:0" width="80" height="30" top="11" initvalueid="ivEdtReadOnly" readonly="true" text="2024" accessibilitylabel="대입학년도"/>
