          <Column id="cddcOrgCd" type="STRING" size="256"/>
          <Column id="cddcOrgCdNm" type="STRING" size="256"/>
          <Column id="passYr" type="STRING" size="256"/>
          <Column id="passTme" type="STRING" size="256"/>
