    <Script type="xscript5.1"><![CDATA[/**
 *	대입전형자료수신자료출력
 *	@MenuPath	대입전형자료수신자료출력
 *	@FileName 	sqa_ueudi01_m00.xfdl
 *	@Creator 	bsw
 *	@CreateDate	2023.03.20
 *	@Desction	
 ************** 소스 수정 이력 ***********************************************
 *	date			Modifier			Description
 *******************************************************************************
 *	2022.09.30		bsw				최초 생성
 *  2024.05.20		진승환			학교폭력 관련 고교입학학교명 추가 (기술지원센터)
 *******************************************************************************
 */

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvCoaDataDownDecPath = this.sqafGetCoaDataDecPath();	  //복호화경로 
this.fvSendSize = 100;										  //임시로 100건으로 함.
this.fvCeckCnt = 0;											  //체크건수
this.fvBtnOtpt;												  //출력버튼여부(출력버튼/그리드셀클릭)
this.fv_arrDispName = [];									  //보고서명(마지막호출확인용)
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리
 */
this.sqa_ueudi01_m00_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

	// Div 초기화
	this.smfInitDiv(obj);

//  	// Grid Checkbox 활성화/활성화 제어
//  	this.smfUpdateRednerGridCheckbox(this.grdList, 0, this.fnRenderGridCheckbox);
//
//  	// 조회 입력창에서 'Ctrl' + 'Enter' 키 입력시 조회수행 이벤트 설정
//  	this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
//
//  	// 데이터 입력 창에서 'Ctrl' + 'Enter' 키 입력시 저장수행 이벤트 설정
//  	this.smfBindEnterKeyToSearch(this.dsList, this.btnSave);

	//초기화
	this.fnInit(obj);

	// 서버단에 설정한 유효성 검증 목록을 획득하여 설정
	this.fnSearchValidation();
	
	//공통코드 조회
	this.fnSerachCmmCd();
	
	// 검정고시대입 공통조회
	this.fnOnloadSearch(obj, ["dsDetaRcritPrd"]);	
};

/**
 * @description 폼 닫기전 이벤트
 */
this.fnOnbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
// 	// 변경내역이 발생한 경우 종료전 confirm수행
// 	return this.smfCloseFormConfirm([this.dsMain]);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
};

/**
 * @description 전형자료경로설정 팝업 콜백함수
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체 
 */
this.fnCoaDataPathCallback = function(e, sender){
	// 2023-09-19 복호화경로 폴더 참조 문제 수정
	this.fvCoaDataDownDecPath = this.sqafGetCoaDataDecPath();
	//this.fvCoaDataDownPath = nexacro.getPrivateProfile(this.sqav_coaDataPathValue);		//수신경로
}

/**
 * @description 폴더 권한확인 콜백
 * @param : isComplete - 완료 확인
 */
this.fnCheckFolderCallback = function(isComplete){
	if(!isComplete){
		return;
	}	
	this.fvPrcsType = 1;		//폴더권한확인
	this.fnReadFile();			//파일읽기
}

/**
* @description VirtualFile 콜백
*/
this.fnVirtualFileCallback = function(){

	var idx = this.dsFile.getColumn(0, "idx");							//dsRcptnApstOtpt의 인덱스	
	var coaSeleFileNm = this.dsFile.getColumn(0, "coaSeleFileNm");		//파일명
	var coaSeleFileCn = this.dsFile.getColumn(0, "coaSeleFileCn");		//파일내용
	var fileExist = this.dsFile.getColumn(0, "fileExist");				//파일존재여부
	
	//dsFile >> dsOz 데이터 복사
	this.dsOz.addRow();													//oz출력 파일정보 ds
	var i = this.dsOz.rowcount - 1										//oz출력ds 인덱스
	this.dsOz.setColumn(i, "idx", idx);									//dsRcptnApstOtpt의 인덱스
	this.dsOz.setColumn(i, "coaSeleFileNm", coaSeleFileNm);				//파일명
	this.dsOz.setColumn(i, "coaSeleFileCn", coaSeleFileCn);				//파일내용
	this.dsOz.setColumn(i, "fileExist", fileExist);						//파일존재여부
	
	this.dsFile.deleteRow(0);											//선택한대상의 파일정보 ds
	this.dsOtpt.deleteRow(0);											//선택한대상ds
	
	//선택한 대상을 복사한 dsOtpt 건수 체크
	if(this.dsOtpt.rowcount > 0) {
		this.fnReadFile();												//파일읽기
	} else {
		this.fnOzOtpt();												//oz출력
	}
}

/**
* @description VirtualFile 보고서 업로드 완료 콜백
*/
this.fnReportLoadCallback = function (obj,sDisplayName) {
	var nIdx = this.fv_arrDispName.indexOf(sDisplayName);
	if(nIdx>-1) this.fv_arrDispName.splice(nIdx,1);
	if(this.fv_arrDispName.length==0 && this.dsOz.getCaseCount("fileExist =='false'") > 0)
	{
		this.smfAlert("파일이 존재하지 않는 대상이 있습니다.");
	}
}	
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 유효성 검증 목록 조회
*/
this.fnSearchValidation = function() {
	this.smfValidateService("validateMain", {
			url: "/sqa_ueu_di01_001.do",
		})
		.mappingRulesetToForm(this.divSearch, "search")					//조회Valid
		.run()
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;
		});
};

/**
 * @description 공통코드 조회
*/
 this.fnSerachCmmCd = function() {		
	this.smfCodeList("code", [this.dsCddcScCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.divSearch.form.cboCddcScCd.set_index(0);
		})
		.run()
	;
};

/**
 * @description 수신자료출력정보(콤보박스) 조회
*/
this.fnSearchCbo = function() {	
	this.smfSearchService("selectRcptnOtptInfo")
		.run() // 실행
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;			
			
			this.divSearch.form.cboUvstSprtDddepNm.set_index(0)
			this.divSearch.form.cboSeleScNm.set_index(0)
			this.divSearch.form.cboRcrtiUnitNm.set_index(0)
		});
};

/**
 * @description 자료수신지원자출력 조회
*/
this.fnSearch = function() {
	this.smfSearchService("listRctpnApstOtpt")
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;			
		});
}

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 초기화
*/
 this.fnInit = function(obj) {
	//세션정보 세팅
	this.dsSearch.setColumn(0, "coaAyr", this.sqav_coaAyr);
	this.dsSearch.setColumn(0, "coaRcritScCd", this.sqav_coaRcritScCd);
	this.dsSearch.setColumn(0, "coaRcritScNm", this.sqav_coaRcritScNm);
	this.dsSearch.setColumn(0, "uvstOrgCd", this.sqav_uvstOrgCd);
};

/**
* @description 검정고시 대입전형 공통조회 콜백
*/
this.fnOnloadSearchCallback = function() {
	//세부모집시기의 조건 - 사용중인 것만 나오도록
	var today = this.smfToday();
	//this.dsDetaRcritPrd.set_filterstr(today + " >= detaRcritScBgngYmd  && " + today + " <= detaRcritScEndYmd");
	this.dsSearch.setColumn(0, 'detaRcritScValue', this.dsDetaRcritPrd.getColumn(0, 'detaRcritScValue'));
	this.dsDetaRcritPrd.setColumn(this.dsDetaRcritPrd.insertRow(0), "detaRcritScNm", "선택");
	this.divSearch.form.cboDetaRcrit.set_index(0);
	this.fnSearchCbo();	
};

/**
* @description 조회 validation
*/
this.fnSearchValid = function() {	
	
	this.staChcCnt.set_text("선택건수 : 0");
	
	//주민등록번호 자리수 체크(입력한경우)
	var trprRrno = this.dsSearch.getColumn(0, "trprRrno");
	if(!this.smfIsNull(trprRrno)) {
		if(trprRrno.length != 13) {
			this.smfAlert("주민등록번호 13자리를 입력하여주십시오.");
			return false;
		}
	}	
	
	return true;
}

/**
* @description 선택건수 세팅
*/
this.fnSetCeckCnt = function() {
	this.fvCeckCnt = this.dsRcptnApstOtpt.getCaseCount("_chk =='1'");
	this.staChcCnt.set_text("선택건수 : " + this.fvCeckCnt);
}

/**
* @description 자료출력 validation
*/
this.fnOtptValid = function(row) {	
	this.dsFile.clearData();	//파일정보ds초기화
	this.dsOz.clearData();		//오즈정보ds초기화
	this.dsOtpt.clearData();	//출력대상ds초기화
		
	if(!this.smfIsNull(row)) {		//그리드 셀클릭 출력 시
		
		this.fvBtnOtpt = "N";		//출력버튼여부(출력버튼/셀클릭)
		
		//셀클릭시 나머지 체크 해제 후 해당 셀 체크
		for(var i = 0 ; i < this.dsRcptnApstOtpt.rowcount; i++) {
			this.dsRcptnApstOtpt.setColumn(i, "_chk", "0");						//그리드 체크박스 초기화
		}
		
		this.dsRcptnApstOtpt.setColumn(row, "_chk", "1");						//해당로우 체크
		this.grdApst.setCellProperty("head", 0, "expr", "0");					//그리드헤더(전체선택/전체해제) 해제		
		this.dsOtpt.copyRow(this.dsOtpt.addRow(), this.dsRcptnApstOtpt, row)	//출력대상복사
		this.dsOtpt.setColumn(this.dsOtpt.rowcount - 1, "idx", row);			//인덱스세팅(dsRcptnApstOtpt인덱스)		
		this.fnSetCeckCnt();
	} else {	
		this.fvBtnOtpt = "Y";	//출력버튼여부(출력버튼/셀클릭)
		
		if(this.dsRcptnApstOtpt.getRowCount() == 0 ) {
			this.smfAlert("자료를 출력할 지원자가 없습니다.");
			return false; 
		};
		
		if(this.fvCeckCnt == 0 ) {
			this.smfAlert("자료를 출력할 지원자를 먼저 선택하여 주십시오.");
			return false;
		}
		
		//출력하고자 선택한 대상 복사 dsRcptnApstOtpt > dsOtpt
		for(var i = 0 ; i < this.dsRcptnApstOtpt.rowcount; i++) {
			if(this.dsRcptnApstOtpt.getColumn(i, "_chk") == "1") {
				this.dsOtpt.copyRow(this.dsOtpt.addRow(), this.dsRcptnApstOtpt, i)	//출력대상복사
				this.dsOtpt.setColumn(this.dsOtpt.rowcount - 1, "idx", i);			//인덱스세팅(dsRcptnApstOtpt인덱스)
			}
		}		
	}
	
	return true;
}

/**
 * @description 폴더 권한 확인
 */
this.fnCheckFolder = function(){
	this.fvPrcsType = 0;

	if(this.smfIsNull(this.sqafGetCoaDataPath())) {
		this.smfAlert("전형자료복호화 경로가 존재하지 않습니다.");
		return;
	}	
	
	this.VirtualFile00.isExist(this.sqafGetCoaDataPath());
}

/**
 * @description 오즈 데이터 생성
 */
this.fnOzOtpt = function(){
	var ozDatas = [];					//oz출력 데이터
	var cnt = this.dsOz.rowcount;		//파일 읽은 후 오즈 출력을 위해 복사한 dsOz건수
	
	for(var i = 0; i < cnt; i++){
		var idx = this.dsOz.getColumn(i, "idx");															//dsRcptnApstOtpt의 인덱스
		var fileNm = this.dsOz.getColumn(i, "coaSeleFileNm");												//파일명
		var coaSeleFileCn = this.dsOz.getColumn(i, "coaSeleFileCn");										//파일내용
		var fileExist = this.dsOz.getColumn(i, "fileExist") == "true" ? true : false;						//파일여부
		var seleScNm = this.dsRcptnApstOtpt.getColumn(idx, "seleScNm");										//전형구분명
		var rcritUnitNm = this.dsRcptnApstOtpt.getColumn(idx, "rcritUnitNm");								//모집구분명
		var uvstExmtNo = this.dsRcptnApstOtpt.getColumn(idx, "uvstExmtNo");									//수험번호
				
		//파일내용, 파일존재 하는 경우 csv생성
		if(!this.smfIsNull(coaSeleFileCn) || fileExist) {			
			ozDatas.push({
				'title' : fileNm,
				'csv' : this.fnTransOzData(seleScNm, rcritUnitNm, uvstExmtNo, fileNm, coaSeleFileCn)		//csv데이터 생성
			});
		}
	}
	
	this.fnShowOzReport(ozDatas);		//oz 호출	
}

/**
 * @description 오즈 데이터 생성
 * @param : coaSeleFileCn - 대입전형자료
 * @param : coaImageFileCn - 대입전형자료이미지
 * @return : csv - 오즈 데이터
 */
this.fnTransOzData = function(seleScNm, rcritUnitNm, uvstExmtNo, fileNm, coaSeleFileCn){

	var otptInfo = this.getOtptInfo();						//출력정보(기관명/금일/IP/사용자명)
	var csvData = "";										//csv데이터(csv_1 + csv_2)
	var csv_1 = "";											//csv_1(시도코드,주민등록번호,전형구분명,모집구분명,수험번호,출력정보,이름,합격발표일,증서번호,총점,평균)
	var csv_2= "";											//csv_2(필수선택,과목,점수,합격년월일,비고)   
	var row = coaSeleFileCn.split('\r\n');					//라인별 파일읽기
	
	if(coaSeleFileCn.length > 0 ) {
		for(var i = 0; i < row.length; i++) {
			var data = row[i].split("^");	
			var chckStr = data[0].substring(0,1);
			
			if(chckStr.match(/0/gi)) {			//첫번째줄(1:시도코드,2:주민등록번호)
				csv_1 += data[1] + "#$!" + data[2] + "#$!" + seleScNm + "#$!" + rcritUnitNm
					     + "#$!" + uvstExmtNo + "#$!" + otptInfo + "#$!";	
			}
				
			if(chckStr.match(/1/gi)) {				//두번째줄(3:이름,4:학교명)
				csv_1 += data[3] + "#$!" + data[4] + "#$!"	
			}
			
			if(chckStr.match(/2/gi)) {				//세번째줄(3:합격발표일,4:증서번호,5:총점,6:평균)
				csv_1 += data[3] + "#$!" + data[4] + "#$!" +  data[5] + "#$!" + data[6] + "#$!^&*";
			}
			
			if(chckStr.match(/3/gi)) {				//세번째줄(4:필수선택,6:과목,7:점수:8:합격년월일
				csv_2 += "^&*" + data[4] + "#$!" + data[6] + "#$!" +  data[7] + "#$!" + data[8] + "" + "#$!";
			}
		}	
		csvData += csv_1 + "//EOR//" + csv_2;
	} else {
		csvData += "//EOR////EOR//";
	}
	
	return csvData;
}

/**
 * @description 오즈 뷰 호출
 * @param : aData - 오즈 데이터 배열 ( csv )
 */
this.fnShowOzReport = function(aData){
	var reports = aData.reduce((a,v,i) => {
		a.push({
			// 기본데이터
			  displayname	: v.title   // [필수] 멀티리포트시 Tree에 보여줄 이름
			, reportname	: '/edu/pa/sqa/ueu/di/sqa_ueudi01_r01.ozr' // [필수] 리포트명  "/jsonsample.ozr"
			// , reportname	: '/edu/pa/sqa/ueu/di/sqa_ueudi01_r00.ozr' // [필수] 리포트명  "/jsonsample.ozr"
			, jsonParam	: ["viewerType=HTML5 Canvas Viewer 1"]
			, csvData    : v.csv                               // [선택] csv데이터
			, security		: "N"	// [선택] 위변조방지 삽입   ("Y"(default):표시,"N":비표시)
			, voiceBarcode	: "N"	// [선택] 보이스바코드 삽입 ("Y"(default):표시,"N":비표시)		
			, zoom : "75"   // [선택] 보고서 화면의 비율을 백분율로 설정(default:"100")
		});
		return a;
	}, []);
		
	var oOzOption = {
		  'reports' : reports
		, 'zoom' : 75
		, 'reportloadevent' : this.fnReportLoadCallback    // [선택] 레포트 로드된 이후 불려지는 함수(인쇄시에도 발생)
	}
	
	// 멀티리포트의 완료 이벤트를 받을 경우
	this.fv_arrDispName = [];
	for(var i=0;i<oOzOption.reports.length;i++)
	{
		this.fv_arrDispName.push( oOzOption.reports[i].displayname);
	}	
	
	this.smfReportView(this, "embedded", oOzOption, this.divReportViewer);
}

/**
* @description virtualFile 생성
*/
this.fnReadFile = function() {
	this.dsFile.copyRow(this.dsFile.addRow(), this.dsOtpt, 0);			//선택한대상ds > 파일정보ds 복사
	//this.VirtualFile00.open(this.fvCoaDataDownDecPath + this.dsFile.getColumn(0, "coaSeleFileNm")+".dec", VirtualFile.openText | VirtualFile.openRead);
	this.VirtualFile00.open(this.fvCoaDataDownDecPath + this.dsFile.getColumn(0, "coaSeleFileNm"), VirtualFile.openText | VirtualFile.openRead);
}

/**
* @description virtualFile 성공
*/
this.VirtualFile00_onsuccess = function(obj:nexacro.VirtualFile,e:nexacro.VirtualFileEventInfo)
{	
	if(this.fvPrcsType == 0){ //폴더 권한 확인
		if(e.reason == 10) {	//isExist complete
			if(e.fileisexist){
				this.fnCheckFolderCallback(true);
			} 
		} else{
			this.smfAlert("전형자료경로가 존재하지 않습니다.", function(){
				this.fnCheckFolderCallback(false);
			});
		}
	} else {
		if(e.reason == 1){	//open complete
			obj.read(e.filesize, 'utf-8');								//파일읽기
		} else if(e.reason == 2){ //close complete
			this.fnVirtualFileCallback();
		} else if(e.reason == 3){ //read complete
			this.dsFile.setColumn(0,"fileExist", "true");				//파일여부
			this.dsFile.setColumn(0, "coaSeleFileCn", e.textdata);		//복호화 상태인 파일
			obj.close();
		}
	}
};

/**
* @description virtualFile 에러
*/
this.VirtualFile00_onerror = function(obj:nexacro.VirtualFile,e:nexacro.VirtualFileErrorEventInfo)
{
	if(this.fvPrcsType == 0){ //폴더 권한 확인
		if(e.statuscode == '1102'){ //Permission Denied
			this.smfAlert("자료복호화경로에 접근권한이 없습니다.", function(){
				this.fnCheckFolderCallback(false);
			});
		}else if(e.statuscode == '1105'){ //Does not exist
			this.smfAlert("자료복호화경로가 존재하지 않습니다.", function(){
				this.fnCheckFolderCallback(false);
			});
		}
	} else {	
		if(e.statuscode == '1105') {			//파일이 존재하지 않을 경우(출력버튼/셀클릭)
			if(this.fvBtnOtpt  == "N") {
				this.smfAlert("자료복호화경로에 파일이 존재하지 않습니다.", function(){
					this.fnCheckFolderCallback(false);
				});	
			} else {							
				this.dsFile.setColumn(0,"fileExist", "false");			//파일여부
				var idx = this.dsFile.getColumn(0, "idx");				//dsRcptnApstOtpt의 인덱스
				this.dsRcptnApstOtpt.setColumn(idx, "_chk", "0");		//체크여부 해제
				this.fnSetCeckCnt();									//선택건수세팅
				this.fnVirtualFileCallback();
			}	
		}
	}	
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 그리드 헤더 클릭
 */
this.grdApst_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var columnName = obj.getCellProperty("body",e.cell,"text");
	if ("bind:_chk" == columnName){
		this.smfToggleChkHeader(obj, e, this.fnRenderGridCheckbox);
	}else{
		// 정렬
		this.smfCheckAndSort(obj, e);
	}	
	this.fnSetCeckCnt();		//선택건수세팅
};

 /**
 * @description 그리드 셀 클릭(보고서출력)
 */
 this.grdApst_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if(e.cell != 0){		
		if(!this.fnOtptValid(e.row)) return;			
		this.fnCheckFolder();	//폴더 권한확인											
	} else {		
		this.fnSetCeckCnt(); 	//선택건수 세팅
	}
};

/**
 * @description 조회
 */
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	if(!this.fnSearchValid()) return;
	this.fnSearch();
};

/**
* @description 경로설정 팝업
*/
this.btnPath_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 팝업 파라메터
	var popupParams = {
		callback: this.fnCoaDataPathCallback, // 콜백함수 지정
		sender: obj, // sender 지정
		params: {
			procType: "search" // 처리타입 지정
		  , dsParam :  this.dsSearch
		},
	};

	// 모달팝업 실행
	this.smfDialog("sqa_ueudd00_p00", "pa_sqa_ueu_dd::sqa_ueudd00_p00.xfdl", popupParams);
};

/**
* @description 출력
*/
this.btnReportView_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	if(!this.fnOtptValid()) return;	
	
	//폴더 권한확인
	this.fnCheckFolder();	
	
};]]></Script>
