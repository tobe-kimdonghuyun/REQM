    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSearch" oncolumnchanged="dsSearch_oncolumnchanged">
        <ColumnInfo>
          <Column id="coaAyr" type="STRING" size="256"/>
          <Column id="coaRcritScCd" type="STRING" size="256"/>
          <Column id="coaRcritScNm" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <LiteDBConnection id="LiteDBConnection" onerror="LiteDB_onerror" onsuccess="LiteDB_onsuccess"/>
      <LiteDBStatement id="LiteDBStatement" onerror="LiteDB_onerror" onsuccess="LiteDB_onsuccess" ldbconnection="LiteDBConnection"/>
      <VirtualFile id="VirtualFile" onerror="VirtualFile_onerror" onsuccess="VirtualFile_onsuccess"/>
      <Dataset id="dsTables" useclientlayout="true">
        <ColumnInfo>
          <Column id="itemNo" type="STRING" size="256"/>
          <Column id="name" type="STRING" size="256"/>
          <Column id="ddl" type="STRING" size="256"/>
          <Column id="rmkCn" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="name">GedStudentBaseInfo</Col>
            <Col id="rmkCn">기본정보</Col>
            <Col id="ddl">CREATE TABLE IF NOT EXISTS GedStudentBaseInfo (Mogib1 VARCHAR(1), Mogib2 VARCHAR(1), UniqueFileName VARCHAR(255), EduOfficesCode VARCHAR(10), SocialNumber VARCHAR(13), SeqNumber INTEGER, Department VARCHAR(255), CONSTRAINT sqlite_autoindex_GedStudentBaseInfo_1 PRIMARY KEY (Mogib1,Mogib2,UniqueFileName,EduOfficesCode,SocialNumber,SeqNumber))</Col>
            <Col id="itemNo">0</Col>
          </Row>
          <Row>
            <Col id="rmkCn">인적사항</Col>
            <Col id="name">GedPersonalInfo</Col>
            <Col id="ddl">CREATE TABLE IF NOT EXISTS GedPersonalInfo (Mogib1 VARCHAR(1), Mogib2 VARCHAR(1), UniqueFileName VARCHAR(255), EduOfficesCode VARCHAR(10), SocialNumber VARCHAR(13), SeqNumber INTEGER, AcceptedYear VARCHAR(4), AcceptedTimes INTEGER, Name VARCHAR(40), SeleScNm VARCHAR(60), InvitationUnit VARCHAR(200), ExamNumber VARCHAR(30), SchoolName VARCHAR(300), CONSTRAINT sqlite_autoindex_GedPersonalInfo_1 PRIMARY KEY (Mogib1,Mogib2,UniqueFileName,EduOfficesCode,SocialNumber,SeqNumber))</Col>
            <Col id="itemNo">1</Col>
          </Row>
          <Row>
            <Col id="name">AcceptedInfo</Col>
            <Col id="rmkCn">합격정보</Col>
            <Col id="ddl">CREATE TABLE IF NOT EXISTS AcceptedInfo (Mogib1 VARCHAR(1), Mogib2 VARCHAR(1), UniqueFileName VARCHAR(255), EduOfficesCode VARCHAR(10), SocialNumber VARCHAR(13), SeqNumber INTEGER, AcceptedYear VARCHAR(4), AcceptedTimes INTEGER, CertificateNumber VARCHAR(20), AcceptedDate VARCHAR(8), EvaluateTotalScore VARCHAR(6), EvaluateAverageScore VARCHAR(5), ValidYN VARCHAR(1), CONSTRAINT sqlite_autoindex_AcceptedInfo_1 PRIMARY KEY (Mogib1,Mogib2,UniqueFileName,EduOfficesCode,SocialNumber,SeqNumber))</Col>
            <Col id="itemNo">2</Col>
          </Row>
          <Row>
            <Col id="rmkCn">성적증명</Col>
            <Col id="name">SubjectScore</Col>
            <Col id="ddl">CREATE TABLE IF NOT EXISTS SubjectScore (Mogib1 VARCHAR(1), Mogib2 VARCHAR(1), UniqueFileName VARCHAR(255), EduOfficesCode VARCHAR(10), SocialNumber VARCHAR(13), SeqNumber INTEGER, AcceptedYear VARCHAR(4), AcceptedTimes INTEGER, SubjectReqCode VARCHAR(1), SubjectReqName VARCHAR(50), SubjectCode VARCHAR(6), SubjectName VARCHAR(300), SubjectScore VARCHAR(6), AcceptedDate VARCHAR(8), ValidYN VARCHAR(1), CONSTRAINT sqlite_autoindex_SubjectScore_1 PRIMARY KEY (Mogib1,Mogib2,UniqueFileName,EduOfficesCode,SocialNumber,SeqNumber))</Col>
            <Col id="itemNo">3</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
 *	전형자료로컬DB생성
 *	@MenuPath	대입전형-전형자료복호화-전형자료로컬DB생성
 *	@FileName 	sqa_ueudd01_p01.xfdl
 *	@Creator 	진승환
 *	@CreateDate	2023.08.10 
 *	@Desction	
 ************** 소스 수정 이력 ***********************************************
 *	date			Modifier			Description
 *******************************************************************************
 *	2023.08.10		진승환				최초 생성
 *  2024.05.20		진승환				DB3 파일에 학교폭력 관련 고교입학학교명 추가 (기술지원센터)
 *******************************************************************************
 */

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::sqa_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvCoaDataDownPath = this.sqafGetCoaDataDownPath();   	// 수신경로
this.fvCoaDataBlindPath = this.sqafGetCoaDataDecPath(); 	// 복호화자료경로

this.fvSems = 'SEMS'
this.fvDbNm = 'StudentCarrer.db3';
this.fvQueWrks = null;
this.fvPath = '';
this.fvLogPerPend = ''; // 복호화자료
this.fvIsBld = false;
this.fvBgngTime = null;
this.fvEndTime = null;
this.fvLog = [];

const JOB_TYPE = {
	EXECUTE_QUERY : 'executeQuery',
	EXECUTE_QUERY_CALLBACK : '7',
	EXECUTE_UPDATE : 'executeUpdate',
	EXECUTE_UPDATE_CALLBACK : '8',
	EXECUTE : 'execute',
	CONN_OPEN : 'connOpen',
	CONN_OPEN_CALLBACK : '5',
	CONN_BEGIN : 'connBegin',
	CONN_BEGIN_CALLBACK : '1',
	CONN_CLOSE : 'connClose',
	CONN_CLOSE_CALLBACK : '2',
	CONN_COMMIT : 'connCommit',
	CONN_COMMIT_CALLBACK : '3',
	STMT_CLOSE : 'stmtClose',
	STMT_CLOSE_CALLBACK : '9',
}
Object.freeze(JOB_TYPE);

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	
	// 초기화
	this.fnInit(obj); 
	
	// 조회
	this.fnSearch();
};

/**
 * @description 폼 닫기전 이벤트
 */
this.fnOnbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	// 변경내역이 발생한 경우 종료전 confirm수행
	return this.smfCloseFormConfirm([this.dsMain]);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 조회
*/
this.fnSearch = function()
{
	// this.fnListCoaPrge();
	// this.fnListEvlUnitCd();
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/**
 * @description 초기화 FUNCTION
 */
this.fnInit = function(obj){
	this.dsSearch.setColumn(0, "coaAyr", this.sqav_coaAyr);
	this.dsSearch.setColumn(0, "coaRcritScCd", this.sqav_coaRcritScCd);
	this.dsSearch.setColumn(0, "coaRcritScNm", this.sqav_coaRcritScNm);
	
	var coaDataPath = nexacro.getPrivateProfile(this.sqav_coaDataPathValue);
	if(this.smfIsNull(coaDataPath)) return false;
	
	this.divMain.form.edtCoaDataPath.set_value(coaDataPath);
	this.divMain.form.txtCoaDataDtlPath.set_value(this.sqafGetCoaDataDtlPath(coaDataPath));
	
	this.fvQueWrks = this.sqafCreateQueue();
}

/**
 * @description 문자열 확인
 */
this.fnIsStr = (s) => typeof s == 'string';

/**
 * @description 다음 작업 실행
 */
this.fnDoNext = function(){
	var wrk = this.fvQueWrks.first();
	if(!this.smfIsNull(wrk)){
		wrk.action();
	}else{
		this.setWaitCursor(false);
		//this.smfAlert(this.fvPath + '\n\n' + this.fvLogPerPend + ' 이관 작업이 완료되었습니다.')
		this.smfAlert(this.fvLogPerPend + ' 이관 작업이 완료되었습니다.')
	}
}

/**
 * @description 에러처리
 */
this.fnOnError = function(msg){
	this.setWaitCursor(false);
	this.fnShowLog(msg);
	this.smfAlert(msg);
}

this.fnShowLog = function(msg){
	if(Array.isArray(msg)){
		for(var i = 0; i < msg.length; i++){
			if(this.fvLog.length > 100) this.fvLog.shift();
			this.fvLog.push('[' + this.smfTodayTime().dateFormat('yyyy.MM.dd hh:mm:ss') + '] ' + msg[i]);
		}
	}else{
		if(this.fvLog.length > 100) this.fvLog.shift();
		this.fvLog.push('[' + this.smfTodayTime().dateFormat('yyyy.MM.dd hh:mm:ss') + '] ' + msg);	
	}

	this.divMain00.form.txtLog.set_value(this.fvLog.join('\n'));
	//this.divMain00.form.txtLog.vscrollbar.set_pos(this.divMain00.form.txtLog.vscrollbar.max);
}

this.fnGetVrfcQuery = function(mogib1, mogib2, uniqueFileName, eduOfficesCode, socialNumber, seqNumber){
	return `
	--기본정보
	SELECT '0'
		|| '^'
		|| IFNULL(A.EduOfficesCode, '/NULL/')
		|| '^'
		|| IFNULL(A.SocialNumber, '/NULL/')
		|| '^'
		|| IFNULL(A.Department, '/NULL/')
		|| '^'
		|| IFNULL(B.SeleScNm, '/NULL/')
		|| '^'
		|| IFNULL(B.InvitationUnit, '/NULL/')
		|| '^'
		|| IFNULL(B.ExamNumber, '/NULL/')
		|| '^' AS CoaData
	  FROM GedStudentBaseInfo	A
	 INNER JOIN GedPersonalInfo	B
	    ON A.Mogib1			= B.Mogib1
	   AND A.Mogib2			= B.Mogib2
	   AND A.UniqueFileName	= B.UniqueFileName
	   AND A.EduOfficesCode	= B.EduOfficesCode
	   AND A.SocialNumber	= B.SocialNumber
	   AND A.SeqNumber		= B.SeqNumber
	 WHERE A.Mogib1 		= '${mogib1}'
	   AND A.Mogib2 		= '${mogib2}'
	   AND A.UniqueFileName = '${uniqueFileName}'
	   AND A.EduOfficesCode = '${eduOfficesCode}'
	   AND A.SocialNumber 	= '${socialNumber}'
	   AND A.SeqNumber 		= '${seqNumber}'
	 UNION ALL
	--인적사항
	SELECT '1'
		|| '^'
		|| IFNULL(AcceptedYear, '/NULL/')
		|| '^'
		|| IFNULL(AcceptedTimes, '/NULL/')
		|| '^'
		|| IFNULL(Name, '/NULL/')
		|| '^' 
		|| IFNULL(SchoolName, '/NULL/')
		|| '^' AS CoaData
	  FROM GedPersonalInfo
	 WHERE Mogib1 = '${mogib1}'
	   AND Mogib2 = '${mogib2}'
	   AND UniqueFileName = '${uniqueFileName}'
	   AND EduOfficesCode = '${eduOfficesCode}'
	   AND SocialNumber = '${socialNumber}'
	   AND SeqNumber = '${seqNumber}'
	 UNION ALL
	--합격정보
	SELECT '2'
		|| '^'
		|| IFNULL(AcceptedYear, '/NULL/')
		|| '^'
		|| IFNULL(AcceptedTimes, '/NULL/')
		|| '^'
		|| IFNULL(AcceptedDate, '/NULL/')
		|| '^'
		|| IFNULL(CertificateNumber, '/NULL/')
		|| '^'
		|| IFNULL(EvaluateTotalScore, '/NULL/')
		|| '^'
		|| IFNULL(EvaluateAverageScore, '/NULL/')
		|| '^' AS CoaData
	  FROM AcceptedInfo
	 WHERE Mogib1 = '${mogib1}'
	   AND Mogib2 = '${mogib2}'
	   AND UniqueFileName = '${uniqueFileName}'
	   AND EduOfficesCode = '${eduOfficesCode}'
	   AND SocialNumber = '${socialNumber}'
	   AND SeqNumber = '${seqNumber}'
	 UNION ALL
	--성적증명
	SELECT * FROM (
	SELECT '3'
		|| '^'
		|| IFNULL(AcceptedYear, '/NULL/')
		|| '^'
		|| IFNULL(AcceptedTimes, '/NULL/')
		|| '^'
		|| IFNULL(SubjectReqCode, '/NULL/')
		|| '^'
		|| IFNULL(SubjectReqName, '/NULL/')
		|| '^'
		|| IFNULL(SubjectCode, '/NULL/')
		|| '^'
		|| IFNULL(SubjectName, '/NULL/')
		|| '^'
		|| IFNULL(SubjectScore, '/NULL/')
		|| '^'
		|| IFNULL(AcceptedDate, '/NULL/')
		|| '^' AS CoaData
	  FROM SubjectScore
	 WHERE Mogib1 = '${mogib1}'
	   AND Mogib2 = '${mogib2}'
	   AND UniqueFileName = '${uniqueFileName}'
	   AND EduOfficesCode = '${eduOfficesCode}'
	   AND SocialNumber = '${socialNumber}'
	 ORDER BY SeqNumber
	)
	`
}

/**
 * @description 데이터베이스 파일 생성
 */
this.fnWrkCreateDatabase = function(path){
	var _cmd = 'create_database';
	var _that = this;
	var _virf = this.VirtualFile;
	var _path = path;
	
	function complete(){
		_that.fnShowLog.call(_that, _that.fvLogPerPend + ' 로컬 데이터베이스 파일 생성이 완료되었습니다.');
		_that.fvQueWrks.dequeue();
		_that.fnDoNext.call(_that);
	}
	
	function error(e){
		var statuscode = (!_that.smfIsNull(e) && e.statuscode) ? e.statuscode : '9999';
		_that.fnOnError.call(_that, '(' + statuscode + ')' + _that.fvLogPerPend + ' 로컬 데이터베이스 파일 생성 중 오류가 발생하였습니다.');
	}
	
	function action(){
		_that.fnShowLog.call(_that, _that.fvLogPerPend +  ' 로컬 데이터베이스 파일 생성을 시작하였습니다.');
		_virf.isExist(_path);
	}
	
	function next(e){
		if(e.reason == '10'){ //isExist
			if(!e.fileisexist){
				_virf.open(_path, VirtualFile.openWrite);
			}else{
				complete();
			}
		}else if(e.reason == '1'){ //open
			_virf.close();
		}else if(e.reason == '2'){ //close
			complete();
		}else{
			error();
		}
	}
	
	return {cmd : () => _cmd, path : () => _path, action : action, next : next, error : error}
}

/**
 * @description 데이터베이스 테이블 생성
 */
this.fnWrkCreateTables = function(path){
	var _cmd = 'create_tables';
	var _that = this;
	var _conn = this.LiteDBConnection;
	var _stmt = this.LiteDBStatement;
	var _path = path;
	var _queTables = this.sqafCreateQueue();
	
	_queTables.init(JSON.parse(this.dsTables.saveJSON()).Rows);
	
	function complete(){
		_that.fnShowLog.call(_that, _that.fvLogPerPend + ' 로컬 데이터베이스 테이블 생성이 완료되었습니다.(' + _path + ')');
		_that.fvQueWrks.dequeue();
		_that.fnDoNext.call(_that);
	}
	
	function error(e){
		var statuscode = (!_that.smfIsNull(e) && e.statuscode) ? e.statuscode : '9999';
		var tableNm = _queTables.first() ? _queTables.first().rmkCn : '데이터베이스';
		
		var msg = '(' + statuscode + ')' +  _that.fvLogPerPend + ' ' + tableNm + ' 테이블 생성 중 오류가 발생하였습니다.';
		
		_that.fnOnError.call(_that, msg);
	}

	function action(){
		_that.fnShowLog.call(_that, _that.fvLogPerPend +  ' 로컬 데이터베이스 테이블 생성을 시작하였습니다.');
		_conn.set_datasource(_path);
		_stmt.set_ldbconnection(_conn);
		_conn.open(_path);
	}
	
	function executeUpdate(){
		_stmt.executeUpdate(_queTables.first().ddl);
	}
	
	function next(e){
		if(e.reason == '5'){ //open
			_conn.begin();
		}else if(e.reason == '1'){ //begin
			executeUpdate();
		}else if(e.reason == '8'){ //executeUpdate
			_queTables.dequeue();
			if(_queTables.isEmpty()){
				_stmt.close();
			}else{
				executeUpdate();
			}
		}else if(e.reason == '9'){ //close (statement)
			_conn.commit();
		}else if(e.reason == '3'){ //commit
			_conn.close();
		}else if(e.reason == '2'){ //close
			complete();
		}else{
			error();
		}
	}
	
	return {cmd : () => _cmd, path : () => _path, action : action, next : next, error : error}
}

/**
 * @description SEMS 파일을 데이터베이스에 저장
 */
this.fnWrkSemsToDatabase = function(path){
	var _cmd = 'sems_to_database';
	var _that = this;
	var _virf = this.VirtualFile;
	var _conn = this.LiteDBConnection;
	var _stmt = this.LiteDBStatement;
	var _path = path;
	var _idx = 0;
	var _tables = JSON.parse(this.dsTables.saveJSON()).Rows;
	var _tableSchema = null;
	var _folder = null;
	var _queStu = this.sqafCreateQueue();
	var _queJob = this.sqafCreateQueue();
	var _cmptnStu = []; //완료 학생
	
	var _deletedTables = {}; //삭제한 테이블
	
	var _totCnt = 0; 	//총 학생수
	var _newCnt = 0;	//신규학생수
	var _modCnt = 0;	//변경학생수
	
	function complete(){
		_that.fvEndTime = Date.now();
		
		var strTime = '';
		var sec = (_that.fvEndTime - _that.fvBgngTime) / 1000.0;
		if(sec >= 60){
			strTime = Math.floor(sec / 60) + '분 ' + Math.floor(sec % 60) + '초';
		}else{
			strTime = sec + '초';
		}
		
		_that.fnShowLog.call(_that, [_that.fvLogPerPend +  ' 로컬 데이터베이스 이관 및 검증 작업이 완료되었습니다.'
									, '처리파일갯수 : ' + (_newCnt + _modCnt)
									, '소요시간 : ' + strTime
									, '신규학생수 : ' + _newCnt
									, '수정학생수 : ' + _modCnt
									]);
		
		_that.fvQueWrks.dequeue();
		_that.fnDoNext.call(_that);
	}
	
	function error(e, type){
		if(type == 'file') errorFile(e);
		else if(type == 'db'){
			
			if(e.statuscode == '1210' || e.statuscode == '1211') trace(_stmt.query);
		
			if(e.statuscode != '1207'){ //rollback 아닐때
				errorDb(e);
			}
		}
	}
	
	function errorFile(e){
		var statuscode = (!_that.smfIsNull(e) && e.statuscode) ? e.statuscode : '9999';
		
		var msg = ['(' + statuscode + ')'];
		if(!_that.smfIsNull(_virf.filename)){
			msg.push('(' + _virf.filename + ')');
		}
		
		msg.push(_that.fvLogPerPend);
		
		if(statuscode == '9999' && _that.fnIsStr(e)){
			msg.push(e);
		}else{
			msg.push(' 파일을 처리하는 중 오류가 발생하였습니다.');
		}
		
		_that.fnOnError.call(_that, msg.join(''));
	}
	
	function errorDb(e){
		_conn.rollback();
		
		var stu = _queStu ? _queStu.first() : null;
		var data = stu ? (stu.queData ? stu.queData.first() : null) : null;
		var statuscode = (!_that.smfIsNull(e) && e.statuscode) ? e.statuscode : '9999';
		var msg = [];
		
		if(statuscode == '1210' || statuscode == '1211' ){ //executeQuery, executeUpdate관련 오류
			msg.push(e.ldberrormsg + '\n\n');
		}
		msg.push('(' + statuscode + ')' + e.ldberrormsg + '\n\n');
		msg.push('(' + statuscode + ')');
		if(!_that.smfIsNull(_virf.filename)){
			msg.push('(' + _virf.filename + ')');
		}
		
		if(!_that.smfIsNull(data)){
			var table = findTable(data[0]);
			if(table != null) msg.push('(' + table.rmkCn + ')');
		}
		
		msg.push(_that.fvLogPerPend);
		
		if(statuscode == '9999' && _that.fnIsStr(e)){
			msg.push(e);
		}else{
			msg.push(' 이관 및 검증 중 오류가 발생하였습니다.');
		}
		
		if(!_that.smfIsNull(data)){
			_that.fnShowLog.call(_that, '오류데이터 : ' + data.join('^'));
		}
		
		_that.fnOnError.call(_that, msg.join(''));
	}

	function action(){
		_that.fnShowLog.call(_that, _that.fvLogPerPend +  ' 로컬 데이터베이스 이관 및 검증 작업을 시작하였습니다.');
		
		_conn.set_datasource(_path);
		_stmt.set_ldbconnection(_conn);
		
		_folder = _path.substring(0, _path.lastIndexOf('\\'));
		_virf.getFileList(_folder, '\\.' + _that.fvSems, VirtualFile.findFileOnly);
	}
	
	function mapping(table, stu){
		var columns = _tableSchema[table.name].columns;
		var pks = _tableSchema[table.name].pks;
		var data = stu.queData.first();
		var values = Array(columns.length).fill('null');
		
		function mappingBasePk(){
			values[0] = toParam(stu.mogib1);			// 모집구분
			values[1] = toParam(stu.mogib2);			// 세부모집구분코드
			values[2] = toParam(stu.uniqueFileName);	// 수신된전형자료파일명
			values[3] = toParam(stu.eduOfficesCode);	// 시도교육청코드
			values[4] = toParam(stu.socialNumber);		// 주민등록번호
			values[5] = '1'								// 순번(고정값)
		}
		
		function toParam(val){
			if(val == '/NULL/') return 'null';
			if(val == null) return 'null';
			
			if(_that.fnIsStr(val)){
				val = val.replace(/[']/g, '\'\'')
				val = val.replace(/\/EOR\//gi, '\n')
				return "'" + val + "'";
			}
			
			return val;
		}
		
		function mappingIndex(valIndex, dataIndex, cnt){
			for(var i = 0; i < cnt; i++){
				values[valIndex + i] = toParam(data[dataIndex + i]);
			}
		}
		
		function getQuerySeqNumber(val){
			if(typeof val != 'number') val = 1;
			if(val < 1) val = 1;
			
			var where = `${pks[0]} = '${stu.mogib1}' 
				  AND ${pks[1]} = '${stu.mogib2}' 
				  AND ${pks[2]} = '${stu.uniqueFileName}'
				  AND ${pks[3]} = '${stu.eduOfficesCode}'
				  AND ${pks[4]} = '${stu.socialNumber}'`;
			return `(SELECT IFNULL(MAX(SeqNumber), 0) + ${val} FROM ${table.name} WHERE ${where})`
		}
		
		//PK 매핑
		mappingBasePk();
		
		if(table.name == 'GedStudentBaseInfo'){			// ------------기본정보
			values[6] = toParam(stu.department);			// Department 지원학과정보
		}else if(table.name == 'GedPersonalInfo'){		// ------------ 인적사항
			values[6] = toParam(data[1]);				// AcceptedYear 합격년도
			values[7] = toParam(data[2]);				// AcceptedTimes 합격회차
			values[8] = toParam(data[3]);				// Name 성명
			values[9] = toParam(stu.seleScNm);			// SeleScNm 전형구분
			values[10] = toParam(stu.invitationUnit);	// InvitationUnit 모집단위
			values[11] = toParam(stu.examNumber);		// ExamNumber 수험번호
			values[12] = toParam(data[4]);				// SchoolName 학교명
		}else if(table.name == 'AcceptedInfo'){			// ------------ 합격증명
			values[6] = toParam(data[1]);				// AcceptedYear 합격년도
			values[7] = toParam(data[2]);				// AcceptedTimes 합격회차
			values[8] = toParam(data[4]);				// CertificateNumber 합격증서번호
			values[9] = toParam(data[3]);				// AcceptedDate 합격연월일
			values[10] = toParam(data[5]);				// EvaluateTotalScore 평가총점
			values[11] = toParam(data[6]);				// EvaluateAverageScore 평가평균
			values[12] = "'Y'";							// ValidYN 유효여부
		}else if(table.name == 'SubjectScore'){			// ------------ 성적증명
			values[5] = getQuerySeqNumber(); 			// SeqNumber 순번
			values[6] = toParam(data[1]);				// AcceptedYear 합격년도
			values[7] = toParam(data[2]);				// AcceptedTimes 합격회차
			values[8] = toParam(data[3]);				// SubjectReqCode 검정고시 과목필수구분코드
			values[9] = toParam(data[4]);				// SubjectReqName 검정고시 과목필수구분명
			values[10] = toParam(data[5]);				// SubjectCode 검정고시 과목코드
			values[11] = toParam(data[6]);				// SubjectName 검정고시 과목명
			values[12] = toParam(data[7]);				// SubjectScore 검정고시 과목점수
			values[13] = toParam(data[8]);				// AcceptedDate 과목별 합격발표일(합격연월일)
			values[14] = "'Y'";							// ValidYN 유효여부
		}
		
		return values;
	}
	
	//전형자료에서 항목 인덱스 찾기
	function findItem(itemNo){
		return _queStu.first().queData.find((v) => v[0] == itemNo);
	}
	
	function findTable(itemNo){
		return _tables.find((v) => v.itemNo == itemNo);
	}

	//업무처리 실행
	function executeJob(){
		_queJob.clear(); //job 초기화
		
		//테이블 스키마 조회
		if(_tableSchema == null){
			_tableSchema = {};
			
			_queJob.enqueue({ type : JOB_TYPE.CONN_OPEN, execute : () => _conn.open() });
			_queJob.enqueue({ type : JOB_TYPE.CONN_OPEN_CALLBACK, execute : () => _queJob.dequeue().execute() });
			
			var tablenames = _tables.map((v) => v.name);
			for(var i = 0; i < tablenames.length; i++){
				//테이블 정보조회
				_queJob.enqueue(function(){
					var tablename = tablenames[i];
					return {
						type : JOB_TYPE.EXECUTE_QUERY,
						execute : () => {
							_stmt.executeQuery(`PRAGMA table_info('${tablename}')`);
						}
					}
				}());
				
				//테이블 정보조회 후처리
				_queJob.enqueue(function(){
					var tablename = tablenames[i];
					return {
						type : JOB_TYPE.EXECUTE_QUERY_CALLBACK,
						execute : (e) => {
							_tableSchema[tablename] = JSON.parse(e.returnvalue.saveJSON()).Rows.reduce((a, v, i) => {
								a.colCnt++;
								
								if(Number(v.pk) > 0){
									a.pkCnt++;
									a.pks.push(v.name);
								}
																
								a.columns.push(v.name);
								return a;
							}, {colCnt : 0, pkCnt : 0, pks : [], columns : []});
							
							//다음 job 호출
							_queJob.dequeue().execute();
						}
					}
				}());
			}
			
			_queJob.enqueue({ type : JOB_TYPE.CONN_CLOSE, execute : () => _conn.close() });
			_queJob.enqueue({ type : JOB_TYPE.CONN_CLOSE_CALLBACK, execute : () => executeJob() });
			
			_queJob.dequeue().execute();
			return;
		}
		
		var stu = _queStu.first();
		var item = stu.queData.first();
		var table = findTable(item[0]);
		
		if(_that.smfIsNull(table)){
			errorDb(' 항목번호 \'' + item[0] +'\'의 테이블은 존재하지 않습니다.');
			return;
		}
		
		var schema = _tableSchema[table.name];
	
		//학생정보 테이블
		if(table.name == 'GedStudentBaseInfo'){
			_queJob.enqueue({ type : JOB_TYPE.CONN_OPEN, execute : () => _conn.open() });
			_queJob.enqueue({ type : JOB_TYPE.CONN_OPEN_CALLBACK, execute : () => { _stmt.set_ldbconnection(_conn); _conn.begin(); } });
			_queJob.enqueue({ type : JOB_TYPE.CONN_BEGIN_CALLBACK, execute : () => _queJob.dequeue().execute() });
			
			//학생정보 수량 조회
			_queJob.enqueue(function(){
				return {
					type : JOB_TYPE.EXECUTE_QUERY,
					execute : () => {
						_stmt.executeQuery(`
							SELECT COUNT(*) AS cnt FROM ${table.name} WHERE Mogib1 = '${stu.mogib1}' AND Mogib2 = '${stu.mogib2}' AND UniqueFileName = '${stu.uniqueFileName}' AND EduOfficesCode = '${stu.eduOfficesCode}' AND SocialNumber = '${stu.socialNumber}' AND SeqNumber = 1
						`);
					}
				}
			}());

			//학생정보 수량 조회 후처리
			_queJob.enqueue(function(){
				return {
					type : JOB_TYPE.EXECUTE_QUERY_CALLBACK,
					execute : (e) => {
						var cnt = e.returnvalue.getColumn(0, 'cnt');
						if(cnt == 0) _newCnt++;
						else _modCnt++;
						
						//다음 job 호출
						_queJob.dequeue().execute();
					}
				}
			}());
			
			//학생정보 저장
			_queJob.enqueue(function(){
				var columns = schema.columns.join(', ');
				var mappedData = mapping(table, stu).join(', ');
				
				return {
					type : JOB_TYPE.EXECUTE_UPDATE,
					execute : (e) => {
						_stmt.executeUpdate(`
							INSERT OR REPLACE INTO ${table.name}(
							  ${columns}
							)VALUES(
							  ${mappedData}
							)
						`);
					}
				}
			}());
			
			//학생정보 저장 후처리
			_queJob.enqueue({ type : JOB_TYPE.EXECUTE_UPDATE_CALLBACK, execute : (e) => _queJob.dequeue().execute() });
			
		}else{
			if(_deletedTables[table.name]){ //이미 삭제한 테이블이면
				_queJob.enqueue({ type : JOB_TYPE.EXECUTE, execute : (e) => _queJob.dequeue().execute() });
			}else{ //삭제하지 않은 테이블이면
				_deletedTables[table.name] = table.name;
				
				//데이터 삭제
				_queJob.enqueue(function(){
					var pks = _tableSchema[table.name].pks;
					//var where = `${pks[0]} = '${stu.mogib1}' AND ${pks[1]} = '${stu.mogib2}' AND ${pks[2]} = '${stu.identifyNumber}'`;
					var where = `${pks[0]} = '${stu.mogib1}' AND ${pks[1]} = '${stu.mogib2}' AND ${pks[2]} = '${stu.uniqueFileName}' AND ${pks[3]} = '${stu.eduOfficesCode}' AND ${pks[4]} = '${stu.socialNumber}'`;
					return {
						type : JOB_TYPE.EXECUTE_UPDATE,
						execute : () => {
							_stmt.executeUpdate(`
								DELETE FROM ${table.name} WHERE ${where}
							`);
						}
					}
				}());
			}
			
			//데이터 삭제 후처리 ( 데이터 저장 )
			_queJob.enqueue(function(){
				var columns = schema.columns.join(', ');
				var valMap = mapping(table, stu);
				
				if(Array.isArray(valMap[0])){
					var mappedData = valMap.map((v) => 'SELECT ' + v.join(', ')).join(' UNION ALL\n');
					return {
						type : JOB_TYPE.EXECUTE_UPDATE_CALLBACK,
						execute : () => {
							_stmt.executeUpdate(`
								INSERT INTO ${table.name}(
								  ${columns}
								)
								${mappedData}
							`);
						}
					}
				}
				
				var mappedData =  valMap.join(', ');
				return {
					type : JOB_TYPE.EXECUTE_UPDATE_CALLBACK,
					execute : () => {
						_stmt.executeUpdate(`
							INSERT INTO ${table.name}(
							  ${columns}
							)VALUES(
							  ${mappedData}
							)
						`);
					}
				}
			}());
			
			//데이터 저장 후처리
			_queJob.enqueue({ type : JOB_TYPE.EXECUTE_UPDATE_CALLBACK, execute : (e) => _queJob.dequeue().execute() });
		}
		
		//업무 완료 되었는지 확인
		_queJob.enqueue({ type : JOB_TYPE.EXECUTE, execute : (e) => {
			//trace("■■■■■■■■■■■■■■■ _queJob.enqueue :: ");
			//완료 항목 제거
			stu.queData.dequeue();
			if(stu.queData.isEmpty()){
				var cmptnRate = ((_newCnt + _modCnt) / _totCnt) * 100;
				_that.pgbCmptn.set_pos(cmptnRate);
				_that.pgbCmptn.set_text(Math.floor(cmptnRate) + "%");
				
				//커밋
				_queJob.enqueue({ type : JOB_TYPE.CONN_COMMIT, execute : () => _conn.commit() });
				//trace("■■■■■■■■■■■■■■■ _queJob.enqueue :: 커밋");
				_queJob.enqueue(function(){
					var mogib1 			= stu.mogib1;
					var mogib2 			= stu.mogib2;
					var uniqueFileName 	= stu.uniqueFileName;
					var eduOfficesCode	= stu.eduOfficesCode;
					var socialNumber	= stu.socialNumber
					var seqNumber		= '1'
					
					//trace("■■■■■■■■■■■■■■■ _queJob.enqueue :: 커밋 :: mogib1 :: " + mogib1);
					//trace("■■■■■■■■■■■■■■■ _queJob.enqueue :: 커밋 :: mogib2 :: " + mogib2);
					//trace("■■■■■■■■■■■■■■■ _queJob.enqueue :: 커밋 :: uniqueFileName :: " + uniqueFileName);
					//trace("■■■■■■■■■■■■■■■ _queJob.enqueue :: 커밋 :: eduOfficesCode :: " + eduOfficesCode);
					//trace("■■■■■■■■■■■■■■■ _queJob.enqueue :: 커밋 :: socialNumber :: " + socialNumber);
					//trace("■■■■■■■■■■■■■■■ _queJob.enqueue :: 커밋 :: seqN22umber :: " + seqNumber);
					return {
						type : JOB_TYPE.CONN_COMMIT_CALLBACK,
						execute : (e) => {
							_stmt.executeQuery(_that.fnGetVrfcQuery(mogib1, mogib2, uniqueFileName, eduOfficesCode, socialNumber, seqNumber));
						}
					}
					//trace("■■■■■■■■■■■■■■■ _queJob.enqueue :: 커밋 끗");
				}());
				
				//검증
				_queJob.enqueue(function(){
					var mogib1 			= stu.mogib1;
					var mogib2 			= stu.mogib2;
					var uniqueFileName 	= stu.uniqueFileName;
					var eduOfficesCode	= stu.eduOfficesCode;
					var socialNumber	= stu.socialNumber
					//trace("■■■■■■■■■■■■■■■ _queJob.enqueue :: 검증 :: mogib1 :: " + mogib1);
					//trace("■■■■■■■■■■■■■■■ _queJob.enqueue :: 검증 :: mogib2 :: " + mogib2);
					//trace("■■■■■■■■■■■■■■■ _queJob.enqueue :: 검증 :: uniqueFileName :: " + uniqueFileName);
					//trace("■■■■■■■■■■■■■■■ _queJob.enqueue :: 검증 :: eduOfficesCode :: " + eduOfficesCode);
					//trace("■■■■■■■■■■■■■■■ _queJob.enqueue :: 검증 :: socialNumber :: " + socialNumber);
					
					//trace("■■■■■■■■■■■■■■■ _queJob.enqueue :: 검증 == orgData :: " + _queStu.first().orgData);
					//trace("■■■■■■■■■■■■■■■ _queJob.enqueue :: 검증 == orgRows :: " +  _queStu.first().orgData.split('\r\n'));
					return {
						type : JOB_TYPE.EXECUTE_QUERY_CALLBACK,
						execute : (e) => {
							var orgRows = _queStu.first().orgData.split('\r\n');
							
							var tarRows = [];
							
							for(var i = 0; i < e.returnvalue.getRowCount(); i++){
								 tarRows.push(e.returnvalue.getColumn(i, 'CoaData'));
							}
							
							for(var i = 0; i < orgRows.length; i++){
								var itemNo = orgRows[i].substring(0, orgRows[i].indexOf('^'));
								
								if(_that.fnIsStr(tarRows[i])){
									tarRows[i] = tarRows[i].replace(/\n/gi, '/EOR/');
								}
								findTable(itemNo).rmkCn
								
								if(orgRows[i] != tarRows[i]){
									//오류 학생 데이터 삭제
									_that.fnShowLog.call(_that, ['[' + findTable(itemNo).rmkCn +  '] 원본(SEMS) 데이터와 이관된 데이터가 일치하지 않아 해당 데이터를 모두 삭제 합니다.'
																, '원본 : ' + orgRows[i]
																, '이관 : ' + tarRows[i]
																]);
									_queJob.clear();
									
									for(var i = 0; i < _tables.length; i++){
										_queJob.enqueue(function(){
											var tableNm = _tables[i].name;
											var pks = _tableSchema[tableNm].pks;
											var where = `${pks[0]} = '${stu.mogib1}' AND ${pks[1]} = '${stu.mogib2}' AND ${pks[2]} = '${stu.uniqueFileName}' AND ${pks[3]} = '${stu.eduOfficesCode}' AND ${pks[4]} = '${stu.socialNumber}'`;
											//var where = `${pks[0]} = '${mogib1}' AND ${pks[1]} = '${mogib2}' AND ${pks[2]} = '${identifyNumber}'`;
											
											return {
												type : JOB_TYPE.EXECUTE_UPDATE,
												execute : () => {
													_stmt.executeUpdate(`
														DELETE FROM ${tableNm} WHERE ${where}
													`);
												}
											}
										}());
										
										_queJob.enqueue({ type : JOB_TYPE.EXECUTE_UPDATE_CALLBACK, execute : () => _queJob.dequeue().execute() });
									}
									
									_queJob.enqueue(function(){
										var rmkCn = findTable(itemNo).rmkCn;
										return {
											type : JOB_TYPE.EXECUTE,
											execute : () => errorDb(' [' + rmkCn + '] 원본(SEMS) 데이터와 이관된 데이터가 일치하지 않습니다.')
										}
									}());
									
									_queJob.dequeue().execute();
									return;
								}
							}
							
							_cmptnStu.push(_queStu.dequeue());
							_deletedTables = {}; //삭제된 테이블 초기화
							
							_queJob.dequeue().execute();
						}
					}
				}());
				
				_queJob.enqueue({ type : JOB_TYPE.CONN_CLOSE, execute : () => _conn.close() });
				_queJob.enqueue({ type : JOB_TYPE.CONN_CLOSE_CALLBACK, execute : () => {
					if(_queStu.isEmpty()) complete();
					else _virf.open(_queStu.first().path, VirtualFile.openRead);
				}});

				//실행
				_queJob.dequeue().execute();
				return;
			}
			
			executeJob();
		}});
		
		//실행
		_queJob.dequeue().execute();
	}
	
	function nextFile(e){
		if(e.reason == '8'){ //getFileList
			var stuInfos = e.fileattributelist.map((v) => {
				var stuInfo = v.filename.substring(0, v.filename.lastIndexOf('.')).split('_');
				return {
					path : _folder + '//' + v.filename,
					mogib1 : stuInfo[4],		  	// 모집구분
					mogib2 : stuInfo[5],    	  	// 세부모집구분코드
					uniqueFileName : v.filename,  	// 전형파일명
					eduOfficesCode : stuInfo[1],	// 시도교육청코드
				}
			});
			if(stuInfos.length > 0){
				_totCnt = stuInfos.length;
				_that.fnShowLog.call(_that, '처리해야할 파일건수는 총 ' + _totCnt + '건입니다.');
				_queStu.init(stuInfos);
				_virf.open(_queStu.first().path, VirtualFile.openRead);
			}else{
				errorFile('가 존재하지 않습니다.');
			}
		}else if(e.reason == '1'){ //open
			_virf.read();
		}else if(e.reason == '3'){ //read
			var stu = _queStu.first();
			stu.orgData = e.textdata;
			stu.queData = _that.sqafCreateQueue();
			
			if(e.textdata.length == 0){
				_virf.close();
				errorFile('가 0KB 입니다.');
				return;
			}
			
			//SEMS파일 마지막이 \r 이면 제거
			if(stu.orgData[stu.orgData.length - 1] == '\r'){
				stu.orgData = stu.orgData.substring(0, stu.orgData.length - 1);
			}
			
			//SEMS파일 마지막이 \r\n 이면 제거
			if(stu.orgData[stu.orgData.length - 1] == '\n' && stu.orgData[stu.orgData.length - 2] == '\r'){
				stu.orgData = stu.orgData.substring(0, stu.orgData.length - 2);
			}
		
			stu.queData.init(stu.orgData.split('\r\n').map((v) => v.split('^')));
			
			var item0 = findItem(0); //기본정보
			var item1 = findItem(1); //인적사항
			
			if(!item0){
				_virf.close();
				errorFile(' 파일에 기본정보가 존재하지 않습니다.'
						+ '\n ※ 복호화자료 파일에 기본정보가 존재하지 않을 시, 수신/복호화 파일 확인 후 이상여부에 따라 재요청/재복호화 바랍니다.'
						+ '\n ※ 재복호화 시 기존에 생성된 복호화된 파일을 삭제해주시기 바랍니다. (복호화 파일명: *_암호화파일순번.SEMS)');
				return;
			}
			
			if(!item1){
				_virf.close();
				errorFile(' 파일에 인적사항이 존재하지 않습니다.');
				return;
			}
			
			stu.socialNumber 	= item0[2];  //주민등록번호
			stu.department 		= item0[3];  //지원학과정보
			stu.seleScNm 		= item0[4];  //전형구분
			stu.invitationUnit 	= item0[5];  //모집단위
			stu.examNumber 		= item0[6];  //수험번호
			
			executeJob();
			
			_virf.close();
		}else if(e.reason == '2'){ //close
		}else{
			errorFile();
		}
	}
	
	function nextDb(e){
		if(e.reason != '6'){ //rollback
			var job = _queJob.dequeue();
			if(job == null || job.type != e.reason) errorDb();
			else job.execute(e);
		}
	}
	
	function next(e, type){
		if(type == 'file') nextFile(e);
		else if(type == 'db') nextDb(e);
	}
	
	return {cmd : () => _cmd, path : () => _path, action : action, next : next, error : error}
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

/**
 * @description 경로선택
 */
this.divMain_btnCoaDataPath_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objExtCommon = this.smfCreateExtCommonAPI();
	
	var coaDataPath = nexacro.getPrivateProfile(this.sqav_coaDataPathValue);
	if(this.smfIsNull(coaDataPath)){
		coaDataPath = objExtCommon._ext_getSystemDir("CSIDL_PERSONAL"); 
	}
	coaDataPath = objExtCommon._ext_selectFolderPath(coaDataPath);
	
	objExtCommon = null;
	
	if(!this.smfIsNull(coaDataPath)){
		this.divMain.form.edtCoaDataPath.set_value(coaDataPath);
		this.divMain.form.txtCoaDataDtlPath.set_value(this.sqafGetCoaDataDtlPath(coaDataPath));
		
		this.sqafSetCoaDataPath(coaDataPath);
		
		this.fvCoaDataDownPath = this.sqafGetCoaDataDownPath();   // 수신경로
		this.fvCoaDataBlindPath = this.sqafGetCoaDataDecPath(); // 블라인드자료경로
	}
};

/**
 * @description 적용
 */
this.btnPrcs_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.setWaitCursor(true);

	this.fvQueWrks.clear();
	
	this.fvIsBld = obj.id == 'btnLocalDbBldCrt';
	this.fvLogPerPend = '복호화자료';
	this.fvPath = (this.fvIsBld ? this.fvCoaDataBlindPath : this.fvCoaDataDecrPath) + this.fvDbNm;
	
	this.pgbCmptn.set_pos(0);
	this.pgbCmptn.set_text("0%");
	this.divMain00.form.txtLog.set_value('');
	this.fvLog.length = 0;
	this.fvBgngTime = Date.now();
	
	//1. db파일 존재 확인 ( 없으면 생성 )
	this.fvQueWrks.enqueue(this.fnWrkCreateDatabase.call(this, this.fvPath));
	
	//2. 테이블 생성
	this.fvQueWrks.enqueue(this.fnWrkCreateTables.call(this, this.fvPath));
	
	//3. 테이블 이관 및 검증
	this.fvQueWrks.enqueue(this.fnWrkSemsToDatabase.call(this, this.fvPath));
	
	//시작
	this.fnDoNext();
};

this.VirtualFile_onerror = function(obj:nexacro.VirtualFile,e:nexacro.VirtualFileErrorEventInfo)
{
	if(this.fvQueWrks != null && !this.fvQueWrks.isEmpty()) this.fvQueWrks.first().error(e, 'file');
};

this.VirtualFile_onsuccess = function(obj:nexacro.VirtualFile,e:nexacro.VirtualFileEventInfo)
{
	if(this.fvQueWrks != null && !this.fvQueWrks.isEmpty()) this.fvQueWrks.first().next(e, 'file');
};

this.LiteDB_onerror = function(obj:nexacro.LiteDBConnection,e:nexacro.LiteDBErrorEventInfo)
{
	if(this.fvQueWrks != null && !this.fvQueWrks.isEmpty()) this.fvQueWrks.first().error(e, 'db');
};

this.LiteDB_onsuccess = function(obj:nexacro.LiteDBConnection,e:nexacro.LiteDBEventInfo)
{
	if(this.fvQueWrks != null && !this.fvQueWrks.isEmpty()) this.fvQueWrks.first().next(e, 'db');
};

/**
 * @description 닫기
 */
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};

]]></Script>
    <Bind>
      <BindItem id="item0" compid="pgbCmptn" propid="pos" datasetid="dsMainTtl" columnid="coaWrkPrcsPos"/>
    </Bind>
  </Form>
</FDL>
