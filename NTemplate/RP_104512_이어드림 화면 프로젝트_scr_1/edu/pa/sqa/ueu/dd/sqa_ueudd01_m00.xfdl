                <Cell col="5" text="bind:trprRrno" textAlign="center" displaytype="mask" maskedittype="string" maskeditformat="######-#######"/>
                <Cell col="6" text="expr:seleDataCrtYn == &quot;Y&quot; ? &quot;완료&quot; : &quot;미완료&quot;" textAlign="center"/>
