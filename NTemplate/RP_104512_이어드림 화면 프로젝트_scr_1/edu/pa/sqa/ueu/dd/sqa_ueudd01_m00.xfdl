/**
* @description 그리드 헤더 클릭
*/
this.grdApst_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var columnName = obj.getCellProperty("body",e.cell,"text");
 
 	if ("bind:_chk" == columnName){
	
 		var chkYn = obj.getCellText(-1, e.cell)=="1"?"0":"1";
 		obj.setCellProperty("head", 0, "expr", chkYn);
		this.fvCeckCnt = 0;
 		for(var i = 0 ; i < this.dsDecApst.rowcount ; i++) {
		    //var param = this.dsDecApst.getColumn(i, "seleDataCrtYn");
 			//var displaytype = param == "N" ? "checkbox" : "none";
 			//if(displaytype != "checkbox") continue;			
			if(chkYn == "1") {	//선택
				this.fvCeckCnt += 1;
				this.dsDecApst.setColumn(i, "_chk", chkYn);						
			} else {	//전체해제
				if(this.dsDecApst.getColumn(i, "_chk") == "1") {
					//this.fvCeckCnt -= 1;
					this.dsDecApst.setColumn(i, "_chk", "0");					
// 					if(this.fvCeckCnt == 0 ) {
// 						break;
// 					}					
				}				
			}		
		}
		this.staChcCnt.set_text("선택건수 : " + this.fvCeckCnt);	
	}
};

