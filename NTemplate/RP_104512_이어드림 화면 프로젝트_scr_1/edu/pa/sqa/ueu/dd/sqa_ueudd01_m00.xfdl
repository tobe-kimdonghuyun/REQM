        <Static id="Static99_00_00_00_00_01_00_00" taborder="8" left="0" top="141" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Plugin id="objKCASE" taborder="9" left="1111" top="95" width="68" height="14" classid="{93D5247D-EBA7-4713-A8BF-448BD277E7AD}" visible="false" enable="true"/>
        <Button id="btnCoaDataLocalDbCrt" taborder="10" text="전형자료로컬DB생성" height="30" width="150" cssclass="btn_WF_Crud" visible="true" initvalueid="ivBtnAccessibilityButton" right="0" top="111" onclick="btnCoaDataLocalDbCrt_onclick"/>
      </Layout>
