    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    전형자료복호화
*  @FileName 	sqa_ueudd00_m00.xfdl
*  @Creator 	bsw
*  @CreateDate 	2022.09.05
*  @Desction    대입전형-대학-전형자료복호화
************** 소스 수정 이력 ***********************************************
*  date				Modifier				Description
*******************************************************************************
*  2022.09.05		bsw						최초 생성
*  2023.08.07		진승환					대학용 sems파일에 db3파일 구조 적용을 위한 데이터 추가
*  2023.10.11		진승환					(SR00098887) 복호화여부와 상관없이 재복호화 가능하도록 수정 
											expr:seleDataCrtYn == "N" ? "checkboxcontrol" : "none"
											expr:seleDataCrtYn == "N" ? "checkbox" : "none"
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvKeyUserDn = '';								  	  	//암호화키	
this.fvObjExtCommon = this.smfCreateExtCommonAPI();		  	//ExtCmmon API
this.fvCoaDataDownPath = this.sqafGetCoaDataDownPath();   	//수신경로 
this.fvCoaDataDownDecPath = this.sqafGetCoaDataDecPath();   //복호화경로 
this.fvPrcsType = 0;									  	//폴더 권한 확인
this.fvSendSize = 100;	   								  	//임시로 100건으로 함.
var today = this.smfToday();							  	//금일		
this.fvCallback;										  	//콜백함수	
this.fvCeckCnt = 0;										  	//선택건수
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose, ontimer)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리
 */
this.sqa_ueudr01_m00_onload = function(obj,e) {

	// Div 초기화
	this.smfInitDiv(obj);

//  	// Grid Checkbox 활성화/활성화 제어
//  	this.smfUpdateRednerGridCheckbox(this.grdList, 0, this.fnRenderGridCheckbox);
//
//  	// 조회 입력창에서 'Ctrl' + 'Enter' 키 입력시 조회수행 이벤트 설정
//  	this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
//
//  	// 데이터 입력 창에서 'Ctrl' + 'Enter' 키 입력시 저장수행 이벤트 설정
//  	this.smfBindEnterKeyToSearch(this.dsList, this.btnSave);

	//초기화
	this.fnInit(obj);

	// 서버단에 설정한 유효성 검증 목록을 획득하여 설정
	this.fnSearchValidation();
	
	//공통코드 조회
	this.fnSerachCmmCd();		
			
	// 검정고시대입 공통조회
	this.fnOnloadSearch(obj, ["dsDetaRcritPrd"]);
	
	//전자서명정보조회
	this.fnOnloadSearchElts();
};

/**
 * @description 폼 닫기전 이벤트
 */
this.sqa_ueudr01_m00_onbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
// 	// 변경내역이 발생한 경우 종료전 confirm수행
// 	return this.smfCloseFormConfirm([this.dsRreqApst]);	
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
};

/**
 * @description 폴더 권한확인 콜백
 * @param : isComplete - 완료 확인
 */
this.fnCheckFolderCallback = function(isComplete){
	if(!isComplete){
		return;
	}
	
	if(this.fnCheckCertification()) {	
		this.fvPrcsType = 1;		//폴더권한확인
		this.fnDoNext();			//다음 실행	
	}
}

/**
 * @description 파일 읽기 콜백
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체 
 */
this.fnVirtualFileCallbackR = function() {		
	this.fnTakeFileInfoW();			//파일쓰기
	this.fnVirtualFileOpen();
}

/**
 * @description 파일 쓰기 콜백
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체 
 */
this.fnVirtualFileCallbackW = function(){
	
	var idx = this.dsFile.getColumn(0, "idx");										//dsDecApst의 인덱스	
	var fileExist = this.dsFile.getColumn(0, "fileExist");							//파일유무
	var coaSeleFileNm = this.dsFile.getColumn(0, "coaSeleFileNm");					//파일명	
	var uvstEncSymmKey = this.dsFile.getColumn(0," uvstEncSymmKey");				//대학암호화대칭키
	var coaSeleFileCnEnc = this.dsFile.getColumn(0, "coaSeleFileCnEnc");			//읽어드린 암호화파일
	var coaSeleFileCn = this.dsFile.getColumn(0, "coaSeleFileCn");					//복호화한 파일
	
	//수신완료 처리(dsDecApst 세팅)	
	if(!this.smfIsNull(coaSeleFileCn)) {	
		this.dsDecApst.setColumn(idx, "seleDataCrtYn", "Y");												//전형자료생성여부	
		this.dsDecApst.setColumn(idx, "rmkCn", "전형자료복호화 : 복호화(" + coaSeleFileNm + ")");		//비고
	} else {	
		this.dsDecApst.setColumn(idx, "seleDataCrtYn", "N");												//전형자료생성여부
		this.dsDecApst.setColumn(idx, "rmkCn", "전형자료복호화 : 복호화실패(" + coaSeleFileNm + ")");	//비고
	}	
	
	this.dsDecApstFile.deleteRow(0);												//스텝별로 조회한 파일정보 dsDecApstFile 삭제
	this.dsFile.deleteRow(0);														//dsDecApstFile에서 복사한 정보 dsFile 삭제
	
	//스텝별 대상자ds 체크 건수
	if(this.dsDecApstFile.rowcount == 0) {
		//업로드ds(dsDecParts)에 마스터ds(dsDecApst) 데이터 업데이트
		var max = this.dsDecParts.rowcount;
		for(var i = 0; i < max; i++) {
			var idx = this.dsDecParts.getColumn(i, "idx");														//dsDecApst의 인덱스
			this.dsDecParts.setColumn(i, "seleDataCrtYn", this.dsDecApst.getColumn(idx, "seleDataCrtYn"));	//수신여부
			this.dsDecParts.setColumn(i, "rmkCn", this.dsDecApst.getColumn(idx, "rmkCn"));					//비고
		}
		this.fnExecuteRctnCmptn(this.fvCallback);					//파일생성완료처리(스텝별로 완료처리) 
	} else {
		this.fnTakeFileInfoR();					//파일읽기전 세팅
		this.fnVirtualFileOpen();				//파일오픈
	}
}

/**
 * @description 전형자료경로설정 팝업 콜백함수
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체 
 */
this.fnCoaDataPathCallback = function(e, sender){
	// 2023-09-19 복호화경로 폴더 참조 문제 수정
	this.fvCoaDataDownPath = this.sqafGetCoaDataDownPath();   	//수신경로 
	this.fvCoaDataDownDecPath = this.sqafGetCoaDataDecPath();   //복호화경로 
	//this.fvCoaDataDownPath = nexacro.getPrivateProfile(this.sqav_coaDataPathValue);		//수신경로
}
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리

************************************************************************************************/
/**
 * @description 유효성 검증 목록 조회
*/
this.fnSearchValidation = function() {
	this.smfValidateService("validateMain", {
			url: "/sqa_ueu_dd01_001.do",
		})
		.mappingRulesetToForm(this.divSearch, "search")					//조회Valid
		.run()
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;
		});
};

/**
 * @description 공통코드 조회
*/
 this.fnSerachCmmCd = function() {		
	this.smfCodeList("code", [this.dsCddcScCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.divSearch.form.cboCddcScCd.set_index(0);
		})
		.run()
	;
};

/**
 * @description 전자서명정보 조회
*/
this.fnOnloadSearchElts = function() {
	this.smfSearchService("listEltsInfo")
		.run() // 실행
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;								
		});
}

/**
 * @description 지원자 조회
*/
this.fnSearch = function() {
	this.dsDecApst.clearData();
	this.grdApst.setCellProperty("summary", 0, "text", "" );
	this.fvCeckCnt = this.dsDecApst.getCaseCount("_chk == '1'");	
	this.staChcCnt.set_text("선택건수 : " + this.fvCeckCnt);
	
	this.smfSearchService("listDecApst")
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;	
			this.grdApst.setCellProperty("summary", 0, "text", "전형자료 복호화 건수: " + this.grdApst.rowcount + "건");
		});
}

/**
 * @description 파일정보 조회
*/
this.fnExecuteDecParts = function(callback) {
	this.smfSearchService("listCtpvDecApstFile")
		.run() // 실행
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;								
			this.fvCallback = callback;
			this.fnTakeFileInfoR();			//파일읽기전세팅
			this.fnVirtualFileOpen();		//파일오픈
		});
}

/**
 * @description 지원자 수신완료처리
*/
this.fnExecuteRctnCmptn = function(callback) {
	this.smfExecuteService("executeDecCmptn")
	    .showConfirm(false)
		.beforeService(function(next){
 			next();
 		})
		.run() // 실행
		.callback(function(callbackParams) {
			if(this.smfIsFunc(callback)) callback.call(this, callbackParams); 				
			if(callbackParams.errors) return;
		});
}
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 초기화
*/
 this.fnInit = function(obj) {
	//세션정보 세팅
	this.dsSearch.setColumn(0, "coaAyr", this.sqav_coaAyr);
	this.dsSearch.setColumn(0, "coaRcritScCd", this.sqav_coaRcritScCd);
	this.dsSearch.setColumn(0, "coaRcritScNm", this.sqav_coaRcritScNm);
	this.dsSearch.setColumn(0, "uvstOrgCd", this.sqav_uvstOrgCd);
	this.dsSearch.setColumn(0, "rcptnBgngYmd", this.smfAddDate(this.smfToday(), -7));
	this.dsSearch.setColumn(0, "rcptnEndYmd", this.smfToday());
};

/**
* @description 검정고시 대입전형 공통조회 콜백
*/
this.fnOnloadSearchCallback = function() {
	//세부모집시기의 조건 - 사용중인 것만 나오도록
	this.dsDetaRcritPrd.set_filterstr(today + " >= detaRcritScBgngYmd  && " + today + " <= detaRcritScEndYmd");
	this.dsSearch.setColumn(0, 'detaRcritScValue', this.dsDetaRcritPrd.getColumn(0, 'detaRcritScValue'));
	this.dsDetaRcritPrd.setColumn(this.dsDetaRcritPrd.insertRow(0), "detaRcritScNm", "선택");
	this.divSearch.form.cboDetaRcrit.set_index(0);
};

/**
* @description 요청대상건수체크
*/
this.fnCeckCnt = function(idx) {
	this.fvCeckCnt = this.dsDecApst.getCaseCount("_chk == '1'");	
	this.staChcCnt.set_text("선택건수 : " + this.fvCeckCnt);	
	return true;
};

/**
* @description 전형자료복호화 validation
*/
this.fnDecValid = function() {
		
	if(this.dsDecApst.getRowCount() == 0 ) {
		this.smfAlert("자료를 복호화할 지원자가 없습니다.");
		return false; 
	};
	
	if(this.fvCeckCnt == 0 ) {
		this.smfAlert("자료를 복호화할 지원자를 먼저 선택하여 주십시오.");
		return false;
	}
	
	this.dsDec.clearData();	//복호화대상ds초기화
	for(var i = 0 ; i < this.dsDecApst.rowcount; i++) {
		if(this.dsDecApst.getColumn(i, "_chk") == "1") {
			this.dsDec.copyRow(this.dsDec.addRow(), this.dsDecApst, i)	//선택한복호화대상ds 복사
			this.dsDec.setColumn(this.dsDec.rowcount - 1, "idx", i);	//인덱스세팅
		}
	}
	
	return true;
}

/**
 * @description 폴더 권한 확인
 */
this.fnCheckFolder = function(){
	this.fvPrcsType = 0;

	if(this.smfIsNull(this.sqafGetCoaDataPath())) {
		this.smfAlert("전형자료복호화 경로가 존재하지 않습니다.");
		return;
	}	
	
	this.VirtualFile00.isExist(this.sqafGetCoaDataPath());
}

/**
 * @description 다음 프로세스 호출(복호화 스텝별)
 */
this.fnDoNext = function() {
	this.fnExecuteDec(this.dsDec, this.dsDecParts, this.fvSendSize,
		function() {
			this.smfAlert("전형자료복호화 작업이 완료되었습니다.", "", function() {
				this.fnSearch();
				
			});			
		}	
	).run();
}

/**
 * @description 전형자료복호화 (by건)
 * @param : dsFrom		- 원본데이터
 * @param : dsTo		- 송신데이터 ( nMax 수량을 가짐 )
 * @param : nMax		- 최대 데이터 수량
 * @return : Object { run }
 */
this.fnExecuteDec = function(dsFrom, dsTo, nMax, completeCallback){
	var _that = this;
	var nStepIdx = 0;
	var nTotalCnt = dsFrom.getRowCount();
	
	//스텝 만들기 [{nIdxStart, nIdxEnd}...]
	var aStep = Array(Math.ceil(nTotalCnt / nMax)).fill().map(function(a, i) {
		var end = (i + 1) * nMax;
		return {
			nIdxStart : i * nMax,
			nIdxEnd : end < nTotalCnt ? end : nTotalCnt
		}
	});
	
	//전형자료복호화 이전 스텝(건수)별로 데이터셋 복사
	function copyDataByStep() {
		var step = aStep[nStepIdx++];
		if(_that.smfIsNull(step)){
			if(_that.smfIsFunc(completeCallback)) completeCallback.call(_that);
			return false;
		}
		
		//초기화
		dsTo.clearData();
		for(var i = step.nIdxStart; i < step.nIdxEnd; i++){			
			dsTo.copyRow(dsTo.addRow(), dsFrom, i);		
		}
		
		return true;
	}
	
	//전형자료복호화 callback
	function next(callbackParams) {
		if(callbackParams.errors) return;
				
		this.setWaitCursor(true);
						
		if(copyDataByStep()){
			_that.fnExecuteDecParts.call(_that, next);
		}
		this.setWaitCursor(false);
	}
	
	//전형자료복호화 호출
	function run(){
		if(copyDataByStep()) _that.fnExecuteDecParts.call(_that, next);
	}
	
	return {
		run
	}
};

/**
* @description virtualFile 읽기 전 세팅
*/
this.fnTakeFileInfoR = function() {
	this.dsFile.copyRow(this.dsFile.addRow(), this.dsDecApstFile, 0);
	var filePath = this.fvCoaDataDownPath + this.dsFile.getColumn(0, "coaSeleFileNm")+".enc";			//파일path
	var fileExist = this.fvObjExtCommon._ext_existFile(filePath);										//파일유무체크	
	
	//파일ds 세팅
	this.dsFile.setColumn(0, "fileExist", fileExist);													//파일유무체크
	this.dsFile.setColumn(0, "mode", "R");																//파일모드(R/W)
}

/**
* @description VirtualFile 읽기
*/
this.fnVirtualFileOpen = function(){

	var fileExist = this.dsFile.getColumn(0, "fileExist");									//파일존재유무
	var mode = this.dsFile.getColumn(0, "mode");											//파일모드(R/W)	
	var path = mode == "R" ? this.fvCoaDataDownPath : this.fvCoaDataDownDecPath;			//경로
	var coaSeleFileNm = mode == "R" ? this.dsFile.getColumn(0, "coaSeleFileNm") + ".enc" 
									//: this.dsFile.getColumn(0, "coaSeleFileNm") + ".dec"; 	//파일명
									: this.dsFile.getColumn(0, "coaSeleFileNm"); 	//파일명
	//파일이 없을때 
	if(mode == 'R'){
		if(fileExist == false){
			this.fnVirtualFileCallbackR();		//콜백
			return;
		}		
	}

	var opt = mode == 'R' ? VirtualFile.openRead : VirtualFile.openWrite;					//파일모드(읽기/쓰기)
	this.VirtualFile00.open(path + coaSeleFileNm, VirtualFile.openText | opt );
}

/**
* @description 파일 쓰기
*/
this.fnTakeFileInfoW = function(){	
	var idx = this.dsFile.getColumn(0, "idx");									//dsDecApst의 인덱스	
	var fileExist = this.dsFile.getColumn(0, "fileExist");						//파일유무
	var coaSeleFileNm = this.dsFile.getColumn(0, "coaSeleFileNm");				//파일명	
	var uvstEncSymmKey = this.dsFile.getColumn(0, "uvstEncSymmKey");			//대학암호화대칭키
	var coaSeleFileCnEnc = this.dsFile.getColumn(0, "coaSeleFileCnEnc");		//읽어드린 암호화파일
	var coaSeleFileCn;															

	// 대칭키 복호화
	var symmKey = this.objKCASE.callMethod("DecryptEnvelopedData", this.fvKeyUserDn, "", uvstEncSymmKey);
	
	//대입파일 복호화
	if(fileExist && !this.smfIsNull(coaSeleFileCnEnc)){
		coaSeleFileCn = this.objKCASE.callMethod("SymmDecrypt", "SEED", symmKey, coaSeleFileCnEnc)
		coaSeleFileCn = this.fvObjExtCommon._ext_getURLdecode(coaSeleFileCn, "utf-8");		
	}
	
	// 2023-08-07 대학용 sems파일에 db3파일 구조 적용을 위한 데이터 추가
	var cnSplitN	= coaSeleFileCn.split('\n');	// 개행문자로 split
	// 시도코드와 주민번호로 데이터셋에서 find
	var cddcCd		= cnSplitN[0].split('^')[1];
	var trprRrno	= cnSplitN[0].split('^')[2];
	
	var sRow 				= this.dsDecApst.findRowExpr("_chk == 1 && cddcOrgCd == '"+cddcCd+"' && trprRrno == '"+trprRrno+"'");
	var uvstSprtDddepNm		= this.dsDecApst.getColumn(sRow, 'uvstSprtDddepNm');	// 지원학과정보
	var seleScNm			= this.dsDecApst.getColumn(sRow, 'seleScNm');			// 전형구분  
	var rcritUnitNm			= this.dsDecApst.getColumn(sRow, 'rcritUnitNm');		// 모집단위 
	var uvstExmtNo			= this.dsDecApst.getColumn(sRow, 'uvstExmtNo');			// 수험번호 
	
	var uvstSprtDddepNmStr	= this.smfIsNull(uvstSprtDddepNm) ? "" : uvstSprtDddepNm;
	var seleScNmStr			= this.smfIsNull(seleScNm) ? "" : seleScNm;
	var rcritUnitNmStr		= this.smfIsNull(rcritUnitNm) ? "" : rcritUnitNm;
	var uvstExmtNoStr		= this.smfIsNull(uvstExmtNo) ? "" : uvstExmtNo;

	// 전형자료 추가 정보 입력
	coaSeleFileCn = coaSeleFileCn.replace(new RegExp('\\^\r\n'), '\^' + uvstSprtDddepNmStr
															   + '\^' + seleScNmStr
															   + '\^' + rcritUnitNmStr
															   + '\^' + uvstExmtNoStr
															   + '\^' + '\r\n');
															   
	this.dsFile.setColumn(0, "coaSeleFileCn", coaSeleFileCn);	//복호화파일
	this.dsFile.setColumn(0, "mode", "W");						//모드(W/R)	
}

/**
* @description virtualFile 성공
*/
this.VirtualFile00_onsuccess = function(obj:nexacro.VirtualFile,e:nexacro.VirtualFileEventInfo)
{	
	if(this.fvPrcsType == 0){ //폴더 권한 확인
		if(e.reason == 10) {	//isExist complete
			if(e.fileisexist){
				this.fnCheckFolderCallback(true);
			} 
		} else{
			this.smfAlert("전형자료경로가 존재하지 않습니다.", function(){
				this.fnCheckFolderCallback(false);
			});
		}
	} else {
		if(e.reason == 1){	//open complete
			var mode = this.dsFile.getColumn(0, "mode");			
			if(mode == 'R'){
				obj.read(e.filesize, 'utf-8');		//파일읽기
			}else{
				//쓰기
				var cn = this.dsFile.getColumn(0, "coaSeleFileCn");		//복호화 파일
				if(this.smfIsNull(cn)){
					obj.close();
				}else{
					obj.write(cn, 'utf-8');			//파일쓰기
				}
			}
		} else if(e.reason == 2){ //close complete
			var mode = this.dsFile.getColumn(0, "mode");	
			if(mode == 'R'){
				this.fnVirtualFileCallbackR();
			}else{
				this.fnVirtualFileCallbackW();
			}
		} else if(e.reason == 3){ //read complete
			this.dsFile.setColumn(0, "coaSeleFileCnEnc", e.textdata);	//암호화 상태인 파일정보 ds세팅
			obj.close();
		} else if(e.reason == 6){ //write complete			
			obj.close();
		}
	}
};

/**
* @description virtualFile 에러
*/
this.VirtualFile00_onerror = function(obj:nexacro.VirtualFile,e:nexacro.VirtualFileErrorEventInfo)
{
	if(this.fvPrcsType == 0){ //폴더 권한 확인
		if(e.statuscode == '1102'){ //Permission Denied
			this.smfAlert("전형자료경로에 접근권한이 없습니다.", function(){
				this.fnCheckFolderCallback(false);
			});
		}else if(e.statuscode == '1105'){ //Does not exist
			this.smfAlert("전형자료경로가 존재하지 않습니다.", function(){
				this.fnCheckFolderCallback(false);
			});
		}
	}
};

/**
* @description 인증서 체크
*/
this.fnCheckCertification = function(){

	//TODO 인증서 처리
	var keyUserDn = this.objKCASE.callMethod("SelectCertKM");
	var certInfo = this.objKCASE.callMethod("GetCertInfoKM", "");
	var certInfoList = certInfo.split("|");
	
	var certDtcNm = certInfoList[0];
	var eltsCertNo = certInfoList[1];
	var eltsDataValue = certInfoList[2];
	
	if(this.isNil(keyUserDn) || this.objKCASE.callMethod("GetErrorCode") != 0){
		// 인증서 오류
		if(this.objKCASE.callMethod("GetErrorCode") != 110007){
			this.smfAlert("인증서와 비밀번호를 확인하세요.", function(){});
		}
		return false;
	}
	
	//DB에 저장된 인증서와 선택한 인증서가 다른경우
	if(this.dsEltsInfo.getColumn(0, "eltsDataValue") != eltsDataValue) {
		this.smfAlert("등록된 담당자의 인증서 정보가 아닙니다.");
		return false;
	}
	
	this.fvKeyUserDn = eltsDataValue;

	return true;
}
