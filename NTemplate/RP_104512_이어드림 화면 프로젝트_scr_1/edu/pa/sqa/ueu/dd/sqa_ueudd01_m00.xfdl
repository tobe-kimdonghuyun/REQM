        <Button id="btnPath" taborder="3" text="복호화경로설정" top="111" width="125" cssclass="btn_WF_Custom" right="225" initvalueid="ivBtnAccessibilityButton" fittocontents="width" onclick="btnPath_onclick" height="30"/>
        <Button id="btnDec" taborder="4" text="복호화" top="111" height="30" width="68" cssclass="btn_WF_Crud" right="153" initvalueid="ivBtnAccessibilityButton" fittocontents="width" onclick="btnDec_onclick"/>
        <Grid id="grdApst" taborder="5" left="0" autofittype="col" top="151" right="0" binddataset="dsDecApst" bottom="170" initvalueid="ivGrdAccessibilityOn" selecttype="cell" onheadclick="grdApst_onheadclick" mouseovertype="cell" cellsizebandtype="body" cellsizingtype="col" oncellclick="grdApst_oncellclick">
