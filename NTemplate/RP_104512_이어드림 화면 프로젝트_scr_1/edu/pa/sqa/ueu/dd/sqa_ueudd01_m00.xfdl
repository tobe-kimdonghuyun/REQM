              <Static id="staDetaRcrit" taborder="4" text="세부모집시기" left="edtCoaRcritScCd:0" top="11" width="128" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Combo id="cboDetaRcrit" taborder="5" left="staDetaRcrit:0" width="200" height="30" innerdataset="dsDetaRcritPrd" codecolumn="detaRcritScValue" datacolumn="detaRcritScNm" index="-1" top="11" initvalueid="ivCmbNormal" accessibilitylabel="조회조건"/>
              <Static id="staCddcOrgCd" taborder="6" text="시도교육청" left="cboDetaRcrit:0" top="11" width="108" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" onclick="divSearch_staCddcOrgCd_onclick"/>
              <Combo id="cboCddcScCd" taborder="7" left="staCddcOrgCd:0" width="200" height="30" innerdataset="dsCddcScCd" codecolumn="unyCdValue" datacolumn="unyCdValueNm" index="-1" top="11" initvalueid="ivCmbNormal" accessibilitylabel="조회조건"/>
