              <Static id="Static65" taborder="10" text="~" left="calRcptnBgngYmd:0" top="51" width="15" height="30" cssclass="sta_WF_AC" initvalueid="ivStcAccessibilityOn" accessibilitylabel="부터"/>
              <Calendar id="calRcptnEndYmd" taborder="11" left="Static65:0" top="51" width="150" height="30" dateformat="yyyy.MM.dd" readonly="false" initvalueid="ivCalNormal" editformat="yyyy.MM.dd" onchanged="divSearch_calEndYmd_onchanged"/>
