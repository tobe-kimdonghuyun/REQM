              <Static id="sta00_00_01_01" taborder="1" left="30" top="73" height="23" cssclass="sta_WF_InfoTxt_Blue" text="전형자료복호화&lt;fc v='#172f57'&gt; : 암호화된 대입전형자료를 &lt;/fc&gt;복호화&lt;fc v='#172f57'&gt;합니다.&lt;/fc&gt;" wordWrap="char" width="1140" usedecorate="true" initvalueid="ivStcAccessibilityOn" onclick="divGuideInfo_sta00_00_01_01_onclick"/>
