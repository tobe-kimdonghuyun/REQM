<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sqa_ueudd00_m00" width="1200" height="900" titletext="전형자료수신" onload="sqa_ueudd00_m00_onload" onbeforeclose="sqa_ueudd00_m00_onbeforeclose">
    <Layouts>
      <Layout height="900" width="1200" screenid="ScreenDeskTop">
        <Div id="divSearch" taborder="0" left="0" top="0" height="70" cssclass="div_WF_Search" right="0" text="" initvalueid="ivDivAccessibilityOn" accessibilitylabel="조회영역">
          <Layouts>
            <Layout>
              <Static id="staCoaAyr" taborder="0" text="대입학년도" left="0" top="20" width="108" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtCoaAyr" taborder="1" left="staCoaAyr:0" top="20" width="100" height="29" text="강원도춘천교육지청" enable="true" readonly="true" initvalueid="ivEdtReadOnly"/>
              <Static id="staCoaRcritScCd" taborder="2" text="모집구분" left="edtCoaAyr:0" top="20" width="96" cssclass="sta_WF_Searchtxt01" height="30" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtCoaRcritScCd" taborder="3" left="staCoaRcritScCd:0" top="20" width="135" height="29" text="강원도춘천교육지청" enable="true" readonly="true" initvalueid="ivEdtReadOnly"/>
              <Static id="staDetaRcrit" taborder="4" text="세부모집시기" left="edtCoaRcritScCd:0" top="20" width="128" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Combo id="cboDetaRcrit" taborder="5" left="staDetaRcrit:0" width="200" height="30" innerdataset="dsDetaRcritPrd" codecolumn="detaRcritScValue" datacolumn="detaRcritScNm" index="-1" top="20" initvalueid="ivCmbNormal" accessibilitylabel="조회조건"/>
              <Static id="staCddcOrgCd" taborder="6" text="시도교육청" left="cboDetaRcrit:0" top="20" width="108" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" onclick="divSearch_staCddcOrgCd_onclick"/>
              <Combo id="cboCddcScCd" taborder="7" left="staCddcOrgCd:0" width="200" height="30" innerdataset="dsCddcScCd" codecolumn="unyCdValue" datacolumn="unyCdValueNm" index="-1" top="20" initvalueid="ivCmbNormal" accessibilitylabel="조회조건"/>
              <Button id="btnSearch" taborder="9" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="20" onclick="btnSearch_onclick"/>
            </Layout>
          </Layouts>
        </Div>
        <ImageViewer id="img00_00_01_00" taborder="1" text="전형자료수신" left="1" top="90" width="149" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
        <Button id="btnPath" taborder="2" text="수신경로설정" top="90" width="120" cssclass="btn_WF_Custom" right="128" initvalueid="ivBtnAccessibilityButton" fittocontents="width" onclick="btnPath_onclick" height="30"/>
        <Button id="btnRcptn" taborder="3" text="전형자료수신" top="90" height="30" width="120" cssclass="btn_WF_Crud" right="0" initvalueid="ivBtnAccessibilityButton" onclick="btnRcptn_onclick" enable="true"/>
        <Grid id="grdCddc" taborder="4" left="0" binddataset="dsRcptnCddc" autofittype="col" top="130" width="35%" bottom="180" initvalueid="ivGrdAccessibilityOn" selecttype="cell" oncellclick="grdCddc_oncellclick">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="150"/>
                <Column size="60"/>
                <Column size="60"/>
                <Column size="60"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="시도교육청"/>
                <Cell col="1" text="생성건수" cssclass="LineNo"/>
                <Cell col="2" cssclass="LineNo" text="미수신"/>
                <Cell col="3" cssclass="LineNo" text="수신완료"/>
              </Band>
              <Band id="body">
                <Cell displaytype="normal" edittype="none" text="bind:cddcOrgCdNm" textAlign="center"/>
                <Cell col="1" text="bind:trgtCnt" textAlign="right"/>
                <Cell col="2" textAlign="right" text="bind:impCnt"/>
                <Cell col="3" textAlign="right" text="bind:cmptnCnt"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Grid id="grdApst" taborder="5" left="grdCddc:30" top="130" binddataset="dsRcptnApst" autofittype="col" right="1" bottom="180" initvalueid="ivGrdAccessibilityOn" selecttype="cell" onheadclick="grdApst_onheadclick" oncellclick="grdApst_oncellclick">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="40"/>
                <Column size="150"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="120"/>
                <Column size="150"/>
                <Column size="120"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
                <Row size="40" band="summ"/>
              </Rows>
              <Band id="head">
                <Cell displaytype="checkboxcontrol" edittype="checkbox"/>
                <Cell col="1" displaytype="normal" text="시도교육청"/>
                <Cell col="2" text="합격년도"/>
                <Cell col="3" text="합격회차"/>
                <Cell col="4" text="이름"/>
                <Cell col="5" text="주민등록번호" cssclass="LineNo"/>
                <Cell col="6" text="수험번호"/>
                <Cell col="7" text="수신여부"/>
              </Band>
              <Band id="body">
                <Cell displaytype="expr:dwldYn == &quot;Y&quot; ? &quot;none&quot; : &quot;checkboxcontrol&quot;" edittype="expr:dwldYn == &quot;Y&quot; ? &quot;none&quot; : &quot;checkbox&quot;" text="bind:_chk" accessibilityrole="checkbox"/>
                <Cell col="1" text="bind:cddcOrgCdNm" textAlign="center"/>
                <Cell col="2" text="bind:passYr" textAlign="center"/>
                <Cell col="3" text="bind:passTme" textAlign="center"/>
                <Cell col="4" text="bind:kornFlnm" textAlign="center"/>
                <Cell col="5" text="bind:trprRrno" textAlign="center" maskeditformat="######-#######" maskedittype="string" displaytype="mask"/>
                <Cell col="6" text="bind:uvstExmtNo" textAlign="center"/>
                <Cell col="7" text="expr:dwldYn == &quot;Y&quot; ? &quot;수신완료&quot; :  &quot;미수신&quot;" textAlign="center"/>
              </Band>
              <Band id="summary">
                <Cell colspan="8" background="#fdfbe5" border="1px solid #c8c1c2" displaytype="text" color="#333333"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Div id="divGuideInfo" taborder="6" left="0" cssclass="div_WF_InfoBOX" right="0" height="160" initvalueid="ivDivAccessibilityOff" bottom="0" visible="true">
          <Layouts>
            <Layout>
              <Static id="sta00_00_01_01_00" taborder="0" left="29" top="28" height="23" cssclass="sta_WF_InfoTit" text="전형자료수신 안내사항" wordWrap="char" width="1140" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00_01_01" taborder="1" left="30" top="67" height="23" cssclass="sta_WF_InfoTxt_Blue" text="전형자료수신 : &lt;fc v='#172f57'&gt;자료요청 후 &lt;/fc&gt;암호화하여 생성된 대입전형자료를 다운로드&lt;fc v='#172f57'&gt;합니다.&lt;/fc&gt;" wordWrap="char" width="1140" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00_01_01_01" taborder="2" left="30" top="91" height="23" cssclass="sta_WF_InfoTxt_Blue" text="&lt;fc v='#172f57'&gt;전형자료 경로설정에서 지정된 경로의 하위 폴더 '1.전형자료수신'에 전형자료가 수신됩니다.&lt;/fc&gt;" wordWrap="char" width="1140" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00" taborder="3" left="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff" top="0"/>
              <Static id="sta99_00_00_00_00_01_01" taborder="4" left="0" top="30" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="20" text="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_00" taborder="5" left="0" height="20" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" bottom="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta99_00_00_00_00_01_01_00" taborder="6" top="30" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="20" text="30" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_01" taborder="7" left="30" top="51" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_01_00" taborder="8" left="33" top="71" height="16" cssclass="sta_GD_Size" text="5" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="5" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta00_00_01_01_01_00" taborder="9" left="30" top="115" cssclass="sta_WF_InfoTxt_Blue" text="'안전하지 않은 파일에 접근합니다. 계속 진행하시겠습니까?' &lt;fc v='#172f57'&gt;안내창이 나타날 경우&lt;/fc&gt; 반드시 '이 폴더 및 하위 폴더는 항상 허용'을 체크&lt;fc v='#172f57'&gt;하고 [Yes]를 클릭하여 합니다.&lt;/fc&gt;" wordWrap="char" width="1140" usedecorate="true" initvalueid="ivStcAccessibilityOn" bottom="20"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="Static99_00_00_00_00_01_00" taborder="7" left="0" top="70" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_00_00" taborder="8" left="0" top="120" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_00_00_00_00" taborder="9" left="419" top="86" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="160" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_00_00_01_00_01" taborder="10" left="0" top="720" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="1" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staChkCnt" taborder="11" text="" left="460" top="92" width="140" height="26" cssclass="sta_WF_Total" fittocontents="none" initvalueid="ivStcAccessibilityOn" onclick="staChkCnt_onclick"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    전형자료수신
*  @FileName 	sqa_ueudd00_m00.xfdl
*  @Creator 	bsw
*  @CreateDate 	2022.09.05
*  @Desction    대입전형-대학-전형자료수신
************** 소스 수정 이력 ***********************************************
*  date				Modifier				Description
*******************************************************************************
*  2022.09.05		bsw						최초 생성
*  2023.08.14		진승환					대학자료수신 폴더 오류 수정
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvCoaDataDownPath = this.sqafGetCoaDataDownPath();   // 수신경로 
this.fvPrcsType = 0;									  //폴더 권한 확인
this.fvSendSize = 100;	   								  //임시로 100건으로 함.
var today = this.smfToday();							  //금일		
this.fvCallback;										  //콜백함수	
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose, ontimer)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리
 */
this.sqa_ueudd00_m00_onload = function(obj,e) {

	// Div 초기화
	this.smfInitDiv(obj);

//  	// Grid Checkbox 활성화/활성화 제어
//  	this.smfUpdateRednerGridCheckbox(this.grdList, 0, this.fnRenderGridCheckbox);
//
//  	// 조회 입력창에서 'Ctrl' + 'Enter' 키 입력시 조회수행 이벤트 설정
//  	this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
//
//  	// 데이터 입력 창에서 'Ctrl' + 'Enter' 키 입력시 저장수행 이벤트 설정
//  	this.smfBindEnterKeyToSearch(this.dsList, this.btnSave);

	//초기화
	this.fnInit(obj);

	// 서버단에 설정한 유효성 검증 목록을 획득하여 설정
	this.fnSearchValidation();
	
	//공통코드 조회
	this.fnSerachCmmCd();		
			
	// 검정고시대입 공통조회
	this.fnOnloadSearch(obj, ["dsDetaRcritPrd"]);
};

/**
 * @description 화면 폼 닫기전 이벤트
 */
this.sqa_ueudd00_m00_onbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
// 		// 변경내역이 발생한 경우 종료전 confirm수행
// 	return this.smfCloseFormConfirm([this.dsDetaRcritPrd]);
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
};

/**
 * @description 폴더 권한확인 콜백
 * @param : isComplete - 완료 확인
 */
this.fnCheckFolderCallback = function(isComplete){
	if(!isComplete){
		return;
	}
	
	this.fvPrcsType = 1;		//폴더권한확인
	this.fnDoNext();			//다음 실행
}

/**
 * @description 파일쓰기 콜백
 */
this.fnVirtualFileCallback = function(){
	var idx = this.dsFile.getColumn(0, "idx");						//dsRcptnApst의 인덱스
	var nm = this.dsFile.getColumn(0, "coaSeleFileNm");				//파일명
	var cn = this.dsFile.getColumn(0, "coaSeleFileCn");				//파일blob
	var crtDt = this.smfTodayTime().substr(0,14);					//파일생성시간(완료)	

	//파일생성시간(완료)
	this.dsRcptnApst.setColumn(idx, "crtDt", crtDt)
	
	//수신완료 처(dsRcptnApst 세팅)
	if(!this.smfIsNull(cn)) {	
		this.dsRcptnApst.setColumn(idx, "dwldYn", "Y");												//수신여부
		this.dsRcptnApst.setColumn(idx, "rmkCn", "전형자료 수신 : 파일생성(" + nm + ")");		//비고
	} else {	
		this.dsRcptnApst.setColumn(idx, "dwldYn", "N");												//수신여부
		this.dsRcptnApst.setColumn(idx, "rmkCn", "전형자료 수신 : 파일생성오류(" + nm + ")");	//비고
	}	
	
	this.dsRcptnApstFile.deleteRow(0);								//스텝별로 조회한 파일정보 dsRcptnApstFile 삭제
	this.dsFile.deleteRow(0);										//dsRcptnApstFile에서 복사한 정보 dsFile 삭제
	
	//스텝별 대상자 ds 건수 체크
	if(this.dsRcptnApstFile.rowcount == 0) {
		//업로드ds(dsRcptnApstParts)에 마스터ds(dsRcptnApst) 데이터 업데이트
		var max = this.dsRcptnApstParts.rowcount;
		for(var i = 0 ; i < max; i++) {
			var idx = this.dsRcptnApstParts.getColumn(i, "idx");											//dsRcptnApst의 인덱스
			this.dsRcptnApstParts.setColumn(i, "dwldYn", this.dsRcptnApst.getColumn(idx, "dwldYn"));		//수신여부
			this.dsRcptnApstParts.setColumn(i, "rmkCn", this.dsRcptnApst.getColumn(idx, "rmkCn"));		//비고
			this.dsRcptnApstParts.setColumn(i, "crtDt", this.dsRcptnApst.getColumn(idx, "crtDt"));		//생성시간
			this.dsRcptnApstParts.setColumn(i, "dmndDt", this.dsRcptnApst.getColumn(idx, "dmndDt"));		//요청시간
		}	
		this.fnExecuteRctnCmptn(this.fvCallback);					//파일생성완료처리(스텝별로 완료처리) 
	} else {
		this.fnMakeFile();											//다음파일생성
	}	
}

/**
 * @description 전형자료경로설정 팝업 콜백함수
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체 
 */
this.fnCoaDataPathCallback = function(e, sender){
	// 2023-08-14 대학자료수신 폴더 참조 문제 수정
	this.fvCoaDataDownPath = this.sqafGetCoaDataDownPath();
	//this.fvCoaDataPathNm = nexacro.getPrivateProfile(this.sqav_coaDataPathValue);		//경로설정
}
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리

************************************************************************************************/
/**
 * @description 유효성 검증 목록 조회
*/
this.fnSearchValidation = function() {
	this.smfValidateService("validateMain", {
			url: "/sqa_ueu_dd00_001.do",
		})
		.mappingRulesetToForm(this.divSearch, "search")					//조회Valid
		.run()
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;
		});
};

/**
 * @description 공통코드 조회
*/
 this.fnSerachCmmCd = function() {		
	this.smfCodeList("code", [this.dsCddcScCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.divSearch.form.cboCddcScCd.set_index(0);
		})
		.run()
	;
};

/**
 * @description 시도 조회
 * @param 선택한 시도 인덱스
*/
this.fnSearchCddc = function(idx) {

	this.dsRcptnApst.clearData();
	this.grdApst.setCellProperty("summary", 0, "text", "" );

	this.smfSearchService("listCtpvRcptnPnsta")
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;
			if(this.smfIsNull(this.dsSearch.getColumn(0, "cddcOrgCd"))) {	//전체인경우
				this.dsRcptnCddc.set_filterstr();
			} else {
				this.dsRcptnCddc.set_filterstr("cddcOrgCdNm != '전체'");
			}
			if(!this.smfIsNull(idx)) {
				this.grdCddc.setCellPos(idx);
				this.fnSearchApst();
			}
		});
}

/**
 * @description 지원자 조회
*/
this.fnSearchApst = function() {
	this.smfSearchService("listCtpvRcptnApst")
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;			
			this.staChkCnt.set_text("선택건수 : " + 0 )
			this.grdApst.setCellProperty("summary", 0, "text", "자료수신 대상 건수 : " + this.dsRcptnApst.rowcount + "건" );					
		});
}

/**
 * @description 지원자 파일정보 조회
*/
this.fnExecuteRcptnParts = function(callback) {
	this.smfSearchService("listCtpvRcptnApstFile")
		.run() // 실행
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;		
			this.fvCallback = callback;
			this.fnMakeFile();
		});
}

/**
 * @description 지원자 수신완료처리
*/
this.fnExecuteRctnCmptn = function(callback) {

	this.smfExecuteService("executeRctnCmptn")
	    .showConfirm(false)
		.beforeService(function(next){
 			next();
 		})
		.run() // 실행
		.callback(function(callbackParams) {
			if(this.smfIsFunc(callback)) callback.call(this, callbackParams); 				
			if(callbackParams.errors) return;
		});
}
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 초기화
*/
 this.fnInit = function(obj) {
	//세션정보 세팅
	this.dsSearch.setColumn(0, "coaAyr", this.sqav_coaAyr);
	this.dsSearch.setColumn(0, "coaRcritScCd", this.sqav_coaRcritScCd);
	this.dsSearch.setColumn(0, "coaRcritScNm", this.sqav_coaRcritScNm);
	this.dsSearch.setColumn(0, "uvstOrgCd", this.sqav_uvstOrgCd);
};

/**
* @description 검정고시 대입전형 공통조회 콜백
*/
this.fnOnloadSearchCallback = function() {
	//세부모집시기의 조건 - 사용중인 것만 나오도록
	this.dsDetaRcritPrd.set_filterstr(today + " >= detaRcritScBgngYmd  && " + today + " <= detaRcritScEndYmd");
	this.dsSearch.setColumn(0, 'detaRcritScValue', this.dsDetaRcritPrd.getColumn(0, 'detaRcritScValue'));
	this.dsDetaRcritPrd.setColumn(this.dsDetaRcritPrd.insertRow(0), "detaRcritScNm", "선택");
	this.divSearch.form.cboDetaRcrit.set_index(0);
};

/**
* @description 전형자료수신 validation
*/
this.fnExecuteRcptnValid = function() {
		
 	if(this.dsRcptnApst.getRowCount() == 0 ) {
 		this.smfAlert("자료를 수신할 지원자가 없습니다.");
 		return false; 
 	};
	
	var vnChkRowCnt	= this.dsRcptnApst.getCaseCount("_chk == '1'");
	if(vnChkRowCnt == 0){
 		this.smfAlert("자료를 수신할 지원자를 먼저 선택하여 주십시오.");
		return false;
	}
	
	return true;
}

/**
 * @description 폴더 권한 확인
 */
this.fnCheckFolder = function(){
	this.fvPrcsType = 0;

	if(this.smfIsNull(this.sqafGetCoaDataPath())) {
		this.smfAlert("전형자료경로가 존재하지 않습니다.");
		return;
	}	

	this.VirtualFile00.isExist(this.sqafGetCoaDataPath());
}

/**
 * @description 다음 프로세스 호출(자료수신 스텝별)
 */
this.fnDoNext = function() {
	this.fnExecuteRcptn(this.dsRcptnApst, this.dsRcptnApstParts, this.fvSendSize,
		function() {
			this.smfAlert("전형자료수신 작업이 완료되었습니다.", "", function() {
				var chcCddcOrgCd = this.dsSearch.getColumn(0, "chcCddcOrgCd");
				var idx = this.dsRcptnCddc.findRow("cddcOrgCd", chcCddcOrgCd);
				this.fnSearchCddc(idx); 			//시도현황조회
			});			
		}	
	).run();
}

/**
 * @description 자료수신 (by건)
 * @param : dsFrom		- 원본데이터
 * @param : dsTo		- 송신데이터 ( nMax 수량을 가짐 )
 * @param : nMax		- 최대 데이터 수량
 * @return : Object { run }
 */
this.fnExecuteRcptn = function(dsFrom, dsTo, nMax, completeCallback){
	var _that = this;
	var nStepIdx = 0;
	//var nTotalCnt = dsFrom.getRowCount();
	var nTotalCnt 	= dsFrom.getCaseCount("_chk == '1'");
	var chkArray	= dsFrom.extractRows("_chk == '1'");
	
	
	//스텝 만들기 [{nIdxStart, nIdxEnd}...]
	var aStep = Array(Math.ceil(nTotalCnt / nMax)).fill().map(function(a, i) {
		var end = (i + 1) * nMax;
		return {
			nIdxStart : i * nMax,
			nIdxEnd : end < nTotalCnt ? end : nTotalCnt
		}
	});

	//자료수신 이전 스텝(건수)별로 데이터셋 복사
	function copyDataByStep() {
		if(nStepIdx == 1){
			if(_that.smfIsFunc(completeCallback)) completeCallback.call(_that);
			return false;
		}
		
		//초기화
		dsTo.clearData();
		//for(var i = step.nIdxStart; i < step.nIdxEnd; i++){			
		for(var i = 0; i < chkArray.length; i++){
			dsTo.copyRow(dsTo.addRow(), dsFrom, chkArray[i]);	
			dsTo.setColumn(i, "idx", chkArray[i]);				//선택이아닌 전체임으로 복사 시 idx 세팅
		}
		
		//시작번호(스텝)
		_that.dsSearch.setColumn(0, "idx", chkArray[nStepIdx]);
		trace("fnExecuteRcptn ___ copyDataByStep");
		nStepIdx++;
		return true;
	}
	
	//자료수신 callback
	function next(callbackParams) {
		trace("fnExecuteRcptn ___ callbackParams1");
		if(callbackParams.errors) return;
		trace("fnExecuteRcptn ___ callbackParams2");
		this.setWaitCursor(true);
		trace("fnExecuteRcptn ___ callbackParams3");
		if(copyDataByStep()){
			_that.fnExecuteRcptnParts.call(_that, next);
		}
		trace("fnExecuteRcptn ___ callbackParams4");
		this.setWaitCursor(false);
		trace("fnExecuteRcptn ___ callbackParams5");
	}
	
	//자료수신 호출
	function run(){
		if(copyDataByStep()) _that.fnExecuteRcptnParts.call(_that, next);
	}
	
	return {
		run
	}
};

/**
* @description virtualFile 생성
*/
this.fnMakeFile = function() {
	this.dsFile.copyRow(this.dsFile.addRow(), this.dsRcptnApstFile, 0);
	this.VirtualFile00.open(this.fvCoaDataDownPath + this.dsFile.getColumn(0, "coaSeleFileNm")+".enc", VirtualFile.openText | VirtualFile.openWrite);				
}

/**
* @description virtualFile 성공
*/
this.VirtualFile00_onsuccess = function(obj:nexacro.VirtualFile,e:nexacro.VirtualFileEventInfo)
{	
	if(this.fvPrcsType == 0){ //폴더 권한 확인
		if(e.reason == 10) {	//isExist complete
			if(e.fileisexist){
				this.fnCheckFolderCallback(true);
			} 
		} else{
			this.smfAlert("전형자료경로가 존재하지 않습니다.", function(){
				this.fnCheckFolderCallback(false);
			});
		}
	} else {
		if(e.reason == 1){	//open complete
			var idx = this.dsFile.getColumn(0, "idx");					//dsRcptnApst의 인덱스
			var cn = this.dsFile.getColumn(0, "coaSeleFileCn");			//파일내용
			var dmndDt = this.smfTodayTime().substr(0,14)				//요청시간(파일생성시작시간)
			this.dsRcptnApst.setColumn(idx, "dmndDt", dmndDt);
			
			if(this.smfIsNull(cn)) {
				obj.close();
			} else{
				obj.write(cn, 'utf-8');			//파일쓰기
			}
		} else if(e.reason == 2){ //close complete
			this.fnVirtualFileCallback();
		} else if(e.reason == 6){ //write complete			
			obj.close();
		}
	}
};

/**
* @description virtualFile 에러
*/
this.VirtualFile00_onerror = function(obj:nexacro.VirtualFile,e:nexacro.VirtualFileErrorEventInfo)
{
	if(this.fvPrcsType == 0){ //폴더 권한 확인
		if(e.statuscode == '1102'){ //Permission Denied
			this.smfAlert("전형자료경로에 접근권한이 없습니다.", function(){
				this.fnCheckFolderCallback(false);
			});
		}else if(e.statuscode == '1105'){ //Does not exist
			this.smfAlert("전형자료경로가 존재하지 않습니다.", function(){
				this.fnCheckFolderCallback(false);
			});
		}
	}
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
* @description 조회
*/
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearchCddc();
};

/**
* @description 그리드 체크박스 클릭
*/
this.grdApst_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var columnName = obj.getCellProperty("body",e.cell,"text");
	if ("bind:_chk" == columnName){
	
		var sColId = obj.getCellProperty("body",e.cell,"text")
		if("bind:_chk" != sColId) return;
		
		var oldChkYn = obj.getCellProperty("head",0,"expr")
		var chkYn = obj.getCellProperty("head", 0, "expr") == "1" ? "0" : "1";
		
		obj.setCellProperty("head", 0 , "expr", chkYn)
		
		var sendSum = 0;
		
		for(var i = 0; i<this.dsRcptnApst.rowcount; i++){
			dwldYn = this.dsRcptnApst.getColumn(i, "dwldYn");
			displaytype = this.fnGetcheck(dwldYn);
			
			if(displaytype == "checkboxcontrol"){
				this.dsRcptnApst.setColumn(i, "_chk", chkYn);
				if(chkYn == "1"){
					sendSum += 1;
				}
			}
			this.staChkCnt.set_text("선택건수 : " + sendSum)
		}
		
// 		// 선택가능한 항목만 토글
// 		this.smfToggleChkHeader(obj, e, function(ds, nRow){
// 			return ds.getColumn(nRow, 'dwldYn') == "N";
// 		});
		
	}else{
		// 정렬
		this.smfCheckAndSort(obj, e);
	}
};

/**
* @description 자료수신
*/
this.btnRcptn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(!this.fnExecuteRcptnValid()) return;
	
	this.smfConfirm("전형자료수신을 실행하시겠습니까? ", function(confirmParams){
		if(confirmParams.confirmResult) {
			//초기화
			this.dsRcptnApstFile.clearData();
			
			//폴더 권한확인
			this.fnCheckFolder();											
		}
	});
};

/**
* @description 지원자조회
*/
this.grdCddc_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	this.dsSearch.setColumn(0, "chcCddcOrgCd", this.dsRcptnCddc.getColumn(e.row, "cddcOrgCd"));
	this.fnSearchApst();
};

/**
* @description 경로설정 팝업
*/
this.btnPath_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 팝업 파라메터
	var popupParams = {
		callback: this.fnCoaDataPathCallback, // 콜백함수 지정
		sender: obj, // sender 지정
		params: {
			procType: "search" // 처리타입 지정
		  , dsParam :  this.dsSearch
		},
	};

	// 모달팝업 실행
	this.smfDialog("sqa_ueudd00_p00", "pa_sqa_ueu_dd::sqa_ueudd00_p00.xfdl", popupParams);
};

/**
 * @description 체크박스 displaytype설정
 */
this.fnGetcheck = function(param)
{
	var rtn = "none";

 	if(param == "N")
	{
		rtn = "checkboxcontrol";
	}

	return rtn;
};

this.grdApst_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var ds = this.dsRcptnApst;
	var sendSum = 0;

	if(e.cell == 0){
		
		chkYn =  ds.getColumn(e.row, "_chk")
		ds.setColumn(e.row, "_chk", chkYn)
		dwldYn = (ds.getColumn(e.row, "dwldYn") == "N" ? 1 : 0);
		
		for(var i = 0; i < ds.rowcount; i++){
			if(ds.getColumn(i, "_chk") == "1"){
				dwldYn = (ds.getColumn(i, "dwldYn") == "N" ? 1 : 0);
				sendSum += dwldYn;
				
				this.staChkCnt.set_text("선택건수 : " + sendSum);
			}
		}
		this.staChkCnt.set_text("선택건수 : " + sendSum);
	}
};
