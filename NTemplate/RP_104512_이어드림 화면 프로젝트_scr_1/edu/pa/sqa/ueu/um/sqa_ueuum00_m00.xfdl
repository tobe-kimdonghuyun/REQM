<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frm01" width="1280" height="707" titletext="시도담당자조회" onload="frm01_onload">
    <Layouts>
      <Layout height="707" width="1280" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="70" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="시도담당자 조회" left="0" top="0" height="44" cssclass="img_WF_SubTit01" width="290" initvalueid="ivTitleAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divSearch" taborder="1" left="0" top="144" height="70" cssclass="div_WF_Search" right="0" initvalueid="ivDivAccessibilityOn" accessibilitylabel="조회영역">
          <Layouts>
            <Layout>
              <Static id="staCoaAyr" taborder="0" text="대입학년도" left="0" top="20" width="108" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtCoaAyr" taborder="1" left="staCoaAyr:0" width="101" height="30" top="20" initvalueid="ivEdtEssential" readonly="false" enable="false" accessibilitylabel="대입학년도"/>
              <Static id="staCoaRcritScNm" taborder="2" text="모집구분" left="edtCoaAyr:0" top="20" width="96" height="30" cssclass="sta_WF_Searchtxt01"/>
              <Edit id="edtCoaRcritScNm" taborder="3" left="staCoaRcritScNm:0" width="135" height="30" top="20" initvalueid="ivEdtEssential" readonly="false" enable="false"/>
              <Static id="staCode" taborder="4" text="교육청" left="edtCoaRcritScNm:0" top="20" width="99" height="30" cssclass="sta_WF_Searchtxt01"/>
              <Combo id="cboCddcCd" taborder="5" left="staCode:0" width="316" height="30" innerdataset="dsCddcList" codecolumn="orgCd" datacolumn="kornOrgNm" text="과목" readonly="false" value="0" top="20" initvalueid="ivCmbNormal" onitemchanged="divSearch_cmbGb_onitemchanged" index="0" accessibilitylabel="교육청"/>
              <Button id="btnSearch" taborder="6" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="20" onclick="divSearch_btnSearch_onclick"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnExcel" taborder="2" text="액셀내려받기" top="234" width="126" height="30" cssclass="btn_WF_Excel03" right="0" onclick="btnExcel_onclick" initvalueid="ivBtnAccessibilityButton"/>
        <Grid id="grdList" taborder="3" left="0" top="274" autofittype="col" right="0" onheadclick="grdMain_onheadclick" binddataset="dsResult" nodatatext="조회된 데이터가 없습니다." height="356" accessibilitylabel="시도담당자조회" initvalueid="ivGrdAccessibilityOn" selecttype="cell">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="150"/>
                <Column size="107"/>
                <Column size="153"/>
                <Column size="130"/>
                <Column size="130"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="시도"/>
                <Cell col="1" text="시도코드"/>
                <Cell col="2" text="성명"/>
                <Cell col="3" text="연락처"/>
                <Cell col="4" text="팩스번호"/>
              </Band>
              <Band id="body">
                <Cell text="bind:cddcOrgNm" textAlign="center"/>
                <Cell col="1" text="bind:cddcOrgCd" textAlign="center"/>
                <Cell col="2" text="bind:prgeFlnm" textAlign="center"/>
                <Cell col="3" text="bind:cddcTelno" textAlign="center"/>
                <Cell col="4" text="bind:cddcFxno" textAlign="center"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="Static99_00_00_00_00" taborder="4" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01" taborder="5" left="0" top="114" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_01" taborder="6" left="0" top="214" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_01_00" taborder="7" left="0" top="264" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_00_00_00" taborder="8" left="0" top="677" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    시도담당자조회
*  @FileName 	sqa_ueuum00_m00.xfdl
*  @Creator 	박가혜
*  @CreateDate 	2023.02.01
*  @Desction    대입전형-대학-시도담당자조회
************** 소스 수정 이력 ***********************************************
*  date				Modifier				Description
*******************************************************************************
*  2022.09.05		박가혜					최초 생성
*******************************************************************************
*/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리
 */
this.frm01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	this.dsSearch.addRow();

	this.dsSearch.setColumn(0, "coaAyr", this.sqav_coaAyr);
	this.dsSearch.setColumn(0, "coaRcritScCd", this.sqav_coaRcritScCd);
	this.dsSearch.setColumn(0, "coaRcritScNm",  this.sqav_coaRcritScNm);
	this.dsSearch.setColumn(0, "uvstOrgCd",  this.sqav_uvstOrgCd);

		  // 서버단에 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
			url: "/sqa_ueu_um00_000.do",
		})

		.mappingRulesetToForm(this.divSearch, "search")
		.run() 
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.fnCddcList(); //시도교육청목록 조회
			
	
		})
	; 	
	
	
	
};

/************************************************************************************************
 * TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnCddcList = function(){
	this.smfSearchService("listCddcList")
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
				this.dsCddcList.insertRow(0);
				this.dsCddcList.setColumn(0, "orgCd", "");
				this.dsCddcList.setColumn(0, "kornOrgNm", "전체");
				this.divSearch.form.cboCddcCd.set_index(0);
				this.divSearch_btnSearch_onclick();
		}) // 콜백
	;

}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 조회 버튼 클릭
 */
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	this.smfSearchService("listPrgeInfo")
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;		
		})
	;
};


/**
 * @description 엔터키실행
 */
this.fnKeyUp = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode=='13'){
		this.btnSearch_onclick();
	}
};
/**
 * @description 엑셀다운로드
 */
this.btnExcel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objOption = {
						objGrid : this.grdList
					,   sheetname : "시도담당자목록"
					,   filename : "시도담당자목록"
					};
	
	this.smfExcelExport(objOption);
};

]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listCddcList</Col>
            <Col id="url">sqa_ueu_um00_001.do</Col>
            <Col id="outDatasets">dsCddcList=dsCddcList</Col>
          </Row>
          <Row>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResult=dsResult</Col>
            <Col id="asynctp"/>
            <Col id="url">sqa_ueu_um00_002.do</Col>
            <Col id="id">listPrgeInfo</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsResult" onrowposchanged="dsUesUemUm04M00SVO_listUesUemUm04M00_onrowposchanged" useclientlayout="true">
        <ColumnInfo>
          <Column id="coaAy" type="STRING" size="4"/>
          <Column id="coaRcritScCode" type="STRING" size="1"/>
          <Column id="cddcOrgCd" type="STRING" size="10"/>
          <Column id="cddcOrgNm" type="STRING" size="300"/>
          <Column id="prgeFlnm" type="STRING" size="30"/>
          <Column id="prgeMblTelNo" type="STRING" size="30"/>
          <Column id="cddcTelno" type="STRING" size="30"/>
          <Column id="cddcFxno" type="STRING" size="30"/>
        </ColumnInfo>
      </Dataset>
      <Dataset cancolumnchange="dsSearch_cancolumnchange" enableevent="true" id="dsSearch" loadfiltermode="keep" loadkeymode="keep" updatecontrol="true" useclientlayout="true">
        <ColumnInfo>
          <Column id="coaAyr" size="4" type="STRING"/>
          <Column id="coaRcritScCd" size="1" type="STRING"/>
          <Column id="coaRcritScNm" type="STRING" size="256"/>
          <Column id="cddcOrgCd" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsCddcList" onrowposchanged="dsUesUemUm04M00SVO_listUesUemUm04M00_onrowposchanged" useclientlayout="true">
        <ColumnInfo>
          <Column id="orgCd" type="STRING" size="10"/>
          <Column id="kornOrgNm" type="STRING" size="300"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item2" compid="divSearch.form.cboCddcCd" propid="value" datasetid="dsSearch" columnid="cddcOrgCd"/>
      <BindItem id="item0" compid="divSearch.form.edtCoaAyr" propid="value" datasetid="dsSearch" columnid="coaAyr"/>
      <BindItem id="item1" compid="divSearch.form.edtCoaRcritScNm" propid="value" datasetid="dsSearch" columnid="coaRcritScNm"/>
    </Bind>
  </Form>
</FDL>
