<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sqa_ueudr10_m00" width="1280" height="900" titletext="대입전형자료온라인제공" onload="fnOnload" nHeight="754">
    <Layouts>
      <Layout height="900" width="1280" screenid="ScreenDeskTop">
        <ImageViewer id="imgTitle" taborder="0" text="대입전형자료요청관리" left="0" top="80" height="44" cssclass="img_WF_SubTit01" width="360" initvalueid="ivTitleAccessibilityOn"/>
        <Button id="btnStep01" taborder="1" text="대학기본정보관리" left="0" top="164" height="66" cssclass="btn_WF_StepS" width="11.88%" onclick="btnStep_onclick" initvalueid="ivBtnAccessibilityButton"/>
        <Static id="staNextStep01" taborder="2" left="btnStep01:17" top="174" width="38" height="47" cssclass="sta_WF_NextStep" initvalueid="ivStcAccessibilityOn" accessibilitylabel="다음"/>
        <Button id="btnStep02" taborder="3" text="대상학생자료&#13;&#10;올리기" left="staNextStep01:12.936000000000007" top="164" width="11.88%" height="66" cssclass="btn_WF_StepN" onclick="btnStep_onclick" initvalueid="ivBtnAccessibilityButton"/>
        <Static id="staNextStep01_00" taborder="4" left="btnStep02:17.872000000000014" top="174" width="38" height="47" cssclass="sta_WF_NextStep" initvalueid="ivStcAccessibilityOn" accessibilitylabel="다음"/>
        <Button id="btnStep03" taborder="5" text="대상학생자료요청" left="staNextStep01_00:8.872000000000014" top="164" width="14.50%" cssclass="btn_WF_StepN" onclick="btnStep_onclick" initvalueid="ivBtnAccessibilityButton" bottom="staNextStep01_00:-20"/>
        <Button id="btnStep04" taborder="6" text="재송부학생자료요청" left="staNextStep01_00:8.872000000000014" top="200" width="14.5%" height="30" cssclass="btn_WF_StepN" onclick="btnStep_onclick" initvalueid="ivBtnAccessibilityButton"/>
        <Static id="staNextStep01_00_00" taborder="7" left="btnStep03:14.807999999999993" top="174" width="38" height="47" cssclass="sta_WF_NextStep" initvalueid="ivStcAccessibilityOn" accessibilitylabel="다음"/>
        <Button id="btnStep05" taborder="8" text="전형자료생성" left="staNextStep01_00_00:9.807999999999993" top="164" width="11.88%" height="66" cssclass="btn_WF_StepN" onclick="btnStep_onclick" initvalueid="ivBtnAccessibilityButton"/>
        <Static id="staNextStep01_00_01" taborder="9" left="btnStep05:17.744000000000028" top="174" width="38" height="47" cssclass="sta_WF_NextStep" initvalueid="ivStcAccessibilityOn" accessibilitylabel="다음"/>
        <Button id="btnStep06" taborder="10" text="전형자료수신" left="staNextStep01_00_01:13.744000000000028" top="164" width="11.88%" height="66" cssclass="btn_WF_StepN" onclick="btnStep_onclick" initvalueid="ivBtnAccessibilityButton"/>
        <Static id="staNextStep01_00_02" taborder="11" left="btnStep06:10.68100000000004" top="174" width="48" height="47" cssclass="sta_WF_NextStep" initvalueid="ivStcAccessibilityOn" accessibilitylabel="다음"/>
        <Button id="btnStep07" taborder="12" text="전형자료복호화" top="164" height="66" cssclass="btn_WF_StepN" onclick="btnStep_onclick" initvalueid="ivBtnAccessibilityButton" left="staNextStep01_00_02:1.68100000000004" right="0"/>
        <Div id="divMain" taborder="13" left="0" top="250" cssclass="div_WF_Detail" url="pa_sqa_ueu_dr::sqa_ueudr00_m00.xfdl" text="" bottom="30" right="0" initvalueid="ivDivAccessibilityOff"/>
        <Static id="Static99_00_00_00_00" taborder="14" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01" taborder="15" left="0" top="134" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_01" taborder="16" left="0" top="230" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
