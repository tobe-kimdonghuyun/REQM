    <Script type="xscript5.1"><![CDATA[/**
 *	시도별대상학생오류내역조회
 *	@MenuPath	대입전형(검정고시)-시도별대상학생오류내역조회
 *	@FileName 	sqa_ueudr02_p03.xfdl
 *	@Creator 	bsw
 *	@CreateDate	2023.02.01
 *	@Desction	
 ************** 소스 수정 이력 ***********************************************
 *	date			Modifier			Description
 *******************************************************************************
 *	2023.02.01		bsw				최초 생성
 *******************************************************************************
 */

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리
 */
this.sqa_ueudr02_p03_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Div 초기화
	this.smfInitDiv(obj);

//  	// Grid Checkbox 활성화/활성화 제어
//  	this.smfUpdateRednerGridCheckbox(this.grdList, 0, this.fnRenderGridCheckbox);
//
//  	// 조회 입력창에서 'Ctrl' + 'Enter' 키 입력시 조회수행 이벤트 설정
//  	this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
//
//  	// 데이터 입력 창에서 'Ctrl' + 'Enter' 키 입력시 저장수행 이벤트 설정
//  	this.smfBindEnterKeyToSearch(this.dsList, this.btnSave);

	//파라메터세팅
	this.pv_params = this.smfGetPopupParams();
	this.dsSearch.copyRow(0, this.pv_params.dsParam, 0);
	
	this.btnSearch.click();
};

/**
 * @description 폼 닫기전 이벤트
 */
this.sqa_ueudr02_p03_onbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
// 	// 변경내역이 발생한 경우 종료전 confirm수행
// 	return this.smfCloseFormConfirm([this.dsList]);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
* @description 조회
*/
this.fnSearch = function(obj, e) {
	//데이터셋세팅
	this.dsService.setColumn(0, "inDatasets", "dsSearch=dsSearch dsPageInfo=dsPageInfo");
	this.dsService.setColumn(0, "outDatasets", "dsList=dsList dsPageInfo=dsPageInfo");
	
	this.smfSearchService("listCtpvApstErrDtl")
		.paginator(this.grdList, this.divPaging, this.divPageSummary, this.dsPageInfo, obj, e)	// 페이징처리
		.run() // 실행
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;
		}) // 콜백
};

/**
 * @description 엑셀다운
 */
this.fnExcel = function() {
	//데이터셋세팅
	this.dsService.setColumn(0, "inDatasets", "dsSearch=dsSearch");
	this.dsService.setColumn(0, "outDatasets", "dsExcel=dsExcel");
	
	this.smfSearchService("listCtpvApstErrDtl")
		.run() // 실행
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;		
			
			//엑셀다운로드
			var objOption = {	objGrid : this.grdExcel
				,	sheetname : "Sheet1"
				,   filename : "시도별 대상학생 오류내역(" + this.dsSearch.getColumn(0,"cddcOrgCdNm") + ")"	 
				};
			this.smfExcelExport(objOption);
		});
};

/**
 * @description 폼 닫기전 이벤트
 */
this.sqa_ueudr02_p02_onbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	// 변경내역이 발생한 경우 종료전 confirm수행
	return this.smfCloseFormConfirm([this.dsList]);
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 초기화 FUNCTION
 */

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 조회
 */
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearch(obj, e);
};

/**
 * @description 엑셀다운
 */
this.btnExcel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.dsList.rowcount == 0 ) {
		this.smfAlert('조회 후 엑셀다운로드가 가능합니다.');
		return;
	}
	
	this.fnExcel();
};

/**
 * @description 닫기
 */
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listCtpvApstErrDtl</Col>
            <Col id="url">/sqa_ueu_dr02_006.do</Col>
            <Col id="inDatasets"/>
            <Col id="outDatasets"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" oncolumnchanged="dsSearch_oncolumnchanged">
        <ColumnInfo>
          <Column id="coaAyr" type="STRING" size="256"/>
          <Column id="coaRcritScCd" type="STRING" size="256"/>
          <Column id="coaRcritScNm" type="STRING" size="256"/>
          <Column id="uvstOrgCd" type="STRING" size="256"/>
          <Column id="detaRcritScValue" type="STRING" size="256"/>
          <Column id="cddcOrgCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsList" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcOrgCd" type="STRING" size="256"/>
          <Column id="cddcOrgCdNm" type="STRING" size="256"/>
          <Column id="detaRcritScValue" type="STRING" size="256"/>
          <Column id="detaRcritScNm" type="STRING" size="256"/>
          <Column id="trprRrno" type="STRING" size="256"/>
          <Column id="errCn" type="STRING" size="256"/>
          <Column id="mdfcnDt" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsPageInfo" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="initPageIndex" type="INT" size="30" value="1"/>
          <ConstColumn id="initPageSize" type="INT" size="30" value="100"/>
          <Column id="pageIndex" type="INT" size="256"/>
          <Column id="pageSize" type="INT" size="256"/>
          <Column id="totalCount" type="INT" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsExcel" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcOrgCd" type="STRING" size="256"/>
          <Column id="cddcOrgCdNm" type="STRING" size="256"/>
          <Column id="detaRcritScValue" type="STRING" size="256"/>
          <Column id="detaRcritScNm" type="STRING" size="256"/>
          <Column id="trprRrno" type="STRING" size="256"/>
          <Column id="errCn" type="STRING" size="256"/>
          <Column id="mdfcnDt" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
  </Form>
</FDL>
