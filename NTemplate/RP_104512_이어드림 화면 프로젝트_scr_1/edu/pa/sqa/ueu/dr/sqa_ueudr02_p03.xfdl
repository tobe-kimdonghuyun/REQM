        <Static id="Static99_00_00_00_00_01_00_00_00_01_00_00_00" taborder="11" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" initvalueid="ivStcAccessibilityOff" bottom="0"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_01_00_00_00_00" taborder="12" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" right="0" initvalueid="ivStcAccessibilityOff" bottom="0"/>
