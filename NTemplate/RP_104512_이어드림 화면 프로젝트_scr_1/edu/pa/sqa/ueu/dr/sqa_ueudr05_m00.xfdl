              <Rows>
                <Row size="62" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="소재지"/>
                <Cell col="1" text="세부모집시기"/>
                <Cell col="2" text="주민등록번호&#13;&#10;(외국인등록번호)"/>
                <Cell col="3" text="등록일시"/>
                <Cell col="4" text="비고"/>
              </Band>
              <Band id="body">
                <Cell text="bind:cddcOrgCdNm" textAlign="center"/>
