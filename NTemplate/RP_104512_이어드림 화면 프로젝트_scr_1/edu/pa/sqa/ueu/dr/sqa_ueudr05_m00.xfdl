                <Cell col="2" textAlign="center" text="bind:trprRrno" maskeditformat="######-#######" displaytype="mask" maskedittype="string"/>
                <Cell col="3" text="bind:mdfcnDt" displaytype="date" calendardateformat="yyyy.MM.dd" calendareditformat="yyyy.MM.dd" textAlign="center"/>
                <Cell col="4" text="bind:seleDtaReqPrgSttusNm" textAlign="center"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Div id="divPaging" taborder="6" left="0" top="716" height="30" right="0" url="comm::comp_paginator.xfdl" initvalueid="ivDivAccessibilityOff" visible="false"/>
        <Static id="Static99_00_00_00_00" taborder="7" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="-2" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01" taborder="8" left="0" top="114" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="-2" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta99_00_00_00_00_00_00_02_00" taborder="9" left="0" top="divSearch:0" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
      </Layout>
