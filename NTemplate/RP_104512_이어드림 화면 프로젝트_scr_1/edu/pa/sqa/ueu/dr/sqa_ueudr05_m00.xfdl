        <Static id="sta00" taborder="2" text="※ 본 화면은 [대상학생 자료올리기] 및 [시도별 대상학생 자료요청]작업 후 발생한 오류에 대한 이력정보가 조회됩니다." left="3" top="246" width="775" height="33" cssclass="sta_WF_Red14" initvalueid="ivStcAccessibilityOn"/>
        <Button id="btnExcel" taborder="4" text="액셀내려받기" top="246" width="135" height="30" cssclass="btn_WF_Excel03" onclick="btnExcel_onclick" right="0"/>
