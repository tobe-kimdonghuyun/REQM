              <Static id="staWrk" taborder="4" text="세부모집시기" left="edtCoaRcritScNm:0" top="11" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" width="120"/>
              <Combo id="cboDetaRcrit" taborder="5" left="staWrk:0" width="196" height="30" innerdataset="dsDetaRcritPrd" codecolumn="detaRcritScValue" datacolumn="detaRcritScNm" text="과목" readonly="false" value="0" top="11" initvalueid="ivCmbNormal" onitemchanged="divSearch_cboDetaRcrit_onitemchanged" index="0" accessibilitylabel="세부모집시기"/>
              <Static id="staWrk01" taborder="6" text="시도" left="cboDetaRcrit:0" top="11" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" width="80"/>
              <Combo id="cboCddcCd" taborder="7" left="staWrk01:0" width="196" height="30" innerdataset="dsCddcScCd" codecolumn="unyCdValue" datacolumn="unyCdValueNm" text="과목" readonly="false" value="0" top="11" initvalueid="ivCmbNormal" onitemchanged="divSearch_cmbGb_onitemchanged" index="0" accessibilitylabel="시도교육청"/>
              <Static id="staWrk00" taborder="8" text="오류구분" left="0" top="51" width="108" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Combo id="cboErrGubun" taborder="9" left="staWrk00:0" width="196" height="30" innerdataset="dsErrGubun" codecolumn="cdcValue" datacolumn="cdcValueNm" text="" readonly="false" value="" top="51" initvalueid="ivCmbNormal" onitemchanged="divSearch_cmbGb_onitemchanged" index="-1" accessibilitylabel="오류구분"/>
              <Button id="btnSearch" taborder="10" text="조회" top="11" width="74" height="30" cssclass="btn_WF_Search03" right="20" onclick="btnSearch_onclick"/>
