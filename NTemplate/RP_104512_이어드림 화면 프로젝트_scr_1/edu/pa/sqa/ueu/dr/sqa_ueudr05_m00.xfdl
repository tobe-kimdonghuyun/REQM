          <Layouts>
            <Layout>
              <Static id="staCoaAyr" taborder="0" text="대입학년도" left="0" top="11" width="108" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtCoaAyr" taborder="1" left="staCoaAyr:0" top="11" width="100" height="30" text="2024" enable="false" accessibilitylabel="대입학년도" initvalueid="ivEdtNormal"/>
              <Static id="staCoaRcrit" taborder="2" text="모집구분" left="edtCoaAyr:0" top="11" width="96" cssclass="sta_WF_Searchtxt01" height="30" initvalueid="ivStcAccessibilityOn"/>
