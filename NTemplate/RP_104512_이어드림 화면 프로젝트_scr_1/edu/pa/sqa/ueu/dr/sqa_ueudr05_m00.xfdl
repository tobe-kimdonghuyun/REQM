        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsCddcScCd" onrowposchanged="dsUesUemUm04M00SVO_listUesUemUm04M00_onrowposchanged" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="FirstCode" type="STRING" size="30" value="ALL" datapath=""/>
          <ConstColumn id="ClfCdValue" type="STRING" size="30" value="CDDC_SC_CD"/>
          <ConstColumn id="FilterExpr" type="STRING" size="30" value=""/>
          <ConstColumn id="UnyCdGrpId" type="STRING" size="30" value=""/>
          <ConstColumn id="BfrClfCdValue" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd1Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd2Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd3Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd4Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd5Value" type="STRING" size="30" value=""/>
          <Column id="clfCdValue" type="STRING" size="30"/>
          <Column id="clfCdValueNm" type="STRING" size="120"/>
          <Column id="clfCdUseYn" type="STRING" size="150"/>
          <Column id="unyCdValue" type="STRING" size="10"/>
          <Column id="unyCdValueNm" type="STRING" size="30"/>
          <Column id="userDfnCd1Value" type="STRING" size="100"/>
          <Column id="userDfnCd2Value" type="STRING" size="100"/>
          <Column id="userDfnCd3Value" type="STRING" size="100"/>
          <Column id="userDfnCd4Value" type="STRING" size="100"/>
          <Column id="userDfnCd5Value" type="STRING" size="100"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsDetaRcritPrd" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="firstCode" type="STRING" size="30" value="SEL"/>
          <ConstColumn id="filterExpr" type="STRING" size="30" value=""/>
          <ConstColumn id="cmbType" type="STRING" size="30" value="detaRcritScCode"/>
          <Column id="_chk" type="STRING" size="1"/>
          <Column id="coaAyr" type="STRING" size="4"/>
          <Column id="coaRcritScCd" type="STRING" size="1"/>
          <Column id="uvstOrgCd" type="STRING" size="150"/>
          <Column id="detaRcritScValue" type="STRING" size="8"/>
          <Column id="detaRcritScNm" type="STRING" size="8"/>
          <Column id="detaRcritScBgngYmd" type="STRING" size="256"/>
          <Column id="detaRcritScEndYmd" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsErrGubun" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="firstCode" size="30" type="STRING" value="SEL"/>
          <ConstColumn id="filterExpr" size="30" type="STRING" value=""/>
          <ConstColumn id="cmbType" size="30" type="STRING" value="cdcValue"/>
          <Column id="cdcValue" size="30" type="STRING"/>
          <Column id="cdcValueNm" size="120" type="STRING"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="cdcValue"/>
            <Col id="cdcValueNm">-선택-</Col>
          </Row>
          <Row>
            <Col id="cdcValue">06</Col>
            <Col id="cdcValueNm">미존재학생</Col>
          </Row>
          <Row>
            <Col id="cdcValue">07</Col>
            <Col id="cdcValueNm">요청제외학생</Col>
          </Row>
          <Row>
            <Col id="cdcValue">01</Col>
            <Col id="cdcValueNm">주민등록중복</Col>
          </Row>
