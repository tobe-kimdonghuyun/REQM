          <Column id="_chk" size="1" type="STRING"/>
          <Column id="cddcOrgCd" size="256" type="STRING"/>
          <Column id="cddcOrgCdNm" size="256" type="STRING"/>
          <Column id="detaRcritScNm" size="256" type="STRING"/>
