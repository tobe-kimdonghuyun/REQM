<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sqa_ueudr03_m00" width="1200" height="720" titletext="전형자료요청" onload="sqa_ueudr03_m00_onload" onbeforeclose="sqa_ueudr03_m00_onbeforeclose">
    <Layouts>
      <Layout height="720" width="1200" screenid="ScreenDeskTop">
        <Div id="divSearch" taborder="0" left="0" top="0" height="70" cssclass="div_WF_Search" right="0" text="" initvalueid="ivDivAccessibilityOff" accessibilitylabel="조회영역">
          <Layouts>
            <Layout>
              <Static id="staCoaAyr" taborder="0" text="대입학년도" left="0" top="20" width="108" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtCoaAyr" taborder="1" left="staCoaAyr:0" width="101" height="30" top="20" initvalueid="ivEdtNormal" enable="false"/>
              <Static id="staCoaRcritScNm" taborder="2" text="모집구분" left="edtCoaAyr:0" top="20" width="96" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtCoaRcritScNm" taborder="3" left="staCoaRcritScNm:0" width="135" height="30" top="20" initvalueid="ivEdtNormal" enable="false"/>
              <Static id="staDetaRcrit" taborder="4" text="세부모집시기" left="edtCoaRcritScNm:0" top="20" width="120" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Combo id="cboDetaRcrit" taborder="5" left="staDetaRcrit:0" width="200" height="30" innerdataset="dsDetaRcritPrd" codecolumn="detaRcritScValue" datacolumn="detaRcritScNm" index="-1" top="20" initvalueid="ivCmbNormal" accessibilitylabel="조회조건"/>
              <Static id="staCddcOrgCd" taborder="6" text="시도교육청" left="cboDetaRcrit:0" top="20" width="108" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" onclick="divSearch_staCddcOrgCd_onclick"/>
              <Combo id="cboCddcScCd" taborder="7" left="staCddcOrgCd:0" width="200" height="30" innerdataset="dsCddcScCd" codecolumn="unyCdValue" datacolumn="unyCdValueNm" index="-1" top="20" initvalueid="ivCmbNormal" accessibilitylabel="조회조건"/>
              <Button id="btnSearch" taborder="8" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="20" onclick="divSearch_btnSearch_onclick"/>
            </Layout>
          </Layouts>
        </Div>
        <ImageViewer id="img00_00_01_00" taborder="1" text="전형자료요청" left="0" top="90" width="130" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="staPrd" taborder="2" left="img00_00_01_00:10" top="90" height="30" cssclass="sta_WF_Black14" text="" wordWrap="char" initvalueid="ivStcAccessibilityOn" width="410" textAlign="left"/>
        <Static id="staChcCnt" text="" top="90" height="30" taborder="3" initvalueid="ivStcAccessibilityOn" width="150" textAlign="left" left="staPrd:-15"/>
        <Button id="btnRtrcn" taborder="4" text="요청취소" top="90" height="30" width="80" cssclass="btn_WF_Crud" right="251" initvalueid="ivBtnAccessibilityButton" onclick="btnRtrcn_onclick" enable="false"/>
        <Button id="btnDmnd" taborder="5" text="전형자료요청" top="90" height="30" width="106" cssclass="btn_WF_Crud" right="139" initvalueid="ivBtnAccessibilityButton" onclick="btnDmnd_onclick" enable="false"/>
        <Button id="btnImps" taborder="6" text="요청불능자료조회" top="90" height="30" cssclass="btn_WF_Crud" width="133" right="0" initvalueid="ivBtnAccessibilityLink" onclick="btnImps_onclick" enable="true"/>
        <Grid id="grdCddc" taborder="7" left="0" binddataset="dsDmndCddc" autofittype="col" top="130" selecttype="cell" initvalueid="ivGrdAccessibilityOn" bottom="180" oncellclick="grdCddc_oncellclick" width="400">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="176"/>
                <Column size="76"/>
                <Column size="76"/>
                <Column size="76"/>
                <Column size="76"/>
              </Columns>
              <Rows>
                <Row size="30" band="head"/>
                <Row size="30" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell rowspan="2" text="시도교육청"/>
                <Cell col="1" colspan="4" text="요청상태"/>
                <Cell row="1" col="1" text="전체대상"/>
                <Cell row="1" col="2" text="미요청" cssclass="LineNo"/>
                <Cell row="1" col="3" text="요청완료"/>
                <Cell row="1" col="4" text="요청불능"/>
              </Band>
              <Band id="body">
                <Cell text="bind:cddcOrgCdNm" textAlign="center"/>
                <Cell col="1" text="bind:dmndTrgtCnt" textAlign="right"/>
                <Cell col="2" displaytype="normal" edittype="text" text="bind:dmndUnCnt" textAlign="right"/>
                <Cell col="3" text="bind:dmndCmptnCnt" textAlign="right"/>
                <Cell col="4" text="bind:dmndImpsCnt" textAlign="right"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Grid id="grdApst" taborder="8" left="grdCddc:10" top="130" binddataset="dsDmndApst" autofittype="col" right="0" initvalueid="ivGrdAccessibilityOn" selecttype="cell" onheadclick="grdApst_onheadclick" oncellclick="grdApst_oncellclick" bottom="180">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="40"/>
                <Column size="150"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="190"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="30" band="head"/>
                <Row size="30" band="head"/>
                <Row size="40"/>
                <Row size="40" band="summ"/>
              </Rows>
              <Band id="head">
                <Cell rowspan="2" text="_chk" displaytype="checkboxcontrol" edittype="checkbox"/>
                <Cell col="1" rowspan="2" text="시도교육청"/>
                <Cell col="2" rowspan="2" text="합격년도"/>
                <Cell col="3" rowspan="2" text="합격회차"/>
                <Cell col="4" rowspan="2" text="요청대상자"/>
                <Cell col="5" colspan="2" text="요청정보"/>
                <Cell col="7" text="요청취소"/>
                <Cell row="1" col="5" text="응답결과"/>
                <Cell row="1" col="6" text="응답일"/>
                <Cell row="1" col="7" displaytype="checkboxcontrol" edittype="checkbox"/>
              </Band>
              <Band id="body">
                <Cell text="bind:_chk" edittype="expr:dmndTrgtCnt + dmndExclCnt &gt; 0 ? &quot;checkbox&quot; : &quot;none&quot;" displaytype="expr:dmndTrgtCnt + dmndExclCnt &gt; 0 ? &quot;checkboxcontrol&quot; : &quot;none&quot;" textAlign="center"/>
                <Cell col="1" text="bind:cddcOrgCdNm" textAlign="center"/>
                <Cell col="2" text="bind:passYr" textAlign="center"/>
                <Cell col="3" text="bind:passTme" textAlign="center"/>
                <Cell col="4" text="expr:comp.parent.fnTrgt(displayRrno, dmndTrgtCnt, dmndPrgCnt, dmndExclCnt)" textAlign="center"/>
                <Cell col="5" text="expr:dataDmndRsltScCd == &quot;Y&quot; ? &quot;성공&quot; : apstDmndStsCd == &quot;51&quot; &amp;&amp; dataDmndRsltScCd == &quot;N&quot; ? &quot;실패&quot; :  &quot;&quot;" textAlign="center"/>
                <Cell col="6" text="bind:dmndTime" textAlign="center" maskedittype="string" maskeditformat="####.##.##" maskeditmaskchar=" " displaytype="date" calendardateformat="yyyy.MM.dd" calendareditformat="yyyy.MM.dd" calendardisplaynulltype="nulltext"/>
                <Cell col="7" text="bind:rtrcnYn" edittype="expr:rtrcnCeckYn == &quot;Y&quot; ? &quot;checkbox&quot; : &quot;none&quot;" displaytype="expr:rtrcnCeckYn == &quot;Y&quot; ? &quot;checkboxcontrol&quot; : &quot;none&quot;" textAlign="center"/>
              </Band>
              <Band id="summary">
                <Cell colspan="8" background="#fdfbe5" border="1px solid #c8c1c2" color="#333333" textAlign="center"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Div id="divInfo" taborder="9" left="0" right="0" initvalueid="ivDivAccessibilityOff" cssclass="div_WF_InfoBOX" top="grdApst:16" text="" height="164">
          <Layouts>
            <Layout>
              <Static id="sta00_00_01_01_00" taborder="0" left="30" top="28" height="23" cssclass="sta_WF_InfoTit" text="이용 전 확인해주세요." wordWrap="char" initvalueid="ivStcAccessibilityOn" width="200"/>
              <Static id="sta01" taborder="1" left="30" top="55" height="24" cssclass="sta_WF_Red14" text="※ ( )안의 수치는 요청제외 건수입니다." wordWrap="char" initvalueid="ivStcAccessibilityOn" width="768"/>
              <Static id="sta02" taborder="2" left="29" top="79" height="24" cssclass="sta_WF_Red14" text="※ [전송중]인 경우, 재조회를 하여 진행상태를 확인하시기 바랍니다." wordWrap="char" initvalueid="ivStcAccessibilityOn" width="1058"/>
              <Static id="sta03" taborder="3" left="30" top="129" cssclass="sta_WF_Blue14" text="" wordWrap="char" initvalueid="ivStcAccessibilityOn" width="879" height="24"/>
              <Static id="sta04" taborder="4" left="29" top="105" height="24" cssclass="sta_WF_Red14" text="※ 요청불능 자료는 [요청불능자료조회] 를 클릭하여 반드시 확인바라며, '미동의학생'의 경우 나이스 대국민 검정고시 서비스에서 온라인 제공 동의 후 재요청바랍니다." wordWrap="char" initvalueid="ivStcAccessibilityOn" width="1058"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="Static99_00_00_00_00_01_00" taborder="10" left="0" top="70" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
        <Static id="Static99_00_00_00_00_01_00_00_00" taborder="11" left="0" top="120" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" onclick="Static99_00_00_00_00_01_00_00_00_onclick"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    전형자료요청
*  @FileName 	sqa_ueudr03_m00.xfdl
*  @Creator 	bsw
*  @CreateDate 	2022.09.05
*  @Desction    대입전형-대학-전형자료요청
************** 소스 수정 이력 ***********************************************
*  date				Modifier				Description
*******************************************************************************
*  2022.09.05		bsw					최초 생성
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvSendSize = 400;	   //임시로 400건으로 함.
this.dmndRtrcnTime = 20;   //요청취소 시간 간격 : 20분
this.fvCeckCnt = 0;		   //선택건수
this.fvRtrcnYn = null;	   //취소여부
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose, ontimer)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리
 */
this.sqa_ueudr03_m00_onload = function(obj,e) {

	// Div 초기화
	this.smfInitDiv(obj);

//  	// Grid Checkbox 활성화/활성화 제어
//  	this.smfUpdateRednerGridCheckbox(this.grdList, 0, this.fnRenderGridCheckbox);
//
//  	// 조회 입력창에서 'Ctrl' + 'Enter' 키 입력시 조회수행 이벤트 설정
//  	this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
//
//  	// 데이터 입력 창에서 'Ctrl' + 'Enter' 키 입력시 저장수행 이벤트 설정
//  	this.smfBindEnterKeyToSearch(this.dsList, this.btnSave);

	//초기화
	this.fnInit(obj);

	// 서버단에 설정한 유효성 검증 목록을 획득하여 설정
	this.fnSearchValidation();
	
	//공통코드 조회
	this.fnSerachCmmCd();
	
	// 검정고시대입 공통조회
	this.fnOnloadSearch(obj, ["dsDetaRcritPrd"]);
		
};

/**
 * @description 폼 닫기전 이벤트
 */
this.sqa_ueudr03_m00_onbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
// 	// 변경내역이 발생한 경우 종료전 confirm수행
// 	return this.smfCloseFormConfirm([this.dsDmndCddc]);
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
};

/**
* @description 요청불능자료조회 콜백
*/
this.fnImpsCallback = function() {

};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리

************************************************************************************************/
/**
 * @description 유효성 검증 목록 조회
*/
this.fnSearchValidation = function() {
	this.smfValidateService("validateMain", {
			url: "/sqa_ueu_dr04_001.do",
		})
		.mappingRulesetToForm(this.divSearch, "search")					//조회Valid
		.run()
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;
		});
};

/**
 * @description 모집기간 조회
*/
this.fnSearchPrd = function() {
	this.smfSearchService("listUvstRcritPrd")
		.run() // 실행
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;
			
			if(this.dsUvstRcritPrd.getColumn(0,"prdYn") == "Y") {
				this.btnDmnd.set_enable(true);
			} else {
				this.staPrd.set_text(this.divSearch.form.edtCoaRcritScNm.text + " 모집기간 : 모집기간이 아닙니다.");
				this.btnDmnd.set_enable(false);
			}
			
		});
};

/**
 * @description 공통코드 조회
*/
 this.fnSerachCmmCd = function() {		
	this.smfCodeList("code", [this.dsCddcScCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.divSearch.form.cboCddcScCd.set_index(0);
		})
		.run()
	;
};

/**
 * @description 시도 조회
 * @param 선택한 시도 인덱스
*/
this.fnSearchCddc = function(idx) {
	
	this.dsDmndApst.clearData();	//지원자ds 초기화
	this.grdApst.setCellProperty("summary", 0, "text", "" );
	this.fvCeckCnt = this.dsDmndApst.getCaseCount("_chk == '1'");	
	this.staChcCnt.set_text("선택건수 : " + this.fvCeckCnt);
	
	this.smfSearchService("listDmndCddc")
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;			
			if(this.smfIsNull(this.dsSearch.getColumn(0, "cddcOrgCd"))) {	//전체인경우
				this.dsDmndCddc.set_filterstr();
			} else {
				this.dsDmndCddc.set_filterstr("cddcOrgCdNm != '전체'");
			}
			if(!this.smfIsNull(idx)) {
				this.grdCddc.setCellPos(idx);
				this.fnSearchApst();
			}
		});
}

/**
 * @description 지원자 조회
*/
this.fnSearchApst = function() {
	this.smfSearchService("listDmndApst")
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;		
			
			var tot = 0
			
			for(var i = 0 ; i < this.dsDmndApst.rowcount ; i++ ) {
				tot = tot + nexacro.toNumber(this.dsDmndApst.getColumn(i, "dmndTrgtCnt")) + nexacro.toNumber(this.dsDmndApst.getColumn(i, "dmndExclCnt"));
			}
			
			this.grdApst.setCellProperty("summary", 0, "text", "자료요청 대상 건수 : " + tot + "건" );	
			
			this.fvCeckCnt = this.dsDmndApst.getCaseCount("_chk == '1'");	
			this.staChcCnt.set_text("선택건수 : " + this.fvCeckCnt);
	
			//요청취소버튼활성화
			if(this.dsDmndApst.getCaseCount("rtrcnCeckYn == 'Y'") > 0) {
				this.btnRtrcn.set_enable(true);	
			}
		});
}

/**
 * @description 전형자료요청
*/
this.fnExecuteParts = function(callback) {			

	var svcNm = "";
	
	if(this.fvRtrcnYn == "Y"){
		svcNm = "executeDmndRtrcn";			//요청취소		
	} else {
		svcNm = "executeDmnd";				//자료요청
	}	
	
	this.smfExecuteService(svcNm)
 	    .showConfirm(false)
		.beforeService(function(next){
 			next();
 		})
 		.run() // 실행
 		.callback(function(callbackParams) {
			if(this.smfIsFunc(callback)) callback.call(this, callbackParams); 	
 			if(callbackParams.errors) {
				return; 				
			}
 		});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 초기화
*/
 this.fnInit = function(obj) { 
	//세션정보 세팅
	this.dsSearch.setColumn(0, "coaAyr", this.sqav_coaAyr);
	this.dsSearch.setColumn(0, "coaRcritScCd", this.sqav_coaRcritScCd);
	this.dsSearch.setColumn(0, "coaRcritScNm", this.sqav_coaRcritScNm);
	this.dsSearch.setColumn(0, "uvstOrgCd", this.sqav_uvstOrgCd);
	this.dsSearch.setColumn(0, "dmndRtrcnTime", this.dmndRtrcnTime);
};

/**
* @description 검정고시 대입전형 공통조회 콜백
*/
this.fnOnloadSearchCallback = function() {
	//세부모집시기의 조건 - 사용중인 것만 나오도록
	var today = this.smfToday();
	this.dsDetaRcritPrd.set_filterstr(today + " >= detaRcritScBgngYmd  && " + today + " <= detaRcritScEndYmd");
	this.dsSearch.setColumn(0, 'detaRcritScValue', this.dsDetaRcritPrd.getColumn(0, 'detaRcritScValue'));
	this.dsDetaRcritPrd.setColumn(this.dsDetaRcritPrd.insertRow(0), "detaRcritScNm", "선택");
	this.divSearch.form.cboDetaRcrit.set_index(0);
	this.divInfo.form.sta03.set_text("※ 자료요청 후, " + this.dmndRtrcnTime + "분 경과 뒤에도 [진행중]인 경우, 요청취소 체크박스가 활성화되며 요청취소 후 다시 자료요청할 수 있습니다.");	
	this.fnSearchPrd();	
};

/**
* @description 대상 상태
* @param displayRrno  주민등록번호"-"포함
* @param dmndTrgtCnt  요청대상자건수
* @param dmndPrgCnt   요청진행자건수
* @param dmndExclCnt  요청제외자건수
*/
this.fnTrgt = function(displayRrno, dmndTrgtCnt, dmndPrgCnt, dmndExclCnt)
{
	var rtn = "";

	if(dmndTrgtCnt > 0 || dmndExclCnt > 0) {
		rtn = "" + displayRrno;
	} else if(dmndPrgCnt > 0) {
		rtn = "[전송중...] " + displayRrno;
	} else {
		rtn = "[대상아님] " + displayRrno;
	}
	return rtn;
};

/**
* @description 전형자료요청 validation
*/
this.fnExecuteDmndValid = function() {
		
	if(this.dsDmndApst.getRowCount() == 0 ) {
		this.smfAlert("자료를 요청할 지원자가 없습니다.");
		return false; 
	};
	
	if(this.fvCeckCnt == 0 ) {
		this.smfAlert("자료를 요청할 지원자를 먼저 선택하여 주십시오.");
		return false;
	}
	
	this.dsDmnd.clearData();	//요청대상ds초기화
	for(var i = 0 ; i < this.dsDmndApst.rowcount; i++) {
		if(this.dsDmndApst.getColumn(i, "_chk") == "1") {
			this.dsDmnd.copyRow(this.dsDmnd.addRow(), this.dsDmndApst, i)	//요청대상복사
		}
	}
	
	return true;
}

/**
* @description 전형자료취소요청 validation
*/
this.fnExecuteRtrcnValid = function() {

	if(this.dsDmndApst.getCaseCount("rtrcnYn =='1'") == 0 ) {
		this.smfAlert("요청취소 대상을 선택하세요");
		return;
	}	
	
	this.dsRtrcn.clearData();	//재요청취소ds초기화
	for(var i = 0 ; i < this.dsDmndApst.rowcount; i++) {
		if(this.dsDmndApst.getColumn(i, "rtrcnYn") == "1") {
			this.dsRtrcn.copyRow(this.dsRtrcn.addRow(), this.dsDmndApst, i); 	//재요청취소복사
		}
	}
	
	return true;
}

/**
* @description 전형자료요청/요청취소 호출
* @param yn	취소여부
*/
this.fnExecute = function(yn) {	
	var dsFrom = null;			//선택한 대상ds
	var dsParts = null;			//저장ds
	var msg = "";				//메시지
	this.fvRtrcnYn = yn;		//취소여부
	
	if(this.fvRtrcnYn == "Y") {	//자료취소
		dsFrom = this.dsRtrcn;
		dsParts = this.dsRtrcnParts;
		msg = "요청 취소가 완료되었습니다.";
	} else {					//자료재요청
		dsFrom = this.dsDmnd;	
		dsParts = this.dsDmndParts;
		msg = "자료가 요청되었습니다.";
	}
	
	//자료요청/요청취소 호출
	this.fnExecuteDmnd(dsFrom, dsParts, this.fvSendSize,
		function() {		
			this.smfAlert(msg, "", function(){		
				var chcCddcOrgCd = this.dsSearch.getColumn(0, "chcCddcOrgCd");
				var idx = this.dsDmndCddc.findRow("cddcOrgCd", chcCddcOrgCd);
				this.fnSearchCddc(idx); 			//시도현황조회
			}); 	
		}	
	).run();
};

/**
 * @description 전형자료재요청/요청취소 (by건)
 * @param : dsFrom		- 원본데이터
 * @param : dsTo		- 송신데이터 ( nMax 수량을 가짐 )
 * @param : nMax		- 최대 데이터 수량
 * @return : Object { run }
 */
this.fnExecuteDmnd = function(dsFrom, dsTo, nMax, completeCallback){
	var _that = this;
	var nStepIdx = 0;
	var nTotalCnt = dsFrom.getRowCount();
	var step;
	var nIdxStart;
	var nIdxEnd;
	
	//스텝 만들기 [{nIdxStart, nIdxEnd}...]
	var aStep = Array(Math.ceil(nTotalCnt / nMax)).fill().map(function(a, i) {
		var end = (i + 1) * nMax;		
		return {
			nIdxStart : i * nMax,
			nIdxEnd : end < nTotalCnt ? end : nTotalCnt
		}
	});
	
	//전형자료재요청/요청취소 이전 스텝(건수)별로 데이터셋 복사
	function copyDataByStep() {
		step = aStep[nStepIdx++];
		if(_that.smfIsNull(step)){
			if(_that.smfIsFunc(completeCallback)) completeCallback.call(_that);
			return false;
		}
		
		//초기화(업로드데이터)
		dsTo.clearData();
		for(var i = step.nIdxStart; i < step.nIdxEnd; i++){						
			dsTo.copyRow(dsTo.addRow(), dsFrom, i);	
		}
		
		return true;
	}
	
	//전형자료재요청/요청취소 callback
	function next(callbackParams) {
		if(callbackParams.errors) return;
				
		this.setWaitCursor(true);
	
		if(copyDataByStep()){
			_that.fnExecuteParts.call(_that, next);
		}
		
		this.setWaitCursor(false);
	}
	
	//전형자료재요청/요청취소 호출
	function run(){
		if(copyDataByStep()) _that.fnExecuteParts.call(_that, next);
	}
	
	return {
		run
	}
};

/**
* @description 요청대상건수체크
*/
this.fnCeckCnt = function(idx) {
	this.fvCeckCnt = this.dsDmndApst.getCaseCount("_chk == '1'");	
	this.staChcCnt.set_text("선택건수 : " + this.fvCeckCnt);	
	return true;
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 /**
 * @description 그리드 헤더 클릭
*/
this.grdApst_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo) {	
 	var columnName = obj.getCellProperty("body",e.cell,"text");
 
 	if ("bind:_chk" == columnName){
	
 		var chkYn = obj.getCellText(-1, e.cell)=="1"?"0":"1";
 		obj.setCellProperty("head", 0, "expr", chkYn);
 		for(var i = 0 ; i < this.dsDmndApst.rowcount ; i++) {
		    var param = this.dsDmndApst.getColumn(i, "dmndTrgtCnt");
			var param2 = this.dsDmndApst.getColumn(i, "dmndExclCnt");
 			var displaytype = param + param2 > 0 ? "checkbox" : "none";
 			if(displaytype != "checkbox") continue;			
			if(chkYn == "1") {	//선택
				this.fvCeckCnt += 1;
				this.dsDmndApst.setColumn(i, "_chk", chkYn);						
			} else {	//전체해제
				if(this.dsDmndApst.getColumn(i, "_chk") == "1") {
					this.fvCeckCnt -= 1;
					this.dsDmndApst.setColumn(i, "_chk", "0");					
					if(this.fvCeckCnt == 0 ) {
						break;
					}					
				}				
			}		
		}
		this.staChcCnt.set_text("선택건수 : " + this.fvCeckCnt);	
	}
	
	//요청취소 일괄선택
	if (e.cell == "9") {
		var chkYn = obj.getCellText(-1, e.cell)=="1"?"0":"1";
		obj.setCellProperty("head", 9, "expr", chkYn);		

		for(var i = 0 ; i < this.dsDmndApst.rowcount ; i++) {
			var rtrcnCeckYn = this.dsDmndApst.getColumn(i, "rtrcnCeckYn");
			if (rtrcnCeckYn == "Y") this.dsDmndApst.setColumn(i, "rtrcnYn", chkYn);
		}
	}
};

 /**
* @description 조회
*/
this.divSearch_btnSearch_onclick = function(obj,e) {	
	this.fnSearchCddc();
};

 /**
* @description 요청취소
*/
this.btnRtrcn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(!this.fnExecuteRtrcnValid()) return;	
	this.fnExecute("Y");
};

 /**
* @description 자료요청
*/
this.btnDmnd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(!this.fnExecuteDmndValid()) return;	
	this.fnExecute("N");
};

 /**
* @description 요청불능조회
*/
this.btnImps_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	if(this.smfIsNull(this.dsSearch.getColumn(0, "detaRcritScValue"))) {
		this.smfAlert("세부모집시기를 선택하여 주시기 바랍니다.");
		return;
	}
	
	this.dsSearch.setColumn(0,"detaRcritScNm",this.divSearch.form.cboDetaRcrit.text);		//세부모지시기명
	this.dsSearch.setColumn(0,"cddcOrgCdNm",this.divSearch.form.cboCddcScCd.text);			//시도교육청명
		
	// 팝업 파라메터
	var popupParams = {
		callback: this.fnImpsCallback, // 콜백함수 지정
		sender: obj, // sender 지정
		params: {
			procType: "search" // 처리타입 지정
		  , dsParam :  this.dsSearch
		},
	};

	// 모달팝업 실행
	this.smfDialog("sqa_ueudr03_p00", "pa_sqa_ueu_dr::sqa_ueudr03_p00.xfdl", popupParams);
};

/**
* @description 시도 선택
*/
this.grdCddc_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	this.dsSearch.setColumn(0, "chcCddcOrgCd", this.dsDmndCddc.getColumn(e.row, "cddcOrgCd"));
	this.fnSearchApst();
};

/**
* @description 지원자 선택
*/
this.grdApst_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	//건수체크
	if (e.cell == 0 && this.fnCeckCnt(e.row)) return;
};]]></Script>
