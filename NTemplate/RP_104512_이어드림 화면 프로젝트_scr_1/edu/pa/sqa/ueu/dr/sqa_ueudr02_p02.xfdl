        <Div id="divSearch" left="20" top="60" height="110" initvalueid="ivDivAccessibilityOn" cssclass="div_WF_Search" text="" width="759" taborder="1" accessibilitylabel="조회영역">
          <Layouts>
            <Layout>
              <Static id="Static00_01" taborder="0" text="대입학년도" left="0" top="20" width="108" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtSearchKeyword" taborder="1" left="Static00_01:0" top="20" width="100" height="30" initvalueid="ivEdtNormal" accessibilitylabel="조회조건" readonly="true"/>
              <Static id="Static00" taborder="2" text="모집구분" left="edtSearchKeyword:0" top="20" width="96" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtSearchKeyword00" taborder="3" left="Static00:0" top="20" width="135" height="30" initvalueid="ivEdtNormal" accessibilitylabel="조회조건" readonly="true"/>
              <Static id="Static00_00" taborder="4" text="세부모집시기" left="edtSearchKeyword00:1" top="20" width="128" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
