              <Static id="Static00_00_00" taborder="6" text="시도교육청" left="0" top="60" width="108" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Combo id="cboCddcScCd" taborder="7" left="Static00_00_00:0" width="140" height="30" innerdataset="dsCddcScCd" codecolumn="unyCdValue" datacolumn="unyCdValueNm" index="-1" top="60" initvalueid="ivCmbNormal" accessibilitylabel="조회조건"/>
              <Static id="Static00_00_00_00" taborder="8" text="요청상태" left="cboCddcScCd:0" top="60" width="96" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Combo id="cboUvstDmndCd" taborder="9" left="Static00_00_00_00:0" width="140" height="30" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" index="0" top="60" initvalueid="ivCmbNormal" accessibilitylabel="조회조건" text="" value="">
                <Dataset id="innerdataset">
                  <ColumnInfo>
                    <Column id="codecolumn" size="256"/>
                    <Column id="datacolumn" size="256"/>
