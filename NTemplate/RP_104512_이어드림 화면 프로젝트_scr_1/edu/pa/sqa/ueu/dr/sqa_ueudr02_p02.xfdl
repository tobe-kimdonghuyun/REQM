        </Div>
        <Grid id="grdList" taborder="2" left="20" top="189" height="431" binddataset="dsList" autofittype="col" selecttype="cell" initvalueid="ivGrdAccessibilityOn" width="762" nodatatext="조회된 데이터가 없습니다." cellsizingtype="col">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="60"/>
                <Column size="180"/>
                <Column size="140"/>
                <Column size="150"/>
                <Column size="230"/>
              </Columns>
              <Rows>
                <Row size="40" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
