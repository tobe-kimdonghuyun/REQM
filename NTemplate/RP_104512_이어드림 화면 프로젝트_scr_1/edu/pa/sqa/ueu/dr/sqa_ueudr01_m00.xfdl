};

/**
 * @description 엑셀파일 검증 후 오류가 없을 시 지원자데이터 DB저장
 */
this.fnExecuteUpldParts = function (callback) {
 	this.smfExecuteService("executeUpld")
 		.showConfirm(false)
		.validateForm(this.divSearch)
 		.beforeService(function(next){
 			next();
 		})
		.run()
 		.callback(function(callbackParams){			
 			if(this.smfIsFunc(callback)) callback.call(this, callbackParams); 			
			if(callbackParams.errors) {
				return;
			}
 		});
};
