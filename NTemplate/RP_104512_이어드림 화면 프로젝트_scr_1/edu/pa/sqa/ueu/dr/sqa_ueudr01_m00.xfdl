/**
* @description 버튼활성화
* @param v	true/false
*/
this.fnBtnEnabled = function(v) {
	this.setWaitCursor(!v);
	this.btnFormDown.set_enable(v);
	this.btnSearch.set_enable(v);
	this.btnPrcs.set_enable(v);
	//this.divFileUpload2.set_enable(v);
}

/**
 * @description 시도코드확인
 */
this.fnCeckCddc = function(grid, rowIndex, columnIndex, datasetOfGrid){
	var rtn = true;
	
	var bindCol = datasetOfGrid.getColID(columnIndex);
	var labelText = this.fvColTitle[bindCol];
	var str = this.smfStr(datasetOfGrid.getColumn(rowIndex, columnIndex));
	var nRow = this.dsCddcScCd.findRow( "unyCdValue", str.substr(0,3));
	
	if ( nRow < 0 ) {
		rtn = labelText + '에 유효하지 않는 시도코드가 존재합니다.';
	}
	return rtn;
};

/**
 * @description 특수문자확인
 */
this.fnValidateSpyChr = function(grid, rowIndex, columnIndex, datasetOfGrid){
	var rtn = true;
	
	var bindCol = datasetOfGrid.getColID(columnIndex);
	var labelText = this.fvColTitle[bindCol];
	var str = this.smfStr(datasetOfGrid.getColumn(rowIndex, columnIndex));
	var invalidStrings = new Array("<",">","{","}","#","&","SCRIPT","'",";","--"," OR ");  // '문자 제한처리 2016.01.11
	
	// 특수문자 체크
	for(var i=0; i < invalidStrings.length;i++) {
		 var objRegExp  = new RegExp(invalidStrings[i],"gi");
		 var tempString = invalidStrings[i];
		  if(objRegExp.test(str)) {
 			rtn = labelText + '에 문자[' + invalidStrings[i] + ']이 존재합니다.';
        }
	}
	
	return rtn;
};

/**
 * @description 자료 업로드 (by건)
 * @param : dsFrom		- 원본데이터
 * @param : dsTo		- 송신데이터 ( nMax 수량을 가짐 )
 * @param : nMax		- 최대 데이터 수량
 * @return : Object { run }
 */
this.fnExecuteUpld = function(dsFrom, dsTo, nMax, completeCallback){
	var _that = this;
	var nStepIdx = 0;
	var nTotalCnt = dsFrom.getRowCount();
	
	//스텝 만들기 [{nIdxStart, nIdxEnd}...]
	var aStep = Array(Math.ceil(nTotalCnt / nMax)).fill().map(function(a, i) {
		var end = (i + 1) * nMax;
		return {
			nIdxStart : i * nMax,
			nIdxEnd : end < nTotalCnt ? end : nTotalCnt
		}
	});
	
	//지원자업로드 이전 스텝(건수)별로 데이터셋 복사
	function copyDataByStep() {
		var step = aStep[nStepIdx++];
		if(_that.smfIsNull(step)){
			if(_that.smfIsFunc(completeCallback)) completeCallback.call(_that);
			//dsRspnsTo.applyChange();
			return false;
		}
		
		//초기화
		dsTo.clearData();
		for(var i = step.nIdxStart; i < step.nIdxEnd; i++){			
			dsTo.copyRow(dsTo.addRow(), dsFrom, i);			
		}		
		return true;
	}
	
	//지원자업로드 callback
	function next(callbackParams) {
		if(callbackParams.errors) return;
				
		this.setWaitCursor(true);
		if(copyDataByStep()){
			_that.fnExecuteUpldParts.call(_that, next);
		}
		this.setWaitCursor(false);
	}
	
	//지원자업로드 호출
	function run(){
		if(copyDataByStep()) _that.fnExecuteUpldParts.call(_that, next);
	}
	
	return {
		run
	}
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 엑셀 양식 다운로드
 */
this.btnFormDown_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo) {

	this.smfConfirm("엑셀자료의 모든 셀의 서식은 반드시 텍스트로 지정하여 주시기 바랍니다."
					 + "\n양식을 다운로드 하시겠습니까?",  function(confirmParams){
		if(confirmParams.confirmResult){
			var objOption = {	objGrid : this.grdExcelForm
					,	sheetname : "Sheet1"
					,   filename : "지원학생등록(양식)"
					};

			this.smfExcelExport(objOption);
		}	
	})
};

/**
 * @description 업로드결과 조회 및 삭제 팝업 호출
 */
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{		
	// 팝업 파라메터
	var popupParams = {
		callback: this.fnUpldRsltCallback, // 콜백함수 지정
		sender: obj, // sender 지정
		params: {
			procType: "search" // 처리타입 지정
		  , dsParam :  this.dsSearch
		},
	};

	// 모달팝업 실행
	this.smfDialog("sqa_ueudr01_p00", "pa_sqa_ueu_dr::sqa_ueudr01_p00.xfdl", popupParams);
};

/**
 * @description 그리드 cssclass
 */
this.fnGrdCssclass = function(val){
	var cssclass = [];
	
	if(!this.smfIsNull(val)){
		cssclass.push(val.indexOf('오류') > -1 ? 'cell_WF_Red' : (val.indexOf('정상') > -1 ? 'cell_WF_Blue' : ''));
	}
	
	return cssclass.join(' ');
}

/************************************************************************************************
 * 파일첨부 로직 
 ************************************************************************************************/

this.btnPrcs_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.smfIsNull(this.divSearch.form.cboDetaRcrit.value)) {
		this.smfAlert("세부모집시기를 선택하여 주십시오.");
		return;
	}
	
	this.divFileInfo.set_visible(true);
	this.divInfo.set_visible(false);						//파일업로드(오류)안내사항
	
	this.dsMain.clearData();
	this.dsMain.set_filterstr('');
		
	//clear하고 컬럼을 새로 만들어주지 않으면 비정상적인 포멧이후 정상포멧 업로드 시 오류가 발생함.
	this.dsExcelUpload.clear();
	
	this.dsExcelUpload.addColumn('cddcOrgCd');
	this.dsExcelUpload.addColumn('passYr');
	this.dsExcelUpload.addColumn('passTme');
	this.dsExcelUpload.addColumn('trprRrno');
	this.dsExcelUpload.addColumn('uvstExmtNo');
	this.dsExcelUpload.addColumn('seleScNm');
	this.dsExcelUpload.addColumn('rcritUnitNm');
	this.dsExcelUpload.addColumn('uvstSprtDddepNm');
	
	var objOption = {	datasetname : "dsExcelUpload"
					,   sheetname   : "Sheet1"
					,   startcell   : "A2"
					,   callback    : "fnExcelUploadCallback"
					,   importId    : "excelUpload"
					,   objForm     : this
					};
	
	this.smfExcelImport(objOption);
};

/**
 * @description 엑셀업로드 callback함수
 */
this.fnExcelUploadCallback = function(importId, bResult, sFilename)
{
	if(!bResult) return false;

	this.smfClearSort(this.grdMain);
	
	// 필터초기화
	this.dsExcelUpload.set_filterstr('');
		
	this.fnBtnEnabled(false);
	
	var regSn = 1;
	// 첫번째행 check - 첫번째행이 양식 타이틀이면 삭제한다.
	var vsCddcOrgCd 		= this.smfTrim(this.dsExcelUpload.getColumn(0, "cddcOrgCd"));
	
	// 샘플양식 안지운경우 삭제하고 진행	
	if(vsCddcOrgCd == "A000000001(샘플삭제요망)"){
		this.dsExcelUpload.deleteRow(0);
	}

	//데이터가 모두 비어있는경우 제거
	for(var i = this.dsExcelUpload.rowcount - 1; i >= 0; i--){
		var row = [
			, this.smfTrim(this.dsExcelUpload.getColumn(i, "cddcOrgCd"))
			, this.smfTrim(this.dsExcelUpload.getColumn(i, "passYr"))
			, this.smfTrim(this.dsExcelUpload.getColumn(i, "passTme"))
			, this.smfTrim(this.dsExcelUpload.getColumn(i, "trprRrno"))
			, this.smfTrim(this.dsExcelUpload.getColumn(i, "uvstExmtNo")) 
			, this.smfTrim(this.dsExcelUpload.getColumn(i, "seleScNm")) 
			, this.smfTrim(this.dsExcelUpload.getColumn(i, "rcritUnitNm")) 
			, this.smfTrim(this.dsExcelUpload.getColumn(i, "uvstSprtDddepNm")) 
		];
		if(row.every((v) => this.smfIsNull(v))){
			this.dsExcelUpload.deleteRow(i);
		}
	}

	//번호, 오류내역 컬럼 추가	
	this.dsExcelUpload.addColumn("regSn", "INT", 10);
	this.dsExcelUpload.addColumn("stsNm");
	this.dsExcelUpload.addColumn("errCn");
			
	for(var i = 0, size = this.dsExcelUpload.rowcount; i < size; i++){
		this.dsExcelUpload.setColumn(i, "regSn", regSn + i);
	}
	
	//validation체크 - 바인딩된 데이터셋을 가지고와서 엑셀업로드valid 데이터셋의 validation 체크
	var isValid = this.fnExcelCeck(this.grdExcelUpld, this.dsExcelUpldValid,
		//init
		() => {
			this.grdMain.set_enableredraw(false);
		},
		//error
		(nRow, nCol, ds, rtnVal) => {
			//trace("로우 :: " + nRow + " 내용 :: " + rtnVal);
			ds.setColumn(nRow, 'stsNm', "오류");
			ds.setColumn(nRow, 'errCn', rtnVal);
		},
		//complete
		() => this.grdMain.setBindDataset(this.grdMain),
		//final
		() => this.grdMain.set_enableredraw(true)
	);
	
	//중복검사 - 데이터셋으로 중복검사
	var isDup = this.fnExcelDupCeck(this.dsExcelUpload, ['uvstExmtNo', 'trprRrno'], '주민번호 또는 수험번호',
		//init
		() => {
			this.grdMain.set_enableredraw(false);
		},
		//error
		(upRow, downRow, ds, rtnVal) => {
			if(this.smfStr(ds.getColumn(upRow, 'errCn')).length == 0){
				//trace("업로우 :: " + upRow + " 내용 :: " + rtnVal);
				ds.setColumn(upRow, 'stsNm', "오류");
				ds.setColumn(upRow, 'errCn', rtnVal);
			}
			if(this.smfStr(ds.getColumn(downRow, 'errCn')).length == 0){
				//trace("다운로우 :: " + downRow + " 내용 :: " + rtnVal);
				ds.setColumn(downRow, 'stsNm', "오류");
				ds.setColumn(downRow, 'errCn', rtnVal);
			}
		},
		//complete
		() => { if(isValid) this.grdMain.setBindDataset(this.grdMain) },
		//final
		() => this.grdMain.set_enableredraw(true)
	);					
	
	var vnErrCnt	= 0;	// 에러 수 
	var vnNorCnt	= 0;	// 정상 수
	var vnSumCnt	= this.dsExcelUpload.getRowCount();
	
	for(var i=0; i<vnSumCnt;i++){
		var vsErrCn	= this.dsExcelUpload.getColumn(i, "errCn");
		if(this.smfIsNull(vsErrCn)){
			vnNorCnt++;
			this.dsExcelUpload.setColumn(i, 'stsNm', "정상");
		}else{
			vnErrCnt++;
		}
	}	

	//유효성 중복 검사 실패
	if(!isValid || isDup) {
	
		this.grdMain.set_enableredraw(true);
		this.dsMain.copyData(this.dsExcelUpload);
		this.dsMain.applyChange();
		
		this.divFileInfo.set_visible(false);
		//this.divUpldFile.set_visible(true);					//파일업로드(오류)그리드 - 이거는 보이면 안됨!
		this.divInfo.set_visible(true);						//파일업로드(오류)안내사항
		var vsCntMsg	= "총 데이터 : " +  vnSumCnt + "건, 정상 : " + vnNorCnt +" 건, 오류 : " + vnErrCnt + " 건";
		this.smfAlert('잘못된형식의 데이터가 있습니다. \n확인후 다시 올려주십시요. \n' + vsCntMsg);
		this.fnBtnEnabled(true);		//버튼활성화
		return;
	}
		
	//문구세팅	
	this.divFileInfo.form.staFileForm.set_visible(false);
	this.divFileInfo.form.staFileForm00.set_visible(false);
	this.divFileInfo.form.staFileInfo.set_text(this.dsExcelUpload.getRowCount() + "건의 파일올리기 작업이 시작되었습니다.\n"
									+ "작업이 완료될 때까지 잠시만 기다려 주시기 바랍니다.\n\n"
									+ "업로드 완료 후에 [업로드결과조회]에서 업로드 결과를 확인할 수 있습니다.");									
	
	//지원자등록 
	this.fnExecuteUpld(this.dsExcelUpload, this.dsMain, this.fvSendSize,
		function() {			
			this.smfAlert('엑셀업로드가 완료 되었습니다.');			
			this.fnBtnEnabled(true);	//버튼활성화
		}	
	).run();
}]]></Script>
  </Form>
</FDL>
