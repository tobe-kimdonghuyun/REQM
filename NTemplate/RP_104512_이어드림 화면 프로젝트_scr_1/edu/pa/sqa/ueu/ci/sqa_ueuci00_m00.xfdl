<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sqa_ueuci00_m00" width="1280" height="687" titletext="코드조회" onload="sqa_ueuci00_m00_onload" onbeforeclose="sqa_ueuci00_m00_onbeforeclose">
    <Layouts>
      <Layout height="687" width="1280" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="70" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="코드조회" left="0" top="0" height="44" cssclass="img_WF_SubTit01" width="170" initvalueid="ivTitleAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divSearch" taborder="1" left="0" top="144" height="52" cssclass="div_WF_Search" text="" right="0" initvalueid="ivDivAccessibilityOn" accessibilitylabel="조회영역">
          <Layouts>
            <Layout>
              <Static id="staPrcsScCd" taborder="0" text="코드구분" left="0" top="11" width="96" height="30" cssclass="sta_WF_Searchtxt01"/>
              <Combo id="cboPrcsScCd" taborder="1" left="staPrcsScCd:0" width="166" height="30" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" text="과목" readonly="false" value="0" top="11" initvalueid="ivCmbNormal" index="0" onitemchanged="divSearch_cboPrcsScCd_onitemchanged" accessibilitylabel="코드구분">
                <Dataset id="innerdataset">
                  <ColumnInfo>
                    <Column id="codecolumn" size="256"/>
                    <Column id="datacolumn" size="256"/>
                  </ColumnInfo>
                  <Rows>
                    <Row>
                      <Col id="codecolumn">0</Col>
                      <Col id="datacolumn">과목</Col>
                    </Row>
                    <Row>
                      <Col id="codecolumn">1</Col>
                      <Col id="datacolumn">시도교육청</Col>
                    </Row>
                  </Rows>
                </Dataset>
              </Combo>
              <Static id="staCdNm" taborder="2" text="과목명" left="cboPrcsScCd:0" top="11" width="118" cssclass="sta_WF_Searchtxt01" height="30" fittocontents="none"/>
              <Edit id="edtCdNm" taborder="3" left="staCdNm:0" top="11" width="130" height="30" text="정시" enable="true" readonly="false" maxlength="15" initvalueid="ivEdtNormal" onkeyup="fnKeyUp_onkeyup" accessibilitylabel="과목명"/>
              <Button id="btnSearch" taborder="4" text="조회" top="11" width="74" height="30" cssclass="btn_WF_Search03" right="20" onclick="btnSearch_onclick"/>
            </Layout>
          </Layouts>
        </Div>
        <Grid id="grdOfcdc" taborder="2" left="0" top="256" autofittype="col" right="0" onheadclick="grdMain_onheadclick" binddataset="dsList" nodatatext="조회된 데이터가 없습니다" height="356" accessibilitylabel="시도교육청코드" initvalueid="ivGrdAccessibilityOn">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="152"/>
                <Column size="306"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="시도교육청코드"/>
                <Cell col="1" text="시도교육청"/>
              </Band>
              <Band id="body">
                <Cell text="bind:cddcOrgCd" textAlign="center"/>
                <Cell col="1" text="bind:kornOrgNm" textAlign="center"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Grid id="grdSbjt" taborder="3" left="0" top="256" autofittype="col" right="0" onheadclick="grdMain_onheadclick" binddataset="dsList" nodatatext="조회된 데이터가 없습니다" height="356" accessibilitylabel="과목코드" initvalueid="ivGrdAccessibilityOn">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="151"/>
                <Column size="292"/>
                <Column size="140"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="과목코드"/>
                <Cell col="1" text="과목명"/>
                <Cell col="2" text="필수여부"/>
              </Band>
              <Band id="body">
                <Cell text="bind:sqeSbjtNo" textAlign="center"/>
                <Cell col="1" text="bind:kornSbjtNm" textAlign="center"/>
                <Cell col="2" text="bind:sqeChcEsntlScCdNm" textAlign="center"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="btnExcel" taborder="4" text="액셀내려받기" top="216" width="135" height="30" cssclass="btn_WF_Excel03" right="0" onclick="btnExcel_onclick"/>
        <Static id="Static99_00_00_00_00" taborder="5" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
        <Static id="Static99_00_00_00_00_01" taborder="6" left="0" top="114" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
        <Static id="Static99_00_00_00_00_00_01" taborder="7" left="0" top="196" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_01_00" taborder="8" left="0" top="246" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_00_00_00" taborder="9" left="0" top="657" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    코드조회
*  @FileName 	sqa_ueuci00_m00.xfdl
*  @Creator 	bsw
*  @CreateDate 	2022.09.05
*  @Desction    대입전형-대학-코드조회
************** 소스 수정 이력 ***********************************************
*  date				Modifier				Description
*******************************************************************************
*  2022.09.05		bsw					최초 생성
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리
 */
this.sqa_ueuci00_m00_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo) {

	// 폼 초기화
	this.smfInitForm(obj);	
	
	// 조회 입력창에서 'Ctrl' + 'Enter' 키 입력시 조회수행 이벤트 설정
	this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
			
	//초기화
	this.fnInit(obj);
	
	// 서버단에 설정한 유효성 검증 목록을 획득하여 설정
	this.fnSearchValidation();
};

/**
 * @description 화면 폼 닫기전 이벤트
 */
this.sqa_ueuci00_m00_onbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
// 		// 변경내역이 발생한 경우 종료전 confirm수행
// 	return this.smfCloseFormConfirm([this.dsDetaRcritPrd]);
};
/************************************************************************************************
 * TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 유효성 검증 목록 조회
 */
this.fnSearchValidation = function() {
	this.smfValidateService("validateMain", {
		url: "/sqa_ueu_ci00_001.do",
	})
	.mappingRulesetToForm(this.divSearch, "search")			//조회Vaild
	.run() 
	.callback(function(callbackParams) {
		if(callbackParams.errors) return;
	}); 
};

/**
 * @description 조회
 */
this.fnSearch = function() {
	this.smfSearchService("listCddcRcptn")
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;
		}) // 콜백
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 초기화
*/ 
 this.fnInit = function(obj){
	//prcsScCd >> 0:과목, 1:시도교육청 세팅
	this.dsSearch.setColumn(0, "prcsScCd", "0");
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 코드구분_조회조건 변경
 */
this.divSearch_cboPrcsScCd_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo) {
	var prcsScCd = obj.value;	
		
	//초기화
	this.divSearch.form.edtCdNm.set_value('');
	this.dsList.clearData();
	
	if(prcsScCd == "0") { //과목명조회
		this.divSearch.form.staCdNm.set_text("과목명");
		this.grdSbjt.set_visible(true);
		this.grdOfcdc.set_visible(false);
	} else {
		this.divSearch.form.staCdNm.set_text("시도교육청명");
		this.grdSbjt.set_visible(false);
		this.grdOfcdc.set_visible(true);
	}
};

/**
 * @description 조회 버튼 클릭
 */
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo) {			
	this.fnSearch();
};

/**
 * @description 엔터키실행
 */
this.fnKeyUp_onkeyup = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo) {
	if(e.keycode=='13') {
		this.btnSearch_onclick();
	}
};

/**
 * @description 엑셀다운로드
 */
this.btnExcel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo) {	
	var gird;														//엑셀그리드
	var fileNm;														//엑셀파일명
	var prcsScCd = this.dsSearch.getColumn(0, 'prcsScCd');	
	
	//조회 validation
	if(this.dsList.getRowCount() == 0 ) {
		this.smfAlert("조회를 먼저 해주시기 바랍니다.")
		return false;
	}
	
	if(prcsScCd == "0") {
		gird = this.grdSbjt;
		fileNm = "코드조회(과목명)"
	} else {
		gird = this.grdOfcdc;
		fileNm = "코드조회(시도교육청)"
	}
		
	var objOption = {
						objGrid : gird
					,   sheetname : "Sheet1"
					,   filename : fileNm
					};
	
	this.smfExcelExport(objOption);
};]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsList=dsList</Col>
            <Col id="asynctp"/>
            <Col id="url">sqa_ueu_ci00_002.do</Col>
            <Col id="id">listCddcRcptn</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" oncolumnchanged="dsSearch_oncolumnchanged">
        <ColumnInfo>
          <Column id="prcsScCd" type="STRING" size="256" description="코드구분"/>
          <Column id="cdNm" type="STRING" size="256" description="과목명"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsList" useclientlayout="true">
        <ColumnInfo>
          <Column id="sqeSbjtNo" type="STRING" size="256" description="검정과목번호"/>
          <Column id="kornSbjtNm" type="STRING" size="256" description="과목명"/>
          <Column id="englSbjtNm" type="STRING" size="256" description="영문과목명"/>
          <Column id="sqeChcEsntlScCd" type="STRING" size="256" description="검정고시선택필수구분코드"/>
          <Column id="sqeChcEsntlScCdNm" type="STRING" size="256" description="검정고시선택필수구분코드명"/>
          <Column id="cddcOrgCd" type="STRING" size="256" description="시도교육청코드"/>
          <Column id="kornOrgNm" type="STRING" size="256" description="기관명"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.cboPrcsScCd" propid="value" datasetid="dsSearch" columnid="prcsScCd"/>
      <BindItem id="item1" compid="divSearch.form.edtCdNm" propid="value" datasetid="dsSearch" columnid="cdNm"/>
    </Bind>
  </Form>
</FDL>
