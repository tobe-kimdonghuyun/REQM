          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="대입전형자료온라인제공" left="0" top="0" height="44" cssclass="img_WF_SubTit01" width="360" initvalueid="ivTitleAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnStep01" taborder="1" text="대입 기본정보 관리" left="0" top="74" height="66" cssclass="btn_WF_StepN" width="11.88%" onclick="btnStep_onclick" initvalueid="ivBtnAccessibilityButton"/>
        <Static id="staNextStep01" taborder="2" left="170" top="84" width="38" height="47" cssclass="sta_WF_NextStep" initvalueid="ivStcAccessibilityOn" accessibilitylabel="다음"/>
        <Button id="btnStep02" taborder="3" text="대상학생&#13;&#10;자료올리기" left="225" top="74" width="11.88%" height="66" cssclass="btn_WF_StepN" onclick="btnStep_onclick" initvalueid="ivBtnAccessibilityButton"/>
        <Static id="staNextStep01_00" taborder="4" left="395" top="84" width="38" height="47" cssclass="sta_WF_NextStep" initvalueid="ivStcAccessibilityOn" accessibilitylabel="다음"/>
        <Button id="btnStep03" taborder="5" text="전형자료요청" left="450" top="74" width="11.88%" height="30" cssclass="btn_WF_StepN" onclick="btnStep_onclick" initvalueid="ivBtnAccessibilityButton"/>
        <Button id="btnStep04" taborder="6" text="전형자료재요청" left="450" top="110" width="11.88%" height="30" cssclass="btn_WF_StepN" onclick="btnStep_onclick" initvalueid="ivBtnAccessibilityButton"/>
        <Static id="staNextStep01_00_00" taborder="7" left="620" top="84" width="38" height="47" cssclass="sta_WF_NextStep" initvalueid="ivStcAccessibilityOn" accessibilitylabel="다음"/>
        <Button id="btnStep05" taborder="8" text="전형자료생성" left="675" top="74" width="11.88%" height="66" cssclass="btn_WF_StepN" onclick="btnStep_onclick" initvalueid="ivBtnAccessibilityButton"/>
        <Static id="staNextStep01_00_01" taborder="9" left="845" top="84" width="38" height="47" cssclass="sta_WF_NextStep" initvalueid="ivStcAccessibilityOn" accessibilitylabel="다음"/>
        <Button id="btnStep06" taborder="10" text="전형자료수신" left="900" top="74" width="11.88%" height="66" cssclass="btn_WF_StepN" onclick="btnStep_onclick" initvalueid="ivBtnAccessibilityButton"/>
        <Static id="staNextStep01_00_02" taborder="11" left="1070" top="84" width="38" height="47" cssclass="sta_WF_NextStep" initvalueid="ivStcAccessibilityOn" accessibilitylabel="다음"/>
        <Button id="btnStep07" taborder="12" text="전형자료복호화" top="74" height="66" cssclass="btn_WF_StepS" onclick="btnStep_onclick" width="11.88%" right="23" initvalueid="ivBtnAccessibilityButton"/>
        <Div id="divMain" taborder="13" left="0" top="160" cssclass="div_WF_Detail" url="pa_uds_ueu_dd::uds_ueudd00_m01.xfdl" text="" bottom="0" right="0"/>
        <Static id="Static99_00_00_00_00" taborder="14" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01" taborder="15" left="0" top="44" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_01" taborder="16" left="0" top="140" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
