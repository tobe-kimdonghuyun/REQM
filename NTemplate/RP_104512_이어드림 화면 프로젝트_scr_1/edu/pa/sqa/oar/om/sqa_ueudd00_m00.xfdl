    <Script type="xscript5.1"><![CDATA[/**
 *	전형자료온라인수신
 *	@MenuPath	대입전형-전형자료온라인수신
 *	@FileName 	uds_ueudd00_m00.xfdl
 *	@Creator 	김동업
 *	@CreateDate	2022.08.22
 *	@Desction	
 ************** 소스 수정 이력 ***********************************************
 *	date			Modifier			Description
 *******************************************************************************
 *	2022.08.22		김동업				최초 생성
 *******************************************************************************
 */

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::uds_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
};

/************************************************************************************************
 * TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 스텝 변경
 */
this.btnStep_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	// 초기화
	this.btnStep01.set_cssclass("btn_WF_StepN");
	this.btnStep02.set_cssclass("btn_WF_StepN");
	this.btnStep03.set_cssclass("btn_WF_StepN");
	this.btnStep04.set_cssclass("btn_WF_StepN");
	this.btnStep05.set_cssclass("btn_WF_StepN");
	this.btnStep06.set_cssclass("btn_WF_StepN");
	this.btnStep07.set_cssclass("btn_WF_StepN");
	
	if(obj.name == 'btnStep01'){
		this.btnStep01.set_cssclass("btn_WF_StepS");
		this.divMain.set_url("pa_uds_ueu_dd::uds_ueudd00_m01.xfdl");
	}else if(obj.name == 'btnStep02'){
		this.btnStep02.set_cssclass("btn_WF_StepS");
		this.divMain.set_url("pa_uds_ueu_dd::uds_ueudd00_m02.xfdl");
	}else if(obj.name == 'btnStep03'){
		this.btnStep03.set_cssclass("btn_WF_StepS");
		this.divMain.set_url("pa_uds_ueu_dd::uds_ueudd00_m03.xfdl");
	}else if(obj.name == 'btnStep04'){
		this.btnStep04.set_cssclass("btn_WF_StepS");
		this.divMain.set_url("pa_uds_ueu_dd::uds_ueudd00_m04.xfdl");
	}else if(obj.name == 'btnStep05'){
		this.btnStep05.set_cssclass("btn_WF_StepS");
		this.divMain.set_url("pa_uds_ueu_dd::uds_ueudd00_m05.xfdl");
	}else if(obj.name == 'btnStep06'){
		this.btnStep06.set_cssclass("btn_WF_StepS");
		this.divMain.set_url("pa_uds_ueu_dd::uds_ueudd00_m06.xfdl");
	}else if(obj.name == 'btnStep07'){
		this.btnStep07.set_cssclass("btn_WF_StepS");
		this.divMain.set_url("pa_uds_ueu_dd::uds_ueudd00_m07.xfdl");
	}
};

]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
