    <Objects>
      <Dataset id="dsSearch">
        <ColumnInfo>
          <Column id="enfcYr" type="STRING" size="256"/>
          <Column id="enfcTme" type="STRING" size="256"/>
          <Column id="sqeScCd" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="rcptNo" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsApplpInfo" useclientlayout="true">
        <ColumnInfo>
          <Column id="enfcYr" type="STRING" size="256"/>
          <Column id="enfcTme" type="STRING" size="256"/>
          <Column id="sqeScCd" type="STRING" size="256"/>
          <Column id="sqeScCdNm" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="kornFlnm" type="STRING" size="256"/>
          <Column id="trprRrno" type="STRING" size="256"/>
          <Column id="rcptNo" type="STRING" size="256"/>
          <Column id="sqeExmtNo" type="STRING" size="256"/>
          <Column id="exmmScNm" type="STRING" size="256"/>
          <Column id="rprsTelno" type="STRING" size="256" description="고사장대표전화번호"/>
          <Column id="pilSun" type="STRING" size="256"/>
          <Column id="kornSbjtNm" type="STRING" size="256"/>
          <Column id="priScCdNm" type="STRING" size="256"/>
          <Column id="eungsiNy" type="STRING" size="256"/>
          <Column id="exmntYmd" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsService">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">selectOarEo</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="url">sqa_oar_eo00_001.do</Col>
            <Col id="outDatasets">dsApplpInfo=dsApplpInfo</Col>
          </Row>
          <Row>
            <Col id="url">sqa_oar_eo00_002.do</Col>
            <Col id="id">selectReport</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsReportInfo=dsReportInfo dsReportInfoSbjt=dsReportInfoSbjt dsRcgnNo=dsRcgnNo dsExamInfo=dsExamInfo</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsExamInfo" useclientlayout="true">
        <ColumnInfo>
          <Column id="examPremaCn" type="STRING" size="256" description="시험준비물내용"/>
          <Column id="atentMteCn" type="STRING" size="256" description="주의사항내용"/>
          <Column id="exmhRlsYmd" type="STRING" size="256" description="고사장공개일"/>
          <Column id="exmhChcYn" type="STRING" size="256" description="고사장선택여부"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsReportInfo" useclientlayout="true">
        <ColumnInfo>
          <Column id="kornFlnm" type="STRING" size="256"/>
          <Column id="trprRrno" type="STRING" size="256"/>
          <Column id="sqeExmtNo" type="STRING" size="256"/>
          <Column id="exmhNm" type="STRING" size="256"/>
          <Column id="rprsTelno" type="STRING" size="256" description="고사장대표전화번호"/>
          <Column id="examYmd" type="STRING" size="256"/>
          <Column id="orgName" type="STRING" size="256"/>
          <Column id="rcgnNo" type="STRING" size="256"/>
          <Column id="photoFileCn" type="STRING" size="256"/>
          <Column id="examPremaCn" type="STRING" size="256" description="시험준비물내용"/>
          <Column id="atentMteCn" type="STRING" size="256" description="주의사항내용"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsPerson">
        <ColumnInfo>
          <Column id="no" type="STRING" size="256"/>
          <Column id="jumin_id" type="STRING" size="256"/>
          <Column id="name" type="STRING" size="256"/>
          <Column id="address" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsReportInfoSbjt" useclientlayout="true">
        <ColumnInfo>
          <Column id="enfcYr" type="STRING" size="256"/>
          <Column id="enfcTme" type="STRING" size="256"/>
          <Column id="sqeScCd" type="STRING" size="256"/>
          <Column id="sqeScCdNm" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="kornFlnm" type="STRING" size="256"/>
          <Column id="trprRrno" type="STRING" size="256"/>
          <Column id="rcptNo" type="STRING" size="256"/>
          <Column id="sqeExmtNo" type="STRING" size="256"/>
          <Column id="exmhNm" type="STRING" size="256" description="고사장"/>
          <Column id="rprsTelno" type="STRING" size="256" description="고사장대표전화번호"/>
          <Column id="pilsun" type="STRING" size="256"/>
          <Column id="kornSbjtNm" type="STRING" size="256"/>
          <Column id="priScCdNm" type="STRING" size="256"/>
          <Column id="eungsiNy" type="STRING" size="256"/>
          <Column id="examYmd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsRcgnNo" useclientlayout="true">
        <ColumnInfo>
          <Column id="rcgnNo" type="STRING" size="256"/>
          <Column id="photoFileCn" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 검정고시서비스 성적조회-개인성적조회
*  @FileName 	sqa_arisi00_m00.xfdl 
*  @Creator 	박가혜
*  @CreateDate 	2022.08.09
*  @Desction    개인성적조회
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.08.09           박가혜                 최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/




include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.fv_param;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frm01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);
	this.dsSearch.addRow();
	// 파라메터 세팅
	this.fv_param = this.smfGetFormParams();
	
	this.fnSetInitParam(this.smfGetFormParams());

	trace("수험표출력화면")
	trace("세션정보 : " + this.smfGetSessionValue("enfcYr") + " : " + this.smfGetSessionValue("enfcTme") + " : " + this.smfGetSessionValue("cddcCd") )
	trace("세션정보 : " + this.smfGetSessionValue("kornFlnm") + " : " + this.smfGetSessionValue("trprRrno") + " : " + this.smfGetSessionValue("rcptNo") )
	
	//로그인이나 세션에서 넘어온 값
	this.dsSearch.setColumn(0, "enfcYr",this.fv_param.enfcYr);
	this.dsSearch.setColumn(0, "enfcTme", this.fv_param.enfcTme);
	this.dsSearch.setColumn(0, "cddcCd", this.smfGetSessionValue("cddcCd"));
	this.dsSearch.setColumn(0, "rcptNo", this.fv_param.rcptNo);
	this.dsSearch.setColumn(0, "sqeScCd", this.fv_param.sqeScCd);


	this.fnInit();

};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnInit = function()
{
	this.smfSearchService("selectOarEo")
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.fnSetData();
		});	
	
	
}




/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd == -1) return;
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 기초데이터(응시자정보) 셋팅
*/
this.fnSetData = function(){
	var enfcYr = this.dsApplpInfo.getColumn(0,"enfcYr")
	var enfcTme = this.dsApplpInfo.getColumn(0,"enfcTme")
	var sqeScCdNm = this.dsApplpInfo.getColumn(0,"sqeScCdNm")
	
	this.imgMainTitle.set_text(enfcYr + "년도 " + enfcTme + "회차 " + sqeScCdNm + " 수험자 정보 ")
	
	//주민등록번호
	var trprRrno = this.dsApplpInfo.getColumn(0,"trprRrno")
	if(trprRrno.length > 0){
		this.divApplpInfo.form.edtTrprRrno1.set_value(trprRrno.substring(0,6))
		this.divApplpInfo.form.edtTrprRrno2.set_value(trprRrno.substring(6,13))
	}
	
	//고사장
// 	if(this.dsExamInfo.getColumn(0,"exmhChcYn") == "Y" && this.smfIsNull(this.dsExamInfo.getColumn(0,"exmhRlsYmd"))
// 	&& this.smfToday() < this.dsExamInfo.getColumn(0,"exmhRlsYmd")){
// 	
// 		this.dsReportInfo.setColumn(0,"exmhNm","고사장 발표 전")
// 			
// 	}else 
	
	if(this.dsExamInfo.getColumn(0,"exmhChcYn") == "N" && this.smfToday() < this.dsExamInfo.getColumn(0,"exmhRlsYmd")){
		
		this.dsReportInfo.setColumn(0,"exmhNm","고사장 발표 전")
	}else{
				this.dsReportInfo.setColumn(0,"exmhNm",this.dsApplpInfo.getColumn(0,"exmmScNm"))
	}
	
	this.smfSearchService("selectReport")
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.dsRcgnNo.getColumn(0,"photoFileCn")
			//this.img00.set_image("data:image/png;base64,"+this.dsRcgnNo.getColumn(0,"photoFileCn"))
			this.fnSetReport();
		});	
	
	
	

}
/**
 * @description Oz 리포트 셋팅 (OZ Report)
*/
this.fnSetReport = function(){

	//var sSecurityYN     = this.chkSecurityYN.value     ?"Y":"N";   // 위변조방지 삽입
	//var sVoiceBarcodeYN = this.chkVoiceBarcodeYN.value ?"Y":"N";   // 보이스바코드 삽입
	//var sBrailleCodeYN  = this.chkBrailleCodeYN.value  ?"Y":"N";   // 점자문서 생성
	
	var enfcYr = this.dsApplpInfo.getColumn(0,"enfcYr")
	var enfcTme = this.dsApplpInfo.getColumn(0,"enfcTme")
	var sqeScCdNm = this.dsApplpInfo.getColumn(0,"sqeScCdNm")
	
	
	var sReportName  = "/edu/pa/sqa/oar/eo/sqa_oareo00_r00.ozr";
	var subTitle = enfcYr + "년도 제" + enfcTme + "회 " + sqeScCdNm + " 수험표 "
	
	var orgName = this.dsReportInfo.getColumn(0,"orgName")
	var trprRrno = this.dsReportInfo.getColumn(0,"trprRrno")
	
	this.dsReportInfo.setColumn(0,"examPremaCn", this.dsExamInfo.getColumn(0,"examPremaCn")) //유의사항
	this.dsReportInfo.setColumn(0,"atentMteCn", this.dsExamInfo.getColumn(0,"atentMteCn")) //시험준비물
	
	
	if(!this.smfIsNull(trprRrno)){
		this.dsReportInfo.setColumn(0,"trprRrno", trprRrno.substring(0,6)+"-"+trprRrno.substring(6,13))
	}
	
	// 리포트를 생성하기 위한 옵션을 설정한다.
	var oOzOption = {
					    reports : [	
							{	
								// 기본데이터
								  displayname         : "수험표출력"   // [필수] 멀티리포트시 Tree에 보여줄 이름
								, reportname : sReportName // [필수] 리포트명  "/jsonsample.ozr"
								
								// json연동형
								//  - Odi인 경우 지정안해도 됨
								//  - jsonDs/jsonDsName은 갯수가 같아야 됨
								, jsonDs     : [this.dsReportInfo,this.dsReportInfoSbjt]  // [선택] json으로 변환할 데이터셋
								, jsonDsName : ["dsReportInfo","dsReportInfoSbjt"]            // [선택] json으로 변환할 데이터의이름(ozr파일에서 지정된 값과 일치)
								, jsonParam  : ["subTitle="+subTitle,"orgName="+orgName]  // [선택] json이외에추가할 데이터(KEY=VALUE형태의 스트링(배열))
								
								
								// 추가/보안옵션
								, security     : "N"       // [선택] 위변조방지 삽입   ("Y"(default):표시,"N":비표시)
								, voiceBarcode : "N"   // [선택] 보이스바코드 삽입 ("Y"(default):표시,"N":비표시)
								, brailleCode  : "N"    // [선택] 점자문서 생성     ("Y":생성,"N"(default):미생성)
							}						
						]
	                };
					
	//리포트를 그린다.
	//var sReportViewType = "embedded";  // Report View Type ("embedded" : Form안의 Div에 표시 , "popup": 공통팝업으로 표시)
	//if(sReportViewType=="embedded")
	//{
	//	this.smfReportView(this,sReportViewType,oOzOption,this.divReportViewer);            // Div로 표시
	//}
	

	this.divReportViewer.optionReport = oOzOption;
	this.divReportViewer.set_url("comm::comp_ozreport.xfdl");
	
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

]]></Script>
    <Bind>
      <BindItem id="item3" compid="divApplpInfo.form.edtKornFlnm" propid="value" datasetid="dsApplpInfo" columnid="kornFlnm"/>
      <BindItem id="item0" compid="divApplpInfo.form.edtRcptNo" propid="value" datasetid="dsApplpInfo" columnid="rcptNo"/>
    </Bind>
  </Form>
</FDL>
