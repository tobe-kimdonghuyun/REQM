              <Static id="sta45_01" taborder="3" left="430" width="160" height="63" cssclass="sta_WF_Input01Top" text="주민등록번호&#13;&#10;(외국인등록번호)" top="0" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn" accessibilitylabel="주민등록번호"/>
              <Edit id="edtTrprRrno1" taborder="4" height="30" text="6235690" left="595" top="16" readonly="true" onchanged="Div01_Edit00_onchanged" cssclass="edi_WF_Input" initvalueid="ivEdtReadOnly" textAlign="left" accessibilitylabel="주민번호앞자리" width="70"/>
              <Static id="edtTrprRrno0" taborder="5" text="-" left="665" top="16" width="15" height="30" cssclass="sta_WF_AC" initvalueid="ivStcAccessibilityOn" accessibilitylabel="다음"/>
              <Edit id="edtTrprRrno2" taborder="6" height="30" text="1235616" left="680" top="16" readonly="true" onchanged="Div01_Edit00_onchanged" cssclass="edi_WF_Input" initvalueid="ivEdtReadOnly" textAlign="left" accessibilitylabel="주민번호뒷자리" width="95"/>
              <Static id="sta45_01_00" taborder="7" left="830" width="160" height="63" cssclass="sta_WF_Input01Top" text="접수번호" top="0" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtRcptNo" taborder="8" height="30" text="강원고등학교" left="995" width="195" top="16" readonly="true" onchanged="Div01_Edit00_onchanged" cssclass="edi_WF_Input" initvalueid="ivEdtReadOnly"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divReportViewer" taborder="3" left="0" top="270" height="680" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout/>
