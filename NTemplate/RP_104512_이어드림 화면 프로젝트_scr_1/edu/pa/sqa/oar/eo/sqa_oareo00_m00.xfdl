          <Layouts>
            <Layout>
              <Static id="sta44" taborder="0" left="0" height="63" cssclass="sta_WF_Input02Top" top="0" right="0" text="" initvalueid="ivStcAccessibilityOff" onclick="Div03_00_sta44_onclick"/>
              <Static id="sta45" taborder="1" left="0" width="160" height="63" cssclass="sta_WF_Input01Top" text="성명" top="0" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn" accessibilitylabel="성명"/>
