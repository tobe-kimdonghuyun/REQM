          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">select</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsOneUserInfo=dsOneUserInfo dsAllUserInfo=dsAllUserInfo dsCancelChk=dsCancelChk</Col>
            <Col id="url">sqa_oar_oi00_001.do</Col>
          </Row>
          <Row>
            <Col id="id">deleteApplpInfo</Col>
            <Col id="inDatasets">dsOneUserInfo=dsOneUserInfo</Col>
            <Col id="url">sqa_oar_oi00_002.do</Col>
            <Col id="outDatasets">dsSearch=dsSearch</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsCancelChk" useclientlayout="true">
        <ColumnInfo>
          <Column id="itnRcptRtrcnBgngYmd" type="STRING" size="256"/>
          <Column id="itnRcptRtrcnEndYmd" type="STRING" size="256"/>
          <Column id="itnRcptRtrcnBgngTm" type="STRING" size="256"/>
          <Column id="itnRcptRtrcnEndTm" type="STRING" size="256"/>
          <Column id="exmhRlsYmd" type="STRING" size="256"/>
          <Column id="exmhChcYn" type="STRING" size="256"/>
          <Column id="exmhRlsTm" type="STRING" size="256"/>
          <Column id="toHour" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsAllUserInfo" useclientlayout="true">
        <ColumnInfo>
          <Column id="sqeSbjtNoNm" type="STRING" size="256"/>
          <Column id="sbjtAplemScCdNm" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="enfcYr" type="STRING" size="256"/>
          <Column id="enfcTme" type="STRING" size="256"/>
          <Column id="sqeScCd" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="rcptNo" type="STRING" size="256"/>
          <Column id="returnVal" type="STRING" size="256"/>
          <Column id="kornFlnm" type="STRING" size="256"/>
          <Column id="trprRrno" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsOneUserInfo" useclientlayout="true">
        <ColumnInfo>
          <Column id="sqeScCd" type="STRING" size="256"/>
          <Column id="enfcYr" type="STRING" size="256"/>
          <Column id="enfcTme" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="sqeScCdNm" type="STRING" size="256"/>
          <Column id="kornFlnm" type="STRING" size="256"/>
          <Column id="rcptNo" type="STRING" size="256"/>
          <Column id="sqeExmtNo" type="STRING" size="256"/>
          <Column id="trprRrno" type="STRING" size="256"/>
          <Column id="ihtRegRoadNmZip" type="STRING" size="256"/>
          <Column id="ihtRegRoadNmAddr" type="STRING" size="256"/>
          <Column id="ihtRegRoadNmDaddr" type="STRING" size="256"/>
          <Column id="claiTelno" type="STRING" size="256"/>
          <Column id="mblTelno" type="STRING" size="256"/>
          <Column id="dltYn" type="STRING" size="256"/>
          <Column id="rcgnDltScCdNm" type="STRING" size="256"/>
          <Column id="prsrScCd" type="STRING" size="256"/>
          <Column id="applpScCd" type="STRING" size="256"/>
          <Column id="applpScCdNm" type="STRING" size="256"/>
          <Column id="acbgScCd" type="STRING" size="256"/>
          <Column id="acbgScCdNm" type="STRING" size="256"/>
          <Column id="grdtnExpelYmd" type="STRING" size="256"/>
          <Column id="shlNm" type="STRING" size="256"/>
          <Column id="shlLctnCtpvCd" type="STRING" size="256"/>
          <Column id="shlLctnCtpvCdNm" type="STRING" size="256"/>
          <Column id="shlLctnAddr" type="STRING" size="256"/>
          <Column id="sbmsnYn" type="STRING" size="256"/>
          <Column id="sbmsnYmd" type="STRING" size="256"/>
          <Column id="exmhNo" type="STRING" size="256"/>
          <Column id="exmmScNm" type="STRING" size="256"/>
          <Column id="photoFileCn" type="STRING" size="256"/>
          <Column id="photoFileNm" type="STRING" size="256"/>
          <Column id="sqe1CnvAplyCdNm" type="STRING" size="256"/>
          <Column id="sqe2CnvAplyCdNm" type="STRING" size="256"/>
          <Column id="sqe3CnvAplyCdNm" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 검정고시서비스 원서접수-응시자정보
*  @FileName 	sqa_oaror02_m00.xfdl 
*  @Creator 	박가혜
*  @CreateDate 	2022.06.14
*  @Desction    응시자정보
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.06.14           박가혜                 최초 생성 
*  2024.10.24			진승환					범정부 UI/UX 가이드라인 적용 (원서삭제시 페이지 이동 수정)
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/




include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.fv_param;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frm01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);
	this.dsSearch.addRow();
	

	// 파라메터 세팅
	this.fv_param = this.smfGetFormParams();
	
	this.fnSetInitParam(this.smfGetFormParams());
	
	//로그인이나 세션에서 넘어온 값
	this.dsSearch.setColumn(0, "enfcYr", this.fv_enfcYr);
	this.dsSearch.setColumn(0, "enfcTme", this.fv_enfcTme);
	this.dsSearch.setColumn(0, "sqeScCd", this.fv_sqeScCd);
	this.dsSearch.setColumn(0, "cddcCd", this.fv_cddcCd);
	this.dsSearch.setColumn(0, "rcptNo", this.fv_rcptNo);
	this.dsSearch.setColumn(0, "trprRrno", this.smfGetTrprRrno());
	this.dsSearch.setColumn(0, "kornFlnm", this.smfGetKornFlnm());
	
	this.fnInit();
	
	this.smfResetScroll(this.divMain1.form) //div사이즈 최적화
	

};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnInit = function()
{
	this.smfSearchService("select")
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.fnSetData();
		});	
	
	
}

//기초데이터 셋팅
this.fnSetData = function(){
	
	var enfcYr = this.dsOneUserInfo.getColumn(0,"enfcYr");
	var enfcTme = this.dsOneUserInfo.getColumn(0,"enfcTme")
	var sqeExmtNo = this.dsOneUserInfo.getColumn(0, "sqeExmtNo")
	
	//서브타이틀
	this.imgSubTitle.set_text(enfcYr + "년도 " + enfcTme + "회차 " + this.dsOneUserInfo.getColumn(0,"sqeScCdNm") + "접수내역 확인")
	
	//사진
	this.divMain1.form.imgViewer.set_image("data:image/png;base64,"+this.dsOneUserInfo.getColumn(0,"photoFileCn"))
	if(this.dsOneUserInfo.getColumn(0,"photoFileCn") != "" && this.dsOneUserInfo.getColumn(0,"photoFileCn") != null){
		this.divMain1.form.imgViewer.set_text("")
	}
	
	//수험번호
	if(!this.smfIsNull(sqeExmtNo)){
		this.divMain1.form.edtSqeExmtNo.set_value(sqeExmtNo)
	}else{
		this.divMain1.form.edtSqeExmtNo.set_value("수험번호는 담당자가 부여한 후, 확인 가능합니다")
	}

	
	//주민등록번호
	var trprRrno = this.dsOneUserInfo.getColumn(0,"trprRrno")
	if(trprRrno.length > 0){
		this.divMain1.form.edtTrprRrno1.set_value(trprRrno.substring(0,6))
		this.divMain1.form.edtTrprRrno2.set_value(trprRrno.substring(6,13))
	}
	
	//주소
	var zipCd = this.dsOneUserInfo.getColumn(0,"ihtRegRoadNmZip")
	var rdnAddr = this.dsOneUserInfo.getColumn(0,"ihtRegRoadNmAddr")
	this.divMain1.form.edtIhtRegRdnAddr.set_value(zipCd + " " + rdnAddr)
	
	//장애여부
	var dltYn = this.dsOneUserInfo.getColumn(0,"dltYn")
	if(dltYn == "N"){ 
		this.divMain1.form.edtDltYn.set_value("일반인")
	}else{
		this.divMain1.form.edtDltYn.set_value("장애인")
	}
	
	//전화번호
	var mblTelno = this.dsOneUserInfo.getColumn(0, "mblTelno")
	var claiTelno = this.dsOneUserInfo.getColumn(0, "claiTelno")
	
	if(this.smfIsNull(claiTelno)){
		this.divMain1.form.edtMblTelno.set_value(mblTelno)
	}else{
		this.divMain1.form.edtMblTelno.set_value(mblTelno + " / " + claiTelno)
	}
	//재소구분
	var prsrScCd = this.dsOneUserInfo.getColumn(0, "prsrScCd")
	
	if(!this.smfIsNull(prsrScCd)){
		if(prsrScCd ==  0){
			this.divMain1.form.edtPrsrScCd.set_value("일반인")
		}else if(prsrScCd == 1){
			this.divMain1.form.edtPrsrScCd.set_value("교도소재소자")
		}else{
			this.divMain1.form.edtPrsrScCd.set_value("소년원재소자")
		}
	}
	

	//제출일자
	var sbmsnYmd = this.dsOneUserInfo.getColumn(0, "sbmsnYmd")
	if(this.smfIsNull(sbmsnYmd)){
		this.divMain1.form.edtSbmsnYmd.set_value("-")
	}else{
		this.divMain1.form.edtSbmsnYmd.set_value(sbmsnYmd.substr(0, 4) + "-" + sbmsnYmd.substr(4, 2) + "-" + sbmsnYmd.substr(6, 2))
	}
	
	//subText
	var sbmsnYn = this.dsOneUserInfo.getColumn(0, "sbmsnYn")
	var sqeExmtNo = this.dsOneUserInfo.getColumn(0, "sqeExmtNo")
	var sqeScCd = this.dsOneUserInfo.getColumn(0, "sqeScCd")
	var itnRcptRtrcnBgngYmd = this.dsCancelChk.getColumn(0, "itnRcptRtrcnBgngYmd")
	var itnRcptRtrcnEndYmd = this.dsCancelChk.getColumn(0, "itnRcptRtrcnEndYmd")
	var itnRcptRtrcnBgngTm = this.dsCancelChk.getColumn(0, "itnRcptRtrcnBgngTm")
	var itnRcptRtrcnEndTm = this.dsCancelChk.getColumn(0, "itnRcptRtrcnEndTm")
	var txt = itnRcptRtrcnBgngYmd.substr(0, 4) + "." + itnRcptRtrcnBgngYmd.substr(4, 2) + "." + itnRcptRtrcnBgngYmd.substr(6, 2) + " " + this.smfRtrim(itnRcptRtrcnBgngTm)+ "시 ~ "
	txt += itnRcptRtrcnEndYmd.substr(0, 4) + "." + itnRcptRtrcnEndYmd.substr(4, 2) + "." + itnRcptRtrcnEndYmd.substr(6, 2) + " " +this.smfRtrim(itnRcptRtrcnEndTm) +"시"
	
	var staSubText4 = new Static("staSubText4",0, "staSubText3:0", null, 25, 0);
	this.divSubText.addChild(staSubText4.name, staSubText4)
	staSubText4.set_text("※ 접수취소기간 : " +  txt)
	staSubText4.set_cssclass("sta_WF_Blue14")
	
	if(sbmsnYn == 'Y' && !this.smfIsNull(sqeExmtNo)){
		this.divSubText.form.staSubText1.set_text("※ 본 원서는 제출 완료 후 수험번호가 부여되었으므로 상단의 [수험표출력] 메뉴에서 수험표를 출력 하실 수 있습니다." )
		this.divSubText.form.staSubText2.set_text("※ 제출 후 교육청담당자의 확인이 완료된 원서에 대해서만 수험번호가 발급되며, 응시원서는 수험번호 발급 여부에 관계없이 출력 가능합니다. \n   - 등록하신 연락처로 연락이 갈 수 있으니 연락을 필히 받아주시기 바랍니다.")
		this.divSubText.form.staSubText3.set_text("※ 접수내역을 취소하실경우에는 접수취소기간에 한해 취소버튼으로 취소 하실수 있습니다.")
		staSubText4.show();
	}else if( sbmsnYn == 'Y' && !this.smfIsNull(sqeScCd)){
		this.divSubText.form.staSubText1.set_text("※ 본 원서는 제출된 문서입니다. 담당자가 수험번호 부여 중입니다." )
		this.divSubText.form.staSubText2.set_text("※ 제출 후 교육청담당자의 확인이 완료된 원서에 대해서만 수험번호가 발급되며, 응시원서는 수험번호 발급 여부에 관계없이 출력 가능합니다. \n   - 등록하신 연락처로 연락이 갈 수 있으니 연락을 필히 받아주시기 바랍니다.")
		this.divSubText.form.staSubText3.set_text("※ 접수내역을 취소하실경우에는 접수취소기간에 한해 취소버튼으로 취소 하실수 있습니다.")
		staSubText4.show();
	}else if((sbmsnYn == 'N' || this.smfIsNull(sbmsnYn) == true) && this.smfIsNull(sqeExmtNo) && sqeScCd != ""){
		this.divSubText.form.staSubText1.set_text("※ 원서접수중 입니다. 원서접수 후 제출을 하셔야 합니다" )
		this.divSubText.form.staSubText2.set_text("※ 접수내역을 취소하실경우에는 접수취소기간에 한해 취소버튼으로 취소 하실수 있습니다.")
		this.divSubText.form.staSubText3.set_text("※ 접수취소기간 : " +  txt)
	}
	this.smfResetScroll(this.divSubText.form) //div사이즈 최적화
	
	//졸업,제적일자
	var grdtnExpelYmd = this.dsOneUserInfo.getColumn(0, "grdtnExpelYmd")
	if(this.smfIsNull(grdtnExpelYmd)){
		this.divMain2.form.edtGrdtnExpelYmd.set_value("-")
	}else{
		this.divMain2.form.edtGrdtnExpelYmd.set_value(grdtnExpelYmd.substr(0, 4) + "-" + grdtnExpelYmd.substr(4, 2) + "-" + grdtnExpelYmd.substr(6, 2))
	}
	
	//고사장
// 	if(this.dsCancelChk.getColumn(0,"exmhChcYn") == "Y" && !this.smfIsNull(this.dsCancelChk.getColumn(0,"exmhRlsYmd"))
// 	&& this.smfToday() < this.dsCancelChk.getColumn(0,"exmhRlsYmd")){
// 	
// 		this.divMain3.form.edtExmmScNm.set_value("고사장 발표 전")
// 			
// 	}else 
	
	//고사장 선택 여부와 상관없이 고사장 공개 날짜에 따라 고사장 공개 또는 비공개 설정
	if(this.dsCancelChk.getColumn(0,"exmhRlsYmd") != null && this.dsCancelChk.getColumn(0,"exmhRlsYmd").trim() != ""){
		if(this.smfToday() < this.dsCancelChk.getColumn(0,"exmhRlsYmd")){
				this.divMain3.form.edtExmmScNm.set_value("고사장 발표 전")
		}else if(this.smfToday() > this.dsCancelChk.getColumn(0,"exmhRlsYmd")){
			this.divMain3.form.edtExmmScNm.set_value(this.dsOneUserInfo.getColumn(0,"exmmScNm"))
		}else{
			if(this.dsCancelChk.getColumn(0,"toHour").trim() < this.dsCancelChk.getColumn(0,"exmhRlsTm").trim()){
				this.divMain3.form.edtExmmScNm.set_value("고사장 발표 전")
			}else{
				this.divMain3.form.edtExmmScNm.set_value(this.dsOneUserInfo.getColumn(0,"exmmScNm"))
			}
		}
	}else{ 
		if(this.dsCancelChk.getColumn(0,"exmhChcYn") == "Y"){
			this.divMain3.form.edtExmmScNm.set_value(this.dsOneUserInfo.getColumn(0,"exmmScNm"))
		}else{
			this.divMain3.form.edtExmmScNm.set_value("고사장 발표 전")
		}
	}
	
	//과목세팅
	this.sbjtUserInfo();
	this.smfResetScroll(this.divMain4.form) //div사이즈 최적화
}


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
	에러코드 (0 : 정상, 0 보다 작으면 에러)
*/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(svcid == "deleteApplpInfo"){
		if(errcd == 0){ //정상
			//this.smfAlert("접수취소가 완료되었습니다.", function(){
				var params = {
					enfcYr :  this.dsOneUserInfo.getColumn(0,"enfcYr"),
					enfcTme : this.dsOneUserInfo.getColumn(0,"enfcTme"),
					sqeScCd : this.dsOneUserInfo.getColumn(0,"sqeScCd"),
					cddcCd : this.dsOneUserInfo.getColumn(0,"cddcCd"),
					rcptNo : this.dsOneUserInfo.getColumn(0,"rcptNo"),
					//subTitle : this.imgSubTitle.text,
					//menuId : "4000"
					};
				
					//this.smfSetWorkPage("pa_sqa_cmm_cm::sqa_cmmcm04_m00.xfdl", params);
					this.smfSetWorkPage("pa_sqa_oar_or::sqa_oaror07_m00.xfdl", params);
			//})	
			
		}else{
			this.smfAlert("접수취소가 완료되지 않았습니다. ")
			return;
		}
	}
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 원서접수 데이터 중 과목 조회
*/
this.sbjtUserInfo = function(){

	if(this.dsAllUserInfo.rowcount > 0){
		for(var i = 0; i < this.dsAllUserInfo.rowcount; i++){
		
			var nTop = i * 41;
		
			var staStatic = new Static("staStatic"+i, 0, nTop, 160, 42, null, null)
			if(i == 0) {
				staStatic.set_cssclass("sta_WF_Input01Top")
			}else{
				staStatic.set_cssclass("sta_WF_Input01")
			}
			staStatic.set_initvalueid("ivStcAccessibilityOn")
			staStatic.set_text(this.dsAllUserInfo.getColumn(i, "sqeSbjtNoNm"))
			this.divMain4.addChild(staStatic.name, staStatic)
			staStatic.show();
			
			var staStatic2 = new Static("staStatic1"+i, "staStatic"+i+":"+ 0, nTop, null, 42, 0, null)
			if(i == 0) {
				staStatic2.set_cssclass("sta_WF_Input02Top")
			}else{
				staStatic2.set_cssclass("sta_WF_Input02")
			}
			staStatic2.set_initvalueid("ivStcAccessibilityOff")
			this.divMain4.addChild(staStatic2.name, staStatic2)
			staStatic2.show();
			
			var edtEdit = new Edit("edtEdit"+i, "staStatic"+i+":"+ 10, nTop+6, null, 30, 105, null)
			edtEdit.set_cssclass("edi_WF_Input")
			edtEdit.set_initvalueid("ivEdtReadOnly")
			edtEdit.set_readonly(true)
			edtEdit.set_value(this.dsAllUserInfo.getColumn(i, "sbjtAplemScCdNm"))
			this.divMain4.addChild(edtEdit.name, edtEdit)
			edtEdit.show();
		}
	}else{
		this.divMain4.set_visible(false)
	} 
}

this.fnCancelCallback = function(){
	var returnVal = this.dsSearch.getColumn(0,"returnVal");
	if(returnVal == "1"){
		this.smfAlert("접수취소가 완료되었습니다.", function(){
			var params = {
				enfcYr :  this.dsOneUserInfo.getColumn(0,"enfcYr"),
				enfcTme : this.dsOneUserInfo.getColumn(0,"enfcTme"),
				sqeScCd : this.dsOneUserInfo.getColumn(0,"sqeScCd"),
				cddcCd : this.dsOneUserInfo.getColumn(0,"cddcCd"),
				rcptNo : this.dsOneUserInfo.getColumn(0,"rcptNo"),
				subTitle : this.imgSubTitle.text,
				menuId : "4000"
				};
			
			this.smfSetWorkPage(url, params);
		})
	}else{
		this.smfAlert("접수취소가 완료되지 않았습니다. ")
	}
	

}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

/**
 * @description 접수취소
*/
this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var current = this.smfTodayTime().substr(0,11)
	

	var itnRcptRtrcnBgngYmd = this.dsCancelChk.getColumn(0, "itnRcptRtrcnBgngYmd")
	var itnRcptRtrcnEndYmd 	= this.dsCancelChk.getColumn(0, "itnRcptRtrcnEndYmd")
	var itnRcptRtrcnBgngTm 	= this.smfRtrim(this.dsCancelChk.getColumn(0, "itnRcptRtrcnBgngTm"))
	var itnRcptRtrcnEndTm 	= this.smfRtrim(this.dsCancelChk.getColumn(0, "itnRcptRtrcnEndTm"))
	var beginYmdVal = itnRcptRtrcnBgngYmd.substr(0, 4) + "." + itnRcptRtrcnBgngYmd.substr(4, 2) + "." + itnRcptRtrcnBgngYmd.substr(6, 2) + " " + this.smfRtrim(itnRcptRtrcnBgngTm)+ "시"
	var endYmdVal =  itnRcptRtrcnEndYmd.substr(0, 4) + "." + itnRcptRtrcnEndYmd.substr(4, 2) + "." + itnRcptRtrcnEndYmd.substr(6, 2) + " " +this.smfRtrim(itnRcptRtrcnEndTm) +"시"

	var beginYmdTm = itnRcptRtrcnBgngYmd + itnRcptRtrcnBgngTm 
	var endYmdTm = itnRcptRtrcnEndYmd + itnRcptRtrcnEndTm

	
	if(beginYmdTm.length == "10" && endYmdTm.length == "10"){
		if(beginYmdTm <= current && endYmdTm > current){
			this.smfConfirm("원서접수 취소시 처음단계부터 재작성 해주셔야 합니다.\n\n원서접수를 취소하시겠습니까?",function(confirmParams){
				if(confirmParams.confirmResult){
				
					this.dsOneUserInfo.setColumn(0, "photoFileCn", "");
					/// 서비스 객체 생성 
					this.smfDeleteService("deleteApplpInfo")
						// 사용자에게 confirm메시지를 표시할지 여부
						.showConfirm(false) 
						// 데이터 존재 필수
						.requireExistsData(this.dsOneUserInfo) 
						// 실행
						.run()
						// 콜백
						.callback(function(callbackParams){
							if(callbackParams.errors) return;
							//this.fnCancelCallback();
						});
				}else{
					return false;
				}
			})
		}else{
			this.smfAlert("현재는 [접수취소] 기간이 아닙니다.\n\n접수취소기간:("+ beginYmdVal +" ~ " + endYmdVal+")");
			return;
		}
	}else{
		this.smfAlert("접수취소기간이 잘못되어있습니다.\n\n시도담당자에게 문의 바랍니다!!!");
	    return;
	}
};
/**
 * @description 원서출력
*/

this.btnPrint_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	//서브타이틀
	var subTitle = this.dsOneUserInfo.getColumn(0,"enfcYr") + "년도 " + this.dsOneUserInfo.getColumn(0,"enfcTme") + "회차 " + this.dsOneUserInfo.getColumn(0,"sqeScCdNm")
	var rcptNo =  this.dsOneUserInfo.getColumn(0,"rcptNo");
	params = {subTitle : subTitle
				,enfcYr : this.dsOneUserInfo.getColumn(0,"enfcYr")
				,enfcTme : this.dsOneUserInfo.getColumn(0,"enfcTme")
				,cddcCd : this.dsOneUserInfo.getColumn(0,"cddcCd")
				,sqeScCd : this.dsOneUserInfo.getColumn(0,"sqeScCd")
				,rcptNo : rcptNo
				}
	this.smfSetWorkPage("pa_sqa_oar_oi::sqa_oaroi00_m01.xfdl", params);
};
]]></Script>
