<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frm01" width="1090" height="470" titletext="작성방법(고사장선택)" onload="frm01_onload" nHeight="754">
    <Layouts>
      <Layout height="470" width="1090" screenid="ScreenDeskTop">
        <ImageViewer id="img00" taborder="0" text="고사장선택" left="0" top="18" width="150" height="35" cssclass="img_WF_SubTit02" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00_02_02" taborder="2" text="※ 고사장 별 수용인원이 도달할 때까지 응시자가 신청가능" top="402" width="320" height="30" cssclass="edi_WF_Input" initvalueid="ivStcAccessibilityOn" right="0"/>
        <Grid id="grd00" taborder="3" left="0" top="166" height="231" right="0" binddataset="ds_grd" autofittype="col" selecttype="row" initvalueid="ivGrdAccessibilityOn" readonly="true">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="338"/>
                <Column size="269"/>
                <Column size="157"/>
                <Column size="145"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="고사장"/>
                <Cell col="1" text="수용가능인원/전체인원"/>
                <Cell col="2" text="신청인원"/>
                <Cell col="3" text="신청"/>
              </Band>
              <Band id="body">
                <Cell text="bind:고사장"/>
                <Cell col="1" text="bind:수용가능인원"/>
                <Cell col="2" text="bind:신청인원"/>
                <Cell col="3" text="bind:신청" displaytype="buttoncontrol" edittype="button"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="Static99_00_00_00_00_01_00_00_00_01" taborder="4" left="0" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_00" taborder="5" left="0" top="46" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta99_00_00_00_00_01_00_00" taborder="6" left="0" top="146" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Div id="divSearch" taborder="1" left="0" top="75" height="70" right="0" initvalueid="ivDivAccessibilityOn" text="" accessibilitylabel="조회영역" cssclass="div_WF_Search">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" text="시행년도" left="0" top="20" width="81" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtEnfcYr" taborder="1" left="81" top="20" width="80" height="30" text="2023" initvalueid="ivEdtReadOnly" accessibilitylabel="시행년도" readonly="true" value="2023"/>
              <Static id="sta00_00" taborder="2" text="시험회차" left="161" top="20" width="81" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtEnfcTme" taborder="3" left="242" top="20" width="50" height="30" text="1" initvalueid="ivEdtReadOnly" accessibilitylabel="시행회차" readonly="true" value="1"/>
              <Button id="btnSearch" taborder="4" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="40" initvalueid="ivBtnAccessibilityButton"/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="ds_grd">
        <ColumnInfo>
          <Column id="고사장" type="STRING" size="256"/>
          <Column id="수용가능인원" type="STRING" size="256"/>
          <Column id="신청인원" type="STRING" size="256"/>
          <Column id="신청" type="STRING" size="256"/>
