      <Layout height="1023" width="1090" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <ImageViewer id="img00_00_01_00_00" taborder="1" text="온라인 원서작성 방법 안내" left="20" top="20" width="351" height="40" cssclass="img_WF_SubTit03" accessibilitylabel="원서작성방법안내" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="Static99_00_00_00_00_01_00_00_00" taborder="2" left="20" top="60" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_01" taborder="3" left="20" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_01_00_00_00" taborder="4" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_01_00_00_00_00" taborder="5" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Div id="divContents" taborder="6" left="20" top="140" right="20" text="" async="false" bottom="130" enable="true" initvalueid="ivDivAccessibilityOff"/>
        <Div id="div00" taborder="7" text="div00" left="20" top="70" height="70" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Button id="btn01" taborder="0" text="응시자정보" left="0" top="0" width="22.86%" height="70" cssclass="btn_WF_Step01" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="응시자정보" enable="false"/>
              <Static id="sta00_01_00_00_00" taborder="1" left="btn01:14" top="10" width="18" height="51" cssclass="sta_WF_NextStep02" initvalueid="ivStcAccessibilityOn" text="" accessibilitylabel="다음"/>
              <Button id="btn02" taborder="2" text="학력과목정보" top="0" width="21.71%" height="70" cssclass="btn_WF_Step02" left="sta00_01_00_00_00:13.971000000000004" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="학력과목정보" enable="false" enableevent="true"/>
              <Static id="sta00_01_00_00_00_00" taborder="3" left="btn02:14" top="10" width="18" height="51" cssclass="sta_WF_NextStep02" initvalueid="ivStcAccessibilityOn" accessibilitylabel="다음"/>
              <Button id="btn03" taborder="4" text="고사장선택" top="0" height="70" cssclass="btn_WF_Step03" width="21.81%" left="sta00_01_00_00_00_00:13.015999999999963" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="고사장선택" enableevent="true" enable="false"/>
              <Static id="sta00_01_00_00_00_00_00" taborder="5" left="btn03:14" top="11" width="18" height="51" cssclass="sta_WF_NextStep02" initvalueid="ivStcAccessibilityOn" accessibilitylabel="다음"/>
              <Button id="btn04" taborder="6" text="제출(미제출)" top="0" height="70" cssclass="btn_WF_Step04" left="sta00_01_00_00_00_00_00:14" initvalueid="ivBtnAccessibilityButton" right="0" accessibilitylabel="접수완료" enableevent="true" enable="false"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnClose" taborder="8" text="닫기" width="119" left="486" initvalueid="ivBtnAccessibilityButton" onclick="btnClose_onclick" cssclass="btn_WF_Action" top="divContents:53" height="42"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_01_00_00" taborder="9" left="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff" top="btnClose:15" height="20"/>
