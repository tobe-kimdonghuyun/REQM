    <Objects/>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 검정고시서비스 원서작성방법안내
*  @FileName 	sqa_oaror02_p00.xfdl 
*  @Creator 	박가혜
*  @CreateDate 	2022.08.18
*  @Desction    원서작성방법 안내 팝업 (응시자정보, 학력과목정보, 고사장선택, 접수완료)
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.08.18          박가혜                 최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/




include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.fv_param;	// 파라메터 세팅


/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.popUpFrm_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitPopup(obj)
	// 파라메터 세팅
	this.fv_param = this.smfGetPopupParams();

	if(this.fv_param.pageId == "sqa_oaror02_m00"){//응시자정보 입력페이지

		this.divContents.set_url("pa_sqa_oar_or::sqa_oaror02_p01.xfdl")
		this.div00.form.btn01.set_cssclass("btn_WF_Step01S")
		this.div00.form.btn01.set_enable(true)
		this.smfResetScroll(this.divContents.form.divMain.form)
		//this.smfResetScroll(this.divContents.form)
		
	}

	if(this.fv_param.pageId == "sqa_oaror03_m00"){//학력과목정보 입력페이지
		this.divContents.set_url("pa_sqa_oar_or::sqa_oaror02_p02.xfdl")
		this.div00.form.btn02.set_cssclass("btn_WF_Step02S")
		this.div00.form.btn02.set_enable(true)
		this.smfResetScroll(this.divContents.form.divDetail.form)
		this.smfResetScroll(this.divContents.form.divSbjt.form)
		this.smfResetScroll(this.divContents.form.divFile)
		//this.smfResetScroll(this.divContents.form.div03.form)
		//this.smfResetScroll(this.divContents.form)
		
	}

	if(this.fv_param.pageId == "sqa_oaror04_m00"){//고사장선택 입력페이지
		this.divContents.set_url("pa_sqa_oar_or::sqa_oaror02_p03.xfdl")
		this.div00.form.btn03.set_cssclass("btn_WF_Step03S")
		this.div00.form.btn03.set_enable(true)

	}

	if(this.fv_param.pageId == "sqa_oaror05_m00"){//접수완료 페이지
		this.divContents.set_url("pa_sqa_oar_or::sqa_oaror02_p04.xfdl")
		this.div00.form.btn04.set_cssclass("btn_WF_Step04S")
		this.div00.form.btn04.set_enable(true)
		this.smfResetScroll(this.divContents.form.divMain.form)
		this.smfResetScroll(this.divContents.form.divDetail.form)
		
		
	}
	
	this.smfResetScroll(this.divContents.form)
	
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/



/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
//닫기 버튼 클릭
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//닫기 버튼을 이용한 팝업종료의 파라미터는 false를 전달
	this.close(false);
};
]]></Script>
  </Form>
</FDL>
