    <Objects>
      <Dataset id="dsService" useclientlayout="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">select</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsSbmsnInfo=dsSbmsnInfo</Col>
            <Col id="url">sqa_oar_or06_001.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch">
        <ColumnInfo>
          <Column id="enfcYr" type="STRING" size="256"/>
          <Column id="enfcTme" type="STRING" size="256"/>
          <Column id="sqeScCd" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="rcptNo" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsSbmsnInfo" useclientlayout="true">
        <ColumnInfo>
          <Column id="kornFlnm" type="STRING" size="256"/>
          <Column id="mblTelno" type="STRING" size="256"/>
          <Column id="enfcYr" type="STRING" size="256"/>
          <Column id="enfcTme" type="STRING" size="256"/>
          <Column id="sqeScCd" type="STRING" size="256"/>
          <Column id="sqeScNm" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="cddcNm" type="STRING" size="256"/>
          <Column id="rcptNo" type="STRING" size="256"/>
          <Column id="sbmsnDt" type="STRING" size="256"/>
          <Column id="sbmsnYn" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 검정고시서비스 원서접수-접수취소완료
*  @FileName 	sqa_oaror06_m00.xfdl 
*  @Creator 	진승환
*  @CreateDate 	2024.10.24
*  @Desction    접수취소완료
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2024.10.24           진승환                 최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.fv_param;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 this.sqa_oaror07_m00_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);

	// 파라메터 세팅
	this.fv_param = this.smfGetFormParams();
	
	this.fnSetInitParam(this.smfGetFormParams());
	
	//로그인이나 세션에서 넘어온 값
	this.dsSearch.setColumn(0, "enfcYr", 	this.fv_enfcYr);
	this.dsSearch.setColumn(0, "enfcTme", 	this.fv_enfcTme);
	this.dsSearch.setColumn(0, "sqeScCd", 	this.fv_sqeScCd);
	this.dsSearch.setColumn(0, "cddcCd", 	this.fv_cddcCd);
	this.dsSearch.setColumn(0, "rcptNo", 	this.fv_rcptNo);
	
	this.fnInit();
	
	//this.smfResetScroll(this.divNotice.form) //div사이즈 최적화
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnInit = function()
{
	// 접수취소는 이미 데이터가 삭제된 상태여서 조회 해도 데이터 없음
	
// 	this.smfSearchService("select")
// 		// 실행
// 		.run()
// 
// 		// 콜백
// 		.callback(function(callbackParams){
// 			if(callbackParams.errors) return;
// 			this.fnSetData();
// 		});		
	this.fnSetData();
}

//기초데이터 셋팅
this.fnSetData = function(){
	
	var enfcYr	= this.fv_enfcYr;
	var enfcTme	= this.fv_enfcTme;
	var sqeScCd	= this.fv_sqeScCd;
	var sqeScNm = "";
	
	switch(sqeScCd){
		case "1" : sqeScNm = "초등학교 졸업학력 검정고시"; 	break;
		case "2" : sqeScNm = "중학교 졸업학력 검정고시";		break;
		case "3" : sqeScNm = "고등학교 졸업학력 검정고시";	break;
		default : sqeScNm = "";	break;
	}
	
	var sqeScNmTxt	= enfcYr + "년 " + enfcTme + "회차 " + sqeScNm;
	
	this.divNotice.form.staNm.set_text(this.smfGetKornFlnm());
	this.divNotice.form.staSqeScNm.set_text(sqeScNmTxt);
	this.divNotice.form.staCddcNm.set_text(this.smfGetCddcName());
	this.divNotice.form.staRcptNo.set_text(this.fv_rcptNo);
	this.divNotice.form.staSbmsnDt.set_text(this.smfTodayTime().dateFormat("yyyy-MM-dd hh:mm:ss"));
}

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 페이지이동
 */
this.fnGoPage = function(url, menuId){

	var params = {
				enfcYr :  this.dsSearch.getColumn(0,"enfcYr"),
				enfcTme : this.dsSearch.getColumn(0,"enfcTme"),
				sqeScCd : this.dsSearch.getColumn(0,"sqeScCd"),
				cddcCd : this.dsSearch.getColumn(0,"cddcCd"),
				rcptNo : this.dsSearch.getColumn(0,"rcptNo"),
				sbmsnYn : this.fv_param.sbmsnYn,
				menuId : menuId
				};
			
	this.smfSetWorkPage(url, params);
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.btnMain_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSetWorkPage("frame::sqa/frameSubMain.xfdl");
};

this.btnMove_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 원서접수화면으로 이동
	this.fnGoPage("pa_sqa_cmm_cm::sqa_cmmcm04_m00.xfdl", "4000");
};
]]></Script>
  </Form>
</FDL>
