    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 검정고시서비스 개인정보처리동의
*  @FileName 	sqa_oaror01_m00.xfdl 
*  @Creator 	박가혜
*  @CreateDate 	2022.06.14
*  @Desction    응시자정보
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.08.16			박가혜                 최초 생성 
*  2024.10.24			진승환					범정부 UI/UX 가이드라인 적용 (안내문구 추가)
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.fv_param;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frm01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);
	this.fv_param = this.smfGetFormParams();
	this.dsSearch.addRow();
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd == -1) return;
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 동의 체크박스 전체 선택/해제
*/
this.chkInfo_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	if(this.divText.form.chkInfo.value == 1){
	
// 		this.divText.form.chkInfo0.set_value(1)
// 		this.divText.form.chkInfo1.set_value(1)
// 		this.divText.form.chkInfo2.set_value(1)
// 		this.divText.form.chkInfo3.set_value(1)
// 		this.divText.form.chkInfo4.set_value(1)
// 		this.divText.form.chkInfo5.set_value(1)

		this.divText.form.divInfo0.form.rdoInfo0.set_value(2);
		this.divText.form.divInfo1.form.rdoInfo1.set_value(2);
		this.divText.form.divInfo2.form.rdoInfo2.set_value(2);
		this.divText.form.divInfo3.form.rdoInfo3.set_value(2);
		this.divText.form.divInfo4.form.rdoInfo4.set_value(2);
		this.divText.form.divInfo5.form.rdoInfo5.set_value(2);

		
	}else if(this.divText.form.chkInfo.value == 0){
	
// 		this.divText.form.chkInfo0.set_value(0)
// 		this.divText.form.chkInfo1.set_value(0)
// 		this.divText.form.chkInfo2.set_value(0)
// 		this.divText.form.chkInfo3.set_value(0)
// 		this.divText.form.chkInfo4.set_value(0)
// 		this.divText.form.chkInfo5.set_value(0)

		this.divText.form.divInfo0.form.rdoInfo0.set_value(1);
		this.divText.form.divInfo1.form.rdoInfo1.set_value(1);
		this.divText.form.divInfo2.form.rdoInfo2.set_value(1);
		this.divText.form.divInfo3.form.rdoInfo3.set_value(1);
		this.divText.form.divInfo4.form.rdoInfo4.set_value(1);
		this.divText.form.divInfo5.form.rdoInfo5.set_value(1);
	}
};
/**
 * @description 다음 버튼 클릭 시
*/
this.btnNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//if(this.divText.form.chkInfo0.value != 1){
	//	this.divText.form.chkInfo0.setFocus();
	if(this.divText.form.divInfo0.form.rdoInfo0.value != 2){
		this.divText.form.divInfo0.form.rdoInfo0.setFocus();
		this.smfAlert("허위사실 기재 안내에 동의가 필요합니다.")
		return false;
	}
	if(this.divText.form.divInfo1.form.rdoInfo1.value != 2){
		this.divText.form.divInfo1.form.rdoInfo1.setFocus();
		this.smfAlert("개인정보수집 항목에 동의가 필요합니다.")
		return false;
	}
	if(this.divText.form.divInfo2.form.rdoInfo2.value != 2){
		this.divText.form.divInfo2.form.rdoInfo2.setFocus();
		this.smfAlert("민감정보수집 항목에 동의가 필요합니다.")
		return false;
	}
	if(this.divText.form.divInfo3.form.rdoInfo3.value != 2){
		this.divText.form.divInfo3.form.rdoInfo3.setFocus();
		this.smfAlert("개인정보 제 3자 제공 항목에 동의가 필요합니다.")
		return false;
	}
	if(this.divText.form.divInfo4.form.rdoInfo4.value != 2){
		this.divText.form.divInfo4.form.rdoInfo4.setFocus();
		this.smfAlert("시스템 저장 항목에 동의가 필요합니다.")
		return false;
	}
	if(this.divText.form.divInfo5.form.rdoInfo5.value != 2){
		this.divText.form.divInfo5.form.rdoInfo5.setFocus();
		this.smfAlert("행정정보공동이용 항목에 동의가 필요합니다.")
		return false;
	}

	var params = {
				enfcYr : this.fv_param.enfcYr,
				enfcTme : this.fv_param.enfcTme,
				sqeScCd : this.fv_param.sqeScCd,
				cddcCd : this.smfGetCddcCode(),
				rcptNo : this.fv_param.rcptNo,
				menuId : "4000",
				sbmsnYn : this.fv_param.sbmsnYn			
				};
	
	if(this.smfGetTrprRrno() == null || this.smfGetTrprRrno().length == 0){ //로그인안되어있을대
	
		this.smfSetWorkPage("pa_sqa_cmm_cm::sqa_cmmcm03_m00.xfdl", params); //로그인화면으로 이동
	}else{
			
		this.fnSetInitParam(params)
		this.fnCheckOnlineAccept();
		
	}
}

this.rdoInfo_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	var rdoInfo0	= this.divText.form.divInfo0.form.rdoInfo0.value;
	var rdoInfo1	= this.divText.form.divInfo1.form.rdoInfo1.value;
	var rdoInfo2	= this.divText.form.divInfo2.form.rdoInfo2.value;
	var rdoInfo3	= this.divText.form.divInfo3.form.rdoInfo3.value;
	var rdoInfo4	= this.divText.form.divInfo4.form.rdoInfo4.value;
	var rdoInfo5	= this.divText.form.divInfo5.form.rdoInfo5.value;
	
	if(rdoInfo0 == 2 && rdoInfo1 == 2 && rdoInfo2 == 2 && rdoInfo3 == 2 && rdoInfo4 == 2 && rdoInfo5 == 2){
		this.divText.form.chkInfo.set_value(1);
	}else{
		this.divText.form.chkInfo.set_value(0);
	}
};
]]></Script>
  </Form>
</FDL>
