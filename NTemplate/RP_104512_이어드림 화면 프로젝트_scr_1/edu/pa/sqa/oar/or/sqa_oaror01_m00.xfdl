              <Div id="div00_00_00_01" taborder="5" left="30" height="151" cssclass="div_WF_InfoBOX" top="divInfo3:10" text="" initvalueid="ivDivAccessibilityOff" width="1138">
                <Layouts>
                  <Layout>
                    <Static id="sta01" taborder="0" text="[필수] 시스템 저장동의" left="30" top="31" width="200" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta00_00_01_01" taborder="1" left="30" top="71" height="44" text="수집된 개인(민감)정보는 관할교육청의 NEIS에 저장됩니다.&#13;&#10;본 안내에 따른 개인정보 저장에 대하여 거부 하실 수 있으며, 본 개인(민감)정보 저장을 거부하는 경우 원서접수가 이루어지지 않습니다." wordWrap="char" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" right="30" verticalAlign="top"/>
                  </Layout>
                </Layouts>
              </Div>
              <Div id="divInfo4" taborder="12" text="div_WF_noticeBox" left="30" top="div00_00_00_01:10" height="40" cssclass="div_WF_InfoBOX01" visible="true" right="30">
                <Layouts>
                  <Layout>
                    <Static id="sta00" taborder="0" text="상기한 내용을 확인하였으며, 시스템 저장에 동의합니다." left="30" top="4" width="500" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Black14"/>
                    <Radio id="rdoInfo4" taborder="1" top="5" height="30" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" rowcount="-1" value="01" text="예" index="0" readonly="false" initvalueid="ivRdoEssential" cssclass="essential" accessibilitylabel="시스템저장동의" enable="true" right="15" width="264" onitemchanged="rdoInfo_onitemchanged">
