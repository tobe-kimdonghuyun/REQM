                    <Static id="sta00" taborder="0" text="상기한 내용을 확인하였으며, 행정정보공동이용에 동의합니다." left="30" top="4" width="500" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Black14"/>
