<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frm01" width="1200" height="2850" titletext="개인정보처리동의" onload="frm01_onload">
    <Layouts>
      <Layout height="2850" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="65" height="54" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="원서접수 허위사실 기재에 관한 안내 및 서약서" left="0" top="0" height="54" cssclass="img_WF_SubTit01" initvalueid="ivTitleAccessibilityOn" width="680"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staSubText3" taborder="1" left="0" top="134" height="26" cssclass="sta_WF_Black14" text="※ 아래의 내용을 읽으시고 동의하셔야 접수가 가능합니다." initvalueid="ivStcAccessibilityOn" fittocontents="none" width="600"/>
        <Static id="staSubText3_00" taborder="2" left="0" top="160" height="26" cssclass="sta_WF_Black14" text="※ 제출 후 수정하시는 경우에는 교육청담당자가 제출처리하기 전까지만 수정이 가능합니다." initvalueid="ivStcAccessibilityOn" fittocontents="none" width="800"/>
        <Div id="divText" taborder="3" left="0" height="2345" cssclass="div_WF_InfoBOX" top="205" text="" initvalueid="ivDivAccessibilityOff" width="1200">
          <Layouts>
            <Layout>
              <Static id="Static99_00_00_00_00_01_01" taborder="0" left="53" top="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="926" initvalueid="ivStcAccessibilityOff"/>
              <Div id="div00" taborder="1" left="30" height="89" cssclass="div_WF_InfoBOX" top="30" text="" right="30" initvalueid="ivDivAccessibilityOff">
                <Layouts>
                  <Layout>
                    <Static id="sta00_00_01_01" taborder="0" left="30" top="18" height="51" text="본 시스템으로 제출하는 응시원서 기재사항은 사실과 틀림없으며, 학력사항 등 원서내용이 허위로 판명될 경우 형사적인 책임 및 합격취소 등 어떠한 불이익도 감수하겠습니다. 또한 시험과 관련한 사실관계 확인을 위하여 관계 기관으로부터 관련정보를 송수신하는 것에 동의합니다. " wordWrap="char" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" right="30"/>
                    <Static id="sta99_00_00_00_00_01_01" taborder="1" left="0" top="0" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="0" text="30" initvalueid="ivStcAccessibilityOff"/>
                    <Static id="Static99_00_00_00_00_01_00_00_01_00" taborder="2" left="0" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
                    <Static id="Static99_00_00_00_00_01_00_00_01_00_00" taborder="3" left="0" top="66" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" height="20"/>
                  </Layout>
                </Layouts>
              </Div>
              <Div id="divInfo0" taborder="8" text="div_WF_noticeBox" left="30" top="div00:10" height="40" cssclass="div_WF_InfoBOX01" visible="true" right="30">
                <Layouts>
                  <Layout>
                    <Static id="sta00" taborder="0" text="위 서약에 동의합니다." left="30" top="4" width="302" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Black14"/>
                    <Radio id="rdoInfo0" taborder="1" top="5" height="30" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" rowcount="-1" value="01" text="예" index="0" readonly="false" initvalueid="ivRdoEssential" cssclass="essential" accessibilitylabel="서약동의" enable="true" right="15" width="264" onitemchanged="rdoInfo_onitemchanged">
                      <Dataset id="innerdataset">
                        <ColumnInfo>
                          <Column id="codecolumn" size="256"/>
                          <Column id="datacolumn" size="256"/>
                        </ColumnInfo>
                        <Rows>
                          <Row>
                            <Col id="datacolumn">동의하지 않음</Col>
                            <Col id="codecolumn">1</Col>
                          </Row>
                          <Row>
                            <Col id="datacolumn">동의함</Col>
                            <Col id="codecolumn">2</Col>
                          </Row>
                        </Rows>
                      </Dataset>
                    </Radio>
                  </Layout>
                </Layouts>
              </Div>
              <Div id="div00_00" taborder="2" left="30" height="454" cssclass="div_WF_InfoBOX" top="divInfo0:10" text="" initvalueid="ivDivAccessibilityOff" width="1138">
                <Layouts>
                  <Layout>
                    <Static id="sta01" taborder="0" text="[필수] 개인정보 수집동의" left="30" top="18" width="200" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta00_00_01_01" taborder="1" left="30" top="58" height="190" text="가. 개인정보의 수집 및 이용목적&#13;&#10;  ㆍ검정고시 응시자에 대한 응시자격 및 결격사유 등을 확인하고, 시험의 합격자격을 확인하기 위함&#13;&#10;나. 수집하려는 개인정보의 항목&#13;&#10;  ㆍ검정고시 응시자 수집정보: (필수) 성명, 성별, 주민등록번호(외국인등록번호), 주소, 휴대전화, 사진, 이메일, 응시자구분, 장애구분, 재소구분, 학력구분, 졸업/재적/합격일자, 학교명, 과목별응시정보, 기합격과목정보, 최종학력증명서첨부&#13;&#10;다. 개인정보의 보유 및 이용기간 : 5년&#13;&#10;라. 동의를 거부할 권리 등 동의 거부에 따른 안내&#13;&#10;  ㆍ응시자는 본 안내에 따른 개인정보수집에 대하여 거부를 하실 수 있는 권리가 있습니다. 본 개인정보수집의 필수항목에 대하여 수집을 거부하는 경우 원서접수가 이루어지지 않습니다." wordWrap="char" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" right="30" verticalAlign="top"/>
                    <Static id="sta99_00_00_00_00_01_01" taborder="2" left="0" top="0" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="0" text="30" initvalueid="ivStcAccessibilityOff"/>
                    <Static id="Static99_00_00_00_00_01_00_00_01_00" taborder="3" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" height="20"/>
                    <Static id="Static99_00_00_00_00_01_00_00_01_00_01" taborder="4" left="30" top="38" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="1106"/>
                    <Static id="Static99_00_00_00_00_01_00_00_01_00_00" taborder="5" left="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" bottom="0" height="20"/>
                    <Static id="sta01_00" taborder="6" text="[필수] 고유식별정보 수집 안내" left="30" top="265" width="200" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta00_00_01_01_00" taborder="7" left="30" top="304" height="127" text="가. 고유식별정보 수집 항목&#13;&#10;  ㆍ주민등록번호, 외국인번호&#13;&#10;나. 고유식별정보 수집 및 목적&#13;&#10;  ㆍ검정고시 온라인 원서접수&#13;&#10;다. 수집 근거&#13;&#10;  ㆍ초중등교육법 시행령 제106조의3에 근거하여 검정고시 원서접수의 목적으로 수집 및 이용합니다." wordWrap="char" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" right="30" verticalAlign="top" onclick="divText_div00_00_00_sta00_00_01_01_onclick"/>
                    <Static id="Static99_00_00_00_00_01_00_00_01_00_01_00" taborder="8" left="30" top="247" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="1106"/>
                    <Static id="Static99_00_00_00_00_01_00_00_01_00_01_00_00" taborder="9" left="30" top="286" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="1106"/>
                  </Layout>
                </Layouts>
              </Div>
              <Div id="divInfo1" taborder="9" text="div_WF_noticeBox" left="30" top="div00_00:10" height="40" cssclass="div_WF_InfoBOX01" visible="true" right="30">
                <Layouts>
                  <Layout>
                    <Static id="sta00" taborder="0" text="상기한 내용을 확인하였으며, 개인정보수집에 동의합니다." left="30" top="4" width="372" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Black14"/>
                    <Radio id="rdoInfo1" taborder="1" top="5" height="30" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" rowcount="-1" value="01" text="예" index="0" readonly="false" initvalueid="ivRdoEssential" cssclass="essential" accessibilitylabel="개인정보수집동의" enable="true" right="15" width="264" onitemchanged="rdoInfo_onitemchanged">
                      <Dataset id="innerdataset">
                        <ColumnInfo>
                          <Column id="codecolumn" size="256"/>
                          <Column id="datacolumn" size="256"/>
                        </ColumnInfo>
                        <Rows>
                          <Row>
                            <Col id="datacolumn">동의하지 않음</Col>
                            <Col id="codecolumn">1</Col>
                          </Row>
                          <Row>
                            <Col id="datacolumn">동의함</Col>
                            <Col id="codecolumn">2</Col>
                          </Row>
                        </Rows>
                      </Dataset>
                    </Radio>
                  </Layout>
                </Layouts>
              </Div>
              <Div id="div00_00_00" taborder="3" left="30" height="242" cssclass="div_WF_InfoBOX" top="divInfo1:10" text="" initvalueid="ivDivAccessibilityOff" width="1138">
                <Layouts>
                  <Layout>
                    <Static id="sta01" taborder="0" text="[필수] 민감정보 수집동의" left="30" top="31" width="200" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta00_00_01_01" taborder="1" left="30" top="71" height="147" text="가. 민감정보의 수집 및 이용목적&#13;&#10;  ㆍ검정고시 응시자에 대한 응시자격 및 결격사유 등을 확인하고, 장애인 편의 지원 업무 등 을 처리하기 위함&#13;&#10;나. 수집하려는 민감정보의 항목 : 장애구분, 재소구분&#13;&#10;다. 민감정보의 보유 및 이용기간 : 5년&#13;&#10;라. 동의를 거부할 권리 등 동의 거부에 따른 안내&#13;&#10;  ㆍ응시자는 본 안내에 따른 민감정보수집에 대하여 거부를 하실 수 있는 권리가 있습니다. 본 개인정보수집의 필수항목에 대하여 수집을 거부하는 경우 원서접수가 이루어지지 않습니다." wordWrap="char" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" right="30" verticalAlign="top" onclick="divText_div00_00_00_sta00_00_01_01_onclick"/>
                  </Layout>
                </Layouts>
              </Div>
              <Div id="divInfo2" taborder="10" text="div_WF_noticeBox" left="30" top="div00_00_00:10" height="40" cssclass="div_WF_InfoBOX01" visible="true" right="30">
                <Layouts>
                  <Layout>
                    <Static id="sta00" taborder="0" text="상기한 내용을 확인하였으며, 민감정보수집에 동의합니다." left="30" top="4" width="372" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Black14"/>
                    <Radio id="rdoInfo2" taborder="1" top="5" height="30" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" rowcount="-1" value="01" text="예" index="0" readonly="false" initvalueid="ivRdoEssential" cssclass="essential" accessibilitylabel="민감정보수집동의" enable="true" right="15" width="264" onitemchanged="rdoInfo_onitemchanged">
                      <Dataset id="innerdataset">
                        <ColumnInfo>
                          <Column id="codecolumn" size="256"/>
                          <Column id="datacolumn" size="256"/>
                        </ColumnInfo>
                        <Rows>
                          <Row>
                            <Col id="datacolumn">동의하지 않음</Col>
                            <Col id="codecolumn">1</Col>
                          </Row>
                          <Row>
                            <Col id="datacolumn">동의함</Col>
                            <Col id="codecolumn">2</Col>
                          </Row>
                        </Rows>
                      </Dataset>
                    </Radio>
                  </Layout>
                </Layouts>
              </Div>
              <Div id="div00_00_00_00" taborder="4" left="30" height="752" cssclass="div_WF_InfoBOX" top="divInfo2:10" text="" initvalueid="ivDivAccessibilityOff" width="1138">
                <Layouts>
                  <Layout>
                    <Static id="sta01" taborder="0" text="[필수] 개인정보 제3자 제공동의" left="30" top="31" width="210" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
                    <Static id="sta00_00_01_01_00" taborder="1" left="30" top="61" height="24" text="가. 제3가 제공내역" wordWrap="char" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" right="30" verticalAlign="top" onclick="divText_div00_00_00_00_sta00_00_01_01_onclick"/>
                    <Grid id="grd00" taborder="2" left="30" top="sta00_00_01_01_00:6" height="571" binddataset="dsInfo" cssclass="grd_policy_detail" right="30" autofittype="col" autosizingtype="row" initvalueid="ivGrdAccessibilityOn">
                      <Formats>
                        <Format id="default">
                          <Columns>
                            <Column size="174"/>
                            <Column size="400"/>
                            <Column size="180"/>
                            <Column size="200"/>
                          </Columns>
                          <Rows>
                            <Row size="50" band="head"/>
                            <Row size="45"/>
                          </Rows>
                          <Band id="head">
                            <Cell text="제공받는 자"/>
                            <Cell col="1" text="제공 목적"/>
                            <Cell col="2" text="제공 항목"/>
                            <Cell col="3" text="보유ㆍ이용기간"/>
                          </Band>
                          <Band id="body">
                            <Cell text="bind:psvnTrpr" autosizerow="limitmin" textAlign="center" wordWrap="char"/>
                            <Cell col="1" text="bind:pvsnPur" wordWrap="char" autosizerow="limitmin" textAlign="center"/>
                            <Cell col="2" text="bind:pvsnItm" wordWrap="char" autosizerow="limitmin" textAlign="center"/>
                            <Cell col="3" text="bind:utilzPrd" autosizerow="limitmin" textAlign="center" wordWrap="char"/>
                          </Band>
                        </Format>
                      </Formats>
                    </Grid>
                    <Static id="sta00_00_01_01" taborder="3" left="30" top="grd00:5" height="64" text="나. 동의를 거부할 권리 등 동의 거부에 따른 안내&#13;&#10;  ㆍ응시자는 본 안내에 따른 제3자 제공에 대하여 거부를 하실 수 있는 권리가 있습니다. 본 개인정보수집의 필수항목에 대하여 수집을 거부하는 경우 원서접수가 이루어지지 않습니다." wordWrap="char" cssclass="sta_WF_Black14" initvalueid="ivStcAccessibilityOn" right="30" verticalAlign="top" onclick="divText_div00_00_00_00_sta00_00_01_01_onclick"/>
                  </Layout>
                </Layouts>
              </Div>
              <Div id="divInfo3" taborder="11" text="div_WF_noticeBox" left="30" top="div00_00_00_00:10" height="40" cssclass="div_WF_InfoBOX01" visible="true" right="30">
                <Layouts>
                  <Layout>
                    <Static id="sta00" taborder="0" text="상기한 내용을 확인하였으며, 개인정보 제3자 제공에 동의합니다." left="30" top="4" width="500" height="30" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Black14"/>
                    <Radio id="rdoInfo3" taborder="1" top="5" height="30" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" rowcount="-1" value="01" text="예" index="0" readonly="false" initvalueid="ivRdoEssential" cssclass="essential" accessibilitylabel="개인정보 제3자 제공동의" enable="true" right="15" width="264" onitemchanged="rdoInfo_onitemchanged">
