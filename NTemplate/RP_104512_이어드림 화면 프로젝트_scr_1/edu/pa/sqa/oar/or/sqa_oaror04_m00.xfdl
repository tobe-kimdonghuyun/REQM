    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 검정고시서비스 원서접수-고사장선택
*  @FileName 	sqa_oaror04_m00.xfdl 
*  @Creator 	박가혜
*  @CreateDate 	2022.06.28
*  @Desction    고사장선택
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.06.128          박가혜                 최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/




include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.fv_param;


/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frm01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);

	this.fv_param = this.smfGetFormParams();
	this.fnSetInitParam(this.smfGetFormParams());
	
	//제출여부에 따라 상단 스탭박스 이동가능 여부 설정(제출한적 있는경우 자유이동가능, 첫 작성인 경우 이동 못함)
	if(this.fv_param.sbmsnYn == "N") {
		this.div00.form.btnOarOr04.removeEventHandler("onclick", this.fnStep_onclick, this)
		this.div00.form.btnOarOr02.set_enable(false)
		this.div00.form.btnOarOr03.set_enable(false)
		this.div00.form.btnOarOr05.set_enable(false)
		this.div00.form.btnOarOr05.set_text("제출(미제출)")
	}
	if(this.fv_param.sbmsnYn == "Y") {
	
		this.div00.form.btnOarOr05.set_text("제출(완료)")
	}
	
	this.fnExmhYn();
	
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd == -1) return;
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 고사장 선택 여부 조회 ( 각 시도 교육청에서 고사장 선택 했는지 조회)
*/
this.fnExmhYn = function(){

	this.dsExmhList.addRow();
	this.dsSelectedExmhNo.addRow();
	this.dsSearch.addRow();
	this.dsChcExmh.addRow();
	
	this.dsSearch.setColumn(0,"enfcYr", this.fv_param.enfcYr);
	this.dsSearch.setColumn(0,"enfcTme", this.fv_param.enfcTme);
	this.dsSearch.setColumn(0,"cddcCd", this.fv_param.cddcCd);
	this.dsSearch.setColumn(0,"sqeScCd", this.fv_param.sqeScCd);
	this.dsSearch.setColumn(0,"rcptNo", this.fv_param.rcptNo);
	
	this.imgSubTitle.set_text(this.fv_param.subTitle);
	// 고사장 여부 조회 
	this.smfSearchService("selectExmhYn")
		
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.dsSelectExmhYn.getColumn(0,"exmhChcYn") == "Y" && this.dsSelectExmhYn.getColumn(0,"exmhChcYn") != null){
			//교육청에서 고사장 선택한 경우
				this.fnExmhList();
				
			}else{
			//교육청에서 고사장 선택하지 않은 경우
				this.divSearch.form.edtEnfcYr.set_value(this.fv_param.enfcYr)
				this.divSearch.form.edtEnfcTme.set_value(this.fv_param.enfcTme)
				//this.divSearch.form.edtCddcCd.set_value(this.dsSelectExmhYn.getColumn(0,"kornOrgNm"))
				this.grdEhList.set_visible(false)
				this.divInfo.set_visible(true)
				//시도교육청 명 세션에서 가져올수 잇나!!!!!!!!!!
				this.divInfo.form.staInfo.set_text(this.dsSelectExmhYn.getColumn(0,"kornOrgNm") + "은 응시자가 고사장을 선택할 수 없습니다. 수험표 출력 시, 배정된 고사장을 확인할 수 있습니다.")
				this.divSearch.form.btnSearch.set_enable(false)
				this.btnAdd.set_visible(false)
				this.btnCancel.set_visible(false)
				
			}
			
		});	
}

/**
 * @description 고사장목록 조회
*/
this.fnExmhList = function(){

	// 고사장 조회 
	this.smfSearchService("selectExmhNo")
		
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.fnExmhListCallback();
			
		});	
}
/**
 * @description 고사장 목록 조회 callback
*/
this.fnExmhListCallback = function(){

	var rowCnt = this.dsExmhList.rowcount;

	for(var i = 0; i < rowCnt; i++){

	//수용가능인원 / 전체인원
	 var cnt = this.dsExmhList.getColumn(i ,"ableCnt") + " / " + this.dsExmhList.getColumn(i, "acmdNmprCnt")
	 //수용가능인원이 (-)일경우 0/전체인원으로 보여준다
	 if(this.dsExmhList.getColumn(i ,"ableCnt") < 0){
			cnt = 0 + " / " + this.dsExmhList.getColumn(i, "acmdNmprCnt")
		}
	 this.dsExmhList.setColumn(i,"ehAbleRcptn",cnt);
	 
	//전체인원보다 신청인원이 많을 경우 전체인원으로 보여준다
	/*
	if(this.dsExmhList.getColumn(i ,"exmhNoCnt") > this.dsExmhList.getColumn(i, "acmdNmprCnt")){
		this.dsExmhList.setColumn(i,"exmhNoCnt",this.dsExmhList.getColumn(i, "acmdNmprCnt"));
	}
	*/

	 if(this.dsSelectedExmhNo.getColumn(0, "exmhNo") != this.dsExmhList.getColumn(i, "exmhNo")
		&& this.dsExmhList.getColumn(i, "ableCnt") <= 0){
		//신청(고사장의 인원이 다 찼을 경우)
		this.dsExmhList.setColumn(i, "selRetn", "만원");
	
		 
		
	 }else if(this.dsSelectedExmhNo.getColumn(0, "exmhNo") != this.dsExmhList.getColumn(i, "exmhNo")
		&& this.dsExmhList.getColumn(i, "ableCnt") > 0){
		//신청(고사장의 인원에 여유가 있을 경우)
		this.dsExmhList.setColumn(i, "selRetn", "신청");
		
	 }else{
		//신청완료
		this.dsExmhList.setColumn(i, "selRetn", "신청완료");
	 }
	 
	}
}
/**
 * @description 고사장 신청 버튼 클릭 후 
*/
this.fnUpdateExmhNo = function(row){
	
	var exmhNo = this.dsExmhList.getColumn(row, "exmhNo");
	var ableCnt = this.dsExmhList.getColumn(row, "ableCnt");
	var exmmScNm = this.dsExmhList.getColumn(row, "exmhNm"); //고사장명exmhNm을 가져오지만 저장 시 exmmScNm고사장구분명으로 저장

	this.dsChcExmh.setColumn(0,"enfcYr", this.fv_param.enfcYr);
	this.dsChcExmh.setColumn(0,"enfcTme", this.fv_param.enfcTme);
	this.dsChcExmh.setColumn(0,"cddcCd", this.fv_param.cddcCd);
	this.dsChcExmh.setColumn(0,"sqeScCd", this.fv_param.sqeScCd);
	this.dsChcExmh.setColumn(0,"rcptNo", this.fv_param.rcptNo);
	this.dsChcExmh.setColumn(0, "exmhNo", exmhNo);
	this.dsChcExmh.setColumn(0, "ableCnt", ableCnt);
	this.dsChcExmh.setColumn(0, "exmmScNm", exmmScNm);
	
	// 고사장 선택
	this.smfSaveService("updateExmhNo")
		//confirm메세지 수정으로 변경
		.messagePrefix("신청")
		// 데이터 존재 필수
		.requireExistsData(this.dsChcExmh)
// 		// 데이터 검증
//		.validateForm(this.divDetail)
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
		
			if(callbackParams.errors) return;
			this.smfAlert(exmmScNm + "이(가) 선택되었습니다.")
			this.fnExmhList();
	
			
		});	
}
/**
 * @description 고사장 만원일 때 경고 창
*/
this.fnImgSelRetn = function(row){

	var ehNm = this.dsExmhList.getColumn(row, "exmhNm")
	this.smfAlert(" ※ "+ ehNm + "는 수용가능인원대비 신청인원이 초과되어 \n    고사장신청을 할수 업습니다. \n\n ※  다른고사장을 신청하셔야 합니다.");
	
}
/**
 * @description 고사장 신청- 저장 
*/
this.saveExmhNo = function(row){
	
	var cnt = 0;
	var selEhNm = "";
	
	for(var i = 0; i< this.dsExmhList.rowcount; i++){
		selEhNm =  this.dsExmhList.getColumn(i, "exmhNo");
		if(this.dsSelectedExmhNo.getColumn(0, "exmhNo") == selEhNm){
			cnt++;
		}
	};
	
	if(cnt <= 0){
		this.smfAlert("고사장을 신청하셔야 저장이 가능합니다");
		return false;
	}
	
	this.smfConfirm("입력하신 정보를 저장하시겠습니까?\n\n저장하시면 다음단계로 이동합니다. ", function(confirmParams){
			if(confirmParams.confirmResult){
					this.smfAlert("저장되었습니다", function(){
					var params = {
						enfcYr :  this.dsSelectedExmhNo.getColumn(0,"enfcYr"),
						enfcTme : this.dsSelectedExmhNo.getColumn(0,"enfcTme"),
						sqeScCd : this.dsSelectedExmhNo.getColumn(0,"sqeScCd"),
						cddcCd : this.dsSelectedExmhNo.getColumn(0,"cddcCd"),
						rcptNo : this.dsSelectedExmhNo.getColumn(0,"rcptNo"),
						subTitle : this.imgSubTitle.text,
						sbmsnYn : this.fv_param.sbmsnYn
					};
					this.smfSetWorkPage("pa_sqa_oar_or::sqa_oaror05_m00.xfdl", params);
			})
			
			}
			
	
	})	
	
}

this.fnChkValidate = function(){

		if(this.dsSelectExmhYn.getColumn(0,"exmhChcYn") == "Y" && this.dsSelectExmhYn.getColumn(0,"exmhChcYn") != null){
		var selEhNm;
		var iCount = 0;
		for(var i = 0; i < this.dsExmhList.rowcount; i++){
			selEhNm = this.dsExmhList.getColumn(i,"exmhNo")
			if(this.dsSelectedExmhNo.getColumn(0, "exmhNo") == selEhNm){
					iCount++;
			}
		}
		
		if(iCount <= 0){
			this.smfAlert("고사장을 신청후 다음으로 이동하십시오.")
			return false;
		}
	}

		return true;
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 신청 버튼 클릭
*/
this.grdEhList_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if(e.col == 3){
		if(this.dsExmhList.getColumn(e.row, "selRetn") == "신청"){
			this.fnUpdateExmhNo(e.row);
		}else if(this.dsExmhList.getColumn(e.row, "selRetn") == "만원"){
			this.fnImgSelRetn(e.row);
		}
	}
};
/**
 * @description 조회 버튼 클릭
*/
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnExmhList();
};
/**
 * @description 저장 버튼 클릭
*/
this.btnAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.saveExmhNo();
};
