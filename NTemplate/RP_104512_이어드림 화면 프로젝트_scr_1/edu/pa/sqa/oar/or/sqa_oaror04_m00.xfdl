              <Static id="sta00_00_01_01_00" taborder="0" left="29" top="28" height="23" cssclass="sta_WF_InfoTit" text="이용 전 확인해주세요." wordWrap="char" initvalueid="ivStcAccessibilityOn" width="200"/>
              <Static id="sta00_00_01_01" taborder="1" left="30" top="81" height="23" cssclass="sta_WF_InfoTxt_Blue" text="수용가능인원 대비 신청인원이 넘는 고사장은 신청이 되지 않습니다." wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="30"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00" taborder="2" left="0" top="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta99_00_00_00_00_01_01" taborder="3" left="0" top="30" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="30" text="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_00" taborder="4" left="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" bottom="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta99_00_00_00_00_01_01_00" taborder="5" top="30" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="30" text="30" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_01" taborder="6" left="30" top="51" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta00_00_01_01_01_00" taborder="7" left="30" top="115" height="23" cssclass="sta_WF_InfoTxt_Red" text="고사장 신청완료 후 고사장을 변경하고자 할 때는 변경하고자 하는 고사장에 신청하면 고사장이 변경되어 신청완료 됩니다." wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="30"/>
