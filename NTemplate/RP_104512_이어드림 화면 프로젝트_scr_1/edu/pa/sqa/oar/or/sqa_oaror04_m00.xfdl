					enfcTme : this.fv_param.enfcTme,
					sqeScCd : this.fv_param.sqeScCd,
					cddcCd : this.fv_param.cddcCd,
					rcptNo : this.fv_param.rcptNo,
					subTitle : this.imgSubTitle.text,
					sbmsnYn: this.fv_param.sbmsnYn
				};
				
					this.smfSetWorkPage("pa_sqa_oar_or::sqa_oaror03_m00.xfdl", params);
				
			}
		
	
};
/**
 * @description 다음 버튼 클릭
*/
this.btnNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.dsSelectExmhYn.getColumn(0,"exmhChcYn") == "Y" && this.dsSelectExmhYn.getColumn(0,"exmhChcYn") != null){
		if(this.fnChkValidate()){
			var params = {
								enfcYr :  this.dsSelectedExmhNo.getColumn(0,"enfcYr"),
								enfcTme : this.dsSelectedExmhNo.getColumn(0,"enfcTme"),
								sqeScCd : this.dsSelectedExmhNo.getColumn(0,"sqeScCd"),
								cddcCd : this.dsSelectedExmhNo.getColumn(0,"cddcCd"),
								rcptNo : this.dsSelectedExmhNo.getColumn(0,"rcptNo"),
								subTitle : this.imgSubTitle.text,
								sbmsnYn : this.fv_param.sbmsnYn
							};
				this.smfSetWorkPage("pa_sqa_oar_or::sqa_oaror05_m00.xfdl", params);
			
		}
			
		

	}else{

		var params = {	
						enfcYr :  this.fv_param.enfcYr,
						enfcTme : this.fv_param.enfcTme,
						sqeScCd : this.fv_param.sqeScCd,
						cddcCd : this.fv_param.cddcCd,
						rcptNo : this.fv_param.rcptNo,
						subTitle : this.imgSubTitle.text,
						sbmsnYn : this.fv_param.sbmsnYn
					};
		this.smfSetWorkPage("pa_sqa_oar_or::sqa_oaror05_m00.xfdl", params);
	}
	
};
/**
 * @description 작성방법 버튼 클릭
 */
this.btnSample_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 팝업을 동작에 필요한 파라메터 지정
		var popupParams = {
			callback: this.fnPopupCallback, // 콜백함수 지정
			sender: obj, // sender 지정

			// 팝업 전달 파라메터 지정
			params: {
				// 처리타입 지정
				procType: "notice",
				pageId : "sqa_oaror04_m00"
			}
		};
		
		// 모달리스팝업 실행
		this.smfOpen("_auto", "pa_sqa_oar_or::sqa_oaror02_p00.xfdl", popupParams);	
};


/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	// 업무콜백 처리
	this.smfAlert("응답결과 ==>"+e.row.Column0+", "+e.row.Column1+", "+e.row.Column2+", "+e.row.Column3);
};

