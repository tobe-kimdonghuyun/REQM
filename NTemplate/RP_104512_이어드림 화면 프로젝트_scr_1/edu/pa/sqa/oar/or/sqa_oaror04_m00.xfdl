 * @description 이전 버튼 클릭
*/
this.btnPrev_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	if(this.dsSelectExmhYn.getColumn(0,"exmhChcYn") == "Y" && this.dsSelectExmhYn.getColumn(0,"exmhChcYn") != null){
		
		//if(this.fnChkValidate()){
		
			var params = {
					enfcYr :  this.dsSelectedExmhNo.getColumn(0,"enfcYr"),
					enfcTme : this.dsSelectedExmhNo.getColumn(0,"enfcTme"),
					sqeScCd : this.dsSelectedExmhNo.getColumn(0,"sqeScCd"),
					cddcCd : this.dsSelectedExmhNo.getColumn(0,"cddcCd"),
					rcptNo : this.dsSelectedExmhNo.getColumn(0,"rcptNo"),
					subTitle : this.imgSubTitle.text,
					sbmsnYn: this.fv_param.sbmsnYn
				};
				
				this.smfSetWorkPage("pa_sqa_oar_or::sqa_oaror03_m00.xfdl", params);
		//}
		
				
				
			}else{
			//교육청에서 고사장 선택하지 않은 경우
				var params = {
