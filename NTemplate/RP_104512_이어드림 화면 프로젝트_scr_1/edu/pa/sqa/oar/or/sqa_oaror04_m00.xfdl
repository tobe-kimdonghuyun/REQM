          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="rcptNo" type="STRING" size="256"/>
          <Column id="exmhNo" type="STRING" size="256"/>
          <Column id="exmmScNm" type="STRING" size="256"/>
          <Column id="ableCnt" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsExmhList" useclientlayout="true">
        <ColumnInfo>
          <Column id="exmhNo" type="STRING" size="256"/>
          <Column id="exmhNm" type="STRING" size="256"/>
          <Column id="ableCnt" type="STRING" size="256"/>
          <Column id="acmdNmprCnt" type="STRING" size="256"/>
          <Column id="exmhNoCnt" type="STRING" size="256"/>
          <Column id="rcgnNoCnt" type="STRING" size="256"/>
          <Column id="sqeOnlBgngExmtNo" type="STRING" size="256"/>
          <Column id="sqeOnlLastExmtNo" type="STRING" size="256"/>
          <Column id="ehAbleRcptn" type="STRING" size="256"/>
          <Column id="selRetn" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSearch">
        <ColumnInfo>
          <Column id="enfcYr" type="STRING" size="256"/>
          <Column id="enfcTme" type="STRING" size="256"/>
          <Column id="rcptNo" type="STRING" size="256"/>
          <Column id="sqeScCd" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSelectExmhYn" useclientlayout="true">
        <ColumnInfo>
          <Column id="exmhChcYn" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="kornOrgNm" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsChcExmh" useclientlayout="true">
        <ColumnInfo>
          <Column id="enfcYr" type="STRING" size="256"/>
          <Column id="enfcTme" type="STRING" size="256"/>
          <Column id="sqeScCd" type="STRING" size="256"/>
          <Column id="sqeScCdNm" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="rcptNo" type="STRING" size="256"/>
          <Column id="exmhNo" type="STRING" size="256"/>
          <Column id="exmmScNm" type="STRING" size="256"/>
          <Column id="ableCnt" type="STRING" size="256"/>
          <Column id="rgtrId" type="STRING" size="256"/>
