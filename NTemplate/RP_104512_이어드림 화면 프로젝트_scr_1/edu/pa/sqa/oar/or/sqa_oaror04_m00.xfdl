              <Static id="sta00_01_00_00_00" taborder="1" left="btnOarOr02:14" top="10" width="18" height="51" cssclass="sta_WF_NextStep02" initvalueid="ivStcAccessibilityOn" text="" accessibilitylabel="다음"/>
              <Button id="btnOarOr03" taborder="2" text="학력과목정보" top="0" width="21.17%" height="70" cssclass="btn_WF_Step02" left="sta00_01_00_00_00:21" initvalueid="ivBtnAccessibilityLink" onclick="fnStep_onclick"/>
              <Static id="sta00_01_00_00_00_00" taborder="3" left="btnOarOr03:14" top="10" width="18" height="51" cssclass="sta_WF_NextStep02" initvalueid="ivStcAccessibilityOn" accessibilitylabel="다음"/>
              <Button id="btnOarOr04" taborder="4" text="고사장선택" top="0" height="70" cssclass="btn_WF_Step03S" width="21.17%" left="sta00_01_00_00_00_00:21" initvalueid="ivBtnAccessibilityLink" onclick="fnStep_onclick"/>
              <Static id="sta00_01_00_00_00_00_00" taborder="5" left="btnOarOr04:14" top="11" width="18" height="51" cssclass="sta_WF_NextStep02" initvalueid="ivStcAccessibilityOn" accessibilitylabel="다음"/>
              <Button id="btnOarOr05" taborder="6" text="제출완료" top="0" height="70" cssclass="btn_WF_Step04" left="sta00_01_00_00_00_00_00:21" initvalueid="ivBtnAccessibilityLink" width="21.17%" onclick="fnStep_onclick"/>
            </Layout>
