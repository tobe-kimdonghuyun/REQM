    <Objects>
      <Dataset id="dsService" useclientlayout="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsOneUserInfo=dsOneUserInfo dsAllUserInfo=dsAllUserInfo dsSbmsnYn=dsSbmsnYn dsExmhNoInfo=dsExmhNoInfo</Col>
            <Col id="asynctp"/>
            <Col id="url">/sqa_oar_or05_001.do</Col>
            <Col id="id">selectUserInfo</Col>
          </Row>
          <Row>
            <Col id="id">deleteInfo</Col>
            <Col id="url">/sqa_oar_or05_002.do</Col>
            <Col id="inDatasets">dsDelete=dsDelete</Col>
          </Row>
          <Row>
            <Col id="id">save</Col>
            <Col id="inDatasets">dsSaveParam=dsSaveParam</Col>
            <Col id="url">/sqa_oar_or05_003.do</Col>
            <Col id="outDatasets">dsReturnVal=dsReturnVal</Col>
          </Row>
          <Row>
            <Col id="id">update</Col>
            <Col id="inDatasets">dsSaveParam=dsSaveParam</Col>
            <Col id="url">/sqa_oar_or05_004.do</Col>
            <Col id="outDatasets">dsReturnVal=dsReturnVal</Col>
          </Row>
        </Rows>
      </Dataset>
