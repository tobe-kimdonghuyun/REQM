    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 검정고시서비스 원서접수-접수완료
*  @FileName 	sqa_oaror05_m00.xfdl 
*  @Creator 	박가혜
*  @CreateDate 	2022.07.25
*  @Desction    접수완료
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.07.25           박가혜                 최초 생성
*  2024.10.23			진승환					범정부 UI/UX 가이드라인 적용 (제출, 원서삭제시 페이지 이동 수정)
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/




include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.enfcYr;
this.enfcTme;
this.sqeScCd;
this.cddcCd;
this.rcptNo;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frm01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);
	
	this.fv_param = this.smfGetFormParams();
	this.fnSetInitParam(this.smfGetFormParams());
	
	this.dsSearch.addRow();
	this.dsSearch.setColumn(0,"enfcYr", this.fv_param.enfcYr);
	this.dsSearch.setColumn(0,"enfcTme", this.fv_param.enfcTme);
	this.dsSearch.setColumn(0,"cddcCd", this.fv_param.cddcCd);
	this.dsSearch.setColumn(0,"sqeScCd", this.fv_param.sqeScCd);
	this.dsSearch.setColumn(0,"rcptNo", this.fv_param.rcptNo);
	this.dsSearch.setColumn(0,"trprRrno", this.smfGetSessionValue("trprRrno"));
	this.dsSearch.setColumn(0,"kornFlnm", this.smfGetSessionValue("kornFlnm"));
	this.imgSubTitle.set_text(this.fv_param.subTitle)
	
	//제출여부에 따라 상단 스탭박스 이동가능 여부 설정(제출한적 있는경우(Y) 자유이동가능, 
	//첫 작성인 경우(N) 이동 못함)
	if(this.fv_param.sbmsnYn == "N") {
		this.div00.form.btnOarOr05.removeEventHandler("onclick", this.fnStep_onclick, this)
		this.div00.form.btnOarOr02.set_enable(false)
		this.div00.form.btnOarOr03.set_enable(false)
		this.div00.form.btnOarOr04.set_enable(false)
		this.div00.form.btnOarOr05.set_text("제출(미제출)")
		this.img00_01.set_text("제출(미제출)")
		
		this.smfAlert("온라인원서접수를 위해 입력한 정보가 맞는지 확인하신 후 \n 반드시, 하단의  제출버튼을 클릭하셔야 \n 최종 원서가 제출되어 접수됩니다.", function(){
			//원서접수 데이터 조회
			this.fnUserInfo();
		})
	}
	
	if(this.fv_param.sbmsnYn == "Y") {
		this.div00.form.btnOarOr05.set_text("제출(완료)")
		this.img00_01.set_text("제출(완료)")
		this.fnUserInfo();
	}
	
	
	

	this.smfResetScroll(this.divMain.form) //div사이즈 최적화
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 원서접수 데이터 조회
*/
this.fnUserInfo = function(){

	// 고사장 조회 
	this.smfSearchService("selectUserInfo")
		
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.fnUserInfoCallback();
			
		});	
}




 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd == -1) return;
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 원서접수 데이터 조회 콜백
*/
this.fnUserInfoCallback = function(){
	enfcYr = this.dsOneUserInfo.getColumn(0,"enfcYr");
	enfcTme = this.dsOneUserInfo.getColumn(0,"enfcTme")
	sqeScCd = this.dsOneUserInfo.getColumn(0,"sqeScCd")
	cddcCd = this.dsOneUserInfo.getColumn(0,"cddcCd")
	rcptNo = this.dsOneUserInfo.getColumn(0,"rcptNo")

		
	//접수번호
	var sbmsnYn = this.dsSbmsnYn.getColumn(0,"sbmsnYn")
	
	if(sbmsnYn != null || sbmsnYn != ""){
		if(sbmsnYn == "Y"){
			this.divMain.form.edtRcptNo.set_value("제출된 원서에 한하여 담당자가 부여한 후 확인 가능합니다.")
		}else{
			this.divMain.form.edtRcptNo.set_value("제출되지 않은 원서이므로 수험번호를 확인할 수 없습니다.")
		}
	}else{
		this.divMain.form.edtRcptNo.set_value("제출되지 않은 원서이므로 수험번호를 확인할 수 없습니다.")
	}
	
	
	//사진
	this.divMain.form.imgViewer.set_image("data:image/png;base64,"+this.dsOneUserInfo.getColumn(0,"photoFileCn"))
	if(this.dsOneUserInfo.getColumn(0,"photoFileCn") != "" && this.dsOneUserInfo.getColumn(0,"photoFileCn") != null){
		this.divMain.form.imgViewer.set_text("")
	}
	
	//주민등록번호
	var trprRrno = this.dsOneUserInfo.getColumn(0,"trprRrno")
	if(trprRrno.length > 0){
		this.divMain.form.edtTrprRrno1.set_value(trprRrno.substring(0,6))
		this.divMain.form.edtTrprRrno2.set_value(trprRrno.substring(6,13))
	}
	
	//주소
	var zipCd = this.dsOneUserInfo.getColumn(0,"ihtRegRoadNmZip")
	var rdnAddr = this.dsOneUserInfo.getColumn(0,"ihtRegRoadNmAddr")
	this.divMain.form.edtIhtRegRdnAddr.set_value(zipCd + " " + rdnAddr)
	
	//졸업제적일
	var grdtnExpelYmd = this.dsOneUserInfo.getColumn(0,"grdtnExpelYmd")==null || this.dsOneUserInfo.getColumn(0,"grdtnExpelYmd")=="" ? "" : this.dsOneUserInfo.getColumn(0,"grdtnExpelYmd");
	var year = grdtnExpelYmd.substr(0,4)
	var month = grdtnExpelYmd.substr(4,2)
	var day = grdtnExpelYmd.substr(6,2)
	this.divMain.form.edtGrdtnExpelYmd.set_value( year+ "-" + month + "-" + day)
	
	
	//과목세팅
	this.sbjtUserInfo();
	this.smfResetScroll(this.divDetail.form) //div사이즈 최적화
	
	//버튼세팅
	if(this.dsOneUserInfo.getColumn(0, "sqeScCd") != ""){
		if(this.dsOneUserInfo.getColumn(0,"regYn") == "" || this.dsOneUserInfo.getColumn(0,"regYn") == "N"){
			this.btnAdd.set_text("제출")
			this.btnAdd.setEventHandler("onclick", this.btnAdd_onclick, this)
		}else{
			//this.btnAdd.set_text("수정후제출")
			//this.btnAdd.set_text("제출")
			this.btnAdd.set_visible(false);
			this.btnCancel.set_right(0);
			this.btnDelete.set_right(140);
			//this.btnAdd.setEventHandler("onclick", this.btnUpdateAdd_onclick, this)
		}
	}
}
/**
 * @description 원서접수 데이터 중 과목 조회
*/
this.sbjtUserInfo = function(){

	if(this.dsAllUserInfo.rowcount > 0){
		for(var i = 0; i < this.dsAllUserInfo.rowcount; i++){
		
			var nTop = i * 41;
		
			var staStatic = new Static("staStatic"+i, 0, nTop, 128, 42, null, null)
			if(i == 0) {
				staStatic.set_cssclass("sta_WF_Input01Top")
			}else{
				staStatic.set_cssclass("sta_WF_Input01")
			}
			staStatic.set_initvalueid("ivStcAccessibilityOn")
			staStatic.set_text(this.dsAllUserInfo.getColumn(i, "sqeSbjtNoNm"))
			this.divDetail.addChild(staStatic.name, staStatic)
			staStatic.show();
			
			var staStatic2 = new Static("staStatic1"+i, "staStatic"+i+":"+ 0, nTop, null, 42, 0, null)
			if(i == 0) {
				staStatic2.set_cssclass("sta_WF_Input02Top")
			}else{
				staStatic2.set_cssclass("sta_WF_Input02")
			}
			staStatic2.set_initvalueid("ivStcAccessibilityOff")
			this.divDetail.addChild(staStatic2.name, staStatic2)
			staStatic2.show();
			
			var edtEdit = new Edit("edtEdit"+i, "staStatic"+i+":"+ 10, nTop+6, null, 30, 105, null)
			edtEdit.set_cssclass("edi_WF_Input")
			edtEdit.set_initvalueid("ivEdtReadOnly")
			edtEdit.set_readonly(true)
			edtEdit.set_value(this.dsAllUserInfo.getColumn(i, "sbjtAplemScCdNm"))
			this.divDetail.addChild(edtEdit.name, edtEdit)
			edtEdit.show();
		}
	}else{
		this.divDetail.set_visible(false)
	} 
}
/**
 * @description 원서 제출 콜백
*/
this.submitCallback = function(){

	var returnVal= this.dsReturnVal.getColumn(0,"returnVal");
	
	if(returnVal == "SUCC"){
		this.div00.form.btnOarOr05.set_text("제출(완료)")
		//this.smfAlert("제출완료되었습니다.",function(){
			//취소버튼 안보이게
			this.btnCancel.set_visible(false) 
			//원서조회화면으로 이동
			//this.fnGoPage("pa_sqa_oar_oi::sqa_oaroi00_m00.xfdl")
			// 제출완료 페이지로 이동
			this.fnGoPage("pa_sqa_oar_or::sqa_oaror06_m00.xfdl");
		//})
		
		
	}else if(returnVal == "SBMT_Y"){ //안쓰는것같음 .
		this.smfAlert("이미 제출되었습니다. 원서조회에서 확인하세요.", function(){
			//원서조회화면으로 이동
			this.fnGoPage("pa_sqa_oar_oi::sqa_oaroi00_m00.xfdl");
		})
		
	}else{
		this.smfAlert("제출되지 않았습니다. 1단계 응시자정보부터 입력 정보를 확인하세요.",function(){
			//응시자정보 페이지로 이동
			this.fnGoPage("pa_sqa_oar_or::sqa_oaror02_m00.xfdl");
		});
		
	}
	
	
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 원서 삭제
*/
this.btnDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	this.dsDelete.addRow();
	this.dsDelete.setColumn(0,"enfcYr", enfcYr)
	this.dsDelete.setColumn(0,"enfcTme",enfcTme);
	this.dsDelete.setColumn(0,"sqeScCd", sqeScCd);
	this.dsDelete.setColumn(0,"cddcCd",cddcCd);
	this.dsDelete.setColumn(0,"rcptNo", rcptNo);
	
	this.smfConfirm("원서접수 취소시 처음단계부터 재작성 해주셔야 합니다.\n원서접수를 취소하시겠습니까?", function(confirmParams){
	
		if(confirmParams.confirmResult){
				//응시원서 삭제 
			this.smfDeleteService("deleteInfo")
				// (권장) 데이터 존재 필수
				.requireExistsData(this.dsSearch)
				
				// 실행
				.run()

				// 콜백
				.callback(function(callbackParams){
					if(callbackParams.errors) return;
					//this.smfAlert("접수취소가 완료되었습니다.", function(){
						//this.fnGoPage("pa_sqa_cmm_cm::sqa_cmmcm04_m00.xfdl");
						this.fnGoPage("pa_sqa_oar_or::sqa_oaror07_m00.xfdl");
					//})
					
				});	
			}else{
				return false;
			}
	})

};
/**
 * @description 원서 제출
*/
this.btnAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var exmhNo = this.dsOneUserInfo.getColumn(0,"exmhNo")
	var ehName  = this.dsOneUserInfo.getColumn(0,"exmmScNm")
	var ableCnt = this.dsExmhNoInfo.getColumn(0,"ableCnt")
	var sqeScCdNm = this.dsOneUserInfo.getColumn(0,"sqeScCdNm")
	
	if(exmhNo != null && exmhNo != ""){
		if(ableCnt <= 0){
			this.smfAlert(" ※ "+ ehName + "는 수용가능인원대비 신청인원이 초과되어 \n\n    다른고사장을 신청하셔야 합니다.")
			this.smfConfirm("※  고사장 등록화면으로 이동하시겠습니까? ", function(confirmParams){
				if(confirmParams.confirmResult){
					var params = {enfcYr : enfcYr,
									enfcTme : enfcTme,
									sqeScCd : sqeScCd,
									sbmsnYn: this.fv_param.sbmsnYn};
					this.smfSetWorkPage("pa_sqa_oar_or::sqa_oaror04_m00.xfdl", params);
				}else{
					return false;
				}
				
			})
		}
	}
	
	var domainCd = this.smfGetCddcCode();
	domainCd = domainCd.substr(0,3)

// 	switch(domainCd) {
// 		case "A00": eduDomainName = "교육부"; break;
// 		case "B10": eduDomainName = "서울특별시교육청"; break;
// 		case "C10": eduDomainName = "부산광역시교육청"; break;
// 		case "D10": eduDomainName = "대구광역시교육청"; break;
// 		case "E10": eduDomainName = "인천광역시교육청"; break;
// 		case "F10": eduDomainName = "광주광역시교육청"; break;
// 		case "G10": eduDomainName = "대전광역시교육청"; break;
// 		case "H10": eduDomainName = "울산광역시교육청"; break;
// 		case "I10": eduDomainName = "세종특별자치시교육청"; break;
// 		case "J10": eduDomainName = "경기도교육청"; break;
// 		case "K10": eduDomainName = "강원도교육청"; break;
// 		case "M10": eduDomainName = "충청북도교육청"; break;
// 		case "N10": eduDomainName = "충청남도교육청"; break;
// 		case "P10": eduDomainName = "전라북도교육청"; break;
// 		case "Q10": eduDomainName = "전라남도교육청"; break;
// 		case "R10": eduDomainName = "경상북도교육청"; break;
// 		case "S10": eduDomainName = "경상남도교육청"; break;
// 		case "T10": eduDomainName = "제주특별자치도교육청"; break;
// 		default:
// 			eduDomainName = "잘못된 교육청 이름";
// 	}

	var eduDomainName = this.smfGetCddcName();
	var mblTelno = this.dsOneUserInfo.getColumn(0,"mblTelno")
	var msg = "원서를 제출할 교육청은 ["+eduDomainName+"]입니다.\n원서를 제출하시면 교육청담당자 확인처리전까지만 수정이 가능합니다.\n\n접수한 검정고시 원서를 제출하시겠습니까?\n\n※ 제출 하시더라도 증빙서류 등 교육청담당자 확인이 되어야 \n수험번호 부여 및 접수가 완료 됩니다.\n\n"
	msg += "- 등록하신 연락처로 연락이 갈 수 있으므로 필히 연락을 받아주시기 바랍니다.\n\n "
	msg += "※ 접수정보 ※ \n\n"
	msg += enfcYr +"년 " + enfcTme + "회차 " + sqeScCdNm + "\n"
	msg += "응시시도교육청 : " + eduDomainName + "\n연락처 : " +  mblTelno 
	
	var objOption= {width:500,height:500};
	
	this.smfLiteralConfirm(msg, function(confirmParams){
	
		if(confirmParams.confirmResult){
			this.dsSaveParam.addRow();
			this.dsSaveParam.setColumn(0,"onlAgreYn", "Y")
			this.dsSaveParam.setColumn(0,"hstrScNo", "0");
			this.dsSaveParam.setColumn(0,"regYn", "Y"); //등록구분
			this.dsSaveParam.setColumn(0,"chgScNo", "0");
			this.dsSaveParam.setColumn(0,"enfcYr", enfcYr);
			this.dsSaveParam.setColumn(0,"enfcTme",enfcTme);
			this.dsSaveParam.setColumn(0,"sqeScCd", sqeScCd);
			this.dsSaveParam.setColumn(0,"cddcCd",cddcCd);
			this.dsSaveParam.setColumn(0,"rcptNo", rcptNo);
		
			
			//응시원서 제출
			this.smfSaveService("save")
				.showConfirm(false)
				.run()
				.callback(function(callbackParams){
					if(callbackParams.errors) return;
					this.submitCallback();
					
				});					
		}else{
		
			this.smfAlert("원서가 제출되지 않았습니다.\n원서를 제출하셔야 원서조회가 가능합니다.\n원서 내용을 확인하시고 제출버튼을 클릭하시기 바랍니다.")
		}
		
	
	},null,objOption)	
};
/**
 * @description 원서 수정 후 제출
*/
this.btnUpdateAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo){
	
	this.smfConfirm("교육청담당자 확인처리전까지만 수정이 가능합니다.\n\n접수한 검정고시 원서를 수정제출하시겠습니까? ", function(confirmParams){
	
		if(confirmParams.confirmResult){
			this.dsSaveParam.addRow();
			this.dsSaveParam.setColumn(0,"regYn", "Y"); //등록구분
			this.dsSaveParam.setColumn(0,"chgScNo", "0");
			this.dsSaveParam.setColumn(0,"onlAgreYn", "Y")
			this.dsSaveParam.setColumn(0,"hstrScNo", "0");
			this.dsSaveParam.setColumn(0,"enfcYr", enfcYr);
			this.dsSaveParam.setColumn(0,"enfcTme",enfcTme);
			this.dsSaveParam.setColumn(0,"sqeScCd", sqeScCd);
			this.dsSaveParam.setColumn(0,"cddcCd",cddcCd);
			this.dsSaveParam.setColumn(0,"rcptNo", rcptNo);
			
			//응시원서 제출
			this.smfSaveService("update")
				
				.showConfirm(false)
				.run()

				// 콜백
				.callback(function(callbackParams){
					if(callbackParams.errors) return;
					this.submitCallback();
					
				});	
			}else{
				return false;
				
			}
		
	})

}
/**
 * @description 취소 버튼 클릭
*/
this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	this.smfConfirm("확인을 클릭하면 1단계 응시자 정보 페이지로 이동합니다. \n 이동하시겠습니까?", function(confirmParams){
		if(confirmParams.confirmResult){
			this.fnGoPage("pa_sqa_oar_or::sqa_oaror02_m00.xfdl")
		}else{
			return false;
		}
	})

};
/**
 * @description 이전 버튼 클릭
*/
this.btnPrev_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	this.fnGoPage("pa_sqa_oar_or::sqa_oaror04_m00.xfdl")
};
/**
 * @description 작성방법 버튼 클릭
 */
this.btnSample_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 팝업을 동작에 필요한 파라메터 지정
		var popupParams = {
			callback: this.fnPopupCallback, // 콜백함수 지정
			sender: obj, // sender 지정

			// 팝업 전달 파라메터 지정
			params: {
				// 처리타입 지정
				procType: "none",
				pageId : "sqa_oaror05_m00"
			}
		};
		
		// 모달리스팝업 실행
		this.smfOpen("_auto", "pa_sqa_oar_or::sqa_oaror02_p00.xfdl", popupParams);	
};

/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	// 업무콜백 처리
	this.smfAlert("응답결과 ==>"+e.row.Column0+", "+e.row.Column1+", "+e.row.Column2+", "+e.row.Column3);
};
/**
 * @description 페이지이동
 */
this.fnGoPage = function(url){

	var params = {
				enfcYr :  this.dsOneUserInfo.getColumn(0,"enfcYr"),
				enfcTme : this.dsOneUserInfo.getColumn(0,"enfcTme"),
				sqeScCd : this.dsOneUserInfo.getColumn(0,"sqeScCd"),
				cddcCd : this.dsOneUserInfo.getColumn(0,"cddcCd"),
				rcptNo : this.dsOneUserInfo.getColumn(0,"rcptNo"),
				subTitle : this.imgSubTitle.text,
				sbmsnYn : this.fv_param.sbmsnYn,
				menuId : "4000" //초중고선택화면으로 이동
				};
			
	this.smfSetWorkPage(url, params);
}
this.fnChkValidate = function(){
	return true;
}
]]></Script>
