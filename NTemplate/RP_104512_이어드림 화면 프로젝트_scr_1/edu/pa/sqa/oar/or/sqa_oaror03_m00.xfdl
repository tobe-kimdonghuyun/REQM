		subjectYnImsiObj.set_value("")
		edtSubjectYnImsi.show();
		
		var bindItem02 = new BindItem();
		bindItem02.init("item02"+i,"this.divSbjt.form.edtSunSubjectYnImsi"+i, "value", "dsSunSaveList", "subjectYnImsi")
		this.divSbjt.addChild("item02"+i, bindItem02);
