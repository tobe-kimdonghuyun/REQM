		this.divSbjt.addChild(edtBfrPassSbjtScr.name, edtBfrPassSbjtScr)
		edtBfrPassSbjtScr.set_readonly(true)
		edtBfrPassSbjtScr.set_value("0")
		edtBfrPassSbjtScr.show();

		var bindItem03 = new BindItem();
		bindItem03.init("item03"+i,"this.divSbjt.form.edtSunBfrPassSbjtScr"+i, "value", "dsSunSaveList", "bfrPassSbjtScr")
		this.divSbjt.addChild("item03"+i, bindItem03);
		bindItem03.bind();
				
		//선택과목 응시과목 콤보박스 생성
		cboKornSbjtNm = new Combo("cboSunKornSbjtNm"+i, 30, nTop+5, 140, 30, null, null)
		cboKornSbjtNm.addEventHandler("onitemchanged",function(obj,e){
			this.saveSunSbjtList_onitemchanged(i,obj,e);
		}
		,this);
		this.divSbjt.addChild(cboKornSbjtNm.name, cboKornSbjtNm);
		cboKornSbjtNm.show();
		
		var bindItem04 = new BindItem();
		bindItem04.init("item04"+i,"this.divSbjt.form.cboSunKornSbjtNm"+i, "value", "dsSunSaveList", "kornSbjtNm")
		this.divSbjt.addChild("item04"+i, bindItem04);
		bindItem04.bind();
		
		
		
}

/**
 * @description 초중고 구분에 따른 필수 과목 동적 생성에 따른 값 셋팅
 */
this.fnDisplaySbjtList = function(){

	// 필수과목 개수만큼 컴포넌트 생성
	for(var i = 0; i < this.dsPilSbjt.rowcount; i++){ // 0 1 2 
	
		this.dsPilSaveList.addRow();
		//row초기화 undefiend를 "" 변경
		this.smfInitRow(this.dsPilSaveList, i);
	
		this.fnAddPilSbjtDiv(i); //컴포넌트 생성
		
		this.dsPilSaveList.setColumn(i, "enfcYr", this.fv_param.enfcYr);
		this.dsPilSaveList.setColumn(i, "enfcTme", this.fv_param.enfcTme);
		this.dsPilSaveList.setColumn(i, "sqeScCd", this.fv_param.sqeScCd);
		this.dsPilSaveList.setColumn(i, "cddcCd", this.fv_param.cddcCd);
		this.dsPilSaveList.setColumn(i, "rcptNo", this.fv_param.rcptNo);

		for(var j = 0; j < this.dsChcSbjt.rowcount; j++){
		
			if((this.dsPilSbjt.getColumn(i, "sqeSbjtNo") == this.dsChcSbjt.getColumn(j, "sqeSbjtNo")) && (this.dsChcSbjt.getColumn(j, "sbjtAplemScCd") == "4")){
				rdoSbjtAplemScCd.set_value(4) //미응시
			}
			if(this.dsPilSbjt.getColumn(i, "sqeSbjtNo") == this.dsChcSbjt.getColumn(j, "sqeSbjtNo") && this.dsChcSbjt.getColumn(j, "sbjtAplemScCd") == "1"){
				rdoSbjtAplemScCd.set_value(1) //응시
			}
			if((this.dsPilSbjt.getColumn(i, "sqeSbjtNo") == this.dsChcSbjt.getColumn(j, "sqeSbjtNo")) && (this.dsChcSbjt.getColumn(j, "sbjtAplemScCd") == "2")){
				rdoSbjtAplemScCd.set_value(2) //기합격
			}
			if(this.dsPilSbjt.getColumn(i, "sqeSbjtNo") == this.dsChcSbjt.getColumn(j, "sqeSbjtNo") && this.dsChcSbjt.getColumn(j, "sbjtAplemScCd") == "3"){
				rdoSbjtAplemScCd.set_value(3) //과목면제
			}

			if(this.dsPilSbjt.getColumn(i,"sqeSbjtNo") == this.dsChcSbjt.getColumn(j, "sqeSbjtNo")){
				this.dsPilSaveList.setColumn(i, "bfrPassSbjtScr", this.dsChcSbjt.getColumn(j,"bfrPassSbjtScr"));
				this.dsPilSaveList.setColumn(i, "bfrPassSbjtNo", this.dsChcSbjt.getColumn(j,"bfrPassSbjtNo"));
				edtBfrPassSbjtScr.set_value(this.dsChcSbjt.getColumn(j, "bfrPassSbjtScr"))
				this.dsPilSaveList.setColumn(i, "passYr", this.dsChcSbjt.getColumn(j,"passYr") == null || this.dsChcSbjt.getColumn(j,"passYr") == "" ? "" : this.dsChcSbjt.getColumn(j,"passYr"))
				this.dsPilSaveList.setColumn(i, "passTme", this.dsChcSbjt.getColumn(j,"passTme") == null || this.dsChcSbjt.getColumn(j,"passTme") == "" ? "" : this.dsChcSbjt.getColumn(j,"passTme"))
				if(this.dsChcSbjt.getColumn(j, "bfrPassSbjtScr") == null){
					edtBfrPassSbjtScr.set_value("0")
				}
			}
			
		}
		
		if(this.dsChcSbjt.rowcount == 0 || this.dsPilSbjt.getColumn(i, "sqeSbjtNo") == "" || this.dsPilSbjt.getColumn(i, "sqeSbjtNo") == null ){
			edtBfrPassSbjtScr.set_value("0")
		}
			
		if(this.dsAcbgInfo.getColumn(0,"grdtnExpelYmd") != ""){
			if(edtSubjectYnImsi.value == ""){
				edtSubjectYnImsi.set_value("없음")
				this.dsPilSaveList.setColumn(i,"subjectYnImsi", "없음")
			}
			if(edtBfrPassSbjtScr.value != "0"  && edtBfrPassSbjtScr.value != "" && edtBfrPassSbjtScr.value != null){
				edtSubjectYnImsi.set_value("있음")
				this.dsPilSaveList.setColumn(i,"subjectYnImsi", "있음")
			}
		}
		
		this.dsPilSaveList.setColumn(i, "sbjtAplemScCd", this.divSbjt.form["rdoPilSbjtAplemScCd"+i].value == null || this.divSbjt.form["rdoPilSbjtAplemScCd"+i].value == " " ? "1" :  this.divSbjt.form["rdoPilSbjtAplemScCd"+i].value)
		this.dsPilSaveList.setColumn(i, "sqePirScCd", this.dsPilSbjt.getColumn(i,"sqePirScCd"));
	}
	
}

/**
 * @description 초중고 구분에 따른 선택 과목 동적 생성 함수
 */
this.fnDisplaySbjtListChc = function(){	

	var idx = 0;
	
	// 선택과목 개수만큼 컴포넌트 생성 후 데이터 셋팅	
	if(this.dsAcbgInfo.getColumn(0, "sqeScCd") == "1"){  //검정고시구분 : 초졸
		
		idx = 2; //초졸일때 선택과목 2개
		
		for(var i = 0; i < idx; i++){
		
			this.dsSunSaveList.addRow();
			//row초기화 undefiend를 "" 변경
			this.smfInitRow(this.dsSunSaveList, i);

			var top = this.dsPilSbjt.rowcount + i  //전체 과목 중 선택과목 순서(몇번째인지)

			this.fnAddSunSbjtDiv(i, top) //컴포넌트생성

			this.dsSunSaveList.setColumn(i, "enfcYr", this.fv_param.enfcYr);
			this.dsSunSaveList.setColumn(i, "enfcTme", this.fv_param.enfcTme);
			this.dsSunSaveList.setColumn(i, "sqeScCd", this.fv_param.sqeScCd);
			this.dsSunSaveList.setColumn(i, "cddcCd", this.fv_param.cddcCd);
			this.dsSunSaveList.setColumn(i, "rcptNo", this.fv_param.rcptNo);
			
			if(this.dsChcSbjt1.getColumn(i,"passYr") != null || this.dsChcSbjt1.getColumn(i,"passYr") != ""){
				this.dsSunSaveList.setColumn(i, "passYr", this.dsChcSbjt1.getColumn(i,"passYr"));
				this.dsSunSaveList.setColumn(i, "passTme", this.dsChcSbjt1.getColumn(i,"passTme"));
			}
			
			if(this.dsChcSbjt2.getColumn(i,"passYr") != null || this.dsChcSbjt2.getColumn(i,"passYr") != ""){
				this.dsSunSaveList.setColumn(i, "passYr", this.dsChcSbjt2.getColumn(i,"passYr"));
				this.dsSunSaveList.setColumn(i, "passTme", this.dsChcSbjt2.getColumn(i,"passTme"));
		
			}
			
			//콤보박스 데이터 셋팅
			var objDs = new Dataset(); //교시구분31 / 32 일때 선택과목 콤보박스 목록 나눠서 보여주기
			objDs.name = "dsCboSbjtList"+i
			objDs.addColumn("sqeSbjtNo" ,"string")
			objDs.addColumn("kornSbjtNm" ,"string")
			this.divSbjt.addChild("dsCboSbjtList"+i, objDs);
			var cnt = 0
			if(i == 0){ //첫번째 콤보박스 
				cboKornSbjtNm.set_displaynulltext("선택1")
				for(var k = 0; k < this.dsSunSbjt.rowcount; k++){
				
					if(this.dsSunSbjt.getColumn(k, "sqePirScCd2") == "31"){
						objDs.addRow();
						objDs.setColumn(cnt, "sqeSbjtNo", this.dsSunSbjt.getColumn(k, "sqeSbjtNo"))
						objDs.setColumn(cnt, "kornSbjtNm", this.dsSunSbjt.getColumn(k, "kornSbjtNm"))
						cnt++;
					}
				}
				
			}else if(i == 1){ //두번째 콤보박스
				cboKornSbjtNm.set_displaynulltext("선택2")
				for(var k = 0; k < this.dsSunSbjt.rowcount; k++){
				
					if(this.dsSunSbjt.getColumn(k, "sqePirScCd2") == "32"){
						objDs.addRow();
						objDs.setColumn(cnt, "sqeSbjtNo", this.dsSunSbjt.getColumn(k, "sqeSbjtNo"))
						objDs.setColumn(cnt, "kornSbjtNm", this.dsSunSbjt.getColumn(k, "kornSbjtNm"))
						cnt++;
					}
				}
			}
		
			cboKornSbjtNm.set_initvalueid("ivCmbNormal")
			cboKornSbjtNm.set_codecolumn("sqeSbjtNo");
			cboKornSbjtNm.set_datacolumn("kornSbjtNm");
			cboKornSbjtNm.set_innerdataset(objDs);
			
			var sunSbjtCnt = this.dsSunSbjtCnt.getColumn(0, "sqeChcEsntlScCd")
		
			if(this.dsAcbgInfo.getColumn(0,"grdtnExpelYmd") != ""){
				if(edtSubjectYnImsi.value == ""){
					subjectYnImsiObj.set_value("없음")
				}
			}

			if( i == 0) { //선택1
				for(var ii = 0; ii< this.dsSunSbjt.rowcount; ii++){
					if(this.dsSunSbjt.getColumn(ii,"sqePirScCd2") == "31" ){ //3교시(3-1)
						if(this.dsSunSbjt.getColumn(ii, "sqeChcEsntlScCd") ==  this.dsSunSbjtCnt.getColumn(i, "sqeChcEsntlScCd")){ //sqeChcEsntlScCd = 검정고시선택필수구분코드 **수정**
							for(var j = 0; j < this.dsChcSbjt1.rowcount; j++){
								if(this.dsSunSbjt.getColumn(ii, "sqeSbjtNo") == this.dsChcSbjt1.getColumn(j, "sqeSbjtNo")){
									cboKornSbjtNm.set_value(this.dsSunSbjt.getColumn(ii, "sqeSbjtNo"))
									this.dsSunSaveList.setColumn(i, "sqeSbjtNo", cboKornSbjtNm.value)
									this.dsSunSaveList.setColumn(i, "kornSbjtNm", cboKornSbjtNm.text)
								}
							}
						}
					}
					
				if(this.dsSunSbjt.getColumn(ii, "sqeChcEsntlScCd") == this.dsSunSbjtCnt.getColumn(i, "sqeChcEsntlScCd")){ //**수정**
					for(var j = 0; j < this.dsChcSbjt1.rowcount; j++){
						
						if(this.dsSunSbjt.getColumn(ii, "sqeSbjtNo") == this.dsChcSbjt1.getColumn(j, "sqeSbjtNo") && this.dsChcSbjt1.getColumn(j, "sbjtAplemScCd") == "4"){
							rdoSbjtAplemScCd.set_value(4) //미응시
						}
						if(this.dsSunSbjt.getColumn(ii, "sqeSbjtNo") == this.dsChcSbjt1.getColumn(j, "sqeSbjtNo") && this.dsChcSbjt1.getColumn(j, "sbjtAplemScCd") == "1"){
							rdoSbjtAplemScCd.set_value(1) //응시
						}
						if(this.dsSunSbjt.getColumn(ii, "sqeSbjtNo") == this.dsChcSbjt1.getColumn(j, "sqeSbjtNo") && this.dsChcSbjt1.getColumn(j, "sbjtAplemScCd") == "2"){
							rdoSbjtAplemScCd.set_value(2) //기합격
						}
						if(this.dsSunSbjt.getColumn(ii, "sqeSbjtNo") == this.dsChcSbjt1.getColumn(j, "sqeSbjtNo") && this.dsChcSbjt1.getColumn(j, "sbjtAplemScCd") == "3"){
							rdoSbjtAplemScCd.set_value(3) //과목면제
						}
						this.dsSunSaveList.setColumn(i, "imsiSbjtCd", "선택1")
						this.dsSunSaveList.setColumn(i, "sbjtAplemScCd", rdoSbjtAplemScCd.value)
						
						if(this.dsSunSbjt.getColumn(ii, "sqeSbjtNo") == this.dsChcSbjt1.getColumn(j, "sqeSbjtNo")){
							edtBfrPassSbjtScr.set_value(this.dsChcSbjt1.getColumn(j, "bfrPassSbjtScr"))
							this.dsSunSaveList.setColumn(i, "bfrPassSbjtScr", this.dsChcSbjt1.getColumn(j,"bfrPassSbjtScr"));
							this.dsSunSaveList.setColumn(i, "bfrPassSbjtNo", this.dsChcSbjt1.getColumn(j,"bfrPassSbjtNo"));
							this.dsSunSaveList.setColumn(i, "passYr", this.dsChcSbjt1.getColumn(j,"passYr") == null || this.dsChcSbjt1.getColumn(j,"passYr") == "" ? "" : this.dsChcSbjt1.getColumn(j,"passYr"))
							this.dsSunSaveList.setColumn(i, "passTme", this.dsChcSbjt1.getColumn(j,"passTme") == null || this.dsChcSbjt1.getColumn(j,"passTme") == "" ? "" : this.dsChcSbjt1.getColumn(j,"passTme"))
							
							if(this.dsChcSbjt1.getColumn(j, "bfrPassSbjtScr") == null || this.dsChcSbjt1.getColumn(j, "bfrPassSbjtScr") == ""){
								edtBfrPassSbjtScr.set_value("0")
							}
						}
					}
				}

			}
			if(this.dsAcbgInfo.getColumn(0, "enfcYr") != "" && this.dsAcbgInfo.getColumn(0, "enfcYr") < 2013){
				this.dsSunSaveList.setColumn(i, "sqePirScCd", "22")
			}else{
				this.dsSunSaveList.setColumn(i, "sqePirScCd", "31")
			}
			
		}
			//선택과목2
		if(i == 1){
			for(var ii = 0; ii< this.dsSunSbjt.rowcount; ii++){
				if( this.dsSunSbjt.getColumn(ii,"sqePirScCd2") == "32" ){ //3교시(3-2)
					if(this.dsSunSbjt.getColumn(ii, "sqeChcEsntlScCd") == this.dsSunSbjtCnt.getColumn(i, "sqeChcEsntlScCd")){ //sqeChcEsntlScCd = 검정고시선택필수구분코드
						for(var j = 0; j < this.dsChcSbjt2.rowcount; j++){
							if(this.dsSunSbjt.getColumn(ii, "sqeSbjtNo") == this.dsChcSbjt2.getColumn(j, "sqeSbjtNo")){
								cboKornSbjtNm.set_value(this.dsSunSbjt.getColumn(ii, "sqeSbjtNo"))
								this.dsSunSaveList.setColumn(i, "sqeSbjtNo", cboKornSbjtNm.value)
								this.dsSunSaveList.setColumn(i, "kornSbjtNm", cboKornSbjtNm.text)
								
							}
						}
					}
				}
				if(this.dsSunSbjt.getColumn(ii, "sqeChcEsntlScCd") == this.dsSunSbjtCnt.getColumn(i, "sqeChcEsntlScCd")){	//**수정**
					for(var j = 0; j < this.dsChcSbjt2.rowcount; j++){
						if(this.dsSunSbjt.getColumn(ii, "sqeSbjtNo") == this.dsChcSbjt2.getColumn(j, "sqeSbjtNo") && this.dsChcSbjt2.getColumn(j, "sbjtAplemScCd") == "4"){
							rdoSbjtAplemScCd.set_value(4)
						}
						if(this.dsSunSbjt.getColumn(ii, "sqeSbjtNo") == this.dsChcSbjt2.getColumn(j, "sqeSbjtNo") && this.dsChcSbjt2.getColumn(j, "sbjtAplemScCd") == "1"){
							rdoSbjtAplemScCd.set_value(1)
						}
						if(this.dsSunSbjt.getColumn(ii, "sqeSbjtNo") == this.dsChcSbjt2.getColumn(j, "sqeSbjtNo") && this.dsChcSbjt2.getColumn(j, "sbjtAplemScCd") == "2"){
							rdoSbjtAplemScCd.set_value(2)
						}
						if(this.dsSunSbjt.getColumn(ii, "sqeSbjtNo") == this.dsChcSbjt2.getColumn(j, "sqeSbjtNo") && this.dsChcSbjt2.getColumn(j, "sbjtAplemScCd") == "3"){
							rdoSbjtAplemScCd.set_value(3)
						}
						
						if(this.dsSunSbjt.getColumn(ii, "sqeSbjtNo") == this.dsChcSbjt2.getColumn(j, "sqeSbjtNo")){
							edtBfrPassSbjtScr.set_value(this.dsChcSbjt2.getColumn(j, "bfrPassSbjtScr"))
							this.dsSunSaveList.setColumn(i, "bfrPassSbjtScr", this.dsChcSbjt2.getColumn(j,"bfrPassSbjtScr"));
							this.dsSunSaveList.setColumn(i, "bfrPassSbjtNo", this.dsChcSbjt2.getColumn(j,"bfrPassSbjtNo"));
							this.dsSunSaveList.setColumn(i, "passYr", this.dsChcSbjt2.getColumn(j,"passYr") == null || this.dsChcSbjt2.getColumn(j,"passYr") == "" ? "" : this.dsChcSbjt2.getColumn(j,"passYr"))
							this.dsSunSaveList.setColumn(i, "passTme", this.dsChcSbjt2.getColumn(j,"passTme") == null || this.dsChcSbjt2.getColumn(j,"passTme") == "" ? "" : this.dsChcSbjt2.getColumn(j,"passTme"))
							if(this.dsChcSbjt2.getColumn(j, "bfrPassSbjtScr") == null || this.dsChcSbjt2.getColumn(j, "bfrPassSbjtScr") == ""){
								edtBfrPassSbjtScr.set_value("0")
							}
						}
					}
				}
			}
			if(this.dsAcbgInfo.getColumn(0, "enfcYr") != "" && this.dsAcbgInfo.getColumn(0, "enfcYr") < 2013){
				this.dsSunSaveList.setColumn(i, "sqePirScCd", "23")
			}else{
				this.dsSunSaveList.setColumn(i, "sqePirScCd", "32")
			}
			this.dsSunSaveList.setColumn(i, "sbjtAplemScCd", this.divSbjt.form["rdoSunSbjtAplemScCd"+i].value == null || this.divSbjt.form["rdoSunSbjtAplemScCd"+i].value == "" ? "1" :  this.divSbjt.form["rdoSunSbjtAplemScCd"+i].value)
		}
			
			
			if(this.dsSunSbjt.rowcount == 0 || sunSbjtCnt == "" || sunSbjtCnt == null || this.dsChcSbjt2.rowcount == 0 || this.dsChcSbjt1.rowcount == 0){ //이상
				edtBfrPassSbjtScr.set_value("0")
			}
		
			if(this.dsAcbgInfo.getColumn(0,"grdtnExpelYmd") != ""){
				if(edtSubjectYnImsi.value == ""){
					edtSubjectYnImsi.set_value("없음")
					this.dsSunSaveList.setColumn(i,"subjectYnImsi", "없음")
				}
	
				if(edtBfrPassSbjtScr.value != "0"  && edtBfrPassSbjtScr.value != "" && edtBfrPassSbjtScr.value != undefined){
					edtSubjectYnImsi.set_value("있음") 
					this.dsSunSaveList.setColumn(i,"subjectYnImsi", "있음")
				}
			}
		}
	//초졸 end
	}else{ 
	//검정고시구분 : 중졸, 고졸	
	
		if(this.fv_param.sqeScCd == '2'){ //중졸 선택과목1개
			var end = this.dsSunSbjtCnt.rowcount;
		}else if(this.fv_param.sqeScCd == '3'){ //고졸 선택과목1 + 선택2
			var end = 2;
		}
		
		for(var i = 0; i < end; i++){ //선택과목 개수
		
			this.dsSunSaveList.addRow();
			//row초기화 undefiend를 "" 변경
			this.smfInitRow(this.dsSunSaveList, i);
			
			var top = this.dsPilSbjt.rowcount + i  //선택과목 div생성시 필요한 div위치 변수(필수과목개수 + 선택과목 시작하는 div순번)
		
			this.fnAddSunSbjtDiv(i, top) //컴포넌트생성
			
			this.dsSunSaveList.setColumn(i, "enfcYr", this.fv_param.enfcYr);
			this.dsSunSaveList.setColumn(i, "enfcTme", this.fv_param.enfcTme);
			this.dsSunSaveList.setColumn(i, "sqeScCd", this.fv_param.sqeScCd);
			this.dsSunSaveList.setColumn(i, "cddcCd", this.fv_param.cddcCd);
			this.dsSunSaveList.setColumn(i, "rcptNo", this.fv_param.rcptNo);
			
			if(!this.smfIsNull(this.dsChcSbjt1.getColumn(0,"passYr")) && i == 0){ //선택1
				this.dsSunSaveList.setColumn(i, "passYr", this.dsChcSbjt1.getColumn(0,"passYr"));
				this.dsSunSaveList.setColumn(i, "passTme", this.dsChcSbjt1.getColumn(0,"passTme"));
			}
			if(!this.smfIsNull(this.dsChcSbjt2.getColumn(0,"passYr")) && i == 1){ //선택2
				this.dsSunSaveList.setColumn(i, "passYr", this.dsChcSbjt2.getColumn(0,"passYr"));
				this.dsSunSaveList.setColumn(i, "passTme", this.dsChcSbjt2.getColumn(0,"passTme"));
				this.dsSunSaveList.setColumn(i, "bfrPassSbjtScr", this.dsChcSbjt2.getColumn(0,"bfrPassSbjtScr"));
				this.dsSunSaveList.setColumn(i, "bfrPassSbjtNo", this.dsChcSbjt2.getColumn(0,"bfrPassSbjtNo"));
		
			}

			
			if(i == 0){cboKornSbjtNm.set_displaynulltext("선택1")}
			else {cboKornSbjtNm.set_displaynulltext("선택2")}
			
			cboKornSbjtNm.set_initvalueid("ivCmbNormal")
			cboKornSbjtNm.set_codecolumn("sqeSbjtNo");
			cboKornSbjtNm.set_datacolumn("kornSbjtNm");
			cboKornSbjtNm.set_innerdataset("dsSunSbjt");
			
			var sunSbjtCnt = this.dsSunSbjtCnt.getColumn(0, "sqeChcEsntlScCd")
	
			if(this.dsSunSbjtCnt.getColumn(i, "sqeChcEsntlScCd") == "1"){ //sqeChcEsntlScCd : 1 (선택)
		
				for( var j = 0; j < this.dsSunSbjt.rowcount; j++){
					if(this.dsSunSbjt.getColumn(j, "sqeChcEsntlScCd") == this.dsSunSbjtCnt.getColumn(i, "sqeChcEsntlScCd")){
						for(var k = 0; k < this.dsChcSbjt.rowcount; k++){
							if(this.dsSunSbjt.getColumn(j , "sqeSbjtNo") == this.dsChcSbjt.getColumn(k, "sqeSbjtNo")){
								cboKornSbjtNm.set_value(this.dsSunSbjt.getColumn(j, "sqeSbjtNo"))
								this.dsSunSaveList.setColumn(i, "sqeSbjtNo", cboKornSbjtNm.value)
								this.dsSunSaveList.setColumn(i, "kornSbjtNm", cboKornSbjtNm.text)
								break;
							}
						}
					}
				}
			}
			
			
				//if(this.dsSunSbjtCnt.getColumn(i, "sqeChcEsntlScCd") == "2"){ //sqeChcEsntlScCd : 2 (선택||)
				if(i == 1){ //(선택||)
					cboKornSbjtNm.set_visible(false)
					if(this.dsChcSbjt2.rowcount > 0 ){ /*선택한과목이 있을경우*/
						if(this.dsChcSbjt2.getColumn(0,"bfrPassSbjtScr") == null || this.dsChcSbjt2.getColumn(0,"bfrPassSbjtScr") == ""){ //기합격점수없을때
							staKornSbjtNm.set_text("선택II 포함여부")
							this.dsSunSaveList.setColumn(i, "sqeSbjtNo", this.dsChcSbjt2.getColumn(0, "sqeSbjtNo"))
							this.dsSunSaveList.setColumn(i, "kornSbjtNm",  this.dsChcSbjt2.getColumn(0, "kornSbjtNm"))
							this.dsSunSaveList.setColumn(i, "subjectYnImsi", "없음")
							this.divSbjt.form["edtSunSubjectYnImsi"+i].set_value("없음")
						}else{
							staKornSbjtNm.set_text(this.dsChcSbjt2.getColumn(0, "kornSbjtNm"))
							this.dsSunSaveList.setColumn(i, "sqeSbjtNo", this.dsChcSbjt2.getColumn(0, "sqeSbjtNo"))
							this.dsSunSaveList.setColumn(i, "kornSbjtNm",  this.dsChcSbjt2.getColumn(0, "kornSbjtNm"))
							this.dsSunSaveList.setColumn(i, "subjectYnImsi", "있음")
							this.divSbjt.form["edtSunSubjectYnImsi"+i].set_value("있음")
						}
					}else{
						/*선택한과목이 없을경우 선택2 과목과 코드에 빈값 넣기*/
						this.dsSunSaveList.setColumn(i, "kornSbjtNm", "")
						this.dsSunSaveList.setColumn(i, "sqeSbjtNo", "")
					}
				}

				

				//라디오버튼
				for( var j = 0; j < this.dsSunSbjt.rowcount; j++){
					if(this.dsSunSbjt.getColumn(j, "sqeChcEsntlScCd") == this.dsSunSbjtCnt.getColumn(i, "sqeChcEsntlScCd")){
						for(var k = 0; k < this.dsChcSbjt.rowcount; k++){
							if(this.dsSunSbjt.getColumn(j, "sqeSbjtNo") == this.dsChcSbjt.getColumn(k, "sqeSbjtNo") && this.dsChcSbjt.getColumn(k, "sbjtAplemScCd") == "4"){
								rdoSbjtAplemScCd.set_value(4) //미응시
							}
							if(this.dsSunSbjt.getColumn(j, "sqeSbjtNo") == this.dsChcSbjt.getColumn(k , "sqeSbjtNo") && this.dsChcSbjt.getColumn(k, "sbjtAplemScCd") == "1"){
								rdoSbjtAplemScCd.set_value(1) //응시
							}
							if(this.dsSunSbjt.getColumn(j, "sqeSbjtNo") == this.dsChcSbjt.getColumn(k , "sqeSbjtNo") && this.dsChcSbjt.getColumn(k, "sbjtAplemScCd") == "2"){
								rdoSbjtAplemScCd.set_value(2) //기합격
							}
							if(this.dsSunSbjt.getColumn(j, "sqeSbjtNo") == this.dsChcSbjt.getColumn(k , "sqeSbjtNo") && this.dsChcSbjt.getColumn(k, "sbjtAplemScCd") == "3"){
								rdoSbjtAplemScCd.set_value(3) //과목면제
							}
							
							if(this.dsSunSbjt.getColumn(j, "sqeSbjtNo") == this.dsChcSbjt.getColumn(k, "sqeSbjtNo")){
							
								edtBfrPassSbjtScr.set_value(this.dsChcSbjt.getColumn(k, "bfrPassSbjtScr"))
								this.dsSunSaveList.setColumn(i, "bfrPassSbjtScr", this.dsChcSbjt.getColumn(k, "bfrPassSbjtScr"));
								this.dsSunSaveList.setColumn(i, "bfrPassSbjtNo", this.dsChcSbjt.getColumn(k, "bfrPassSbjtNo"));
								if(this.dsChcSbjt.getColumn(k, "bfrPassSbjtScr") == null || this.dsChcSbjt.getColumn(k, "bfrPassSbjtScr") == ""){
									edtBfrPassSbjtScr.set_value("0")
								}
							}
							
							
						}
					}			
				}
				this.dsSunSaveList.setColumn(i, "sbjtAplemScCd", this.divSbjt.form["rdoSunSbjtAplemScCd"+i].value == null || this.divSbjt.form["rdoSunSbjtAplemScCd"+i].value == "" ? "1" :  this.divSbjt.form["rdoSunSbjtAplemScCd"+i].value)

				//선택1 과목
				if(this.dsSunSbjtCnt.getColumn(i, "sqeChcEsntlScCd") == "1"){
					this.dsSunSaveList.setColumn(i, "imsiSbjtCd", "선택1")
				}
				
				
				//if(this.dsSunSbjtCnt.getColumn(i, "sqeChcEsntlScCd") == "2"){
				if(i == 1) { //선택||
				//선택||과목이 있을 경우, (포함/미포함) 중 선택 (dsCheckApply00)
					rdoSbjtAplemScCd.set_innerdataset("dsCheckApply00") // rdoSbjtAplemScCd == 4 : 미포함 , rdoSbjtAplemScCd == 2  포함
					rdoSbjtAplemScCd.set_value("4") 
					edtBfrPassSbjtScr.set_value("")
					this.dsSunSaveList.setColumn(i, "imsiSbjtCd", "선택2")
					this.dsSunSaveList.setColumn(i, "sbjtAplemScCd", "4")
					
					
				}

				if(this.dsSunSbjt.rowcount == 0 || sunSbjtCnt == "" || sunSbjtCnt == null || this.dsChcSbjt.rowcount == 0 || this.dsChcSbjt1.rowcount == 0){ //이상
					edtBfrPassSbjtScr.set_value("0")
				}
				
				if(this.dsAcbgInfo.getColumn(0,"grdtnExpelYmd") != ""){
		
					if(edtSubjectYnImsi.value == ""){
						edtSubjectYnImsi.set_value("없음")
						this.dsSunSaveList.setColumn(i,"subjectYnImsi", "없음")
					}
		
					if(edtBfrPassSbjtScr.value != "0"  && edtBfrPassSbjtScr.value != ""){
						edtSubjectYnImsi.set_value("있음") 
						this.dsSunSaveList.setColumn(i,"subjectYnImsi", "있음")
					}
				
				}
				
				if(this.dsSunSbjtCnt.getColumn(i, "sqeChcEsntlScCd") == "1"){
					this.dsSunSaveList.setColumn(i, "sqePirScCd", this.dsSunSbjt.getColumn(0,"sqePirScCd"))
				}
				
				//if(this.dsSunSbjtCnt.getColumn(i, "sqeChcEsntlScCd") == "2"){
				if(i == 1){ //선택2 일때
					this.dsSunSaveList.setColumn(i, "sqePirScCd", "08")
				}			
				
			
				if(this.dsAcbgInfo.getColumn(0, "sqeScCd") == "3"){ //고졸
				
					if(this.dsChcSbjt2.rowcount > 0 ){ /*선택한과목이 있을경우*/
						if(i == 1){ //선택2 일때
							if(this.dsChcSbjt2.getColumn(0,"bfrPassSbjtScr") == null || this.dsChcSbjt2.getColumn(0,"bfrPassSbjtScr") == ""){ //기합격점수없을때
								staKornSbjtNm.set_text("선택II 포함여부")
								this.dsSunSaveList.setColumn(i, "sqeSbjtNo", this.dsChcSbjt2.getColumn(0, "sqeSbjtNo"))
								this.dsSunSaveList.setColumn(i, "kornSbjtNm",  this.dsChcSbjt2.getColumn(0, "kornSbjtNm"))

							}else{
								staKornSbjtNm.set_text(this.dsChcSbjt2.getColumn(0, "kornSbjtNm"))
								this.dsSunSaveList.setColumn(i, "sqeSbjtNo", this.dsChcSbjt2.getColumn(0, "sqeSbjtNo"))
								this.dsSunSaveList.setColumn(i, "kornSbjtNm",  this.dsChcSbjt2.getColumn(0, "kornSbjtNm"))
							}
						}
						
					}
					
					if(this.dsChcSbjt2.rowcount == 0){
						staKornSbjtNm.set_text("선택II 포함여부")
					}
					
					//if(this.dsSunSbjtCnt.getColumn(i, "sqeChcEsntlScCd") == "2"){
					if(i == 1){ //선택||
					//선택||과목이 있을 경우, (포함/미포함) 중 선택 (dsCheckApply00)
						rdoSbjtAplemScCd.set_innerdataset("dsCheckApply00")
						rdoSbjtAplemScCd.set_value("4");
						this.dsSunSaveList.setColumn(i, "imsiSbjtCd", "선택2")
					}
					
					if(this.dsChcSbjt2.rowcount  > 0){ //선택과목 있을때
						if(i == 1){ //선택2일때
							if(this.dsChcSbjt2.getColumn(0, "sbjtAplemScCd") == "4" || this.dsChcSbjt2.getColumn(0, "sbjtAplemScCd") == "" || this.dsChcSbjt2.getColumn(0, "sbjtAplemScCd") == null){
								rdoSbjtAplemScCd.set_value("4"); //미포함
								this.dsSunSaveList.setColumn(i, "sbjtAplemScCd", "4")
								this.dsSunSaveList.setColumn(i, "passYr", this.dsChcSbjt2.getColumn(0, "passYr"))
								this.dsSunSaveList.setColumn(i, "passTme", this.dsChcSbjt2.getColumn(0, "passTme"))
							}
							if(this.dsChcSbjt2.getColumn(0, "sbjtAplemScCd") == "2" || this.dsChcSbjt2.getColumn(0, "sbjtAplemScCd") == "" || this.dsChcSbjt2.getColumn(0, "sbjtAplemScCd") == null){
								rdoSbjtAplemScCd.set_value("2");
								this.dsSunSaveList.setColumn(i, "sbjtAplemScCd", "2")
								this.dsSunSaveList.setColumn(i, "passYr", this.dsChcSbjt2.getColumn(0, "passYr"))
								this.dsSunSaveList.setColumn(i, "passTme", this.dsChcSbjt2.getColumn(0, "passTme"))
								this.dsSunSaveList.setColumn(i, "bfrPassSbjtScr", this.dsChcSbjt2.getColumn(0, "bfrPassSbjtScr"));
								this.dsSunSaveList.setColumn(i, "bfrPassSbjtNo", this.dsChcSbjt2.getColumn(0, "bfrPassSbjtNo"));
							}
							if(this.dsChcSbjt2.getColumn(0, "bfrPassSbjtScr") != "" && this.dsChcSbjt2.getColumn(0, "bfrPassSbjtScr") != null){
								edtBfrPassSbjtScr.set_value(this.dsChcSbjt2.getColumn(0, "bfrPassSbjtScr"))
							}else{
								edtBfrPassSbjtScr.set_value("0")
							}
						}
						
					}else{
						if(i == 1){  //선택2일때
							rdoSbjtAplemScCd.set_value("4");
							edtSubjectYnImsi.set_value("없음")
							edtBfrPassSbjtScr.set_value("0")
						}
					}
			} //고졸인경우
			
		} //선택과목구분코드(1,2..) end

	}//중졸, 고졸 end
};

/**
 * @description 팝업 콜백
 */
this.fnCommpopCallback = function(e, sender){
	//학교찾기 팝업 callback
	if(sender == this.divDetail.form.btnFdSch){ 
		var nRow = this.dsAcbgInfo.rowposition;

		this.dsAcbgInfo.setColumn(nRow, "shlNm", e.row.kornOrgNm);
		this.dsAcbgInfo.setColumn(nRow, "shlCd", e.row.orgCd);
		this.dsAcbgInfo.setColumn(nRow, "shlLctnAddr", e.row.zipAddr);
		
		this.divDetail.form.edtShlLctnAddr.set_value(e.row.zipAddr);
		this.divDetail.form.edtShlNm.set_value(e.row.kornOrgNm);
		
	//기합격과목 팝업	callback
	}else if(sender == this.divDetail.form.btnPassSbjt){

		this.iCnt = 0;
		this.iCnt00 = 0;
		
		var ds = e.ds;


		for(var i = 0 ; i < ds.rowcount; i++){

			var param = {
					enfcYr : ds.getColumn(i,"enfcYr"),
					enfcTme :ds.getColumn(i,"enfcTme"),
					sqeSbjtNo :ds.getColumn(i,"sqeSbjtNo"),
					kornSbjtNm : ds.getColumn(i,"kornSbjtNm"),
					sqeChcEsntlScCd : ds.getColumn(i,"sqeChcEsntlScCd"),
					sqeChcEsntlScNm : ds.getColumn(i,"sqeChcEsntlScNm"),
					sbjtScr : ds.getColumn(i,"sbjtScr"),
					sbjtDivCd : ds.getColumn(i,"sbjtDivCd"),
				 }
		 
			this.fnSetScore(param)
		}


//메세지줘야하나 ..	
// 		if (this.iCnt > 0 || this.iCnt00 > 0) {
// 			this.smfAlert("선택하신 기합격과목 중 응시 과목과 같지 않은 과목이 있습니다.\n 다시 한번 확인 바랍니다.");
// 			return false;
// 		}

		//this.dsMain.setColumn(nRow, "kornOrgNm2", e.row.kornOrgNm + " " + e.row.orgCd);
	}

	
};

/**
 * @description 다음버튼 클릭 시 callback
 */
this.fnNextCallback = function(){
	
	if(this.dsSbjtListYn.rowcount == 0 || this.dsSbjtListYn == null){
		this.smfAlert("학력과목정보를 입력하시고 저장버튼으로 저장을 하셔야\n고사장선택으로 이동하실수 있습니다.")
		return false;
		
	}else{
		var sqeScCd = this.dsAcbgInfo.getColumn(0,"sqeScCd")
		var acbgScCd = this.divDetail.form.cboAcbgScCd.value
		
		if(acbgScCd != ""){
		
			if(sqeScCd == "1"){
			
				if(acbgScCd == "801"){
					if(this.divDetail.form.calGrdtnExpelYmd.value == ""){
						this.smfAlert("졸업/제적/합격일자를 입력하셔야합니다.")
						this.divDetail.form.calGrdtnExpelYmd.setFocus();
						return false;
					}
					
				}

			}else if(sqeScCd != "1"){
					
					if(acbgScCd != "701" && acbgScCd != "601" && acbgScCd != "501" && acbgScCd != "801"){
						if(this.divDetail.form.edtShlLctnAddr.value == "" || this.divDetail.form.edtShlNm.value ==  "" 
							|| this.divDetail.form.cboShlLctnCtpvCd.value == "" || this.divDetail.form.calGrdtnExpelYmd.value == ""){
								this.smfAlert("졸업/제적/합격일자, 학교관할시도, 학교, 학교소재지를\n입력하셔야합니다.")
								return false;
						}
					}else if(acbgScCd == "501" || acbgScCd == "801"){
						if(this.divDetail.form.calGrdtnExpelYmd.value == ""){
							this.smfAlert("졸업/제적/합격일자를 입력하셔야합니다.")
							this.divDetail.form.calGrdtnExpelYmd.setFocus();
							return false;
						}
					}
				}
			//고사장선택 페이지 이동
			this.fnMoveNext();
			
		}else{
			this.smfAlert("필수 입력 또는 저장후 이동이 가능합니다.");
			return false;
		}
	}
}

/**
 * @description 저장완료 후 , 다음버튼 클릭 시 페이지이동
 */
this.fnMoveNext = function(){

	var params = {
					enfcYr :  this.dsAcbgInfo.getColumn(0,"enfcYr"),
					enfcTme : this.dsAcbgInfo.getColumn(0,"enfcTme"),
					sqeScCd : this.dsAcbgInfo.getColumn(0,"sqeScCd"),
					cddcCd : this.dsAcbgInfo.getColumn(0,"cddcCd"),
					rcptNo : this.dsAcbgInfo.getColumn(0,"rcptNo"),
					subTitle : this.imgSubTitle.text,
					sbmsnYn : this.fv_param.sbmsnYn
				};
			
	this.smfSetWorkPage("pa_sqa_oar_or::sqa_oaror04_m00.xfdl", params);
	
}
/**
 * @description 학력과목 저장
 */
this.fnSave = function()
{
	if(this.fnChkSaveValidation()){
	
		//검정고시 교시구분이 누락되어 검증코드 추가(SR00139237)
		for(var i = 0; i<this.dsSunSaveList.rowcount; i++){
			if(this.dsSunSaveList.getColumn(i, "kornSbjtNm") != "" && this.dsSunSaveList.getColumn(i, "sqePirScCd") == ""){
				this.smfAlert("선택과목 저장 중 문제가 발생하였습니다. 새로고침 후 재저장 부탁드립니다.");
				return false;
			} else if(this.dsSunSaveList.getColumn(i, "kornSbjtNm") != "" && this.dsSunSaveList.getColumn(i, "sqePirScCd") == undefined){
				this.smfAlert("선택과목 저장 중 문제가 발생하였습니다. 새로고침 후 재저장 부탁드립니다.");
				return false;
			}
		}
		
		this.smfConfirm("입력하신 정보를 저장하시겠습니까?\n\n저장하시면 다음단계로 이동합니다.", function(confirmParams){

			if(confirmParams.confirmResult){
// 				if(this.smfIsNull(this.divFile.form.divUpload01._FileGbnValue) && this.smfIsNull(this.divFile.form.divUpload02._FileGbnValue)
// 				&& this.smfIsNull(this.divFile.form.divUpload03._FileGbnValue) && this.smfIsNull(this.divFile.form.divUpload11._FileGbnValue)
// 				&& this.smfIsNull(this.divFile.form.divUpload12._FileGbnValue) && this.smfIsNull(this.divFile.form.divUpload13._FileGbnValue)) {
// 
// 					this.callSaveServie();
// 				}else{
					this.divFile.form.divFileUpload.form.fnFileUpload(); //파일저장 후 콜백 시점에 callSaveServie() 호출하여 정보 저장
//				}
			}else{
				return false;
				
			}
	
		})
	}
/*	this.smfConfirm("입력하신 정보를 저장하시겠습니까?\n\n저장하시면 다음단계로 이동합니다.", function(confirmParams){
			this.callSaveServie();
	});
*/
};
this.fnChkSaveValidation = function(){

	var sqeScCd = this.dsAcbgInfo.getColumn(0,"sqeScCd")
	var acbgScCd = this.divDetail.form.cboAcbgScCd.value

	if(this.smfIsNull(acbgScCd)){
		this.smfAlert("학력구분을 선택하여야 합니다.")
		this.divDetail.form.cboAcbgScCd.setFocus();
		return;
	}
	
	if(!this.smfIsNull(acbgScCd)){
		if(sqeScCd == "1"){

			if(acbgScCd == "801" || acbgScCd == "902"){ //801 기합격자(초졸), 902 정원외관리
				if(this.divDetail.form.calGrdtnExpelYmd.value == ""){
					this.smfAlert("졸업/제적/합격일자를 입력하셔야합니다.")
					this.divDetail.form.calGrdtnExpelYmd.setFocus();
					return false;
				}
			}

		}else if(sqeScCd != "1"){
				
				if(acbgScCd != "701" && acbgScCd != "601" && acbgScCd != "501" && acbgScCd != "801" && acbgScCd != "402"){ //701 외국, 601 의무취학면제자, 501 초졸검정고시합격, 801 기합격자(중졸)(고졸), 402 고등기술학교 각종학교 졸업예정
					if(this.divDetail.form.edtShlLctnAddr.value == "" || this.divDetail.form.edtShlNm.value ==  "" 
						|| this.divDetail.form.cboShlLctnCtpvCd.value == "" || this.divDetail.form.calGrdtnExpelYmd.value == ""){
							this.smfAlert("졸업/제적/합격일자, 학교관할시도, 학교, 학교소재지를\n입력하셔야합니다.")
							return false;
					}
				}else if(acbgScCd == "501" || acbgScCd == "801"){  //501 중졸검정고시합격, 801기합격자(중졸), 기합격자(고졸)
					if(this.divDetail.form.calGrdtnExpelYmd.value == ""){
						this.smfAlert("졸업/제적/합격일자를 입력하셔야합니다.")
						this.divDetail.form.calGrdtnExpelYmd.setFocus();
						return false;
					}
				}
		}
	}
	
	if(!this.smfIsNull(this.divDetail.form.calGrdtnExpelYmd.value) && !this.smfIsDate(this.divDetail.form.calGrdtnExpelYmd.value)){
		this.divDetail.form.calGrdtnExpelYmd.setFocus();
		this.smfAlert("올바른 날짜를 입력해 주세요.")
		return false;
	}
	
	this.dsAcbgInfo.setColumn(0, "acbgScCd", this.divDetail.form.cboAcbgScCd.value)
	this.dsAcbgInfo.setColumn(0, "shlLctnCtpvCd", this.divDetail.form.cboShlLctnCtpvCd.value)
	if(this.smfIsNull(this.divDetail.form.edtShlNm.value)){
			this.dsAcbgInfo.setColumn(0, "shlCd", "")
	}
	
	if(sqeScCd == "3"){ //고등학교만 적용
		for(var i = 0; i<this.dsSunSaveList.rowcount; i++){
	
			var bfrPassSbjtScr = this.dsSunSaveList.getColumn(i, "bfrPassSbjtScr")
			var sbjtAplemScCd = this.dsSunSaveList.getColumn(i,"sbjtAplemScCd")
			var subjectYnImsi = this.dsSunSaveList.getColumn(i,"subjectYnImsi")

			if(i == 1 && ((sbjtAplemScCd == "2" && bfrPassSbjtScr == "0") || (sbjtAplemScCd == "2" && subjectYnImsi == "없음"))){
				this.smfAlert("기합격 과목이 존재하지 않다면, 선택II과목 미포함을 선택해주세요.")
				return false;
			}	
		}
	}
	
	for(var i = 0; i<this.dsPilSaveList.rowcount; i++){ //필수과목 : 응시구분이 기합격(2) 일 때만 과목,점수 들어감
		if(this.divSbjt.form["rdoPilSbjtAplemScCd"+i].value == "2"){
			if(this.dsPilSaveList.getColumn(i,"bfrPassSbjtScr") < 60 || this.divSbjt.form["edtPilBfrPassSbjtScr"+i].value == 0){
				this.smfAlert("기합격과목 정보가 잘못입력되었습니다.\n다시 한번 확인해주십시오.")
				return false;
			}
		}
	}
	
	for(var i = 0; i<this.dsSunSaveList.rowcount; i++){

		if(this.dsSunSaveList.getColumn(i, "sqeSbjtNo") != ""){

			if(this.dsSunSaveList.getColumn(i, "sqeSbjtNo") == this.dsSunSaveList.getColumn(i+1, "sqeSbjtNo")){
				this.smfAlert("선택과목이 중복됩니다. 확인바랍니다.")
				return false;
			}
		}else{
			if(this.dsSunSaveList.getColumn(i, "imsiSbjtCd") == "선택2"){
				break;
			}else{
				this.smfAlert("선택과목 중 과목을 선택안한 목록이 있습니다.\n\n과목선택을 하셔야 저장이 가능합니다.");
				return false;
			}
		}
		
		if(this.divSbjt.form["rdoSunSbjtAplemScCd"+i].value == "2"){ //선택과목 : 응시구분이 기합격(2) 또는 포함(2) 일 때만 과목,점수 들어감
			if(this.dsSunSaveList.getColumn(i,"bfrPassSbjtScr") < 60 || this.divSbjt.form["edtSunBfrPassSbjtScr"+i].value == 0){
				this.smfAlert("기합격과목 정보가 잘못입력되었습니다.\n다시 한번 확인해주십시오.")
				return false;
			}
		}
	}
	
	// 2023-09-11 SR00089977 원서접수 첨부파일 필수 기능개선
	// 부산
	if(sqeScCd == "1"){
		if( acbgScCd != '901'){	// 진학사실없음(초등교육과정 미이수자) 이외는 최종학력증명서 필수
			if( this.divFile.form.divFileUpload.form.fnGetTotalFileCount() == 0){
				 this.smfAlert("[진학사실없음] 이외의 학력구분은 최종학력증명서를 필수로 첨부하시고 \n저장을 하셔야 합니다.\n\n서류첨부 후 저장하시기바랍니다.")
				return false;
			}
		}
	}

	if(this.dsAcbgInfo.getColumn(0,"sqeScCd") != "1"){
		if(this.divFile.form.divFileUpload.form.fnGetTotalFileCount() + this.divFile.form.divFileUpload1.form.fnGetTotalFileCount() == 0){
			 this.smfAlert("과목합격서류, 기타서류 중 하나는 필수로 첨부하시고 \n저장을 하셔야 합니다.\n\n서류첨부 후 저장하시기바랍니다.")
			 return false;
		}
		
	}

	return true;
}

this.callSaveServie = function(){

		//선택2 가 미포함 일 경우 dsSunSaveList에서 row삭제
		for(var i = 0; i < this.dsSunSaveList.rowcount; i++){
			if(this.divSbjt.form["rdoSunSbjtAplemScCd"+i].value == "4"){
				if(this.smfIsNull(this.dsSunSaveList.getColumn(i, "sqeSbjtNo")) || this.dsSunSaveList.getColumn(i, "sqeSbjtNo") == ""){
					this.dsSunSaveList.deleteRow(i);
				}
			}
		}

	
		// 서비스 객체 생성 
		this.smfSaveService("save")
		// 데이터 존재 필수
		.requireExistsData([this.dsPilSaveList,this.dsSunSaveList,this.dsAcbgInfo]) 
		// 데이터 변경 필수
		//.requireModifredData([this.dsPilSaveList, this.dsSunSaveList, this.dsAcbgInfo]) 
		// 데이터 검증
		.validateForm(this.divDetail)
		.showConfirm(false)
		
		.run()
		
		
		// 콜백
			.callback(function(callbackParams){
				if(callbackParams.errors) return;
				
				
				// 저장이 완료되었습니다.
				// 재조회
				this.smfAlert('PA072', ['저장'] , function(){
						this.fnMoveNext();
					});
			});
}

this.fnChkValidate = function(){
	if(this.smfIsUpdate(this.dsPilSaveList) || this.smfIsUpdate(this.dsSunSaveList) || this.smfIsUpdate(this.dsAcbgInfo)){ //정보 변경
		//정보 변경 있으면 저장하라는  메시지
		this.smfAlert("PA074", ["학력과목정보"]) //{0}를 저장 후 다음으로 이동하십시오.
		return false;
	
	}

	return true;
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
* 
*@description 필수과목 라디오버튼 클릭
*/
this.chkApply_onitemchanged = function(idx, obj, e)
{
	var sbjtAplemScCdVal 	= obj.value		//응시구분 라디오버튼값
	this.dsPilSaveList.setColumn(idx, "sbjtAplemScCd", sbjtAplemScCdVal) //응시구분
	var sqeSbjtNo			= this.dsPilSaveList.getColumn(idx, "sqeSbjtNo")
	
	//필요한과정인가.............?
	if(sqeSbjtNo == ""	|| sqeSbjtNo == "undefined"){
		for(var i = 0; i < this.dsPilSaveList.rowcount; i++){
			if(this.dsAcbgInfo.getColumn(0,"sqeScCd") == "1"){ //고등학교일경우 팝업창 띄우기 위해서
				sqeSbjtNo = this.dsSunSaveList.getColumn(idx, "sqeSbjtNo");
			}else{
				sqeSbjtNo = "2"
			}
		}
	}
	
	if(sbjtAplemScCdVal == "2"){ //기합격선택시
	
		var gubun = "필수";
		this.fnBfrPassSbjtSearch(sqeSbjtNo, idx, gubun)
		
	}else{
		this.dsPilSaveList.setColumn(idx, "bfrPassSbjtNo", "")
		this.dsPilSaveList.setColumn(idx, "bfrPassSbjtScr", "")
		this.dsPilSaveList.setColumn(idx, "passYr", "")
		this.dsPilSaveList.setColumn(idx, "passTme", "")
		this.dsPilSaveList.setColumn(idx, "subjectYnImsi", "없음")
		this.divSbjt.form["edtPilSubjectYnImsi"+idx].set_value("없음")
		this.divSbjt.form["edtPilBfrPassSbjtScr"+idx].set_value("0")
	}
};

/**
* 
*@description 선택과목 라디오버튼 클릭
*/
this.chkApply1_onitemchanged = function(idx, obj, e)
{

	var sqeSbjtNo;
	var sbjtAplemScCdVal 	= obj.value //라디오버튼값
	this.dsSunSaveList.setColumn(idx, "sbjtAplemScCd", sbjtAplemScCdVal)  //응시구분

	if(this.dsSunSaveList.getColumn(idx, "imsiSbjtCd") == "선택1"){ //선택1일떄
		if(this.dsAcbgInfo.getColumn(0,"sqeScCd") == "1"){  //초등학교
			sqeSbjtNo = this.dsSunSaveList.getColumn(idx, "sqeSbjtNo");
		}else{
			sqeSbjtNo = this.dsSunSaveList.getColumn(idx, "sqeSbjtNo");
		}
	}else{ //선택2일떄
		if(this.dsAcbgInfo.getColumn(0,"sqeScCd") == "1"){
			sqeSbjtNo = this.dsSunSaveList.getColumn(idx, "sqeSbjtNo");
		}else{
			sqeSbjtNo = "2"
		}
	}

	if(sbjtAplemScCdVal == "2"){ //기합격(포함)선택시
		var gubun = "선택";
		this.fnBfrPassSbjtSearch(sqeSbjtNo, idx, gubun) //기합격과목조회
	
	}else{  //기합격(포함) 외에 선택
		this.dsSunSaveList.setColumn(idx, "bfrPassSbjtNo", "")
		this.dsSunSaveList.setColumn(idx, "bfrPassSbjtScr", "")
		this.dsSunSaveList.setColumn(idx, "passYr", "")
		this.dsSunSaveList.setColumn(idx, "passTme", 0)
		this.dsSunSaveList.setColumn(idx, "subjectYnImsi", "없음")
		this.divSbjt.form["edtSunSubjectYnImsi"+idx].set_value("없음")
		this.divSbjt.form["edtSunBfrPassSbjtScr"+idx].set_value("0")
		if(sqeSbjtNo == "2"){
			if(this.dsSunSaveList.getColumn(idx,"imsiSbjtCd") == "선택2"){
				this.divSbjt.form["staSunKornSbjtNm"+idx].set_text("선택II 포함여부")
				this.divSbjt.form["rdoSunSbjtAplemScCd"+idx].set_value("4")
				this.dsSunSaveList.setColumn(idx,"sqeSbjtNo","")
			}
		}
	}
	

	
};
/**
* 
*@description 선택과목 콤보박스 선택 시
*/
this.saveSunSbjtList_onitemchanged = function(idx, obj, e){
		
	this.divSbjt.form["rdoSunSbjtAplemScCd" + idx].set_index("0")
	this.divSbjt.form["edtSunSubjectYnImsi" + idx].set_value("없음")
	this.divSbjt.form["edtSunBfrPassSbjtScr" + idx].set_value("0")
	
	this.dsSunSaveList.setColumn(idx, "sqeSbjtNo", obj.value)
	this.dsSunSaveList.setColumn(idx, "kornSbjtNm", obj.text)
	this.dsSunSaveList.setColumn(idx, "bfrPassSbjtScr", this.divSbjt.form["edtSunBfrPassSbjtScr" + idx].value)
	this.dsSunSaveList.setColumn(idx, "bfrPassSbjtNo", "")
	this.dsSunSaveList.setColumn(idx, "passYr", "")
	this.dsSunSaveList.setColumn(idx, "passTme", "")
	this.dsSunSaveList.setColumn(idx, "kornSbjtNm", obj.text)
	this.dsSunSaveList.setColumn(idx, "sqeSbjtNoImsi","")
	this.dsSunSaveList.setColumn(idx, "enfcYrImsi","")
	this.dsSunSaveList.setColumn(idx, "enfcTmeImsi","")
	this.dsSunSaveList.setColumn(idx, "sbjtAplemScCd", this.divSbjt.form["rdoSunSbjtAplemScCd" + idx].value) 
	//this.chkApply1_onitemchanged(idx,obj,nexacro.ItemChangeEventInfo)
	
}
