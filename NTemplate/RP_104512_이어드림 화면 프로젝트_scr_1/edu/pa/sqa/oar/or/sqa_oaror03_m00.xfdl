			shlLctnCtpvCd : this.divDetail.form.cboShlLctnCtpvCd.value, // 학교소재지시도코드(vachar 3)
			shlLctnCtpvCdNm : this.divDetail.form.cboShlLctnCtpvCd.text //관할시도교육청명
		
		},
	};

	// 모달팝업 실행
	this.smfDialog("_auto", "pa_sqa_oar_or::sqa_oaror03_p00.xfdl", popupParams);
};

