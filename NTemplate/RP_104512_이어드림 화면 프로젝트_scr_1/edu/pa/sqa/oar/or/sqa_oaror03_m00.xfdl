        <Static id="staTxt00" taborder="7" text="※ 응시구분에 [기합격]을 선택하시면 해당 과목은 응시하지 않게 됩니다.(기합격이더라도 응시를 원하시는 경우 [응시]를 선택해 주세요.)" left="0" cssclass="sta_WF_Red14" onclick="sta00_00_00_00_onclick" right="0" initvalueid="ivStcAccessibilityOn" top="divSbjt:2" height="25"/>
        <Static id="staTxt" taborder="8" text="※ 2015년 이전 선택 II 합격자가 해당 과목의 점수를 반영하고자 할 때에는 신청 과목을 포함하여 총 8개의 과목의 평균으로 합격 결정" left="0" cssclass="sta_WF_Red14" onclick="sta00_00_00_00_onclick" right="0" initvalueid="ivStcAccessibilityOn" top="staTxt00:5" height="25"/>
        <Div id="divFile" taborder="9" left="0" top="staTxt00:40" text="" cssclass="div_WF_Detail" initvalueid="ivDivAccessibilityOff" height="500" right="0">
          <Layouts>
            <Layout>
              <Static id="staFile0" taborder="0" left="3" cssclass="sta_WF_Input02Top" top="0" right="0" initvalueid="ivStcAccessibilityOff" text="" onclick="divFile_sta44_onclick" height="250" fittocontents="none"/>
              <Static id="sta0" taborder="1" left="0" width="200" cssclass="sta_WF_Input01Top" text="최종학력증명서 첨부&#13;&#10;(10MB이하  pdf/jpg/gif/png &#13;&#10;3개까지 첨부가능)" top="0" onclick="Static45_onclick" height="250" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00" taborder="2" text="※ 초졸은 정원외관리증명서 또는 미진학사실확인서, 중졸/고졸은 졸업(졸업예정)증명서, 제적증명서, &#13;&#10;     정원외관리증명서, 초졸/중졸 합격증명서, 학력인정서, 직전학교 졸업증명서 등 최종학력을 증명하는 서류 첨부&#13;&#10;&lt;fc v='red'&gt;※ 첨부파일 업로드 시 파일명(특수문자)및 암호화에 주의바라며 응시원서 및 수험표 출력이 불가능할 수 있습니다.&#13;&#10; ※ 제적증명서 및 정원외관리 증명서는 2024.01.20(토) 이후 발급된 증명서를 제출하도록 합니다.&lt;/fc&gt; " left="207" top="15" height="90" cssclass="sta_WF_Black14" onclick="Div03_sta00_onclick" initvalueid="ivStcAccessibilityOn" width="800" usedecorate="true"/>
              <Static id="staFile1" taborder="3" left="0" height="250" cssclass="sta_WF_Input02" top="staFile0:-1" right="0" initvalueid="ivStcAccessibilityOff" text="" onclick="divFile_staFile1_onclick"/>
              <Static id="sta1" taborder="4" left="0" width="200" cssclass="sta_WF_Input01" text="기타서류첨부&#13;&#10;(10MB이하  pdf/jpg/gif/png &#13;&#10;3개까지 첨부가능)" top="sta0:-1" onclick="Static45_onclick" height="250" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00" taborder="5" text="※ &lt;b v='true'&gt;기타서류&lt;/b&gt;를 업로드 해주시기 바랍니다.&lt;fc v='red'&gt;&#13;&#10;※ 첨부파일 등록 시 암호화 파일 업로드에 주의바라며 응시원서 및 수험표 출력이 불가능할 수 있습니다.&#13;&#10;※ 정원외 관리 증명서를 수기발급한 경우, 생활기록부 등 해당 학력을 증빙할 수 있는 서류를 함께 제출해주세요.&#13;&#10;(예시: 학교생활기록부 - 학적사항의 &quot;특기사항&quot;에 &quot;정원 외 학적관리&quot; 기재사항)&lt;/fc&gt; " left="207" top="staFile0:7" height="90" cssclass="sta_WF_Black14" onclick="Div03_sta00_onclick" initvalueid="ivStcAccessibilityOn" usedecorate="true" width="800"/>
              <Div text="div00" width="980" height="140" url="comm::comm_fileAdd.xfdl" Mode="upload" uploadLocation="PA.SQA.OAR" addProp="fnSetRaonProp" privInfoFiltYn="N" fileEncryptYn="Y" fileSaveStg="SV" fileInfSaveYn="Y" id="divFileUpload" left="210" top="108" taborder="6" enable="true" visible="true"/>
              <Div text="div00" width="980" height="138" url="comm::comm_fileAdd.xfdl" Mode="upload" uploadLocation="PA.SQA.OAR" addProp="fnSetRaonProp1" privInfoFiltYn="N" fileEncryptYn="Y" fileSaveStg="SV" fileInfSaveYn="Y" id="divFileUpload1" left="210" top="348" taborder="7" enable="true" visible="true"/>
            </Layout>
          </Layouts>
        </Div>
