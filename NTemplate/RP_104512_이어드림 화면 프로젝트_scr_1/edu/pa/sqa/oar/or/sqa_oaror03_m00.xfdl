		staStatic02.set_initvalueid("ivStcAccessibilityOff")
		this.divSbjt.addChild(staStatic02.name, staStatic02)
		staStatic02.show();
		
		staStatic03 = new Static("staStatic03"+n, "staStatic02"+n+":"+ -1, nTop, null, 42, 0, null)
