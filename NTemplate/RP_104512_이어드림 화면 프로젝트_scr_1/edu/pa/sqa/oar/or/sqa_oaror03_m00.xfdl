 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	// 업무콜백 처리
	this.smfAlert("응답결과 ==>"+e.row.Column0+", "+e.row.Column1+", "+e.row.Column2+", "+e.row.Column3);
};
/**
 * @description 졸업/제적일 이벤트
 */
this.divDetail_calGrdtnExpelYmd_onchanged = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{
	this.btnAdd.set_enable(true)
	this.btnNext.set_enable(true)
	
	var acbgScCd = this.divDetail.form.cboAcbgScCd.value;
	var grdtnExpelYmd = this.divDetail.form.calGrdtnExpelYmd.value;
	var pbancYmd = this.dsAcbgInfo.getColumn(0,"pbancYmd");

	if(!this.smfIsNull(grdtnExpelYmd) && !this.smfIsDate(grdtnExpelYmd)){
		this.divDetail.form.calGrdtnExpelYmd.setFocus();
		this.smfAlert("올바른 날짜를 입력해 주세요.")
		return false;
	}

	if(this.dsAcbgInfo.getColumn(0,"sqeScCd") == "1"){ //초등학교 응시자격제한
		if(acbgScCd == "104" && grdtnExpelYmd >= pbancYmd  //104 학업유예
			|| acbgScCd == "701" && grdtnExpelYmd >=  pbancYmd){ //701 외국
			this.smfAlert("시험 공고일 이후 학적이 정원외로 관리되신 경우 시험 응시가 불가합니다.");
			//응시자격제한 대상인 경우 다음 페이지 이동 못함.
			this.btnAdd.set_enable(false)
			this.btnNext.set_enable(false)
		}
		if (acbgScCd == "902" && grdtnExpelYmd  >= pbancYmd //902 정원외관리
			 || acbgScCd == "903" && grdtnExpelYmd  >= pbancYmd //903 면제자
			  || acbgScCd == "904" && grdtnExpelYmd  >= pbancYmd // 904 제적
			){
				this.smfAlert(this.dsAcbgInfo.getColumn(0,"pbancYmd")+"(공고일 기준) 이후 초등학교"+this.divDetail.form.cboAcbgScCd.text+"는 \n"+this.dsAcbgInfo.getColumn(0,"enfcYr") +"년도 "+this.dsAcbgInfo.getColumn(0,"enfcTme")+"회 초졸 검정고시에 응시가 불가합니다.");
				//응시자격제한 대상인 경우 다음 페이지 이동 못함.
				this.btnAdd.set_enable(false)
				this.btnNext.set_enable(false)
			}
			
	}else if(this.dsAcbgInfo.getColumn(0,"sqeScCd") == "2"){ //중학교 응시자격제한
		if (acbgScCd == "101" && grdtnExpelYmd  >= pbancYmd){// 101 초등학교 졸업자
				this.smfAlert("시험 공고일 이후 초등학교를 졸업하신 경우 시험 응시가 불가합니다.");
				//응시자격제한 대상인 경우 다음 페이지 이동 못함.
				this.btnAdd.set_enable(false)
				this.btnNext.set_enable(false)
			}
			if (acbgScCd == "204" && grdtnExpelYmd  >= pbancYmd){// 204 정원외관리
				this.smfAlert("시험 공고일 이후 정원외 관리자가 되신 경우 시험 응시가 불가합니다.");
				//응시자격제한 대상인 경우 다음 페이지 이동 못함.
				this.btnAdd.set_enable(false)
				this.btnNext.set_enable(false)
			}
			
	}else if(this.dsAcbgInfo.getColumn(0,"sqeScCd") == "3"){ //고등학교 응시자격제한
		
		var yy = pbancYmd.substr(0,4);
		var yy2 = pbancYmd.substr(0,4);
		var mm = pbancYmd.substr(4,2)-6;
		var mm2 = pbancYmd.substr(4,2);
		var dd = pbancYmd.substr(6,2);

		if (mm <= 0){
			yy = this.smfStr(yy-1);
			mm =12+mm;
		}else{
			yy = this.smfStr(yy);
		}
	

		if (mm < 10){
			mm = this.smfLPad(mm,"0",2)
		}

		if (dd < 10){
			dd = this.smfLPad(dd,"0",2)
		}
		
		var noticYmdDtm = yy+mm+dd
		var noticYmdDtm2 = yy2+mm2+dd

		if ((acbgScCd == "201" && grdtnExpelYmd  >= noticYmdDtm2      // 중학교졸업
			|| acbgScCd == "401" && grdtnExpelYmd  >= noticYmdDtm2 )  // 고등기술 각종학교졸
	//		|| acbgScCd == "402" && grdtnExpelYmd  >= noticYmdDtm2  // 고등기술 각종학교졸업예정 (제외)
			){
			this.smfAlert("시험 공고일 이후 졸업하신 경우 시험 응시가 불가합니다.");
			//응시자격제한 대상인 경우 다음 페이지 이동 못함.
			this.btnAdd.set_enable(false)
			this.btnNext.set_enable(false)
		}
		if(this.dsAcbgInfo.getColumn(0,"dltYn") == "N"){
			if ((acbgScCd == "313" && grdtnExpelYmd  > noticYmdDtm      // 고등학교 1년퇴
				|| acbgScCd == "323" && grdtnExpelYmd  > noticYmdDtm   // 고등학교 2년퇴
				|| acbgScCd == "333" && grdtnExpelYmd  > noticYmdDtm )  // 고등학교 3년퇴
				){
				this.smfAlert("기준일(공고일로부터  6개월 전) 이후에 제적이 되신 경우 응시자격이 제한됩니다.\n\n해당 교육청으로 문의 후 진행해 주시기 바랍니다.");
				//응시자격제한 대상인 경우 다음 페이지 이동 못함.
				this.btnAdd.set_enable(false)
				this.btnNext.set_enable(false)
			}
		}
	}
	
	this.dsAcbgInfo.setColumn(0, "acbgScCd", this.divDetail.form.cboAcbgScCd.value)
	this.dsAcbgInfo.setColumn(0, "grdtnExpelYmd", grdtnExpelYmd)
};


/**
 * @description 기합격과목 팝업
 */
this.divSbjt_btnPassSbjt_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	var sbjtCd = obj == "2" ? "2" : "";
	//파라미터 obj 는 sbjtCd : 선택2 구분코드
	
	var popupParams = {
		callback: this.fnCommpopCallback, // 콜백함수 지정
		sender: this.divDetail.form.btnPassSbjt, // sender 지정
		//titlebar:false,  // 타이틀바를 표시하지 않는다.

		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: 'search',

			// 파라메터 전달 
			enfcYr : this.dsAcbgInfo.getColumn(0,"enfcYr"),
			enfcTme : this.dsAcbgInfo.getColumn(0,"enfcTme"),
			sqeScCd : this.dsAcbgInfo.getColumn(0,"sqeScCd"),
			rcptNo : this.dsAcbgInfo.getColumn(0,"rcptNo"),
			kornFlnm : this.dsAcbgInfo.getColumn(0,"kornFlnm"),
			cddcCd : this.dsAcbgInfo.getColumn(0,"cddcCd"),
			ygGubun : "1",
			popupDiv : "1",
			kornOrgNm: "--",
			sqeSbjtNo : sbjtCd
		
		},
	};
	// 모달팝업 실행
	this.smfDialog("_auto", "pa_sqa_oar_or::sqa_oaror03_p01.xfdl", popupParams);

};
/**
 * @description 기합격과목 조회
 */
this.fnBfrPassSbjtSearch= function(sbjtCd,idx,gubun)
{
	this.dsBfrSbjtList.clearData();
	this.dsSearch.addRow();
	this.dsSearch.setColumn(0, "ygGubun" ,"1")
	this.dsSearch.setColumn(0, "enfcYr", this.dsAcbgInfo.getColumn(0,"enfcYr"))
	this.dsSearch.setColumn(0, "enfcTme", this.dsAcbgInfo.getColumn(0,"enfcTme"))
	this.dsSearch.setColumn(0, "sqeScCd", this.dsAcbgInfo.getColumn(0,"sqeScCd"))
	this.dsSearch.setColumn(0, "rcptNo",  this.dsAcbgInfo.getColumn(0,"rcptNo"))
	this.dsSearch.setColumn(0, "cddcCd",  this.dsAcbgInfo.getColumn(0,"cddcCd"))
	this.dsSearch.setColumn(0, "sqeSbjtNo",  sbjtCd)
	this.smfSearchService("selectBfrPassSbjt")
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.fnBfrPassCallback(sbjtCd, idx, gubun);
		});	
};

this.fnBfrPassCallback = function(sbjtCd, idx, gubun){

 if(this.dsBfrSbjtList.rowcount == 1) { //기합격과목이 1과목 인 경우 단건조회
	if(sbjtCd == "2"){
		var param = {
				enfcYr : this.dsBfrSbjtList.getColumn(0,"enfcYr"),
				enfcTme : this.dsBfrSbjtList.getColumn(0,"enfcTme"),
				sqeSbjtNo : this.dsBfrSbjtList.getColumn(0,"sqeSbjtNo"),
				kornSbjtNm :this.dsBfrSbjtList.getColumn(0,"kornSbjtNm"),
				sqeChcEsntlScCd : this.dsBfrSbjtList.getColumn(0,"sqeChcEsntlScCd"),
				sqeChcEsntlScNm :this.dsBfrSbjtList.getColumn(0,"sqeChcEsntlScNm"),
				sbjtScr : this.dsBfrSbjtList.getColumn(0,"sbjtScr"),
				sbjtDivCd : "2"
			 }
		this.fnSetScore(param);
	}else{
		var param = {
				enfcYr : this.dsBfrSbjtList.getColumn(0,"enfcYr"),
				enfcTme : this.dsBfrSbjtList.getColumn(0,"enfcTme"),
				sqeSbjtNo : this.dsBfrSbjtList.getColumn(0,"sqeSbjtNo"),
				kornSbjtNm :this.dsBfrSbjtList.getColumn(0,"kornSbjtNm"),
				sqeChcEsntlScCd : this.dsBfrSbjtList.getColumn(0,"sqeChcEsntlScCd"),
				sqeChcEsntlScNm :this.dsBfrSbjtList.getColumn(0,"sqeChcEsntlScNm"),
				sbjtScr : this.dsBfrSbjtList.getColumn(0,"sbjtScr"),
				sbjtDivCd : sbjtCd
			 }
		this.fnSetScore(param);
	}
 }else if( this.dsBfrSbjtList.rowcount >= 1){ //기합격과목이 1과목이상인 경우
 
	this.divSbjt_btnPassSbjt_onclick(sbjtCd); //기합격과목 팝업 호출
	
 }else{ //기합격과목이 없을 경우
	if(sbjtCd == "2"){
		if(gubun =="필수"){
			this.divSbjt.form["rdoPilSbjtAplemScCd"+idx].set_value("1");
			this.dsPilSaveList.setColumn(idx, "sbjtAplemScCd", "1")
		}else{
			this.divSbjt.form["rdoSunSbjtAplemScCd"+idx].set_value("1");
			this.dsSunSaveList.setColumn(idx, "sbjtAplemScCd", "1");
		}
		this.smfAlert("선택Ⅱ과목의 기합격 정보가 없습니다. 다시 확인하시기 바랍니다.")
		this.divSbjt.form["rdoSunSbjtAplemScCd"+idx].set_value("4");
		this.dsSunSaveList.setColumn(idx, "subjectYnImsi", "없음")
		this.dsSunSaveList.setColumn(idx, "sbjtAplemScCd", "4")
		this.divSbjt.form["edtSunSubjectYnImsi"+idx].set_value("없음")
		return false;
		
	}else{
		if(gubun =="필수"){
			this.divSbjt.form["rdoPilSbjtAplemScCd"+idx].set_value("1");
			this.dsPilSaveList.setColumn(idx, "sbjtAplemScCd", "1");
		}else{
			this.divSbjt.form["rdoSunSbjtAplemScCd"+idx].set_value("1");
			this.dsSunSaveList.setColumn(idx, "sbjtAplemScCd", "1");
		}
		this.smfAlert("기합격과목이 아닙니다. 기합격과목 유무를 확인바랍니다!")
		return false;
	}
 }

}
/**
 * @description 기합격과목 정보 받은 후 그리드에 셋팅
 */
this.fnSetScore = function(param){
	var flag = "N";
	var flag00 = "N";


//필수과목
	for(var i = 0; i < this.dsPilSaveList.rowcount; i++){
		if(this.divSbjt.form["edtPilSubjectYnImsi"+i].value == ""){
			this.dsPilSaveList.setColumn(i, "subjectYnImsi","없음")
			this.divSbjt.form["edtPilSubjectYnImsi"+i].set_value("없음")
			this.divSbjt.form["rdoPilSbjtAplemScCd"+i].set_value("1")
		}
		if(this.divSbjt.form["edtPilBfrPassSbjtScr"+i].value != "" 
			&& this.divSbjt.form["edtPilBfrPassSbjtScr"+i].value != "0"){
			this.dsPilSaveList.setColumn(i, "subjectYnImsi", "있음")
			}
	}
	//선택과목
	for(var i = 0; i < this.dsSunSaveList.rowcount; i++){
		if(this.divSbjt.form["edtSunSubjectYnImsi"+i].value == ""){
			this.dsSunSaveList.setColumn(i, "없음")
			this.divSbjt.form["edtSunSubjectYnImsi"+i].set_value("없음")
			this.divSbjt.form["rdoSunSbjtAplemScCd"+i].set_value("1")
		}
		if(this.divSbjt.form["edtSunBfrPassSbjtScr"+i].value != "" 
			&& this.divSbjt.form["edtSunBfrPassSbjtScr"+i].value != "0"){
			this.dsSunSaveList.setColumn(i, "있음")
			}
	}

	if(param.enfcYr.length != 0){
	
		if(param.sbjtDivCd != "2"){
			//if(param.sqeChcEsntlScCd == "필수"){
				for(var i = 0; i<this.dsPilSaveList.rowcount; i++){ //필수과목인경우
					if(this.dsPilSaveList.getColumn(i,"sqeSbjtNo") == param.sqeSbjtNo){
						var scr = param.sbjtScr
						this.divSbjt.form["edtPilSubjectYnImsi"+i].set_value("있음") 	//기합격과목 조회 시 기합격여부 값 변경
						this.divSbjt.form["rdoPilSbjtAplemScCd"+i].set_value("2")		//기합격과목 조회 후 응시구분(기합격) 변경
						this.divSbjt.form["edtPilBfrPassSbjtScr"+i].set_value(scr)		//기합격과목 조회 후 기합격점수 값 변경
																					
						this.dsPilSaveList.setColumn(i, "subjectYnImsi","있음")		//기합격여부임시
						this.dsPilSaveList.setColumn(i,"passYr",param.enfcYr)		//이전합격년도
						this.dsPilSaveList.setColumn(i,"passTme",param.enfcTme)		//이전합격회차
						this.dsPilSaveList.setColumn(i,"sqeSbjtNoImsi",param.sqeSbjtNo) //임시
						this.dsPilSaveList.setColumn(i,"sbjtAplemScCd","2")			//응시구분(기합격)
						this.dsPilSaveList.setColumn(i,"bfrPassSbjtScr",scr)		//이전합격점수				
						this.dsPilSaveList.setColumn(i, "bfrPassSbjtNo", param.sqeSbjtNo) //이전합격과목
						flag = "Y"

					}
				}
				//일치하는 과목이 없는 경우
				if(flag == "N"){
					this.iCnt++;
				}
				for(var i = 0; i<this.dsPilSaveList.rowcount; i++){
					if(this.divSbjt.form["edtPilSubjectYnImsi"+i].value == "없음"  && this.divSbjt.form["rdoPilSbjtAplemScCd"+i].value != "3" 
					&& this.divSbjt.form["rdoPilSbjtAplemScCd"+i].value != "4"){
						this.divSbjt.form["rdoPilSbjtAplemScCd"+i].set_value("1") //응시구분(응시)
						this.dsPilSaveList.setColumn(i,"sbjtAplemScCd","1")
					}
				}			

				
			//}
			//if(param.sqeChcEsntlScCd == "선택"){
				for(var i = 0; i<this.dsSunSaveList.rowcount; i++){ //선택과목인경우
					if(this.dsSunSaveList.getColumn(i,"sqeSbjtNo") == param.sqeSbjtNo){
						var scr = param.sbjtScr
					
						this.divSbjt.form["edtSunSubjectYnImsi"+i].set_value("있음")	//기합격과목 조회 후 기합격여부 값 변경
						this.divSbjt.form["rdoSunSbjtAplemScCd"+i].set_value("2")		//기합격과목 조회 후 응시구분(기합격) 변경
						this.divSbjt.form["edtSunBfrPassSbjtScr"+i].set_value(scr)		//기합격과목 조회 후 기합격점수 값 변경
						
						this.dsSunSaveList.setColumn(i, "subjectYnImsi","있음")				//기합격여부임시
						this.dsSunSaveList.setColumn(i,"passYr",param.enfcYr)				//이전합격년도
						this.dsSunSaveList.setColumn(i,"passTme",param.enfcTme)				//이전합격회차
						this.dsSunSaveList.setColumn(i,"sqeSbjtNoImsi",param.sqeSbjtNo)		//임시
						this.dsSunSaveList.setColumn(i,"sbjtAplemScCd","2")					//응시구분(기합격)
						this.dsSunSaveList.setColumn(i,"bfrPassSbjtScr",scr)				//이전합격점수				
						this.dsSunSaveList.setColumn(i, "bfrPassSbjtNo", param.sqeSbjtNo) 	//이전합격과목
						flag00 = "Y"
					}
				}
				//일치하는 과목이 없는 경우
				if(flag00 == "N"){
					this.iCnt00++;
				}
				
				for(var i = 0; i<this.dsSunSaveList.rowcount; i++){
					if(this.divSbjt.form["edtSunSubjectYnImsi"+i].value == "없음" && this.divSbjt.form["rdoSunSbjtAplemScCd"+i].value != "3" 
					&& this.divSbjt.form["rdoSunSbjtAplemScCd"+i].value != "4"){
						this.divSbjt.form["rdoSunSbjtAplemScCd"+i].set_value("1") //응시구분(응시)	
						this.dsSunSaveList.setColumn(i,"sbjtAplemScCd","1")
					}
				}
			//}
		}
		
		if(param.sbjtDivCd == "2"){ //선택2일경우만 따로 처리
			
			for(var i = 0; i<this.dsSunSaveList.rowcount; i++){ //선택과목인경우
				if(this.dsSunSaveList.getColumn(i,"sqeSbjtNo") == param.sqeSbjtNo || i == 1 && this.divSbjt.form["rdoSunSbjtAplemScCd"+i].value == "2"){
					this.divSbjt.form["edtSunSubjectYnImsi"+i].set_value("있음")
					this.divSbjt.form["staSunKornSbjtNm"+i].set_text(param.kornSbjtNm)
					this.divSbjt.form["rdoSunSbjtAplemScCd"+i].set_value("2")
					
					this.dsSunSaveList.setColumn(i, "subjectYnImsi","있음")				//기합격여부임시
					this.dsSunSaveList.setColumn(i,"enfcYrImsi",param.enfcYr)
					this.dsSunSaveList.setColumn(i,"enfcTmeImsi",param.enfcTme)
					this.dsSunSaveList.setColumn(i,"sqeSbjtNoImsi",param.sqeSbjtNo)
					this.dsSunSaveList.setColumn(i,"passYr",param.enfcYr)
					this.dsSunSaveList.setColumn(i,"passTme",param.enfcTme)
					this.dsSunSaveList.setColumn(i,"sqeSbjtNo",param.sqeSbjtNo)
					this.dsSunSaveList.setColumn(i,"bfrPassSbjtNo",param.sqeSbjtNo)
					var scr = param.sbjtScr
					this.divSbjt.form["edtSunBfrPassSbjtScr"+i].set_value(scr)
					this.dsSunSaveList.setColumn(i,"bfrPassSbjtScr",scr)
					flag00 = "Y"
				}
			}
			//일치하는 과목이 없는 경우
			if(flag00 == "N"){
				this.iCnt00++;
			}
		}
	}
}





