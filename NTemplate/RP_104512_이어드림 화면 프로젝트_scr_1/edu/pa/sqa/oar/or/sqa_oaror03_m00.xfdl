    <Script type="xscript5.1"><![CDATA[
/**
*  
*  @MenuPath    대국민 검정고시서비스 원서접수-학력과목정보
*  @FileName 	sqa_oaror03_m00.xfdl 
*  @Creator 	박가혜
*  @CreateDate 	2022.06.14
*  @Desction    학력과목정보
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.06.14           박가혜					최초 생성 
*  2024.10.23			진승환					범정부 UI/UX 가이드라인 적용 (버튼명 변경, 안내문구 추가)
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.fv_param;
this.dsForwardParam;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frm01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	
	
	// 폼을 초기화
	this.smfInitForm(obj);
	this.dsSelectExmhYn.addRow();

	//=======================================
	// 업로드관련 초기설정을 한다.
	//=======================================
	// 업로드시 저장위치등을 판별할 정보 세팅(대문자 : 시스템코드(2)+"."+서브시스템코드(3)+"."+대분류코드(3))
	this.divFile.form.divFileUpload.UPLOAD_CreateComplete = this.fnEventUploadCreateComplete;  // 필요한 경우만 세팅
	this.divFile.form.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;        // 필요한 경우만 세팅(세팅권장)
	this.divFile.form.divFileUpload.UPLOAD_OnError        = this.fnEventUploadError;           // 필요한 경우만 세팅(세팅권장)
	this.divFile.form.divFileUpload.UPLOAD_AfterAddFile   = this.fnEventAfterAddFile;           // 필요한 경우만 세팅(세팅권장)
	this.divFile.form.divFileUpload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)                    
	
	this.divFile.form.divFileUpload1.UPLOAD_CreateComplete = this.fnEventUploadCreateComplete1;  // 필요한 경우만 세팅
	this.divFile.form.divFileUpload1.UPLOAD_UploadComplete = this.fnEventUploadComplete1;        // 필요한 경우만 세팅(세팅권장)
	this.divFile.form.divFileUpload1.UPLOAD_OnError        = this.fnEventUploadError1;           // 필요한 경우만 세팅(세팅권장)
	this.divFile.form.divFileUpload1.UPLOAD_AfterAddFile   = this.fnEventAfterAddFile1;           // 필요한 경우만 세팅(세팅권장)
	this.divFile.form.divFileUpload1.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)   
	
	//=======================================
	// 업로드관련 초기설정 끝.
	//=======================================
	
	
	// 파라메터 세팅
	this.fv_param = this.smfGetFormParams();
	this.fnSetInitParam(this.smfGetFormParams());
	
	this.fv_sqeScCd = this.fv_param.sqeScCd;
	this.fv_menuId =this. fv_param.menuId;

	this.dsSearch.addRow();
			
	this.dsSearch.setColumn(0, "enfcYr", this.fv_param.enfcYr);
	this.dsSearch.setColumn(0, "enfcTme", this.fv_param.enfcTme);
	this.dsSearch.setColumn(0, "sqeScCd", this.fv_param.sqeScCd);
	this.dsSearch.setColumn(0, "cddcCd", this.smfGetSessionValue("cddcCd"));
	this.dsSearch.setColumn(0, "rcptNo", this.fv_param.rcptNo);
		
	
	//제출여부에 따라 상단 스탭박스 이동가능 여부 설정(제출한적 있는경우 자유이동가능, 첫 작성인 경우 이동 못함)
	if(this.fv_param.sbmsnYn == "N") {
		this.div00.form.btnOarOr03.removeEventHandler("onclick", this.fnStep_onclick, this)
		this.div00.form.btnOarOr02.set_enable(false)
		this.div00.form.btnOarOr04.set_enable(false)
		this.div00.form.btnOarOr05.set_enable(false)
		this.div00.form.btnOarOr05.set_text("제출(미제출)")
	}
	if(this.fv_param.sbmsnYn == "Y") {
	
		this.div00.form.btnOarOr05.set_text("제출(완료)")
	}
	
	// 공통코드 (교육청)
	this.smfCodeList("code", [this.dsCddcScCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;	
			for(var i = 1; i < this.dsCddcScCd.rowcount; i++){
				this.dsCddcScCd.setColumn(i, "unyCdValue", this.dformat("{unyCdValue}", this.dsCddcScCd, i));
			}
			this.fnInitData();
		})		
		.run()
	;
	
	 // 서버단에 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
			url: "/sqa_oar_or03_000.do",
		})
		.mappingRulesetToForm(this.divDetail, "acbgInfo")
		.run() 
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		})
	; 

	if(this.fv_param.sqeScCd == "3"){
		this.staTxt.set_visible(true)
		this.divFile.set_top("staTxt:5px")
	}else{
		this.staTxt.set_visible(false)
		this.divFile.set_top("staTxt00:5px")
	}
	
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 초기데이터 호출 (과목정보, 학력정보)
 */
this.fnInitData = function()
{
	
	this.smfSearchService("listSbjt")
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.fnSetData();
		});	
};


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd == -1) return;
};



/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 초기데이터 셋팅(학력정보, 과목정보)
 */
this.fnSetData = function(){

	this.dsAcbgInfo.set_updatecontrol(false);	
	this.dsPilSaveList.set_updatecontrol(false);
	this.dsSunSaveList.set_updatecontrol(false);
	
	
	/****학력정보 div세팅 start****/
	var title =  this.dsAcbgInfo.getColumn(0,"enfcYr") + "년도 " + this.dsAcbgInfo.getColumn(0,"enfcTme") + "회차 " + this.dsAcbgInfo.getColumn(0, "sqeScCdNm");
	this.imgSubTitle.set_text(title)

	if(this.dsAcbgInfo.getColumn(0, "acbgScCd") != null || this.dsAcbgInfo.getColumn(0, "acbgScCd") != ""){
		this.divDetail.form.cboAcbgScCd.set_value(this.dsAcbgInfo.getColumn(0, "acbgScCd"));
		this.divDetail_cboAcbgScCd_onitemchanged(this.divDetail.form.cboAcbgScCd,nexacro.ItemChangeEventInfo);
	}

	if(this.dsAcbgInfo.getColumn(0, "grdtnExpelYmd") != null || this.dsAcbgInfo.getColumn(0, "grdtnExpelYmd") != ""){
		this.divDetail.form.calGrdtnExpelYmd.set_value(this.dsAcbgInfo.getColumn(0, "grdtnExpelYmd"));
		this.divDetail_calGrdtnExpelYmd_onchanged(this.divDetail.form.calGrdtnExpelYmd,nexacro.ItemChangeEventInfo);
	}else{
		this.divDetail.form.calGrdtnExpelYmd.set_value("")
	}

	if(this.dsAcbgInfo.getColumn(0, "shlLctnCtpvCd") != null || this.dsAcbgInfo.getColumn(0, "shlLctnCtpvCd") != ""){
		this.divDetail.form.cboShlLctnCtpvCd.set_value(this.dsAcbgInfo.getColumn(0, "shlLctnCtpvCd"));
	}else{
		this.divDetail.form.cboShlLctnCtpvCd.set_value(this.smfGetCddcCode().substr(0,3))
	}

	

	/****학력정보 div세팅 End****/
	
	
	/****과목정보 div세팅 start****/
	//this.set_enableredraw(false);
		
	this.fnDisplaySbjtList(); //필수과목 셋팅
	this.fnDisplaySbjtListChc(); //선택과목 셋팅
		
	this.smfResetScroll(this.divSbjt.form) //div사이즈 최적화
	//this.set_enableredraw(true);
	/****과목정보 div세팅 End****/
	
	
	/****파일정보 div세팅 start****/
// 	if(!this.smfIsNull(this.dsOutFileInfo)){
 		this.fnSetFile();
// 	}
	/****파일정보 div세팅 End****/
	

	this.dsPilSaveList.set_updatecontrol(true);
	this.dsSunSaveList.set_updatecontrol(true);		
	this.dsAcbgInfo.set_updatecontrol(true);	

}



/**
 * @description 초중고 구분에 따른 필수 과목 컴포넌트 동적 생성 함수
 * 필수 과목 개수만큼 컴포넌트 생성
 */
this.fnAddPilSbjtDiv = function(i){

		var nTop = 83 + 42 * (i)  //높이

		//응시과목(필수과목) 생성
		staKornSbjtNm = new Static("staPilKornSbjtNm"+i, 0, nTop, 200, 42, null, null)
		staKornSbjtNm.set_cssclass("sta_WF_Input01");
		staKornSbjtNm.set_initvalueid("ivStcAccessibilityOn")
		staKornSbjtNm.set_text(this.dsPilSbjt.getColumn(i, "kornSbjtNm"));
		this.dsPilSaveList.setColumn(i, "sqeSbjtNo", this.dsPilSbjt.getColumn(i, "sqeSbjtNo"));
		this.dsPilSaveList.setColumn(i, "kornSbjtNm", this.dsPilSbjt.getColumn(i, "kornSbjtNm"));
		this.divSbjt.addChild(staKornSbjtNm.name, staKornSbjtNm);
		staKornSbjtNm.show();
		
		var bindItem1 = new BindItem();
		bindItem1.init("item1"+i,"this.divSbjt.form.staPilKornSbjtNm"+i, "text", "dsPilSaveList", "kornSbjtNm")
		this.divSbjt.addChild("item1"+i, bindItem1);
		bindItem1.bind();

		staStatic01 = new Static("staStatic01"+i, "staPilKornSbjtNm"+i+":"+ 0, nTop, 422, 42, null, null)
		staStatic01.set_cssclass("sta_WF_Input_Line");
		staStatic01.set_initvalueid("ivStcAccessibilityOn")
		this.divSbjt.addChild(staStatic01.name, staStatic01)
		staStatic01.show();
		
		staStatic02 = new Static("staStatic02"+i, "staStatic01"+i+":"+ -1, nTop, 330, 42, null, null)
		staStatic02.set_cssclass("sta_WF_Input_Line");
		staStatic02.set_initvalueid("ivStcAccessibilityOff")
		this.divSbjt.addChild(staStatic02.name, staStatic02)
		staStatic02.show();
		
		staStatic03 = new Static("staStatic03"+i, "staStatic02"+i+":"+ -1, nTop, null, 42, 0, null)
		staStatic03.set_cssclass("sta_WF_Input_Line");
		staStatic03.set_initvalueid("ivStcAccessibilityOff")
		this.divSbjt.addChild(staStatic03.name, staStatic03)
		staStatic03.show();
		
		//응시구분 라디오버튼생성
		rdoSbjtAplemScCd = new Radio("rdoPilSbjtAplemScCd"+i, 255, nTop+5, 345, 30)
		this.divSbjt.addChild(rdoSbjtAplemScCd.name, rdoSbjtAplemScCd)
		rdoSbjtAplemScCd.addEventHandler("onitemchanged",function(obj,e){
			this.chkApply_onitemchanged(i,obj,e);
		}
		,this);
		rdoSbjtAplemScCd.set_initvalueid("ivRdoNormal")
		rdoSbjtAplemScCd.set_codecolumn("sbjtAplemScCd")
		rdoSbjtAplemScCd.set_columncount("4")
		rdoSbjtAplemScCd.set_datacolumn("sbjtAplemScNm")
		rdoSbjtAplemScCd.set_innerdataset("dsCheckApply")
		rdoSbjtAplemScCd.set_value("1")
		rdoSbjtAplemScCd.show();
		
		var bindItem2 = new BindItem();
		bindItem2.init("item2"+i,"this.divSbjt.form.rdoPilSbjtAplemScCd"+i, "value", "dsPilSaveList", "sbjtAplemScCd")
		this.divSbjt.addChild("item2"+i, bindItem2);
		bindItem2.bind();
	
		//기합격과목 edit생성
		edtSubjectYnImsi = new Edit("edtPilSubjectYnImsi"+i, 626, nTop+5, 320, 30, null, null)
		subjectYnImsiObj = new Edit("subjectYnImsi"+i, 626, nTop+5, 320, 30, null, null) //기합격유무
		this.divSbjt.addChild(edtSubjectYnImsi.name, edtSubjectYnImsi)
		this.divSbjt.addChild(subjectYnImsiObj.name, subjectYnImsiObj)
		edtSubjectYnImsi.set_readonly(true)
		edtSubjectYnImsi.set_initvalueid("ivEdtReadOnly")
		subjectYnImsiObj.set_enable(false)
		subjectYnImsiObj.set_initvalueid("ivEdtAccessibilityOff")
		edtSubjectYnImsi.set_value("")
		subjectYnImsiObj.set_value("")
		edtSubjectYnImsi.show();
		
		var bindItem3 = new BindItem();
		bindItem3.init("item3"+i,"this.divSbjt.form.edtPilSubjectYnImsi"+i, "value", "dsPilSaveList", "subjectYnImsi")
		this.divSbjt.addChild("item3"+i, bindItem3);
		bindItem3.bind();
	
		//기합격과목 점수 edit생성
		edtBfrPassSbjtScr = new Edit("edtPilBfrPassSbjtScr"+i, 958, nTop+5, null, 30, 5, null)
		this.divSbjt.addChild(edtBfrPassSbjtScr.name, edtBfrPassSbjtScr)
		edtBfrPassSbjtScr.set_readonly(true)
		edtBfrPassSbjtScr.set_value("0")
		edtBfrPassSbjtScr.show();
		
		var bindItem4 = new BindItem();
		bindItem4.init("item4"+i,"this.divSbjt.form.edtPilBfrPassSbjtScr"+i, "value", "dsPilSaveList", "bfrPassSbjtScr")
		this.divSbjt.addChild("item4"+i, bindItem4);
		bindItem4.bind();
		
		
}
