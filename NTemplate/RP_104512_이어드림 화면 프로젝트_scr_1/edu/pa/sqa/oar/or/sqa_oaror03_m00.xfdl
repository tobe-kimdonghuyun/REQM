this.fnEventUploadComplete = function(obj,paramObj,objResultDataset)
{
// 
// 	this.dsOutFileInfo.copyData(objResultDataset);
// 	// 업로드 성공 후, newfile에 있는 파일들을 webfile로 옮긴다.
// 	this.divFile.form.divFileUpload.form.fnSetUploadCompleteState(obj,paramObj);	
// 
// 	// 업로드한 file을 가져오는 법(샘플 가이드)
// 	if(objResultDataset)
// 	{
// 		
// 		// 신규서비스
// 		trace("=== Sample : fnEventUploadComplete");	
// 		trace( "objResultDataset===========================\n" 
// 			 + objResultDataset.saveXML() 
// 			 + "\n==================================");
// 		
// 		
// 	
// 		trace("====업로드한 결과 데이터셋 ========== \n"+objResultDataset.saveXML());
// 		
// 		var sFileRefrnId = objResultDataset.getColumn(1,"fileRefrnId");
// 
// 		trace("====업로드한 결과 데이터셋 ========== \n"+objResultDataset.saveXML());
// 		trace("====업로드한 파일 개수 ========== \n"+objResultDataset.rowcount);
// 		
// 		// 나중에 다운로드하기 위해 관련 정보 세팅
// 		this.divFile.form.divUpload01._FileRefrnId = sFileRefrnId;
// 		this.divFile.form.divUpload02._FileRefrnId = sFileRefrnId;
// 		this.divFile.form.divUpload03._FileRefrnId = sFileRefrnId;	
// 		this.divFile.form.divUpload11._FileRefrnId = sFileRefrnId;
// 		this.divFile.form.divUpload12._FileRefrnId = sFileRefrnId;
// 		this.divFile.form.divUpload13._FileRefrnId = sFileRefrnId;
// 		
// 		
// 		//첫번째 과목파일은 응시자정보테이블에 저장하고, 나머지 파일들은 추가첨부파일테이블에 저장함(기타파일도 동일)
// 		this.fnSetSaveFile(); //저장할 파일 셋팅
// 	}else{
// 		
// 		
// 		this.fnSetSaveFile();
// 		
// 	}
// 
// 	return;
	// 신규서비스
	var listInfo = obj.GetListInfo("json");
	
	var nTotalCount = this.divFile.form.divFileUpload.form.fnGetTotalFileCount(); // 현재 파일 갯수
	var bExistUploadFile = this.divFile.form.divFileUpload.form.fnIsExistUploadFile(); // 업로드할 파일 존재 여부
	
	var jsonNew     = listInfo.newFile;			// 새로 업로드된 파일 정보
    var jsonDel     = listInfo.deleteFile;		// 삭제된 파일 정보
	var jsonMerge   = listInfo.mergeFile;
	var jsonWeb     = listInfo.webFile;
	
	// 업로드 성공 후, newfile에 있는 파일들을 webfile로 옮긴다.
	this.divFile.form.divFileUpload.form.fnSetUploadCompleteState(obj,paramObj);	
	
	// 업로드한 file을 가져오는 법(샘플 가이드)
	if(objResultDataset)
	{
		if (jsonNew) {
			var sFileRefrnId = objResultDataset.getColumn(0,"fileRefrnId");
			trace("====업로드한 결과 데이터셋 ========== \n"+objResultDataset.saveXML());
			
			var sFileRefrnId = objResultDataset.getColumn(0,"fileRefrnId");
			trace("업로드결과 데이터셋의 첫번째 row의 fileRefrnId=["+sFileRefrnId+"]");
			this.dsFileSave.setColumn(0, "sbjtFileRefrnId", sFileRefrnId);
		} else if (jsonDel && nTotalCount == 0){
			// 다 지운상태
			this.dsFileSave.setColumn(0, "sbjtFileRefrnId", "");
		} else {
			this.dsFileSave.setColumn(0, "sbjtFileRefrnId", jsonMerge.customValue[0].split(",")[1]);
		}
	}else{
		// 화면들어와서 첨부파일 컴포넌트 조작을 1도 안한 상태
		if (jsonMerge && jsonMerge.customValue.length > 0) {
			this.dsFileSave.setColumn(0, "sbjtFileRefrnId", jsonMerge.customValue[0].split(",")[1]);
		}
	}
	
	// 기타 업로드 호출
	this.divFile.form.divFileUpload1.form.fnFileUpload();
}
this.fnEventUploadComplete1 = function(obj,paramObj,objResultDataset)
{
	// 신규서비스
	var listInfo = obj.GetListInfo("json");
	
	var jsonNew     = listInfo.newFile;			// 새로 업로드된 파일 정보
    var jsonDel     = listInfo.deleteFile;		// 삭제된 파일 정보
	var jsonMerge   = listInfo.mergeFile;
	var jsonWeb     = listInfo.webFile;
	
	var nTotalCount = this.divFile.form.divFileUpload1.form.fnGetTotalFileCount(); // 현재 파일 갯수
	var bExistUploadFile = this.divFile.form.divFileUpload1.form.fnIsExistUploadFile(); // 업로드할 파일 존재 여부
	
	// 업로드 성공 후, newfile에 있는 파일들을 webfile로 옮긴다.
	this.divFile.form.divFileUpload1.form.fnSetUploadCompleteState(obj,paramObj);	
	
	// 업로드한 file을 가져오는 법(샘플 가이드)
	if(objResultDataset)
	{
		if (jsonNew) {
			trace("====업로드한 결과 데이터셋 ========== \n"+objResultDataset.saveXML());
			
			var sFileRefrnId = objResultDataset.getColumn(0,"fileRefrnId");
			trace("업로드결과 데이터셋의 첫번째 row의 fileRefrnId=["+sFileRefrnId+"]");
			this.dsFileSave.setColumn(0, "etcFileRefrnId", sFileRefrnId);
		} else if (jsonDel && nTotalCount == 0){
			// 다 지운상태
			this.dsFileSave.setColumn(0, "etcFileRefrnId", "");
		} else {
			this.dsFileSave.setColumn(0, "etcFileRefrnId", jsonMerge.customValue[0].split(",")[1]);
		}
	}else{
		// 화면들어와서 첨부파일 컴포넌트 조작을 1도 안한 상태
		if (jsonMerge && jsonMerge.customValue.length > 0) {
			this.dsFileSave.setColumn(0, "etcFileRefrnId", jsonMerge.customValue[0].split(",")[1]);
		}
	}
	
	this.fnSetSaveFile();
}

this.divSbjt_Static07_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	
};
]]></Script>
