		this.divSbjt.addChild("item01"+i, bindItem01);
		bindItem01.bind();
	
		//선택과목 기합격과목 edit생성
		edtSubjectYnImsi = new Edit("edtSunSubjectYnImsi"+i, 626, nTop+5, 320, 30, null, null)
		subjectYnImsiObj = new Edit("edtsubjectYnImsi"+i, 626, nTop+5, 320, 30, null, null) //기합격유무
		this.divSbjt.addChild(edtSubjectYnImsi.name, edtSubjectYnImsi)
		this.divSbjt.addChild(subjectYnImsiObj.name, subjectYnImsiObj)
		edtSubjectYnImsi.set_readonly(true)
		edtSubjectYnImsi.set_initvalueid("ivEdtReadOnly")
		subjectYnImsiObj.set_enable(false)
		subjectYnImsiObj.set_initvalueid("ivEdtAccessibilityOn")
