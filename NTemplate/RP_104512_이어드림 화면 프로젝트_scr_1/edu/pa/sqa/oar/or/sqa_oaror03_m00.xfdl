        <Button id="btnNext" taborder="11" text="다음" left="130" top="divFile:28" width="120" height="40" cssclass="btn_WF_FunctionN_B" enable="true" initvalueid="ivBtnAccessibilityLink" onclick="btnNext_onclick"/>
