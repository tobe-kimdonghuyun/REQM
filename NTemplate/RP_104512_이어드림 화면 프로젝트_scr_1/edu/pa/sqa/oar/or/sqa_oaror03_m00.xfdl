this.fnSetFile = function(){
	var sbjtFileRefrnId = this.dsAcbgInfo.getColumn(0,"sbjtFileRefrnId1");
	var etcFileRefrnId = this.dsAcbgInfo.getColumn(0,"etcFileRefrnId1");
	
	this.dsFileSave.setColumn(0, "sbjtFileRefrnId", sbjtFileRefrnId);
	this.dsFileSave.setColumn(0, "etcFileRefrnId", etcFileRefrnId);
	
	// 업로드 초기화
	this.divFile.form.divFileUpload.form.fnResetUpload();
		//파일Id가져와야 SV에 저장 후 UseYN update가능
	   this.transaction("fn_filesearch" // serviceId
				,"baseUrl::/cm_cmc_file_upload_001.do" // url
				,"" // inDataset
				,"dsOutFileInfo=atchFileinfo" // outDataset
				,"fileRefrnId='"+sbjtFileRefrnId+"'"
				,this.btnUpload_FileSearch_callback // callbackFunction
				,false // true: 비동기, false:동기
   );
	   
	
	   for (var i = 0; i < this.dsOutFileInfo.rowcount; i++) {
		        //trace("=== Sample : fnEventUploadComplete"+this.smfUploadInfoFileSn(jsonNew.responseCustomValue[i],0));	
				var responseCustomValue = "";
				var sDownloadUrl       = "";   // 
				var sPrivInfoFiltYn    = "";   // 항목 관리안함
				var sFileInfSaveYn     = "Y";  // 업무에 맞게 개발자가 세팅(Y/N)
				var sHandlerCode       = "PA.SQA.OAR";  //this.smfUploadInfoFileSn(jsonWebFile.customValue[i],0);
				var sFileSn            = this.dsOutFileInfo.getColumn(i,"fileRefrnId"   );
				var sFileSeq           = this.dsOutFileInfo.getColumn(i,"fileId"        );
				var sFileSize          = this.dsOutFileInfo.getColumn(i,"atchFileMg"    );
				var sBackendFilename   = this.dsOutFileInfo.getColumn(i,"atchFileGuid"  );
				var sForntendFilename  = this.dsOutFileInfo.getColumn(i,"atchFileNm"    );
				var sFileEncryptYn     = this.dsOutFileInfo.getColumn(i,"fileEncryptYn" );
				var sFileSaveStg       = this.dsOutFileInfo.getColumn(i,"fileSaveStg"   );
				var sDownloadUrl       = this.dsOutFileInfo.getColumn(i,"fileCoursNm"   );

				this.divFile.form.divFileUpload.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sForntendFilename, sFileSeq, sDownloadUrl
														  ,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn );
		}			
	
	
	// 업로드 초기화
	this.divFile.form.divFileUpload1.form.fnResetUpload();
		//파일Id가져와야 SV에 저장 후 UseYN update가능
	   this.transaction("fn_filesearch" // serviceId
				,"baseUrl::/cm_cmc_file_upload_001.do" // url
				,"" // inDataset
				,"dsOutFileInfo1=atchFileinfo" // outDataset
				,"fileRefrnId='"+etcFileRefrnId+"'"
				,this.btnUpload_FileSearch_callback // callbackFunction
				,false // true: 비동기, false:동기
   );
	   
	
	   for (var i = 0; i < this.dsOutFileInfo1.rowcount; i++) {
		        //trace("=== Sample : fnEventUploadComplete"+this.smfUploadInfoFileSn(jsonNew.responseCustomValue[i],0));	
				var responseCustomValue = "";
				var sDownloadUrl       = "";   // 
				var sPrivInfoFiltYn    = "";   // 항목 관리안함
				var sFileInfSaveYn     = "Y";  // 업무에 맞게 개발자가 세팅(Y/N)
				var sHandlerCode       = "PA.SQA.OAR";  //this.smfUploadInfoFileSn(jsonWebFile.customValue[i],0);
				var sFileSn            = this.dsOutFileInfo1.getColumn(i,"fileRefrnId"   );
				var sFileSeq           = this.dsOutFileInfo1.getColumn(i,"fileId"        );
				var sFileSize          = this.dsOutFileInfo1.getColumn(i,"atchFileMg"    );
				var sBackendFilename   = this.dsOutFileInfo1.getColumn(i,"atchFileGuid"  );
				var sForntendFilename  = this.dsOutFileInfo1.getColumn(i,"atchFileNm"    );
				var sFileEncryptYn     = this.dsOutFileInfo1.getColumn(i,"fileEncryptYn" );
				var sFileSaveStg       = this.dsOutFileInfo1.getColumn(i,"fileSaveStg"   );
				var sDownloadUrl       = this.dsOutFileInfo1.getColumn(i,"fileCoursNm"   );

				this.divFile.form.divFileUpload1.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sForntendFilename, sFileSeq, sDownloadUrl
														  ,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn );
		}
}

this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfConfirm("변경전 내역으로 재조회됩니다.\n\n변경전 내역으로 이동하시겠습니까? ",function(confirmParams){
		if(confirmParams.confirmResult){
			this.reload();
		}else{
			return false;
		}
	})
};









//////////////첨부파일공통//////////////////////////////////////////////////////
// KUpload를 생성시 지정할 property값을 지정
this.fnSetRaonProp = function()
{
	//  Property의 자세한 설명은 
	//  \12 나이스개발센터\17. 도입SW\01. 나이스클라우드\분리-06.파일 업로드 관리(RAON K Upload 2018)\raonkupload\sdk\index.html 참조 

	// 설정할 property
	var objAddRaonProps = {
								ExtensionAllowOrLimit : "1"        // 업로드 할 파일 확장자를 허용 또는 제한 설정("0":지정된 확장자를 제한(선택 금지) , "1":지정된 확장자만 허용(선택가능))
							,   ExtensionArr          : "pdf,jpg,gif,png"  // 제한 및 허용할 확장자명을 ",(콤마)"로 구분하여 설정
							,   AllowedZeroFileSize   : "1"        // 0byte 파일의 업로드를 허용 할지 설정합니다.(기본값은 "0" 허용안함이고, "1"로 설정시 허용입니다.)
							, 	MaxTotalFileCount	  : "3"			//업로드 할 최대 파일 개수 제한값을 설정합니다.
							,	MaxOneFileSize		  : "10MB"		//업로드할 때 파일당 용량제한을 설정합니다.
							,	MaxTotalFileSize	  : "30MB"		//업로드할 때 용량제한을 설정합니다.
						  };
						  
	return objAddRaonProps;
}
this.fnSetRaonProp1 = function()
{
	//  Property의 자세한 설명은 
	//  \12 나이스개발센터\17. 도입SW\01. 나이스클라우드\분리-06.파일 업로드 관리(RAON K Upload 2018)\raonkupload\sdk\index.html 참조 

	// 설정할 property
	var objAddRaonProps = {
								ExtensionAllowOrLimit : "1"        // 업로드 할 파일 확장자를 허용 또는 제한 설정("0":지정된 확장자를 제한(선택 금지) , "1":지정된 확장자만 허용(선택가능))
							,   ExtensionArr          : "pdf,jpg,gif,png"  // 제한 및 허용할 확장자명을 ",(콤마)"로 구분하여 설정
							,   AllowedZeroFileSize   : "1"        // 0byte 파일의 업로드를 허용 할지 설정합니다.(기본값은 "0" 허용안함이고, "1"로 설정시 허용입니다.)
							, 	MaxTotalFileCount	  : "3"			//업로드 할 최대 파일 개수 제한값을 설정합니다.
							,	MaxOneFileSize		  : "10MB"		//업로드할 때 파일당 용량제한을 설정합니다.
							,	MaxTotalFileSize	  : "30MB"		//업로드할 때 용량제한을 설정합니다.
						  };
						  
	return objAddRaonProps;
}
