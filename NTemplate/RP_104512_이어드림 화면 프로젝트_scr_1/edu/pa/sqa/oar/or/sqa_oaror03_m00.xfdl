/**
 * @description 학력구분 콤보박스 이벤트
 */
this.divDetail_cboAcbgScCd_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.btnAdd.set_enable(true)
	this.btnNext.set_enable(true)
	var acbgScCd = this.divDetail.form.cboAcbgScCd.value;
	var grdtnExpelYmd = this.divDetail.form.calGrdtnExpelYmd.value;
	var pbancYmd = this.dsAcbgInfo.getColumn(0,"pbancYmd");
	var sqeScCd = this.dsAcbgInfo.getColumn(0,"sqeScCd");
	
	if(obj.value == "901" || obj.value == "701" || obj.value == "601"){  //901 진학사실없음(초), 701 외국, 601 의무취학면제자(중)
		this.divDetail.form.edtShlLctnAddr.set_value("")
		this.divDetail.form.edtShlNm.set_value("")
		this.divDetail.form.calGrdtnExpelYmd.set_value("")
		this.divDetail.form.cboShlLctnCtpvCd.set_value("")
		this.divDetail.form.cboShlLctnCtpvCd.set_enable(false)
		this.divDetail.form.edtShlLctnAddr.set_enable(false)
		this.divDetail.form.edtShlNm.set_enable(false)
		this.divDetail.form.calGrdtnExpelYmd.set_enable(false)
		this.divDetail.form.btnFdSch.set_enable(false)

		this.smfClearRulesetToComponent(this.divDetail.form.calGrdtnExpelYmd);
		this.smfClearRulesetToComponent(this.divDetail.form.cboShlLctnCtpvCd);
		this.smfClearRulesetToComponent(this.divDetail.form.edtShlLctnAddr);
		this.smfClearRulesetToComponent( this.divDetail.form.edtShlNm);
		
		
	}else if(obj.value == "801"){ //기합격자(초,중,고)
			this.divDetail.form.edtShlLctnAddr.set_value("")
			this.divDetail.form.edtShlNm.set_value("")
			this.divDetail.form.calGrdtnExpelYmd.set_value(this.dsAcbgInfo.getColumn(0, "grdtnExpelYmd") == null || this.dsAcbgInfo.getColumn(0, "grdtnExpelYmd") == "" ? "" : this.dsAcbgInfo.getColumn(0, "grdtnExpelYmd"))
			this.divDetail.form.cboShlLctnCtpvCd.set_value("")
			this.divDetail.form.cboShlLctnCtpvCd.set_enable(false)
			this.divDetail.form.edtShlLctnAddr.set_enable(false)
			this.divDetail.form.edtShlNm.set_enable(false)
			this.divDetail.form.calGrdtnExpelYmd.set_enable(true)

			this.smfUpdateValidateToComponent("title:졸업/제적/합격일자,required", this.divDetail.form.calGrdtnExpelYmd);
			this.smfClearRulesetToComponent(this.divDetail.form.cboShlLctnCtpvCd);
			this.smfClearRulesetToComponent(this.divDetail.form.edtShlLctnAddr);
			this.smfClearRulesetToComponent( this.divDetail.form.edtShlNm);
			
			this.divDetail.form.btnFdSch.set_enable(false)
	}else if (obj.value == "402"){  // 고등기술 각종학교졸업예정 
			this.smfClearRulesetToComponent(this.divDetail.form.calGrdtnExpelYmd);
			this.smfClearRulesetToComponent(this.divDetail.form.cboShlLctnCtpvCd);
			this.smfClearRulesetToComponent(this.divDetail.form.edtShlLctnAddr);
			this.smfClearRulesetToComponent( this.divDetail.form.edtShlNm);
			
			this.divDetail.form.edtShlLctnAddr.set_value("")
			this.divDetail.form.edtShlNm.set_value("")
			this.divDetail.form.calGrdtnExpelYmd.set_value("")
			this.divDetail.form.cboShlLctnCtpvCd.set_value("")

	}else{ //제적, 면제,정원외관리
		this.smfClearRulesetToComponent(this.divDetail.form.calGrdtnExpelYmd);
		this.smfClearRulesetToComponent(this.divDetail.form.cboShlLctnCtpvCd);
		this.smfClearRulesetToComponent(this.divDetail.form.edtShlLctnAddr);
		this.smfClearRulesetToComponent( this.divDetail.form.edtShlNm);

		this.divDetail.form.cboShlLctnCtpvCd.set_enable(true)
		this.divDetail.form.edtShlLctnAddr.set_enable(true)
		this.divDetail.form.edtShlNm.set_enable(true)
		this.divDetail.form.calGrdtnExpelYmd.set_enable(true)

		if(obj.value == "902"){ //정원외관리(초)
			this.smfUpdateValidateToComponent("title:졸업/제적/합격일자,required", this.divDetail.form.calGrdtnExpelYmd);
			
		}else if(sqeScCd != "1"  && obj.value != "701" && obj.value != "601" && obj.value != "501" && !this.smfIsNull(obj.value)){

			this.smfUpdateValidateToComponent("title:졸업/제적/합격일자,required", this.divDetail.form.calGrdtnExpelYmd);
			this.smfUpdateValidateToComponent("title:학교관할시도,required", this.divDetail.form.cboShlLctnCtpvCd);
			this.smfUpdateValidateToComponent("title:학교소재지,required", this.divDetail.form.edtShlLctnAddr);
			this.smfUpdateValidateToComponent("title:학교명,required", this.divDetail.form.edtShlNm);
			
		}else if(obj.value == "501"){
			this.smfUpdateValidateToComponent("title:졸업/제적/합격일자,required", this.divDetail.form.calGrdtnExpelYmd);
			this.smfClearRulesetToComponent(this.divDetail.form.cboShlLctnCtpvCd);
			this.smfClearRulesetToComponent(this.divDetail.form.edtShlLctnAddr);
			this.smfClearRulesetToComponent( this.divDetail.form.edtShlNm);
			
		}
		
		this.divDetail.form.btnFdSch.set_enable(true) 

	}
	
	if(this.dsAcbgInfo.getColumn(0,"sqeScCd") == "1" && this.divDetail.form.calGrdtnExpelYmd.value != ""){ //초등학교 응시자격제한
	
		if(acbgScCd == "104" && grdtnExpelYmd >= pbancYmd  //104 학업유예
			|| acbgScCd == "701" && grdtnExpelYmd >=  pbancYmd){ //701 외국
			this.smfAlert("시험 공고일 이후 학적이 정원외로 관리되신 경우 시험 응시가 불가합니다.");
			//응시자격제한 대상인 경우 다음 페이지 이동 못함.
			this.btnAdd.set_enable(false)
			this.btnNext.set_enable(false)
		}
		if (acbgScCd == "902" && this.divDetail.form.calGrdtnExpelYmd.value  >= pbancYmd // 902 정원외관리
			 || acbgScCd == "903" && this.divDetail.form.calGrdtnExpelYmd.value  >= pbancYmd // 903 면제자
			 || acbgScCd == "904" && this.divDetail.form.calGrdtnExpelYmd.value  >= pbancYmd // 904 제적
			 
			){
				this.smfAlert(this.dsAcbgInfo.getColumn(0,"pbancYmd")+"(공고일 기준) 이후 초등학교"+this.divDetail.form.cboAcbgScCd.text+"은(는) \n"+this.dsAcbgInfo.getColumn(0,"enfcYr") +"년도 "+this.dsAcbgInfo.getColumn(0,"enfcTme")+"회 초졸 검정고시에 응시가 불가합니다.");
				//응시자격제한 대상인 경우 다음 페이지 이동 못함.
				this.btnAdd.set_enable(false)
				this.btnNext.set_enable(false)
			}
		
		
	}else if(this.dsAcbgInfo.getColumn(0,"sqeScCd") == "2" && this.divDetail.form.calGrdtnExpelYmd.value != ""){ //중학교 응시자격제한
	
		if (acbgScCd == "101" && grdtnExpelYmd  >= pbancYmd){// 101 초등학교 졸업자
				this.smfAlert("시험 공고일 이후 초등학교를 졸업하신 경우 시험 응시가 불가합니다.");
				//응시자격제한 대상인 경우 다음 페이지 이동 못함.
				this.btnAdd.set_enable(false)
				this.btnNext.set_enable(false)
			}
			if (acbgScCd == "204" && grdtnExpelYmd  >= pbancYmd){// 204 정원외관리
				this.smfAlert("시험 공고일 이후 정원외 관리자가 되신 경우 시험 응시가 불가합니다.");
				//응시자격제한 대상인 경우 다음 페이지 이동 못함.
				this.btnAdd.set_enable(false)
				this.btnNext.set_enable(false)
			}
	}else if(this.dsAcbgInfo.getColumn(0,"sqeScCd") == "3" && this.divDetail.form.calGrdtnExpelYmd.value != ""){ //고등학교 응시자격제한
		
		var yy = pbancYmd.substr(0,4);
		var yy2 = pbancYmd.substr(0,4);
		var mm = pbancYmd.substr(4,2)-6; //6개월전
		var mm2 = pbancYmd.substr(4,2);
		var dd = pbancYmd.substr(6,2);

		
		if (mm <= 0){
			yy = this.smfStr(yy-1);
			mm =12+mm;
		}else{
			yy = this.smfStr(yy);
		}
	

		if (mm < 10){
			mm = this.smfLPad(mm,"0",2)
		}

		if (dd < 10){
			dd = this.smfLPad(dd,"0",2)
		}
		
		var noticYmdDtm = yy+mm+dd
		var noticYmdDtm2 = yy2+mm2+dd

		if ((acbgScCd == "201" && grdtnExpelYmd  >= noticYmdDtm2      // 중학교졸업
			|| acbgScCd == "401" && grdtnExpelYmd  >= noticYmdDtm2)   // 고등기술 각종학교졸
	//		|| acbgScCd == "402" && grdtnExpelYmd  >= noticYmdDtm2    // 고등기술 각종학교졸업예정 (제외)
			){
			this.smfAlert("시험 공고일 이후 졸업하신 경우 시험 응시가 불가합니다.");
				//응시자격제한 대상인 경우 다음 페이지 이동 못함.
				this.btnAdd.set_enable(false)
				this.btnNext.set_enable(false)
		}
		if(this.dsAcbgInfo.getColumn(0,"dltYn") == "N"){
			if ((acbgScCd == "313" && grdtnExpelYmd  > noticYmdDtm      // 고등학교 1년퇴
				|| acbgScCd == "323" && grdtnExpelYmd  > noticYmdDtm   // 고등학교 2년퇴
				|| acbgScCd == "333" && grdtnExpelYmd  > noticYmdDtm)   // 고등학교 3년퇴
				){
				this.smfAlert("기준일(공고일로부터  6개월 전) 이후에 제적이 되신 경우 응시자격이 제한됩니다.\n\n해당 교육청으로 문의 후 진행해 주시기 바랍니다.");
						//응시자격제한 대상인 경우 다음 페이지 이동 못함.
					this.btnAdd.set_enable(false)
					this.btnNext.set_enable(false)
			}
		}
	}
	
	this.dsAcbgInfo.setColumn(0, "acbgScCd", this.divDetail.form.cboAcbgScCd.value)
	this.dsAcbgInfo.setColumn(0, "shlLctnCtpvCd", this.divDetail.form.cboShlLctnCtpvCd.value)
};
