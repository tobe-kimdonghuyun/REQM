        <Div id="div00_00" taborder="14" left="0" cssclass="div_WF_InfoBOX" top="btnAdd:70" initvalueid="ivDivAccessibilityOff" right="0" height="190" text="">
          <Layouts>
            <Layout>
              <Static id="sta00_00_01_01_00" taborder="0" left="29" top="28" height="23" cssclass="sta_WF_InfoTit" text="이용 전 확인해주세요." wordWrap="char" initvalueid="ivStcAccessibilityOn" width="220"/>
              <Static id="sta00_00_01_01" taborder="1" left="30" top="67" height="23" cssclass="sta_WF_InfoTxt_Blue" text="외국 학력 소지자는 온라인접수가 불가하오니, 교육청에서 지정한 원서 접수장에서 현장 접수&lt;fc v='#172f57'&gt;하시기 바랍니다.&lt;/fc&gt;" wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="30"/>
              <Static id="sta00_00_01_01_01_00" taborder="2" left="29" top="98" height="23" cssclass="sta_WF_InfoTxt_Blue" text="접수한 내역을 취소하시려면,  [step 04. 접수완료]페이지에서 &quot;응시원서 삭제&quot; 버튼을 클릭&lt;fc v='#172f57'&gt;하시기 바랍니다.&lt;/fc&gt;" wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="31"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divFileDownload" taborder="15" text="div00" left="1420" top="1140" height="180" url="comm::comp_fileDownload.xfdl" Mode="download" width="420"/>
        <Static id="sta00_00_01_01_01" taborder="16" left="820" top="302" height="23" cssclass="sta_WF_Red14" text="*표시된 항목은 필수 입력 사항입니다." wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="btnSample:12"/>
