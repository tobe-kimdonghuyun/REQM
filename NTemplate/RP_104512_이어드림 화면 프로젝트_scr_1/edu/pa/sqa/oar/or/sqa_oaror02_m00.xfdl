		},
	};

	// 모달팝업 실행
	this.smfDialog("_auto", "commpop::commpop_rdn_zip.xfdl", popupParams);
};
/**
 * @description 장애구분선택
 */
this.rdoDltYn_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	if(obj.value == "1") { //일반인
	
		this.divMain.form.cboRcgnDltScCd.set_enable(false);
		this.divMain.form.cboSqe1CnvAplyCd.set_enable(false);
		this.divMain.form.cboSqe2CnvAplyCd.set_enable(false);
		this.divMain.form.cboSqe3CnvAplyCd.set_enable(false);
		this.divMain.form.edtEtcCnvPvsnDmndCn.set_enable(false);
		
		this.divMain.form.chkCnvAplyCd.set_enable(false);
		this.divMain.form.chkCnvAplyCd.set_value(false)
		
		this.divMain.form.cboRcgnDltScCd.set_cssclass("");
		
		this.divMain.form.cboRcgnDltScCd.set_value("");
		this.divMain.form.cboSqe1CnvAplyCd.set_value("");
		this.divMain.form.cboSqe2CnvAplyCd.set_value("");
		this.divMain.form.cboSqe3CnvAplyCd.set_value("");
		this.divMain.form.edtEtcCnvPvsnDmndCn.set_value("");
		this.dsApplpInfo.setColumn(0,"dltYn","1");
		
	}else if (obj.value == "2"){ //장애인
	
		this.divMain.form.cboRcgnDltScCd.set_enable(true);
		this.divMain.form.cboSqe1CnvAplyCd.set_enable(true);
		this.divMain.form.cboSqe2CnvAplyCd.set_enable(true);
		this.divMain.form.cboSqe3CnvAplyCd.set_enable(true);
		//this.divMain.form.edtEtcCnvPvsnDmndCn.set_enable(true);
		this.divMain.form.chkCnvAplyCd.set_enable(true);
		
		this.divMain.form.cboRcgnDltScCd.set_cssclass("essential");
		
		this.dsApplpInfo.setColumn(0,"dltYn","2");
		
		/*
		if(this.divMain.form.cboRcgnDltScCd.value == ""){
			this.divMain.form.edtEtcCnvPvsnDmndCn.set_enable(false)
		}else{
			this.divMain.form.edtEtcCnvPvsnDmndCn.set_enable(true)
		}*/
		
	}

};

/**
 * @description 편의제공신청 없음 체크박스 선택
 */
this.divMain_chkCnvAplyCd_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	if(obj.isChecked()){ //체크할때

		this.divMain.form.cboSqe1CnvAplyCd.set_enable(false);
		this.divMain.form.cboSqe2CnvAplyCd.set_enable(false);
		this.divMain.form.cboSqe3CnvAplyCd.set_enable(false);
		this.divMain.form.edtEtcCnvPvsnDmndCn.set_enable(false);
		this.divMain.form.cboSqe1CnvAplyCd.set_value("")
		this.divMain.form.cboSqe2CnvAplyCd.set_value("")
		this.divMain.form.cboSqe3CnvAplyCd.set_value("")
		this.divMain.form.edtEtcCnvPvsnDmndCn.set_value("")
	}else if (!obj.isChecked()){ //체크풀때

		this.divMain.form.cboSqe1CnvAplyCd.set_enable(true);
		this.divMain.form.cboSqe2CnvAplyCd.set_enable(true);
		this.divMain.form.cboSqe3CnvAplyCd.set_enable(true);
		
		if(this.divMain.form.cboRcgnDltScCd.value == "07"){ //장애유형 기타인 경우에만 열기
			this.divMain.form.edtEtcCnvPvsnDmndCn.set_enable(true);
		}
		
	}
	
};
//장애유형 07(기타)인 경우
this.divMain_cboRcgnDltScCd_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	if(obj.value == "07"){
		if(this.divMain.form.chkCnvAplyCd.isChecked()){ //편의신청없음 체크되어 있는 경우
			this.divMain.form.edtEtcCnvPvsnDmndCn.set_enable(false);
		}else{
			this.divMain.form.edtEtcCnvPvsnDmndCn.set_enable(true);
		}
	} else {
		if(this.divMain.form.cboSqe1CnvAplyCd.value == "07" || this.divMain.form.cboSqe2CnvAplyCd.value =="07" || this.divMain.form.cboSqe3CnvAplyCd.value == "07"){
			this.divMain.form.edtEtcCnvPvsnDmndCn.set_enable(true);
		}else{
				this.divMain.form.edtEtcCnvPvsnDmndCn.set_value("");
			this.divMain.form.edtEtcCnvPvsnDmndCn.set_enable(false);
		}

	}
};

this.divMain_cboSqeCnvAplyCd_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	if(obj.value == "07"){ //기타일경우
		this.divMain.form.edtEtcCnvPvsnDmndCn.set_enable(true)
	}else{ //기타가아닐때
		if(this.divMain.form.cboRcgnDltScCd.value == "07" || this.divMain.form.cboSqe1CnvAplyCd.value == "07" || this.divMain.form.cboSqe2CnvAplyCd.value =="07" || this.divMain.form.cboSqe3CnvAplyCd.value == "07"){
			this.divMain.form.edtEtcCnvPvsnDmndCn.set_enable(true)
		}else{
			this.divMain.form.edtEtcCnvPvsnDmndCn.set_value("")
			this.divMain.form.edtEtcCnvPvsnDmndCn.set_enable(false)
		}
	}
};
//이메일 직접입력 콤보박스 클릭 시
this.cboEmlAddr2_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	if(obj.value == "직접입력"){
		this.divMain.form.edtEmlAddr3.set_readonly(false)
		this.smfUpdateValidateToComponent("title:이메일,required", this.divMain.form.edtEmlAddr3);
	}else{
		this.divMain.form.edtEmlAddr3.set_readonly(true)
		this.divMain.form.edtEmlAddr3.set_value("")
		this.smfClearRulesetToComponent(this.divMain.form.edtEmlAddr3);
	}
};
