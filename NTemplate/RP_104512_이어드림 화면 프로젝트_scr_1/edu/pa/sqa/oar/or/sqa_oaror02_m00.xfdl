    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 검정고시서비스 원서접수-응시자정보
*  @FileName 	sqa_oaror02_m00.xfdl 
*  @Creator 	박가혜
*  @CreateDate 	2022.06.14
*  @Desction    응시자정보
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.06.14           박가혜                 최초 생성
*  2024.11.19           진승환                 만 14세 미만 응시자의 법정대리인 동의 절차 추가
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/




include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.fv_param;
this.flagLmtt = "0";			//자격제한여부 확인 플래그 값  0:자격제한 미확인, 1:자격제한확인
this.qlfLmtt = "Y";				//자격제한여부 Y :응시가능 N : 자격제한
this.fvBase64ImageData ="";

this.fv_age14SeStYn	= "";		// 만 14세 미만 여부
this.fv_sttyCetYn	= "N";		// 법정대리인 본인인증 여부
this.fv_sttyNm = "";			// 법정대리인 성명
this.fv_sttRrno = "";			// 법정대리인 주민번호
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frm01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);

	  // 서버단에 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
			url: "/sqa_oar_or02_000.do",
		})

		.mappingRulesetToForm(this.divMain, "applpInfo")
		.run() 
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		})
	; 	
	
	// 파라미터 세팅
	this.fv_param 	=	this.smfGetFormParams();
	this.fnSetInitParam(this.smfGetFormParams());
	
	this.fv_sqeScCd =	this.fv_param.sqeScCd;
	this.fv_menuId 	=	this.fv_param.menuId;
	this.fv_rcptNo 	=  	this.fv_param.rcptNo;
	
	//row초기화 undefiend를 "" 변경
	this.smfInitRow(this.dsApplpInfo, 0);
	
 	this.dsSearch.setColumn(0,"sqeScCd",this.fv_param.sqeScCd)
	this.dsSearch.setColumn(0,"enfcYr",this.fv_param.enfcYr)
	this.dsSearch.setColumn(0,"enfcTme",this.fv_param.enfcTme)
	this.dsSearch.setColumn(0,"cddcCd",this.smfGetSessionValue("cddcCd"))
	this.dsSearch.setColumn(0,"rcptNo",this.fv_param.rcptNo)
	this.dsSearch.setColumn(0,"rmkMteCn","0")  //자격제한자 flag - default값
	this.dsSearch.setColumn(0,"downLoadYN", "N")
	
// 	trace(this.dsSearch.getColumn(0,"sqeScCd",this.fv_param.sqeScCd));
// 	trace(this.dsSearch.getColumn(0,"enfcYr",this.fv_param.sqeScCd));
// 	trace(this.dsSearch.getColumn(0,"enfcTme",this.fv_param.sqeScCd));
// 	trace(this.dsSearch.getColumn(0,"cddcCd",this.fv_param.sqeScCd));
// 	trace(this.dsSearch.getColumn(0,"rcptNo",this.fv_param.sqeScCd));
// 	trace(this.dsSearch.getColumn(0,"rmkMteCn",this.fv_param.sqeScCd));
// 	trace(this.dsSearch.getColumn(0,"downLoadYN",this.fv_param.sqeScCd));
	
	
	//제출여부에 따라 상단 스탭박스 이동가능 여부 설정(제출한적 있는경우 자유이동가능, 첫 작성인 경우 이동 못함)
	if(this.fv_param.sbmsnYn == "N") {
		this.div00.form.btnOarOr02.removeEventHandler("onclick", this.fnStep_onclick, this)
		this.div00.form.btnOarOr03.set_enable(false)
		this.div00.form.btnOarOr04.set_enable(false)
		this.div00.form.btnOarOr05.set_enable(false)
		this.div00.form.btnOarOr05.set_text("제출(미제출)")
	}
	if(this.fv_param.sbmsnYn == "Y") {
	
		this.div00.form.btnOarOr05.set_text("제출(완료)")
	}
	
 	this.fv_param.juminCheckYn = "Y"; ///////////////////////??????????????????????????
 	
	var clfCode = "";
	if(this.fv_param.sqeScCd == "1") {
		clfCode = "ESH_GRDTN_SQE_APPLP_CD"; 	//"MSKUL_ETRC_EXMNE_SC_CODE" 중입응시자
	}else if(this.fv_param.sqeScCd == "2") {
		clfCode = "MSKUL_GRDTN_SQE_APPLP_CD"; 	//"HS_ETRC_EXMNE_SC_CODE" 	고입응시자
	}else if(this.fv_param.sqeScCd == "3") {
		clfCode = "HSH_GRDTN_SQE_APPLP_CD"; 	//"HS_GRDTN_EXMNE_SC_CODE" 고졸응시자
	}

	this.dsApplpCd.setConstColumn("ClfCdValue", clfCode)
	
	// 공통코드의 코드구분

	
		// 공통코드 호출
	this.smfCodeList("code", [this.dsApplpCd, this.dsPrsrScCd, this.dsRcgnDltScCd, this.dsCnvAplyCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;	
			this.dsCnvAplyCd.deleteRow(5); //[단독고사실배정] row(5) 삭제(공통코드에서 삭제못해서 화면에서 삭제)
			this.fnInit();
		})		
		.run()
	;	
	
	//=======================================
	// 업로드관련 초기설정을 한다.
	//=======================================
	// 업로드시 저장위치등을 판별할 정보 세팅(대문자 : 시스템코드(2)+"."+서브시스템코드(3)+"."+대분류코드(3))
	this.divFileUpload.UPLOAD_CreateComplete = this.fnEventUploadCreateComplete;  // 필요한 경우만 세팅
	this.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;        // 필요한 경우만 세팅(세팅권장)
	this.divFileUpload.UPLOAD_OnError        = this.fnEventUploadError;           // 필요한 경우만 세팅(세팅권장)
	this.divFileUpload.UPLOAD_AfterAddFile   = this.fnEventAfterAddFile;           // 필요한 경우만 세팅(세팅권장)
	this.divFileUpload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)                    
	//=======================================
	// 업로드관련 초기설정 끝.
	//=======================================
	
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnInit = function()
{
	this.smfSearchService("selectApplpInfo")
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.fnSetData();
		});	
}

//기초데이터 셋팅
this.fnSetData = function(){

	this.dsApplpInfo.set_updatecontrol(false); //rowType변경안됨
	
	this.fv_age14SeStYn	= this.dsApplpInfo.getColumn(0, 'age14SeStYn');
	
	var enfcYr = this.dsApplpInfo.getColumn(0, "enfcYr")
	var enfcTme = this.dsApplpInfo.getColumn(0, "enfcTme")
	var sqeScCdNm = this.dsApplpInfo.getColumn(0, "sqeScCdNm")
	this.imgSubTitle.set_text(enfcYr  + "년 " + enfcTme + "회차 " + sqeScCdNm)
	
	var trprRrno = this.dsApplpInfo.getColumn(0, "trprRrno")
	this.divMain.form.edtTrprRrno1.set_value(trprRrno.substring(0,6))
	this.divMain.form.edtTrprRrno2.set_value(trprRrno.substring(6,7)+"******")
	
	//자격제한
	if(!this.smfIsNull(this.dsApplpInfo.getColumn(0,"applpScCd"))){ //한번 저장되었다는 의미니까..
		this.flagLmtt = "1";
	}
	
// 	if(this.flagLmtt == "1"){ //자격제한 확인 함
// 		this.divMain.form.staLmttMsg.set_text("※ 응시가능 대상자 입니다.")
// 	}else{ //자격제한 확인 안함
// 		this.divMain.form.staLmttMsg.set_text("※ 응시자격버튼을 클릭하여 응시자격을 확인해주세요.")
// 	}
		
	//생년월일
  	var birthYear = (trprRrno.charAt(6) == "1") || (trprRrno.charAt(6) == "2")  ||
  					(trprRrno.charAt(6) == "5") || (trprRrno.charAt(6) == "6") ? "19" : "20";
 		birthYear += trprRrno.substr(0, 2);
 	var birthMonth = trprRrno.substr(2, 2);
 	var birthDay = trprRrno.substr(4, 2);
 	var birth = birthYear + "/" + birthMonth + "/" + birthDay
 
 	this.dsApplpInfo.setColumn(0, "apstBrdt", birth);

	//전화번호
	var mbltelno1 = this.divMain.form.cboMblTelno1.set_value(this.smfSplit(this.dsApplpInfo.getColumn(0, "mblTelno"), "-")[0])
	var mbltelno2 = this.divMain.form.edtMblTelno2.set_value(this.smfSplit(this.dsApplpInfo.getColumn(0, "mblTelno"), "-")[1])
	var mbltelno3 = this.divMain.form.edtMblTelno3.set_value(this.smfSplit(this.dsApplpInfo.getColumn(0, "mblTelno"), "-")[2])
	var claiTelno1 = this.divMain.form.cboClaiTelno1.set_value(this.smfSplit(this.dsApplpInfo.getColumn(0, "claiTelno"), "-")[0])
	var claiTelno2 = this.divMain.form.edtClaiTelno2.set_value(this.smfSplit(this.dsApplpInfo.getColumn(0, "claiTelno"), "-")[1])
	var claiTelno3 =  this.divMain.form.edtClaiTelno3.set_value(this.smfSplit(this.dsApplpInfo.getColumn(0, "claiTelno"), "-")[2])

	//이메일
	var emlAddr = this.divMain.form.edtEmlAddr1.set_value(this.smfSplit(this.dsApplpInfo.getColumn(0,"emlAddr"),"@")[0])
	var emlAddr02 = this.smfSplit(this.dsApplpInfo.getColumn(0,"emlAddr"),"@")[1]
	if(!this.smfIsNull(this.dsApplpInfo.getColumn(0,"emlAddr"))){
			if(this.dsEmail.findRow(0,emlAddr02) > -1){
			this.dsApplpInfo.setColumn(0,"emlAddr2", emlAddr02)
			this.divMain.form.edtEmlAddr3.set_readonly(true)
		}else{
			this.dsApplpInfo.setColumn(0,"emlAddr2", "직접입력")
			this.dsApplpInfo.setColumn(0,"emlAddr3", emlAddr02)
			this.divMain.form.edtEmlAddr3.set_readonly(false)
		}
	}

	
	//장애여부 Y/N변경
	if(this.dsApplpInfo.getColumn(0, "dltYn") == "N"){
		this.divMain.form.rdoDltYn.set_value("1")
	}else if(this.dsApplpInfo.getColumn(0, "dltYn") == "Y"){
		this.divMain.form.rdoDltYn.set_value("2")
	}
	
	//장애구분
	if(this.dsApplpInfo.getColumn(0, "dltYn") == "Y" ){ //장애인일때
		this.divMain.form.cboRcgnDltScCd.set_enable(true);
		this.divMain.form.cboSqe1CnvAplyCd.set_enable(true);
		this.divMain.form.cboSqe2CnvAplyCd.set_enable(true);
		this.divMain.form.cboSqe3CnvAplyCd.set_enable(true);
		this.divMain.form.edtEtcCnvPvsnDmndCn.set_enable(true);
		this.divMain.form.chkCnvAplyCd.set_enable(true);
		
		this.divMain.form.cboRcgnDltScCd.set_cssclass("essential");

		if(this.divMain.form.cboRcgnDltScCd.value == "07"){
			this.divMain.form.edtEtcCnvPvsnDmndCn.set_enable(true)
		}else{
			this.divMain.form.edtEtcCnvPvsnDmndCn.set_enable(false)
		}
		
		if(this.smfIsNull(this.divMain.form.cboSqe1CnvAplyCd.value)&& this.smfIsNull(this.divMain.form.cboSqe2CnvAplyCd.value) 
		&& this.smfIsNull(this.divMain.form.cboSqe3CnvAplyCd.value) && this.smfIsNull(this.divMain.form.edtEtcCnvPvsnDmndCn.value)){
			this.divMain.form.chkCnvAplyCd.set_value(true)
			this.divMain.form.cboSqe1CnvAplyCd.set_enable(false);
			this.divMain.form.cboSqe2CnvAplyCd.set_enable(false);
			this.divMain.form.cboSqe3CnvAplyCd.set_enable(false);
			this.divMain.form.edtEtcCnvPvsnDmndCn.set_enable(false);
		}
	}else{
		this.divMain.form.cboRcgnDltScCd.set_enable(false);
		this.divMain.form.cboSqe1CnvAplyCd.set_enable(false);
		this.divMain.form.cboSqe2CnvAplyCd.set_enable(false);
		this.divMain.form.cboSqe3CnvAplyCd.set_enable(false);
		this.divMain.form.edtEtcCnvPvsnDmndCn.set_enable(false);
		
		this.divMain.form.chkCnvAplyCd.set_enable(false);
		
		this.divMain.form.cboRcgnDltScCd.set_cssclass("");
	}
	
	//성별
	var trprRrno2 = trprRrno.substring(6,7)
	if(trprRrno2.length > 0){
		if(trprRrno2.substring(0,1) == "1" || trprRrno2.substring(0,1) == "3" || trprRrno2.substring(0,1) == "5" || trprRrno2.substring(0,1) == "7"){
			this.divMain.form.rdoSxdsScCd.set_value("1")
		}else{
			this.divMain.form.rdoSxdsScCd.set_value("2")
		}
	}
	
	//사진
	this.dsFile.set_updatecontrol(false);   //rowType변경안됨
	this.dsFile.addRow();
	this.dsFile.setColumn(0,"photoFileCn",this.dsApplpInfo.getColumn(0,"photoFileCn"))
	this.dsFile.setColumn(0,"fileChk","N")
	this.dsFile.set_updatecontrol(true);
	
	this.divMain.form.imgPhoto.set_image("data:image/png;base64,"+this.dsApplpInfo.getColumn(0,"photoFileCn"))
	if(this.dsApplpInfo.getColumn(0,"photoFileCn") != "" && this.dsApplpInfo.getColumn(0,"photoFileCn") != null){
		this.divMain.form.imgPhoto.set_text("")
	}
	
	// 법정대리인 관련 세팅
	if(this.fv_age14SeStYn == 'Y'){
	
		var objOption1 = {};
		var objOption1 = {
			target : this.div14Under.form.edtTrprRrno2,	//대상 Edit 컴포넌트 [필수]
			targetKey : this.div14Under.form.staTransKey, //Edit와 쌍으로 있는 마우스입력 체크박스(static) [필수]
			bshow :  true, //  마우스입력 체크박스 보이기 여부 (default = false) [선택]
			maxLength : 7,
			kbdType : "number", //라온 키보드 타입 number/qwerty (default = qwerty)[선택)
		}
		this.smfInitTranskey(objOption1);
		
		this.div14Under.set_visible(true);
		this.divButton.set_top("div14Under:30px");
		this.set_height(1580);
		this.smfResetScroll(this);
		
		var sqeSttyAgtFlnm	= this.dsApplpInfo.getColumn(0,'sqeSttyAgtFlnm');
		if(!this.smfIsNull(sqeSttyAgtFlnm)){
			this.fv_sttyCetYn	= 'Y';
			this.fnSet14UnderComplete(true);
			var sqeSttyAgtTelno1 = this.div14Under.form.cboSqeSttyAgtTelno1.set_value(this.smfSplit(this.dsApplpInfo.getColumn(0, "sqeSttyAgtTelno"), "-")[0]);
			var sqeSttyAgtTelno2 = this.div14Under.form.edtSqeSttyAgtTelno2.set_value(this.smfSplit(this.dsApplpInfo.getColumn(0, "sqeSttyAgtTelno"), "-")[1]);
			var sqeSttyAgtTelno3 = this.div14Under.form.edtSqeSttyAgtTelno3.set_value(this.smfSplit(this.dsApplpInfo.getColumn(0, "sqeSttyAgtTelno"), "-")[2]);
		}else{
			this.fv_sttyCetYn	= 'N';
			this.fnSet14UnderComplete(false);
		}
		
		// 정보제공동의 여부 Y/N변경
		if(this.dsApplpInfo.getColumn(0, "sqeSttyAgtAgreYn") == "N"){
			this.div14Under.form.chkSqeSttyAgtAgreYn.set_value("1")
		}else if(this.dsApplpInfo.getColumn(0, "sqeSttyAgtAgreYn") == "Y"){
			this.div14Under.form.chkSqeSttyAgtAgreYn.set_value("2")
		}
		
	}else{
		this.div14Under.set_visible(false);
		this.divButton.set_top("divMain:30px");
		this.set_height(1270);
		this.smfResetScroll(this);
	}

	this.dsApplpInfo.set_updatecontrol(true); //rowType변경안됨
}
/**
 * @description 저장 버튼
 */
this.fnSave = function()
{	
	//자격제한 체크
	if(this.dsApplpInfo.getColumn(0,"sqeScCd") == "2" || this.dsApplpInfo.getColumn(0,"sqeScCd") == "1"){
		var enfcYr = this.dsApplpInfo.getColumn(0, "enfcYr")
		var bYear = this.divMain.form.edtApstBrdt.value.substr(0,4)
		var age = enfcYr - bYear
		if(age <= 11){
			this.smfAlert("만 11세 미만은 시험 응시가 불가합니다.");
			return false;
		}
	}
	
/* start : 학력조회 버튼 체크로직 주석처리*/
// 	if(this.flagLmtt == "0"){ //자격제한자 확인 안한경우
// 			this.smfAlert("학력조회 버튼을 클릭해서, 자격제한여부를 확인하세요!");
// 			return false;
// 	}else if(this.flagLmtt == "1" && this.qlfLmtt == "N"){ // 자격제한자 확인하고 자격제한자이면
// 			this.smfAlert("자격제한자입니다. 자세한 사항은 해당교육청으로 문의바랍니다.");
// 			return false;
// 		
// 	}else if(this.flagLmtt == "1" && this.qlfLmtt == "Y" ){ //자격제한자 확인 후 응시가능자

		// 데이터 존재 검증
		if(this.dsApplpInfoChData() == false){ return; }

		//전화번호결합
		this.dsApplpInfoTelno();
		
		var mblTelno = this.dsApplpInfo.getColumn(0,"mblTelno");
		var claiTelno = this.dsApplpInfo.getColumn(0,"claiTelno");
		
		if(mblTelno == claiTelno){
			this.divMain.form.edtClaiTelno2.setFocus();
			this.smfAlert("휴대전화와 다른 전화번호를 입력하시기 바랍니다.")
			return false;
		}
		
		if(this.smfIsNull(this.divMain.form.edtClaiTelno2.value) || this.smfIsNull(this.divMain.form.edtClaiTelno3.value)){
			this.dsApplpInfo.setColumn(0,"claiTelno","")
		}
		
		//이메일결합
		this.dsApplpInfoEmlAddr();
		var sEmail = this.dsApplpInfo.getColumn(0,"emlAddr");
		
		if(!this.smfIsEmail(sEmail)){
			this.divMain.form.edtEmlAddr1.setFocus();
			this.smfAlert('이메일의 형식이 잘못되었습니다.');
			return;
		}
		
		if(this.smfLength(sEmail) > 400){
			this.divMain.form.edtEmlAddr1.setFocus();
			this.smfAlert('이메일은 최대 400자까지 가능합니다.');
			return;
		}
		
		
		if(sEmail.length != this.smfLenB(sEmail))

		{
			this.divMain.form.edtEmlAddr1.setFocus();
			this.smfAlert('이메일은 영문 및 숫자만 입력가능합니다.');
			return;

		}
		
		// 만 14세 미만의 경우 유효성 체크
		if(this.fv_age14SeStYn == 'Y'){
		
			var sqeSttyAgtAgreYn	= this.dsApplpInfo.getColumn(0, 'sqeSttyAgtAgreYn');
			var sqeSttyAgtBrdt		= this.dsApplpInfo.getColumn(0, 'sqeSttyAgtBrdt');
			var sqeSttyAgtTelno		= this.dsApplpInfo.getColumn(0, 'sqeSttyAgtTelno');
				
			//엣지 자동완성 관련 검증 추가
			//성명
			var sqeSttyAgtFlnm = this.dsApplpInfo.getColumn(0,"sqeSttyAgtFlnm");
			if(sqeSttyAgtFlnm == undefined || sqeSttyAgtFlnm == null || sqeSttyAgtFlnm == "") {
				this.div14Under.form.edtSqeSttyAgtFlnm.setFocus();
				this.div14Under.form.edtSqeSttyAgtFlnm.set_value("");
				this.smfAlert('법정대리인성명은 필수입니다.');
				return false;
			}
			
			//휴대전화
			var sqeSttyAgtTelno2 = this.dsApplpInfo.getColumn(0,"sqeSttyAgtTelno2");	
			var sqeSttyAgtTelno3 = this.dsApplpInfo.getColumn(0,"sqeSttyAgtTelno3");
			if(sqeSttyAgtTelno2 == undefined || sqeSttyAgtTelno2 == null || sqeSttyAgtTelno2 == "") {
				this.div14Under.form.edtSqeSttyAgtTelno2.setFocus();
				this.div14Under.form.edtSqeSttyAgtTelno2.set_value("");
				this.smfAlert('법정대리인연락처는 필수입니다.');
				return false;
			}else if(sqeSttyAgtTelno3 == undefined || sqeSttyAgtTelno3 == null || sqeSttyAgtTelno3 == ""){
				this.div14Under.form.edtSqeSttyAgtTelno3.setFocus();
				this.div14Under.form.edtSqeSttyAgtTelno3.set_value("");
				this.smfAlert('법정대리인연락처는 필수입니다.');
				return false;
			}
		
			if( this.smfIsNull(sqeSttyAgtAgreYn) || sqeSttyAgtAgreYn == 'N'){
				this.smfAlert('14세 미만의 아동의 경우에는 법정대리인의 동의가 반드시 필요합니다.');
				return;
			} else if( this.smfIsNull(sqeSttyAgtBrdt) || sqeSttyAgtBrdt.length != 8 ){
				this.smfAlert('법정대리인의 생년월일을 확인바랍니다.');
				return;
			}else{
				if(!this.smfIsPhoneNo(sqeSttyAgtTelno)){
					this.smfAlert('법정대리인연락처를 확인바랍니다.');
					return;
				}
			}

		}

		this.dsApplpInfo.setColumn(0,"photoFileCn","") //blob까지 데이터 보낼필요 없어서 삭제.
		this.dsApplpInfo.getColumn(0,"downLoadYN", "N")
		this.smfSaveService("save")
		// 데이터 존재 필수
		.requireExistsData(this.dsApplpInfo) 
		// 데이터 검증
		.validateForm(this.divMain)
		.command(function(next){
			
			if(this.smfIsNull(this.dsFile.getColumn(0,"photoFileCn"))) {
				this.smfAlert("PA071",[]); //파일추가 버튼을 선택하여 사진을 선택하여 주세요.
				return false;
			}else{
				next();
			}

		})
// 		.command(function(next){
// 		
// 			if(!this.smfIsNull(this.dsApplpInfo.getColumn(0,"fileCoursNm"))){
// 
// 				// 사진파일 저장
// 				this.smfSaveService("savePhotoFile")
// 					.showConfirm(false)
// 					// 실행
// 					.run()
// 			
// 					// 콜백
// 					.callback(function(callbackParams){
// 						if(callbackParams.errors) return;
// 							next();
// 					});
// 
// 
// 			}else{
// 				next();
// 			}
// 			
// 		})
		
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;

			if(!this.smfIsNull(this.dsApplpInfo.getColumn(0,"fileCoursNm"))){

				// 사진파일 저장
				this.smfSaveService("savePhotoFile")
					.showConfirm(false)
					// 실행
					.run()
			
					// 콜백
					.callback(function(callbackParams){
						if(callbackParams.errors) return;
					
					});
			}
			
			// 비동기 현상 수정 (init 전에 데이터셋(빈값으로 params를 생성하는 경우 발생)
			this.fnInit();
			
			// 저장이 완료되었습니다.
			// 재조회
			this.smfAlert('PA072', ["저장"], function(){ //{0}이 완료되었습니다.
				var params = {
								enfcYr :  this.dsApplpInfo.getColumn(0,"enfcYr"),
								enfcTme : this.dsApplpInfo.getColumn(0,"enfcTme"),
								sqeScCd : this.dsApplpInfo.getColumn(0,"sqeScCd"),
								cddcCd : this.dsApplpInfo.getColumn(0,"cddcCd"),
								rcptNo : this.dsApplpInfo.getColumn(0,"rcptNo"),
								sbmsnYn: this.fv_param.sbmsnYn
							};
				this.smfSetWorkPage("pa_sqa_oar_or::sqa_oaror03_m00.xfdl", params);
			});
		});	


//	}	/* end : 자격제한자 체크로직 주석처리*/
};

/**
 * @description 전화번호 결합
 */
this.dsApplpInfoTelno = function(){

 	//전화번호결합
	this.dsApplpInfo.set_updatecontrol(false); //rowType변경안됨
	var telno1 = this.dsApplpInfo.getColumn(0,"claiTelno1");	
	var telno2 = this.dsApplpInfo.getColumn(0,"claiTelno2");	
	var telno3 = this.dsApplpInfo.getColumn(0,"claiTelno3");
	var telno = [telno1,telno2,telno3].join("-"); 
	if ( telno == "--" ) telno = "";
	this.dsApplpInfo.setColumn(0,"claiTelno",telno);
	
	var mblTelno1 = this.dsApplpInfo.getColumn(0,"mblTelno1");	
	var mblTelno2 = this.dsApplpInfo.getColumn(0,"mblTelno2");	
	var mblTelno3 = this.dsApplpInfo.getColumn(0,"mblTelno3");	
	var mblTelno = [mblTelno1,mblTelno2,mblTelno3].join("-");
	this.dsApplpInfo.setColumn(0,"mblTelno",mblTelno);
	
	if(this.fv_age14SeStYn == 'Y'){
		var sqeSttyAgtTelno1 = this.dsApplpInfo.getColumn(0,"sqeSttyAgtTelno1");	
		var sqeSttyAgtTelno2 = this.dsApplpInfo.getColumn(0,"sqeSttyAgtTelno2");	
		var sqeSttyAgtTelno3 = this.dsApplpInfo.getColumn(0,"sqeSttyAgtTelno3");
		var sqeSttyAgtTelno = [sqeSttyAgtTelno1,sqeSttyAgtTelno2,sqeSttyAgtTelno3].join("-"); 
		this.dsApplpInfo.setColumn(0,"sqeSttyAgtTelno",sqeSttyAgtTelno);
	}
	
	this.dsApplpInfo.set_updatecontrol(true);
}

/**
 * @description 이메일결합
 */
this.dsApplpInfoEmlAddr = function(){

 	//이메일결합
	this.dsApplpInfo.set_updatecontrol(false); //rowType변경안됨
	var emlAddr1 = this.dsApplpInfo.getColumn(0,"emlAddr1")
	var emlAddr2 = this.dsApplpInfo.getColumn(0,"emlAddr2")
	var emlAddr3 = this.dsApplpInfo.getColumn(0,"emlAddr3")
	var emlAddr = "";
	if(emlAddr2 == "직접입력"){
		emlAddr = emlAddr1 +  "@" + emlAddr3
	}else{
		emlAddr = emlAddr1 +  "@" + emlAddr2
	}

	this.dsApplpInfo.setColumn(0,"emlAddr",emlAddr);
	
	this.dsApplpInfo.set_updatecontrol(true);
}

/**
 * @description 데이터 존재 검증
 */
this.dsApplpInfoChData = function(){
	// 엣지 자동완성 관련 데이터 존재 확인 로직 추가
	
	//상세주소
	var ihtRegRoadNmDaddr = this.dsApplpInfo.getColumn(0,"ihtRegRoadNmDaddr");	
	if(ihtRegRoadNmDaddr == undefined || ihtRegRoadNmDaddr == null || ihtRegRoadNmDaddr == "") {
		this.divMain.form.edtIhtRegRdnDaddr.setFocus();
		this.divMain.form.edtIhtRegRdnDaddr.set_value(ihtRegRoadNmDaddr);
		this.smfAlert('주민등록도로명상세주소는 필수입니다.');
		return false;
	}
	
	//휴대전화
	var mblTelno2 = this.dsApplpInfo.getColumn(0,"mblTelno2");	
	var mblTelno3 = this.dsApplpInfo.getColumn(0,"mblTelno3");
	
	if(mblTelno2 == undefined || mblTelno2 == null || mblTelno2 == "") {
		this.divMain.form.edtMblTelno2.setFocus();
		this.divMain.form.edtMblTelno2.set_value("");
		this.smfAlert('휴대전화는 필수입니다.');
		return false;
	}else if( mblTelno2.length < 3){
		this.divMain.form.edtMblTelno2.setFocus();
		this.divMain.form.edtMblTelno2.set_value(mblTelno2);
		this.smfAlert('휴대전화 중앙 번호는 3자리 이상입니다.');
		return false;
	}
	
	if(mblTelno3 == undefined || mblTelno3 == null || mblTelno3 == ""){
		this.divMain.form.edtMblTelno3.setFocus();
		this.divMain.form.edtMblTelno3.set_value("");
		this.smfAlert('휴대전화는 필수입니다.');
		return false;
	}else if( mblTelno3.length < 4){
		this.divMain.form.edtMblTelno3.setFocus();
		this.divMain.form.edtMblTelno3.set_value(mblTelno3);
		this.smfAlert('휴대전화 마지막 번호는 4자리입니다.');
		return false;
	}
	
	//비상연락처
	var telno2 = this.dsApplpInfo.getColumn(0,"claiTelno2");	
	var telno3 = this.dsApplpInfo.getColumn(0,"claiTelno3");
	
	if(telno2 == undefined || telno2 == null || telno2 == "") {
		this.divMain.form.edtClaiTelno2.setFocus();
		this.divMain.form.edtClaiTelno2.set_value("");
		this.smfAlert('비상연락처는 필수입니다.');
		return false;
	}else if( telno2.length < 3){
		this.divMain.form.edtClaiTelno2.setFocus();
		this.divMain.form.edtClaiTelno2.set_value(telno2);
		this.smfAlert('비상연락처 중앙 번호는 3자리 이상입니다.');
		return false;
	}
	
	if(telno3 == undefined || telno3 == null || telno3 == ""){
		this.divMain.form.edtClaiTelno3.setFocus();
		this.divMain.form.edtClaiTelno3.set_value("");
		this.smfAlert('비상연락처는 필수입니다.');
		return false;
	}else if( telno3.length < 4){
		this.divMain.form.edtClaiTelno3.setFocus();
		this.divMain.form.edtClaiTelno3.set_value(telno3);
		this.smfAlert('비상연락처 마지막 번호는 4자리입니다.');
		return false;
	}
	
	//이메일
	var emlAddr1 = this.dsApplpInfo.getColumn(0,"emlAddr1");
	if(emlAddr1 == undefined || emlAddr1 == null || emlAddr1 == "") {
		this.divMain.form.edtEmlAddr1.setFocus(); 
		this.divMain.form.edtEmlAddr1.set_value("");
		this.smfAlert('이메일은 필수입니다.');
		return false
	}
}
 
