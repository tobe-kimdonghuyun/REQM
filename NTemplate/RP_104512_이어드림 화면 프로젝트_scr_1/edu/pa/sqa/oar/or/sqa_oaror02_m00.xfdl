{
	this.fnSave();
};

//취소버튼
this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	this.smfConfirm("PA073",[],function(confirmParams){ //변경 전 내역으로 재조회 됩니다. 변경전 내역으로 이동하시겠습니까?

		if(confirmParams.confirmResult){

			this.fnInit();

		}else{

			return false;		

		}

	})
};


//우편번호검색
this.divMain_btnFindPost_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var popupParams = {
		callback: this.fnCommpopRdnZip, // 콜백함수 지정
		sender: obj, 
		params: {
