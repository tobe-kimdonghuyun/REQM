};

/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */

/**
 * @description 증명사진 업ㄴ로드 팝업(이미지 크롭) 오픈
 */
this.divMain_btnImage_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	/*바로파일선택*/
//  	this.divFileUpload._divFormObj   = obj.parent;
//  	this.divFileUpload._FileGbnValue = obj.parent._FileGbnValue;
//  	this.divFileUpload.form.fnAddFile();
	/*바로파일선택*/
//////////////////////

/*이미지크롭팝업*/
var sBase64ImageData = "";

	var objParam = {
						type : "file"             // [필수] 이미지 전달 방식 ("data": base64형태의 데이터롤 이미지 전달, "file":팝업에서 파일선택)
					, 	data : sBase64ImageData   // [선택] (type="data"인 경우는 필수) 팝업에 전달할 이미지 데이터
				   };

	var sPopupId = "popupImageCrop";
	this.smfImgCropPopup(objParam,sPopupId,obj);
	
/*이미지크롭팝업*/	
	
};

/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){

	trace("====>fnPopupCallback");
	var sImageType       = "";
	var sImageFileName   = "";   // 선택된 파일이름
	var sImageDataBase64 = "";
	
	if(e.imageInfo)
	{
		sImageType       = e.imageInfo.imageType;   // 이미지 타입(image/png)
		sImageFileName   = e.imageInfo.imageFileName;   // 파일이름(test.png)
		sImageDataBase64 = e.imageInfo.imageDataBase64;  // BASE64의 이미지 파일

	}
	
	trace("파일제목길이" + this.smfLenB(sImageFileName))
	trace("파일제목길이" + this.smfLength(sImageFileName))
	
	if(sImageFileName.length> 20){
		alert("사진파일명은 20자 이내여야합니다.")
		return false;
	}
	

	
	this.divMain.form.imgPhoto._imagetype = sImageType; 
	this.divMain.form.imgPhoto._imagename = sImageFileName;
	this.divMain.form.imgPhoto._imageDataBase64 = sImageDataBase64;
	
	var sBase64Data = sImageDataBase64;
	var sFilename = sImageFileName;
	this.divFileUpload.form.fnFileUploadWithBase64(sImageDataBase64,sFilename,this,this.fnAddBase64DataCallback);
	


};

this.fnAddBase64DataCallback = function(paramObj)
{
	if(paramObj)
	{
		trace("===> this.fnAddBase64DataCallback : paramObj=" + JSON.stringify(paramObj) );
		
	}
	
}


