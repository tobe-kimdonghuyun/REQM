// KUpload를 생성시 지정할 property값을 지정
this.fnSetRaonProp = function()
{
	// 설정할 property
	var objAddRaonProps = {
								ExtensionAllowOrLimit : "1"        // 업로드 할 파일 확장자를 허용 또는 제한 설정("0":지정된 확장자를 제한(선택 금지) , "1":지정된 확장자만 허용(선택가능))
							,   ExtensionArr          : "gif,jpg,png"  // 제한 및 허용할 확장자명을 ",(콤마)"로 구분하여 설정
							,   AllowedZeroFileSize   : "1"        // 0byte 파일의 업로드를 허용 할지 설정합니다.(기본값은 "0" 허용안함이고, "1"로 설정시 허용입니다.)
							, 	MaxTotalFileCount	  : "6"			//업로드 할 최대 파일 개수 제한값을 설정합니다.
							,	MaxOneFileSize		  : "1MB"		//업로드할 때 파일당 용량제한을 설정합니다.
						  };
						  
	return objAddRaonProps;
}

/*********************************** 만 14세 미만 관련 법정대리인의 본인인증 관련 로직들 **********************************/

/**
 * @description 공동인증 클릭 시
 */
this.div14Under_btnCert_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.chk(obj)){ //빈칸체크

		//@KBR 입력된 참여번호 가져오기
		var transKey = this.fnTransKey(this.div14Under.form.edtTrprRrno2);
		this.dsRaonKeyData.setColumn(0,"trprRrno1",this.div14Under.form.edtTrprRrno1.value)
		
		this.smfSearchService("selectKeyDec")
			.run()
			.callback(function(callbackParams){
				if(callbackParams.errors) return;

				this.fv_sttyNm = this.div14Under.form.edtSqeSttyAgtFlnm.value;
				this.fv_sttRrno = this.dsMain.getColumn(0,"encRrno"); //암호화된 값

				var sRrno = this.div14Under.form.edtTrprRrno1.value + this.dsMain.getColumn(0,"trprRrno2")
				
				if(this.checkRrno(sRrno,obj)){

					var sConnectBaseUrl = window.location.protocol + "//" + window.location.host;

					var sInitUrl  = sConnectBaseUrl + "/cmc_fcm_es01_003.do";
					var sLoginUrl = sConnectBaseUrl + "/cmc_fcm_es01_004.do";

					var userId = sRrno;
					
					var objLoginInfo = {
											initUrl  : sInitUrl    // init시 사용하는 서비스명(앞에 "/"을 붙일 것)
										,   loginUrl : sLoginUrl   // login시 사용하는 서비스명(앞에 "/"을 붙일 것)
										,	userId : userId
									   };   // 생략가능

					var objParam = {objForm:this, popupcallback :this.fnCertPopupCallback, loginInfo:objLoginInfo};

					this.smfExecNpkiAuth(objParam);
				}
			});	 
		}
};

/**
 * 팝업의 콜백함수 지정한다 (공동인증서)
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnCertPopupCallback = function(e, sender){

	var sLog = "";
	if(e.result)
	{
		var sData = JSON.parse(e.data);
		if(sData.vidResult == "true"){
			var subjectDnCn = sData.subjectDn;
			if(subjectDnCn.indexOf(this.fv_sttyNm) != -1){  //이름이 포함되어 있을때
				this.fnCertComlpete(sData);
			}else{
				this.smfLiteralAlert("현재 선택하신 인증서의 성명과 입력하신 성명이 일치하지 않습니다.");
			}
		}else if(sData.vidResult.indexOf("VID") != -1){ 
			this.smfLiteralAlert("입력된 정보와 인증서 정보가 일치하지 않습니다. 다시 한 번 확인 해 주세요.");
		}else{
			this.smfLiteralAlert("인증서 인증에 에러가 발생했습니다. 관리자에게 문의하세요.");
		}
	}
	else
	{
		var sData = e.data;
		var arrData = sData.split(":");
		
		if(arrData[0].trim()=="800000")
		{  // 유저가 팝업을 강제 종료한 경우
			sLog += "처리결과 : [에러(유저강제종료)]\n";
			sLog += "data : ["+sData+"]";	
		}
		else
		{
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+sData+"]";		
		}
		
	}
};

/**
 * @description 금융인증 클릭 시
 */
this.div14Under_btnFinCert_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.chk(obj)){ //빈칸체크
	//@KBR 입력된 참여번호 가져오기
	var transKey = this.fnTransKey(this.div14Under.form.edtTrprRrno2);
	this.dsRaonKeyData.setColumn(0,"trprRrno1",this.div14Under.form.edtTrprRrno1.value)
	
	this.smfSearchService("selectKeyDec")
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.fv_sttRrno = this.dsMain.getColumn(0,"encRrno") //암호화된 값
			// 주민등록번호
			var sRrno = this.div14Under.form.edtTrprRrno1.value + this.dsMain.getColumn(0,"trprRrno2");
			
			// 주민번호 전체 체크
			if(this.checkRrno(sRrno,obj)){
				var objParam = {objForm:this, popupcallback :this.fnFinAuthPopupCallback, rrno : sRrno};
				this.smfExecFinAuth(objParam);
			}
		});	
	
	}
};

/**
 * 팝업의 콜백함수 지정한다 (금융인증서)
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnFinAuthPopupCallback = function(e, sender){

	var sLog = "";
	if(e.result)
	{
		var sData = e.data;
		sLog += "처리결과 : [성공]\n";
		sLog += "data : ["+sData+"]";
		
		var subjectDn = JSON.parse(sData).certificate.subject_dn.toString();
		var dnNm = subjectDn.substring(3, subjectDn.indexOf("("))
		var vidResult = JSON.parse(sData).vidresult.toString();
		
		if(vidResult == "true"){
			this.fv_sttyNm = this.div14Under.form.edtSqeSttyAgtFlnm.value;
			if(dnNm != this.fv_sttyNm){
				this.smfLiteralAlert("현재 선택하신 인증서의 성명과 입력하신 성명이 일치하지 않습니다.");
			}else{
				this.fnCertComlpete(sData);
			}
		}else if(vidResult == "false"){
			this.smfLiteralAlert("입력된 정보와 인증서 정보가 일치하지 않습니다. 다시 한 번 확인 해 주세요.");
		}else{
			this.smfLiteralAlert("인증서 인증에 에러가 발생했습니다. 관리자에게 문의하세요.");
		}
	}
	else
	{
		var sData = e.data;
		var arrData = sData.split(":");
		
		if(arrData[0].trim()=="800000")
		{  // 유저가 팝업을 강제 종료한 경우
			sLog += "처리결과 : [에러(유저강제종료)]\n";
			sLog += "data : ["+sData+"]";
		}
		else
		{
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+sData+"]";	
		}
	}
};

/**
 * @description 간편인증 클릭 시
 */
this.div14Under_btnSimpleCert_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 오픈방식을 설정한다.
	var sOpenType   = "ssn";  // [선택] Open방식 -  "birth"(default) : 생년월일 , "ssn" : 주민등록번호
	var sActionType = 'trans';  // [선택] 간편인증 동작방식 -  "trans" : 중계형(온라인채용/검정고시) , "instl" : 설치형(교육비원클릭/그외)
	                                             // 미지정시 subSys를 체크하여 설정. 미지정을 권장

	var objParam = {objForm:this, popupcallback :this.fnSimpleAuthPopupCallback , openType: sOpenType, actionType: sActionType };
	this.smfExecSimpleAuth(objParam);
};

/**
 * @description 법정대리인 본인인증 완료
 */
this.fnSimpleAuthPopupCallback = function(e, sender){

	var sLog = "";
	if(e.result){
		var sData = JSON.parse(e.data);
		if(this.smfIsNull(sData)){
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+sData+"]";
			//console.log(sLog);
			this.smfLiteralAlert("본인 인증 인증에 실패 하였습니다..");
			return;
		}else{
			this.fv_sttRrno	= sData.ssn;
			this.fv_sttyNm 	= sData.userNm;
			this.fnCertComlpete(sData);
		}
	}
};

/**
 * @description 재인증 버튼 클릭
 */
this.div14Under_btnReCert_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	this.smfConfirm("법정대리인의 본인인증을 다시 진행하시겠습니까?", function(confirmParams){
		if(confirmParams.confirmResult){
			this.div14Under.form.edtSqeSttyAgtFlnm.set_value("");
			this.div14Under.form.edtTrprRrno1.set_value("");
			this.div14Under.form.edtTrprRrno2.set_value("");
			this.div14Under.form.chkSqeSttyAgtAgreYn.set_value('N');
			this.fv_sttyCetYn = 'N';
			this.fnSet14UnderComplete(false);
		}else{
			return false;		
		}
	})
};


this.fnCertComlpete = function(sData){
	
	// 응시자와 법정대리인이 같으면 안됨
	var fv_appRrno	= this.dsApplpInfo.getColumn(0, "trprRrno");
	var fv_appFlnm	= this.dsApplpInfo.getColumn(0, "kornFlnm");
	
	if( this.fv_sttRrno == fv_appRrno){
		this.smfLiteralAlert("응시자 본인은 법정대리인이 될 수 없습니다.");
		return false;
	}
	var sLog = "";
	
	sLog += "처리결과 : [성공]\n";
	sLog += "data : ["+sData+"]";	
	
	this.dsApplpInfo.setColumn(0, "sqeSttyAgtFlnm", this.fv_sttyNm);
	
	this.fv_sttyCetYn	= 'Y';
	this.fnSet14UnderComplete(true);
}

/**
 * @description 법정대리인 본인인증 완료여부로 컴퍼넌트 처리
 */
this.fnSet14UnderComplete = function(flag){

	if(flag){
		this.div14Under.form.edtTrprRrno1.set_visible(false);		
		this.div14Under.form.staDash.set_visible(false);
		this.div14Under.form.edtTrprRrno2.set_visible(false);
		
		this.div14Under.form.btnCert.set_visible(false);
		this.div14Under.form.btnFinCert.set_visible(false);
		this.div14Under.form.btnSimpleCert.set_visible(false);
		
		this.div14Under.form.edtSqeSttyAgtFlnm.set_readonly(true);
		this.div14Under.form.staComplete.set_visible(true);
		this.div14Under.form.staComplete.set_left(196);
		this.div14Under.form.staComplete.set_visible(true);
		
		this.div14Under.form.btnReCert.set_left(400);
		this.div14Under.form.btnReCert.set_visible(true);
		
	}else{
		this.div14Under.form.edtTrprRrno1.set_visible(true);		
		this.div14Under.form.staDash.set_visible(true);
		this.div14Under.form.edtTrprRrno2.set_visible(true);
		
		this.div14Under.form.btnCert.set_visible(true);
		this.div14Under.form.btnFinCert.set_visible(true);
		this.div14Under.form.btnSimpleCert.set_visible(true);
		
		this.div14Under.form.edtSqeSttyAgtFlnm.set_readonly(false);
		this.div14Under.form.staComplete.set_visible(false);
		
		this.div14Under.form.btnReCert.set_visible(false);
	}
}

/**
 * @description 법정대리인 동의 여부 체크
 */
this.div14Under_chkInfo_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	if('Y' != this.fv_sttyCetYn){
		this.smfAlert('법정대리인 본인인증 이후에 진행하시길 바랍니다.');
		obj.set_value("N");
		return;
	}
};

this.fnSttyAgtCallback = function(){

}


this.chk = function(obj){
	
	var sqeSttyAgtFlnm = this.div14Under.form.edtSqeSttyAgtFlnm.value;
	var sqeSttyAgtRrno = this.div14Under.form.edtTrprRrno1.value + this.div14Under.form.edtTrprRrno2.value;
	
	if( this.smfIsNull(sqeSttyAgtFlnm)){
		this.smfLiteralAlert("법정대리인성명을 입력해주세요.");
		this.div14Under.form.edtSqeSttyAgtFlnm.setFocus();
		return false;
	}
	
	if(this.smfIsNull(this.div14Under.form.edtTrprRrno1.value)){
		this.smfLiteralAlert("주민등록번호 앞자리를 입력해주세요.")
		this.div14Under.form.edtTrprRrno1.setFocus();
		return false;
	}
	return true;
	
}

this.fnTransKey = function(obj)
{	
	var sVal    = "";
	var arrComp = [obj];  //대상 Edit component List: array [필수]
	
	if(!this.smfIsMobile()){
		// 키보드보안 적용여부
		var sRtnVal = this.smfGetValueTranskey(obj);
	
		if(sRtnVal == "transkey"){	//선택
			var sVal = this.smfGetEncDataTranskey(arrComp);
	
			//전달받은 파라미터 데이터셋에 담기
			this.smfConvRaonDataToDs(this.dsRaonKeyData,arrComp,sVal);
			this.dsRaonKeyData.setColumn(0, 'tk_col_check', "transkey");
		}else if(sRtnVal == "e2e"){ //미선택
			sVal= obj.value;
		}
	}else{
		sVal = this.smfGetEncDataTranskey(arrComp);
		
		//전달받은 파라미터 데이터셋에 담기
		this.smfConvRaonDataToDs(this.dsRaonKeyData,arrComp,sVal);
		this.dsRaonKeyData.setColumn(0, 'tk_col_check', "transkey");
	}
};

/**
* 주민번호 체크
*/
this.checkRrno = function(applpRrno, obj) {
	
	if(this.div14Under.form.edtTrprRrno1.value.length != 6){
		this.div14Under.form.edtTrprRrno1.setFocus();
		this.smfLiteralAlert("주민등록번호(외국인등록번호)를 바르게 입력해주세요.")
		return false;
	}

	// 주민등록번호 자리수가 맞는가를 확인
	if (applpRrno.length != 13){
		this.smfLiteralAlert("주민등록번호(외국인등록번호)를 바르게 입력해주세요.")
		return false;
		
	}

	// 성별 (외국인 포함)
	var chr6 = applpRrno.charAt(6);

 	if((chr6 == '5' || chr6 == '6' || chr6 == '7' || chr6 == '8')){
 		if(!this.smfIsForeignNo(applpRrno)){
 		
 			this.div14Under.form.edtTrprRrno2.setFocus();
 			this.smfLiteralAlert("올바른 외국인등록번호를 입력해주세요.")
 			return false;
 		}
 	
 	}else{
 		if(!this.smfIsRsrNoOld(applpRrno)){
 			this.div14Under.form.edtTrprRrno2.setFocus();
 			this.smfLiteralAlert("올바른 주민등록번호를 입력해주세요.")
 			return false;
 		}	
 	}

	return true;
}
]]></Script>
