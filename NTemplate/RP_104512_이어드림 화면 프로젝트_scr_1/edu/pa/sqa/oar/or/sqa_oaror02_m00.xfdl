/**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd == -1) return;
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 도로명주소찾기 콜백
 */
this.fnCommpopRdnZip = function(e, sender){
	var nRow = this.dsApplpInfo.rowposition;

	this.dsApplpInfo.setColumn(nRow, "ihtRegRoadNmZip", e.zipCd); //우편번호
	this.dsApplpInfo.setColumn(nRow, "ihtRegRoadNmAddr", e.roadNmAddr); //도로명주소
	
	//도로명 자동등록되는거 자동 등록되지 않도록 수정
	var troadNmDtl = e.roadNmDtl.trim();
	
	if(troadNmDtl){
		if(troadNmDtl[0] == '('){
			var index = troadNmDtl.indexOf(')');
			if(index != (troadNmDtl.length - 1)){
				this.dsApplpInfo.setColumn(nRow, "ihtRegRoadNmDaddr", e.roadNmDtl);	//도로명상세
			}else{
				this.dsApplpInfo.setColumn(nRow, "ihtRegRoadNmDaddr", '');	
			}
		}else{
			this.dsApplpInfo.setColumn(nRow, "ihtRegRoadNmDaddr", e.roadNmDtl);	//도로명상세
		}
	}else{
		this.dsApplpInfo.setColumn(nRow, "ihtRegRoadNmDaddr", e.roadNmDtl);	//도로명상세
	}
	

};

this.fnChkValidate  = function(){

		if(this.smfIsNull(this.dsFile.getColumn(0,"photoFileCn"))) {
			this.smfAlert("PA071",[]); //파일추가 버튼을 선택하여 사진을 선택하여 주세요.
			return false;
		}
		
		if(this.smfIsUpdate(this.dsApplpInfo) || this.smfIsUpdate(this.dsFile)){ //정보 변경
			//정보 변경 있으면 저장하라는  메시지
			this.smfAlert("PA074", ["응시자 정보"]) //{0}를 저장 후 다음으로 이동하십시오.
			return false;
		
		}
		
		return true;
		
		
}
