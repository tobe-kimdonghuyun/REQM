          <ConstColumn id="UserDfnCd2Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd3Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd4Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd5Value" type="STRING" size="30" value=""/>
          <Column id="pgeId" type="STRING" size="256"/>
          <Column id="clfCdValue" type="STRING" size="30"/>
          <Column id="clfCdValueNm" type="STRING" size="120"/>
          <Column id="clfCdUseYn" type="STRING" size="150"/>
          <Column id="unyCdValue" type="STRING" size="10"/>
          <Column id="unyCdValueNm" type="STRING" size="30"/>
          <Column id="userDfnCd1Value" type="STRING" size="100"/>
          <Column id="userDfnCd2Value" type="STRING" size="100"/>
          <Column id="userDfnCd3Value" type="STRING" size="100"/>
          <Column id="userDfnCd4Value" type="STRING" size="100"/>
          <Column id="userDfnCd5Value" type="STRING" size="100"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsResult" useclientlayout="true">
        <ColumnInfo>
          <Column id="grd" type="STRING" size="256" description="학년"/>
          <Column id="schorFlctnScCd" type="STRING" size="256" description="학적변동코드"/>
          <Column id="schorFlctnScCdNm" type="STRING" size="256" description="학적변동코드명"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="atptOfcdcNm" type="STRING" size="256" description="학교관할시도"/>
          <Column id="shlCd" type="STRING" size="256" description="학교코드"/>
          <Column id="shlCdNm" type="STRING" size="256" description="학교명"/>
          <Column id="shlLctnAddr" type="STRING" size="256" description="학교주소"/>
          <Column id="shlTelno" type="STRING" size="256" description="학교전화번호"/>
          <Column id="shlCrseScCd" type="STRING" size="256" description="학교과정구분코드"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 응시자격제한대상확인
*  @FileName 	sqa_oaror01_p05.xfdl 
*  @Creator 	박가혜
*  @CreateDate 	2022.12.23
*  @Desction    응시자격제한대상확인 팝업
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.12.23         박가혜                 최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/




include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.fv_params;	// 파라메터 세팅
this.qlfLmtt;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frm01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitPopup(obj)
	
	this.fv_params = this.smfGetPopupParams();
	
	this.dsSearch.addRow();
	
	this.divSearch.form.edtKornFlnm.set_value(this.fv_params.kornFlnm)
	this.divSearch.form.edtTrprRrno.set_value(this.fv_params.trprRrno1)
	this.divSearch.form.edtTrprRrno2.set_value(this.fv_params.trprRrno2)
	this.dsSearch.setColumn(0,"kornFlnm",this.fv_params.kornFlnm)
	this.dsSearch.setColumn(0,"trprRrno1",this.fv_params.trprRrno.substr(0,6))
	this.dsSearch.setColumn(0,"trprRrno2",this.fv_params.trprRrno.substr(6,13))
	
	if(this.fv_params.sqeScCd == "1"){ //초졸
		this.divMeqInfo.move(20,356,null,null,20)
		this.btnClose.set_top("divMeqInfo:30")
		this.divMeqInfo.set_visible(true)
	}else if(this.fv_params.sqeScCd == "2"){
		this.divHeqInfo.move(20,356,null,null,20)
		this.btnClose.set_top("divHeqInfo:30")
		this.divHeqInfo.set_visible(true)
	}else if(this.fv_params.sqeScCd == "3"){
		this.divHgqInfo.move(20,356,null,null,20)
		this.btnClose.set_top("divHgqInfo:30")
		this.divHgqInfo.set_visible(true)
	}
	
	this.smfResetScroll(this)
	
	this.btnSearch_onclick();
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 최종학력 조회
*/
this.fnSearch = function(){
	

		// 서비스 객체 생성
	this.smfSearchService("select")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
		
			if(callbackParams.errors) return;

			//shlCrseScCd(학교과정구분코드) 1:유치원 2:초등학교 3:중학교 4:고등학교 5:특수학교교(부) 6:전공과 
			var shlCrseScCd = this.dsResult.getColumn(0,"shlCrseScCd") //학교과정구분코드
			var schorFlctnScCd = this.dsResult.getColumn(0,"schorFlctnScCd") //학적변동구분코드
			
			if(this.fv_params.sqeScCd == "1") { //초졸검정고시 응시일때
				if(shlCrseScCd == "3" || shlCrseScCd == "4"){ // 소재에 중학교 또는 고등학교 기록이 있을 경우
					this.qlfLmtt = "N" //응시 불가
				}
			}else if(this.fv_params.sqeScCd == "2"){ //중졸검정고시 응시일때
				if(shlCrseScCd == "4"){ //소재에 고등학교 기록이 있는 경우(학교과정구분코드가 고등학교)
					this.qlfLmtt = "N" //응시 불가
				}
			}else if(this.fv_params.sqeScCd == "3"){ //고졸검정고시 응시일때
				if(shlCrseScCd == "4" && schorFlctnScCd == "18") //학교과정구분코드=고등학교 / 학적변동구분코드(18)=졸업
				this.qlfLmtt = "N" //응시 불가
			}
			
		});	
}


/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 확인 버튼 클릭
*/

this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
//	 응답을 opener에 전달
//	opener에 callback 호출
	this.smfSendResponseToOpener({
		"gubun": true,
		"qlfLmtt" : this.qlfLmtt
	});
	this.close(false)

};


this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearch();
};
]]></Script>
  </Form>
</FDL>
