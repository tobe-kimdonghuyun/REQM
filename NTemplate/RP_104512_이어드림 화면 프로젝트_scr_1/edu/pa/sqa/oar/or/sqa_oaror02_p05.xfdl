        <Div id="divMeqInfo" taborder="5" left="850" height="254" cssclass="div_WF_InfoBOX" right="-810" initvalueid="ivDivAccessibilityOff" top="73" visible="false">
          <Layouts>
            <Layout>
              <Static id="sta00_00_01_01_00" taborder="0" left="29" top="28" height="23" cssclass="sta_WF_InfoTit" text="응시자격 제한에 대한 안내" wordWrap="char" initvalueid="ivStcAccessibilityOn" width="250"/>
              <Static id="sta00_00_01_01" taborder="1" left="30" top="68" cssclass="sta_WF_InfoTxt" text="초등학교(특수학교 포함) 재학 중인 자" wordWrap="char" initvalueid="ivStcAccessibilityOn" height="25" right="30" fittocontents="height"/>
              <Static id="sta00_00_01_01_01" taborder="2" left="30" top="sta00_00_01_01:0" cssclass="sta_WF_InfoTxt" text="공고일 이후(공고일 까지의 정원 외 관리자 포함) 초등학교에 재학 중 학적이 정원 외로 관리되는 자" wordWrap="char" initvalueid="ivStcAccessibilityOn" height="25" right="30" fittocontents="height"/>
              <Static id="sta00_00_01_01_01_00" taborder="3" left="30" top="sta00_00_01_01_01:0" cssclass="sta_WF_InfoTxt" text="공고일 기준으로 고시에 관하여 부정행위를 한 자로서 처분 일부터 응시자격 제한기간이 경과되지 아니한 자" wordWrap="char" initvalueid="ivStcAccessibilityOn" height="25" right="30" fittocontents="height"/>
              <Static id="sta00_00_01_01_01_00_00" taborder="4" left="30" top="sta00_00_01_01_01_00:0" cssclass="sta_WF_Black14" text="※응시자격은 시험시행일까지 유지하여야하며 적법하게 응시원서를 접수하였다 하더라도, 그 이후 시험일까지 편•입학 등으로 재학생의 신분을 획득한 경우 응시자격을 박탈함" wordWrap="char" initvalueid="ivStcAccessibilityOn" height="45" right="30" fittocontents="height"/>
              <Static id="sta00_00_01_01_01_00_00_00" taborder="5" left="30" top="sta00_00_01_01_01_00_00:0" cssclass="sta_WF_Black14" text="※위 응시자격 제한자에 해당하는 경우 응시자격을 박탈당할 수 있으므로 유의하시기 바랍니다." wordWrap="char" initvalueid="ivStcAccessibilityOn" height="25" right="30" fittocontents="height"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_01" taborder="6" left="30" top="51" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff"/>
