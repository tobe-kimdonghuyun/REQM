              <Static id="sta00_00_01_01_01_00" taborder="3" left="30" top="sta00_00_01_01_01:0" cssclass="sta_WF_InfoTxt" text="공고일 이후(공고일 까지의 정원 외 관리 포함) 중학교에 재학 중 학적이 정원 외로 관리되는 자" wordWrap="char" initvalueid="ivStcAccessibilityOn" height="25" fittocontents="height" right="30"/>
              <Static id="sta00_00_01_01_01_00_01" taborder="4" left="30" top="sta00_00_01_01_01_00:0" cssclass="sta_WF_InfoTxt" text="공고일 기준으로 고시에 관하여 부정행위를 한 자로서 처분 일부터 응시자격 제한기간이 경과되지 아니한자" wordWrap="char" initvalueid="ivStcAccessibilityOn" height="25" fittocontents="height" right="30"/>
