        <Div id="divHgqInfo" taborder="7" left="860" height="324" cssclass="div_WF_InfoBOX" right="-820" initvalueid="ivDivAccessibilityOff" top="708" visible="false">
          <Layouts>
            <Layout>
              <Static id="sta00_00_01_01_00" taborder="0" left="29" top="28" height="23" cssclass="sta_WF_InfoTit" text="응시자격 제한에 대한 안내" wordWrap="char" initvalueid="ivStcAccessibilityOn" width="250"/>
              <Static id="sta01" taborder="1" left="30" top="68" cssclass="sta_WF_InfoTxt" text="고등학교 또는 초,중등교육법시행령 제98조 제1항 제2호의 학교를 졸업한 자 또는 재학 중인 자 (휴학 중인 자 포함)" wordWrap="char" initvalueid="ivStcAccessibilityOn" height="25" right="30" fittocontents="height"/>
              <Static id="sta02" taborder="2" left="30" top="sta01:0" cssclass="sta_WF_InfoTxt" text="공고일 이후 중학교 또는 초,중등교육법시행령 제97조 제1항 제2호의 학교를 졸업한 자" wordWrap="char" initvalueid="ivStcAccessibilityOn" height="25" right="30" fittocontents="height"/>
              <Static id="sta03" taborder="3" left="30" top="sta02:0" cssclass="sta_WF_InfoTxt" text="공고일 기준으로 고시에 관하여 부정행위를 한 자로서 처분 일부터 응시자격 제한기준이 경과되지 아니한자" wordWrap="char" initvalueid="ivStcAccessibilityOn" height="25" right="30" fittocontents="height"/>
              <Static id="sta04" taborder="4" left="30" top="sta03:0" cssclass="sta_WF_InfoTxt" text="공고일 기준, 6개월 이전 1호의 학교에 재학 중 제적된 자&#13;&#10;(단, 장애인복지법 제32조의 규정에 의하여 등록된 장애인으로서 신체적, 정신적 장애로 학업을 계속하는 것이 불가능하여 자퇴한 자는 제외한다.)" wordWrap="char" initvalueid="ivStcAccessibilityOn" height="71" right="30" fittocontents="height"/>
              <Static id="sta05" taborder="5" left="30" top="sta04:0" cssclass="sta_WF_Black14" text="※응시자격은 시험시행일까지 유지하여야하며 적법하게 응시원서를 접수하였다 하더라도, 그 이후 시험일까지 편•입학 등으로 재학생의 신분을 획득한 경우 응시자격을 박탈함" wordWrap="char" initvalueid="ivStcAccessibilityOn" height="45" right="30" fittocontents="height"/>
              <Static id="sta06" taborder="6" left="30" top="sta05:0" cssclass="sta_WF_Black14" text="※위 응시자격 제한자에 해당하는 경우 응시자격을 박탈당할 수 있으므로 유의하시기 바랍니다." wordWrap="char" initvalueid="ivStcAccessibilityOn" height="25" right="30" fittocontents="height"/>
