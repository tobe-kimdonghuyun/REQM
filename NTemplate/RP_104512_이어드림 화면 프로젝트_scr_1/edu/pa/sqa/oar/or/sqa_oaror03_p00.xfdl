<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <TypeDefinition url="..\default_typedef.xml"/>
  <Form id="commpop_school" classname="form" inheritanceid="" titletext="학교찾기" onload="form_onload" position="absolute" width="865" height="444">
    <Layouts>
      <Layout width="865" height="444" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divSearch" taborder="1" left="20" top="20" height="83" accessibilityenable="false" right="20" cssclass="div_WF_Detail" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staTxt3" taborder="0" left="194" top="0" height="42" cssclass="sta_WF_Input02Top" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staCddc" taborder="1" text="*시·도 교육청" left="0" top="0" width="195" height="42" cssclass="sta_WF_EssentialTop" accessibilitydescription="필수입력" initvalueid="ivStcEssential"/>
              <Edit id="edtCddcCdNm" taborder="2" left="200" top="6" width="308" height="30" cssclass="essential" accessibilitylabel="학교명(필수입력)" maxlength="20" initvalueid="ivEdtReadOnly" readonly="true" onkeydown="schulNm_onkeydown"/>
              <Static id="staTxt4" taborder="3" left="194" top="41" height="42" cssclass="sta_WF_Input02" right="0" text="" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staSchulNm" taborder="4" text="*학교명" left="0" top="41" width="195" height="42" cssclass="sta_WF_Essential" accessibilitydescription="필수입력" initvalueid="ivStcEssential"/>
              <Edit id="edtSchulNm" taborder="5" left="200" top="47" width="308" height="30" cssclass="essential" accessibilitylabel="학교명(필수입력)" maxlength="20" initvalueid="ivEdtEssential" onkeydown="schulNm_onkeydown"/>
              <Button id="btnSearch" taborder="6" text="검색" left="513" top="47" width="48" height="30" onclick="btnSearch_onclick" initvalueid="ivBtnAccessibilityButton"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="div00" taborder="2" left="20" top="123" height="252" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Grid binddataset="dsSchoolList" id="grdMain" left="0" top="0" height="252" taborder="0" autofittype="col" right="0" initvalueid="ivGrdAccessibilityOn" selecttype="cell" oncelldblclick="grdMain_oncelldblclick">
                <Formats>
                  <Format id="default">
                    <Columns>
                      <Column size="80"/>
                      <Column size="224"/>
                    </Columns>
                    <Rows>
                      <Row size="36" band="head"/>
                      <Row size="40"/>
                    </Rows>
                    <Band id="head">
                      <Cell text="학교명"/>
                      <Cell col="1" text="소재지"/>
                    </Band>
                    <Band id="body">
                      <Cell text="bind:kornOrgNm"/>
                      <Cell col="1" text="bind:zipAddr"/>
                    </Band>
                  </Format>
                  <Format id="mobile">
                    <Columns>
                      <Column size="140"/>
                      <Column size="460"/>
                    </Columns>
                    <Rows>
                      <Row size="50" band="head"/>
                      <Row size="70"/>
                    </Rows>
                    <Band id="head">
                      <Cell text="학교명"/>
                      <Cell col="1" text="소재지"/>
                    </Band>
                    <Band id="body">
                      <Cell text="bind:kornOrgNm"/>
                      <Cell col="1" text="bind:zipAddr"/>
                    </Band>
                  </Format>
                </Formats>
              </Grid>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnSelect" taborder="3" text="확인" left="47.05%" top="395" width="50" height="30" initvalueid="ivBtnAccessibilityButton" onclick="btnSelect_onclick"/>
        <Static id="sta00" taborder="4" left="20" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta01" taborder="5" left="20" height="20" cssclass="sta_GD_Size" text="Grid 모바일 버전 접근성  관련 사항 때문에 Div 처리 &lt;스크립트 확인해주세요&gt;" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" top="103" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta02" taborder="6" left="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff" height="20" top="375"/>
        <Static id="sta03" taborder="7" left="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff" height="20" top="425"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsSearch">
        <ColumnInfo>
          <Column id="cddcOrgCd" type="STRING" size="256"/>
          <Column id="kornOrgNm" type="STRING" size="256"/>
          <Column id="ygGubun" type="STRING" size="256"/>
          <Column id="cddcNm" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="ygGubun">3</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">select</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsSchoolList=dsSchoolList</Col>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">R</Col>
            <Col id="bindingControls"/>
            <Col id="url">sqa_oar_or03_004.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSchoolList" onrowposchanged="dsMain_onrowposchanged" useclientlayout="true">
        <ColumnInfo>
          <Column id="orgCd" type="STRING" size="256"/>
          <Column id="zipAddr" type="STRING" size="256"/>
          <Column id="kornOrgNm" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    학교찾기
*  @FileName 	sqa_oaror03_p00.xfdl 
*  @CreateDate 	2022.01.06
*  @Desction    학교찾기 팝업 화면
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.01.06     	박가혜	                최초 생성
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.pv_params;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	
	// 팝업 폼 초기화
	this.smfInitPopup(obj); 
	this.smfUpdatePopupTitle("학교찾기");
	pv_params = this.smfGetPopupParams();

	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
		url : "/sqa_oar_or03_000.do",
		})
		.mappingRulesetToForm(this.divSearch, "schSearch")
		.callback(function(callbackParams) {
		})
		.run()
	;

		// opener 화면에서 시도교육청 코드를 넘겨주면 세팅
		if(this.isNotNil(pv_params.shlLctnCtpvCd)){
			this.divSearch.form.edtCddcCdNm.set_value(pv_params.shlLctnCtpvCdNm);
		}else{
			this.smfAlert("학교관할시도를 먼저 선택하셔야 합니다.")
			this.close(false);
		}
		
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 /**
 * 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchList = function()
{
	
// 	if(this.smfIsNull(this.divSearch.form.edtSchulNm.value)){
// 		this.smfAlert("학교명을 입력해주세요.")
// 		return false;
// 	}
	
	this.dsSearch.setColumn(0,"cddcOrgCd",pv_params.shlLctnCtpvCd+"0000001")
	this.dsSearch.setColumn(0,"kornOrgNm", this.divSearch.form.edtSchulNm.value);

	this.smfSearchService("select")
		.validateForm(this.divSearch) // 폼 유효성검사
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
		});	
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
  
  /**
 * 학교 선택
 * @param : N/A
 * @param : N/A
 */
 this.fnChoice = function(){
	if(this.dsSchoolList.rowposition <= -1) return;
	
	this.smfSendResponseToOpener({
		"row": this.smfRowToObject(this.dsSchoolList)
	});

	this.close(true);
};

/**
 * @description 학교검색
*/
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearchList()
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 입력창 입력 시
* @param  : obj		   - [object]Edit
* @param  : e		   - [string]KeyEventInfo
* @return : N/A
 */
this.schulNm_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	// 엔터키 이벤트
	if(e.keycode == "13"){
		this.btnSearch_onclick();
	}
};

/**
 * 검색 버튼 클릭 시
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearchList();
};

/**
 * 그리드 셀 더블 클릭 시
* @param  : obj		   - [object]Grid
* @param  : e		   - [string]GridClickEventInfo
* @return : N/A
 */
this.grdMain_oncelldblclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	this.fnChoice();
};

/**
 * 확인 버튼 클릭 시
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
this.btnSelect_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnChoice();
};

]]></Script>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.edtSchulNm" propid="value" datasetid="dsSearch" columnid="kornOrgNm"/>
      <BindItem id="item2" compid="divSearch.form.edtCddcCdNm" propid="value" datasetid="dsSearch" columnid="cddcNm"/>
    </Bind>
  </Form>
</FDL>
