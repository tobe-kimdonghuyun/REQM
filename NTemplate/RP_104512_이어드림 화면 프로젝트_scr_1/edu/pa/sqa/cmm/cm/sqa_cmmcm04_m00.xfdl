    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 검정고시서비스 공통
*  @FileName 	sqa_oaror01_m00.xfdl 
*  @Creator 	박가혜
*  @CreateDate 	2022.06.21
*  @Desction    원서접수 최초 분기 화면
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.06.21           박가혜                 최초 생성 
*  2024.10.23			진승환					범정부 UI/UX 가이드라인 적용 (원서접수, 수험표출력, 성적조회 기간 표시)
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/




include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.fv_param;
this.itnRcptBgngYmdtm = "";
this.itnRcptEndYmdtm = "";


/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frm01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	//페이지 구분 4000:온라인원서접수 5000:원서조회 6000:수험표출력 7000:성적조회
	
	// 폼을 초기화
	this.smfInitForm(obj);
	// 파라메터 세팅
	this.fv_param = this.smfGetFormParams();

	this.dsMain.addRow();
	this.dsSearch.addRow();
	
	this.fv_menuId = this.fv_param.menu == "" || this.fv_param.menu == null ? this.fv_param.menuId : this.fv_param.menu; //메뉴 아이디 설정

	this.fv_param.cddcCd = this.smfGetCddcCode(); //받아오기
	this.dsMain.setColumn(0, "cddcCd", this.smfGetCddcCode()); // 받아오기
	this.dsMain.setColumn(0, "menuId", this.fv_param.menu)	
	
	//페이지 타이틀 설정
	this.fnPageDivTitle();
	
	var sessionCddcCd = this.smfGetCddcCode();
	var sidoCd = sessionCddcCd.substr(0,3);

	var cddcNm = this.smfGetCddcName();
	
	// 해당로직은 밑으로 이동
// 	if(this.fv_menuId == "4000"){
// 		//시도교육청 확인 팝업 오픈
// 		this.chkCddcCdPop(cddcNm); 
// 		
// 	}else{
// 			
// 		//초기데이터 셋팅
// 		this.fnInitData();
// 	}
	this.fnInitData();
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description initData - 초기데이터 조회
*/
this.fnInitData = function(){
	//초,중,고 검정고시 접수기간 조회
	
	// 서비스 객체 생성
	this.smfSearchService("selectRcptInfo")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.fnInitDataPrd();
		});

	this.dsResult.setColumn(0,"enfcAtptCd",this.smfGetCddcCode()); // 접속도메인코드를 셋팅(변수명변경)
	var enfcAtptCd = this.smfGetCddcCode().substr(0,3)//DOMAIN_CODE들어가야함
	
	if(this.fv_menuId == "4000"){
		var cddcNm = this.smfGetCddcName();
		//시도교육청 확인 팝업 오픈
		this.chkCddcCdPop(cddcNm); 
	}
	
	if (enfcAtptCd != "B10"
					&& enfcAtptCd != "C10"
					&& enfcAtptCd != "D10"
					&& enfcAtptCd != "E10"
					&& enfcAtptCd != "F10"
					&& enfcAtptCd != "G10"
					&& enfcAtptCd != "H10"
					&& enfcAtptCd != "J10"
					&& enfcAtptCd != "K10"
					&& enfcAtptCd != "M10"
					&& enfcAtptCd != "N10"
					&& enfcAtptCd != "P10"
					&& enfcAtptCd != "Q10"
					&& enfcAtptCd != "R10"
					&& enfcAtptCd != "S10"
					&& enfcAtptCd != "T10"
					&& enfcAtptCd != "I10")
				{

					this.smfAlert("해당시도교육청은 초등학교졸업학력검정고시,\n중학교졸업학력검정고시, 고등학교졸업학력검정고시\n온라인 접수를 지원하지 않습니다.\n\n시도교육청 공고문을 확인하시어 현장접수하시기 바랍니다.");
					//comUtil.goMenuPage("m71000");
				}
}

/**
 * @description 페이지 구분에 따른 title, 버튼명 설정
*/
this.fnPageDivTitle = function(){
	var page = ""; 
	var btn = "";
	var sta = "";
	if(this.fv_menuId== "4000"){
		page = "온라인 원서접수";
		btn = "원서 접수하기";
		sta = "원서 접수 기간";
	}else if(this.fv_menuId == "5000"){
		page = "원서조회";
		btn = "원서 조회하기";
		sta = "";
	}else if(this.fv_menuId == "6000"){
		page = "수험표출력";
		btn = "수험표출력하기";
		sta = "수험표 출력 기간";
	}else if(this.fv_menuId == "7000"){
		page = "성적조회";
		btn = "성적조회";
		sta = "성적 조회 기간";
	}
	var txt = "희망하시는 자격의 검정고시를 선택해 주시기 바랍니다. \n선택 후에 해당 검정고시의 "+page+" 페이지로 이동합니다."
	
	this.div00.form.staTitle.set_text(page);
	this.div00.form.staText1.set_text(txt);
	this.div00.form.divHeq.form.btnHeq.set_text(btn);
	this.div00.form.divHgq.form.btnHgq.set_text(btn);
	this.div00.form.divMeq.form.btnMeq.set_text(btn);
	
	this.div00.form.divHeq.form.divItnRcptPrd.form.staTempTitle.set_text(sta);
	this.div00.form.divHgq.form.divItnRcptPrd.form.staTempTitle.set_text(sta);
	this.div00.form.divMeq.form.divItnRcptPrd.form.staTempTitle.set_text(sta);
	
}

/**
 * @description 페이지 구분에 따른 기간 설정
*/
this.fnInitDataPrd = function(){
	
	var meqStartYmd	= "";	
	var meqStartHr	= "";
	var meqEndYmd	= "";
	var meqEndHr	= "";
	
	var heqStartYmd	= "";
	var heqStartHr	= "";
	var heqEndYmd	= "";
	var heqEndHr	= "";
	
	var hgqStartYmd	= "";
	var hgqStartHr	= "";
	var hgqEndYmd	= "";
	var hgqEndHr	= "";
	
	// 원서접수
	if(this.fv_menuId== "4000"){
		meqStartYmd = this.fnGetWeekDateFormat(this.dsEshRcptInfo.getColumn(0,'itnRcptBgngYmd'));
		meqEndYmd 	= this.fnGetWeekDateFormat(this.dsEshRcptInfo.getColumn(0,'itnRcptEndYmd'));
		meqStartHr 	= this.smfTrim(this.dsEshRcptInfo.getColumn(0,'itnRcptBgngTm'));
		meqEndHr 	= this.smfTrim(this.dsEshRcptInfo.getColumn(0,'itnRcptEndTm'));
		
		heqStartYmd = this.fnGetWeekDateFormat(this.dsMskulRcptInfo.getColumn(0,'itnRcptBgngYmd'));
		heqEndYmd 	= this.fnGetWeekDateFormat(this.dsMskulRcptInfo.getColumn(0,'itnRcptEndYmd'));
		heqStartHr 	= this.smfTrim(this.dsMskulRcptInfo.getColumn(0,'itnRcptBgngTm'));
		heqEndHr 	= this.smfTrim(this.dsMskulRcptInfo.getColumn(0,'itnRcptEndTm'));
		
		hgqStartYmd = this.fnGetWeekDateFormat(this.dsHshRcptInfo.getColumn(0,'itnRcptBgngYmd'));
		hgqEndYmd 	= this.fnGetWeekDateFormat(this.dsHshRcptInfo.getColumn(0,'itnRcptEndYmd'));
		hgqStartHr 	= this.smfTrim(this.dsHshRcptInfo.getColumn(0,'itnRcptBgngTm'));
		hgqEndHr 	= this.smfTrim(this.dsHshRcptInfo.getColumn(0,'itnRcptEndTm'));
	}
	// 원서조회
	else if(this.fv_menuId == "5000"){
		meqStartYmd = "";
		meqEndYmd 	= "";
		meqStartHr 	= "";
		meqEndHr 	= "";
		
		heqStartYmd	= "";
		heqStartHr	= "";
		heqEndYmd	= "";
		heqEndHr	= "";
	
		hgqStartYmd	= "";
		hgqStartHr	= "";
		hgqEndYmd	= "";
		hgqEndHr	= "";
	}
	// 수험표출력
	else if(this.fv_menuId == "6000"){
		meqStartYmd = this.fnGetWeekDateFormat(this.dsEshRcptInfo.getColumn(0,'eiOtptBgngYmd'));
		meqEndYmd 	= this.fnGetWeekDateFormat(this.dsEshRcptInfo.getColumn(0,'eiOtptEndYmd'));
		meqStartHr 	= this.smfTrim(this.dsEshRcptInfo.getColumn(0,'eiOtptBgngTm'));
		meqEndHr 	= this.smfTrim(this.dsEshRcptInfo.getColumn(0,'eiOtptEndTm'));
		
		heqStartYmd = this.fnGetWeekDateFormat(this.dsMskulRcptInfo.getColumn(0,'eiOtptBgngYmd'));
		heqEndYmd 	= this.fnGetWeekDateFormat(this.dsMskulRcptInfo.getColumn(0,'eiOtptEndYmd'));
		heqStartHr 	= this.smfTrim(this.dsMskulRcptInfo.getColumn(0,'eiOtptBgngTm'));
		heqEndHr 	= this.smfTrim(this.dsMskulRcptInfo.getColumn(0,'eiOtptEndTm'));
		
		hgqStartYmd = this.fnGetWeekDateFormat(this.dsHshRcptInfo.getColumn(0,'eiOtptBgngYmd'));
		hgqEndYmd 	= this.fnGetWeekDateFormat(this.dsHshRcptInfo.getColumn(0,'eiOtptEndYmd'));
		hgqStartHr 	= this.smfTrim(this.dsHshRcptInfo.getColumn(0,'eiOtptBgngTm'));
		hgqEndHr 	= this.smfTrim(this.dsHshRcptInfo.getColumn(0,'eiOtptEndTm'));
	}
	// 성적조회
	else if(this.fv_menuId == "7000"){ 
		meqStartYmd = this.fnGetWeekDateFormat(this.dsEshRcptInfo.getColumn(0,'screInqBgngYmd'));
		meqEndYmd 	= this.fnGetWeekDateFormat(this.dsEshRcptInfo.getColumn(0,'screInqEndYmd'));
		meqStartHr 	= this.smfTrim(this.dsEshRcptInfo.getColumn(0,'screInqBgngTm'));
		meqEndHr 	= this.smfTrim(this.dsEshRcptInfo.getColumn(0,'screInqEndTm'));
		
		heqStartYmd = this.fnGetWeekDateFormat(this.dsMskulRcptInfo.getColumn(0,'screInqBgngYmd'));
		heqEndYmd 	= this.fnGetWeekDateFormat(this.dsMskulRcptInfo.getColumn(0,'screInqEndYmd'));
		heqStartHr 	= this.smfTrim(this.dsMskulRcptInfo.getColumn(0,'screInqBgngTm'));
		heqEndHr 	= this.smfTrim(this.dsMskulRcptInfo.getColumn(0,'screInqEndTm'));
		
		hgqStartYmd = this.fnGetWeekDateFormat(this.dsHshRcptInfo.getColumn(0,'screInqBgngYmd'));
		hgqEndYmd 	= this.fnGetWeekDateFormat(this.dsHshRcptInfo.getColumn(0,'screInqEndYmd'));
		hgqStartHr 	= this.smfTrim(this.dsHshRcptInfo.getColumn(0,'screInqBgngTm'));
		hgqEndHr 	= this.smfTrim(this.dsHshRcptInfo.getColumn(0,'screInqEndTm'));
	}
	
	var meqPrd	= "";
	var heqPrd	= "";
	var hgqPrd	= "";
	
	// 원서접수, 성적조회는 시간 까지 표시
	if(this.fv_menuId == "4000" || this.fv_menuId == "7000"){
		meqPrd	= meqStartYmd + " " + meqStartHr + ":00 ~ " + meqEndYmd + " " + meqEndHr + ":00";
		heqPrd	= heqStartYmd + " " + heqStartHr + ":00 ~ " + heqEndYmd + " " + heqEndHr + ":00";
		hgqPrd	= hgqStartYmd + " " + hgqStartHr + ":00 ~ " + hgqEndYmd + " " + hgqEndHr + ":00";
	}
	// 수험표출력은 일자만 표시
	else if(this.fv_menuId == "6000"){
		meqPrd	= meqStartYmd + " ~ " + meqEndYmd;
		heqPrd	= heqStartYmd + " ~ " + heqEndYmd;
		hgqPrd	= hgqStartYmd + " ~ " + hgqEndYmd;
	}
	
	this.div00.form.divMeq.form.divItnRcptPrd.form.staPrd.set_text(meqPrd);
	this.div00.form.divHeq.form.divItnRcptPrd.form.staPrd.set_text(heqPrd);
	this.div00.form.divHgq.form.divItnRcptPrd.form.staPrd.set_text(hgqPrd);

}

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd == -1) return;
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 페이지 이동시 필요한 파라미터 설정
*/

this.fnSetParam = function(gubun){
	
	if(gubun == "1"){ //초졸검정고시
	
		 itnRcptBgngYmdtm = this.smfTrim(this.dsEshRcptInfo.getColumn(0, "itnRcptBgngYmdtm")) //인터넷접수시작일시
		 itnRcptEndYmdtm = this.smfTrim(this.dsEshRcptInfo.getColumn(0, "itnRcptEndYmdtm")) //인터넷접수종료일시
		 this.fv_enfcYr = this.dsEshRcptInfo.getColumn(0,"enfcYr")
		 this.fv_enfcTme = this.dsEshRcptInfo.getColumn(0,"enfcTme")
		 this.fv_sqeScCd = this.dsEshRcptInfo.getColumn(0,"sqeScCd")
		 this.sCddcCd = this.dsEshRcptInfo.getColumn(0,"cddcCd")
		 this.dsSearch.setColumn(0,"enfcYr",this.fv_enfcYr)
		 this.dsSearch.setColumn(0,"enfcTme",this.fv_enfcTme)
		 this.dsSearch.setColumn(0,"sqeScCd",this.fv_sqeScCd)
		 this.dsSearch.setColumn(0,"cddcCd",this.smfGetCddcCode())
		 
		 
	}else if(gubun == "2"){ //중졸검정고시
	
		 itnRcptBgngYmdtm = this.smfTrim(this.dsMskulRcptInfo.getColumn(0, "itnRcptBgngYmdtm")) //인터넷접수시작일시
		 itnRcptEndYmdtm = this.smfTrim(this.dsMskulRcptInfo.getColumn(0, "itnRcptEndYmdtm")) //인터넷접수종료일시
		 this.fv_enfcYr = this.dsMskulRcptInfo.getColumn(0,"enfcYr")
		 this.fv_enfcTme = this.dsMskulRcptInfo.getColumn(0,"enfcTme")
		 this.fv_sqeScCd = this.dsMskulRcptInfo.getColumn(0,"sqeScCd")
		 this.sCddcCd = this.dsMskulRcptInfo.getColumn(0,"cddcCd")
		 this.dsSearch.setColumn(0,"enfcYr",this.fv_enfcYr)
		 this.dsSearch.setColumn(0,"enfcTme",this.fv_enfcTme)
		 this.dsSearch.setColumn(0,"sqeScCd",this.fv_sqeScCd)
		 this.dsSearch.setColumn(0,"cddcCd",this.smfGetCddcCode())
		 
	}else if(gubun == "3"){ //고졸검정고시
	
		 itnRcptBgngYmdtm = this.smfTrim(this.dsHshRcptInfo.getColumn(0, "itnRcptBgngYmdtm")) //인터넷접수시작일시
		 itnRcptEndYmdtm = this.smfTrim(this.dsHshRcptInfo.getColumn(0, "itnRcptEndYmdtm")) //인터넷접수종료일시
		 this.fv_enfcYr = this.dsHshRcptInfo.getColumn(0,"enfcYr")
		 this.fv_enfcTme = this.dsHshRcptInfo.getColumn(0,"enfcTme")
		 this.fv_sqeScCd = this.dsHshRcptInfo.getColumn(0,"sqeScCd")
		 this.sCddcCd = this.dsHshRcptInfo.getColumn(0,"cddcCd")
		 this.dsSearch.setColumn(0,"enfcYr",this.fv_enfcYr)
		 this.dsSearch.setColumn(0,"enfcTme",this.fv_enfcTme)
		 this.dsSearch.setColumn(0,"sqeScCd",this.fv_sqeScCd)
		 this.dsSearch.setColumn(0,"cddcCd",this.smfGetCddcCode())
	}
	
}



//시도교육청 확인 팝업
this.chkCddcCdPop = function(cddcNm)
{
	// 팝업을 동작에 필요한 파라메터 지정
		var popupParams = {
			callback: this.chkCddcPopupCallback, // 콜백함수 지정
			sender: obj, // sender 지정
			titlebar:false, 

			// 팝업 전달 파라메터 지정
			params: {
				// 처리타입 지정
				procType: "notice",
				pageId : "sqa_oaror02_m00",
				cddcNm : cddcNm
			}
		};
		
		//this.popUp_open("pa_sqa_oar_or::sqa_oaror01_p00.xfdl", popupParams);
		this.smfDialog("_auto","pa_sqa_oar_or::sqa_oaror01_p00.xfdl", popupParams);
};

/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.chkCddcPopupCallback = function(e, sender){
//시도교육청 확인 팝업 후 기초 데이터 세팅

if(e.gubun == "gotoMain"){ //취소 클릭시 홈화면으로 이동
			var objFrame = this.getOwnerFrame();
			
			if(objFrame.form.divAll)
			{
				// Top 에 값을 세팅
				var sMainUrl = objFrame.form.fv_mainformUrl;
				
				// 메인URL로 이동한다.
				if(!this.smfIsNull(sMainUrl))
				{
					objFrame.form.fnSetMainpage(sMainUrl);	
				}
			}
	}else{ //확인클릭시
	
		//this.fnInitData();
	}
};

this.dateFormatDash = function(sDate){
 
 var sYear = sDate.substr(0,4)
 var sMonth = sDate.substr(4,2)
 var sDay = sDate.substr(6,2)
 
 return sYear+"-"+sMonth+"-"+sDay
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.btnMeq_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	gubun =  "1" //초졸
	
	this.fnSetParam(gubun)
	this.ChkLogin(gubun);

};


this.btnHeq_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	gubun =  "2" //중졸
	this.fnSetParam(gubun)
	this.ChkLogin(gubun);
}

this.btnHgq_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	gubun =  "3" //고졸
	this.fnSetParam(gubun)
	this.ChkLogin(gubun);
};
