        <Div id="div00" taborder="10" left="0" top="709" cssclass="div_Login_Notice02" initvalueid="ivDivAccessibilityOff" height="102" visible="true" text="" right="0">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" left="55" width="134" cssclass="sta_Login_MemberNotice01" initvalueid="ivStcAccessibilityOn" top="38" height="30" accessibilitylabel="알려드립니다."/>
              <Static id="sta01" taborder="1" text="&lt;b v='true'&gt;초 - 중등교육법 시행령 제106조의3에 의거 주민등록번호(또는 외국인등록번호) 수집하여 검정고시의 응시접수, 실시, 처리에 사용합니다. &lt;/b&gt;" left="248" top="26" cssclass="sta_Login_MemberNotice" initvalueid="ivStcAccessibilityOn" usedecorate="true" onclick="div00_00_sta02_onclick" width="902" height="34" color="#333333"/>
              <Static id="sta01_00_00" taborder="2" text="&lt;b v='true'&gt;고유식별번호의 수집과 이용 동의는 원서접수시 동의를 받고 있습니다.&lt;/b&gt;" left="248" top="54" cssclass="sta_Login_MemberNotice" initvalueid="ivStcAccessibilityOn" usedecorate="true" onclick="div00_00_sta02_onclick" width="902" height="34" fittocontents="none" color="#333333"/>
            </Layout>
            <Layout name="default0">
              <Static id="sta00" taborder="0" left="20" cssclass="sta_Login_MemberNotice01_M" initvalueid="ivStcAccessibilityOn" top="40" height="50" accessibilitylabel="알려드립니다." right="20"/>
              <Static id="sta01" taborder="1" text="&lt;b v='true'&gt;나이스 학원서비스는 회원가입 없이 사용자의 인증서 인증만으로도 이용이 가능합니다.&lt;/b&gt;&#13;&#10;※ 개인용 인증서로 만 로그인이 가능(법인용 인증서 사용 불가)하며, 학원·교습소 등 설립등록(방문 민원) 시 '온라인사용자 등록'을 먼저 하셔야 합니다.&#13;&#10;   - 온라인사용자 등록 완료 후 인증서로 로그인하시면, 민원신청, 열람 등의 서비스를 별도의 인증절차 없이 이용하실 수 있습니다.&#13;&#10;      단, 로그인 시 타 시·도교육청으로 이동하거나 다른 서비스로 이동 시 다시 로그인을 하게 될 수도 있습니다.&#13;&#10;※ 민원신청, 열람 등의 인증서 로그인(가상키패드 사용 포함)이 필요 한 서비스는 PC환경 만 이용가능하며 모바일 환경에서는 이용하실 수 없습니다.&#13;&#10;   - 인증서 로그인 시 개인민감정보의 입력은 가상키패드 또는 키보드보안 프로그램을 통하여 입력이 가능합니다.&#13;&#10;     (가상키패드는 마우스를 사용하므로 불편하실 수 있습니다.)&#13;&#10;※ 보안성 향상 및 편의성 보장을 위하여, 키보드보안 프로그램 또한 제공하고 있습니다.(사용권장)&#13;&#10;※ 키보드보안 프로그램은 설치가 필요하며 보안 기능이 추가적으로 제공됩니다." left="20" cssclass="sta_Login_MemberNotice_M" initvalueid="ivStcAccessibilityOn" usedecorate="true" height="585" fittocontents="height" right="20" top="100"/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
/**
*  
*  @MenuPath    대국민 검정고시서비스 로그인
*  @FileName 	sqa_cmmcm03_m00.xfdl 
*  @Creator 	박가혜
*  @CreateDate 	2022.06.21
*  @Desction    본인인증
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.06.21           박가혜                 최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/


include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/

this.fv_param;
this.mberNm;
this.mberRrn;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frameLogin_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

// 폼을 초기화
	this.smfInitForm(obj);
	this.fv_param = this.smfGetFormParams();

	//페이지 구분(menuId) 4000:온라인원서접수 5000:원서조회 6000:수험표출력 7000:성적조회
	this.fv_menuId 		= this.fv_param.menuId;
	this.fv_schDivCd 	= this.fv_param.schDivCd;
	this.fv_enfcYr		= this.fv_param.enfcYr;
	this.fv_enfcTme		= this.fv_param.enfcTme;
	this.fv_sqeScCd		= this.fv_param.sqeScCd;

	this.dsMain.addRow();
	this.dsSearch.addRow();
 	var objOption1 = {};
 	var objOption2 = {};
	
//가상키보드 세팅 objOption1 : 공동인증서 , objOption2 : 금융인증서

//가상키보드 : tabstap :false로 하고 주석풀기
	var objOption1 = {
		target : this.divLogin1.form.edtTrprRrno2, //대상 Edit 컴포넌트 [필수]
		targetKey : this.divLogin1.form.staTransKey, //Edit와 쌍으로 있는 마우스입력 체크박스(static) [필수]
		bshow :  true, //  마우스입력 체크박스 보이기 여부 (default = false) [선택]
		maxLength : 7,
		kbdType : "number", //라온 키보드 타입 number/qwerty (default = qwerty)[선택)
	}
	
	var objOption2 = {
		target : this.divLogin2.form.edtTrprRrno2, //대상 Edit 컴포넌트 [필수]
		targetKey : this.divLogin2.form.staTransKey, //Edit와 쌍으로 있는 마우스입력 체크박스(static) [필수]
		bshow : true, //  마우스입력 체크박스 보이기 여부 (default = false) [선택]
		maxLength : 7, 
		kbdType : "number", //라온 키보드 타입 number/qwerty (default = qwerty)[선택)
	}
	
	this.smfInitTranskey(objOption1);
	this.smfInitTranskey(objOption2);
	
	//금융인증서, 간편인증 가리기
	//this.btn01.set_left("514")
	//this.btn02.set_visible(false)
	//this.btn03.set_visible(false)

};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description initData - 초기데이터 조회
*/
this.fnInitData = function(){

}

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd == -1) return;
};

/**
 * 팝업의 콜백함수 지정한다 (공동인증서)
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	var sLog = "";
	var obj = sender.divLogin1.form;
	if(e.result)
	{
		var sData = JSON.parse(e.data);
		
		if(sData.vidResult == "true"){
		
			var subjectDnCn = sData.subjectDn;
			
			if(subjectDnCn.indexOf(mberNm) != -1){  //이름이 포함되어 있을때
			
				this.dsSearch.setColumn(0, "sqeScCd", this.fv_sqeScCd);
				this.dsSearch.setColumn(0, "cddcCd",  this.smfGetCddcCode());
				this.dsSearch.setColumn(0, "trprRrno", mberRrn);
				this.dsSearch.setColumn(0, "kornFlnm", mberNm);
			
				this.fnCallbackConfirmAuth(obj);
			
			}else{
			
				this.smfLiteralAlert("현재 선택하신 인증서의 성명과 입력하신 성명이 일치하지 않습니다.");
			
			}

		}else if(sData.vidResult.indexOf("VID") != -1){ 
		
			this.smfLiteralAlert("입력된 정보와 인증서 정보가 일치하지 않습니다. 다시 한 번 확인 해 주세요.");
			
		}else{
			this.smfLiteralAlert("인증서 인증에 에러가 발생했습니다. 관리자에게 문의하세요.");
		}
		
	}
	else
	{
		var sData = e.data;
		var arrData = sData.split(":");
		
		if(arrData[0].trim()=="800000")
		{  // 유저가 팝업을 강제 종료한 경우
			sLog += "처리결과 : [에러(유저강제종료)]\n";
			sLog += "data : ["+sData+"]";
			
			trace(sLog);			
		}
		else
		{
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+sData+"]";
			
			trace(sLog);			
		}
		
	}
};

/**
 * 팝업의 콜백함수 지정한다 (금융인증서)
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnFinAuthPopupCallback = function(e, sender){
	trace("===>this.fnPopupCallback : popup callback");
	var sLog = "";
	var obj = sender.divLogin2.form;
	if(e.result)
	{
		var sData = e.data;
		
		sLog += "처리결과 : [성공]\n";
		sLog += "data : ["+sData+"]";
		
		trace(sLog);
		var subjectDn = JSON.parse(sData).certificate.subject_dn.toString();
		var dnNm = subjectDn.substring(3, subjectDn.indexOf("("))
		var vidResult = JSON.parse(sData).vidresult.toString();
		
		if(vidResult == "true"){
		
			mberNm = obj.edtKornFlnm.value;
			
			if(dnNm != mberNm){
			
				this.smfLiteralAlert("현재 선택하신 인증서의 성명과 입력하신 성명이 일치하지 않습니다.");
				
			}else{
						
				this.dsSearch.setColumn(0, "trprRrno", mberRrn);
				this.dsSearch.setColumn(0, "kornFlnm", mberNm);
				this.dsSearch.setColumn(0, "sqeScCd",  this.fv_sqeScCd);
				this.dsSearch.setColumn(0, "cddcCd",   this.smfGetCddcCode());
				
				this.fnCallbackConfirmAuth(obj);
			}
		
	
			
		}else if(vidResult == "false"){
		
			this.smfLiteralAlert("입력된 정보와 인증서 정보가 일치하지 않습니다. 다시 한 번 확인 해 주세요.");
			
		}else{
			this.smfLiteralAlert("인증서 인증에 에러가 발생했습니다. 관리자에게 문의하세요.");
		}
	}
	else
	{
		var sData = e.data;
		var arrData = sData.split(":");
		
		if(arrData[0].trim()=="800000")
		{  // 유저가 팝업을 강제 종료한 경우
			sLog += "처리결과 : [에러(유저강제종료)]\n";
			sLog += "data : ["+sData+"]";
			
			trace(sLog);		
		}
		else
		{
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+sData+"]";
			
			trace(sLog);		
		}
		
	}
};

/**
 * 팝업의 콜백함수 지정한다 (간편인증)
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnSimpleAuthPopupCallback = function(e, sender){
	trace("===>this.fnSimpleAuthPopupCallback : popup callback");
	
	var sLog = "";
	var obj = sender.divLogin3.form;

	if(e.result){
		var sData = JSON.parse(e.data);

		if(this.smfIsNull(sData)){
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+sData+"]";
			console.log(sLog);
			this.smfLiteralAlert("본인 인증 인증에 실패 하였습니다..");
			return;
		}
		
		sLog += "처리결과 : [성공]\n";
		//sLog += "data : ["+sData+"]";	
		console.log(sLog);
		
		mberNm = sData.userNm;
		mberRrn = sData.ssn;

		this.dsSearch.setColumn(0, "trprRrno", mberRrn);
		this.dsSearch.setColumn(0, "kornFlnm", mberNm);
		this.dsSearch.setColumn(0, "sqeScCd", this.fv_sqeScCd);
		this.dsSearch.setColumn(0, "cddcCd",  this.smfGetCddcCode());
		
		this.fnCallbackConfirmAuth(obj);
		

	}
}
/************************************************************************************************
 * 사용자 FUNCTION 영역
/************************************************************************************************

/**
 * @description 실명인증 후 세션생성
*/
this.fnCallbackConfirmAuth = function(obj){

		//세션에 정보담기
		this.smfSearchService("selectSessionInfo")
			.run()
			.callback(function(callbackParams){
				if(callbackParams.errors) return;
			
				this.smfSetSessionDataset(this.dsSqaSession);
				
				/* LG002:NPKI /  LG009:금융인증서 /  LG005: 간편인증 */
				if(obj.parent.id == "divLogin1"){ //NPKI
					var sLgnTypCd = "LG002";
				}else if(obj.parent.id == "divLogin2"){ //금융인증서
					var sLgnTypCd = "LG009";
				}else if (obj.parent.id === 'divLogin3'){ // 간편인증 
						sLgnTypCd ='LG005';
				}
				
				//로그인 후 접속이력
				this.smfSendLoginLog(this,sLgnTypCd);
				
				//세션저장 후 처리
				this.fnSelectSession(obj);
			});	
};
/**
 * @description 세션 저장 후 처리
*/
this.fnSelectSession = function(obj){
	//topframe에 세션타임과 로그아웃 버튼
	this.getOwnerFrame().form.divTop.form.fnLoginAfter();
	
	if(this.smfGetSubSystemDetailGb() == "101"){

		this.fnCheckOnlineAccept(); //기존접수건 조회

	}else if(this.smfGetSubSystemDetailGb() == "102"){

			var sUrl = ""
			if(this.fv_param.menuId == "4000"){ //자료확인 및 신청
				sUrl = "pa_sqa_uep_sc::sqa_uepsc03_m00.xfdl"
			}else if(this.fv_param.menuId == "5000"){ //제출현황조회
				sUrl ="pa_sqa_uep_sc::sqa_uepsc04_m00.xfdl"
			}else if(this.fv_param.menuId == "6000"){ //수신대학현황
				sUrl ="pa_sqa_uep_sc::sqa_uepsc05_m00.xfdl"
			}else if(this.fv_param.menuId == "7000"){ //마이페이지
				sUrl ="pa_sqa_mpg_mp::sqa_mpgmp00_m00.xfdl"
			}else{
				//메뉴아이디 없을땐 (상단바 로그인) 메인화면으로 이동
				var objFrame = this.getOwnerFrame();
				
				if(objFrame.form.divAll)
				{
					// Top 에 값을 세팅
					var sMainUrl = objFrame.form.fv_mainformUrl;
					
					// 메인URL로 이동한다.
					if(!this.smfIsNull(sMainUrl))
					{
						
						objFrame.form.fnSetMainpage(sMainUrl);	
					}
				}
				
				return false;
			}
				var params = {
							kornFlnm : mberNm,
							cddcCd : this.smfGetCddcCode(),
							menuId : this.fv_param.menuId};
							
				this.smfSetWorkPage(sUrl, params);
	}
}

this.fnTransKey = function(obj)
{	
	var sVal    = "";
	var arrComp = [obj];  //대상 Edit component List: array [필수]
	
	if(!this.smfIsMobile()){
		// 키보드보안 적용여부
		var sRtnVal = this.smfGetValueTranskey(obj);
	
		if(sRtnVal == "transkey"){	//선택
			var sVal = this.smfGetEncDataTranskey(arrComp);
	
			//전달받은 파라미터 데이터셋에 담기
			this.smfConvRaonDataToDs(this.dsRaonKeyData,arrComp,sVal);
			this.dsRaonKeyData.setColumn(0, 'tk_col_check', "transkey");
		}else if(sRtnVal == "e2e"){ //미선택
			sVal= obj.value;
		}
	}else{
		sVal = this.smfGetEncDataTranskey(arrComp);
		
		//전달받은 파라미터 데이터셋에 담기
		this.smfConvRaonDataToDs(this.dsRaonKeyData,arrComp,sVal);
		this.dsRaonKeyData.setColumn(0, 'tk_col_check', "transkey");
	}
};

