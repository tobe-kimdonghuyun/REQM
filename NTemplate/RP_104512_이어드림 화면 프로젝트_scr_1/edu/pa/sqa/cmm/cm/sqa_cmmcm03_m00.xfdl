this.fnImsiSelectSession = function(obj){

this.getOwnerFrame().form.divTop.form.fnLoginAfter();

		if(this.smfGetSubSystemDetailGb() == "101"){

		this.fnImsiCheckOnlineAccept(); //기존접수건 조회
			

	}else if(this.smfGetSubSystemDetailGb() == "102"){

			var sUrl = ""
			if(this.fv_param.menuId == "4000"){ //자료확인 및 신청
				sUrl = "pa_sqa_uep_sc::sqa_uepsc03_m00.xfdl"
			}else if(this.fv_param.menuId == "5000"){ //제출현황조회
				sUrl ="pa_sqa_uep_sc::sqa_uepsc04_m00.xfdl"
			}else if(this.fv_param.menuId == "6000"){ //수신대학현황
				sUrl ="pa_sqa_uep_sc::sqa_uepsc05_m00.xfdl"
			}else if(this.fv_param.menuId == "7000"){ //마이페이지
				sUrl ="pa_sqa_mpg_mp::sqa_mpgmp00_m00.xfdl"
			}else{
				//메뉴아이디 없을땐 (상단바 로그인) 메인화면으로 이동
				var objFrame = this.getOwnerFrame();
				
				if(objFrame.form.divAll)
				{
					// Top 에 값을 세팅
					var sMainUrl = objFrame.form.fv_mainformUrl;
					
					// 메인URL로 이동한다.
					if(!this.smfIsNull(sMainUrl))
					{
						
						objFrame.form.fnSetMainpage(sMainUrl);	
					}
				}
				
				return false;
			}
				var params = {
							kornFlnm : mberNm,
							cddcCd : this.smfGetCddcCode(),
							menuId : this.fv_param.menuId};
							
				this.smfSetWorkPage(sUrl, params);
	}
}
this.fnImsiCheckOnlineAccept = function(){

	trace("2.기존접수건조회")

	this.dsSearch.setColumn(0, "enfcYr",  this.fv_enfcYr);
	this.dsSearch.setColumn(0, "enfcTme",  this.fv_enfcTme);
	this.dsSearch.setColumn(0, "sqeScCd",  this.fv_sqeScCd);
	this.dsSearch.setColumn(0, "cddcCd", this.smfGetCddcCode());
	this.dsSearch.setColumn(0, "menuId", this.fv_menuId);
	this.dsSearch.setColumn(0, "schDivCd", this.fv_schDivCd);
	
	this.dsSearch.setColumn(0, "trprRrno", this.smfGetTrprRrno());
	this.dsSearch.setColumn(0, "kornFlnm", mberNm);
	
	this.smfSearchService("selectPbancYmd")
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;

			this.dsSearch.setColumn(0,"pbancYmd", this.dsMain.getColumn(0,"pbancYmd")); //공고일 조회. 핸드폰번호 조회해올때 같이 조회 해옴(listPhoneNumber)
			
			this.smfSearchService("selectIdCheck")
			// 실행
			.run()

			// 콜백
			.callback(function(callbackParams){
				if(callbackParams.errors) return;

				this.fnCheckOnlineAcceptCallBackSuccess();
			});	
			
		});	
	
}


this.divLogin_edtTrprRrno2_oneditclick = function(obj:nexacro.Edit,e:nexacro.ChangeEventInfo)
{
