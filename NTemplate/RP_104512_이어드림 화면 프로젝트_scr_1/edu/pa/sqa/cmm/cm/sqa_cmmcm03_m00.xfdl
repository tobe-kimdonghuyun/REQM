this.fnImsiCallbackConfirmAuth = function(obj){
 //가상키보드사용시
if(this.chk(obj)){

	//@KBR 입력된 참여번호 가져오기
	var transKey = this.fnTransKey(obj.parent.edtTrprRrno2);
	this.dsRaonKeyData.setColumn(0,"trprRrno1",obj.parent.edtTrprRrno1.value)
	this.smfSearchService("selectKeyDec")
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		
			
			obj.parent.edtTrprRrno2.set_value(this.dsMain.getColumn(0,"trprRrno2"))
			var sRrno = obj.parent.edtTrprRrno1.value + this.dsMain.getColumn(0,"trprRrno2");
			 
			if(this.checkRrno(sRrno,obj)){
				mberNm = obj.parent.edtKornFlnm.value;
				mberRrn = this.dsMain.getColumn(0,"encRrno");

				this.dsSearch.setColumn(0,"trprRrno",this.dsMain.getColumn(0,"encRrno"));
				this.dsSearch.setColumn(0, "sqeScCd", this.fv_sqeScCd);
				this.dsSearch.setColumn(0, "cddcCd", this.smfGetCddcCode());
				this.dsSearch.setColumn(0,"kornFlnm",mberNm);
				
				this.dsSearch.setColumn(0, "enfcYr", this.fv_enfcYr);
				this.dsSearch.setColumn(0, "enfcTme",this.fv_enfcTme);
				
			//<------------		
							//세션에 정보담기
					this.smfSearchService("selectSessionInfo")
						
						// 실행
						.run()

						// 콜백
						.callback(function(callbackParams){
							if(callbackParams.errors) return;
							//세션에 담기
							this.smfSetSessionDataset(this.dsSqaSession);
							
							this.fnImsiSelectSession(obj);
									
						});
			}
		});	 		
}


