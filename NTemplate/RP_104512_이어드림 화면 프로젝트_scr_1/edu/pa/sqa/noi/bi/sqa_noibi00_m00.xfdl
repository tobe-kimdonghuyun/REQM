                          <Cell col="2" text="10:00~10:40" textAlign="center"/>
                          <Cell col="3" text="11:00~11:40" textAlign="center" cssclass="LineNo"/>
                          <Cell row="1" text="배분시간" textAlign="center"/>
                          <Cell row="1" col="1" text="40분" textAlign="center"/>
                          <Cell row="1" col="2" text="40분" textAlign="center"/>
                          <Cell row="1" col="3" text="40분" textAlign="center" cssclass="LineNo"/>
                          <Cell row="2" text="과목" textAlign="center"/>
                          <Cell row="2" col="1" text="국어, 사회" textAlign="center"/>
                          <Cell row="2" col="2" text="수학, 과학" textAlign="center"/>
                          <Cell row="2" col="3" text="선택1, 선택2" textAlign="center" cssclass="LineNo"/>
                        </Band>
                      </Format>
                    </Formats>
                  </Grid>
                  <Static id="sta00_00_00_00_00_01" taborder="13" text="※ &lt;b v='true'&gt;&lt;u v='true'&gt;시험당일 해당 교육청의 공고 시간을 준수하여 지정 시험실에 입실&lt;/u&gt;&lt;/b&gt;하여야 함" left="0" top="grdMeq03:10" height="22" cssclass="sta_WF_Blue14" onclick="sta00_00_00_00_onclick" initvalueid="ivStcAccessibilityOn" usedecorate="true" width="600"/>
                  <Static id="sta00_00_00_00_00_01_00" taborder="14" left="0" top="sta00_00_00_00_00_01:0" height="22" cssclass="sta_WF_Blue14" onclick="sta00_00_00_00_onclick" initvalueid="ivStcAccessibilityOn" usedecorate="true" width="600" text="※ 일반응시자의 일부과목 응시자는 과목 당 시험시간을 20분으로 제한함"/>
                  <ImageViewer id="img00_00_00_00_00_00_00_00" taborder="15" text="▪ 응시자격 및 응시자격 제한" left="0" top="sta00_00_00_00_00_01_00:20" width="230" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
                  <Grid id="grdMeq04" taborder="16" left="0" top="img00_00_00_00_00_00_00_00:10" height="200" binddataset="ds04" autofittype="col" initvalueid="ivGrdAccessibilityOn" useselcolor="false" right="0" selecttype="cell" scrollbartype="none none" scrolltype="none" accessibilitylabel="응시자격설명목록">
                    <Formats>
                      <Format id="default">
                        <Columns>
                          <Column size="250"/>
                          <Column size="250"/>
                        </Columns>
                        <Rows>
                          <Row size="36" band="head"/>
                          <Row size="168"/>
                        </Rows>
                        <Band id="head">
                          <Cell text="응시자격"/>
                          <Cell col="1" text="응시자격 제한" cssclass="LineNo"/>
                        </Band>
                        <Band id="body">
                          <Cell text="①검정고시가 시행되는 해의 전(前)년도를 기준으로 만11세 이상인 자로서 초등학교 교육과정을 이수하지 아니한 자 &#13;&#10;②초등학교(특수학교 포함) 재학생 중 만 11세 이상인 자로서,「초·중등교육법시행령」제29조의 규정에 의하여 학적이 정원외로 관리되는 자  &#13;&#10;③「보호소년 등의 처우에 관한 법률 시행령」제69조 제1호에 해당하는 자" textAlign="left" wordWrap="char"/>
                          <Cell col="1" text="①초등학교(특수학교 포함) 재학 중인 자&#13;&#10;②공고일 이후 초등학교(특수학교 포함)의 학교에 재학 중 학적이 정원외로 관리되는 자&#13;&#10;③공고일 기준으로 고시에 관하여 부정행위를 한 자로서 처분일부터 응시자격제한 기간이 경과되지 아니한 자" wordWrap="char" cssclass="LineNo"/>
                        </Band>
                      </Format>
                    </Formats>
                  </Grid>
                  <ImageViewer id="img00_00_00_00_00_00_00_00_00" taborder="17" text="▪ 합격자 결정" left="0" top="grdMeq04:20" width="120" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
                  <Static id="sta01" taborder="18" text="① 고시 합격" left="0" top="img00_00_00_00_00_00_00_00_00:20" width="120" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
                  <Static id="sta00" taborder="19" left="0" top="sta01:0" height="42" cssclass="sta_WF_Black14" text="- 각 과목을 100점 만점으로 하여 전 과목 평균 60점 이상을 취득한 자&#13;&#10;- 단, 전 과목 평균이 60점 이상일지라도 결시과목이 있을 경우에는 불합격 처리함" usedecorate="true" initvalueid="ivStcAccessibilityOn" width="550"/>
                  <Static id="sta01_00" taborder="20" text="② 과목 합격" left="0" top="sta00:7" width="120" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn"/>
                  <Static id="sta00_01" taborder="21" left="0" top="sta01_00:0" height="62" cssclass="sta_WF_Black14" text="- 검정고시 불합격자 중 고시성적이 60점 이상인 과목에 대하여는 과목합격을 인정하고, 본인이 원할 경우 차후 고시에 있어서 당해 과목의 고시를 면제하며, &#13;&#10;  그 면제되는 과목의 성적을 고시성적에 합산할 수 있음&#13;&#10;- 기존 과목합격자가 해당과목을 재응시할 경우, 기존 과목합격성적과 상관없이 재응시한 과목 성적으로 합격여부를 결정함" usedecorate="true" initvalueid="ivStcAccessibilityOn" width="1140"/>
                  <ImageViewer id="img00_00_00_00_00_00_00_00_00_00" taborder="22" text="▪ 합격 취소" left="0" top="sta00_01:21" width="103" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
                  <Static id="sta00_01_00" taborder="23" left="0" top="img00_00_00_00_00_00_00_00_00_00:0" height="64" cssclass="sta_WF_Black14" text="① 응시자격에 결격이 있는 자&#13;&#10;② 제출서류를 위조 또는 변조한 자&#13;&#10;③ 부정행위자" usedecorate="true" initvalueid="ivStcAccessibilityOn" width="600"/>
                  <Static id="sta00_00_00_00_00_01_00_00" taborder="24" text="※ 부정행위자는 부정행위를 행한 회차 이후 2년간 검정고시 응시가 제한될 수 있음" left="0" top="sta00_01_00:0" height="30" cssclass="sta_WF_Blue14" onclick="sta00_00_00_00_onclick" initvalueid="ivStcAccessibilityOn" usedecorate="true" width="600"/>
                  <Static id="sta00_01_00_00_00" taborder="25" left="0" top="1652" height="21" cssclass="sta_WF_Black14" usedecorate="true" initvalueid="ivStcAccessibilityOn" width="600"/>
                  <Static id="sta00_00_01_01_00_00_00_00_00_00_00_00_00_00" taborder="26" left="0" top="sta00_00_00_00_00_01_00_00:20" height="30" text="이 외 자세한 내용은, 각·시도교육청 홈페이지에서 [검정고시 공고] 참조 바람" wordWrap="char" cssclass="sta_WF_InfoTit02" initvalueid="ivStcAccessibilityOn" usedecorate="true" width="600"/>
                  <Static id="Static99_00_00_00_00_01_00_00_01_00" taborder="27" left="0" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
                  <Static id="Static99_00_00_00_00_01_00_00_01_00_01" taborder="28" left="0" top="63" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
                  <Static id="Static99_00_00_00_00_01_00" taborder="29" left="0" top="240" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" right="0"/>
                  <Static id="Static99_00_00_00_00_01_00_00_01_00_01_00" taborder="30" left="0" top="418" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
                  <Static id="Static99_00_00_00_00_01_00_00" taborder="31" left="0" top="484" height="20" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" right="0"/>
                </Layout>
              </Layouts>
