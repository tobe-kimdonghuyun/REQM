                  <Static id="Static99_00_00_00_00_01_00_00_00_01" taborder="33" left="0" top="938" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" right="0"/>
                  <Static id="Static99_00_00_00_00_01_00_00_00_01_00" taborder="34" left="0" top="1156" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" right="0"/>
                  <Static id="Static99_00_00_00_00_01_00_00_00_00_00_00" taborder="35" left="0" top="1459" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" right="0"/>
