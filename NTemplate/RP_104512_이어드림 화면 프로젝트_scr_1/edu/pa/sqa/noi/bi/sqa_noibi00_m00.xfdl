                  <Static id="sta00_00_00_00_00" taborder="11" text="※ 2015년 개정 교육과정 고시일 : 2015. 09. 23." left="0" top="844" height="44" cssclass="sta_WF_Blue14" onclick="sta00_00_00_00_onclick" initvalueid="ivStcAccessibilityOn" usedecorate="true" width="800"/>
                  <ImageViewer id="img00_00_00_00_00_00" taborder="12" text="▪ 출제수준 : 고등학교 졸업 정도의 지식과 그 응용 능력을 측정할 수 있는 수준" left="0" top="908" width="680" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
