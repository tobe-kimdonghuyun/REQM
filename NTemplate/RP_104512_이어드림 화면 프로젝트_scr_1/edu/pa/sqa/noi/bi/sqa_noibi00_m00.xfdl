                  </Grid>
                  <ImageViewer id="img00_00_00_00_00" taborder="8" text="▪ 출제범위 : 2015 개정 교육과정에 근거하여 출제" left="0" top="682" width="390" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
                  <Static id="sta00_00_00_00_00" taborder="9" text="※ 2015년 개정 교육과정 고시일 : 2015. 09. 23.&#13;&#10;※ 문제은행(기출문항 포함) 출제 방식을 학교 급별로 차등 적용&#13;&#10;   → 초졸 50% 내외, 중졸 30% 내외, 고졸: 적용하지 않음" left="0" top="722" height="72" cssclass="sta_WF_Blue14" onclick="sta00_00_00_00_onclick" initvalueid="ivStcAccessibilityOn" usedecorate="true" width="1000"/>
                  <ImageViewer id="img00_00_00_00_00_00" taborder="10" text="▪ 출제수준 : 초등학교 졸업 정도의 지식과 기초 능력을 측정할 수 있는 수준" left="0" top="sta00_00_00_00_00:22" width="570" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
                  <ImageViewer id="img00_00_00_00_00_00_00" taborder="11" text="▪ 고사 시간표" left="0" top="img00_00_00_00_00_00:20" width="120" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
                  <Grid id="grdMeq03" taborder="12" left="0" top="img00_00_00_00_00_00_00:10" height="150" binddataset="ds03" autofittype="col" autosizebandtype="body" useselcolor="false" initvalueid="ivGrdAccessibilityOn" right="0" selecttype="cell" scrollbartype="none none" scrolltype="none" accessibilitylabel="시간표목록">
                    <Formats>
