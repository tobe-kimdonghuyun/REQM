<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frm01" width="1200" height="1040" titletext="성적조회-개인성적조회" onload="frm01_onload">
    <Layouts>
      <Layout height="1040" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="65" height="54" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="성적조회" left="0" top="0" height="54" cssclass="img_WF_SubTit01" width="160" initvalueid="ivTitleAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <ImageViewer id="imgSubTitle" taborder="1" text="" left="0" top="136" width="638" height="40" cssclass="img_WF_SubTit02" initvalueid="ivTitleAccessibilityOn" fittocontents="width"/>
        <Div id="divApplpInfo" taborder="2" left="0" height="112" top="188" text="" cssclass="div_WF_Detail" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="sta44" taborder="0" left="0" height="63" cssclass="sta_WF_Input02Top" top="0" right="0" text="" initvalueid="ivStcAccessibilityOff" onclick="Div03_00_sta44_onclick"/>
              <Static id="sta45" taborder="1" left="0" width="160" height="63" cssclass="sta_WF_Input01Top" text="성명" top="0" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtKornFlnm" taborder="2" height="30" text="중학교졸업" left="165" width="260" top="16" readonly="true" onchanged="Div01_Edit00_onchanged" cssclass="edi_WF_Input" initvalueid="ivEdtReadOnly" accessibilitylabel="성명"/>
              <Static id="sta45_01" taborder="3" left="430" width="160" height="63" cssclass="sta_WF_Input01Top" text="주민등록번호&#13;&#10;(외국인등록번호)" top="0" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtTrprRrno1" taborder="4" height="30" text="6235690" left="595" width="70" top="16" readonly="true" onchanged="Div01_Edit00_onchanged" cssclass="edi_WF_Input" initvalueid="ivEdtReadOnly" textAlign="left" accessibilitylabel="주민번호앞자리"/>
              <Static id="edtTrprRrno0" taborder="5" text="-" left="665" top="16" width="15" height="30" cssclass="sta_WF_AC" initvalueid="ivStcAccessibilityOn" accessibilitylabel="다음"/>
              <Edit id="edtTrprRrno2" taborder="6" height="30" text="1235616" left="680" width="82" top="16" readonly="true" onchanged="Div01_Edit00_onchanged" cssclass="edi_WF_Input" initvalueid="ivEdtReadOnly" textAlign="left" accessibilitylabel="주민번호뒷자리"/>
              <Static id="sta45_01_00" taborder="7" left="830" width="160" height="63" cssclass="sta_WF_Input01Top" text="접수번호" top="0" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtRcptNo" taborder="8" height="30" text="강원고등학교" left="995" top="16" readonly="true" onchanged="Div01_Edit00_onchanged" cssclass="edi_WF_Input" initvalueid="ivEdtReadOnly" width="200" accessibilitylabel="접수번호"/>
              <Static id="sta44_01" taborder="9" left="0" height="42" cssclass="sta_WF_Input02" top="62" right="0" text="" initvalueid="ivStcAccessibilityOff" onclick="divApplpInfo_sta44_01_onclick"/>
              <Static id="sta45_00" taborder="10" left="0" width="160" cssclass="sta_WF_Input01" text="합격구분" top="62" onclick="Static45_onclick" height="42" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtPassScCd" taborder="11" height="30" text="중학교졸업" left="165" width="260" top="68" readonly="true" onchanged="Div01_Edit00_onchanged" cssclass="edi_WF_Input" initvalueid="ivEdtReadOnly" accessibilitylabel="합격구분"/>
            </Layout>
          </Layouts>
        </Div>
        <Grid id="grd00" taborder="3" left="0" top="312" height="280" binddataset="dsAriSi" autofittype="col" cellmovingtype="col" right="0" selecttype="cell" initvalueid="ivGrdAccessibilityOn" accessibilitylabel="성적조회">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="166"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
                <Row size="40" band="summ"/>
              </Rows>
              <Band id="head">
                <Cell text="과목명"/>
                <Cell col="1" text="성적"/>
                <Cell col="2" text="합격여부"/>
                <Cell col="3" text="비고"/>
              </Band>
              <Band id="body">
                <Cell text="bind:kornSbjtNm" textAlign="center"/>
                <Cell col="1" text="bind:sbjtScr" textAlign="center" displaytype="normal" edittype="none"/>
                <Cell col="2" text="bind:sbjtPassTme" textAlign="center"/>
                <Cell col="3" text="bind:pilsun" textAlign="center"/>
              </Band>
              <Band id="summary">
                <Cell text="총점" textAlign="center"/>
                <Cell col="1" textAlign="center" text="bind:evlTtsr" expr="dataset.parent.dsAriSi.getColumn(0,&quot;evlTtsr&quot;)" maskeditformat="9,999.99" edittype="none" displaytype="normal"/>
                <Cell col="2" text="평균" textAlign="center"/>
                <Cell col="3" textAlign="center" expr="dataset.parent.dsAriSi.getColumn(0,&quot;evlAvrg&quot;)"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Div id="divSrc" taborder="4" left="0" height="42" top="835" text="" cssclass="div_WF_Detail" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout/>
          </Layouts>
        </Div>
        <Static id="Static99_00_00_00_00" taborder="5" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01" taborder="6" left="0" top="114" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_00" taborder="7" left="0" top="168" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta99_00_00_00_00_01_01_00" taborder="8" left="0" top="292" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsSearch">
        <ColumnInfo>
          <Column id="enfcYr" type="STRING" size="256"/>
          <Column id="enfcTme" type="STRING" size="256"/>
          <Column id="sqeScCd" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="rcptNo" type="STRING" size="256"/>
          <Column id="trprRrno" type="STRING" size="256"/>
          <Column id="kornFlnm" type="STRING" size="256"/>
          <Column id="sqeExmtNo" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsAriSi" useclientlayout="true">
        <ColumnInfo>
          <Column id="enfcYr" type="STRING" size="256"/>
          <Column id="enfcTme" type="STRING" size="256"/>
          <Column id="sqeScCd" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="kornFlnm" type="STRING" size="256"/>
          <Column id="trprRrno" type="STRING" size="256"/>
          <Column id="sqeExmtNo" type="STRING" size="256"/>
          <Column id="rcptNo" type="STRING" size="256"/>
          <Column id="passScCd" type="STRING" size="256" description="합격구분"/>
          <Column id="sqeScCdNm" type="STRING" size="256"/>
          <Column id="kornSbjtNm" type="STRING" size="256"/>
          <Column id="sbjtScr" type="STRING" size="256"/>
          <Column id="sbjtPassTme" type="STRING" size="256"/>
          <Column id="pilsun" type="STRING" size="256"/>
          <Column id="evlTtsr" type="STRING" size="256" description="평가총점"/>
          <Column id="evlAvrg" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsService">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">selectAriSi</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="url">sqa_ari_si00_001.do</Col>
            <Col id="outDatasets">dsAriSi=dsAriSi</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 검정고시서비스 성적조회-개인성적조회
*  @FileName 	sqa_arisi00_m00.xfdl 
*  @Creator 	박가혜
*  @CreateDate 	2022.08.09
*  @Desction    개인성적조회
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.08.09           박가혜                 최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/




include "lib::cm_script.xjs"
include "lib::sqa_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.fv_param;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frm01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	
	// 폼을 초기화
	this.smfInitForm(obj);
	this.fv_param = this.smfGetFormParams();

	this.dsSearch.addRow();
	// 파라메터 세팅
	this.fv_param = this.smfGetFormParams();
	this.fnSetInitParam(this.smfGetFormParams());
	
 	this.dsSearch.setColumn(0, "enfcYr", this.fv_param.enfcYr);
 	this.dsSearch.setColumn(0, "enfcTme", this.fv_param.enfcTme);
 	this.dsSearch.setColumn(0, "sqeScCd", this.fv_param.sqeScCd);
 	this.dsSearch.setColumn(0, "cddcCd", this.smfGetSessionValue("cddcCd"));
	this.dsSearch.setColumn(0, "rcptNo", this.smfIsNull(this.fv_param.rcptNo) ? "" : this.fv_param.rcptNo);
	this.dsSearch.setColumn(0, "kornFlnm", this.smfGetSessionValue("kornFlnm"));
	this.dsSearch.setColumn(0, "sqeExmtNo", this.smfIsNull(this.fv_param.sqeExmtNo) ? "" : this.fv_param.sqeExmtNo);
	
	this.fnInit(); 
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnInit = function()
{
	this.smfSearchService("selectAriSi")
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.fnSetData();
		});	
	
	
}




/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd == -1) return;
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 기초데이터 셋팅
*/
this.fnSetData = function(){
	this.imgSubTitle.set_text(this.fv_enfcYr + "년도 "+ this.fv_enfcTme + "회차 "
					+ this.dsAriSi.getColumn(0,"sqeScCdNm") + " 수험자 정보")
					
	this.divApplpInfo.form.edtRcptNo.set_value(this.fv_param.rcptNo);
	
	//주민등록번호
	var trprRrno = this.dsAriSi.getColumn(0,"trprRrno")
	if(trprRrno.length > 0){
		this.divApplpInfo.form.edtTrprRrno1.set_value(trprRrno.substring(0,6))
		this.divApplpInfo.form.edtTrprRrno2.set_value(trprRrno.substring(6,7)+"******")
	}
	
	this.smfGrdResetHeight(this.grd00) 
	this.smfResetScroll(this.grd00)

}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

]]></Script>
    <Bind>
      <BindItem id="item3" compid="divApplpInfo.form.edtKornFlnm" propid="value" datasetid="dsAriSi" columnid="kornFlnm"/>
      <BindItem id="item1" compid="divApplpInfo.form.edtPassScCd" propid="value" datasetid="dsAriSi" columnid="passScCd"/>
    </Bind>
  </Form>
</FDL>
