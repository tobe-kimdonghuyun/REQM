    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교과용도서(공급업체서비스)-학교별 주문정보 조회
*  @FileName 	ibm_ibsfs01_m00.xfdl 
*  @Creator 	Kangchaeyoon
*  @CreateDate 	2022.12.27 
*  @Desction    교과용도서(공급업체서비스)-학교별 주문정보 조회
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.12.27            Kangchaeyoon                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	//필수 파라미터 값 세팅
	this.dsSearch.setColumn(0, "cddcCd", this.smfGetCddcCode());
	
	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
			url : "/ibm_ims_fs01_000.do",
		})
		.mappingRulesetToForm(this.divSearch, "search")
		.callback(function(callbackParams) {
		})
		.run()
	;
	
	// 공통코드의 코드구분
	this.smfCodeList("code", [this.dsSemScCd, this.dsUtxbScCd, this.dsShlKndScCd, this.dsThmrScCd, this.dsBosWrkScCd])
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			//공통코드 데이터셋 값 재세팅
			this.dataCodeValueSet();			
		})
	;
	
	//신청년도 값 세팅
	//this.dsSearch.setColumn(0, "bosAplyTrgtYr", this.smfToday().substr(0, 4));
	this.fnSearchTrgtYr();

	//관할지원청 목록 조회
	this.fnSearchCteOrg();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 조회조건 - 신청년도 조회 Transaction
 */
this.fnSearchTrgtYr = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("selectTrgtYr")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.dsAplyTrgtYr.getRowCount() > 0){
				this.dsSearch.setColumn(0, "bosAplyTrgtYr", this.dsAplyTrgtYr.getColumn(0, "txbAplyYr"));
			}else{
				this.dsSearch.setColumn(0, "bosAplyTrgtYr", this.smfToday().substr(0, 4));
			}
		});
}; 
 
/**
 * @description 조회조건 - 관할교육지원청 리스트 조회 Transaction
 */
this.fnSearchCteOrg = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("listCteOrg")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.dsCteOrgList.getRowCount() < 0) return;
			
			this.dsCteOrgList.insertRow(0);
			this.dsCteOrgList.setColumn(0, "cteOrgNm", "- 전체 -");
			this.dsCteOrgList.setColumn(0, "cteOrgCd", "");
			this.divSearch.form.cboCteOrg.set_index(0);
		});
};

/**
 * @description 주문정보 조회 Transaction
 */
this.fnSearch = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){
				//총 조회건수 세팅
				this.totalRowCountSet();
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')]);
			}
			
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 총 조회건수 세팅
 */
this.totalRowCountSet = function(){
	
	var rowCnt = this.dsMain.getRowCount();
	if(!this.isNil(rowCnt)) rowCnt == 0;

	this.staTotal.set_text(rowCnt+"건");

}

/**
 * @description 공통코드 데이터셋 값 재세팅
 */
this.dataCodeValueSet = function(){
	//학교구분 데이터셋에 필요한 값만 세팅
	this.dsShlKndScCd.filter('unyCdValue < 6');
	
	//교과서/지도서구분 데이터셋에 필요한 값만 세팅
	this.dsThmrScCd.filter('unyCdValue <= 1 || unyCdValue == 3');
	
	//학기구분 데이터셋에 필요한 값만 세팅
	this.dsSemScCd.filter('unyCdValue < 3');
	
	//신청구분 데이터셋에 필요한 값만 세팅
	this.dsBosWrkScCd.filter('unyCdValue != 4 && unyCdValue != 5');
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description '조회' 버튼 클릭 시
 */
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//필수값 확인
	var bosAplyTrgtYr = this.dsSearch.getColumn(0, "bosAplyTrgtYr");
	if(this.isNil(bosAplyTrgtYr) || bosAplyTrgtYr < 1){
		this.divSearch.form.spnAplyYr.setFocus();
		this.smfAlert('CM006',['신청학년도']);
		return;
	}
	
	var bosAplyTrgtSem = this.dsSearch.getColumn(0, "bosAplyTrgtSem");
	if(this.isNil(bosAplyTrgtSem)){
		this.divSearch.form.cboSemSc.setFocus();
		this.smfAlert('CM006',['학기']);
		return;
	}
	
	var bosWrkScCd = this.dsSearch.getColumn(0, "bosWrkScCd");
	if(this.isNil(bosWrkScCd)){
		this.divSearch.form.cboAplySc.setFocus();
		this.smfAlert('CM006',['신청구분']);
		return;
	}
	var test1 = this.dsMain.getColumn(0, "utxbCd");
	var test2 = this.dsMain.getColumn(0, "utxbNm");
	trace("test1: " + test1);
	trace("test2: " +test2);
	console.log(test1);
	console.log(test2);
	//주문정보 조회
	this.fnSearch();
};

/**
 * @description '자료내려받기' 버튼 클릭 시
 */
this.btnDownload_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objOption = {
					objGrid : this.grdMain
				,   sheetname : "Sheet1"
				,   filename : "공급업체별 주문정보"
				};
	this.smfExcelExport(objOption);
};
]]></Script>
    <Bind>
      <BindItem id="item3" compid="divSearch.form.cboAplyYr" propid="value" datasetid="dsSearch" columnid="bosAplyTrgtYr"/>
      <BindItem id="item0" compid="divSearch.form.cboShlSc" propid="value" datasetid="dsSearch" columnid="shlKndScCd"/>
      <BindItem id="item1" compid="divSearch.form.edtSplComyNm" propid="value" datasetid="dsSearch" columnid="splComyNm"/>
      <BindItem id="item2" compid="divSearch.form.edtPucSc" propid="value" datasetid="dsSearch" columnid="pucNm"/>
      <BindItem id="item4" compid="divSearch.form.edtShl" propid="value" datasetid="dsSearch" columnid="shlNm"/>
      <BindItem id="item5" compid="divSearch.form.edtAutNm" propid="value" datasetid="dsSearch" columnid="autNm"/>
      <BindItem id="item6" compid="divSearch.form.edtBosNm" propid="value" datasetid="dsSearch" columnid="utxbNm"/>
      <BindItem id="item7" compid="divSearch.form.cboSemSc" propid="value" datasetid="dsSearch" columnid="bosAplyTrgtSem"/>
      <BindItem id="item8" compid="divSearch.form.cboTxbCchSc" propid="value" datasetid="dsSearch" columnid="thmrScCd"/>
      <BindItem id="item9" compid="divSearch.form.cboCteOfcdc" propid="value" datasetid="dsSearch" columnid="cteOrgCd"/>
      <BindItem id="item10" compid="divSearch.form.cboBosSc" propid="value" datasetid="dsSearch" columnid="utxbScCd"/>
      <BindItem id="item11" compid="divSearch.form.spnAplyYr" propid="value" datasetid="dsSearch" columnid="bosAplyTrgtYr"/>
      <BindItem id="item12" compid="divSearch.form.cboAplySc" propid="value" datasetid="dsSearch" columnid="bosWrkScCd"/>
      <BindItem id="item13" compid="divSearch.form.cboCteOrg" propid="value" datasetid="dsSearch" columnid="cteOrgCd"/>
    </Bind>
  </Form>
</FDL>
