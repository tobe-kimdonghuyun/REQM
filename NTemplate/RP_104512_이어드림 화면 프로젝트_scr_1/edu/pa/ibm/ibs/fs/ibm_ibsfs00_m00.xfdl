    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교과용도서 > 공급업체서비스 > 공급학교 정보 조회
*  @FileName 	ibm_ibsfs00_m00.xfdl 
*  @Creator 	Kangchaeyoon
*  @CreateDate 	2022.12.27 
*  @Desction    교과용도서 > 공급업체서비스 > 공급학교 정보 조회
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.12.27            Kangchaeyoon                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_cddcCd; // 시도교육청 코드
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	//필수 파라미터 값 세팅
	this.fv_cddcCd = this.smfGetCddcCode();
	this.dsSearch.setColumn(0, "cddcCd", this.fv_cddcCd);
	
	//조회조건 필수 값 세팅
	this.searchValueSet();

};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 공급업체 정보조회 Transaction
 */
this.fnSearchList = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){
				//주소 값 합치기
				this.addAddr();
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')]);
			}
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 조회조건 필수 값 세팅
 */
this.searchValueSet = function(){
	//신청년도 기본 값(올해) 세팅
	//this.dsSearch.setColumn(0, "bosAplyTrgtYr", this.smfToday().substr(0, 4));
	
	// 서비스 객체 생성
	this.smfSearchService("selectTrgtYr")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.dsAplyTrgtYr.getRowCount() > 0){
				this.dsSearch.setColumn(0, "bosAplyTrgtYr", this.dsAplyTrgtYr.getColumn(0, "txbAplyYr"));
			}else{
				this.dsSearch.setColumn(0, "bosAplyTrgtYr", this.smfToday().substr(0, 4));
			}
		});
}

/**
 * @description 주소 합치기
 */
this.addAddr = function(){
	var roadNmAddr = this.dsComyInfo.getColumn(0, "splComyRoadNmAddr");
	var roadNmAddrDtl = this.dsComyInfo.getColumn(0, "splComyRoadNmDtlAddr");
	this.dsComyInfo.setColumn(0, "allRoadNmAddr", roadNmAddr+roadNmAddrDtl);
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description '조회' 버튼 클릭 시
 */
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//공급업체 정보조회
	this.fnSearchList();
};
]]></Script>
