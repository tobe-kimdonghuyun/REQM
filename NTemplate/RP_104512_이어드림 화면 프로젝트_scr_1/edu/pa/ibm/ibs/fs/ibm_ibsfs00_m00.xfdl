          <Column id="telno" type="STRING" size="256" description="전화번호"/>
          <Column id="mblTelno" type="STRING" size="256" description="휴대전화"/>
          <Column id="emlAddr" type="STRING" size="256" description="이메일"/>
          <Column id="splComyRoadNmZip" type="STRING" size="256" description="도로명우편번호"/>
          <Column id="splComyRoadNmAddr" type="STRING" size="256" description="도로명주소"/>
          <Column id="splComyRoadNmDtlAddr" type="STRING" size="256" description="도로명 상세주소"/>
          <Column id="allRoadNmAddr" type="STRING" size="256" description="도로명주소 전체"/>
        </ColumnInfo>
        <Rows>
