              <Static id="staSbjt" taborder="0" text="교과목명" left="6" top="14" width="120" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtSbjtNm" taborder="1" left="staSbjt:10" top="14" height="30" text="우리날" width="150" initvalueid="ivEdtNormal" maxlength="50" autoselect="true" onkeydown="divSearch_edt_onkeydown"/>
              <Static id="staUtxbNm" taborder="2" text="도서명" left="edtSbjtNm:20" top="14" width="120" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtUtxbNm" taborder="3" left="staUtxbNm:10" top="14" height="30" text="우리날" width="150" initvalueid="ivEdtNormal" maxlength="50" autoselect="true" onkeydown="divSearch_edt_onkeydown"/>
              <Button id="btnSearch" taborder="8" text="조회" top="52" width="74" height="30" cssclass="btn_WF_Search03" right="10" initvalueid="ivBtnAccessibilityButton" onclick="fnSearch"/>
              <Static id="staPucSc" taborder="4" text="출판사명" left="6" top="staSbjt:8" width="120" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtPucNm" taborder="5" left="staPucSc:10" top="52" height="30" text="우리날" width="150" initvalueid="ivEdtNormal" maxlength="50" autoselect="true" onkeydown="divSearch_edt_onkeydown"/>
              <Static id="staAutNm" taborder="6" text="저자명" left="306" top="52" width="120" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtAutNm" taborder="7" left="staAutNm:10" top="52" height="30" text="우리날" width="150" initvalueid="ivEdtNormal" maxlength="50" autoselect="true" onkeydown="divSearch_edt_onkeydown"/>
