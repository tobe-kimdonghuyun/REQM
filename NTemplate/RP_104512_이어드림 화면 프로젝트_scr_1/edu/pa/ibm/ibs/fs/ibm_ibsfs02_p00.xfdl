<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="ibm_ibsfs02_p00" width="1000" height="800" titletext="도서등록" nHeight="754" onload="fnOnload">
    <Layouts>
      <Layout height="800" width="1000" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
