        <Static id="sta04" taborder="11" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="20" height="800" left="0"/>
        <Static id="sta05" taborder="12" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="20" right="0" height="800"/>
        <Button id="btnSave" taborder="4" text="등록" width="50" fittocontents="width" initvalueid="ivBtnAccessibilityButton" onclick="fnSave" left="445" height="30" bottom="sta03:0"/>
