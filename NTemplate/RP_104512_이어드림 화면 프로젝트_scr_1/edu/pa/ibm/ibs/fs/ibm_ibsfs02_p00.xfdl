        <Static id="sta01" taborder="8" left="20" top="190" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20"/>
        <Static id="sta01_01" taborder="15" left="20" top="240" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20"/>
        <Grid id="grdMain" taborder="3" left="20" top="sta01_01:0" autofittype="col" right="20" selecttype="cell" initvalueid="ivGrdAccessibilityOn" binddataset="dsList" autosizingtype="row" extendsizetype="row" cellsizingtype="both" bottom="60" onheadclick="grdMain_onheadclick" oncellclick="grdMain_oncellclick" wheelscrollrow="1">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="30"/>
                <Column size="150"/>
                <Column size="60"/>
                <Column size="60"/>
                <Column size="70"/>
                <Column size="60"/>
                <Column size="80"/>
                <Column size="120"/>
                <Column size="150"/>
                <Column size="100"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell displaytype="checkboxcontrol" edittype="checkbox"/>
                <Cell col="1" text="교육과정차수"/>
                <Cell col="2" text="도서구분"/>
                <Cell col="3" text="교과서 /&#13;&#10;지도서"/>
                <Cell col="4" text="학교급"/>
                <Cell col="5" text="사용학기"/>
