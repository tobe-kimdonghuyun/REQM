        <Static id="sta03" taborder="10" left="20" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff" bottom="0"/>
        <Button id="btnClose" taborder="5" text="닫기" onclick="btn_close_onclick" cssclass="btn_WF_Custom" width="50" height="30" escapebutton="true" hotkey="ALT+C" initvalueid="ivBtnAccessibilityButton" bottom="sta03:0" right="445"/>
        <Static id="sta00" taborder="6" left="20" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20"/>
        <Static id="sta01_00" taborder="7" left="20" top="64" height="30" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
