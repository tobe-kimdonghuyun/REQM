              </Band>
              <Band id="body">
                <Cell displaytype="checkboxcontrol" edittype="checkbox" text="bind:chk"/>
                <Cell col="1" text="bind:eduCrseDgrNm" tooltiptext="bind:eduCrseDgrNm" textAlign="center" wordWrap="char"/>
                <Cell col="2" text="bind:utxbScNm" tooltiptext="bind:utxbScNm" textAlign="center" autosizerow="limitmin"/>
                <Cell col="3" tooltiptext="bind:thmrScNm" text="bind:thmrScNm" textAlign="center" autosizerow="limitmin" wordWrap="char"/>
                <Cell col="4" text="bind:shlCrseScNm" tooltiptext="bind:shlCrseScNm" textAlign="center" autosizerow="limitmin"/>
                <Cell col="5" text="bind:semScNm" tooltiptext="bind:semScNm" textAlign="center" autosizerow="limitmin"/>
                <Cell col="6" text="bind:grdNm" tooltiptext="bind:grdNm" autosizerow="limitmin" wordWrap="char"/>
                <Cell col="7" text="bind:sbjtNm" tooltiptext="bind:sbjtNm" textAlign="center" autosizerow="limitmin" wordWrap="char"/>
                <Cell col="8" text="bind:utxbNm" textAlign="left" wordWrap="char" autosizerow="limitmin" tooltiptext="bind:utxbNm"/>
                <Cell col="9" text="bind:pucNm" tooltiptext="bind:pucNm" autosizerow="limitmin" wordWrap="char"/>
                <Cell col="10" text="bind:autNm" tooltiptext="bind:autNm" autosizerow="limitmin" wordWrap="char"/>
              </Band>
            </Format>
          </Formats>
