              <ImageViewer id="imgTitle" taborder="0" text="도서등록" left="0" top="0" height="54" cssclass="img_WF_SubTit01" width="140" initvalueid="ivTitleAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divSearch" taborder="2" left="20" top="94" height="96" cssclass="div_WF_Search" right="20" initvalueid="ivDivAccessibilityOff">
