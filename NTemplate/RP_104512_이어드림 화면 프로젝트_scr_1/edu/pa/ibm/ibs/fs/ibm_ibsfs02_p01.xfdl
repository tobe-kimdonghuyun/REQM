<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="ibm_ibsfs02_p01" width="400" height="250" titletext="승인교육청 선택" onload="frmMain_onload">
    <Layouts>
      <Layout height="250" width="400" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Static id="staGD00" taborder="1" left="20" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGD00_00" taborder="2" left="20" top="180" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGD01" taborder="3" left="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" height="20" initvalueid="ivStcAccessibilityOff" top="230"/>
        <Static id="staGD02" taborder="4" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGD03" taborder="5" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Div id="divTitle" taborder="6" left="20" top="15" height="54" text="" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="승인교육청 선택" left="0" top="0" height="54" cssclass="img_WF_SubTit01" width="250" initvalueid="ivTitleAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnSave" taborder="7" text="승인요청" width="80" fittocontents="width" initvalueid="ivBtnAccessibilityButton" height="30" onclick="fnSave" top="200" right="190"/>
        <Button id="btnClose" taborder="8" text="취소" onclick="btn_close_onclick" cssclass="btn_WF_Custom" left="220" width="50" height="30" escapebutton="true" hotkey="ALT+C" initvalueid="ivBtnAccessibilityButton" bottom="20"/>
        <Div id="divSearch" taborder="9" left="20" top="94" height="86" cssclass="div_WF_Search" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staSbjt" taborder="0" text="승인교육(지원)청" left="5" top="30" width="150" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Combo id="cboCteOrg" taborder="1" left="staSbjt:20" width="160" height="30" innerdataset="dsCteOrgList" codecolumn="cteOrgCd" datacolumn="cteOrgNm" index="-1" text="전체" top="30" initvalueid="ivCmbNormal" accessibilitylabel="조회조건"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta01_00" taborder="10" left="20" top="64" height="30" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
      <Layout height="326" width="600" screenid="mobile,tablet" name="default0">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Static id="staGD00" taborder="1" left="20" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGD00_00" taborder="2" left="20" top="246" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGD01" taborder="3" left="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" height="20" initvalueid="ivStcAccessibilityOff" top="306"/>
        <Static id="staGD02" taborder="4" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGD03" taborder="5" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsCteOrgList" useclientlayout="true">
        <ColumnInfo>
          <Column id="cteOrgCd" type="STRING" size="256"/>
          <Column id="cteOrgNm" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listCteOrg</Col>
            <Col id="url">/ibm_ims_fs01_002.do</Col>
            <Col id="outDatasets">dsCteOrgList=dsCteOrgList</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
          </Row>
          <Row>
            <Col id="id">update</Col>
            <Col id="inDatasets">dsParam=dsParam dsTarget=dsTarget</Col>
            <Col id="svctp">U</Col>
            <Col id="outDatasets">dsApiResponseList=dsApiResponseList</Col>
            <Col id="url">/ibm_ims_fs02_003.do</Col>
            <Col id="callback">fnTransCallback</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="false">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256" description="지역교육청코드"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsTarget" useclientlayout="true">
        <ColumnInfo>
          <Column id="utxbCd" type="STRING" size="256" description="도서코드"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsParam" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256" description="시도교육청코드"/>
          <Column id="regScVal" type="STRING" size="256" description="등록구분값"/>
          <Column id="cteOrgCd" type="STRING" size="256" description="관할교육청코드"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsApiResponseList" useclientlayout="true">
        <ColumnInfo>
          <Column id="code" type="STRING" size="256" description="연계상태값"/>
          <Column id="message" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  교과용도서-공급도서 목록 관리-승인교육청 선택 팝업(승인요청시)
*  @MenuPath    pa_ibm_ibs_fs
*  @FileName 	ibm_ibsfs02_p01.xfdl
*  @Creator 	
*  @CreateDate 	2024.06.04
*  @Desction    교과용도서-공급도서 목록 관리-승인교육청 선택 팝업
************** 소스 수정 이력 ***********************************************
*  date                Modifier            Description
*******************************************************************************
*  2024.06.04    	 	이동영             최초 생성 
********************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

	// default 초기처리를 한다.
	this.smfInitPopup(obj);

	// 파라메터 셋
	var initValue = this.smfGetPopupParams();
	
	this.dsTarget.copyData(this.opener.dsTarget);
	
	//필수 파라미터 값 세팅
	this.dsSearch.setColumn(0, "cddcCd", this.smfGetCddcCode());
	this.dsParam.setColumn(0, "cddcCd", this.smfGetCddcCode());
	this.dsParam.setColumn(0, "regScVal", "2"); //등록구분값 : 승인요청
	
	//관할교육지원청 조회
	this.fnSearchCteOrg(initValue.lastCteOfcdcCd);
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

 /************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 /**
 * @description 조회조건 - 관할교육지원청 리스트 조회 Transaction
 */
this.fnSearchCteOrg = function(lastCteOfcdcCd)
{
 	// 서비스 객체 생성
	this.smfSearchService("listCteOrg")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.dsCteOrgList.getRowCount() < 0) return;
			
			if(this.isNotNil(lastCteOfcdcCd)){
				this.divSearch.form.cboCteOrg.set_value(lastCteOfcdcCd);
			}else{
				this.divSearch.form.cboCteOrg.set_index(0);
			}
		});
};
 
 
 /************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/


/**
 * 취소버튼 클릭
 */
this.btn_close_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};

/**
 * 승인요청 버튼 클릭
 */
this.fnSave = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 서비스 객체 생성
	this.smfSaveService("update")
		// 사용자에게 confirm메시지를 표시할지 여부
		.showConfirm(false)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){
				this.smfAlert('PA001', ["승인요청"]);	//승인요청 되었습니다.
				this.close(true);
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')]);
			}
		});
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.cboScCd" propid="value" datasetid="dsSearch" columnid="scCd"/>
      <BindItem id="item1" compid="divSearch.form.edtUtxbNm" propid="value" datasetid="dsSearch" columnid="utxbNm"/>
      <BindItem id="item2" compid="divSearch.form.edtSbjtNm" propid="value" datasetid="dsSearch" columnid="sbjtNm"/>
      <BindItem id="item3" compid="divSearch.form.edtPucNm" propid="value" datasetid="dsSearch" columnid="pucNm"/>
      <BindItem id="item4" compid="divSearch.form.edtAutNm" propid="value" datasetid="dsSearch" columnid="autNm"/>
      <BindItem id="item5" compid="divSearch.form.cboCteOrg" propid="value" datasetid="dsParam" columnid="cteOrgCd"/>
    </Bind>
  </Form>
</FDL>
