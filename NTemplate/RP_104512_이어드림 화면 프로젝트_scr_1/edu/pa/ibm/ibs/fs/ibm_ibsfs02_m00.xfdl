    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교과용도서(공급업체서비스)-공급도서 목록 관리
*  @FileName 	ibm_ibsfs02_m00.xfdl 
*  @Creator 	dylee
*  @CreateDate 	2024.05.10 
*  @Desction    교과용도서(공급업체서비스)-공급도서 목록 관리
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2024.05.10            dylee                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	//필수 파라미터 값 세팅
	this.dsSearch.setColumn(0, "cddcCd", this.smfGetCddcCode());
	this.dsParam.setColumn(0, "cddcCd", this.smfGetCddcCode());
	
	//학년 선택 readonly 처리
	this.divSearch.form.cboGrd.set_readonly(true);
	
	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
			url : "/ibm_ims_fs02_000.do",
		})
		.mappingRulesetToForm(this.divSearch, "search")
		.callback(function(callbackParams) {
		})
		.run()
	;
	
	// 공통코드의 코드구분
	this.smfCodeList("code", [this.dsSemScCd, this.dsGrdCd, this.dsUtxbScCd, this.dsShlKndScCd, this.dsThmrScCd, this.dsAprvPrgStsCd])
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			//공통코드 데이터셋 값 재세팅
			this.dataCodeValueSet();			
		})
	;

};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/**
 * @description 주문정보 조회 Transaction
 */
this.fnSearch = function()
{
	//조회구분설정(1:메인/2:팝업)
	this.dsSearch.setColumn(0, "srchScVal", "1");
 	// 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){
				//총 조회건수 세팅
				this.totalRowCountSet();
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')]);
			}
		});
	//전체선택 해제
	this.grdMain.setCellProperty("head", 0, "expr", 0);
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 총 조회건수 세팅
 */
this.totalRowCountSet = function(){
	
	var rowCnt = this.dsMain.getRowCount();
	if(!this.isNil(rowCnt)) rowCnt == 0;

	this.staTotal.set_text(rowCnt+"건");

}

/**
 * @description 공통코드 데이터셋 값 재세팅
 */
this.dataCodeValueSet = function(){
	//학교구분 데이터셋에 필요한 값만 세팅(전체/초/중/고)
	this.dsShlKndScCd.filter('(unyCdValue > 1 && unyCdValue < 5) || unyCdValue == 0');
	
	//교과서/지도서구분 데이터셋에 필요한 값만 세팅
	this.dsThmrScCd.filter('unyCdValue <= 1 || unyCdValue == 3');
	
	//학기구분 데이터셋에 필요한 값만 세팅
	this.dsSemScCd.filter('unyCdValue < 3');
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description '조회' 버튼 클릭 시
 */
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//주문정보 조회
	this.fnSearch();
};

this.divSearch_cboShlSc_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	if(this.divSearch.form.cboShlSc.value == '02'){	//초등학교
		this.divSearch.form.cboGrd.set_readonly(false);
		this.divSearch.form.cboGrd.set_index(0);
		this.dsGrdCd.filter('(unyCdValue >= 1 && unyCdValue <= 6) || unyCdValue == 0');
	}else if(this.divSearch.form.cboShlSc.value == '03' || this.divSearch.form.cboShlSc.value == '04'){ //중학교, 고등학교
		this.divSearch.form.cboGrd.set_index(0);
		this.divSearch.form.cboGrd.set_readonly(false);
		this.dsGrdCd.filter('(unyCdValue >= 1 && unyCdValue <= 3) || unyCdValue == 0');
	}else{
		this.divSearch.form.cboGrd.set_index(0);
		this.divSearch.form.cboGrd.set_readonly(true);
	}
};

this.grdMain_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	this.smfToggleChkHeader(obj, e);
	
	//전체 선택 시 선택 불가능 한 체크박스 값 비활성화
	var ds = obj.getBindDataset();
	
	for(var i=0; i<ds.getRowCount(); i++){
		if(obj.getCellPropertyValue(i, 0, "edittype") == "none")
			ds.setColumn(i, "chk", 0);
	}
};

this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var ds = obj.getBindDataset();
	if (e.col == 0){
		var cnt = 0;
		for(var i=0; i<ds.getRowCount(); i++){
			if(obj.getCellPropertyValue(i, 0, "edittype") != "none")
				cnt++;
		}
		if (ds.extractRows("chk == 1").length != cnt){
			obj.setCellProperty( "head", e.cell, "expr", 0);
		}else{
			obj.setCellProperty( "head", e.cell, "expr", 1);
		}
	}
};

this.btnAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: this.fnPopupCallback,
		internalCallback : this.fnPopupCallback,
		sender: obj, // sender 지정
		params: {
			// 처리타입 지정
			procType : 'insert'
		},
	};

	this.smfDialog("_auto", "pa_ibm_ibs_fs::ibm_ibsfs02_p00.xfdl", popupParams);
};

this.btnAprv_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//this.dsParam.setColumn(0, "regScVal", "2"); //등록구분값 : 승인요청
	
	//기존 데이터 초기화
	this.dsTarget.clearData();
	
	var dsMainSize = this.dsMain.getRowCount();
	var cnt = 0;
	for(var i=0; i<dsMainSize; i++){
		if(this.dsMain.getColumn(i, "chk") == true){
			this.dsTarget.addRow();
			this.dsTarget.setColumn(cnt, "utxbCd", this.dsMain.getColumn(i, "utxbCd"));
			cnt++;
		}
	}
	
	if(cnt == 0){
		this.smfAlert('CM013', ["공급도서"]);
		return;
	}
	
	this.smfConfirm("총 "+cnt+"건의 공급도서에 대해 승인요청하시겠습니까?", function(result){
		if(result.confirmResult){	//YES
			/* 팝업에서 승인요청할 교육청 선택 후 승인요청 하는 것으로 변경
			
			// 서비스 객체 생성
			this.smfSaveService("update")
				// 사용자에게 confirm메시지를 표시할지 여부
				.showConfirm(false)
				// 실행
				.run()
				// 콜백
				.callback(function(callbackParams){
					if(callbackParams.errors) return;
					
					if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){
						this.smfAlert('PA001', ["승인요청"]);	//승인요청 되었습니다.
						this.fnSearch();
					}else{
						this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')]);
					}
				});
			*/
			var maxDate = null;
			var lastDstrtOfcdcCd = null;
			var temp = 0;
			
			for(var i=0; i<this.dsMain.getRowCount(); i++){
				if(this.dsMain.getColumn(i, "aprvPrgStsCd") != '1'){
					//최초값 세팅
					if(temp == 0){
						maxDate = this.dsMain.getColumn(i, "mdfcnDt");
						temp++;
					}else{
						if(this.dsMain.getColumn(i, "mdfcnDt") > maxDate)
							maxDate = this.dsMain.getColumn(i, "mdfcnDt");
					}
				}
			}
			if(maxDate != null){
				lastDstrtOfcdcCd = this.dsMain.getColumn(this.dsMain.findRow("mdfcnDt", maxDate), "dstrtOfcdcCd");
			}
			
			// 팝업을 동작에 필요한 파라메터 지정
			var popupParams = {
				callback: this.fnPopupCallback,
				internalCallback : this.fnPopupCallback,
				sender: obj, // sender 지정
				params: {
					// 처리타입 지정
					procType : 'insert'
				  , lastCteOfcdcCd : lastDstrtOfcdcCd
				},
			};

			this.smfDialog("_auto", "pa_ibm_ibs_fs::ibm_ibsfs02_p01.xfdl", popupParams);
		}
	});
};


/**
 * 팝업의 콜백함수
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	this.fnSearch();
};


this.fnDelete = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsParam.setColumn(0, "regScVal", "3"); //등록구분값 : 삭제
	
	//기존 데이터 초기화
	this.dsTarget.clearData();
	
	var dsMainSize = this.dsMain.getRowCount();
	
	var cnt = 0;
	for(var i=0; i<dsMainSize; i++){
		if(this.dsMain.getColumn(i, "chk") == true){
			this.dsTarget.addRow();
			this.dsTarget.setColumn(cnt, "utxbCd", this.dsMain.getColumn(i, "utxbCd"));
			cnt++;
		}
	}
	
	if(cnt == 0){
		this.smfAlert('CM012');
		return;
	}
	
	this.smfConfirm("총 "+cnt+"건의 공급도서를 삭제하시겠습니까?", function(result){
		if(result.confirmResult){	//YES
			// 서비스 객체 생성
			this.smfDeleteService("delete")
				// 사용자에게 confirm메시지를 표시할지 여부
				.showConfirm(false)
				// 실행
				.run()
				// 콜백
				.callback(function(callbackParams){
					if(callbackParams.errors) return;
					
					if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){
						this.smfAlert('PA020');	//삭제가 완료되었습니다.
						this.fnSearch();
					}else{
						this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')]);
					}
				});
		}
	});
	
};
]]></Script>
    <Bind>
      <BindItem id="item3" compid="divSearch.form.cboAplyYr" propid="value" datasetid="dsSearch" columnid="bosAplyTrgtYr"/>
      <BindItem id="item0" compid="divSearch.form.cboShlSc" propid="value" datasetid="dsSearch" columnid="shlKndScCd"/>
      <BindItem id="item1" compid="divSearch.form.edtSplComyNm" propid="value" datasetid="dsSearch" columnid="splComyNm"/>
      <BindItem id="item2" compid="divSearch.form.edtPucSc" propid="value" datasetid="dsSearch" columnid="pucNm"/>
      <BindItem id="item4" compid="divSearch.form.edtSbjt" propid="value" datasetid="dsSearch" columnid="sbjtNm"/>
      <BindItem id="item5" compid="divSearch.form.edtAutNm" propid="value" datasetid="dsSearch" columnid="autNm"/>
      <BindItem id="item6" compid="divSearch.form.edtUtxbNm" propid="value" datasetid="dsSearch" columnid="utxbNm"/>
