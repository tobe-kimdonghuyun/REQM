        <Div id="div00_00" taborder="10" left="0" cssclass="div_WF_InfoBOX" right="0" top="staGd01_00:0" height="312" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="sta00_00_01_01_00" taborder="0" left="29" top="28" height="23" cssclass="sta_WF_InfoTit" text="대입전형자료 생성 및 신청 안내" wordWrap="char" initvalueid="ivStcAccessibilityOn" width="320"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_01" taborder="10" left="30" top="51" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta00_00_01_01_02" taborder="1" left="30" top="71" height="23" cssclass="sta_WF_InfoTxt_Black" text="1. 대입전형자료 생성 및 신청 진행순서 : 대상자확인 &gt; 생성 &gt; 미리보기 &gt; 신청" wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="30"/>
              <Static id="sta00_00_01_01_02_00" taborder="2" left="30" top="97" height="23" cssclass="sta_WF_InfoTxt_Black" text="2. 진행 상태별 안내 : &lt;fc v='#172f57'&gt;대상자확인대기&lt;/fc&gt; &gt; &lt;fc v='#138d71'&gt;생성대기&lt;/fc&gt; &gt; &lt;fc v='#8e62fc'&gt;신청대기&lt;/fc&gt; &gt; &lt;fc v='#2a65f2'&gt;신청완료&lt;/fc&gt;" wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="30"/>
              <Static id="sta00_00_01_01" taborder="3" left="40" top="123" height="23" cssclass="sta_WF_InfoTxt_Black" text="※ &lt;fc v='#172f57'&gt;대상자확인대기&lt;/fc&gt;: 대입전형자료 생성 및 신청을 위해 대상자 확인이 필요한 상태" wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="30"/>
              <Static id="sta00_00_01_01_01_00_00" taborder="4" left="40" top="sta00_00_01_01:2" height="23" cssclass="sta_WF_InfoTxt_Black" text="※ &lt;fc v='#d32850'&gt;대상자확인오류&lt;/fc&gt;: 학교명, 성명, 주민등록번호로 대상자를 확인 중 오류가 발생한 상태(해당학교로 문의바랍니다)" wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="30"/>
              <Static id="sta00_00_01_01_01" taborder="5" left="40" top="sta00_00_01_01_01_00_00:2" height="23" cssclass="sta_WF_InfoTxt_Black" text="※ &lt;fc v='#138d71'&gt;생성대기&lt;/fc&gt;: 대상자확인이 완료되어 대입전형자료 생성이 가능한 상태" wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="30"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00" taborder="9" left="0" top="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_00" taborder="11" left="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" bottom="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta99_00_00_00_00_01_01" taborder="12" left="0" top="30" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="30" text="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta99_00_00_00_00_01_01_00" taborder="13" top="30" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="30" text="30" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta00_00_01_01_01_01" taborder="6" left="40" top="sta00_00_01_01_01:2" height="23" cssclass="sta_WF_InfoTxt_Black" text="※ &lt;fc v='#8e62fc'&gt;신청대기&lt;/fc&gt;: 자료생성이 완료되어 대입전형자료 신청이 가능한 상태" wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="30"/>
              <Static id="sta00_00_01_01_01_01_00" taborder="7" left="40" top="sta00_00_01_01_01_01:2" height="23" cssclass="sta_WF_InfoTxt_Black" text="※ &lt;fc v='#2a65f2'&gt;신청완료&lt;/fc&gt;: 대입전형자료 생성 및 신청이 완료된 상태" wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="30"/>
              <Static id="sta00_00_01_01_01_00" taborder="8" left="30" top="sta00_00_01_01_01_01_00:2" height="33" cssclass="sta_WF_InfoTxt_Black" text="3. 대입전형자료(학교생활기록부) 온라인 생성신청을 완료한 후에는 생성한 대입전형자료의 변경, 재생성, 대학에 온라인 제공 중지 등은 불가하며, &#13;&#10;   학교생활기록부에 이상이 있을 경우 해당 학교(졸업한 고등학교)로 문의하시기 바랍니다." wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="30" fittocontents="height"/>
            </Layout>
