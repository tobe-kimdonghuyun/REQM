			.modify(function(sel){ //선택된 원본을 조작
				//하나의 row로 합침
				var tmp = sel.reduce(function(a,v,i){
					
					if(blindYn == "Y"){ // 해제일떄
						//전출 09, 유급 10, 휴학 11, 면제 12, 유예 13, 제적 14, 자퇴 15, 퇴학 16
						if(v[1] != '09' && v[1] != '10' && v[1] != '11' && v[1] != '12' && v[1] != '13' && v[1] != '14' && v[1] != '15' && v[1] != '16'){
							if(i != 0){
								a.push('/EOR/'); // 맨처음행은 줄을 바꾸지않는다
							}
						
							a.push(v[3].substr(0, 4) + '년 ' + v[3].substr(4, 2) + '월 ' + v[3].substr(6, 2) + '일  ' + v[4]);
						
						}else{
							a.push("("+v[3].substr(0, 4) + '년 ' + v[3].substr(4, 2) + '월 ' + v[3].substr(6, 2) + '일  ' + v[4]+")");
						}
					}else{ //블라인드 자료일떄
						if(i != 0){
							a.push('/EOR/'); // 맨처음행은 줄을 바꾸지않는다
						}
						a.push(+v[3].substr(0, 4) + '년 ' + v[3].substr(4, 2) + '월 ' + v[3].substr(6, 2) + '일  ' + v[2]);
					}
					return a;
				}, []).join('');
				return [[2, tmp]];
			})
