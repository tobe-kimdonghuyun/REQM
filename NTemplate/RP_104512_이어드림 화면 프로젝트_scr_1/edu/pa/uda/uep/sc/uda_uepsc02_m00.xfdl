											if(!this.smfIsNull(item[14])){
												return item[12]+'( )/'+item[14];
											}else{
												return item[12]+'( )';
											}
										}else{
											if(!this.smfIsNull(item[14])){
												return item[12]+'('+'.'+')/'+item[14];
											}else{
												return item[12]+'('+'.'+')';
											}
										}
									}
								}
 							}
							
						})); //석차등급(수강자수)
							
