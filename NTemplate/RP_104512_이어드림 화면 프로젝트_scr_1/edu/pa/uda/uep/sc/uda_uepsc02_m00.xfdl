    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    자료생성 및 신청
*  @FileName 	uda_uepsc02_m00.xfdl 
*  @Creator 	최재영
*  @CreateDate 	2022.08.29
*  @Desction    대입전형자료(학교생활기록부)-생성 및 신청
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2024.02.13          최재영                 최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::cm_script.xjs"
include "lib::uds_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.fv_param;
var coaAyr 		    = "";
var coaRcritScCd 	= "";
var coaRcritScCdNm 	= "";

this.fvQueFiles = null;	  //파일 큐 버퍼
this.fvQueRawData = null; //리포트 원시 데이터 큐 버퍼
this.fvQueIdx = null;	  //선택된 데이터 인덱스 큐 버퍼

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);
	this.fv_param = this.smfGetFormParams();
	this.fnSelectCoaCtr();	//기준정보 조회 
};


/**
 * @description 졸업생대입전형자료 대상자확인
 */
this.btnTrprCeck_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo){
	// 오류메시지 초기화
	this.dsErrMsg.clearData();
	
	// 대입기준 조회
	this.smfSearchService("selectCoaCtr")
		.run() // 실행
		.callback(function(callbackParams){ // 콜백
			if(callbackParams.errors) return;
			
			if(this.dsErrMsg.getRowCount() > 0){
				// 오류메시지 처리
				this.smfAlert(this.dsErrMsg.getColumn(0, 'message'), function(){
					var objFrame = this.getOwnerFrame();
					if(objFrame.form.divAll){
						var sMainUrl = objFrame.form.fv_mainformUrl;
						if(!this.smfIsNull(sMainUrl)) objFrame.form.fnSetMainpage(sMainUrl); // 메인URL로 이동한다.
					}
				});
			} else {
				var rcritNm = this.dsCoaCtrList.getColumn(0,"rcritNm"); // 모집구분명
				var seleDataCrtBgngYmd = this.dsCoaCtrList.getColumn(0,"seleDataCrtBgngYmd"); // 신청시작일자
				var seleDataCrtEndYmd  = this.dsCoaCtrList.getColumn(0,"seleDataCrtEndYmd");  // 신청종료일자
				var finYn  			   = this.dsCoaCtrList.getColumn(0,"finYn");  // 신청일자체크
				if(finYn == "N"){
					this.fnAlertUda(function(){
						}, {message : "대입전형자료(학교생활기록부)\n온라인 생성신청 기간이 아닙니다.",
							messageCn : "\n\n- " + rcritNm + " 생성신청 기간: " + seleDataCrtBgngYmd.dateFormat("yyyy.MM.dd.") + " ~ " + seleDataCrtEndYmd.dateFormat("yyyy.MM.dd.") + " \n\n해당 기간에만 이용하실 수 있습니다.",
							messageRmk : "",
							color : "#1E5DF2"}
					);
				} else {
					var popupParams = {
						callback: this.fnPopupCallback, // 콜백함수지정
						sender: obj, // sender 지정
						params: {
							procType: "none" //처리타입지정
						}
					};
					// 학교찾기 모달팝업 실행
					this.smfDialog("uda_uepsc02_p00", "pa_uda_uep_sc::uda_uepsc02_p00.xfdl", popupParams);	
				}
			}
		});	
	
	
};

/**
 * @description 학교찾기 callback
 */
this.fnPopupCallback = function(e, sender){
	if(e.row){
		this.dsSearch.setColumn(0, "shlCd"		, e.row["orgCd"]); 		// 학교코드
		this.dsSearch.setColumn(0, "shlNm"		, e.row["afchOrgNm"]); 	// 학교명
		this.dsSearch.setColumn(0, "shlCrseScCd", e.row["shlCrseScCd"]);// 학교과정구분코드
		this.dsSearch.setColumn(0, "shlKndScCd"	, e.row["shlKndScCd"]); // 학교종류구분코드
		this.dsSearch.setColumn(0, "cddcScCd"	, e.row["cddcScCd"]); 	// 시도교육청구분코드
		
		// 대입전형자료 대상자 확인
		this.fnGrsCoaDataTrprIdnty();
	}
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/**
 * @description 대입기준 조회
*/
this.fnSelectCoaCtr = function(){
	// 오류메시지 초기화
	this.dsErrMsg.clearData();
	try {
		this.dsSearch.setColumn(0, "tsCetCd", window.location.search.substring(1).split("=")[0] == "tsCetCd" ? window.location.search.substring(1).split("=")[1] : "");
	} catch (e) {
		trace(e);
	}
	
	// 대입기준 조회
	this.smfSearchService("selectCoaCtr")
		.run() // 실행
		.callback(function(callbackParams){ // 콜백
			if(callbackParams.errors) return;
			
			if(this.dsErrMsg.getRowCount() > 0){
				// 오류메시지 처리
				this.smfAlert(this.dsErrMsg.getColumn(0, 'message'), function(){
					var objFrame = this.getOwnerFrame();
					if(objFrame.form.divAll){
						var sMainUrl = objFrame.form.fv_mainformUrl;
						if(!this.smfIsNull(sMainUrl)) objFrame.form.fnSetMainpage(sMainUrl); // 메인URL로 이동한다.
					}
				});
			} else if(this.dsCoaCtrList.getRowCount() == 0 || this.smfIsNull(this.dsCoaCtrList.getColumn(0, "coaAyr"))){
				// 오류 처리
				this.fnAlertUda(function(){
						var objFrame = this.getOwnerFrame();
						if(objFrame.form.divAll){
							var sMainUrl = objFrame.form.fv_mainformUrl;
							if(!this.smfIsNull(sMainUrl)) objFrame.form.fnSetMainpage(sMainUrl); // 메인URL로 이동한다.
						}
					}, {message : "대입전형자료(학교생활기록부)\n온라인 생성신청을 실행할 수 없습니다.",
						messageCn : "\n\n아이폰 등 모바일기기에서 정상적으로 실행되지 않을 수 있습니다.\n\n실행되지 않는 경우 일반PC에서 대입전형자료(학교생활기록부) 온라인 생성신청을 진행하시기 바랍니다.",
						messageRmk : "",
						color : "#1E5DF2"}
				);
			} else {
				this.fnInit(); // 초기화
			}
		});	
}


/**
 * @description 대입전형자료 대상자 확인
 */
this.fnGrsCoaDataTrprIdnty = function(){
	
	// 대입전형자료 대상자 확인
	this.smfExecuteService("executeGrsCoaDataTrprIdnty")
		.messagePrefix([this.dsCoaCtrList.getColumn(0, "coaAyr")+"학년도 대입전형자료(학교생활기록부) 대상자 확인을"])
		.run() // 실행
		.callback(function(callbackParams){ // 콜백
			if(callbackParams.errors) return;
			
			if(this.dsErrMsg.getColumn(0, "messageCode") == "undefined" || this.dsErrMsg.getColumn(0, "messageCode") == null){//cjy 수정
				this.smfAlert(this.dsCoaCtrList.getColumn(0, "coaAyr")+"학년도 대입전형자료(학교생활기록부)\n온라인 개인 생성신청 대상자입니다.", function(){this.fnCoaDataSearch();}); 
			} else {
				this.fnAlertUda(this.fnCoaDataSearch, {color : "#1E5DF2"});
			}
		});	
}

/*
 * @description 대입전형자료 알림창
   @param  message : 메시지 dataSet
   @param  callback : 확인버튼 클릭후 콜백함수
   @param  objOption : dialog를 띄울때의 조건(JOSN형태. {left:100,top:100,width:100,height:100} 생략가능)
*/
this.fnAlertUda = function(callBack, objOption) {
	var nLeft   = null;
	var nTop    = null;
	var nWidth  = null;
	var nHeight = null;
	var nAlign  = null;
	var nColor  = null;
	var message  = null;
	var messageCn  = null;
	var messageRmk  = null;

	// 옵션이 있다면 값을 적용(주로 left,top,width,height)
	if(objOption)
	{
		nLeft   = objOption.left;
		nTop    = objOption.top;
		nWidth  = objOption.width;
		nHeight = objOption.height;
		nAlign  = objOption.align;
		nColor	= objOption.color;
		message	= objOption.message;
		messageCn	= objOption.messageCn;
		messageRmk	= objOption.messageRmk;
	}
	if(!this.smfIsNull(message) || !this.smfIsNull(messageCn) || !this.smfIsNull(messageRmk)){
		// 오류메시지 초기화
		this.dsErrMsg.clearData();
		this.dsErrMsg.addRow();
		this.dsErrMsg.setColumn(0, "message", this.smfIsNull(message) ? "" : message);
		this.dsErrMsg.setColumn(0, "messageCn", this.smfIsNull(messageCn) ? "" : messageCn);
		this.dsErrMsg.setColumn(0, "messageRmk", this.smfIsNull(messageRmk) ? "" : messageRmk);
	}
	
	this.smfDialog("comm_alertUda" , "comm::comm_alertUda.xfdl", {
		callback: callBack,
		titlebar:true,
		params: {
			procType : "none",
			message  : this.dsErrMsg,
			align    : nAlign,
			color    : nColor
		}
	}
	,nLeft,nTop,nWidth,nHeight
	);
}

/*
 * @description 대입전형자료 생성 
*/
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 오류메시지 초기화
	this.dsErrMsg.clearData();
	
	// 대입기준 조회
	this.smfSearchService("selectCoaCtr")
		.run() // 실행
		.callback(function(callbackParams){ // 콜백
			if(callbackParams.errors) return;
			
			if(this.dsErrMsg.getRowCount() > 0){
				// 오류메시지 처리
				this.smfAlert(this.dsErrMsg.getColumn(0, 'message'), function(){
					var objFrame = this.getOwnerFrame();
					if(objFrame.form.divAll){
						var sMainUrl = objFrame.form.fv_mainformUrl;
						if(!this.smfIsNull(sMainUrl)) objFrame.form.fnSetMainpage(sMainUrl); // 메인URL로 이동한다.
					}
				});
			} else {
				var rcritNm = this.dsCoaCtrList.getColumn(0,"rcritNm"); // 모집구분명
				var seleDataCrtBgngYmd = this.dsCoaCtrList.getColumn(0,"seleDataCrtBgngYmd"); // 신청시작일자
				var seleDataCrtEndYmd  = this.dsCoaCtrList.getColumn(0,"seleDataCrtEndYmd");  // 신청종료일자
				var finYn  			   = this.dsCoaCtrList.getColumn(0,"finYn");  // 신청일자체크
				if(finYn == "N"){
					this.fnAlertUda(function(){
						}, {message : "대입전형자료(학교생활기록부)\n온라인 생성신청 기간이 아닙니다.",
							messageCn : "\n\n- " + rcritNm + " 생성신청 기간: " + seleDataCrtBgngYmd.dateFormat("yyyy.MM.dd.") + " ~ " + seleDataCrtEndYmd.dateFormat("yyyy.MM.dd.") + " \n\n해당 기간에만 이용하실 수 있습니다.",
							messageRmk : "",
							color : "#1E5DF2"}
					);
				} else {
					this.dsCoaDataInfo.setColumn(0, "grsDataSbmsnYyCnt"	, this.dsCoaCtrList.getColumn(0, "grsDataSbmsnYyCnt"));
	
					// 대입전형자료 생성
					this.smfExecuteService("executeCoaData")
						.messagePrefix(["대입전형자료(학교생활기록부)를 생성"])
						.run() // 실행
						.callback(function(callbackParams){ // 콜백
							if(callbackParams.errors) return;
							
							if(this.dsErrMsg.getColumn(0, "messageCode") == "undefined" || this.dsErrMsg.getColumn(0, "messageCode") == null){//cjy 수정
								this.smfAlert("대입전형자료(학교생활기록부) 생성이 완료되었습니다.\n\n(신청 단계까지 모두 마쳐야 대입전형자료 온라인 생성신청이 완료됩니다.)", function(){this.fnCoaDataSearch();}); 
							}else{
								//this.smfAlert(this.dsErrMsg.getColumn(0, 'message'), function(){this.fnCoaDataSearch();}); //에러메시지
								this.fnAlertUda(this.fnCoaDataSearch);
							}
						});	
				}
			}
		});	
};

this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnCoaDataSearch();  // 대입전형자료 생성 및 신청 조회	
};

/************************************************************************************************
 * 대입전형수신자료출력 SYNC
 ************************************************************************************************/
/**
 * @description 초기화 FUNCTION
 */
this.fnInit = function(){
	var rcritNm = this.dsCoaCtrList.getColumn(0,"rcritNm"); // 모집구분명
	var seleDataCrtBgngYmd = this.dsCoaCtrList.getColumn(0,"seleDataCrtBgngYmd"); // 신청시작일자
	var seleDataCrtEndYmd  = this.dsCoaCtrList.getColumn(0,"seleDataCrtEndYmd");  // 신청종료일자
	var finYn  			   = this.dsCoaCtrList.getColumn(0,"finYn");  // 신청일자체크
	var chkYn 			   = this.dsCoaCtrList.getColumn(0,"chkYn");
	if(finYn == "N" && chkYn == "Y"){
		// 신청기간 X, 대학수신기간 X
		this.fnAlertUda(function(){
				var objFrame = this.getOwnerFrame();
				if(objFrame.form.divAll){
					var sMainUrl = objFrame.form.fv_mainformUrl;
					if(!this.smfIsNull(sMainUrl)) objFrame.form.fnSetMainpage(sMainUrl); // 메인URL로 이동한다.
				}
			}, {message : "대입전형자료(학교생활기록부)\n온라인 생성신청 기간이 아닙니다.",
				messageCn : "\n\n- 수시 생성신청 기간: 2024. 9. 9. ~ 2024. 9.13. \n- 정시 생성신청 기간: 2024.12.31. ~ 2025. 1. 3.\n\n해당 기간에만 이용하실 수 있습니다.",
				messageRmk : "",
				color : "#1E5DF2"}
		);
	} else {
		var menuId = this.fv_param.menu;
		if(this.udsfUepChkLogin(menuId)){//로그인여부 판단
			this.dsSearch.setColumn(0, "coaAyr"      		, this.dsCoaCtrList.getColumn(0, "coaAyr"));
			this.dsSearch.setColumn(0, "coaRcritScCd"		, this.dsCoaCtrList.getColumn(0, "coaRcritScCd"));
			this.dsSearch.setColumn(0, "aplcnBgngAyr"		, this.dsCoaCtrList.getColumn(0, "aplcnBgngAyr"));
			this.dsSearch.setColumn(0, "aplcnEndAyr"      	, this.dsCoaCtrList.getColumn(0, "aplcnEndAyr"));
			// this.dsSearch.setColumn(0, "coaRcritScNm"		, this.dsCoaCtrList.getColumn(0, "rcritNm"));
			this.dsSearch.setColumn(0, "grsDataSbmsnYyCnt"	, this.dsCoaCtrList.getColumn(0, "grsDataSbmsnYyCnt"));
			
			// this.dsSearch.setColumn(0, "coaEvlUnitId", "");
			// this.dsSearch.setColumn(0, "coaEvlUnitNm", "- 전체 -");
			
			// this.dsSearch.setColumn(0, "bldRmvYn", "N");
			
			this.dsSearch.setColumn(0, "prtOpt", "1");
			this.dsSearch.setColumn(0, "orgaOtptYn", "N");
			this.dsSearch.setColumn(0, "sbjtEvlInfoOtptYn", "N");
			
			// this.dsSearch.setColumn(0,"cddcCd",this.smfGetCddcCode());
			
			this.fnCoaDataSearch(); // 대입전형자료 생성 및 신청 조회	
			
			this.staCoaRcritSc.set_text("※ 대입전형자료(학교생활기록부) 온라인 생성신청 기간("+this.dsCoaCtrList.getColumn(0, "rcritNm")+"): "+seleDataCrtBgngYmd.dateFormat("yyyy.MM.dd.")+ " ~ " +seleDataCrtEndYmd.dateFormat("yyyy.MM.dd."));
			
			this.fvQueFiles = this.udsfCreateQueue();
			this.fvQueRawData = this.udsfCreateQueue();
			this.fvQueIdx = this.udsfCreateQueue();
		}
	}
}

/**
 * 대입전형자료 생성 및 신청 조회	
*/
this.fnCoaDataSearch = function(){
	// 오류메시지 초기화
	this.dsErrMsg.clearData();
	
	var rcritNm = this.dsCoaCtrList.getColumn(0,"rcritNm"); // 모집구분명
	var seleDataCrtBgngYmd = this.dsCoaCtrList.getColumn(0,"seleDataCrtBgngYmd"); // 신청시작일자
	var seleDataCrtEndYmd  = this.dsCoaCtrList.getColumn(0,"seleDataCrtEndYmd");  // 신청종료일자
	var finYn  			   = this.dsCoaCtrList.getColumn(0,"finYn");  // 신청일자체크
	
	this.smfSearchService("listCoaDataCrt")
			.run() // 실행
			.callback(function(callbackParams){ // 콜백
				if(callbackParams.errors) return;
				
				if(this.dsErrMsg.getColumn(0, "messageCode") == "undefined" || this.dsErrMsg.getColumn(0, "messageCode") == null){//cjy 수정
					
				} else {
					this.fnAlertUda(function(){
							var objFrame = this.getOwnerFrame();
							if(objFrame.form.divAll){
								var sMainUrl = objFrame.form.fv_mainformUrl;
								if(!this.smfIsNull(sMainUrl)) objFrame.form.fnSetMainpage(sMainUrl); // 메인URL로 이동한다.
							}
						}, {color : "#1E5DF2"});
				}
				
				if(this.dsCoaDataInfo == null || this.dsCoaDataInfo.rowcount == 0){ // 대상자확인X
					this.divCoaDataInfo.form.staSeleDataCrtStsCn.set_cssclass("sta_WF_InfoTit01");
					this.divCoaDataInfo.form.staSeleDataCrtStsCn.set_text("대상자확인대기");
					
					//로우를 추가하고 초기화 시킨다.
					this.smfInitRow(this.dsCoaDataInfo, this.dsCoaDataInfo.addRow());
					this.dsCoaDataInfo.setColumn(this.dsCoaDataInfo.rowposition, "shlNm", "-");
					this.dsCoaDataInfo.setColumn(this.dsCoaDataInfo.rowposition, "grdtnYr", "-");
					this.dsCoaDataInfo.setColumn(this.dsCoaDataInfo.rowposition, "grdtnYmdNm", "-");
					this.dsCoaDataInfo.setColumn(this.dsCoaDataInfo.rowposition, "grdtnYmd", "-");
					this.dsCoaDataInfo.setColumn(this.dsCoaDataInfo.rowposition, "seleDataCrtDt", "-");
					this.dsCoaDataInfo.setColumn(this.dsCoaDataInfo.rowposition, "ddlnDt", "-");
					this.dsCoaDataInfo.setColumn(this.dsCoaDataInfo.rowposition, "vrfcSn", "-");
					
					this.btnSave.set_enable(false); // 생성버튼 비활성화
					this.btnReportView.set_enable(false); // 미리보기버튼 비활성화
					this.btnSeleDataAply.set_enable(false); // 신청버튼 비활성화
					this.divCoaDataInfo.form.btnVrfcSnCopy.set_visible(false); // 복사하기 비표시
					
					//대입전형자료생성신청 절차에 따른 border 변화
					if(!this.smfIsMobile()){//pc
						this.divStep.form.div00.set_border("2px solid #2B72DE"); //대상자확인
						this.divStep.form.div00_00.set_border("2px solid #f5f5f5"); //생성
						this.divStep.form.div00_00_00.set_border("2px solid #f5f5f5"); //신청
					}else{//모바일
					}
					
				} else if(this.dsCoaDataInfo != null && this.dsCoaDataInfo.getColumn(0, "coaErrCd") == "49"){ // 대상자확인 후 오류
					this.divCoaDataInfo.form.staSeleDataCrtStsCn.set_cssclass("sta_WF_Red14");
					this.divCoaDataInfo.form.staSeleDataCrtStsCn.set_text("대상자확인오류(" + this.dsCoaDataInfo.getColumn(0, "errCn") + ")");

					this.dsCoaDataInfo.setColumn(this.dsCoaDataInfo.rowposition, "grdtnYr", "-");
					this.dsCoaDataInfo.setColumn(this.dsCoaDataInfo.rowposition, "grdtnYmdNm", "-");
					this.dsCoaDataInfo.setColumn(this.dsCoaDataInfo.rowposition, "grdtnYmd", "-");
					this.dsCoaDataInfo.setColumn(this.dsCoaDataInfo.rowposition, "seleDataCrtDt", "-");
					this.dsCoaDataInfo.setColumn(this.dsCoaDataInfo.rowposition, "ddlnDt", "-");
					this.dsCoaDataInfo.setColumn(this.dsCoaDataInfo.rowposition, "vrfcSn", "-");
					
					this.btnSave.set_enable(false); // 생성버튼 비활성화
					this.btnReportView.set_enable(false); // 미리보기버튼 비활성화
					this.btnSeleDataAply.set_enable(false); // 신청버튼 비활성화
					this.divCoaDataInfo.form.btnVrfcSnCopy.set_visible(false); // 복사하기 비표시
					
					//대입전형자료생성신청 절차에 따른 border 변화
					if(!this.smfIsMobile()){//pc
						this.divStep.form.div00.set_border("2px solid #2B72DE"); //대상자확인
						this.divStep.form.div00_00.set_border("2px solid #f5f5f5"); //생성
						this.divStep.form.div00_00_00.set_border("2px solid #f5f5f5"); //신청					
					}else{ //모바일
					}
				}else if(this.dsCoaDataInfo != null && this.dsCoaDataInfo.getColumn(0, "coaErrCd") != "49" && this.dsCoaDataInfo.getColumn(0, "ddlnYn") == "N" && this.dsCoaDataInfo.getColumn(0, "seleDataCrtYn") == "N"){ 
					this.dsCoaDataInfo.setColumn(this.dsCoaDataInfo.rowposition, "seleDataCrtDt", "-");
					this.dsCoaDataInfo.setColumn(this.dsCoaDataInfo.rowposition, "ddlnDt", "-");
					this.dsCoaDataInfo.setColumn(this.dsCoaDataInfo.rowposition, "vrfcSn", "-");
					
					// 대상자 확인이 정상적으로 실행된 경우
					this.divCoaDataInfo.form.staSeleDataCrtStsCn.set_cssclass("sta_WF_Quick02");
					this.divCoaDataInfo.form.staSeleDataCrtStsCn.set_text("생성대기");
					
					this.btnSave.set_enable(true); // 생성버튼 비활성화
					this.btnReportView.set_enable(false); // 미리보기 버튼 비활성화	
					this.btnSeleDataAply.set_enable(false); // 신청버튼 비활성화
					this.divCoaDataInfo.form.btnVrfcSnCopy.set_visible(false); // 복사하기 비표시
					
					//대입전형자료생성신청 절차에 따른 border 변화
					if(!this.smfIsMobile()){//pc
						this.divStep.form.div00.set_border("2px solid #f5f5f5"); //대상자확인
						this.divStep.form.div00_00.set_border("2px solid #2B72DE"); //생성
						this.divStep.form.div00_00_00.set_border("2px solid #f5f5f5"); //신청
					}else{
						this.divStep.form.sta00_00.set_background("#2B72DE");
						this.divStep.form.sta00_00_00.set_background("#f5f5f5");
						this.divStep.form.sta00_00_00_00.set_background("#f5f5f5");
					}
				}else{
					if(this.dsCoaDataInfo.getColumn(0, "ddlnYn") == "N" && this.dsCoaDataInfo.getColumn(0, "seleDataCrtYn") == "Y"){						
						this.dsCoaDataInfo.setColumn(this.dsCoaDataInfo.rowposition, "ddlnDt", "-");
						this.dsCoaDataInfo.setColumn(this.dsCoaDataInfo.rowposition, "vrfcSn", "-");
						this.divCoaDataInfo.form.staSeleDataCrtStsCn.set_text("신청대기");
						this.divCoaDataInfo.form.staSeleDataCrtStsCn.set_cssclass("sta_WF_Quick");
						this.btnTrprCeck.set_enable(true); // 대상자확인버튼 비활성화
						this.btnSave.set_enable(false); // 생성버튼 비활성화
						this.btnReportView.set_enable(true); // 미리보기버튼 비활성화
						this.btnSeleDataAply.set_enable(true); // 신청버튼 비활성화
						this.divCoaDataInfo.form.btnVrfcSnCopy.set_visible(false); // 복사하기 비표시
						
						//대입전형자료생성신청 절차에 따른 border 변화
						if(!this.smfIsMobile()){//pc
							this.divStep.form.div00.set_border("2px solid #f5f5f5"); //대상자확인
							this.divStep.form.div00_00.set_border("2px solid #f5f5f5"); //생성
							this.divStep.form.div00_00_00.set_border("2px solid #2B72DE"); //신청
						}else{
							this.divStep.form.sta00_00.set_background("#2B72DE");
							this.divStep.form.sta00_00_00.set_background("#2B72DE");
							this.divStep.form.sta00_00_00_00.set_background("#2B72DE");
						}
					}else if(this.dsCoaDataInfo.getColumn(0, "ddlnYn") == "Y"){
						this.divCoaDataInfo.form.staSeleDataCrtStsCn.set_text("신청완료");
						this.divCoaDataInfo.form.staSeleDataCrtStsCn.set_cssclass("sta_WF_Quick03");
						this.btnTrprCeck.set_enable(false); // 대상자확인버튼 비활성화
						this.btnSave.set_enable(false); // 생성버튼 비활성화
						this.btnReportView.set_enable(true); // 미리보기버튼 비활성화
						this.btnSeleDataAply.set_enable(false); // 신청버튼 비활성화
						this.divCoaDataInfo.form.btnVrfcSnCopy.set_visible(true); // 복사하기 표시
						
						//대입전형자료생성신청 절차에 따른 border 변화
						if(!this.smfIsMobile()){//pc
							this.divStep.form.div00.set_border("2px solid #f5f5f5"); //대상자확인
							this.divStep.form.div00_00.set_border("2px solid #f5f5f5"); //생성
							this.divStep.form.div00_00_00.set_border("2px solid #f5f5f5"); //신청
						}else{//mobile
							this.divStep.form.sta00_00.set_background("#2B72DE");
							this.divStep.form.sta00_00_00.set_background("#2B72DE");
							this.divStep.form.sta00_00_00_00.set_background("#2B72DE");						
						}
					}
				}
				
				if(finYn == "N"){
					this.btnTrprCeck.set_enable(false); // 대상자확인버튼 비활성화
					this.btnSave.set_enable(false); // 생성버튼 비활성화
					this.btnSeleDataAply.set_enable(false); // 신청버튼 비활성화
					
					if(!this.smfIsMobile()){//pc
						this.divStep.form.div00.set_border("2px solid #f5f5f5"); //대상자확인
						this.divStep.form.div00_00.set_border("2px solid #f5f5f5"); //생성
						this.divStep.form.div00_00_00.set_border("2px solid #f5f5f5"); //신청
					}else{//mobile
						this.divStep.form.sta00_00.set_background("#2B72DE");
						this.divStep.form.sta00_00_00.set_background("#2B72DE");
						this.divStep.form.sta00_00_00_00.set_background("#2B72DE");						
					}
					
					this.fnAlertUda(function(){
						}, {message : "대입전형자료(학교생활기록부)\n온라인 생성신청 기간이 아닙니다.",
							messageCn : "\n\n- " + rcritNm + " 생성신청 기간: " + seleDataCrtBgngYmd.dateFormat("yyyy.MM.dd.") + " ~ " + seleDataCrtEndYmd.dateFormat("yyyy.MM.dd.") + " \n\n해당 기간에만 이용하실 수 있습니다.",
							messageRmk : "",
							color : "#1E5DF2"}
					);
				}
			});	
}

/**
 * @description  블라인드여부
 */
this.fnIsBld = function(){
	return false; //this.dsSearch.getColumn(0, 'bldRmvYn') == 'N';
}

/**
 * @description  오즈레포트 생성
 * @param : data - 대입전형자료
 * @return : report - 대입전형자료 오즈 공통
 */
this.fnCreateReport = function(data){
	var _that = this;
	var _report = {};
	
	var _dataOrg = data.split('\r\n');
	
	var _selectOrg = [];
	var _selectTar = [];
	var _selectTarCol = 0;
	var _selectOrgCon = null;
	var _selectTarCon = null;
	var _takeType = 0; //0:mandatory, 1:optional
	var _trim = false;
	
	var _sepField = '^'; //원본 데이터의 필드 구분자
	var _dataTar = [];
	
	var fnIsStr = (s) => typeof s == 'string';
	
	//조건식
	var fnPass = (v, condition) => {
		if(_that.smfIsNull(condition)) return false;
		var strFn = 'var _v = arguments[0];'
		strFn += 'return ' + condition.replace(/\s/gi, '').replace(/\$([0-9]+)/gi, '_v[$1]').replace(/\={1,}/gi, '==').replace(/-_v\[([0-9]+)\]/gi, '_v[_v.length - $1]') + ';';
		return Function(strFn)(v);
	}
	
	//매핑 인덱스를 분리하여 원본데이터 push
 	var fnDoMapng = (tar, input, org) => {
 		var t = 1;
 		input = input.replace(/\s/gi, '').replace(/\$([0-9]+)/gi, '$1');
 		if(input[0] == '-') {
 			t = -1;
 			input = input.replace(/^-/, '');
 		}
 		if(_that.smfIsNull(input.match(/[^0-9]/))){
 			if(_that.smfIsNull(org)){
 				tar.push('');
 			}else{
 				var orgValue = org[(t < 0 ? org.length + (input * t) : input)];
 				if(_trim == true && fnIsStr(orgValue)) orgValue = orgValue.trim();
 				tar.push(orgValue);
 			}
 		}else{
 			tar.push(input);
 		}
 	}
	
	//문자열의 인덱스만 분리하여 배열로 변환
	//'$1 $2 -$3' -> [1,2,-3]
	function sepIdxs(str, max){
		var rtnIdxs = [];
		var idxs = str.replace(/\s/gi, '').match(/(\$[0-9]+)|(-\$[0-9]+)/gi);
		if(idxs != null && idxs.length > 0){
			idxs.forEach((v, i) => {
				var n = Number(v.replace(/\$/gi, ''));
				if(n < 0) n = max - n;
				rtnIdxs.push(n);
			})
		}
		return rtnIdxs;
	}
	
	//...^\n숫자^ 형식이 아니면 하나의 데이터로 보고 newLine을 추가하여 합친다.
	_report.adjustNewline = function(newLine){
		_dataOrg = _dataOrg.reduce((a,v,i) => {
			if(_that.smfIsNull(v.match(/^[0-9]+\^/gi))){
				if(a.length > 0) a[a.length - 1] += newLine + v;
			}else{
				a.push(v);
			}
			return a;
		}, []);
		
		return _report;
	}
	
	//2차원 데이터로 분리
	_report.seprate = function(sep){
		_dataOrg = _dataOrg.map((v) => v.split(sep));
		return _report;
	}
	
	//원본, 타겟, 타켓 Col 선택
	_report.select = function(conOrg, conTar, tarCol){
		this.selectOrg(conOrg);
		this.selectTar(conTar);
		return this.selectTarCol(tarCol);
	}
	
	//원본데이터 선택
	_report.selectOrg = function(condition, callback){
		_selectOrg.length = 0;
		if(!_that.smfIsNull(condition)){
			_dataOrg.forEach((v, row) => {
				if(fnPass(v, condition)) _selectOrg.push(v);
			});
		}
		_selectOrgCon = condition;
		if(_that.smfIsFunc(callback)) callback(_report, _selectOrg);
		return _report;
	}
	
	//타겟테이터 선택
	_report.selectTar = function(condition, callback){
		_selectTar.length = 0;
		if(!_that.smfIsNull(condition)){
			_dataTar.forEach((v, row) => {
				if(fnPass(v, condition)) _selectTar.push(v);
			});
		}
		_selectTarCon = condition;
		if(_that.smfIsFunc(callback)) callback(_report, _selectTar);
		return _report;
	}
	
	//타켓컬럼위치 선택 : 음수이면 맨뒤에부터
	_report.selectTarCol = function(nColIdx){
		if(_that.smfIsNull(nColIdx)) nColIdx = 0;
		_selectTarCol = nColIdx < 0 ? (_selectTar[0].length + 1) + nColIdx : nColIdx;
		return _report;
	}
	
	//선택된 원본데이터를 조작
	_report.modify = function(callback){
		if(_that.smfIsFunc(callback)){
			var tmp = callback(_selectOrg);
			_selectOrg.length = 0;
			_selectOrg.push(...tmp);
		}
	
		return _report;
	}
	
	//선택된 선택된 원본데이터 그룹
	//callback의 결과 값에 따라 원본데이터를 변경
	//@param : string - groupCols '$1 $2 $3 -$5'
	//@param : callback - group된 3차원 데이터를 그룹단위로 전달하여 결과 값을 원본데이터에 넣는다
	_report.groupBy = function(groupCols, callback){
		if(_selectOrg.length > 0){
			var groupIdxs = sepIdxs(groupCols)
			var group =_selectOrg.reduce((a, v) => {
				var key = v.filter((v, i) => groupIdxs.includes(i) ? true : false).join('');
				if(!a[key]) a[key] = [];
				a[key].push(v);
				return a;
			}, {});
			
			if(_that.smfIsFunc(callback)){
				var vals = Array.from(Object.values(group));
				_selectOrg.length = 0;
				
				vals.forEach((v) => {
					var tmp = callback.call(_that, _report, v);
					_selectOrg.push(tmp);
				});
			}
		}
		return _report;
	}
	
	_report.groupUtils = {
		max : (arr, idx) => {
			return Math.max(...arr.reduce((a, v) => {
				a.push(v.filter((v, i) => i == idx ? true : false));
				return a;
			}, []));
		},
		min : (arr, idx) => {
			return Math.min(...arr.reduce((a, v) => {
				a.push(v.filter((v, i) => i == idx ? true : false));
				return a;
			}, []));
		},
		caseWhen : (arr, cond, callbck) =>{
			for(var i = 0; i < arr.length; i++){
				if(fnPass(arr[i], cond)){
					if(_that.smfIsFunc(callbck)) return callbck.call(_that, arr[i]);
				}
			}
			return '';
		},
	}
	
	//원본데이터가 없으면
	//$부분은 빈값, 직접 입력 부분은 값이 들어감
	_report.mandatory = function(){
		_takeType = 0;
		return _report;
	}
	
	//원본데이터가 없으면 입력 안함.
	_report.optional = function(){
		_takeType = 1;
		return _report;
	}
	
	//타겟 테이터를 넣을때 trim 처리.
	_report.trim = function(bFlg){
		_trim = bFlg;
		return _report;
	}
	
	//org -> tar 데이터 이동 복사
	//1. 원본 select 상태가 있고 원본 select 결과 데이터가 없을때 컬럼번호('$') 부분은 ''로 넣어진다.
	//2. 원본 select 상태가 없을때 value값을 그냥 넣는다.
	//3. 원본 select 상태가 있고 원본 select 결과 데이터가 있을때
	//		> value 값이 없으면 원본데이터 row 전체를 타겟 데이터에 추가. ( copy all )
	//		> 타겟 select 결과 데이터가 있으면 _selectTarCol 인덱스 부터 데이터를 추가. ( append )
	//		> 타켓 select 결과 데이터가 없으면 타겟 데이터에 추가. ( add )
	_report.take = function(...value){
		if(_selectOrg.length > 0 || !_that.smfIsNull(_selectOrgCon)){
			if(_selectOrg.length == 0){
				//optional 이면 리턴
				if(_takeType == 1) return _report;
				//선택했는데 원본데이터가 없으면 ''로 넣는다.
				var vals = value.reduce((a, val) =>{
					if(_that.smfIsFunc(val)){
						a.push('');
					}else if(fnIsStr(val) && val.indexOf('$') > -1){
						fnDoMapng(a, val);
					}else{
						a.push(val);
					}
					return a;
				}, []);
			
				if(_selectTar.length == 0){
					_dataTar.push(vals); //타겟이터 추가
				}else{
					//선택타겟데이터의 선택컬럼위치부터 넣어준다.
					_selectTar.forEach((v) => {
						v.splice(_selectTarCol, 0, ...vals);
					});
				}
			}else{
				_selectOrg.forEach((v, row) => {
					if(_that.smfIsNull(value)){
						if(_selectTar.length == 0){
							_dataTar.push(v); //타겟이터 추가
						}else{
							//선택타겟데이터의 선택컬럼위치부터 넣어준다.
							//_selectOrg와 _selectTar의 rowIdx 데이터 매핑 일치 해야함
							_selectTar[row].splice(_selectTarCol, 0, ...v);
						}
					}else{
						var vals = value.reduce((a, val) =>{
							if(_that.smfIsFunc(val)){
								a.push(val(v));
							}else if(fnIsStr(val) && val.indexOf('$') > -1){
								fnDoMapng(a, val, v);
							}else{
								a.push(val);
							}
							return a;
						}, []);
						
						if(_selectTar.length == 0){
							_dataTar.push(vals); //타겟이터 추가
						}else{
							//선택타겟데이터의 선택컬럼위치부터 넣어준다.
							//TODO : select 에서 원본의 수량이 많을때 에러가남
							_selectTar[row].splice(_selectTarCol, 0, ...vals);
						}
					}
				});
			}
		} else {
			if(_selectTar.length == 0){
				_dataTar.push(value); //타겟데이터 추가
			}else{
				//선택타겟데이터의 선택컬럼위치부터 넣어준다.
				_selectTar.forEach((v) => {
					v.splice(_selectTarCol, 0, ...value);
				});
			}
		}
		
		return _report;
	}
	
	//oz의 csv 파일로 만든다.
	//필드구분, 로우구분, 데이터셋 종료구분
	//'#$!', '^&*', '//EOR//'
	_report.toOzCSV = function(field, row, dsEnd){
		return _dataTar.reduce((a,v,i) => {
			var itmNo = v[0];
			v.splice(0, 1); //아이템 번호 제거
			
 			for(var j = 0; j < v.length; j++){
 				if(!_that.smfIsNull(v[j]) && typeof v[j] == 'string'){
 					v[j] = v[j].replace(/\/EOR\//gi, '\n');
 				}
 			}
			
			if(a.n == itmNo && a.d.length > 0){
				 a.d[a.d.length - 1] += row + v.join(field);
			}else{
				a.n = itmNo;
				a.d.push(v.join(field));
			}
			
			return a;
		}, {n:null, d:[]}).d.map((v) => v.length == 0 ? field : v).join(row + dsEnd + row);
	}
	
	//값을 가져온다.
	_report.getOrg = function(row, col){
		if(_that.smfIsNull(col)){
			return _dataOrg[row < 0 ? _dataOrg.length + row : row];
		}
		return _dataOrg[row < 0 ? _dataOrg.length + row : row][col < 0 ? _dataOrg[row].length + col : col];
	}
	
	//_selectOrg 값을 가져온다. 선택된 원본의 로우배열
	_report.getSelectOrg = function(){
	
		return _selectOrg;
	}
	
	/////////////////////////////
	//콘솔 출력
	////////////////////////////
	var _tracer = {
		prefix : '',
		sel : '' ,
		data : null,
		enable : false
	};
	
	_tracer.org = function(){
		if(!_tracer.enable) return _tracer;
		
		_tracer.data = _dataOrg;
		_tracer.sel = 'org';
		
		return _tracer;
	}
	
	_tracer.tar = function(){
		if(!_tracer.enable) return _tracer;
		_tracer.data = _dataTar;
		_tracer.sel = 'tar';
		return _tracer;
	}
	
	_tracer.selected = function(){
		if(!_tracer.enable) return _tracer;
		
		if(_tracer.sel == 'org') _tracer.data = _selectOrg;
		else if(_tracer.sel == 'tar') _tracer.data = _selectTar;
		
		return _tracer;
	}
	
	_tracer.end = function(){
		if(!_tracer.enable) return _report;
		trace(_tracer.prefix + JSON.stringify(_tracer.data));
		return _report;
	}
	
	_report.trace = function(prefix){
		if(!_tracer.enable) return _tracer;
		_tracer.prefix = prefix;
		return _tracer;
	}
	
	_report.enableTrace = function(flg){
		_tracer.enable = _that.smfIsNull(flg) ? true : flg;
		return _report;
	}

	return _report;
}

/**
 * @description 오즈 데이터 생성
 * 
 */
this.fnDoOzReport = function(aplyYn){ //cjy 수정 신청버튼여부
	var ozDatas = [];
	this.dsReportNm.clearData(); //리포트명 데이터셋 클리어
	
	var nCnt = this.fvQueRawData.length();
	for(var i = 0; i < nCnt; i++){
		var rawData = this.fvQueRawData.dequeue();
		var coaEvlUnitNm = '';
		var stuIdfNo = '';
		
		var prcsSn = '';
		var rreqNts = '';
		
		if(rawData.sele.cn == null || rawData.sele.cn.trim().length == 0){
			this.setWaitCursor(false);
			
			this.fnClearQueue();
			
			if(this.dsErrMsg.getColumn(0, "messageCode") == "undefined" || this.dsErrMsg.getColumn(0, "messageCode") == null){//cjy 수정
				this.smfAlert("전형자료 조회 중 오류가 발생하였습니다.");
			}
			
			return;
		}

		ozDatas.push({
			'title' : coaEvlUnitNm + '-' + stuIdfNo,
			'csv' : this.fnTransOzData(rawData.shlNm, rawData.sele.cn, rawData.image ? rawData.image.cn : '', rawData.idx),
			'prcsSn' : prcsSn,
			'rreqNts' : rreqNts
		});
	}
	
	this.fnShowOzReport(ozDatas, aplyYn); //cjy 수정 신청버튼여부
}

this.fnScrgOfodAplcnYn = function(ayr, shlCrseSc, grd, dgr) {

	// 728호 - 초 : 초등학교는 728호 훈령 적용대상 아님
	// 중,고 : 2009년도 1학년 2010년도 1,2학년 2011년도 모두
	// 학교과정구분 2:초등, 3:중등, 4:고등
	// 사용법 getOfodAplcnYn(학년도, 학교과정구분, 학년, 훈령차수))
	
	if ("" == ayr || ayr == null) {
		return ""; // 학년도 없음
	}
	if ("" == shlCrseSc || shlCrseSc == null) {
		return ""; // 학교과정구분 없음
	}
	if ("" == grd || grd == null) {
		return ""; // 학년 없음
	}
	if ("" == dgr || dgr == null) {
		return ""; // 훈령차수 없음
	}
	
	var shlCrseScCd = shlCrseSc;
	if ("4" == shlCrseSc) {
		shlCrseScCd = "3"; // 중,고는 동일
	}

	var ayrShlCrseScGrd = ayr + shlCrseScCd + grd;
	
	if ("616" == dgr) {
		if ("200231" == ayrShlCrseScGrd) {
			return "Y"; // 2002년도 고1학년
		} else if ("200331" == ayrShlCrseScGrd || "200332" == ayrShlCrseScGrd) {
			return "Y"; // 2003년도 고1,2학년
		} else if (parseInt(ayr) == 2004) {
			return "Y"; // 2004년도는 모두
		} else if ("200532" == ayrShlCrseScGrd || "200533" == ayrShlCrseScGrd) {
			return "Y"; // 2005년도 고2,3학년
		} else if ("200633" == ayrShlCrseScGrd) {
			return "Y"; // 2006년도 고3학년
		} else {
			return "N";
		}
	} else if ("676" == dgr) {
		if ("200531" == ayrShlCrseScGrd) {
			return "Y"; // 2005년도 고1학년
		} else if ("200631" == ayrShlCrseScGrd || "200632" == ayrShlCrseScGrd) {
			return "Y"; // 2006년도 고1,2학년
		} else if ("200732" == ayrShlCrseScGrd || "200733" == ayrShlCrseScGrd) {
			return "Y"; // 2007년도 고2,3학년
		} else if ("200833" == ayrShlCrseScGrd) {
			return "Y"; // 2008년도 고3학년
		} else {
			return "N";
		}
	} else if ("719" == dgr) {
		if ("200731" == ayrShlCrseScGrd) {
			return "Y"; // 2007년도 고1학년
		} else if ("200831" == ayrShlCrseScGrd || "200832" == ayrShlCrseScGrd) {
			return "Y"; // 2008년도 고1,2학년
		} else if (parseInt(ayr) >= 2009) {
			return "Y"; // 2009년도 부터는 모두
		} else {
			return "N";
		}
	} else if ("728" == dgr) {
		if ("200931" == ayrShlCrseScGrd) {
			return "Y"; // 2009년도 중1학년
		} else if ("201031" == ayrShlCrseScGrd || "201032" == ayrShlCrseScGrd) {
			return "Y"; // 2010년도 중1,2학년
		} else if (parseInt(ayr) >= 2011) {
			return "Y"; // 2011년도 부터는 모두
		} else {
			return "N";
		}
	} else if ("205" == dgr) {
		if ("201131" == ayrShlCrseScGrd) {
			return "Y"; // 2011년도 중1학년
		} else if ("201231" == ayrShlCrseScGrd || "201232" == ayrShlCrseScGrd) {
			return "Y"; // 2012년도 중1,2학년
		} else if (parseInt(ayr) >= 2013) {
			return "Y"; // 2013년도 부터는 모두
		} else {
			return "N";
		}
	} else if ("239" == dgr) {
		if ("201231" == ayrShlCrseScGrd) {
			return "Y"; // 2012년도 중1학년
