				 );
			
		//교과학습발달상황 훈령280호(시스템훈령:765) 이후
		for(var i = 0; applyYn504 == "N" && i < 3; i++){
			var grd = i + 1; //1,2,3 학년
			var stdN = 9;	 //Oz의 교과학습발당상황 시작 데이터셋 번호
			var n = stdN + 0 + (i * 8);
			var screScCode = "";
			
			report
				//과목
				.optional()
				.select(`$0=13 && $2=${grd} && $3=1 && -$3=01`) //학목코드=13 && 학년=1 && 학기=1 && 과목구분코드=01
				.take( n
				     , '$3'  // 학기
					 , '$5'  // 교과 
					 , '$9'  // 과목
					 , '$10' // 단위수 or 학점수
					 , (v) => {
						screScCode = this.getScreScCode(v[1], v[2]);//성적구분코드
						
						if(screScCode == '02' && v[19] == '15' && v[21] == '15'){ // 학교밖교육여부(OOSCH_YN) 컬럼 미존재로 성취도, 석차등급 코드 기준 학교밖교육 처리
							return '·';
						}else if(screScCode == '02'){
							return [v[15], '/', v[16], '(', v[17], ')'].join('');
						}else{
							return v[11];
						}
					 }// 원점수/과목평균(표준편차)
				     , (v) => {
						if(screScCode == '02' && v[19] == '15' && v[21] == '15'){ // 학교밖교육여부(OOSCH_YN) 컬럼 미존재로 성취도, 석차등급 코드 기준 학교밖교육 처리
							return '·';
						}else if(screScCode == '02'){
							return [v[20], '(', v[14], ')'].join('');
						}else{
							if((v[13] != null && v[13] != '')){
								if(!this.smfIsNull(v[14])){
									return v[12]+'('+v[13]+')/'+v[14];
								}else{
									return v[12]+'('+v[13]+')';
								}
							}else if((v[13] == null || v[13] == '')){
								if(!this.smfIsNull(v[14])){
									return v[12]+'('+'.'+')/'+v[14];
								}else{
									return v[12]+'('+'.'+')';
								}
							}
						}
					 }// 성취도(수강자수)
					 , '$18' // 석차등급
					 , '$20' // 성취도 
					 )
				.select(`$0=13 && $2=${grd} && $3=2 && -$3=01`) //학목코드=13 && 학년=1 && 학기=2 && 과목구분코드=01
				.take( n
				     , '$3'  // 학기
					 , '$5'  // 교과 
					 , '$9'  // 과목
					 , '$10' // 단위수 or 학점수
					 , (v) => {
						screScCode = this.getScreScCode(v[1], v[2]);//성적구분코드
						
						if(screScCode == '02' && v[19] == '15' && v[21] == '15'){ // 학교밖교육여부(OOSCH_YN) 컬럼 미존재로 성취도, 석차등급 코드 기준 학교밖교육 처리
							return '·';
						}else if(screScCode == '02'){
							return [v[15], '/', v[16], '(', v[17], ')'].join('');
						}else{
							return v[11];
						}
					 }// 원점수/과목평균(표준편차)
					 , (v) => {
						if(screScCode == '02' && v[19] == '15' && v[21] == '15'){ // 학교밖교육여부(OOSCH_YN) 컬럼 미존재로 성취도, 석차등급 코드 기준 학교밖교육 처리
							return '·';
						}else if(screScCode == '02'){
							return [v[20], '(', v[14], ')'].join('');
						}else{
							if((v[13] != null && v[13] != '')){
								if(!this.smfIsNull(v[14])){
									return v[12]+'('+v[13]+')/'+v[14];
								}else{
									return v[12]+'('+v[13]+')';
								}
