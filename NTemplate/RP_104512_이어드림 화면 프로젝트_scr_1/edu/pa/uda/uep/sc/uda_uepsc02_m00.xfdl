						tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => item[10])); //단위수
						tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => {
							/* 성적구분(2004이전 입학생:02, 2005이후 입학생:01)   2008관련 : 02
						     * 2004년 이전의 입학생일지라도 2005년 이후에 복학했을 경우 이전자료를 조회하도록 과목별로 성적구분 정보를 가짐.
						     */
							screScCode = this.getScreScCode(item[1], item[2]);//성적구분코드
							
							if(screScCode == '02'){
								if(!this.smfIsNull(item[15]) && !this.smfIsNull(item[16]) && !this.smfIsNull(item[17])){
									return [item[15], '/', item[16], '(', item[17], ')'].join('')
								}else if (this.smfIsNull(item[15]) && this.smfIsNull(item[16]) && this.smfIsNull(item[17])){
									return ''
								}
							}else{
								return item[11];
							}
							
						})); //원점수/과목평균(표준편차)
						tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => {
							if(screScCode == '02'){
								if(!this.smfIsNull(item[18]) && !this.smfIsNull(item[14])){
									return [item[18], '(', item[14], ')'].join('');
								}else if(!this.smfIsNull(item[18])){
									return item[18]
								}else if(!this.smfIsNull(item[14])){
									return '('+item[14]+')'
								}else{
									return ''
								}
							}else{
								//item[12] CURR_LRN_RAK_VALUE
								//item[13] CURR_LRN_SRK
								if(item[12] == null || item[12] == ''){
									return ''
								}else{
									if((item[13] != null && item[13] != '')){
										if(!this.smfIsNull(item[14])){
											return item[12]+'('+item[13]+')/'+item[14];
										}else{
											return item[12]+'('+item[13]+')';
										}
									}else if((item[13] == null || item[13] == '')){
										if(applyYn616 == 'Y'){
											if(!this.smfIsNull(item[14])){
												return item[12]+'( )/'+item[14];
											}else{
												return item[12]+'( )';
											}
										}else{
											if(!this.smfIsNull(item[14])){
												return item[12]+'('+'.'+')/'+item[14];
											}else{
												return item[12]+'('+'.'+')';
											}
										}
									}
								}
 							}
							
						})); //석차등급(수강자수)
						
						tmp.push('');
						tmp.push('');
							
					}else{
						//1학기
						tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => item[10])); //단위수
						tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => {
						
							/* 성적구분(2004이전 입학생:02, 2005이후 입학생:01)   2008관련 : 02
						     * 2004년 이전의 입학생일지라도 2005년 이후에 복학했을 경우 이전자료를 조회하도록 과목별로 성적구분 정보를 가짐.
						     */
							screScCode = this.getScreScCode(item[1], item[2]);//성적구분코드
							
							if(screScCode == '02'){
								if(!this.smfIsNull(item[15]) && !this.smfIsNull(item[16]) && !this.smfIsNull(item[17])){
									return [item[15], '/', item[16], '(', item[17], ')'].join('')
								}else if (this.smfIsNull(item[15]) && this.smfIsNull(item[16]) && this.smfIsNull(item[17])){
									return ''
								}
							}else{
								return item[11];
							}
							
						})); //원점수/과목평균(표준편차)
						tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => {
							if(screScCode == '02'){
								if(!this.smfIsNull(item[20]) && !this.smfIsNull(item[14])){
									return [item[20], '(', item[14], ')'].join('');
								}else if(!this.smfIsNull(item[20])){
									return item[20]
								}else if(!this.smfIsNull(item[14])){
									return '('+item[14]+')'
								}else{
									return ''
								}
							}else{
								//item[12] CURR_LRN_RAK_VALUE
								//item[13] CURR_LRN_SRK
								if(item[12] == null || item[12] == ''){
									return ''
								}else{
									if((item[13] != null && item[13] != '')){
										if(!this.smfIsNull(item[14])){
											return item[12]+'('+item[13]+')/'+item[14];
										}else{
											return item[12]+'('+item[13]+')';
										}
									}else if((item[13] == null || item[13] == '')){
										if(!this.smfIsNull(item[14])){
											return item[12]+'('+'.'+')/'+item[14];
										}else{
											return item[12]+'('+'.'+')';
										}
									}
								}
 							}
							
						})); //성취도(수강자수)
						tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => item[18])); //석차등급
						
						//2학기
						tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => item[10])); //단위수
						tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => {
						
						/* 성적구분(2004이전 입학생:02, 2005이후 입학생:01)   2008관련 : 02
						 * 2004년 이전의 입학생일지라도 2005년 이후에 복학했을 경우 이전자료를 조회하도록 과목별로 성적구분 정보를 가짐.
						 */
						screScCode = this.getScreScCode(item[1], item[2]);//성적구분코드
						
						if(screScCode == '02'){
							if(!this.smfIsNull(item[15]) && !this.smfIsNull(item[16]) && !this.smfIsNull(item[17])){
								return [item[15], '/', item[16], '(', item[17], ')'].join('')
							}else if (this.smfIsNull(item[15]) && this.smfIsNull(item[16]) && this.smfIsNull(item[17])){
								return ''
							}
						}else{
							return item[11];
						}
							
						})); //원점수/과목평균(표준편차)
						tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => {
							if(screScCode == '02'){
								if(!this.smfIsNull(item[20]) && !this.smfIsNull(item[14])){
									return [item[20], '(', item[14], ')'].join('');
								}else if(!this.smfIsNull(item[20])){
									return item[20]
								}else if(!this.smfIsNull(item[14])){
									return '('+item[14]+')'
								}else{
									return ''
								}
							}else{
								if((item[13] != null && item[13] != '')){
									if(!this.smfIsNull(item[14])){
										return item[12]+'('+item[13]+')/'+item[14];
									}else{
										return item[12]+'('+item[13]+')';
									}
								}else if((item[13] == null || item[13] == '')){
									if(!this.smfIsNull(item[14])){
										return item[12]+'('+'.'+')/'+item[14];
									}else{
										return item[12]+'('+'.'+')';
									}
								}
							}
							
						})); //성취도(수강자수)
						tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => item[18])); //석차등급
					}
					return tmp;

				})
				.take( n   // 훈령29-2호적용여부 Y , N
					, '$0'      
					, '$1'  // 학년도, 학년도 
					, '$2'  // 학년, 학년 
					, '$3'  // 교과, 교과 
					, '$4'  // 과목, 과목
					, '$5'  // 1학기 단위수, 1학기 단위수
					, '$6'  // 1학기 원점수/과목평균(표준편차), 1학기 원점수/과목평균(표준편차) 
					, '$7'  // 1학기 성취도(수강자수), 1학기 석차등급(수강자수)
					, '$8'  // 1학기 석차등급, 2학기 단위수
					, '$9'  // 2학기 단위수, 2학기 원점수/과목평균(표준편차)
					, '$10' // 2학기 원점수/과목평균(표준편차), 2학기 석차등급(수강자수)
					, '$11' // 2학기 성취도(수강자수), 공백 
					, '$12' // 2학기 석차등급, 공백
					)
				.select().selectTar(`$0=${n}`, (r, v) => { if(v.length == 0) r.take(n, ...Array(13).fill('')) }) //데이터가 없으면 추가
					
				//1995년 이전자료(과년도) 환산총점 훈령280호(시스템훈령:765) 이전
				.mandatory()
				.select(`$0=14 && $2=${grd}`).groupBy('$1 $2', function(r, v){
					//trace('1995 280이전 groupBy callback : ' + JSON.stringify(v));
					
					var tmp = [];
					
					//1학기
					tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => this.getIntVal(item[4]))); // 환산총점 gr1
					tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => this.getIntVal(item[5]))); // 환산평균 gr2
					tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => {
							if(!this.smfIsNull(item[6]) && item[6] != " "){
								return [item[6], '/', item[7]].join('')
							}else{
								return ''
							}
						})); //학급석차/재적수 gr2
					tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => {
							if(!this.smfIsNull(item[8]) && item[8] != " "){
								return [item[8], '/', item[9]].join('')
							}else{
								return ''
							}
						})); //계열(학년)석차/재적수 gr3	

					//2학기
					tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => this.getIntVal(item[4]))); // 환산총점 gr1
					tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => this.getIntVal(item[5]))); // 환산평균 gr2
					tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => {
							if(!this.smfIsNull(item[6]) && item[6] != " "){
								return [item[6], '/', item[7]].join('')
							}else{
								return ''
							}
						})); //학급석차/재적수 gr2
					tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => {
							if(!this.smfIsNull(item[8]) && item[8] != " "){
								return [item[8], '/', item[9]].join('')
							}else{
								return ''
							}
						})); //계열(학년)석차/재적수 gr3	
					return tmp;	
				})
				.take( ++n  
					, '$0'      
					, '$1'  // 1학기 환산총점
					, '$2'  // 1학기 환산평균
					, '$3'  // 1학기 학급석차/재적수 
					, '$4'  // 1학기 계열(학년)석차/재적수
					, '$5'  // 2학기 환산총점
					, '$6'  // 2학기 환산평균
					, '$7'  // 2학기 학급석차/재적수
					, '$8'  // 2학기 계열(학년)석차/재적수
					, ''
					, ''
					, ''
					, ''
				)
				
				//세부능력 및 특기사항 ( 과목 ) 훈령280호(시스템훈령:765) 이전
				.mandatory()
				.select(`$0=15 && $2=${grd}`)
				.take(++n, '$3')

				//체육예술과목 훈령280호(시스템훈령:765) 이전
				.optional()
				.select(`$0=13 && $2=${grd} && -$3=03`).groupBy('$4 $6 $8', function(r, v){
					//trace('groupBy callback : ' + JSON.stringify(v));
					
					var tmp = [];
					
					tmp.push(v[0][0]); 
					tmp.push(v[0][1]); //학년도
					tmp.push(v[0][2]); //학년
					tmp.push(v[0][5]); //교과
					tmp.push(v[0][9]); //과목
					
					//1학기
					tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => item[10])); //단위수
					tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => [item[20].trim() || item[18]])); //성취도
					
					//2학기
					tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => item[10])); //단위수
					tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => [item[20].trim() || item[18]])); //성취도
					
					return tmp;
				}).take( ++n
					   , '$0'
					   , '$1' // 학년도
					   , '$2' // 학년
					   , '$3' // 교과
					   , '$4' // 과목
					   , '$5' // 1학기 단위수
					   , '$6' // 1학기 성취도 or 등급   
					   , '$7' // 2학기 단위수
					   , '$8' // 2학기 성취도 or 등급
					   )
				.select().selectTar(`$0=${n}`, (r, v) => { if(v.length == 0) r.take(n, ...Array(9).fill('')) }) //데이터가 없으면 추가
				
				//세부능력 및 특기사항 ( 체육예술과목 ) 훈령280호(시스템훈령:765) 이전
				.mandatory()
				.select(`$0=15 && $2=${grd}`)
				.take(++n, '$4')
				
				//자료
				.select()
				.take(++n, '해당 학년의 자료가 없습니다.') //자료(?)
				
				//alert("n :" +n);
			}
			
			//독서활동상황 훈령280호(시스템훈령:765) 이전
			report.mandatory().select('$0=16').take(27, '학년', '과목또는영역', '독서활동상황');
			
			report.trace("독서활동상황=====\n").tar().end();
				
			//행동특성 및 종합의견 훈령280호(시스템훈령:765) 이전
			var atteArr = report.select(`$0=3`).getSelectOrg()// 출결 배열;
			
			var atteArrLength = report.select(`$0=3`).getSelectOrg().length; // 출결 배열길이
			var grdArr = [];
			
			for(var i = 0; i < atteArrLength; i++){ //출결배열 갯수 만큼 행특이 나와야함 예) 출결이 3개 행특이 2개면 빈칸을 채워줘야함
				grdArr[i] = atteArr[i][2];
			}
			
			for(var i = 0; i < atteArrLength; i++){ //출결배열 갯수 만큼 행특이 나와야함 예) 출결이 3개 행특이 2개면 빈칸을 채워줘야함
				var ghvrChrtrYn = report.select(`$0=17 && $2=`+ grdArr[i]).getSelectOrg() == '' ? 'N' : 'Y';
				if(ghvrChrtrYn == 'Y'){
					report.mandatory().select(`$0=17 && $2=`+ grdArr[i]).take(28, '$2', '$3'); //행특 배열의 길이 만큼 출력
				}else if(ghvrChrtrYn == 'N'){
					report.mandatory().select().take(28, grdArr[i], '');
				}
			}
			
			report.trace("행동특성=====\n").tar().end();
			
			//정정대장 훈령280호(시스템훈령:765) 이전
			report.mandatory()
				.select('$0=50')
				.take( 29
					 , '$2' // 정정대장 연월일
					 , '$3' // 학년도 학년 반 번호 졸업대장번호
					 , '$4' // 성명
					 , '$5' // 항목
					 , '$6' // 오류 내용
					 , '$7' // 정정 내용
					 , '$8' // 정정 사유 내용
					 )
					 ;
			
			//편제 및 시간배당 훈령280호(시스템훈령:765) 이전
			report.mandatory()
				.select('$0=60')
				.take( 30
					 , '$1' // 학년도
					 , '$7' // 학년
					 , '$2' // 학기
					 , '$6' // 계열구분명
					 , '$4' // 주야과정 구분명
					 , '$9' // 학과명
					 , '$11' // 편제명
					 , '$13' // 과목명
					 , '$14' // 시수
					 , '$15' //단위수
					 , '$16' //비고
					 );

			// 창의적재량활동
			report.mandatory()
				.select('$0=8')
				.take( 31
					 , '$2' // 학년
					 , '$3' // 활동영역 또는 주제
					 ,  (v) => [v[4], v[5]].join('') // 이수시간
					 , '$6' // 특기사항
					 );
			
			// 특별활동
			report.mandatory()
				.select('$0=9')
				.take( 32
					 , '$2' // 학년
					 , '$3' // 영역
					 , '$4' // 시간
					 , '$5' // 특기사항
					 );
			// 체험활동
			report.mandatory()
				.select('$0=12')
				.take( 33
					 , '$2' // 학년
				     , '$3' // 봉사활동 기간
				     , ''  
				     , '$4' // 장소 또는 주관기관명
				     , '$5' // 활동내용
				     , '$6' // 시간
					 );
	}
	
	//디버그
	report.trace('ret ==============================> \n').tar().end();
	
	var csvdata = report.toOzCSV('#$!', '^&*', '//EOR//')
						.replace(/\n+\^\&\*/gi, '^&*');
	
// 	var csvdata = report.toOzCSV('#$!', '^&*', '//EOR//') //OZ 디자인의 설정과 동일하게
// 						.replace(/\/EOR\/\/EOR\/\^\&\*/gi, '^&*') // /EOR//EOR/^&* 을 ^&*로 변경
// 						.replace(/\/EOR\/\^\&\*/gi, '^&*')        // /EOR/^&* 을 ^&*로 변경
// 						.replace(/\/EOR\/\/EOR\//gi, '\n\n')      // /EOR//EOR/ 을 \n로 변경
// 						.replace(/(?<=[^\/])\/EOR\/(?=[^\/]|$)/gi, '\n'); // /EOR/ 줄바꿈으로 변경 (//EOR//아님)
						
	//var csvdata = report.toOzCSV('#$!', '^&*', '//EOR//') //OZ 디자인의 설정과 동일하게
	//					.replace(/(?<=[^\/])\/EOR\/(?=[^\/]|$)/gi, '\n'); // /EOR/ 줄바꿈으로 변경 (//EOR//아님)	
	
	//trace(" csvdata : " + csvdata);
	
	return csvdata;
}

this.fnReportLoadCallback = function (obj,sReportName)
{
	//trace("====> fnReportLoadCallback - reportName=[" + sReportName + "]");
	this.setWaitCursor(false);
}

/**
 * @description 오즈 뷰 호출
 * @param : aData - 오즈 데이터 배열 ( csv )
 */
this.fnShowOzReport = function(aData, aplyYn){  //cjy 수정 신청버튼여부

	//양면출력
	var prtOpt = (this.dsSearch.getColumn(0, 'prtOpt') == '1') ? 'none' : 'duplexvertical';
	
	var objButton = { "toolbar.save"              : "false"    // 저장 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)       
                    , "toolbar.print"             : "false" // (this.udsfIsDevMode || (this.dsSearch.getColumn(0, "coaRcritScCd") == "4")) ? "true" : "false"    // 인쇄 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
					, "toolbar.pdf"           	  : "false"    // PDF 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
	                , "toolbar.addmemo"           : "false"    // 메모 추가 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
	                , "toolbar.savedm"            : "false"    // 데이터 모듈 저장 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
					, "viewer.usemenubar"         : "false"
					, "print.duplex"              : prtOpt     //duplexvertical 긴쪽, duplexhorizontal 짧은쪽 
					, "global.concatpage"         : "false"
	                }

	//훈령에따른 reportName 분기

	var reportName = "";

	var reports = aData.reduce((a,v,i) => {
	
		var childNum =  i + 1; 
		objButton["child" + childNum + ".toolbar.save" ]    = false;
		objButton["child" + childNum + ".toolbar.print" ]   = false;
		objButton["child" + childNum + ".toolbar.pdf" ]     = false;
		objButton["child" + childNum + ".toolbar.addmemo" ] = false;
		objButton["child" + childNum + ".toolbar.savedm" ]  = false;
		objButton["child" + childNum + ".print.duplex" ]    = prtOpt;
		
		var reportIdx = this.dsReportNm.findRowExpr(this.udsfGetCondition(['prcsSn','rreqNts'], [v.prcsSn, v.rreqNts]));
		
		reportName = this.dsReportNm.getColumn(i, "reportName");
		a.push({
			// 기본데이터
			  displayname	: v.title   // [필수] 멀티리포트시 Tree에 보여줄 이름
			, reportname	: reportName // [필수] 리포트명  "/jsonsample.ozr"
			, jsonParam	: ["viewerType=HTML5 Canvas Viewer 1"]
			, csvData    : v.csv                               // [선택] csv데이터
			, security		: "N"	// [선택] 위변조방지 삽입   ("Y"(default):표시,"N":비표시)
			, voiceBarcode	: "N"	// [선택] 보이스바코드 삽입 ("Y"(default):표시,"N":비표시)		
			, zoom : "100"   // [선택] 보고서 화면의 비율을 백분율로 설정(default:"100")
		});
		return a;
	}, []);
	
	//cjy 수정 신청버튼여부에 따른 팝업 크기 조절
	if(!this.smfIsMobile()){
		var width = aplyYn == 'Y' ? 1030 : 1030;
		//var height = aplyYn == 'Y' ? 940 : 860;	
		var height = aplyYn == 'Y' ? document.body.clientHeight : document.body.clientHeight - 50;	
	}else{
		var width = aplyYn == 'Y' ? 640 : 640;
		var height = aplyYn == 'Y' ? 650 : 650;	
	}
	var oOzOption = {
		  'reports' : reports
		, 'zoom' : 100
		, 'reportloadevent' : this.fnReportLoadCallback    // [선택] 레포트 로드된 이후 불려지는 함수(인쇄시에도 발생)
		, button : objButton    // [선택] 버튼의 표시 비표시를 통제
		, popupWidth : width    //cjy 수정 신청버튼여부에 따른 팝업 크기 조절
		, popupHeight : height  //cjy 수정 신청버튼여부에 따른 팝업 크기 조절
		, 'shlCd' : this.dsCoaDataInfo.getColumn(0, "shlCd")  //학교코드
		, security : "N"   // [선택] 위변조방지 삽입   ("Y"(default):표시,"N":비표시)
	}
	
	//cjy 수정 신청버튼여부
	this.udsReportView(this, oOzOption, this.fnPopupCallback, aplyYn);// CJY 수정 popup 형태(모바일) 지원
}

/**
* @description coaWrkPrcsCd 에 따른 읽기할 파일을 this.fvQueFiles에 담는다.
*/
this.fnTakeFileInfo = function(i){
	var ds = this.dsMain;

	var coaSeleFileNm = ds.getColumn(i, "coaSeleFileNm");
	var coaImageFileNm = ds.getColumn(i, "coaImageFileNm");
	var shlNm = ds.getColumn(i, "shlNm");
	
	var coaSeleFilePath = this.fvCoaDataPath + "\\" + coaSeleFileNm;
	this.fvQueFiles.enqueue({
		'idx' : i,
		'nm' : coaSeleFilePath,
		'cn' : '',
		'type' : 'T', //text
		'attr' : 'F', //file
		'shlNm' : shlNm
	});
	
	if(!this.fnIsBld()){
		var coaImagePath = this.fvCoaDataPath + "\\" + coaImageFileNm;
		this.fvQueFiles.enqueue({
			'idx' : i,
			'nm' : coaImagePath,
			'cn' : '',
			'type' : 'B', //binary
			'attr' : 'I', //image
			'shlNm' : shlNm
		});
	}
}

/** 
 * @description 대입_졸업생개인신청암호화파일내역 조회
 * 대입 수정(fnVirtualFileOpen 메서드)
 */
this.fnSearchCoaSeleFileCn = function(aplyYn){ //cjy 수정 신청버튼여부
	this.dsSearch.setColumn(0, "shlCd", this.dsCoaDataInfo.getColumn(0, "shlCd"));
	//파라미터 조회 
	this.smfSearchService("selectCoaSeleData")
	
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			
			var dsCoaData = this.dsCoaData;
			var coaSeleFileNm = dsCoaData.getColumn(0, "coaSeleFileNm");
			var coaImageFileNm = dsCoaData.getColumn(0, "coaImageFileNm");
			var shlNm = dsCoaData.getColumn(0, "shlNm");
			var dddepNm = dsCoaData.getColumn(0, "dddepNm");
			
			var dsMain = this.dsMain;
			dsMain.addRow();
			dsMain.setColumn(0, 'coaSeleFileNm', coaSeleFileNm);
			dsMain.setColumn(0, 'coaImageFileNm', coaImageFileNm);
			dsMain.setColumn(0, 'shlNm', shlNm);
			dsMain.setColumn(0, 'dddepNm', dddepNm);
			
			if(this.dsErrMsg.getColumn(0, "messageCode") != "undefined" && this.dsErrMsg.getColumn(0, "messageCode") != null){
				this.smfAlert(this.dsErrMsg.getColumn(0, 'message'), function(){this.fnCoaDataSearch();}); //에러메시지
			}
			
			//fvQueRawData 큐에 요소 추가 되어 있는지 확인.  
			if(this.fvQueRawData.isEmpty()){
				this.fnTakeFileInfo(this.fvQueIdx.dequeue());
			}
			this.fnCoaDataCallback(aplyYn); //cjy 수정 신청버튼여부
		});
};

/**
* @description VirtualFile 콜백
*/
this.fnVirtualFileCallback = function(aplyYn){ //cjy 수정 신청버튼여부
	var f = this.fvQueFiles.dequeue();
	var firstRawData = this.fvQueRawData.first(-1);
	
	if(this.smfIsNull(firstRawData) || firstRawData.idx != f.idx){
		coaData = { idx : f.idx, shlNm : f.shlNm };
		if(f.attr == 'F'){
			coaData.sele = { cn : f.cn };
		}else if(f.attr == 'I'){
			coaData.image = { cn : f.cn};
		}
		this.fvQueRawData.enqueue(coaData);
	}else{
		if(f.attr == 'F'){
			firstRawData.sele = { cn : f.cn };
		}else if(f.attr == 'I'){
			firstRawData.image = { cn : f.cn};
		}
	}
	
	//비지니스 로직
	if(this.fvQueFiles.isEmpty()){
		this.fnDoNext(aplyYn); //cjy 수정 신청버튼여부
	}else{
		this.fnCoaDataCallback(aplyYn); //cjy 수정 신청버튼여부
	}
}

/**
* @description 큐 버퍼 클리어
*/
this.fnClearQueue = function(){
	this.fvQueFiles.clear();
	this.fvQueRawData.clear();
	this.fvQueIdx.clear();
}

/**
* @description 다음작업 실행
* 대입 수정
*/
this.fnDoNext = function(aplyYn){ //cjy 수정 신청버튼여부 

	if(this.fvQueIdx.isEmpty()){
		if(!this.fvQueRawData.isEmpty()){
			this.fnDoOzReport(aplyYn); //cjy 수정 신청버튼여부 
			this.setWaitCursor(false);
		}
	}else{
		this.fnSearchCoaSeleFileCn(aplyYn); //cjy 수정 신청버튼여부 
	}
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.btnSeleDataAply_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	const chkList = '0'		// index
	
	this.fnClearQueue();
	this.setWaitCursor(true);
	
	this.fvQueIdx.enqueue(chkList);
	
	this.fnDoNext('Y'); //cjy 수정 신청버튼여부
};

/**
 * @description 대입전형자료 미리보기
 */
this.btnReportView_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	const chkList = '0'		// index
	
	this.fnClearQueue();
	this.setWaitCursor(true);
	
	this.fvQueIdx.enqueue(chkList);
	
	this.fnDoNext();
};

/*
 * @description 대입전형자료 읽기 
 * 대입 수정(VirtualFile00_onsuccess 메서드) 
*/
this.fnCoaDataCallback = function(aplyYn) //cjy 수정 신청버튼여부
{
	var f = this.fvQueFiles.first();
	
	if(f.type == 'T'){
		f.cn = this.dsCoaData.getColumn(0, "coaSeleFileCn");
	}else if(f.type == 'B'){
		f.cn = this.dsCoaData.getColumn(0, "coaImageFileCn");
	}

	this.fnVirtualFileCallback(aplyYn); //cjy 수정 신청버튼여부
};

this.btnVrfcSnCopy_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfCopyToClipboard(this.divCoaDataInfo.form.edtVrfcSn.value);
	this.smfAlert("자료 제공 인증번호를 클립보드로 복사하였습니다.");
};

/************************************************************************************************
 * 대입전형수신자료출력 END
 ************************************************************************************************/
]]></Script>
