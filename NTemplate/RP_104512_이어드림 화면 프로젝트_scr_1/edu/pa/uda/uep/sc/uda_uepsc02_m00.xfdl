/**
 * @description 전달받은 인자가 null 혹은 ""인지 판단하여 리턴
 * @param  : String
 * @return : boolean
 */
this.getIsEmptyString = function(str){
	if("" == str){
		return true;
	}else{
		return false;
	}  
}

/**
 * @description 전달받은 인자가 null 혹은 ""인지 판단하여 리턴
 * @param  : String
 * @return : String
 */
this.getIsNullToString = function(str){
	if("/NULL/" == str){
		return "";
	}else{
		return str.toString();
	}  
}

/**
 * @description 전달받은 인자가 null 혹은 undefined 인지 판단하여 리턴
 * @param  : String
 * @return : boolean
 */
this.checkNullNumber = function(num){
	if(num === null || num === undefined){
		return true;
	}else{
		return false;
	}  
}

/**
 * 전달받은 숫자형 문자의 소수점이 0값이면 소수점값을 버리고 정수만 리턴
 * @return 
 * */
this.getIntVal = function(num){
	if(this.checkNullNumber(num)){
		return num;
	}
	
	if(Math.round(parseFloat(num)) == parseFloat(num)){
		return Math.round(parseFloat(num))
	}else{
		return num;
	}
}


/**
 * @description 전달받은 인자가 /EOR/ 일 경우 ''으로 치환
 * @param  : String
 * @return : String
 */
this.getEorToEmpty = function(str){
	
	/*
	/EOR/은 ^&*로 치환되는데 데이터가 /EOR/만 있는 경우
	오즈리포트에서 빈줄무시 기능으로 자료 없음으로 인식되기때문에 빈값으로 치환함
	자료에 개행 외 다른 값이 있을 경우에는 치환하지 않음.
	*/

	if("/EOR/" == this.getIsNullToString(str)){
		return " ";
	}else{
		return str.toString();
	}  
}

/**
 * @description 성적구분(2004이전 입학생:02, 2005이후 입학생:01)
 * @param  : ayr
 * @param  : grd
 * @return : screScCode 성적구분코드
 * */
this.getScreScCode = function(ayr, grd){
	 /* 성적구분(2004이전 입학생:02, 2005이후 입학생:01)   2008관련 : 02
	  * 2004년 이전의 입학생일지라도 2005년 이후에 복학했을 경우 이전자료를 조회하도록 과목별로 성적구분 정보를 가짐.
	  */
	if(Number(ayr) > 2004){
		if((ayr == '2005' && grd == '2') || (ayr == '2005' && grd == '3') || (ayr == '2006' && grd == '3')){
			return '01';
		}else{
			return '02';
		}
	}else{
		return '01';
	}
}

/**
 * @description 오즈 데이터 생성
 * @param : coaSeleFileCn - 대입전형자료
 * @param : coaImageFileCn - 대입전형자료이미지
   @param : rowDataidx - 로우데이터 인덱스
 * @return : csv - 오즈 데이터
 */
this.fnTransOzData = function(shlNm, coaSeleFileCn, coaImageFileCn, rowDataidx){
	var report = this.fnCreateReport(coaSeleFileCn).adjustNewline('/EOR/').seprate('^').trim(true);
	//report.enableTrace(true);
	report.trace('org------------------------->\n').org().end();
	
	var stuInfo = []; // 학생정보
	var viewGb = "03"; // 학생부종류
	stuInfo = report.select('$0=0').getSelectOrg();	
	
	var blindYn = "Y";//this.divSearch.form.rdoSeleDataScCd.value; //블라인드여부		// [대입개인생성수정]
	
	var stuIdfNo    = stuInfo[0][3];  // 학생 식별번호
	var strGrdtnYr  = stuInfo[0][5];  // 학생 졸업학년도
	var strGrdtnGrd = stuInfo[0][6];  // 학생 졸업학년
	var sMeisterYn  = stuInfo[0][7];  // 마이스터고 여부
	var sSpecrzdYn  = stuInfo[0][8];  // 특성화고 여부
	
	var grd1 = 1;
	var grd2 = 2;
	var grd3 = 3;
	
	if (strGrdtnGrd == 1) {
		grd1 = 1;
		grd2 = 0;
		grd3 = 0;
	}
	if (strGrdtnGrd == 2) {
		grd1 = 1;
		grd2 = 2;
		grd3 = 0;
	}
	if (strGrdtnGrd == 3) {
		grd1 = 1;
		grd2 = 2;
		grd3 = 3;
	}
	
	this.fnChkOfod(strGrdtnYr, strGrdtnGrd); // 훈령체크후 데이터셋에 정보 셋
	
	var applyYn616 = this.dsOfodIdnty.getColumn(0,"hr616ApplyYn"); //훈령616호적용여부 Y
	var applyYn676 = this.dsOfodIdnty.getColumn(0,"hr676ApplyYn"); //훈령676호적용여부 Y
	// 2015년 부터
	var applyYn719 = this.dsOfodIdnty.getColumn(0,"hr719ApplyYn"); //훈령719호적용여부 Y
	var applyYn728 = this.dsOfodIdnty.getColumn(0,"hr728ApplyYn"); //훈령728호적용여부 Y
	var applyYn205 = this.dsOfodIdnty.getColumn(0,"hr205ApplyYn"); //훈령205호적용여부 Y
	var applyYn239 = this.dsOfodIdnty.getColumn(0,"hr239ApplyYn"); //훈령239호적용여부 Y
	
	var applyYn29A = this.dsOfodIdnty.getColumn(0,"hr29AApplyYn"); //훈령29-1호적용여부
	var applyYn29B = this.dsOfodIdnty.getColumn(0,"hr29BApplyYn"); //훈령29-2호적용여부 (교과학습발달상황 폼 변경)
	var applyYn169 = this.dsOfodIdnty.getColumn(0,"hr169ApplyYn"); //훈령169호적용여부  (Y => 국가직무)
	var applyYn195 = this.dsOfodIdnty.getColumn(0,"hr195ApplyYn"); //훈령195호적용여부
	var applyYn243 = this.dsOfodIdnty.getColumn(0,"hr243ApplyYn"); //훈령243호적용여부  (<체육ㆍ예술> 여부)
	var applyYn280 = this.dsOfodIdnty.getColumn(0,"hr280ApplyYn"); //훈령280호적용여부
	var applyYn321 = this.dsOfodIdnty.getColumn(0,"hr321ApplyYn"); //훈령321호적용여부 단위수 학점수로 명칭이 바뀜 (마이스터고)
	var applyYn365 = this.dsOfodIdnty.getColumn(0,"hr365ApplyYn"); //훈령365호적용여부
	var applyYn393 = this.dsOfodIdnty.getColumn(0,"hr393ApplyYn"); //훈령393호적용여부 단위수 학점수로 명칭이 바뀜 (특성화고)
	var applyYn433 = this.dsOfodIdnty.getColumn(0,"hr433ApplyYn"); //훈령433호적용여부
	var applyYn477 = this.dsOfodIdnty.getColumn(0,"hr477ApplyYn"); //훈령477호적용여부
	var applyYn504 = this.dsOfodIdnty.getColumn(0,"hr504ApplyYn"); //훈령504호적용여부
	
	sMeisterYn = ((applyYn321 =='Y') && "Y" == sMeisterYn) ? "Y" : "N";
	//370호 부터 특성화고 여부 적용
	/*393호 차수 누락됨.. 추가 필요 . 20220825 to-be  */
	/*차수가 학점수로 명칭이 바뀜 */
	
	// TO-DO [대입전형]특성화고 훈령 확인 필요.
	//20240617 일반고, 특목고 조기졸업예정자 훈령433(785차수)인 경우 단위수->학점수 변경
	if("Y" == sSpecrzdYn){
		sSpecrzdYn = ((applyYn393 == 'Y') && "Y" == sSpecrzdYn) ? "Y" : "N";
	}else{
		sSpecrzdYn = (applyYn433 == 'Y') ? "Y" : "N";
	}
	
	var coaEvlUnitNm   = this.dsMain.getColumn(rowDataidx,'coaEvlUnitNm'); //평가단위명
	var uvstExmtNo     = this.dsMain.getColumn(rowDataidx,'uvstExmtNo'); // 수험번호
	var pulExmtNo      = this.dsMain.getColumn(rowDataidx,'pulExmtNo'); // 복수수험번호
	var crctRgrInclsYn = "N";// this.dsMain.getColumn(rowDataidx,'crctRgrInclsYn'); // 정정대장포함여부 // [대입개인생성수정]
	
	var prcsSn = this.dsMain.getColumn(rowDataidx,'prcsSn'); // 처리대장일련번호
	var rreqNts = this.dsMain.getColumn(rowDataidx,'rreqNts'); //재요청 횟수
	
	//리포트 명 데이터셋 
	var addIdx = this.dsReportNm.addRow();
	
	this.dsReportNm.setColumn(addIdx, "prcsSn", prcsSn);
	this.dsReportNm.setColumn(addIdx, "rreqNts", rreqNts);
		
	if(applyYn504 == 'Y'){
		this.dsReportNm.setColumn(addIdx, "reportName", "/edu/pa/uds/ueu/dd/uds_ueudd01_r07.ozr");
	}else if(applyYn280 == 'Y'){
		this.dsReportNm.setColumn(addIdx, "reportName", "/edu/pa/uds/ueu/dd/uds_ueudd01_r06.ozr");
	}else{
		this.dsReportNm.setColumn(addIdx, "reportName", "/edu/pa/uds/ueu/dd/uds_ueudd01_r05.ozr");
	}
	
	//양면출력
	var prtOpt = this.dsSearch.getColumn(0, 'prtOpt');
	
	//편제 제공여부
	var orgaOtptYn = this.dsSearch.getColumn(0, 'orgaOtptYn'); // [대입개인생성수정]
	
	//과목별평가정보 제공여부
	var sbjtEvlInfoOtptYn = this.dsSearch.getColumn(0, 'sbjtEvlInfoOtptYn'); // [대입개인생성수정]
	
	//훈령 280이후
	var ncsYn280 = "N";                // 국가직무능력 표준 이수상황 여부
	var mjrDisable280 = "Y";           // 전공과정 숨김여부
