    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    TEMPLATE
*  @FileName 	uda_uep_sc02_p01.xfdl
*  @Creator 	최재영
*  @CreateDate 	2024.02.27
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.7.22     	홍길동 	        최초 생성
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 팝업 폼 초기화
	this.smfInitPopup(obj); 
	this.fnSelectCoaCtr(); // 대입기준 조회
	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	this.dsSearch.setColumn(0, "shlCd", this.pv_params.reportOption.shlCd);
	this.divReport.optionReport = this.pv_params.reportOption;
	this.divReport._objForm = this.pv_params.sender;
	// report를 그린다.
	this.divReport.set_url("comm::comp_ozreport.xfdl");
	
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnSelectCoaCtr = function(){
	// 대입기준 조회
	this.smfSearchService("selectCoaApstNpvsnCeck")
		.run() // 실행		
		.callback(function(callbackParams){ // 콜백
			if(callbackParams.errors) return;
			// 초기화
			this.fnInit();
		});	
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};

//신청버튼 클릭
this.btnAply_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var dataIdntyYn = "Y";
	var dataSbmsnYn = "N";
	
	/* 안내문구 통합.
	if(this.chkDtaIdntyYn.value == "Y"){
		dataIdntyYn = "Y";
	}*/
	if(this.chkSbmsnYn.value == "Y"){
		dataSbmsnYn = "Y";
	}
	
	if(dataIdntyYn == "Y" && dataSbmsnYn == "Y"){
		// 오류메시지 초기화
		this.dsErrMsg.clearData();
		try {
			this.dsSearch.setColumn(0, "tsCetCd", window.location.search.substring(1).split("=")[0] == "tsCetCd" ? window.location.search.substring(1).split("=")[1] : "");
		} catch (e) {
			trace(e);
		}
		// 대입기준 조회
		this.smfSearchService("selectCoaApstNpvsnCeck")
		.run() // 실행		
		.callback(function(callbackParams){ // 콜백
			if(callbackParams.errors) return;
			
			if(this.dsErrMsg.getRowCount() > 0){
				// 오류메시지 처리
				this.smfAlert(this.dsErrMsg.getColumn(0, 'message'));
			} else {
				
				var rcritNm = this.dsCoaCtrList.getColumn(0,"rcritNm"); // 모집구분명
				var seleDataCrtBgngYmd = this.dsCoaCtrList.getColumn(0,"seleDataCrtBgngYmd"); // 신청시작일자
				var seleDataCrtEndYmd  = this.dsCoaCtrList.getColumn(0,"seleDataCrtEndYmd");  // 신청종료일자
				var finYn  			   = this.dsCoaCtrList.getColumn(0,"finYn");  // 신청일자체크
				if(finYn == "N"){
					this.fnAlertUda(function(){
						}, {message : "대입전형자료(학교생활기록부)\n온라인 생성신청 기간이 아닙니다.",
							messageCn : "\n\n- " + rcritNm + " 생성신청 기간: " + seleDataCrtBgngYmd.dateFormat("yyyy.MM.dd.") + " ~ " + seleDataCrtEndYmd.dateFormat("yyyy.MM.dd.") + " \n\n해당 기간에만 이용하실 수 있습니다.",
							messageRmk : "",
							color : "#1E5DF2"}
					);
				} else {
					//파라미터 셋팅
					this.dsSearch.setColumn(0, "coaAyr"      , this.dsCoaCtrList.getColumn(0, "coaAyr")); // 대입학년도
					this.dsSearch.setColumn(0, "coaRcritScCd", this.dsCoaCtrList.getColumn(0, "coaRcritScCd")); // 모집구분코드
					//학생의 주민등록번호 고유 키 셋팅
					this.smfExecuteService("executeCoaSeleDataAply")
						.messagePrefix(["대입전형자료(학교생활기록부) 온라인 생성을 신청"])
						.run() // 실행			
						.callback(function(callbackParams){ // 콜백
							if(callbackParams.errors) return;
							if(this.dsErrMsg.getColumn(0, "messageCode") != "undefined" && this.dsErrMsg.getColumn(0, "messageCode") != null){
								this.smfAlert(this.dsErrMsg.getColumn(0, 'message')); //에러메시지
							}else{
								this.smfAlert("대입전형자료(학교생활기록부) 온라인 생성 신청이 완료되었습니다.", function(){
									this.close();
									this.opener.fnCoaDataSearch();
								});	
							}
						});	
				}
			}
		});
		
		
		
	}else{
		if(dataIdntyYn == "N"){
			this.chkDtaIdntyYn.setFocus();
			this.smfAlert("대입전형자료(학교생활기록부)가 이상 없음을 확인 후 신청을 진행바랍니다.");
		}else if(dataSbmsnYn == "N"){
			this.chkSbmsnYn.setFocus();
			this.smfAlert("대입전형자료(학교생활기록부) 온라인 제공에 동의 후 신청을 진행바랍니다.");	
		}
	}
};


/*
 * @description 대입전형자료 알림창
   @param  message : 메시지 dataSet
   @param  callback : 확인버튼 클릭후 콜백함수
   @param  objOption : dialog를 띄울때의 조건(JOSN형태. {left:100,top:100,width:100,height:100} 생략가능)
*/
this.fnAlertUda = function(callBack, objOption) {
	var nLeft   = null;
	var nTop    = null;
	var nWidth  = null;
	var nHeight = null;
	var nAlign  = null;
	var nColor  = null;
	var message  = null;
	var messageCn  = null;
	var messageRmk  = null;

	// 옵션이 있다면 값을 적용(주로 left,top,width,height)
	if(objOption)
	{
		nLeft   = objOption.left;
		nTop    = objOption.top;
		nWidth  = objOption.width;
		nHeight = objOption.height;
		nAlign  = objOption.align;
		nColor	= objOption.color;
		message	= objOption.message;
		messageCn	= objOption.messageCn;
		messageRmk	= objOption.messageRmk;
	}
	if(!this.smfIsNull(message) || !this.smfIsNull(messageCn) || !this.smfIsNull(messageRmk)){
		// 오류메시지 초기화
		this.dsErrMsg.clearData();
		this.dsErrMsg.addRow();
		this.dsErrMsg.setColumn(0, "message", this.smfIsNull(message) ? "" : message);
		this.dsErrMsg.setColumn(0, "messageCn", this.smfIsNull(messageCn) ? "" : messageCn);
		this.dsErrMsg.setColumn(0, "messageRmk", this.smfIsNull(messageRmk) ? "" : messageRmk);
	}
	
	this.smfDialog("comm_alertUda" , "comm::comm_alertUda.xfdl", {
		callback: callBack,
		titlebar:true,
		params: {
			procType : "none",
			message  : this.dsErrMsg,
			align    : nAlign,
			color    : nColor
		}
	}
	,nLeft,nTop,nWidth,nHeight
	);
}]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsCoaCtrList=dsCoaCtrList dsErrMsg=dsErrMsg</Col>
            <Col id="asynctp"/>
            <Col id="url">uda_uep_sc02_000.do</Col>
            <Col id="id">selectCoaApstNpvsnCeck</Col>
          </Row>
          <Row>
            <Col id="id">executeCoaSeleDataAply</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="url">uda_uep_sc02_004.do</Col>
            <Col id="outDatasets">dsSearch=dsSearch dsErrMsg=dsErrMsg</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="coaAyr" type="STRING" size="256"/>
          <Column id="coaRcritScCd" type="STRING" size="256"/>
          <Column id="trprRrno" type="STRING" size="256"/>
