        <Grid id="grdList" taborder="2" left="0" top="234" height="282" right="0" binddataset="dsMain" autofittype="col" initvalueid="ivGrdAccessibilityOn" cellclickbound="control" visible="false" enable="true" readonly="false" enableevent="true" useselcolor="false" selecttype="cell" accessibilitylabel="수신대학현황" cellsizingtype="col">
