        <Div id="div00_00" taborder="3" left="0" cssclass="div_WF_InfoBOX" right="0" top="grdList:20" height="304" initvalueid="ivDivAccessibilityOff" text="">
          <Layouts>
            <Layout>
              <Static id="sta00_00_01_01_00" taborder="0" left="29" top="28" height="23" cssclass="sta_WF_InfoTit" text="대입전형자료 온라인제공 진행상태 안내" wordWrap="char" initvalueid="ivStcAccessibilityOn" width="310"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_01" taborder="10" left="30" top="51" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta00_00_01_01_03" taborder="1" left="30" top="73" height="23" cssclass="sta_WF_InfoTxt_Black" text="1. 대입전형자료(학교생활기록부) 온라인 생성신청 완료 후 대학이 자료 수신을 시작해야 대학별 수신 현황 확인이 가능함" wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="20"/>
              <Static id="sta00_00_01_01_03_00" taborder="2" left="30" top="sta00_00_01_01_03:2" height="23" cssclass="sta_WF_InfoTxt_Black" text="2. 대학이 자료 수신을 시작하지 않은 경우 ‘공란’으로 표시됨" wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="11" onclick="div00_00_sta00_00_01_01_03_00_onclick"/>
              <Static id="sta00_00_01_01" taborder="3" left="30" top="sta00_00_01_01_03_00:2" height="23" cssclass="sta_WF_InfoTxt_Black" text="3. 대학교 작업진행순서 : 자료요청 &gt; 수신준비 &gt; 수신완료" wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="30"/>
              <Static id="sta00_00_01_01_01" taborder="4" left="30" top="sta00_00_01_01:2" height="23" cssclass="sta_WF_InfoTxt_Black" text="4. 진행 상태별 안내" wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="30"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00" taborder="9" left="0" top="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta00_00_01_01_02" taborder="5" left="40" top="sta00_00_01_01_01:4" height="23" cssclass="sta_WF_InfoTxt_Black" text="※&lt;fc v='red'&gt; 자료요청&lt;/fc&gt;:  대학에서 고등학교에 대입전형자료(학생부)를 요청한 상태" wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="20"/>
              <Static id="sta00_00_01_01_01_00" taborder="6" left="40" top="202" height="23" cssclass="sta_WF_InfoTxt_Black" text="※&lt;fc v='red'&gt; 수신준비&lt;/fc&gt;: 요청한 학생이 해당 고등학교 학생으로 확인되어 대입전형자료(학생부) 제공이 준비된상태" wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="20"/>
              <Static id="sta00_00_01_01_02_00" taborder="7" left="40" top="229" height="23" cssclass="sta_WF_InfoTxt_Black" text="※&lt;fc v='red'&gt; 수신완료&lt;/fc&gt;: 수신 준비한 대입 전형자료(학생부)를 대학에서 수신받은 상태" wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="10"/>
              <Static id="sta00_00_01_01_01_00_00" taborder="8" left="40" top="256" height="23" cssclass="sta_WF_InfoTxt_Black" text="       (대학에서 기재한 재요청 사유로 인해 한 학생 자료를 여러번 요청할 수도 있습니다.)" wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="10"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_00" taborder="11" left="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" bottom="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta99_00_00_00_00_01_01" taborder="12" left="0" top="30" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="30" text="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta99_00_00_00_00_01_01_00" taborder="13" top="30" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="30" text="30" right="0" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="sta00_00_01_01_01_00" text="※&lt;fc v='red'&gt; 수신준비&lt;/fc&gt;: 요청한 학생이 해당 고등학교 학생으로 확인되어 대입전형자료(학생부) 제공이 준비된상태" fittocontents="height" left="40" top="sta00_00_01_01_02:4" height="23" right="20" taborder="6"/>
              <Static id="sta00_00_01_01_02" fittocontents="height" left="40" top="sta00_00_01_01_01:4" height="23" right="20" taborder="5"/>
