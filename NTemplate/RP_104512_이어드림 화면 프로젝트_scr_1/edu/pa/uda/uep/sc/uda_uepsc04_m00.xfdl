          <Column id="messageCode" type="STRING" size="256" description="메세지코드" datapath="메세지코드"/>
          <Column id="message" type="STRING" size="256" description="메세지" datapath="메세지"/>
          <Column id="messageCn" type="STRING" size="256" datapath="메세지내용" description=""/>
          <Column id="messageRmk" type="STRING" size="256" datapath="메세지비고" description=""/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대입전형자료 수신대학 현황조회
*  @FileName 	sqa_upesc05_m00.xfdl 
*  @Creator 	최재영
*  @CreateDate 	2022.09.05
*  @Desction    대입전형자료 수신대학 현황조회
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2024.02.15          최재영                 최초 생성
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::cm_script.xjs"
include "lib::uds_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.fv_param;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);

	this.fv_param = this.smfGetFormParams();
	var menuId = this.fv_param.menu;
	if(this.smfIsMobile()){//모바일
		this.grdList.setFormatRowProperty(0, "size", 60);
		this.grdList.setFormatRowProperty(1, "size", 70);
	}
	
	this.fnSelectCoaCtr();	//기준정보 조회 
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd == -1) return;
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 조회 버튼 클릭
*/
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnCoaSeleRcptnPnsta();
};

/**
 * @description 대입전형자료기준정보조회
*/
this.fnSelectCoaCtr = function(){
	
	this.dsSearch.setColumn(0, "tsCetChk", window.location.search.substring(1).split("=")[0] == "tsCetCd" ? window.location.search.substring(1).split("=")[1] : "");
	
	//기준정보조회
	this.smfSearchService("selectCoaApstNpvsnCeck")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			if(this.dsErrMsg.getColumn(0, "messageCode") == "undefined" || this.dsErrMsg.getColumn(0, "messageCode") == null){//cjy 수정
				//초기화
				this.fnInit();
			}else{
				//에러메시지
				this.smfAlert(this.dsErrMsg.getColumn(0, 'message'), function(){
					var objFrame = this.getOwnerFrame();
				
					if(objFrame.form.divAll)
					{
						// Top 에 값을 세팅
						var sMainUrl = objFrame.form.fv_mainformUrl;
						
						// 메인URL로 이동한다.
						if(!this.smfIsNull(sMainUrl))
						{
							objFrame.form.fnSetMainpage(sMainUrl);	
						}
					}
				}); 
			}
		});	
	
}

/**
 * @description 대입전형자료수신대학현황조회
*/
this.fnCoaSeleRcptnPnsta = function(){
	this.smfSearchService("selectDataList")
		
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;			
		});	
}

/**
 * @description 초기화 FUNCTION
*/
this.fnInit = function(){	
	var rcritScByBgngYmd = this.dsCoaCtrList.getColumn(0,"rcritScByBgngYmd"); // 모집시작일자
	var rcritScByEndYmd  = this.dsCoaCtrList.getColumn(0,"rcritScByEndYmd");  // 모집종료일자
		
	if(this.dsCoaCtrList != null && this.dsCoaCtrList != "undefined"){
		this.dsSearch.setColumn(0, "coaAyr"      , this.dsCoaCtrList.getColumn(0, "coaAyr"));
		this.dsSearch.setColumn(0, "coaRcritScCd", this.dsCoaCtrList.getColumn(0, "coaRcritScCd"));
		this.dsSearch.setColumn(0, "coaRcritScNm", this.dsCoaCtrList.getColumn(0, "rcritNm"));
		this.dsSearch.setColumn(0, "coaEvlUnitId", "");
		this.dsSearch.setColumn(0, "coaEvlUnitNm", "- 전체 -");
		
		this.dsSearch.setColumn(0, "bldRmvYn", "N");
		
		this.dsSearch.setColumn(0, "prtOpt", "1");
		this.dsSearch.setColumn(0, "orgaOtptYn", "Y");// CJY 수정 안보일시 N
		this.dsSearch.setColumn(0, "prtOrgaOpt", "N");
		
		this.dsSearch.setColumn(0,"cddcCd",this.smfGetCddcCode())
		
		var idx = this.dsCoaCtrList.rowcount -1;
		if(this.dsCoaCtrList.getColumn(idx, "chkYn") != null && this.dsCoaCtrList.getColumn(idx, "chkYn") != "" && this.dsCoaCtrList.getColumn(idx, "chkYn") != "undefined"){
			chkYn = this.dsCoaCtrList.getColumn(idx, "chkYn")
		}
		if(this.dsCoaCtrList.getColumn(idx, "finYn") != null && this.dsCoaCtrList.getColumn(idx, "finYn") != "" && this.dsCoaCtrList.getColumn(idx, "finYn") != "undefined"){
			finYn = this.dsCoaCtrList.getColumn(idx, "finYn")
		}
		if(this.dsCoaCtrList.getColumn(idx, "rcritScByFromTo") != null && this.dsCoaCtrList.getColumn(idx, "rcritScByFromTo") != "" && this.dsCoaCtrList.getColumn(idx, "rcritScByFromTo") != "undefined"){
			finFromTo = this.dsCoaCtrList.getColumn(idx, "rcritScByFromTo")
		}	
	}
	
	//신청기간 구분
	if(chkYn == "Y"){
		this.divSearch.set_enable(false);
		this.grdList.set_enable(false);
		this.grdList.set_visible(true);
		this.fnAlertUda(function(){
				var objFrame = this.getOwnerFrame();
				if(objFrame.form.divAll){
					var sMainUrl = objFrame.form.fv_mainformUrl;
					if(!this.smfIsNull(sMainUrl)) objFrame.form.fnSetMainpage(sMainUrl); // 메인URL로 이동한다.
				}
			}, {message : "대학의 대입전형자료(학교생활기록부)\n온라인 수신 기간이 아닙니다.",
				messageCn : "\n\n- 수시 수신기간: 2024. 9.14. ~ 12.12. \n- 정시 수신기간: 2025. 1. 7. ~ 2.28.\n\n해당 기간에만 이용하실 수 있습니다.",
				messageRmk : "",
				color : "#1E5DF2"}
		);
		return;
	}else if(chkYn == "N"){
		var menuId = this.fv_param.menu;
		if(this.udsfUepChkLogin(menuId)){//로그인여부 판단
			this.divSearch.set_visible(true);
			this.grdList.set_visible(true);
			this.fnCoaSeleRcptnPnsta()
		}
	}
}


/*
 * @description 대입전형자료 알림창
   @param  message : 메시지 dataSet
   @param  callback : 확인버튼 클릭후 콜백함수
   @param  objOption : dialog를 띄울때의 조건(JOSN형태. {left:100,top:100,width:100,height:100} 생략가능)
*/
this.fnAlertUda = function(callBack, objOption) {
	var nLeft   = null;
	var nTop    = null;
	var nWidth  = null;
	var nHeight = null;
	var nAlign  = null;
	var nColor  = null;
	var message  = null;
	var messageCn  = null;
	var messageRmk  = null;

	// 옵션이 있다면 값을 적용(주로 left,top,width,height)
	if(objOption)
	{
		nLeft   = objOption.left;
		nTop    = objOption.top;
		nWidth  = objOption.width;
		nHeight = objOption.height;
		nAlign  = objOption.align;
		nColor	= objOption.color;
		message	= objOption.message;
		messageCn	= objOption.messageCn;
		messageRmk	= objOption.messageRmk;
	}
	if(!this.smfIsNull(message) || !this.smfIsNull(messageCn) || !this.smfIsNull(messageRmk)){
		// 오류메시지 초기화
		this.dsErrMsg.clearData();
		this.dsErrMsg.addRow();
		this.dsErrMsg.setColumn(0, "message", this.smfIsNull(message) ? "" : message);
		this.dsErrMsg.setColumn(0, "messageCn", this.smfIsNull(messageCn) ? "" : messageCn);
		this.dsErrMsg.setColumn(0, "messageRmk", this.smfIsNull(messageRmk) ? "" : messageRmk);
	}
	
	this.smfDialog("comm_alertUda" , "comm::comm_alertUda.xfdl", {
		callback: callBack,
		titlebar:true,
		params: {
			procType : "none",
			message  : this.dsErrMsg,
			align    : nAlign,
			color    : nColor
		}
	}
	,nLeft,nTop,nWidth,nHeight
	);
}
]]></Script>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.edtCoaAyr" propid="value" datasetid="dsCoaCtrList" columnid="coaAyr"/>
      <BindItem id="item1" compid="divSearch.form.edtCoaRcritScCd" propid="value" datasetid="dsCoaCtrList" columnid="rcritNm"/>
    </Bind>
  </Form>
</FDL>
