              <Static id="sta00_00_01_01_00" taborder="0" left="29" top="18" height="23" cssclass="sta_WF_InfoTit" text="이용 전 확인해주세요." wordWrap="char" initvalueid="ivStcAccessibilityOn" width="220"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_01" taborder="5" left="30" top="sta00_00_01_01_00:0" height="10" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta00_00_01_01" taborder="1" left="30" top="Static99_00_00_00_00_01_00_00_01_00_01:-3" height="23" cssclass="sta_WF_InfoTxt" text="대입전형자료(학교생활기록부) 온라인 생성신청을 완료한 후에는 생성한 대입전형자료의 변경, 재생성, 대학에 온라인 제공 중지 등은 불가합니다." wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="0"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_01_00" taborder="6" left="30" top="sta00_00_01_01:0" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta00_00_01_01_01" taborder="2" left="30" top="Static99_00_00_00_00_01_00_00_01_00_01_00:-3" height="23" cssclass="sta_WF_InfoTxt" text="학교생활기록부에 이상이 있는 경우, 해당 학교(졸업한 고등학교)로 문의하시기 바랍니다." wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="0"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00" taborder="4" left="0" top="0" height="20" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_01_00_00" taborder="10" left="30" top="sta00_00_01_01_01:0" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta00_00_01_01_01_00" taborder="3" left="30" top="108" height="23" cssclass="sta_WF_InfoTxt_Red" text="본인의 자료를 확인하지 않아서 발생되는 모든 불이익에 대한 책임은 지원자 본인에게 있습니다." wordWrap="char" usedecorate="true" initvalueid="ivStcAccessibilityOn" right="0"/>
