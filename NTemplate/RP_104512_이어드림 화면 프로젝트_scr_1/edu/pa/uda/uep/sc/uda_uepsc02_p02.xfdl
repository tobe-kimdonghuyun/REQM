    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    TEMPLATE
*  @FileName 	uda_uep_sc02_p02.xfdl
*  @Creator 	최재영
*  @CreateDate 	2024.02.27 
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.7.22     	홍길동 	        최초 생성
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 팝업 폼 초기화
	this.smfInitPopup(obj); 
	this.fnSelectCoaCtr(); // 대입기준 조회
	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	this.dsSearch.setColumn(0, "shlCd", this.pv_params.reportOption.shlCd);
	this.divReport.optionReport = this.pv_params.reportOption;
	this.divReport._objForm = this.pv_params.sender;
	// report를 그린다.
	this.divReport.set_url("comm::comp_ozreport.xfdl");
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnSelectCoaCtr = function(){
		// 대입기준 조회
	this.smfSearchService("selectCoaApstNpvsnCeck")
		.run() // 실행		
		.callback(function(callbackParams){ // 콜백
			if(callbackParams.errors) return;
			// 초기화
			this.fnInit();
		});	
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};
]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsCoaCtrList=dsCoaCtrList</Col>
            <Col id="asynctp"/>
            <Col id="url">uda_uep_sc02_000.do</Col>
            <Col id="id">selectCoaApstNpvsnCeck</Col>
          </Row>
          <Row>
            <Col id="id">executeCoaSeleDataAply</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="url">uda_uep_sc02_004.do</Col>
            <Col id="outDatasets">dsSearch=dsSearch dsErrMsg=dsErrMsg</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="coaAyr" type="STRING" size="256"/>
          <Column id="coaRcritScCd" type="STRING" size="256"/>
          <Column id="trprRrno" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="prtOpt" type="STRING" size="256"/>
          <Column id="orgaOtptYn" type="STRING" size="256"/>
          <Column id="shlCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsCoaCtrList" useclientlayout="true">
        <ColumnInfo>
          <Column id="coaAyr" type="STRING" size="256" datapath="대입학년도"/>
          <Column id="coaRcritScCd" type="STRING" size="256" datapath="대입모집구분코드"/>
          <Column id="stuRrno" type="STRING" size="256" datapath="신청자주민등록번호"/>
          <Column id="stuFlnm" type="STRING" size="256" datapath="성명"/>
          <Column id="rcritNm" type="STRING" size="256" datapath="모집구분명"/>
          <Column id="chkYn" type="STRING" size="256"/>
          <Column id="rcritScByFromTo" type="STRING" size="256"/>
          <Column id="rcritScByBgngYmd" type="STRING" size="256" datapath="전형자료확인시작일자"/>
          <Column id="rcritScByEndYmd" type="STRING" size="256" datapath="전형자료확인종료일자"/>
          <Column id="seleDataCrtBgngYmd" type="STRING" size="256"/>
          <Column id="seleDataCrtEndYmd" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsErrMsg" useclientlayout="true">
        <ColumnInfo>
          <Column id="messageCode" type="STRING" size="256"/>
          <Column id="message" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item1" compid="Tab00.Tabpage1.form.div00.form.edt00_00_01_00_00" propid="value" datasetid="dsBaseFieldMap" columnid="trprRrno"/>
