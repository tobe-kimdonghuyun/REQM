              <Static id="sta99_00_00_00_00_01_01" taborder="8" left="0" top="20" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="27" text="30" initvalueid="ivStcAccessibilityOff"/>
