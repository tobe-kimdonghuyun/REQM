        <Div id="div00" taborder="0" left="0" height="1173" cssclass="div_WF_InfoBOX" top="137" text="" initvalueid="ivDivAccessibilityOff" right="0" minwidth="1200" maxwidth="">
          <Layouts>
            <Layout>
              <Static id="staSTitle01" taborder="0" left="30" top="33" height="23" text="대입전형자료(학교생활기록부) 온라인 제공 추진 배경" initvalueid="ivStcAccessibilityOn" right="50" cssclass="sta_WF_SubTit_B18" fittocontents="height"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_01" taborder="16" left="30" top="56" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta00_00_01_01_00_01" taborder="1" left="40" top="Static99_00_00_00_00_01_00_00_01_00_01:-3" height="23" text="학교생활기록부 등 대입 서류 제출에 대한 수험생, 학부모의 불편 해소 및 고교, 대학의 대입업무 부담 완화" cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="40"/>
              <Static id="sta00_00_01_01_00_01_00" taborder="2" left="40" top="sta00_00_01_01_00_01:0" height="23" text="전산화된 학생부 제공으로 성적 자료의 위·변조 및 대입시험 대리 응시 등 방지를 통해 대입전형의 공정성, 신뢰성 강화" cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="40"/>
              <Static id="Static99_00_00_00_00_01_00" taborder="17" left="30" top="sta00_00_01_01_00_01_00:0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff" onclick="div00_Static99_00_00_00_00_01_00_onclick"/>
              <Static id="staSTitle02" taborder="3" left="30" top="Static99_00_00_00_00_01_00:0" height="23" text="2025학년도 대입전형자료(학교생활기록부) 온라인 생성신청 세부사항" initvalueid="ivStcAccessibilityOn" right="51" cssclass="sta_WF_SubTit_B18" fittocontents="height" onclick="div00_sta00_00_01_01_00_01_01_00_onclick"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_01_00" taborder="18" left="30" top="172" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staInfoTxt0201" taborder="4" left="40" top="192" height="23" text="대상: &lt;b v='true'&gt;2004학년도 졸업자('05.2.졸업) ~ 2015학년도 졸업자('16.2.졸업)&lt;/b&gt;" cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="40" usedecorate="true"/>
              <Static id="staInfoTxt0202" taborder="5" left="40" top="staInfoTxt0201:0" height="46" text="방법: 2025학년도 대입 수시·정시모집에 대입전형자료(학교생활기록부) 온라인 제공을 희망하는 경우&#13;&#10;         ‘대입전형자료 온라인 생성신청 시스템(apply.neis.go.kr)’을 통해 대입전형자료 온라인 제공 신청" cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="10" fittocontents="height" wordWrap="char"/>
              <Static id="staInfoTxt0203" taborder="6" left="40" top="staInfoTxt0202:0" height="23" text="생성항목: 고등학교 학교생활기록부 항목 중 대입정책에 따라 대학에 제공되는 내용만 추출" cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="40"/>
              <Static id="staInfoTxt0204" taborder="7" left="40" top="staInfoTxt0203:0" height="23" text="생성신청기간: &lt;b v='true'&gt;(수시) 2024.9.9.(월)~9.13.(금), (정시) 2024.12.31.(화)~2025.1.3.(금)&lt;/b&gt;" cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="40" usedecorate="true"/>
              <Static id="staInfoTxt0205" taborder="8" left="40" top="staInfoTxt0204:0" height="23" text="수신현황조회: 대입전형자료 온라인 생성신청을 완료한 경우 지원한 대학의 자료수신 현황조회 가능" cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="40"/>
              <Static id="Static99_00_00_00_00_01_01_00_00" taborder="19" left="30" top="staInfoTxt0205:0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta00_00_01_01_00_01_01_00_00" taborder="9" left="30" top="Static99_00_00_00_00_01_01_00_00:0" height="23" text="대입전형자료(학교생활기록부) 온라인 생성신청시 유의사항" initvalueid="ivStcAccessibilityOn" right="51" cssclass="sta_WF_SubTit_B18" fittocontents="height"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_01_00_00" taborder="21" left="30" top="sta00_00_01_01_00_01_01_00_00:0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta00_00_01_01_00_01_00_00_00_02" taborder="10" left="40" top="Static99_00_00_00_00_01_00_00_01_00_01_00_00:0" height="23" text="대입전형자료 온라인 생성신청을 완료한 후에는 생성한 대입전형자료의 변경, 재생성, 대학에 온라인 제공 중지 등은 불가함" cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="40"/>
              <Static id="sta00_00_01_01_00_01_00_00_00_02_00" taborder="11" left="40" top="sta00_00_01_01_00_01_00_00_00_02:0" height="23" text="수시모집에 대입전형자료 온라인 생성신청을 완료하였더라도, 정시모집에 대입전형자료 온라인 제공을 희망하는 경우 정시모집 생성신청기간에 다시 생성신청을 완료해야 함" cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="40"/>
              <Static id="sta00_00_01_01_00_01_00_00_00_02_00_01" taborder="12" left="40" top="sta00_00_01_01_00_01_00_00_00_02:25" height="100" text="학교생활기록부의 정정이 필요한 경우, 졸업한 고등학교에 문의하기 바람. &#13;&#10;대입전형자료 온라인 생성신청 기간 내에 학교생활기록부 정정이 완료되는 경우 대입전형자료(학교생활기록부)에서 정정사항의 반영 여부를 확인할 수 있음. &#13;&#10;다만, 대입전형자료 온라인 생성신청 기간 내에 학교생활기록부 정정이 완료되지 않는 경우 대입전형자료(학교생활기록부)에 정정사항이 반영되지 않으므로 &#13;&#10;정정하기 전의 대입전형자료(학교생활기록부)를 온라인 생성신청하거나 학교생활기록부Ⅱ 민원서류 출력물을 대학이 정한 기간 내에 직접 제출해야 함.&#13;&#10;대입전형자료 온라인 생성신청을 완료한 이후, 학교생활기록부 정정이 이루어진 경우 대입전형자료 온라인 생성신청 시스템을 활용한 재생성은 불가함." cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="41" fittocontents="height"/>
              <Static id="sta00_00_01_01_00_01_00_00_00_02_00_00" taborder="13" left="40" top="sta00_00_01_01_00_01_00_00_00_02_00_01:2" height="23" text="&lt;fc v='#d32850'&gt;&lt;b v='true'&gt;대입전형자료 온라인 제공을 희망하지 않거나 온라인 생성신청을 완료하지 않은 경우 학교생활기록부Ⅱ 민원서류 출력물을 대학이 정한 기간 내에 직접 제출해야 함&lt;/b&gt;&lt;/fc&gt;" cssclass="sta_WF_InfoTxt" initvalueid="ivStcAccessibilityOn" right="40" wordWrap="char" usedecorate="true"/>
              <Static id="Static99_00_00_00_00_01_01_00_00_00" taborder="20" left="30" top="sta00_00_01_01_00_01_00_00_00_02_00_00:0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staSTitle03" taborder="14" left="30" top="Static99_00_00_00_00_01_01_00_00_00:10" height="23" text="졸업생 대입전형자료 온라인 제공 서비스 흐름도" initvalueid="ivStcAccessibilityOn" right="51" cssclass="sta_WF_SubTit_B18" fittocontents="height"/>
              <ImageViewer id="img00" taborder="15" left="40" top="staSTitle03:17" height="440" image="url('theme://images/img_UDA_guide.png')" width="1059" initvalueid="ivImgAccessibilityOn" accessibilitylabel="졸업생 대입전형자료 온라인 제공 서비스 흐름도" text="" imagealign="center middle" stretch="fixaspectratio" border="0px none"/>
            </Layout>
            <Layout name="Layout0">
              <ImageViewer id="img00" left="10.00%" top="staSTitle03:20" right="10.00%" stretch="fixaspectratio" text="" imagealign="center top" height="1200" image="url('theme://images/img_UDA_guide_M.png')" minheight="" maxwidth="" minwidth="450" fittocontents="height" padding="20px" taborder="15"/>
              <Static id="sta00_00_01_01_00_01" cssclass="sta_WF_InfoTxt" left="30" top="Static99_00_00_00_00_01_00_00_01_00_01:10" right="50" height="45" fittocontents="height" text="학교생활기록부 등 대입 서류 제출에 대한 수험생, 학부모의 불편 해소 및 고교, 대학의 대입업무 부담 완화" taborder="1"/>
              <Static id="sta00_00_01_01_00_01_00" cssclass="sta_WF_InfoTxt" left="30" top="sta00_00_01_01_00_01:0" right="40" height="45" fittocontents="height" taborder="2" text="전산화된 학생부 제공으로 성적 자료의 위·변조 및 대입시험 대리 응시 등 방지를 통해 대입전형의 공정성, 신뢰성 강화"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_01" left="30" top="staSTitle01:4" height="20" right="30" text="20" taborder="16"/>
              <Static id="staInfoTxt0201" left="40" top="Static99_00_00_00_00_01_00_00_01_00_01_00:10" height="23" right="40" cssclass="sta_WF_InfoTxt" fittocontents="height" taborder="4"/>
              <Static id="staInfoTxt0202" left="40" top="staInfoTxt0201:0" height="23" right="40" cssclass="sta_WF_InfoTxt" fittocontents="height" text="방법: 2025학년도 대입 수시·정시모집에 대입전형자료(학교생활기록부) 온라인 제공을 희망하는 경우  ‘대입전형자료 온라인 생성신청 시스템(apply.neis.go.kr)’을 통해 대입전형자료 온라인 제공 신청" taborder="5"/>
              <Static id="staInfoTxt0203" left="40" top="staInfoTxt0202:0" height="23" right="40" text="생성항목: 고등학교 학교생활기록부 항목 중 대입정책에 따라 대학에 제공되는 내용만 추출" cssclass="sta_WF_InfoTxt" fittocontents="height" taborder="6"/>
              <Static id="sta00_00_01_01_00_01_00_00_00_02" left="40" top="sta00_00_01_01_00_01_01_00_00:20" height="23" right="40" fittocontents="height" taborder="10"/>
