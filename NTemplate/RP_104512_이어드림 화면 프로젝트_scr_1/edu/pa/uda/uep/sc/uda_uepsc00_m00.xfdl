    <Objects>
      <Dataset id="dsCoaCtrList" useclientlayout="true">
        <ColumnInfo>
          <Column id="coaAyr" type="STRING" size="256" datapath="대입학년도"/>
          <Column id="coaRcritScCd" type="STRING" size="256" datapath="대입모집구분코드"/>
          <Column id="stuRrno" type="STRING" size="256" datapath="신청자주민등록번호"/>
