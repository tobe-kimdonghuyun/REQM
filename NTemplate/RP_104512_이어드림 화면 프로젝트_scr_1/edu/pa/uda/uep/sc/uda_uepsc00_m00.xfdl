/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::cm_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(this);

	this.fv_param = this.smfGetFormParams();
	var menuId = this.fv_param.menu;
	
	this.fnSearch();
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 대입전형자료 수신대학 현황조회
*/
this.fnSearch = function(){

	// 대입전형자료 조회
	this.smfSearchService("selectCoaApstNpvsnCeck")
		.run() // 실행
		.callback(function(callbackParams){ // 콜백
			if(callbackParams.errors) return;
			this.fnListCallback();
		});
}

/**
 * @description 대입전형자료 확인 및 제출 자료 조회 callback
*/
this.fnListCallback = function(){
	if(this.dsCoaCtrList.getColumn(0, "rcritNm") != null && this.dsCoaCtrList.getColumn(0, "rcritNm") != "undefined"){
		//this.div00.form.staSTitle02.set_text(this.dsCoaCtrList.getColumn(0, "coaAyr")+"학년도 대입전형자료(학교생활기록부) 온라인 생성신청 세부사항");
		//this.div00.form.staInfoTxt0201.set_text("대상: <b v='true'>"+this.dsCoaCtrList.getColumn(0, "aplcnEndAyr")+"학년도 졸업자('"+this.lpad(parseInt(this.dsCoaCtrList.getColumn(0, "aplcnEndAyr")) - 1999, "0", 2)+".2.졸업)~"+this.dsCoaCtrList.getColumn(0, "aplcnBgngAyr")+"학년도 졸업자('"+this.lpad(parseInt(this.dsCoaCtrList.getColumn(0, "aplcnBgngAyr")) - 1999, "0", 2)+".2.졸업)</b>");
		//this.div00.form.staInfoTxt0202.set_text("방법: "+this.dsCoaCtrList.getColumn(0, "coaAyr")+"학년도 대입 수시·정시모집에 대입전형자료(학교생활기록부) 온라인 제공을 희망하는 경우 \n‘대입전형자료 온라인 생성신청 시스템(apply.neis.go.kr)’을 통해 대입전형자료 온라인 제공 신청");
	} else {
		this.div00.form.staCoaDate.set_text("신청 기간이 아닙니다.");
	}
}
