    <Script type="xscript5.1"><![CDATA[/**
*  대국민 대입전형자료(학교생활기록부) 온라인 생성신청 서비스 로그인
*  @MenuPath    대입전형자료(학교생활기록부) 온라인 생성신청 서비스 로그인
*  @FileName 	uds_uepcm00_m00.xfdl 
*  @Creator     최재영
*  @CreateDate 	2022.06.21
*  @Desction    본인인증
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
*  2024.01.30           최재영                 최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::cm_script.xjs"
include "lib::uds_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.fv_param;
this.mberNm;
this.mberRrn;
this.selectedTab = "1";

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frameLogin_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);
	this.fv_param = this.smfGetFormParams();
	
	if(this.smfIsMobile()){
		this.selectedTab = "3";
		this.divLogin1.form.btnLogin.set_text("간편인증");
		this.divLogin1.form.edtKornFlnm.set_visible(false);
		this.divLogin1.form.edtTrprRrno1.set_visible(false);
		this.divLogin1.form.edtTrprRrno2.set_visible(false);
		this.divLogin1.form.staTrprRrno.set_visible(false);
		//this.divLogin1.form.staTransKey.set_visible(false);
		this.divLogin1.form.staLoginMemberNotice.set_visible(false);
		this.divLogin1.form.divSimpleLogin.set_visible(true);
		this.divLogin1.form.staSimpleLogin01.set_visible(true);
		this.divLogin1.form.staSimpleLogin02.set_visible(true);
		
		this.btn01.set_cssclass("btn_Login_TabCase_M");
		this.btn02.set_cssclass("btn_Login_TabCase_M");
		this.btn03.set_cssclass("btn_Login_TabCaseS_M");
	}
	
	//가상키보드 세팅
 	var objOption = {
 		target : this.divLogin1.form.edtTrprRrno2, //대상 Edit 컴포넌트 [필수]
 		targetKey : this.divLogin1.form.staTransKey, //Edit와 쌍으로 있는 마우스입력 체크박스(static) [필수]
 		bshow :  true, //  마우스입력 체크박스 보이기 여부 (default = false) [선택]
 		maxLength : 7,
 		kbdType : "number", //라온 키보드 타입 number/qwerty (default = qwerty)[선택)
 	}
	this.smfInitTranskey(objOption);
	this.fnSelectCoaCtr();	//기준정보 조회
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd == -1) return;
};

/**
 * 팝업의 콜백함수 지정한다 (공동인증서)
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	var sLog = "";
	var obj = sender.divLogin1.form;
	if(e.result){
		var sData = JSON.parse(e.data);
		
		if(sData.vidResult == "true"){
			var subjectDnCn = sData.subjectDn;
			if(subjectDnCn.indexOf(mberNm) != -1){  //이름이 포함되어 있을때
				this.dsSearch.setColumn(0, "trprRrno", mberRrn);
				this.dsSearch.setColumn(0, "kornFlnm", mberNm);
				this.fnCallbackConfirmAuth(obj);
			}else{
				this.smfLiteralAlert("현재 선택하신 인증서의 성명과 입력하신 성명이 일치하지 않습니다.");
			}
		}else if(sData.vidResult.indexOf("VID") != -1){ 
			this.smfLiteralAlert("입력된 정보와 인증서 정보가 일치하지 않습니다. 다시 한 번 확인 해 주세요.");
		}else{
			this.smfLiteralAlert("인증서 인증에 에러가 발생했습니다. 관리자에게 문의하세요.");
		}
	} else {
		var sData = e.data;
		var arrData = sData.split(":");
		if(arrData[0].trim()=="800000") {  // 유저가 팝업을 강제 종료한 경우
			sLog += "처리결과 : [에러(유저강제종료)]\n";
			sLog += "data : ["+sData+"]";
			trace(sLog);			
		} else {
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+sData+"]";
			trace(sLog);			
		}
	}
};

/**
 * 팝업의 콜백함수 지정한다 (금융인증서)
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnFinAuthPopupCallback = function(e, sender){
	trace("===>this.fnPopupCallback : popup callback");
	var sLog = "";
	var obj = sender.divLogin1.form;
	
	if(e.result){
		var sData = e.data;
		sLog += "처리결과 : [성공]\n";
		sLog += "data : ["+sData+"]";
		trace(sLog);
		
		var subjectDn = JSON.parse(sData).certificate.subject_dn.toString();
		var dnNm = subjectDn.substring(3, subjectDn.indexOf("("))
		var vidResult = JSON.parse(sData).vidresult.toString();
		
		if(vidResult == "true"){
			mberNm = obj.edtKornFlnm.value;
			if(dnNm != mberNm){
				this.smfLiteralAlert("현재 선택하신 인증서의 성명과 입력하신 성명이 일치하지 않습니다.");
			} else {
				this.dsSearch.setColumn(0, "trprRrno", mberRrn);
				this.dsSearch.setColumn(0, "kornFlnm", mberNm);
				this.fnCallbackConfirmAuth(obj);
			}
		}else if(vidResult == "false"){
			this.smfLiteralAlert("입력된 정보와 인증서 정보가 일치하지 않습니다. 다시 한 번 확인 해 주세요.");
		}else{
			this.smfLiteralAlert("인증서 인증에 에러가 발생했습니다. 관리자에게 문의하세요.");
		}
	}else{
		var sData = e.data;
		var arrData = sData.split(":");
		
		if(arrData[0].trim()=="800000"){  // 유저가 팝업을 강제 종료한 경우
			sLog += "처리결과 : [에러(유저강제종료)]\n";
			sLog += "data : ["+sData+"]";
			trace(sLog);		
		}else{
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+sData+"]";
			trace(sLog);		
		}
	}
};

/**
 * 팝업의 콜백함수 지정한다 (간편인증)
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnSimpleAuthPopupCallback = function(e, sender){
	trace("===>this.fnSimpleAuthPopupCallback : popup callback");
	var sLog = "";
	// console.log("this.fnSimpleAuthPopupCallback : popup callback - e:" + e);
	// console.log("this.fnSimpleAuthPopupCallback : popup callback - e.result:" + e.result);
	// console.log("this.fnSimpleAuthPopupCallback : popup callback - e.data:" + e.data);
	if(e.result){
		// var sData = JSON.parse(e.data);

		if(this.smfIsNull(e.data)){
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+e.data+"]";
			// console.log(sLog);
			this.smfLiteralAlert("본인 인증 인증에 실패 하였습니다..");
			return;
		}
		
		sLog += "처리결과 : [성공]\n";
		//sLog += "data : ["+sData+"]";	
		// console.log(sLog);
		
		//this.dsSearch.setColumn(0, "trprRrno", mberRrn);
		//this.dsSearch.setColumn(0, "kornFlnm", mberNm);
		this.dsSearch.setColumn(0, "jwt", e.data);
		
		// 서비스 객체 생성
		this.smfSearchService("selectSessionInfoBySimpleAuth")
			.run()	// 실행
			// 콜백
			.callback(function(callbackParams){
				if(callbackParams.errors) return;
				
				this.smfSetSessionDataset(this.dsUdaSession);
				
				//로그인 후 접속이력
				this.smfSendLoginLog(this,'LG005');
				
				//세션저장 후 처리
				this.fnSelectSession(obj);
			});
	}
}

/************************************************************************************************
 * 사용자 FUNCTION 영역
/************************************************************************************************

/**
 * @description 대입기준 조회
*/
this.fnSelectCoaCtr = function(){
	// 오류메시지 초기화
	this.dsErrMsg.clearData();
	
	this.dsSearch.setColumn(0, "tsCetCd", window.location.search.substring(1).split("=")[0] == "tsCetCd" ? window.location.search.substring(1).split("=")[1] : "");
	
	// 대입기준 조회
	this.smfSearchService("selectCoaCtr")
		.run() // 실행
		.callback(function(callbackParams){ // 콜백
			if(callbackParams.errors) return;
			
			if(this.dsErrMsg.getRowCount() > 0){
				// 오류메시지 처리
				this.smfAlert(this.dsErrMsg.getColumn(0, 'message'), function(){
					var objFrame = this.getOwnerFrame();
					if(objFrame.form.divAll){
						var sMainUrl = objFrame.form.fv_mainformUrl;
						if(!this.smfIsNull(sMainUrl)) objFrame.form.fnSetMainpage(sMainUrl); // 메인URL로 이동한다.
					}
				});
			} else {
				var finYn = this.dsCoaCtrList.getColumn(0,"finYn");  // 신청일자체크
				var chkYn = this.dsCoaCtrList.getColumn(0,"chkYn");
				if(finYn == "N" && chkYn == "Y"){
					this.fnAlertUda(function(){
							var objFrame = this.getOwnerFrame();
							if(objFrame.form.divAll){
								var sMainUrl = objFrame.form.fv_mainformUrl;
								if(!this.smfIsNull(sMainUrl)) objFrame.form.fnSetMainpage(sMainUrl); // 메인URL로 이동한다.
							}
						}, {message : "대입전형자료(학교생활기록부)\n온라인 생성신청 기간이 아닙니다.",
							messageCn : "\n\n- 수시 생성신청 기간: 2024. 9. 9. ~ 2024. 9.13. \n- 정시 생성신청 기간: 2024.12.31. ~ 2025. 1. 3.\n\n해당 기간에만 이용하실 수 있습니다.",
							messageRmk : "",
							color : "#1E5DF2"}
					);
				}
			}
		});	// 대입기준 조회
}

/**
 * @description 실명인증 후 세션생성
*/
this.fnCallbackConfirmAuth = function(obj){

	//세션에 정보담기
	this.smfSearchService("selectSessionInfo")
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		
			this.smfSetSessionDataset(this.dsUdaSession);
			
			/* LG002:NPKI /  LG009:금융인증서 /  LG005: 간편인증 */
			if(this.selectedTab == "1"){ //NPKI
				var sLgnTypCd = "LG002";
			}else if(this.selectedTab == "2"){ //금융인증서
				var sLgnTypCd = "LG009";
			}else if (this.selectedTab == "3"){ // 간편인증 
				sLgnTypCd ='LG005';
			}
			
			//로그인 후 접속이력
			this.smfSendLoginLog(this,sLgnTypCd);
			
			//세션저장 후 처리
			this.fnSelectSession(obj);
		});	
};
/**
 * @description 세션 저장 후 처리
*/
this.fnSelectSession = function(obj){
	//topframe에 세션타임과 로그아웃 버튼
	this.getOwnerFrame().form.divTop.form.fnLoginAfter();
	
	var sUrl = ""
	if(this.fv_param.menuId == "4000"){ //자료생성 및 신청
		sUrl = "pa_uda_uep_sc::uda_uepsc02_m00.xfdl"
	}else if(this.fv_param.menuId == "6000"){ //대입전형자료 수신대학 현황조회
		sUrl ="pa_uda_uep_sc::uda_uepsc04_m00.xfdl"
	}else if(this.fv_param.menuId == "8000"){ //마이페이지
		sUrl ="pa_uda_uep_mp::uda_uepmp00_m00.xfdl"
	}else{
		//메뉴아이디 없을땐 (상단바 로그인) 메인화면으로 이동
		var objFrame = this.getOwnerFrame();
		
		if(objFrame.form.divAll)
		{
			// Top 에 값을 세팅
			var sMainUrl = objFrame.form.fv_mainformUrl;
			
			// 메인URL로 이동한다.
			if(!this.smfIsNull(sMainUrl)){
				objFrame.form.fnSetMainpage(sMainUrl);	
			}
		}
		
		return false;
	}
	var params = { kornFlnm : mberNm
				 , menuId   : this.fv_param.menuId
				 };
					
	this.smfSetWorkPage(sUrl, params);
}

this.fnTransKey = function(obj)
{	
	var sVal    = "";
	var arrComp = [obj];  //대상 Edit component List: array [필수]
	
	if(!this.smfIsMobile()){
		// 키보드보안 적용여부
		var sRtnVal = this.smfGetValueTranskey(obj);
		
		if(sRtnVal == "transkey"){	//선택
			var sVal = this.smfGetEncDataTranskey(arrComp);
	
			//전달받은 파라미터 데이터셋에 담기
			this.smfConvRaonDataToDs(this.dsRaonKeyData,arrComp,sVal);
			this.dsRaonKeyData.setColumn(0, 'tk_col_check', "transkey");
			
		}else if(sRtnVal == "e2e"){ //미선택
			sVal= obj.value;
		}
	}else{
		sVal = this.smfGetEncDataTranskey(arrComp);
		//전달받은 파라미터 데이터셋에 담기
		this.smfConvRaonDataToDs(this.dsRaonKeyData,arrComp,sVal);
		this.dsRaonKeyData.setColumn(0, 'tk_col_check', "transkey");
	}
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// 공동인증서/금융인증서/간편인증 로그인 버튼 클릭
this.btnLogin_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.selectedTab == "3"){
		// 오픈방식을 설정한다.
		var sOpenType   = "ssn";    // [선택] Open방식 -  "birth"(default) : 생년월일 , "ssn" : 주민등록번호
		var sActionType = "instl";  // [선택] 간편인증 동작방식 -  "trans" : 중계형(온라인채용/검정고시) , "instl" : 설치형(교육비원클릭/그외)
									// 미지정시 subSys를 체크하여 설정. 미지정을 권장
		var objParam = {objForm:this, popupcallback :this.fnSimpleAuthPopupCallback, openType: sOpenType, actionType: sActionType };
		this.smfExecSimpleAuth(objParam);
	} else {
		//가상키보드 사용시 edtTrprRrno2 -> userproperty(userRaon:Y , e2e) / tabstop : false /  this.smfInitTranskey :옵션 설정
		//(가상키보드적용시)
		if(this.chk(obj)){ //빈칸체크
			//@KBR 입력된 참여번호 가져오기
			this.fnTransKey(obj.parent.edtTrprRrno2);
			this.dsRaonKeyData.setColumn(0, "trprRrno1", obj.parent.edtTrprRrno1.value);
			
			this.smfSearchService("selectKeyDec")
				.run()
				.callback(function(callbackParams){
					if(callbackParams.errors) return;
					
					mberNm = obj.parent.edtKornFlnm.value;
					mberRrn = this.dsMain.getColumn(0,"encRrno"); //암호화된 값
					
					var sRrno = obj.parent.edtTrprRrno1.value + this.dsMain.getColumn(0,"trprRrno2");
					
					if(this.selectedTab == "1"){
						if(this.udsfIsDevMode() || this.checkRrno(sRrno,obj)){
							var sConnectBaseUrl = window.location.protocol + "//" + window.location.host;

							var sInitUrl  = sConnectBaseUrl + "/cmc_fcm_es01_003.do";
							var sLoginUrl = sConnectBaseUrl + "/cmc_fcm_es01_004.do";

							var userId = sRrno;
							
							var objLoginInfo = { initUrl  : sInitUrl    // init시 사용하는 서비스명(앞에 "/"을 붙일 것)
											   , loginUrl : sLoginUrl   // login시 사용하는 서비스명(앞에 "/"을 붙일 것)
											   , userId   : userId
											   };   // 생략가능

							var objParam = {objForm:this, popupcallback :this.fnPopupCallback, loginInfo:objLoginInfo};
							this.smfExecNpkiAuth(objParam);
						}
					}else if(this.selectedTab == "2"){					
						// 주민번호 전체 체크
						if(this.udsfIsDevMode() || this.checkRrno(sRrno,obj)){						
							var objParam = {objForm:this, popupcallback :this.fnFinAuthPopupCallback, rrno : sRrno};
							this.smfExecFinAuth(objParam);
						}
					}
				});	 
		}
	}
}

