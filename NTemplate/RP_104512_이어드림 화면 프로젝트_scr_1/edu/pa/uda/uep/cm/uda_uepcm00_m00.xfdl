this.chk = function(obj){
	if( obj.parent.parent.name == "divLogin1" && this.smfIsNull(obj.parent.edtKornFlnm.value)){
		this.smfLiteralAlert("성명을 입력해주세요.");
		obj.parent.edtKornFlnm.setFocus();
		return false;
	}
	
	if( obj.parent.parent.name == "divLogin2" && this.smfIsNull(obj.parent.edtKornFlnm.value)){
		this.smfLiteralAlert("성명을 입력해주세요.");
		obj.parent.edtKornFlnm.setFocus();
		return false;
	}

	if(this.smfIsNull(obj.parent.edtTrprRrno1.value)){
		this.smfLiteralAlert("주민등록번호 앞자리를 입력해주세요.")
		obj.parent.edtTrprRrno1.setFocus();
		return false;
	}

	return true;
}

//간편인증 로그인
this.btnSimpleLogin_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 오픈방식을 설정한다.
	var sOpenType   = "ssn";    // [선택] Open방식 -  "birth"(default) : 생년월일 , "ssn" : 주민등록번호
	var sActionType = "instl";  // [선택] 간편인증 동작방식 -  "trans" : 중계형(온라인채용/검정고시) , "instl" : 설치형(교육비원클릭/그외)
							    // 미지정시 subSys를 체크하여 설정. 미지정을 권장
	var objParam = {objForm:this, popupcallback :this.fnSimpleAuthPopupCallback, openType: sOpenType, actionType: sActionType };
	this.smfExecSimpleAuth(objParam);
};

/**
* 주민번호 체크
*/
this.checkRrno = function(applpRrno, obj) {

	if(obj.parent.edtTrprRrno1.value.length != 6){
		obj.parent.edtTrprRrno1.setFocus();
		this.smfLiteralAlert("주민등록번호(외국인등록번호)를 바르게 입력해주세요.")
		return false;
	}
	
	// 주민등록번호 자리수가 맞는가를 확인
	if (applpRrno.length != 13){
		this.smfLiteralAlert("주민등록번호(외국인등록번호)를 바르게 입력해주세요.")
		return false;
		
	}
	
	// 성별 (외국인 포함)
	var chr6 = applpRrno.charAt(6);

	if((chr6 == '5' || chr6 == '6' || chr6 == '7' || chr6 == '8')){
		if(!this.smfIsForeignNo(applpRrno)){
		
			obj.parent.edtTrprRrno2.setFocus();
			this.smfLiteralAlert("올바른 외국인등록번호를 입력해주세요.")
			return false;
		}
	
	}else{
		if(!this.smfIsRsrNoOld(applpRrno)){
			obj.parent.edtTrprRrno2.setFocus();
			this.smfLiteralAlert("올바른 주민등록번호를 입력해주세요.")
			return false;
		}	
	}

	return true;
}

// 사전점검 임시로그인 활성화
this.img00_00_onclick = function(obj:nexacro.ImageViewer,e:nexacro.ClickEventInfo)
{
	if(e.ctrlkey && e.shiftkey && e.altkey){
		this.divLogin1.form.edtTestLogin.set_visible(true);
		this.divLogin1.form.btnTestLogin.set_visible(true);
		this.dsSearch.setColumn(0, "tsCetCd", "");
	}
};

// 사전점검 임시로그인
this.divLogin1_btnTestLogin_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.chk(obj)){
		var transKey = this.fnTransKey(obj.parent.edtTrprRrno2);
		this.dsRaonKeyData.setColumn(0,"trprRrno1",obj.parent.edtTrprRrno1.value);
		
		this.smfSearchService("selectKeyDec")
			.run()
			.callback(function(callbackParams){
				if(callbackParams.errors) return;
				
				var sRrno = obj.parent.edtTrprRrno1.value + this.dsMain.getColumn(0,"trprRrno2");
				 
				if(this.udsfIsDevMode() || this.checkRrno(sRrno,obj)){
					mberNm = obj.parent.edtKornFlnm.value;
					mberRrn = this.dsMain.getColumn(0,"encRrno");
					
					this.dsSearch.setColumn(0, "trprRrno", this.dsMain.getColumn(0,"encRrno"));
					this.dsSearch.setColumn(0, "kornFlnm", mberNm);
					this.dsSearch.setColumn(0, "tsCetYn", "Y");
					
					//세션에 정보담기
					this.smfSearchService("selectSessionInfo")
						.run()
						// 콜백
						.callback(function(callbackParams){
							if(callbackParams.errors) return;
							//세션에 담기
							this.smfSetSessionDataset(this.dsUdaSession);
							
							this.fnSelectSession(obj);										
						});
					this.dsSearch.setColumn(0, "tsCetYn", "");
				}
			});	 	
	}
};


/*
 * @description 대입전형자료 알림창
   @param  message : 메시지 dataSet
   @param  callback : 확인버튼 클릭후 콜백함수
   @param  objOption : dialog를 띄울때의 조건(JOSN형태. {left:100,top:100,width:100,height:100} 생략가능)
*/
this.fnAlertUda = function(callBack, objOption) {
	var nLeft   = null;
	var nTop    = null;
	var nWidth  = null;
	var nHeight = null;
	var nAlign  = null;
	var nColor  = null;
	var message  = null;
	var messageCn  = null;
	var messageRmk  = null;

	// 옵션이 있다면 값을 적용(주로 left,top,width,height)
	if(objOption)
	{
		nLeft   = objOption.left;
		nTop    = objOption.top;
		nWidth  = objOption.width;
		nHeight = objOption.height;
		nAlign  = objOption.align;
		nColor	= objOption.color;
		message	= objOption.message;
		messageCn	= objOption.messageCn;
		messageRmk	= objOption.messageRmk;
	}
	if(!this.smfIsNull(message) || !this.smfIsNull(messageCn) || !this.smfIsNull(messageRmk)){
		// 오류메시지 초기화
		this.dsErrMsg.clearData();
		this.dsErrMsg.addRow();
		this.dsErrMsg.setColumn(0, "message", this.smfIsNull(message) ? "" : message);
		this.dsErrMsg.setColumn(0, "messageCn", this.smfIsNull(messageCn) ? "" : messageCn);
		this.dsErrMsg.setColumn(0, "messageRmk", this.smfIsNull(messageRmk) ? "" : messageRmk);
	}
	
	this.smfDialog("comm_alertUda" , "comm::comm_alertUda.xfdl", {
		callback: callBack,
		titlebar:true,
		params: {
			procType : "none",
			message  : this.dsErrMsg,
			align    : nAlign,
			color    : nColor
		}
	}
	,nLeft,nTop,nWidth,nHeight
	);
}
]]></Script>
    <Objects>
      <Dataset id="dsService">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">selectSessionInfo</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
