        <Button id="btnClose" taborder="2" top="0" width="30" height="30" cssclass="btn_Pop_close_W" initvalueid="ivBtnAccessibilityButton" right="-81" visible="false" onclick="btnClose_onclick"/>
      </Layout>
      <Layout name="Layout0" screenid="mobile,tablet" width="640" height="950" mobileorientation="portrait" type="default" background="rgba(0,0,0,0.40)">
