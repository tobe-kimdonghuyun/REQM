          <Column id="shlCrseScNm" type="STRING" size="256"/>
          <Column id="shlKndScCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsApiResponseList" useclientlayout="true">
        <ColumnInfo>
          <Column id="code" type="STRING" size="256" description="연계상태값"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsPageInfo" useclientlayout="true">
        <ColumnInfo>
          <Column id="pageIndex" type="INT" size="256"/>
          <Column id="pageSize" type="INT" size="256"/>
          <Column id="totalCount" type="INT" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="pageIndex">1</Col>
            <Col id="pageSize">8</Col>
            <Col id="totalCount">1</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsChldList" useclientlayout="true">
        <ColumnInfo>
          <Column id="tadStuInvlNo" type="STRING" size="256"/>
          <Column id="stuFlnm" type="STRING" size="256"/>
          <Column id="grd" type="STRING" size="256"/>
          <Column id="clsNm" type="STRING" size="256"/>
          <Column id="clsNo" type="STRING" size="256"/>
          <Column id="schpaOflEvlYn" type="STRING" size="256"/>
          <Column id="schpaCetNo" type="STRING" size="256"/>
          <Column id="eduActPtptRspnsYn" type="STRING" size="256"/>
          <Column id="chldInfoScCd" type="STRING" size="256"/>
          <Column id="schorStuDpcnYn" type="STRING" size="256"/>
          <Column id="exmplShlYn" type="STRING" size="256"/>
          <Column id="chldInfoScCdNm" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 
*  @FileName 	eds_tados04_t01.xfdl 
*  @Creator 	kangjihye
*  @CreateDate 	2023.02.08
*  @Desction    교육설문 - 공지사항
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.02.08          Kangjihye                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
 
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 this.fv_param;	// 파라메터 세팅
 this.fv_evlTrprId;
 this.btn_param;
 this.fv_evlKndScCd="3";
 this.fv_shlKndgrScCd = "2";
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnonload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.fnSetcompSizeP();
	// 폼 초기화
	this.smfInitForm(obj);
	var sDate = new Date();
	
	//검사연도 세팅
	var sYear  = sDate.getFullYear().toString();
	// 전달받은 파라메터 값 세팅
	this.fv_param = this.smfGetFormParams();
	
	this._cddcCd = this.fv_param.cddcCd;
	this._cddcNm = this.fv_param.cddcNm;
	if ( this.smfIsMobile() ) {
		this.divTop.form.fnSetPtptPrd(this._cddcNm);
	}
	this.fv_evlKndScCd = this.fv_param.evlKndScCd;
	
	this.dsSearch.setColumn(0, "cddcCd", this._cddcCd);
	this.dsPreset.loadXML(this.fv_param.dataset);
	this.dsPreset1.loadXML(this.fv_param.dataset1);	
	this.dsSearch.loadXML(this.fv_param.schdataset);
	
	if( this.fv_evlKndScCd == "3" ){
		this.dsChldList.loadXML(this.fv_param.dataset2);
	}
	
	
	//스크롤바 갱신
	this.smfResetScroll(this);
	
	this.fnListSelect();
};

/*만족도조사*/
this.div00_div01_btnSurvey_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
		var param = {
			cddcCd : this._cddcCd,
			cddcNm : this._cddcNm,
			shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd") ,
			evlKndScCd : this.fv_evlKndScCd,
			dataset: this.dsPreset.saveXML(),
			dataset1: this.dsPreset1.saveXML(),	
			dataset2 : this.dsChldList.saveXML(),
			schdataset :  this.dsSearch.saveXML(),
		};
		this.smfSetWorkPage("pa_ktd_tad_os::ktd_tados07_m01.xfdl", param, false);
};

/*교원능력개발평가*/
this.div00_div01_btnInform_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
		var param = {
			cddcCd : this._cddcCd,
			cddcNm : this._cddcNm,
			shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd") ,
			evlKndScCd : this.fv_evlKndScCd,
			dataset: this.dsPreset.saveXML(),
			dataset1: this.dsPreset1.saveXML(),	
			dataset2 : this.dsChldList.saveXML(),
			schdataset :  this.dsSearch.saveXML(),
		};
		this.smfSetWorkPage("pa_ktd_tad_os::ktd_tados09_m01.xfdl", param, false);
};



/************************************************************************
 * 검색
 ************************************************************************/
this.div00_div00_div05_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnListSelect(obj, e);
};

this.fnListSelect = function (obj, e) {

	this.dsSearch.setColumn(0,"instCd",this._cddcCd);
	
	//학교유치원구분코드 1:학교 2:유치원
	this.dsSearch.setColumn(0,"shlKndgrScCd" 	, "2" );
							   
	this.dsSearch.setColumn(0,"evlKndScCd"		, this.fv_evlKndScCd );
	
	var tadStuInvlNo = this.dsPreset.getColumn(0,"tadStuInvlNo");
	if( this.isNotNil(tadStuInvlNo)){
		this.dsSearch.setColumn(0,"tadStuInvlNo",tadStuInvlNo);
		this.dsSearch.setColumn(0,"evlPaptId"	,tadStuInvlNo);
	}
	
	var shlCrseScCd =  this.dsPreset1.getColumn(0,"shlCrseScCd");
	if( this.isNotNil(shlCrseScCd)){
		this.dsSearch.setColumn(0,"shlCrseScCd",shlCrseScCd);
	}
	
	var shlCd =  this.dsPreset1.getColumn(0,"shlCd");
	if( this.isNotNil(shlCd)){
		this.dsSearch.setColumn(0,"shlCd",shlCd);
	}
	
	//srchKw_검색어 셋팅
	this.dsSearch.setColumn(0, "srchKw", this.div00.form.div00.form.div05.form.edtSearch.text);
	//srchCond_검색유형 셋팅
	this.dsSearch.setColumn(0, "srchCond", this.div00.form.div00.form.div05.form.cmbCondi.value);
	
	this.smfSearchService("list")
		// 페이징처리
		//.paginator(this.div00.form.div00.form.grdList, this.div00.form.div00.form.divPaging, this.divTotal, this.dsPageInfo, obj, e)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return; 
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){ //조회 성공
				// 총 검색결과와 현재 검색 결과 수가 일치할 경우 [더보기]버튼 숨김 (TODO)
				//if(this.dsPageInfo.getColumn(0, "pageIndex") < 1 ){
				//	this.div00.form.div00.form.divPaging.set_visible(false);
				//}else{
				//	this.div00.form.div00.form.divPaging.set_visible(true);
				//}
				
				//데이터에 따른 폼, 그리드 높이 조절
				//10개의 데이터까지는 스크롤 없이 보이도록 되어있음
				if(this.smfIsMobile() == true){ //모바일
					
					//this.div00.form.div00.form.grdList.setOffsetHeight(this.dsNtcList.getRowCount()*160);
					this.div00.form.div00.form.grdList.setOffsetHeight(this.div00.form.div00.form.grdList.getRealRowFullSize());
					this.div00.form.div00.form.set_height(this.dsNtcList.getRowCount()*160+310);
					
				}else{ //pc
					if(this.dsNtcList.rowcount > 10){
					
						this.div00.form.div00.form.grdList.setOffsetHeight(this.div00.form.div00.form.grdList.getRealRowFullSize());
						this.div00.form.div00.form.set_height(this.div00.form.div00.form.grdList.height + 172);
						
					}else{
						
						this.div00.form.div00.form.grdList.setOffsetHeight(480);
						this.div00.form.div00.form.set_height(652);
						
					}
					
				}
					
				//다시 그리기
				this.smfResetScroll(this.div00.form.div00.form.grdList);
				this.smfResetScroll(this.div00.form.div00.form);
			}
		});
};

this.div00_div00_div05_btnClean_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
		this.div00.form.div00.form.div05.form.cmbCondi.set_index(0);
		this.div00.form.div00.form.div05.form.edtSearch.set_value("");
		this.fnListSelect();
};


this.div00_div00_div05_cmbCondi_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.dsSearch.setColumn(0,"srchCond",e.postvalue);
};

this.div00_div00_grdList_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var condi = this.div00.form.div00.form.div05.form.cmbCondi.index;
	var title = this.div00.form.div00.form.div05.form.edtSearch.text;
	var currow = this.div00.form.div00.form.grdList.currentrow;
	
	var param = {
		cddcCd 		: this._cddcCd,
		cddcNm      : this._cddcNm,
		shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd"),
		evlKndScCd  : this.fv_evlKndScCd,
		condi		: condi,
		kwd			: title,
		rn  		: currow + 1,
		dataset		: this.dsPreset.saveXML(),
		dataset1 	: this.dsPreset1.saveXML(),
		dataset2 	: this.dsNtcList.saveXML(),
		datachild 	: this.dsChldList.saveXML(),
		ntcMteId 	: this.dsNtcList.getColumn(e.row,"ntcMteId"),
	};
	this.smfSetWorkPage("pa_ktd_tad_os::ktd_tados04_t02.xfdl", param, false);
};

this.div00_div00_div05_edtSearch_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	//Enter 키
	if(e.keycode == 13){
		
		//검색
		this.div00_div00_div05_btnSearch_onclick();
	}
};

this.eds_tados04_t01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnSetcompSizeP();
};

/**
 * 컴포넌트 사이즈 조절(PC)
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnSetcompSizeP = function(){
	if (!this.smfIsMobile()){
		var nMaxWidth = 1200 - nexacro.toNumber(this._getHScrollBarSize());
		var nFormWidth = this.getOffsetWidth();
		var vLeft = Math.floor((this.getOffsetWidth() - (this.div00.form.div00.getOffsetWidth()))/2);
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.div00.form.div01.setOffsetLeft(10 + nLeft);
			this.div00.form.div00.setOffsetLeft(10 + vLeft);
		}else{
			var nLeft = 0;
			this.div00.form.div01.setOffsetLeft(10);
			this.div00.form.div00.setOffsetLeft(10);
		}
		this.div00.form.resetScroll();
	}
};

]]></Script>
    <Bind>
      <BindItem id="item0" compid="div00.form.div00.form.div05.form.edtSearch" propid="value" datasetid="dsSearch" columnid="srchKw"/>
    </Bind>
  </Form>
</FDL>
