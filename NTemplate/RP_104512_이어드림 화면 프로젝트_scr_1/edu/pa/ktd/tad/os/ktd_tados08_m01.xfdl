              <Div id="div00" taborder="3" left="360" top="90" cssclass="div_WF_SurvLgnBox3" initvalueid="ivDivAccessibilityOff" width="1200" height="652">
                <Layouts>
                  <Layout>
                    <Div id="div00" taborder="0" left="86" top="19" width="1060" height="180" initvalueid="ivDivAccessibilityOff">
                      <Layouts>
                        <Layout>
                          <Static id="sta00" taborder="0" text="실시목적" left="0" top="8" width="164" height="164" cssclass="font16BCircle" initvalueid="ivStcAccessibilityOn"/>
                          <Static id="sta01" taborder="1" text="“학부모의 의견을 모아 선생님의 개인별 능력개발을 지원합니다.”" left="207" top="41" width="682" height="30" cssclass="sta_WF_Txt18M" initvalueid="ivStcAccessibilityOn"/>
                          <Static id="sta02" taborder="2" text="선생님의 교육활동 전반에 대한 전문성을 진단하고 그 결과에 따른 능력개발을 지원하여 유치원 교육의 질 향상을 도모합니다." left="208" top="91" width="740" height="21" cssclass="sta_WF_survDot14" initvalueid="ivStcAccessibilityOn"/>
                          <Static id="sta02_00" taborder="3" text="학생들에게 양질의 교육을 제공하여 유치원 교육 만족도를 향상하고, 구성원간의 소통증진을 통하여 공교육의 신뢰도를 제고합니다." left="208" top="112" width="818" height="20" cssclass="sta_WF_survDot14" initvalueid="ivStcAccessibilityOn"/>
                        </Layout>
                        <Layout name="Layout0">
                          <Static id="sta01" left="0" top="142" height="88" cssclass="sta_WF_Txt28B" textAlign="center" text="“학생, 학부모의 의견을 모아&#13;&#10;선생님의 개인별 능력개발을 지원합니다.”" right="0" taborder="1" fittocontents="height"/>
                          <Static id="sta02" left="20" top="sta01:11" height="99" text="선생님의 교육활동 전반에 대한 전문성을 진단하고 그 결과에 따른 능력개발을 지원하여 학교 교육의 질 향상을 도모합니다." cssclass="sta_WF_survDot24L" right="20" taborder="2" fittocontents="height"/>
                          <Static id="sta02_00" left="20" top="sta02:15" height="99" text="학생들에게 양질의 교육을 제공하여 학교 교육 만족도를 향상하고, 구성원간의 소통증진을 통하여 공교육의 신뢰도를 제고합니다." cssclass="sta_WF_survDot24L" right="20" taborder="3" fittocontents="height"/>
                          <Static id="sta00" left="0" top="0" height="120" right="0" cssclass="font16BCircle_M" taborder="0"/>
                        </Layout>
                        <Layout name="Layout1">
                          <Static id="sta01" left="20" top="sta00:42" height="88" cssclass="sta_WF_Txt28B" textAlign="center" text="“학생, 학부모의 의견을 모아&#13;&#10;선생님의 개인별 능력개발을 지원합니다.”" right="20" fittocontents="height"/>
                          <Static id="sta02" left="20" top="sta01:31" height="74" text="선생님의 교육활동 전반에 대한 전문성을 진단하고 그 결과에 따른 능력개발을 지원하여 학교 교육의 질 향상을 도모합니다." cssclass="sta_WF_survDot24L" right="20" fittocontents="height"/>
                          <Static id="sta02_00" left="20" top="sta02:10" height="74" text="학생들에게 양질의 교육을 제공하여 학교 교육 만족도를 향상하고, 구성원간의 소통증진을 통하여 공교육의 신뢰도를 제고합니다." cssclass="sta_WF_survDot24L" right="20" fittocontents="height"/>
                          <Static id="sta00" left="0" top="0" height="120" right="0" cssclass="font16BCircle_M"/>
                        </Layout>
