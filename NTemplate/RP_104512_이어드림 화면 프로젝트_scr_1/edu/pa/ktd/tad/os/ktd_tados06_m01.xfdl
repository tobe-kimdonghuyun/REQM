this.div01_div00_btn01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var popupParams = {
		callback: this.fnPopupCallback,
		sender: obj, // sender 지정
		params: {
			procType : 'search'
		},
		titlebar : false,
	};

	this.smfIsMobile() ? this.smfDialog("_auto", "pa_ktd_tad_os::ktd_tados03_p03.xfdl", popupParams, null, null, 600, 960) : this.smfDialog("_auto", "pa_eds_tad_os::eds_tados03_p03.xfdl", popupParams);
};

