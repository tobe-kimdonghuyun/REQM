            <Layout>
              <Static id="sta00" taborder="0" width="283" right="0" bottom="0" height="641" cssclass="sta_WF_SurvGraph03" initvalueid="ivStcAccessibilityOff" exceptResetScroll="Y"/>
              <Div id="div01" taborder="1" text="div01" left="360" top="20" width="1200" height="202" cssclass="div_WF_SurvBox16R" initvalueid="ivDivAccessibilityOff" formscrollbartype="none none">
                <Layouts>
                  <Layout>
                    <Static id="sta00" taborder="0" text="꼭 읽어야 할 유의사항" left="82" top="35" width="267" height="40" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_SurvCautionL"/>
                    <Static id="sta000" taborder="1" left="371" top="35" width="620" height="45" cssclass="sta_WF_survDot14" initvalueid="ivStcAccessibilityOn" usedecorate="true" text="학부모 만족도조사는 자녀정보를 확인(학부모참여번호 포함)한 후에 참여가 가능합니다.&#13;&#10;&#13;※ 학부모참여번호는 유치원을 통해 발급 안내되오니 확인이 필요하신 경우 유치원으로 문의하여 주세요." wordWrap="none" fittocontents="height"/>
                    <Static id="sta001" taborder="2" left="371" top="sta000:-3" width="661" height="26" cssclass="sta_WF_survDot14" initvalueid="ivStcAccessibilityOn" usedecorate="true" text="참여번호의 입력은 가상키패드(기본 적용) 또는 키보드보안 프로그램(선택)을 통하여 입력이 가능합니다." wordWrap="none" fittocontents="height"/>
                    <Static id="sta002" taborder="3" left="371" top="sta001:0" width="620" height="30" cssclass="sta_WF_survDot14" initvalueid="ivStcAccessibilityOn" usedecorate="true" text="자녀정보 확인에 어려움이 있으시면 자녀의 유치원으로 문의하여 주세요." wordWrap="none"/>
                    <Static id="sta003" taborder="4" left="371" top="sta002:-5" width="705" height="46" cssclass="sta_WF_survDot14" initvalueid="ivStcAccessibilityOn" usedecorate="true" text="학부모 만족도조사 결과는 어느 누구도 알 수 없도록 처리되니 안심하고 참여하여 주세요.&#13;&#10;&#13;(본 조사는 「교원등의 연수에 관한 규정」 및 「교원능력개발평가 실시에 관한 훈령」을 근거로 실시되고 있습니다.)" onclick="div01_div01_sta00_00_01_00_00_00_00_onclick" wordWrap="none"/>
                    <Static id="sta01" taborder="5" left="1729" top="107" width="55" height="45" visible="false" enable="false" initvalueid="ivStcAccessibilityOff" onsize="div01_div01_sta01_onsize"/>
