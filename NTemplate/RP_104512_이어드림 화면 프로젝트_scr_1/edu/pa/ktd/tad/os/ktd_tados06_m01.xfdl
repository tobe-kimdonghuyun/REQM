this.div01_div00_cbo00_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	var cnt = Number(this.dsChldCnt.getColumn(e.postindex , "Code" ));
	this.fv_chldCnt = cnt;
	this.fnDiv00Reset();
	if(cnt > 0){
		this.div01.form.div00.form.staChldNoneText.set_visible(false);
		this.fnDiv00Setting(cnt);
	}else{
		this.div01.form.div00.form.staChldNoneText.set_visible(true);
		this.div01.form.div00.form.div00.form.div00_01.set_visible(true);
	}
	this.fnDiv00EdtSetReadonly(false);
	this.fv_btn = "";
	this.div01.form.btnIn.set_text("자녀확인");
 	this.smfResetScroll(this.div01.form.div00.form.div00.form);
};

