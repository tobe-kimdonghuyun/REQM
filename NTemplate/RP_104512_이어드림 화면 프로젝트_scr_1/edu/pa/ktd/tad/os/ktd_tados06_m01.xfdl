this.fnDiv00Setting = function (cnt) {
	if(cnt >= 1 )
		this.div01.form.div00.form.div00.form.div00_01.set_visible(true);
	if(cnt >= 2 )
		this.div01.form.div00.form.div00.form.div00_02.set_visible(true);
	if(cnt >= 3 )
		this.div01.form.div00.form.div00.form.div00_03.set_visible(true);
	if(cnt >= 4 )
		this.div01.form.div00.form.div00.form.div00_04.set_visible(true);
	if(cnt >= 5 )
		this.div01.form.div00.form.div00.form.div00_05.set_visible(true);
	if(cnt >= 6 )
		this.div01.form.div00.form.div00.form.div00_06.set_visible(true);
	if(cnt >= 7 )
		this.div01.form.div00.form.div00.form.div00_07.set_visible(true);
	if(cnt >= 8 )
		this.div01.form.div00.form.div00.form.div00_08.set_visible(true);
	if(cnt >= 9 )
		this.div01.form.div00.form.div00.form.div00_09.set_visible(true);
	if(cnt >= 10)
		this.div01.form.div00.form.div00.form.div00_10.set_visible(true);
};


this.div01_div00_btnShlSrch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var shlNm  = "";
	if( this.div01.form.div00.form.edtShl.getLength() > 0 ){
		shlNm  = this.div01.form.div00.form.edtShl.text;
	}
	trace("[ POP UP ] 으로 데이터를 보내기 전에 :: " + shlNm );
	
	var popupParams = {
		callback: this.fnPopupCallback,		// 콜백함수 지정
		sender: obj, 						// sender 지정
		params: {							// 팝업 전달 파라메터 지정
			procType: "none",				// 처리타입 지정
			cddcOrgCd : this._cddcCd,
			shlNm : shlNm,
		},
		titlebar : false
	};
	if (this.smfIsMobile()) {
		this.smfDialog("_auto", "pa_ktd_tad_os::ktd_tados03_p01.xfdl", popupParams, null, null, 640, 980);
	} else {
		this.smfDialog("_auto", "pa_ktd_tad_os::ktd_tados03_p01.xfdl", popupParams);
	}
};

this.fnStuChk = function () {
	var shlCd = this.dsSearch.getColumn(0, "shlCd");
	var cerCnt = this.dsChldList.getRowCount();

	if(this.fv_chldCnt == 0){
		this.smfAlert('CM006',['자녀수']);
		return;
	}
	if(this.isNil(shlCd)){
		this.smfAlert('CM006',['유치원명']);
		return;
	}
	
//   	for( var i = 0 ; i < cerCnt ; i++ ){
//   		var schpaCetNo = this.dsChldList.getColumn(i , "schpaCetNo") ;
//   		if( this.smfIsNull(schpaCetNo)){
//   			this.smfAlert('CM006',['참여번호']);
//   			return;
//   		}
//   	}

	this.smfSearchService("check")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return; 
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){ 	//본인확인 성공
				trace("■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■");
				trace(this.dsEvlYr.saveXML());
				trace(this.dsSchInfo.saveXML());
				trace(this.dsSearch.saveXML());
				trace(this.dsChldList.saveXML());
				trace("---------------------------------------------------");
				trace(this.dsEvlYnInfo.saveXML());
				trace(this.dsEvlPrdInfo.saveXML());
				trace("■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■");
				
				// dsSearch 파라미터 세팅
				this.dsSearch.setColumn(0, "shlCrseScCd", this.dsSchInfo.getColumn(0, "shlCrseScCd"	));	// 학교과정구분코드
				this.dsSearch.setColumn(0, "shlKndScCd" , this.dsSchInfo.getColumn(0, "shlKndScCd"	));	// 학교종류구분코드
				this.dsSearch.setColumn(0, "evlYr" 		, this.dsEvlYr	.getColumn(0, "evlYr"		));	// 학년도
				for( var i = 0 ; i < this.dsChldList.getRowCount() ; i++ ){
					var grdText = "";
					if( this.dsChldList.getColumn(i , "grd") != null){
						grdText = this.dsChldList.getColumn(i , "grd");
					}else{
						grdText = this.dsChldList.getColumn(i , "chldInfoScCdNm");
					}
						if(i+1 == 1)
							this.div01.form.div00.form.div00.form.div00_01.form.sta00_00_00_00.set_text(grdText);
						if(i+1 == 2)
							this.div01.form.div00.form.div00.form.div00_02.form.sta00_00_00_00.set_text(grdText);
						if(i+1 == 3)
							this.div01.form.div00.form.div00.form.div00_03.form.sta00_00_00_00.set_text(grdText);
						if(i+1 == 4)
							this.div01.form.div00.form.div00.form.div00_04.form.sta00_00_00_00.set_text(grdText);
						if(i+1 == 5)
							this.div01.form.div00.form.div00.form.div00_05.form.sta00_00_00_00.set_text(grdText);
						if(i+1 == 6)
							this.div01.form.div00.form.div00.form.div00_06.form.sta00_00_00_00.set_text(grdText);
						if(i+1 == 7)
							this.div01.form.div00.form.div00.form.div00_07.form.sta00_00_00_00.set_text(grdText);
						if(i+1 == 8)
							this.div01.form.div00.form.div00.form.div00_08.form.sta00_00_00_00.set_text(grdText);
						if(i+1 == 9)
							this.div01.form.div00.form.div00.form.div00_09.form.sta00_00_00_00.set_text(grdText);
						if(i+1 == 10)   
							this.div01.form.div00.form.div00.form.div00_10.form.sta00_00_00_00.set_text(grdText);
				}
 				// 테스트
// 				this.dsEvlYnInfo.setColumn(0, "schpaEvlCmptnYn", "N");
				
				if (this.dsChldList.findRowExpr("evlPaptCnt > '0'") == -1 ){
					var tadResultMsg 	= "학부모만족도조사에 참여하실 수 없습니다.\n온라인 학부모만족도조사 참여학생이 아닙니다.";
					var tadResultDtlMsg = "소속학교에 문의 후 다시 시도해주시기 바랍니다.\n감사합니다.";
					this.smfAlertEds(tadResultMsg + "\n\n" + tadResultDtlMsg, null, null, null, {align:'left'});
					return false;
				}
				
				if (this.dsEvlYnInfo.getColumn(0, "schpaOnlEvlYn") != "Y" ) 
				{
					var tadResultMsg 	= "학부모만족도조사에 참여하실 수 없습니다.\n온라인 학부모만족도조사 진행유치원이 아닙니다.";
					var tadResultDtlMsg = "소속유치원에 문의 후 다시 시도해주시기 바랍니다.\n감사합니다.";
					this.smfAlertEds(tadResultMsg + "\n\n" + tadResultDtlMsg, null, null, null, {align:'left'});
					return false;
				}
				else if(this.dsEvlPrdInfo.getColumn(0, "shlEvlPrdYn") != "Y") 
				{
					var tadResultMsg = "학부모만족도조사에 참여하실 수 없습니다.\n학부모만족도조사 참여기간이 아닙니다.";
					if (this.isNil(this.dsEvlPrdInfo.getColumn(0, "evlBgngYmd")) == false && 
					    this.isNil(this.dsEvlPrdInfo.getColumn(0, "evlEndYmd" )) == false)
					{
						tadResultMsg = tadResultMsg + "\n" + "참여기간(" + this.dsEvlPrdInfo.getColumn(0, "evlBgngYmd") + " ~ " + this.dsEvlPrdInfo.getColumn(0, "evlEndYmd" ) + ")";
					}
					var tadResultDtlMsg = "소속유치원에 문의 후 다시 시도해주시기 바랍니다.\n감사합니다.";
					this.smfAlertEds(tadResultMsg + "\n\n" + tadResultDtlMsg, null, null, null, {align:'left'});
					return false;
				}
				else if (this.dsEvlYnInfo.getColumn(0, "schpaEvlCmptnYn") != "N" ) 
				{
					var tadResultMsg = "학부모만족도조사에 참여하실 수 없습니다.\n학부모만족도조사가 종료되었습니다.";
					if (this.isNil(this.dsEvlPrdInfo.getColumn(0, "evlBgngYmd")) == false && 
					    this.isNil(this.dsEvlPrdInfo.getColumn(0, "evlEndYmd" )) == false)
					{
						tadResultMsg = tadResultMsg + "\n" + "참여기간(" + this.dsEvlPrdInfo.getColumn(0, "evlBgngYmd") + " ~ " + this.dsEvlPrdInfo.getColumn(0, "evlEndYmd" ) + ")";
					}
					var tadResultDtlMsg = "소속유치원에 문의 후 다시 시도해주시기 바랍니다.\n감사합니다.";
					this.smfAlertEds(tadResultMsg + "\n\n" + tadResultDtlMsg, null, null, null, {align:'left'});
					return false;
				}
				
				//this.div01.form.btnIn.set_enable(true);
				var chk = 0	;			
				for( var i =0 ; i < this.dsChldList.getRowCount() ; i ++) 
				{
					if( this.dsChldList.getColumn(i,"chldInfoScCd") == "TAD_REG_CHLD" )
					{
						chk = chk+1;
					}
				}
				
				if( chk > 0 )
				{
					this.fv_btn = "Y";				
					this.div01.form.btnIn.set_text("참여하기");
					//this.div01.form.div00.form.grdList.set_readonly(true);
					this.div01.form.div00.form.cmbChld.set_readonly(true);
					this.div01.form.div00.form.edtShl.set_readonly(true);
					this.div01.form.div00.form.btnShlSrch.set_enableevent(false);
					this.fnDiv00EdtSetReadonly(true);
					if (this.fv_isQr == "Y") {
						if(this.dsEvlYnInfo.getColumn(0, "cddcNm") != null && this.dsEvlYnInfo.getColumn(0, "cddcNm") != "" ) {
							this._cddcNm = this.dsEvlYnInfo.getColumn(0, "cddcNm");
						}
						// -------------------------------------------------------------------------
						// 참여하기
						// -------------------------------------------------------------------------
						this.div01_btnIn_onclick();
					}
				}
			}
			else
			{	
				//this.div01.form.div00.form.grdList.set_readonly(false);
				this.div01.form.div00.form.cmbChld.set_readonly(false);
				this.div01.form.div00.form.edtShl.set_readonly(false);
				this.fnDiv00EdtSetReadonly(false);
				this.div01.form.div00.form.btnShlSrch.set_enableevent(true);
				this.fv_btn = "";
				this.div01.form.btnIn.set_text("자녀확인");
				
			}
			
			this.fv_isQr = "";
		});
}



this.div01_div00_btnSelect_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	this.dsChldList.clearData();
	this.dsSearch.clearData();
	this.dsSearch.addRow();
	this.dsSearch.setColumn(0, "cddcCd", this._cddcCd);
	this.div01.form.div00.form.cmbChld.set_index(0);
	this.fnDiv00Reset();
	this.div01.form.div00.form.staChldNoneText.set_visible(true);
	this.div01.form.div00.form.div00.form.div00_01.set_visible(true);
	this.smfResetScroll(this.div01.form.div00.form);
	this.div01.form.div00.form.cmbChld.set_readonly(false);
	this.div01.form.div00.form.edtShl.set_readonly(false);
	this.fnDiv00EdtSetReadonly(false);
	this.div01.form.div00.form.btnShlSrch.set_enableevent(true);
	this.smfResetScroll(this.div01.form.div00.form.div00.form);
	this.fnClearTranskey();
	this.fv_btn="";
	this.div01.form.btnIn.set_text("자녀확인");
};

this.div01_btnIn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	trace("■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■");
	trace(this.dsEvlYr.saveXML());
	trace(this.dsSchInfo.saveXML());
	trace(this.dsSearch.saveXML());
	trace(this.dsChldList.saveXML());
	trace(this.fv_btn);
	trace("■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■");
	if( this.fv_btn == "Y" ){
		var tf = false; 
 		for( var i = 0 ; i < this.dsChldList.getRowCount() ; i++ ){
 			if( this.dsChldList.getColumn(i , "grd") == null){
 				tf = true; 
 			}
 		}
 		if(tf){
 			this.smfConfirm('확인되지 않은 자녀정보가 있습니다.\n학부모만족도조사 접속하시겠습니까?', function(result){
 				if(result.confirmResult){
 					
 					//EVL_KND_SC_CD
 					var popupParams = {
 						callback: this.fnPopupCallback,		// 콜백함수 지정
 						sender: obj, 						// sender 지정
 						params: {							// 팝업 전달 파라메터 지정
 							procType: "none",				// 처리타입 지정
 							cddcOrgCd : this._cddcCd,			
 							evlKndScCd : this.fv_evlKndScCd,
 						},
 						titlebar : false
 					};
 					this.smfDialog("_auto", "pa_ktd_tad_os::ktd_tados03_p02.xfdl" ,popupParams);
 				}else{
 					//this.div01.form.div00.form.grdList.set_readonly(false);
 					this.div01.form.div00.form.cmbChld.set_readonly(false);
 					this.div01.form.div00.form.edtShl.set_readonly(false);
					this.fnDiv00EdtSetReadonly(false);
 					this.div01.form.div00.form.btnShlSrch.set_enableevent(true);
 					this.fv_btn="";
 					this.div01.form.btnIn.set_text("자녀확인");
 				}
 			});
 		}else{
 			var popupParams = {
 				callback: this.fnPopupCallback,		// 콜백함수 지정
 				sender: obj, 						// sender 지정
 				params: {							// 팝업 전달 파라메터 지정
 					procType: "none",				// 처리타입 지정
 					cddcOrgCd : this._cddcCd,			
 					evlKndScCd : this.fv_evlKndScCd,
 				},
 				titlebar : false
 			};
 			this.smfDialog("_auto", "pa_ktd_tad_os::ktd_tados03_p02.xfdl" ,popupParams);
 		}
	}else{
		this.fnSettingDsChldList();
		this.fnStuChk();
		//
	}
};
this.fnSettingDsChldList = function () {
	var cnt = this.fv_chldCnt;

	this.dsChldList.clearData();
	this.dsRaonKeyData.clearData();
	for(var i = 0 ; i < cnt ; i++){
		
		var indexI = i+1;
		var edtVelue = this.div01.form.div00.form.div00.form["div00_"+(indexI != 10 ? "0"+indexI: indexI)];
		if(edtVelue.form.edt00.value != ""){
			this.dsChldList.addRow();
			this.dsChldList.setColumn(i,"schpaCetNo",edtVelue.form.edt00.value);
		}
		if ( this.fv_isQr != "Y") 
		{
			this.fnTransKey(edtVelue.form.edt00);
		}
		this.dsRaonKeyData.appendData(this.dsRaonKeyDataCopy);
		trace(this.dsRaonKeyData.saveXML());
	}
	

};

this.fnSettingforNext = function () {
	
	this.dsChldListA.deleteAll();
	
	for( var i = 0 ; i < this.dsChldList.getRowCount() ; i++ ){
		if( this.dsChldList.getColumn(i , "chldInfoScCd") == "TAD_REG_CHLD" ){
			var add = this.dsChldListA.addRow();
			this.dsChldListA.copyRow(add, this.dsChldList , i );
		}
	
	}

};


 /**
 * 컴포넌트 사이즈 조절
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnSetcompSize = function(){
	if (this.fvIsInfoOpen){ // 안내문 오픈 > 닫힘
		this.div01.form.div01.set_height(93);		
		this.div01.form.div01.form.btn00.set_cssclass('btn_WF_SurvDropUp');
		this.fvIsInfoOpen = false;
		this.smfResetScroll(this.div01.form);
	}else{ // 안내문 닫힘 > 오픈
		this.div01.form.div01.form.btn00.set_cssclass('btn_WF_SurvDropDown');
		this.fvIsInfoOpen = true;
		this.smfResetScroll(this.div01.form.div01.form);
		this.smfResetScroll(this.div01.form.div00.form);
		this.div01.form.div01.set_height(this.div01.form.div01.form.sta003.getOffsetBottom() + 40);
		this.smfResetScroll(this.div01.form);
	}
	this.div01.setOffsetHeight(this.div01.height + 60);
	this.smfResetScroll(this);
}

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnPopupCallback = function(e, sender)
{
	
	if(e.urlName == "searchShl"){			//학교찾기 팝업 콜백
		if(e.row){
			this.dsSearch.setColumn(0, "shlCd", e.row["orgCd"]);
			this.dsSearch.setColumn(0, "shlNm", e.row["kornOrgNm"]);	
			this.dsSearch.setColumn(0, "shlKndScCd", e.row["shlKndScCd"]);
			this.dsSearch.setColumn(0, "shlCrseScCd", "2");
			//shlKndScCd
		}
	}else if(e.urlName == "gotoNext"){
		//검색된 아이들만 조회
		this.fnSettingforNext();
		
		var param = {
			cddcCd : this._cddcCd,
			cddcNm : this._cddcNm,
			screenScCd : "P",	
			evlKndScCd : this.fv_evlKndScCd,
			dataset1 : this.dsSearch.saveXML(),
			dataset2 : this.dsChldListA.saveXML(),
		};
		
		trace(this.dsResult.saveXML());
		trace("****************************************************************");
		trace(this.dsSearch.saveXML());		
		trace("****************************************************************");
		
		this.smfSetWorkPage("pa_ktd_tad_os::ktd_tados09_m01.xfdl", param, false);
	}
	
};

this.div01_div00_edtShl_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	trace("화면 이벤트 ID :: " + e.keycode );
	if(e.keycode == "13" ){
		this.div01_div00_btnShlSrch_onclick(obj,e);
	}
};

this.div01_div00_edtShl_onkeyup = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode == "13" ){
		this.div00_div00_btnShlSrch_onclick(obj,e);
	}
};

this.div01_div01_btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSetcompSize();
};

