    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 
*  @FileName 	eds_tados05_m01.xfdl 
*  @Creator 	kangjihye
*  @CreateDate 	2023.02.14
*  @Desction    교육설문 - 교원평가 
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.02.14           Kangjihye                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 this.fv_param;	// 파라메터 세팅
 this.fv_btn==""; //버튼컨트롤 
 this.fv_evlKndScCd="3";
 this.fvIsInfoOpen = false;
 this.fv_isQr = "";
 var realRowFullSize = "";
 this.fv_chldCnt = 0;
 this.fv_shlKndgrScCd = "2";
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnonload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.fnSetcompSizeP();
	// 폼 초기화
	this.smfInitForm(obj);
	var sDate = new Date();
	
	//검사연도 세팅
	var sYear  = sDate.getFullYear().toString();
	// 전달받은 파라메터 값 세팅
	this.fv_param = this.smfGetFormParams();
	this._cddcCd = this.fv_param.cddcCd;
	this._cddcNm = this.fv_param.cddcNm;
	if ( this.smfIsMobile() ) {
		this.divTop.form.fnSetPtptPrd(this._cddcNm);
	}
	this.dsSearch.setColumn(0, "cddcCd", this._cddcCd);
	this.dsSearch.setColumn(0, "evlYr" 		, sYear);
	this.dsSearch.setColumn(0, "shlKndgrScCd", this.fv_shlKndgrScCd);
	//스크롤바 갱신
	this.smfResetScroll(this);
	
	if (this.smfIsMobile()) {
		this.fvIsInfoOpen = false;
		this.fnSetcompSize();
	}
	//this.div01.form.div00.form.grdList.set_readonly(false);
	this.div01.form.div00.form.cmbChld.set_readonly(false);
	this.div01.form.div00.form.edtShl.set_readonly(false);
	this.div01.form.div00.form.btnShlSrch.set_enableevent(true);
	
	this.div01.form.btnIn.set_text("자녀확인");
	this.div01.form.div00.form.cmbChld.set_index(0);
	//var hp = this.div01.form.div00.form.grdList.getRealRowFullSize();
	//this.div01.form.div00.form.grdList.setOffsetHeight(hp);	
	//this.smfResetScroll(this.div01.form.div00.form);
	//this.div01.form.btnIn.set_enable(false);
	
	// ---------------------------------------------------------------------------------------------
	// 테스트 값 Set
// 	this.dsSearch.setColumn(0, "shlCd", "K100000383");
// 	this.dsSearch.setColumn(0, "shlNm", "김화공업고등학교");	
// 	this.dsSearch.setColumn(0, "shlKndScCd", "04");
// 	this.dsSearch.setColumn(0, "shlCrseScCd", " ");
// 	this.dsChldList.setColumn(0, "schpaCetNo", "28UMU4");
	// ---------------------------------------------------------------------------------------------


	// ---------------------------------------------------------------------------------------------
	// QR코드로 진입시
	// 예) http://dev.eduro.go.kr/nxui/index.html?edstype=CA&edsdata=K100000001K100000383BADVRV
	// this.fv_param
	// "autoLogin": "Y",
	// "edsType": "CA",
	// "edsData": "K100000001K100000383BADVRV"
	// ---------------------------------------------------------------------------------------------
	// 	아래 주석 삭제 해야함
// 		this.fv_param.subsys = "EDS";
//  		this.fv_param.edsType = "CB";
// 		this.fv_param.edsData = "K100000001K100000383TZNL2T";
	if (this.smfIsNull(this.fv_param.edsType) == false && this.smfIsNull(this.fv_param.edsData) == false && this.fv_param.edsData.length != 10) {
		trace(this.fv_param);
		this.divTop.form.fnSetPtptPrd("교육청");
		if (this.fv_param.edsType.length != 2 || this.fv_param.edsData.length != 26) {
			this.smfAlertEds('잘못된 접근입니다.', [], function() {
				window.location.href = document.location.href.split("?")[0];
			});
			return;
		}
		
		// 전역변수
		this.fv_isQr = "Y";
		this._cddcCd = this.fv_param.edsData.substr(0, 10);	// 시도교육청코드

		// 조회조건
		this.fv_chldCnt = 1;
		this.dsSearch.setColumn(0, "cddcCd"		, this.fv_param.edsData.substr( 0, 10)	);	// 시도교육청코드
		this.dsSearch.setColumn(0, "evlYr" 		, this.smfToday().substr(0, 4)			);	// 평가연도
		this.dsSearch.setColumn(0, "shlCd" 		, this.fv_param.edsData.substr(10, 10)	);	// 학교코드
		trace(this.dsSearch.saveXML());
 		this.dsChldList.clearData();
 		this.dsChldList.addRow();
		this.dsChldList.setColumn(0, "schpaCetNo", this.fv_param.edsData.substr(20,  6)	);	// 학부모인증번호
		trace(this.dsChldList.saveXML());
		
		// -----------------------------------------------------------------------------------------
		// 학적확인
		// -----------------------------------------------------------------------------------------
		this.fnStuChk();
	}else{
		if ( this.smfIsNull(this.fv_param.edsType) == false && this.smfIsNull(this.fv_param.edsData) == false && this.fv_param.edsData.length == 10) {
			this._cddcCd = this.fv_param.edsData.substr(0, 10);
			this.dsSearch.setColumn(0, "cddcCd", this.fv_param.edsData.substr( 0, 10)	);	// 시도교육청코드
		} else if ( ( this.smfIsNull(this.fv_param.edsType) == false && this.smfIsNull(this.fv_param.edsData) == true ) || ( this.smfIsNull(this.fv_param.edsType) == false && this.smfIsNull(this.fv_param.edsData) == false && this.fv_param.edsData.length < 10) )  {
			this.smfAlertEds('잘못된 접근입니다.', [], function() {
				window.location.href = document.location.href.split("?")[0];
			});
			return;
		}
		//@KBR 가상키보드 사용
 	 	var objOption1 = {
 	 		target : this.div01.form.div00.form.div00.form.div00_01.form.edt00, // 대상 Edit 컴포넌트 [필수]
 	 		targetKey : this.div01.form.div00.form.staTransKey01, // Edit와 쌍으로 있는 마우스입력 체크박스(static) [필수]
			dataType:"A",
 	 		maxLength : 6,
 	 		bshow : true
 	 	}
 	 	this.smfInitTranskey(objOption1);
 	 	var objOption2 = {
 	 		target : this.div01.form.div00.form.div00.form.div00_02.form.edt00, // 대상 Edit 컴포넌트 [필수]
 	 		targetKey : this.div01.form.div00.form.staTransKey02, // Edit와 쌍으로 있는 마우스입력 체크박스(static) [필수]
			dataType:"A",
 	 		maxLength : 6,
 	 		bshow : true
 	 	}
 	 	this.smfInitTranskey(objOption2);
 	 	var objOption3 = {
 	 		target : this.div01.form.div00.form.div00.form.div00_03.form.edt00, // 대상 Edit 컴포넌트 [필수]
 	 		targetKey : this.div01.form.div00.form.staTransKey03, // Edit와 쌍으로 있는 마우스입력 체크박스(static) [필수]
			dataType:"A",
 	 		maxLength : 6,
 	 		bshow : true
 	 	}
 	 	this.smfInitTranskey(objOption3);
