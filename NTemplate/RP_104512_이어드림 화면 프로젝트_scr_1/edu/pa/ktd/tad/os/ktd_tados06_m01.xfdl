/**
 * 가상키패드
 * @param  : obj			- edit 컴포넌트
 * @return : N/A
 */
this.fnTransKey = function(obj)
{
	var arrComp = [obj];  //대상 Edit component List: array [필수]
	
	if(!this.smfIsMobile()){
		// 키보드보안 적용여부
		var sRtnVal = this.smfGetValueTranskey(obj);
	
		if(sRtnVal == "transkey"){	//선택
			var sVal = this.smfGetEncDataTranskey(arrComp);
	
			//전달받은 파라미터 데이터셋에 담기
			this.smfConvRaonDataToDs(this.dsRaonKeyDataCopy,arrComp,sVal);
			this.dsRaonKeyDataCopy.setColumn(0, 'tk_col_check', "transkey");
		}else if(sRtnVal == "e2e"){ //미선택
			sVal= obj.value;
		}
	}else{
		var sRtnVal = this.smfGetValueTranskey(obj);
	
		if(sRtnVal == "transkey"){
			var sVal = this.smfGetEncDataTranskey(arrComp);
			
			//전달받은 파라미터 데이터셋에 담기
			this.smfConvRaonDataToDs(this.dsRaonKeyDataCopy,arrComp,sVal);
			this.dsRaonKeyDataCopy.setColumn(0, 'tk_col_check', "transkey");
		}
	}
	//return sRtnVal;
}

