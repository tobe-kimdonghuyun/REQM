/**
 * 컴포넌트 사이즈 조절(PC)
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnSetcompSizeP = function(){
	if (!this.smfIsMobile()){
		var nMaxWidth = 1200 - nexacro.toNumber(this._getHScrollBarSize());
		var nFormWidth = this.getOffsetWidth();
		var vLeft = Math.floor((this.getOffsetWidth() - (this.div01.form.div00.getOffsetWidth()))/2);
		var bLeft = Math.floor((this.getOffsetWidth() - (this.div01.form.btnIn.getOffsetWidth()))/2);
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.div01.form.div01.setOffsetLeft(10 + nLeft);
			this.div01.form.div00.setOffsetLeft(10 + vLeft);
			this.div01.form.btnIn.setOffsetLeft(10 + bLeft);
		}else{
			var nLeft = 0;
			this.div01.form.div01.setOffsetLeft(nLeft);
			this.div01.form.div00.setOffsetLeft(vLeft);
			this.div01.form.btnIn.setOffsetLeft(bLeft);
		}
		this.div01.form.resetScroll();
	}
};]]></Script>
    <Bind>
      <BindItem id="shlNm" compid="div01.form.div00.form.edtShl" propid="value" datasetid="dsSearch" columnid="shlNm"/>
    </Bind>
  </Form>
</FDL>
