		document.getElementsByClassName("staTransKey")[5].children.item(0).children.item(0).click();
		document.getElementsByClassName("staTransKey")[6].children.item(0).children.item(0).click();
		document.getElementsByClassName("staTransKey")[7].children.item(0).children.item(0).click();
		document.getElementsByClassName("staTransKey")[8].children.item(0).children.item(0).click();
		document.getElementsByClassName("staTransKey")[9].children.item(0).children.item(0).click();
		document.getElementsByClassName("staTransKey")[0].children.item(0).children.item(0).click();	
	}
	this.fnClearTranskey();
