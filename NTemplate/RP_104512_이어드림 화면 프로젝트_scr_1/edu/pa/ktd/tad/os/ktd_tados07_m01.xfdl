	    this.div00.form.div00.form.div01.form.sta002.setOffsetHeight(0);
		if ( val ) {
			var staSbj = this.div00.form.div00.form.div01.form.staSbj.text;
			if ( staSbj == '' ) {
				this.div00.form.div00.form.div01.form.sta003.setOffsetHeight(0);
