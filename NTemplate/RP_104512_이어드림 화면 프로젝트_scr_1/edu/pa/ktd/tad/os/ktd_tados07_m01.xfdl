this.fnCountYrk = function () {

	this.dsSvyInfo.deleteAll();
	this.dsSvyInfo.addRow();
	var cnt = this.dsEvlprQuitmListAll.getRowCount();
	var yrk1=0;
	var yrk2=0;
	var yrk3=0;
	var yrk4=0;
	var yrk5=0;
	var yrk6=0;
	var val = 0;
	for( var i=0 ; i < cnt ; i++ )
	{	
			var tmp	=  this.dsEvlprQuitmListAll.getColumn(i , "ytkSn" );
			if( this.isNotNil(tmp) ){
				var fRow = this.dsEvlYdstkList.findRow("ytkSn", tmp);
				switch(tmp){
					case "1":
						yrk1 = yrk1+1;
					break;
					
					case "2":
						yrk2 = yrk2+1;
					break;
					
					case "3":
						yrk3 = yrk3+1;
					break;
					
					case "4":
						yrk4 = yrk4+1;
					break;
					
					case "5":
						yrk5 = yrk5+1;
					break;		
					
					case "6":
						yrk6 = yrk6+1;
					break;		
				}
				//evlYtkScr
				val += Number(this.dsEvlYdstkList.getColumn( fRow , "evlYtkScr" ));
			}
		
	}
	var Average = val/5;
	this.dsSvyInfo.setColumn(0, "ytkSn1" , yrk1);
	this.dsSvyInfo.setColumn(0, "ytkSn2" , yrk2);
	this.dsSvyInfo.setColumn(0, "ytkSn3" , yrk3);
	this.dsSvyInfo.setColumn(0, "ytkSn4" , yrk4);
	this.dsSvyInfo.setColumn(0, "ytkSn5" , yrk5);
	this.dsSvyInfo.setColumn(0, "ytkSn6" , yrk6);
	this.dsSvyInfo.setColumn(0, "avrScr" , Average.toFixed(1) );
	
	console.log(this.dsSvyInfo.saveXML());
};


this.fnPopUPCall = function (){
	this.fnCountYrk();
	console.log("=========== " + this.dsSvyInfo.saveXML());
	var popupParams = {
		callback: this.fnPopupCallback,		// 콜백함수 지정
		sender: obj, 						// sender 지정
		params: {							// 팝업 전달 파라메터 지정
			procType: "none",				// 처리타입 지정
			cddcOrgCd : this._cddcCd,
			dataset : this.dsSvyInfo.saveXML(),
			dataset1 : this.dsQstnRspns.saveXML(),
			dataset2 : this.dsBasicQstnRspns.saveXML()
		},
		titlebar : false
	};
	this.smfDialog("_auto", "pa_ktd_tad_os::ktd_tados07_p01.xfdl" ,popupParams);
};



this.fnPopupCallback = function(e, sender)
{
	
	if(e.urlName == "confirm"){			//학교찾기 팝업 콜백
		this.fv_message="confirm";
		this.fnSaveCall();
	
	}else if(e.urlName == "cancel"){
		
		console.log("확인필요 ");
	
	}else if(e.urlName == "addSearch"){
		//저장 후 추가설문으로 Call 
		this.fv_message="addSearch";
		this.fnSaveCall();
		console.log("-----추가설문 호출--------");
		
	}
	
};

this.fnAddSearchCall = function () 
{
	//listadd
	this.smfSearchService("listAdd")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return; 
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){ //성공
				 if( this.dsEvlprQuitmList00.getRowCount() >  0) {
					this.fnGotoAddSvy();
				 }else{
					this.smfAlert("추가설문 문항이 존재하지 않습니다");
				    this.fnListSelect();
				 }
				 
			}
		});
};

this.fnGotoAddSvy = function ()
{
	var param = {
			cddcCd : this._cddcCd,
			cddcNm : this._cddcNm,
			evlKndScCd : this.fv_evlKndScCd,
			shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd") ,
			dataset: this.dsResult.saveXML(),	
			dataset1: this.dsPreset.saveXML(),
			dataset2: this.dsChldList.saveXML(),	
			schdataset :  this.dsSearch.saveXML(),
	};
				
	this.smfSetWorkPage("pa_ktd_tad_os::ktd_tados07_t01.xfdl", param, false);
};

this.fnDivDropDown = function (val)
{
	
	if( val ){
		this.div00.form.div00.form.div01.setOffsetHeight(540);
		this.div00.form.div00.form.div01.form.btnEx.set_text("닫기");
		this.div00.form.div00.form.div01.form.btnEx.set_cssclass("btn_WF_SurveyInfoClose"+this.fv_mobile);		
		this.fnDivShow(val);
		if ( this.smfIsMobile() ) {
			var bottom = this.div00.form.div00.form.div01.form.staDetail.getOffsetBottom();
			this.div00.form.div00.form.div01.form.btnEx.setOffsetTop(bottom+10);
		}
		this.smfResetScroll(this.div00.form.div00.form.div01.form);
		this.fv_btn = false;	
		this.smfResetScroll(this.div00.form.div00.form);
	}else{
		this.div00.form.div00.form.div01.setOffsetHeight(100);
		if(this.smfIsMobile()) { 
			var bottom = this.div00.form.div00.form.div01.form.sta000.getOffsetBottom();
			this.div00.form.div00.form.div01.form.btnEx.setOffsetTop(bottom+70);
		}
		this.div00.form.div00.form.div01.form.btnEx.set_text("교원정보");
		this.div00.form.div00.form.div01.form.btnEx.set_cssclass("btn_WF_SurveyMore"+this.fv_mobile);		
		this.fnDivShow(val);
		this.smfResetScroll(this.div00.form.div00.form.div01.form);
		
		this.fv_btn = true;
		this.smfResetScroll(this.div00.form.div00.form);
	}
};

/**
* 평가지 구분 코드에 따른 명칭
*/
this.fnEvlprScNm = function(evlprScCd) {
    var evlprScNm = "";
	if ( evlprScCd == "301" ) {
	    evlprScNm = "원장";
	} else if ( evlprScCd == "302" ) {
	    evlprScNm = "원감";
	} else if ( evlprScCd == "303" ) {
		evlprScNm = "담임";
	} else if ( evlprScCd == "305" ) {                                             
		evlprScNm = "특수";
	} else if ( evlprScCd == "306" ) {
		evlprScNm = "보건";
	} else if ( evlprScCd == "307" ) {
		evlprScNm = "영양";
	} else if ( evlprScCd == "311" ) {                               
		evlprScNm = "수석";
	} else if ( evlprScCd == "811") {
		evlprScNm = "비담임";
	}
    return evlprScNm;
}
/************************************************************************************************
 * 연계 후처리
 ************************************************************************************************/
this.fnSettingCmb = function () {
	
	this.div00.form.div00.form.cboChldList.set_index(this.fv_load_chld);
	this.div00.form.div00.form.cboTchList.set_index(this.fv_load_tch );
	
	this.fv_evlYn = this.dsEvlTrprList.getColumn(this.fv_load_tch, "evlYn");
	this.smfResetScroll(this.div00.form.div00.form);
};

this.div00_div00_cboEvlList_ondropdown = function(obj:nexacro.Combo,e:nexacro.EventInfo)
{
	var objPdv = this.div00.form.div00.form.pdvEvlListCmb;
	
	// 데이터에 맞추어 높이 조절(필요시 표시방향- 콤보의 상단에 표시)
	var nLeft = 0;
	var nTop = obj.getOffsetHeight();
	var nWidth = obj.getOffsetWidth();
	var nHeight = objPdv.form.grdEvlListCmb.getRealRowFullSize() + 2;
	
	objPdv.form.grdEvlListCmb.setOffsetHeight(nHeight);
	
	// 만약 높이가 긴 경우(지정된 값만 세팅 - 스크롤 생기게) - minheight/maxheight로 조절
	
	
	// 그리드의 row위치 이동
	var nPreValue = obj.text;
	if(!this.smfIsNull(nPreValue))
	{
		var objGrd = objPdv.form.grdEvlListCmb;
		var objDs  = objGrd.getBindDataset();
		var sComboDataColId = obj.datacolumn;
		
		var nFindIdx = objDs.findRow(sComboDataColId,nPreValue);	
		if(nFindIdx<0) nFindIdx = 0;
		
		objDs.set_rowposition(nFindIdx);
	}
		
	// 팝업을 표시한다.
	objPdv.trackPopupByComponent(obj,nLeft,nTop,nWidth,nHeight);
	
	return false;
};

this.div00_div00_pdvEvlListCmb_grdEvlListCmb_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	// 해당 오브젝트를 구한다.
	var objCombo = this.div00.form.div00.form.cboTchList;
	var objDs  = obj.getBindDataset();
	
	var sComboCodeColId = objCombo.codecolumn;
	var sComboDataColId = objCombo.datacolumn;
	
	// 선택한 값을 구한다.
	var post_index = e.row;
	var post_value = objDs.getColumn(post_index ,sComboCodeColId  );
	var post_text  = objDs.getColumn(post_index ,sComboDataColId  );
	
	
	// 콤보의 값을 가져온다.
	var pre_index = objCombo.index;
	var pre_text  = objCombo.text ;
	var pre_value = objCombo.value;
	
	// 콤보에 값을 세팅하고 리스트팝업을 닫는다.
	objCombo.set_value(post_value);
	objCombo.set_text(post_text);
	objCombo._accessibility_index = objCombo.index = post_index;
	objCombo.applyto_bindSource("value", post_value);
	
	// 콤보의 이벤트 발생(값만을 세팅한 경우 onItemChanged이벤트가 발생을 하지 않으므로 강제로 발생)
	objCombo.on_fire_onitemchanged(this, pre_index  , pre_text  , pre_value, post_index  , post_text, post_value);
	
	// 팝업DIV를 닫는다.
	obj.parent.parent.closePopup();
};

this.div00_div00_grdTxtSvy_oninput = function(obj:nexacro.Grid,e:nexacro.GridInputEventInfo)
{
	var ansTxt = obj.getEditingText(); //textArea value
	var txtLen = ansTxt.length + " / 300";
	var row = obj._currentCellRow;
	this.dsEvlprDscrpQuitmList.setColumn(row, "txtLen", txtLen);
};

this.div00_div00_div02_staHpg_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	system.execBrowser(obj.text);
};

this.div00_div00_div01_sta002_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	
};


this.eds_tados07_m01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnSetcompSizeP();
};

/**
 * 컴포넌트 사이즈 조절(PC)
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnSetcompSizeP = function(){
	if (!this.smfIsMobile()){
		var nMaxWidth = 1200 - nexacro.toNumber(this._getHScrollBarSize());
		var nFormWidth = this.getOffsetWidth();
		var vLeft = Math.floor((this.getOffsetWidth() - (this.div00.form.div00.getOffsetWidth()))/2);
		var tLeft = Math.floor((this.getOffsetWidth() - (this.div00.form.btnTemp.getOffsetWidth()))/2-((this.div00.form.btnTemp.getOffsetWidth())/2) - 2 );
		var sLeft = Math.floor((this.getOffsetWidth() - (this.div00.form.btnCfrm.getOffsetWidth()))/2+((this.div00.form.btnCfrm.getOffsetWidth())/2) + 2 );
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.div00.form.div01.setOffsetLeft(10 + nLeft);
			this.div00.form.div00.setOffsetLeft(10 + vLeft);
			this.div00.form.btnTemp.setOffsetLeft(10 + tLeft);
			this.div00.form.btnCfrm.setOffsetLeft(10 + sLeft);
		}else{
			var nLeft = 0;
			this.div00.form.div01.setOffsetLeft(10);
			this.div00.form.div00.setOffsetLeft(10);
			this.div00.form.btnTemp.setOffsetLeft(tLeft);
			this.div00.form.btnCfrm.setOffsetLeft(sLeft);
		}
		this.div00.form.resetScroll();
	}
};]]></Script>
