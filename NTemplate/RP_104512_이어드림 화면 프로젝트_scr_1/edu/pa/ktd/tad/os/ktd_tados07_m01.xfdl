******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.02.21          Kangjihye                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
 this.fv_param;	// 파라메터 세팅
 this.fv_load_chld=0;
 this.fv_load_tch=0;
 this.fv_btn=false;
 this.fv_load_page="";
 this.fn_tmpYn="N";
 this.fv_evlKndScCd="3";
 this.fv_evlYn="N";
 this.fv_child_change=false;
 this.fv_message;
 this.fv_mobile = "";
 this.cmbIdxVal=0;
 if( this.smfIsMobile() ){		
	console.log("현재는 모바일버젼입니다");
	this.fv_mobile = "_M";
}

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 this.fnonload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.fnSetcompSizeP();
	// 폼 초기화
	this.smfInitForm(obj);
	var sDate = new Date();
	
	//검사연도 세팅
	var sYear  = sDate.getFullYear().toString();
	// 전달받은 파라메터 값 세팅
	this.fv_param = this.smfGetFormParams();
	
	this._cddcCd = this.fv_param.cddcCd;
	this._cddcNm = this.fv_param.cddcNm;
	if ( this.smfIsMobile() ) {
		this.divTop.form.fnSetPtptPrd(this._cddcNm);
	}
	this.fv_evlKndScCd = this.fv_param.evlKndScCd;
	
	this.dsSearch.setColumn(0, "cddcCd", this._cddcCd);	
	this.dsSearch.setColumn(0,"shlKndScCd" , "3"); //학부모 
	this.dsSearch.setColumn(0,"evlKndScCd",this.fv_evlKndScCd);
	this.dsSearch.setColumn(0, "evlYr" 		, sYear);
	this.dsPreset.loadXML(this.fv_param.dataset1);
	this.dsChldList.loadXML(this.fv_param.dataset2);
	trace(this.dsChldList.saveXML());
	//로딩순서 초기 값setting
	this.fv_load_chld=0;
	this.fv_load_tch=0;
	this.fv_btn = false;
	this.fv_load_page="";
	//스크롤바 갱신dh
	this.smfResetScroll(this);
	this.fnSettingCmb();
	this.fnListSelect();
	
};

 /************************************************************************************************
 * EVENT Call
 ************************************************************************************************/
 this.div00_div00_grdSvy_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	console.log( "눌러진 값 :: " + e.cell + " :::: " + e.col + " ::: " + e.row + "::" ); 
	var val = 0;
	if( this.smfIsMobile() ){
		var tmp = e.cell >= 1 && e.cell < 7 ? e.cell : e.cell-6 ;	
		if( this.fv_evlYn == "N" ){
		    if(e.cell >= 1 ) {
				this.dsEvlprQuitmListAll.setColumn(e.row, "ytkSn" , tmp );
				var rowChk = this.dsEvlYdstkList.findRow("ytkSn", tmp);
			    this.dsEvlprQuitmListAll.setColumn(e.row, "evlYtkScr" , this.dsEvlYdstkList.getColumn(rowChk,"evlYtkScr"));	
			}
		}else{
			this.smfAlert("이미 완료된 설문입니다.");
		}
	}else{
		val = Math.ceil(Number(e.cell/2));
		if( this.fv_evlYn == "N" ){
			this.dsEvlprQuitmListAll.setColumn(e.row, "ytkSn" , val );
			var rowChk = this.dsEvlYdstkList.findRow("ytkSn", val);
			this.dsEvlprQuitmListAll.setColumn(e.row, "evlYtkScr" , this.dsEvlYdstkList.getColumn(rowChk,"evlYtkScr"));	
		}else{
			this.smfAlert("이미 완료된 설문입니다.");
		}
	}
};

this.div00_div00_grdTxtSvy_onclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if( this.fv_evlYn == "Y" ){
		this.smfAlert("이미 완료된 설문입니다.");
		return;
	}
};

this.div00_div00_div01_btnEx_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnDivDropDown( this.fv_btn );
};

this.div00_div00_cboTchList_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	//if( this.fv_load_page > 1 ){
		this.fv_child_change=false;
		this.fv_load_tch = e.postindex;
		this.fnListSelect();
// 		var tchDesc = "교원 기본정보 ";
// 		var tchNm = this.dsEvlTrprList.getColumn(e.postindex , "tchFlnm");
// 		var title = this.dsEvlTrprList.getColumn(e.postindex , "evlprTitlNm");
// 		this.div00.form.div00.form.staTchInfo.set_text( tchDesc + "(" + tchNm +")" );
// 		this.div00.form.div00.form.div02.form.staTchInfo.set_text(title);
// 		
// 		var fromdate = this.dsEvlprList.getColumn(0,"evlBgngYmd");
// 		var todate = this.dsEvlprList.getColumn(0,"evlEndYmd");
// 		this.div00.form.div00.form.div02.form.staTerm.set_text("<fc v='#6b5dc0'>만족도조사기간</fc> : "+fromdate+ " ~ "+ todate);
	//}	
};

this.div00_btnTemp_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	this.fn_tmpYn = "Y";
	this.div00.form.div00.form.grdTxtSvy.updateToDataset();
	if( this.fv_evlYn == "Y" ){
		this.smfAlert("이미 완료된 설문입니다.");
		return;
	}else{
		console.log(this.dsEvlprQuitmListAll.saveXML());
	    console.log(this.dsEvlprDscrpQuitmList.saveXML());
		this.fnSaveCall();
	}
};

this.div00_btnCfrm_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fn_tmpYn = "N";
	this.div00.form.div00.form.grdTxtSvy.updateToDataset();
	var cnt = this.dsEvlprQuitmListAll.findRow("ytkSn",undefined);
	if ( cnt > -1 ) {
// 	    this.dsEvlprQuitmListAll.set_rowposition(cnt);
//		this.div00.form.div00.form.grdSvy.setFocus();
		var objGrid = this.div00.form.div00.form.grdSvy;
		this.smfAlertEds((cnt+1) + '번 만족도 조사 문항에 응답하세요. ',null,()=>{this.smfSetGridScroll(objGrid,cnt);},null,{align:'center'});
		return false;
	}
	if( this.fv_evlYn == "Y" ){
		this.smfAlert("이미 완료된 설문입니다.");
		return;
	}else{
		this.fnPopUPCall();
	}
};

/*공지사항을 이동 */
this.div00_div01_btnNoti_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var param = {
		cddcCd : this._cddcCd,
		cddcNm : this._cddcNm,
		shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd") ,
		evlKndScCd : this.fv_evlKndScCd,
		dataset: this.dsResult.saveXML(),	
		dataset1: this.dsPreset.saveXML(),
		dataset2: this.dsChldList.saveXML(),	
		schdataset :  this.dsSearch.saveXML(),
	};
	this.smfSetWorkPage("pa_ktd_tad_os::ktd_tados04_t01.xfdl", param, false);
};

/*교원평가소개*/
this.div00_div01_btnInform_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var param = {
		cddcCd : this._cddcCd,
		cddcNm : this._cddcNm,
		shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd") ,
		evlKndScCd : this.fv_evlKndScCd,
		dataset: this.dsResult.saveXML(),	
		dataset1: this.dsPreset.saveXML(),	
		dataset2: this.dsChldList.saveXML(),	
		schdataset :  this.dsSearch.saveXML(),
	};
	this.smfSetWorkPage("pa_ktd_tad_os::ktd_tados09_m01.xfdl", param, false);
};


this.div00_div00_cboChldList_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	//if( this.fv_load_page > 0 ){
		this.fv_load_chld = e.postindex;
		this.fv_child_change=true;
		//this.fv_load_tch=0;
		this.fnListSelect();
	//}
};

/************************************************************************************************
 * 사용자정의 function
************************************************************************************************/
 this.fnListSelect = function () {
	this.dsSearch.setColumn(0,"instCd",this._cddcCd);
	
	//학교유치원구분코드 1:학교 2:유치원
	this.dsSearch.setColumn(0,"shlKndgrScCd","2");
	
	var tadStuInvlNo = this.dsChldList.getColumn( this.fv_load_chld ,"tadStuInvlNo");
	if( this.isNotNil(tadStuInvlNo)){
		this.dsSearch.setColumn(0,"tadStuInvlNo",tadStuInvlNo);
		this.dsSearch.setColumn(0,"evlPaptId",tadStuInvlNo);
	}
	
	var shlCrseScCd =  this.dsPreset.getColumn(0,"shlCrseScCd");
	if( this.isNotNil(shlCrseScCd)){
		this.dsSearch.setColumn(0,"shlCrseScCd",shlCrseScCd);
	}
	
	var shlCd =  this.dsPreset.getColumn(0,"shlCd");
	if( this.isNotNil(shlCd)){
		this.dsSearch.setColumn(0,"shlCd",shlCd);
	}
	
	if( this.isNotNil(this.fv_load_page) || this.fv_load_page != ""  ){		
		if( this.fv_child_change ){
			this.dsSearch.setColumn(0,"evlTrprId"	, "" );
			this.dsSearch.setColumn(0,"evlprId"		, "" );
		}else{
			this.dsSearch.setColumn(0,"evlTrprId"	, this.dsEvlTrprList.getColumn(this.fv_load_tch, "evlTrprId" ));	
			this.dsSearch.setColumn(0,"evlprId"		, this.dsEvlTrprList.getColumn(this.fv_load_tch, "evlprId" ));
		}
	}
	
	console.log("[dsSearch] " + this.dsSearch.saveXML() );
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return; 
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){ //설문정보조회 성공
				console.log("---------");
				this.fnSettingCmb();

				console.log("[ dsEvlprQuitmListAll ]" );
				console.log(this.dsEvlprQuitmListAll.saveXML());
				this.fv_load_page = "1";	
				this.fnDivDropDown(false);
				console.log("[dsEvlprDscrpQuitmList]" + this.dsEvlprDscrpQuitmList.saveXML());				
				/*console.log(this.dsEvlTrprList.saveXML());*/
				if ( this.dsEvlTrprList.rowcount > 0 ) {
					for ( var i=0; i < this.dsEvlTrprList.rowcount; i++ ) {
					    var tchFlnm = this.dsEvlTrprList.getColumn(i,"tchFlnm");
						var fnEvlprScNm = this.fnEvlprScNm(this.dsEvlTrprList.getColumn(i,"evlprScCd"));
						var aditSubj = typeof this.dsEvlTrprList.getColumn(i,"aditSubj") == "undefined" ? '' : this.dsEvlTrprList.getColumn(i,"aditSubj") ;
						var tchFlnmFull2 = tchFlnm + " / " + fnEvlprScNm + ( aditSubj.length > 0 ? "["+ aditSubj + "]" : "" )
						if ( aditSubj.length > 8 ) {
							aditSubj = aditSubj.substring(0,8) + "..."
						}
						var tchFlnmFull = tchFlnm + "/" + fnEvlprScNm + ( aditSubj.length > 0 ? "["+ aditSubj + "]" : "" )
					    this.dsEvlTrprList.setColumn(i,"tchFlnmFull",tchFlnmFull);
						this.dsEvlTrprList.setColumn(i,"tchFlnmFull2",tchFlnmFull2);
					}
					this.div00.form.div00.form.pdvEvlListCmb.form.grdEvlListCmb.setOffsetHeight(this.div00.form.div00.form.pdvEvlListCmb.form.grdEvlListCmb.getRealRowFullSize()+2);
				}
				console.log(this.dsEvlTrprList.saveXML());
				/**********************************************************/
				//설문 그리드 사이즈 조회된 갯수만큼 그려주기//
				/**********************************************************/
				this.fnGridSetting();
				/**********************************************************/
				
				this.fv_child_change=false;
				this.fnStaticSetting();
				if ( this.smfIsMobile() ) {
					this.smfResetScroll(this.div00.form.div00.form.div03.form);
				} else {
				    if ( this.dsChldList.rowcount < 3 ) {
						this.div00.form.div00.form.div03.set_formscrolltype('none');
					}
				}
				this.smfResetScroll(this.div00.form.div00.form);
			}
		});
};

this.fnSaveCall = function () {

	this.dsSearch.setColumn(0,"evlTrprId"	, this.dsEvlTrprList.getColumn(this.fv_load_tch, "evlTrprId" ));	
	this.dsSearch.setColumn(0,"evlprId"		, this.dsEvlTrprList.getColumn(this.fv_load_tch, "evlprId" ));
	this.dsSearch.setColumn(0,"tmprStrgYn"	, this.fn_tmpYn );
	console.log("----------------------------------");
	console.log(this.dsSearch.saveXML());
	console.log("----------------------------------");
	this.smfSaveService("save")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return; 
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){ //설문정보조회 성공
				console.log("---------");
				//this.fv_load_chld=0;
				//this.fv_load_tch=0;
				this.fnSettingCmb();
				this.smfResetScroll(this.div00.form.div00.form);
				console.log("[ dsEvlprQuitmListAll save]" );
				console.log(this.dsEvlprQuitmListAll.saveXML());
				console.log(this.dsEvlTrprList.saveXML());
				this.fv_evlYn="Y";
				
				if( this.fv_message == "addSearch" ) {
					this.fnAddSearchCall();
					//this.fnGotoAddSvy();
				} else {
				    this.fnListSelect();
				}
			}
		});

};
//완료 미완료 건수 정보 Setting And Static 정보
this.fnStaticSetting = function () {
	var cmpCnt = 0;
	var nonCmpCnt = 0;
	
	var cnt = this.dsEvlTrprList.getRowCount();
	
	for( var i = 0; i < cnt ; i++ ){
		if( this.dsEvlTrprList.getColumn(i,"evlYn") == "Y" ){
			cmpCnt = cmpCnt+1;
		}else{
			nonCmpCnt = nonCmpCnt+1;
		}
	}
	this.div00.form.div00.form.div00.form.cnt1.set_text(nonCmpCnt + "건" );
	this.div00.form.div00.form.div00.form.cnt2.set_text(cmpCnt + "건" );
	
	var evlprScCd = this.dsEvlTrprList.getColumn(this.fv_load_tch , "evlprScCd");
	var evlprScNm = "";
	if( evlprScCd == "301" ) {
		evlprScNm = "[원장 만족도조사]";
	} else if( evlprScCd == "303" ) {
		evlprScNm = "[담임 만족도조사]";
	} else if ( evlprScCd == "302" || evlprScCd == "304" ) {
		evlprScNm = "[원감 만족도조사]";
	} else if ( evlprScCd == "305" || evlprScCd == "306" || evlprScCd == "307" || evlprScCd == "308" || evlprScCd == "309" ) {
		evlprScNm = "[비교과교사 만족도조사]";
	}else if ( evlprScCd == "311" ) {
		evlprScNm = "[수석 만족도조사]";	
	}else if ( evlprScCd == "811") {
		evlprScNm = "[비담임 만족도조사]";		
	}
	/*
	* 담당과목 우선순위 
	* 1.chgChrgeSbjtNm(변경담당과목명) , 2.leSbjtNm(담당과목명), 3.chrgeSbjtCdNm(전공과목명)
	*/
 	var chgChrgeSbjtNm = this.dsEvlTrprDtlList.getColumn(0 , "chgChrgeSbjtNm");
 	var leSbjtNm = this.dsEvlTrprDtlList.getColumn(0 , "leSbjtNm");
 	var chrgeSbjtCdNm = this.dsEvlTrprDtlList.getColumn(0 , "chrgeSbjtCdNm");
    console.log(this.dsEvlTrprDtlList.saveXML());
	var sbj = "";
	if ( typeof chgChrgeSbjtNm != "undefined" && chgChrgeSbjtNm.length > 0 ) {
		sbj = chgChrgeSbjtNm;
	} else if ( typeof leSbjtNm != "undefined" && leSbjtNm.length > 0 ) {
		sbj = leSbjtNm;
	} else if ( typeof chrgeSbjtCdNm != "undefined" && chrgeSbjtCdNm.length > 0 ) {
		sbj = chrgeSbjtCdNm;
	}
	
	var stuFlnm = this.dsEvlTrprDtlList.getColumn(0 , "stuFlnm");
	var hmpg1Addr = this.dsEvlTrprDtlList.getColumn(0 , "hmpg1Addr");
	var hmpg2Addr = this.dsEvlTrprDtlList.getColumn(0 , "hmpg2Addr");
	var appntScCd = this.dsEvlTrprDtlList.getColumn(0, "appntScCd");
	var appntScCdNm = this.dsEvlTrprDtlList.getColumn(0, "appntScCdNm");
	var tchDesc = "<fc v='#6b5dc0'>교원 기본정보</fc> ";
	var tchNm = this.dsEvlTrprDtlList.getColumn(0 , "tchFlnm");
	var title = this.dsEvlTrprList.getColumn(this.fv_load_tch , "evlprTitlNm");
	this.div00.form.div00.form.div01.form.staTchNm.set_text(tchNm+evlprScNm)
	this.div00.form.div00.form.staTchInfo.set_text( tchDesc + "(" + tchNm +" "+( appntScCd == 1 || appntScCd == 2 ? appntScCdNm : "선생님" ) + ")" );
	this.div00.form.div00.form.div02.form.staTchInfo.set_text(title);
	this.div00.form.div00.form.div01.form.staSbj.set_text(sbj);
	this.div00.form.div00.form.div01.form.staChldNm.set_text(stuFlnm);
	this.div00.form.div00.form.div01.form.staHpg.set_text(hmpg1Addr);
	this.div00.form.div00.form.div01.form.staHpg2.set_text(hmpg2Addr);
	
	console.log("★★★★★★★★★★★★★★★★★★★★★★★★★");
	console.log(this.dsEvlprList.saveXML());
	console.log("★★★★★★★★★★★★★★★★★★★★★★★★★");
	var fromdate = this.dsEvlprList.getColumn(0,"evlBgngYmd");
	var todate = this.dsEvlprList.getColumn(0,"evlEndYmd");
	this.div00.form.div00.form.div02.form.staTerm.set_text("<fc v='#6b5dc0'>만족도조사기간</fc> : "+fromdate+ " ~ "+ todate);
	var dscrpGdccCn = this.dsEvlprList.getColumn(0,"dscrpGdccCn");
	if ( this.dsEvlprList.getRowCount() > 0 && dscrpGdccCn != "" ) {
		this.div00.form.div00.form.sta03.set_text("※ " + dscrpGdccCn);
		this.div00.form.div00.form.sta03.set_visible(true);
	} else {
		this.div00.form.div00.form.sta03.set_text("");
		this.div00.form.div00.form.sta03.set_visible(false);
	}
	if ( this.dsEvlprList.getRowCount() > 0 ) {
		if ( this.dsEvlprList.getColumn(0,"evlYn") == "Y" ) {
			this.div00.form.btnTemp.set_visible(false);
			this.div00.form.btnCfrm.set_visible(false);
			this.div00.form.div00.form.div06.set_visible(true);
			this.div00.form.div00.form.grdSvy.set_visible(false);
			this.div00.form.div00.form.sta03.set_visible(false);
			this.div00.form.div00.form.grdTxtSvy.set_visible(false);
		} else {
			this.div00.form.btnTemp.set_visible(true);
			this.div00.form.btnCfrm.set_visible(true);
			this.div00.form.div00.form.div06.set_visible(false);
			this.div00.form.div00.form.grdSvy.set_visible(true);
			this.div00.form.div00.form.sta03.set_visible(true);
			this.div00.form.div00.form.grdTxtSvy.set_visible(true);
		}
	}
};

this.fnGridSetting = function () {
	var hp = this.div00.form.div00.form.div03.form.grdChldList.getRealRowFullSize();
	this.div00.form.div00.form.div03.form.grdChldList.setOffsetHeight(hp);
	
	var hp1 = 0;
	var hp2 = 0;
	if ( this.dsEvlprList.getColumn(0,"evlYn") == "N" ) {
		hp1 = this.div00.form.div00.form.grdSvy.getRealRowFullSize();
		hp2 = this.div00.form.div00.form.grdTxtSvy.getRealRowFullSize();
	}
	this.div00.form.div00.form.grdSvy.setOffsetHeight(hp1);	
	this.div00.form.div00.form.grdTxtSvy.setOffsetHeight(hp2);		
};


this.fnDivShow = function ( val ) {
	var setHeight = 0;
	var setHeight2 = 0;
	var setHeight3 = 0;
	var setHieght4 = 0;
	var setTop;
	if ( val ) {
	    if ( this.smfIsMobile() ) {
		  setHeight = 60;
		  setHeight2 = 258;
		  setHeight3 = 60;
		  setHieght4 = 110;
		  setTop = 20;
		} else {
		  setHeight = 44;
		  setHeight2 = 258;
		  setHeight3 = 44;
		  setHieght4 = 110;
		  setTop = 20;
		}
	} 
