				this.div00.form.div00.form.div01.form.staSbj.setOffsetHeight(0);
				this.div00.form.div00.form.div01.form.sta003.set_visible(false);
				this.div00.form.div00.form.div01.form.staSbj.set_visible(false);
			} else {
