          <Column id="coaDataPrcsNocs" type="INT" size="10" sumtext="처리건수"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listCoaRcritCtr</Col>
            <Col id="url">uds_ueu_dd00_712.do</Col>
            <Col id="outDatasets">dsCoaCtrBsc</Col>
            <Col id="inDatasets">dsSearch</Col>
          </Row>
          <Row>
            <Col id="inDatasets">dsSearch</Col>
            <Col id="outDatasets">dsMain</Col>
            <Col id="url">uds_ueu_dd03_001.do</Col>
            <Col id="id">listWrkHstr</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" oncolumnchanged="dsSearch_oncolumnchanged">
        <ColumnInfo>
          <Column id="coaAyr" type="STRING" size="256" sumtext="대입학년도"/>
          <Column id="coaRcritScCd" type="STRING" size="256" sumtext="대입모집구분코"/>
          <Column id="coaDataPrcsCd" type="STRING" size="256" sumtext="대입자료처리코"/>
          <Column id="coaRcritScNm" type="STRING" size="256"/>
          <Column id="cddcScCd" type="STRING" size="256" sumtext="시도교육청구분코"/>
          <Column id="instClfCd" type="STRING" size="255" sumtext="기관분류코드"/>
          <Column id="coaWrkCd" type="STRING" size="256" sumtext="대입업무구분코드"/>
          <Column id="coaDataRegDt" type="STRING" size="256" sumtext="대입자료등록일시"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsCoaCtrBsc" oncolumnchanged="dsSearch_oncolumnchanged" useclientlayout="true">
        <ColumnInfo>
          <Column id="coaAyr" type="STRING" size="256" sumtext="대입학년도"/>
          <Column id="coaRcritScCd" type="STRING" size="256" sumtext="대입모집구분코"/>
          <Column id="rcritScByBgngYmd" type="STRING" size="256" sumtext="모집구분별시작일자"/>
          <Column id="rcritScByEndYmd" type="STRING" size="255" sumtext="모집구분별종료일자"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsCoaWrkCd" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="FirstCode" type="STRING" size="30" value="ALL" datapath=""/>
          <ConstColumn id="ClfCdValue" type="STRING" size="30" value="COA_WRK_CD"/>
          <ConstColumn id="FilterExpr" type="STRING" size="30" value="unyCdValue == 'U01' || unyCdValue == 'U02' || unyCdValue == 'U03' || unyCdValue == 'U04' || unyCdValue == 'U06' || unyCdValue == 'U07'"/>
          <ConstColumn id="UnyCdGrpId" type="STRING" size="30" value=""/>
          <ConstColumn id="BfrClfCdValue" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd1Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd2Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd3Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd4Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd5Value" type="STRING" size="30" value=""/>
          <Column id="pgeId" type="STRING" size="256"/>
          <Column id="clfCdValue" type="STRING" size="30"/>
          <Column id="clfCdValueNm" type="STRING" size="120"/>
          <Column id="clfCdUseYn" type="STRING" size="150"/>
          <Column id="unyCdValue" type="STRING" size="10"/>
          <Column id="unyCdValueNm" type="STRING" size="30"/>
          <Column id="userDfnCd1Value" type="STRING" size="100"/>
          <Column id="userDfnCd2Value" type="STRING" size="100"/>
          <Column id="userDfnCd3Value" type="STRING" size="100"/>
          <Column id="userDfnCd4Value" type="STRING" size="100"/>
          <Column id="userDfnCd5Value" type="STRING" size="100"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsExcel" useclientlayout="true" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="chk" type="BIGDECIMAL" size="15"/>
          <Column id="orgCd" type="STRING" size="256" sumtext="조직코드"/>
          <Column id="orgNm" type="STRING" size="256" sumtext="조직구분명"/>
          <Column id="coaDataRgtrId" type="STRING" size="256" sumtext="처리자ID"/>
          <Column id="coaDataRegIpAddr" type="STRING" size="256" sumtext="처리자IP주소"/>
          <Column id="coaDataRegDt" type="STRING" size="256" sumtext="처리자IP시기"/>
          <Column id="coaWrkCd" type="STRING" size="256" sumtext="대입업무코드"/>
          <Column id="coaWrkNm" type="STRING" size="256" sumtext="대입업무명"/>
