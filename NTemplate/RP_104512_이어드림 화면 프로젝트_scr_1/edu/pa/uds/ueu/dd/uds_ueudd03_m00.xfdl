              <Calendar id="calCoaDataRegDt" taborder="7" left="staInqDd:0" top="20" width="120" height="30" value="20230306" dateformat="yyyy.MM.dd." initvalueid="ivCalNormal" editformat="yyyy.MM.dd" onchanged="divSearch_calCoaDataRegDt_onchanged" cssclass="sta_WF_Input01" validate="required:true"/>
