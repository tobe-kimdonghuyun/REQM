    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    대입전형자료업무이력조회
*  @FileName 	uds_ueudd03_m00
*  @Creator 	최재영
*  @CreateDate 	2022.05.31  
*  @Desction    대입전형-대학-대입전형자료업무이력조회
************** 소스 수정 이력 ***********************************************
*  date				Modifier				Description
*******************************************************************************
*  2022.05.31		최재영					최초 생성
*  2023.03.08		최재영					개발
*******************************************************************************
*/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::uds_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Div 초기화
	this.smfInitDiv(obj);
	
	// 대입서비스체크
	this.udsfCoaSvcChck(function(){
		// 초기화
		this.fnInit(obj); 
		
		// 공통코드 조회
		this.smfCodeList("code", [this.dsCoaWrkCd])
			.run()
			.callback(function(callbackParams){
				if(callbackParams.errors) return;
				
				this.fnSearch(); // 조회
			});
	});
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
	
	if(svcid == "listCoaRcritCtr"){
		
		var coaAyr       = this.dsCoaCtrBsc.getColumn(0,"coaAyr");
		var coaRcritScCd = this.dsCoaCtrBsc.getColumn(0,"coaRcritScCd");
		var coaRcritScNm = this.udsfGetCoaRcritScNm(coaRcritScCd);
		
		if(!this.isNil(coaAyr) && !this.isNil(coaRcritScCd)){
			this.dsSearch.setColumn(0,"coaAyr" , coaAyr);            // 대입학년도
			this.dsSearch.setColumn(0,"coaRcritScCd", coaRcritScCd); // 대입모집구분코드
			this.dsSearch.setColumn(0,"coaRcritScNm", coaRcritScNm); // 대입모집구분명
			
		}else{
			coaAyr       = this.dsSearch.getColumn(0,"coaAyr");
		    coaRcritScCd = this.dsSearch.getColumn(0,"coaRcritScCd");
			coaRcritScNm = this.dsSearch.getColumn(0,"coaRcritScNm");
		}
		
		this.divSearch_calCoaDataRegDt_onchanged() // 조회일 변경쿼리
		
	}else if(svcid == "listWrkHstr"){
	
		//엑셀버튼 비활성화
		if(this.dsMain.getRowCount() > 0){
			this.btnExcelDown.set_enable("true");
		}else{
			this.btnExcelDown.set_enable("false");

		}
	}	
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 대입모집기준 조회 FUNCTION
*/
this.fnCoaRcritCtr = function()
{
	// 조회 서비스
	this.smfSearchService("listCoaRcritCtr")
		.confirmIfModifiedDataset(this.dsCoaCtrBsc) // 데이터가 변경되었으면 확인메시지
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		}); // 콜백
};	

/**
 * @description 업무이력 목록조회 FUNCTION
*/
this.fnWrkHstrList = function()
{
	// 조회 서비스
	this.smfSearchService("listWrkHstr")
		.confirmIfModifiedDataset(this.dsMain) // 데이터가 변경되었으면 확인메시지
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		}); // 콜백
};	

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/**
 * @description 초기화 FUNCTION
 */
this.fnInit = function(obj){
	this.dsSearch.setColumn(0, "coaAyr", this.udsv_coaAyr);
	this.dsSearch.setColumn(0, "coaRcritScCd", this.udsv_coaRcritScCd);
	this.dsSearch.setColumn(0, "coaRcritScNm", this.udsv_coaRcritScNm);
	this.dsSearch.setColumn(0, "uvstOrgCd", this.udsv_instCd);
	this.dsSearch.setColumn(0, "coaDataRegDt",this.smfToday()); // 조회일
}
/**
 * @description 초기화 FUNCTION
 */
this.fnSearch = function(obj){
	this.fnCoaRcritCtr(); // 대입모집기준 조회
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 조회버튼클릭 FUNCTION
*/
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnWrkHstrList();
};

/**
 * @description 엑셀버튼클릭 FUNCTION
*/
this.btnExcelDown_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsExcel.clearData();
	this.dsExcel.copyData(this.dsMain);
	this.dsExcel.set_keystring("S:+chk, O:chk['en-US']{'numeric':true}");
	
	var objOption = {	objGrid : this.grdExcel
					,	sheetname : "Sheet1"
					,   filename : "대입전형자료업무이력"
					};
	
	this.smfExcelExport(objOption);
};

/**
 * @description 조회일자 변경 FUNCTION
*/
this.divSearch_calCoaDataRegDt_onchanged = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{
	
	var objValue         = this.divSearch.form.calCoaDataRegDt.value;
	var rcritScByBgngYmd = this.dsCoaCtrBsc.getColumn(0,"rcritScByBgngYmd"); // 모집시작일자
	var rcritScByEndYmd  = this.dsCoaCtrBsc.getColumn(0,"rcritScByEndYmd");  // 모집종료일자

	
	if(objValue < rcritScByBgngYmd || rcritScByEndYmd < objValue){
		//this.divSearch.form.calCoaDataRegDt.set_value(rcritScByBgngYmd);
		this.dsSearch.setColumn(0, "coaDataRegDt", rcritScByBgngYmd);
	}
};
]]></Script>
    <Objects>
      <Dataset id="dsMain" useclientlayout="true" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
