/**
 * 실행활성화
 * @param : ds - 데이터셋
 * @param : nRow - rowposition
 */
this.fnExecuteEnable = function(bEnable){
	this.setWaitCursor(!bEnable);
	this.divSearch.form.btnSearch.set_enable(bEnable);
	this.divSearch.form.btnEvlUnit.set_enable(bEnable);
	this.btnCoaDataPath.set_enable(bEnable);
	this.btnCoaDataLocalDbCrt.set_enable(bEnable);
	
	var bldRmvYn = this.dsSearch.getColumn(0, "bldRmvYn");
	if(bldRmvYn == "Y"){
		this.btnExecuteBldRmv.set_enable(bEnable);
	} else {
		this.btnExecute.set_enable(bEnable);
	}
};

/**
* @description 블라인드처리
*/
this.fnDoBldCrt = function(coaSale){
	//0.학생정보, 1.인적사항, 2.학적사항, 11.봉사활동, 50.정정대장
	return coaSale.replaceBld(1, 1)   //SHL_CD
				  .replaceBld(1, 5)   //STU_FLNM
				  .replaceBld(1, 6)   //STU_RRNO
				  .replaceBld(1, 7)   //SCHOR_SPABL_MTE_CN 
				  .replaceBld(2, 4)   //SCHOR_FLCTN_MTE_CN
				  .replaceBld(11, 4)  //PLACE_MNGT_INST_NM 
				  .replaceBld(12, 4)  //PLACE_MNGT_INST_NM
				  .replaceBld(50, 4)  //STU_FLNM
}

/**
* @description 정정대장 블라인드처리
*/
this.fnDoBldCrtCrctRgrUinl = function(coaSale){
	var nNum = 50; //정정대장
	var aCoaSale = coaSale.split(/\n/g);
	return aCoaSale.reduce((a, c, i) => {
		if(c.indexOf(`${nNum}^`) == 0){
			a.push('');
		}else if(this.smfIsNull(c.match(/^[0-9]+\^/gi)) && a.length > 0 && a[a.length - 1] == ''){
			if(c.trim() == 'null') a.push(c);
		}else{
			a.push(c);
		}
		
		return a;
	}, []).filter((m) => m != '').join('\n');
}

/**
* @description 읽기할 파일을 this.fvQueFiles에 담는다.
* 
*/
this.fnTakeFileInfoR = function(i){
	var ds = this.fnCurDataset();

	var coaSeleFileNm = ds.getColumn(i, "coaSeleFileNm");
	var coaImageFileNm = ds.getColumn(i, "coaImageFileNm");
	var isCrctRgrUinl = ds.getColumn(i, 'crctRgrInclsYn') != 'Y';
	
	var coaSeleFilePath = this.fvCoaDataDownPath + "\\" + coaSeleFileNm + ".enc";
	var coaSaleFileExist = this.fvObjExtCommon._ext_existFile(coaSeleFilePath);
	
	this.fvQueFiles.enqueue({
		'idx' : i,
		'nm' : coaSeleFilePath,
		'cn' : '',
		'type' : 'T', //txt
		'exist' : coaSaleFileExist,
		'mode' : 'R',
	});
	
	if(!this.fnIsBldCrt()){
		var coaImageFilePath = this.fvCoaDataDownPath + "\\" + coaImageFileNm + ".enc";
		var coaImageFileExist = this.fvObjExtCommon._ext_existFile(coaImageFilePath);
		
		this.fvQueFiles.enqueue({
			'idx' : i,
			'nm' : coaImageFilePath,
			'cn' : '',
			'type' : 'T', //txt
			'exist' : coaImageFileExist,
			'mode' : 'R',
		});
	}
}

/**
* @description 쓰기할 파일을 this.fvQueFiles에 담는다.
* 
*/
this.fnTakeFileInfoW = function(){
	var ds = this.fnCurDataset();
	var mf = this.fvQueMergeFiles.dequeue();
	var i = mf.idx;
	
	var coaSeleFileNm = ds.getColumn(i, "coaSeleFileNm");
	var coaImageFileNm = ds.getColumn(i, "coaImageFileNm");
	var crctRgrInclsYn = ds.getColumn(i, "crctRgrInclsYn");
	var uvstExmtNo = ds.getColumn(i, "uvstExmtNo");
	var isCrctRgrUinl = ds.getColumn(i, 'crctRgrInclsYn') != 'Y';
	
	var seleFile = mf.sele;
	var imageFile = mf.image;
	
	// 대칭키 복호화
	var symmKey = this.objKCASE.callMethod("DecryptEnvelopedData", this.fvKeyUserDn, "", ds.getColumn(i, "uvstEncSymmKey"));
	
	//대입파일 복호화
	var coaSaleFileExist = seleFile.exist;
	var coaSeleFileCn = '';
	
	//복호화 재시도 3회
	if(coaSaleFileExist && !this.smfIsNull(seleFile.cn)){
		for(var retryIdx = 0; retryIdx < 4; retryIdx++){
			if(retryIdx != 0) trace('파일 retry : ' + retryIdx);
			
			coaSeleFileCn = seleFile.cn;
			coaSeleFileCn = this.objKCASE.callMethod("SymmDecrypt", "SEED", symmKey, coaSeleFileCn);
			coaSeleFileCn = this.fvObjExtCommon._ext_getURLdecode(coaSeleFileCn, "utf-8");
			
			if(coaSeleFileCn[0] == '0' && coaSeleFileCn[1] == '^'){
				// 전형자료 추가 정보 입력
				coaSeleFileCn = coaSeleFileCn.replace(new RegExp('\\^\r\n'), '\^' + crctRgrInclsYn 
																			+ '\^' + (this.fnIsBldCrt() === true ? ' ' : uvstExmtNo)
																			+ '\^' + coaSeleFileNm
																			+ '\^' + (this.fnIsBldCrt() === true ? ' ' : coaImageFileNm) 
																			+ '\^' + '\r\n');
				
				//대입파일 블라인드 작업
				if(this.fnIsBldCrt() === true) coaSeleFileCn = this.fnDoBldCrt(coaSeleFileCn);
				if(isCrctRgrUinl === true) coaSeleFileCn = this.fnDoBldCrtCrctRgrUinl(coaSeleFileCn);
				
				break;
			}
			coaSeleFileCn = '';
		}
	}else{
		coaSeleFileCn = '';
	}
	
	this.fvQueFiles.enqueue({
		'idx' : i,
		'nm' : this.fvCoaDataPath + "\\" + coaSeleFileNm,
		'cn' : coaSeleFileCn,
		'type' : 'T', //txt
		'col' : !this.fnIsBldCrt() ? 'coaSaleFilePrcsYn' : 'cmptnYn',
		'exist' : coaSaleFileExist,
		'mode' : 'W',
	});
	
	if(!this.smfIsNull(coaSeleFileCn) && !this.fnIsBldCrt()){
		//이미지 파일
		var coaImageFileExist = imageFile.exist;
		var coaImageFileCn = '';
		
		if(coaImageFileExist && !this.smfIsNull(imageFile.cn)){
			for(var retryIdx = 0; retryIdx < 4; retryIdx++){
				if(retryIdx != 0) trace('이미지 retry : ' + retryIdx);
			
				coaImageFileCn = imageFile.cn;
				coaImageFileCn = this.fvObjExtCommon._ext_getURLdecode(coaImageFileCn, "utf-8");
				coaImageFileCn = this.objKCASE.callMethod("SymmDecrypt", "SEED", symmKey, coaImageFileCn);
				if(coaImageFileCn.length > 10) break;
				
				coaImageFileCn = '';
			}
		}else{
			coaImageFileCn = '';
		}
		
		this.fvQueFiles.enqueue({
			'idx' : i,
			'nm' : this.fvCoaDataPath + "\\" + coaImageFileNm,
			'cn' : coaImageFileCn,
			'type' : 'B', //binary
			'col' : 'coaImagepPrcsYn',
			'colChk' : ['coaSaleFilePrcsYn', 'coaImagepPrcsYn'],
			'colCmptn' : 'cmptnYn',
			'exist' : coaImageFileExist && coaSaleFileExist,
			'mode' : 'W',
		});
	}
	
	var hasError = false;
	if(this.smfIsNull(this.fvQueFiles.first().cn)) hasError = true;
	if(!this.fnIsBldCrt() && !hasError && this.smfIsNull(this.fvQueFiles.first(1).cn)) hasError = true;
	
	//오류 처리
	if(hasError){
		var f = this.fvQueFiles.first();
		this.fvQueFiles.clear();
		this.fnVirtualFileCallbackWNextPrcs(ds, f);
		return false;
	}
	
	return true;
}

/**
* @description VirtualFile 열기
*/
this.fnVirtualFileOpen = function(fileInfo){
	if(fileInfo.mode == 'R'){
		//파일이 없을때 
		if(fileInfo.exist == false){
			this.fnVirtualFileCallbackR();
			return;
		}
	}

	var opt = fileInfo['type'] == 'T' ? VirtualFile.openText : VirtualFile.openBinary;
	opt = fileInfo['mode'] == 'R' ? opt | VirtualFile.openRead : opt | VirtualFile.openWrite;
	this.VirtualFile00.open(fileInfo['nm'], opt);
}

/**
 * @description d00을 ds으로 복사
 */
this.fnCopyDs00 = function(){
	var ds00 = this.fnCurDataset(true);
	var ds = this.fnCurDataset();
				
	//인덱스로 바로 넣기
	for(var i = 0; i < ds00.getRowCount(); i++){
		var idx = ds00.getColumn(i, 'idx');
		var coaApstStsCd = ds00.getColumn(i, 'coaApstStsCd');
		var coaApstStsNm = ds00.getColumn(i, 'coaApstStsNm');
		
		ds.setColumn(idx, 'coaApstStsCd', coaApstStsCd);
		ds.setColumn(idx, 'coaApstStsNm', coaApstStsNm);
	}
	
	ds.applyChange();
}

this.fnRunDesc = function(){
	this.fvPrcsType = 1;

	//블라인드 여부에 따른 전형자료 위치 변경
	this.fvCoaDataPath = this.fnIsBldCrt() ? this.fvCoaDataBlindPath : this.fvCoaDataDecrPath;

	this.fvCoaWrkHstrService.send(false, function(){
		// 실행 비활성화
		this.fnExecuteEnable(false);
		
		// 다음 실행
		this.fnDoNext();
	});
}

/**
 * @description fvQueIdx의 인덱스로 파일정보를 만들고 파일오픈함.
 */
this.fnDoNext = function(){
	//인덱스로 저장할 파일 가져와 Open
	if(this.fvQueIdx.isEmpty()){
		if(this.fvQueIdxAll.isEmpty()){
			this.fnCompleteCallback();
		}else{
			this.dsMainTrgt.clearData();
			
			//executeBldCrt 서브스 호출
			for(var i = 0; i < this.fvMaxCnt; i++){
				//원본데이터셋 타겟데이터셋으로 이동 복사
				if(this.fvQueIdxAll.isEmpty()){
					break;
				}else{
					var idx = this.fvQueIdxAll.dequeue();
					var nRow = this.dsMainTrgt.addRow();
					this.dsMainTrgt.copyRow(nRow, this.dsMain, idx);
					this.dsMainTrgt.setColumn(nRow, 'idx', idx);
				}
			}
			
			this.fnExecuteBldCrt(function(){
				var nCnt = this.dsMainTrgt.getRowCount();
				for(var i = 0; i < nCnt; i++){
					this.fvQueIdx.enqueue(this.dsMainTrgt.getColumn(i, 'idx'));
				}
			});
		}
	}else{
		var idx = this.fvQueIdx.dequeue();
		this.fnTakeFileInfoR(idx);
		this.fnVirtualFileOpen(this.fvQueFiles.first());
	}
}

/**
 * @description 파일 읽기 콜백 ( 암호화 수신 파일 )
 */
this.fnVirtualFileCallbackR = function(){
	var ds = this.fnCurDataset();
	var f = this.fvQueFiles.dequeue();
	
	//머지파일에 enqueue
	if(this.fvQueMergeFiles.isEmpty()){
		this.fvQueMergeFiles.enqueue({ idx : f.idx, sele : f });
	}else{
		var mf = this.fvQueMergeFiles.first();
		mf.image = f;
	}
	
	//쓰기 파일 생성
	if(this.fvQueFiles.isEmpty()){
		//쓰기 시작
		if(!this.fnTakeFileInfoW()) return;
	}
	
	this.fnVirtualFileOpen(this.fvQueFiles.first());
}

/**
 * @description 파일 쓰기 콜백 ( 복호화 파일 )
 */
this.fnVirtualFileCallbackW = function(){
	var ds = this.fnCurDataset();
	var f = this.fvQueFiles.dequeue();
	
	//로우의 부분 완료 설정 ( 전형자료 or 이미지 )
	if(!this.smfIsNull(f['cn'])){
		ds.setColumn(f['idx'], f['col'], 'Y');
	}

	//로우 완료 설정
	if(!this.smfIsNull(f['colChk'])){
		var chkCols = Array.isArray(f['colChk']) ? f['colChk'] : [f['colChk']];
		if(chkCols.every((col) =>ds.getColumn(f['idx'], col) == 'Y')){
			ds.setColumn(f['idx'], f['colCmptn'], 'Y');
		}
	}
	
	if(this.fvQueFiles.isEmpty()){
		this.fnVirtualFileCallbackWNextPrcs(ds, f);
	}else{
		this.fnVirtualFileOpen(this.fvQueFiles.first());
	}
}

/**
 * @description 복호화 파일 쓰기 다음 처리
 */
this.fnVirtualFileCallbackWNextPrcs = function(ds, f){
	//원본데이터셋 타겟데이터셋으로 이동 복사
	var nRow = this.dsMainTrgt.addRow();
	this.dsMainTrgt.copyRow(nRow, ds, f['idx']);
	this.dsMainTrgt.setColumn(nRow, 'idx', f['idx']);
	
	//하이라이트
	this.fnToggleHighlight(f['idx']);
	
	//수신파일 없음
	if(f['exist'] == false) ds.setColumn(f['idx'], 'rmkCn', '수신파일없음');
	else ds.setColumn(f['idx'], 'rmkCn', '');
	
	if(this.fvQueIdx.isEmpty()){
		this.fnExecuteBldCrtCmptn();
	}else{
		this.fnDoNext();
	}
}

/**
 * @description grdMain expr 상태 
 */
this.fnGetCoaApstStsNm = function(coaApstStsCd, coaApstStsNm){
	return this.smfIsNull(coaApstStsNm) ? coaApstStsCd : coaApstStsNm;
}

/**
 * @description 공통에서 경로 가져오기
 */
this.fnCoaDataPathCallback = function(){
	this.fvCoaDataDownPath = this.udsfGetCoaDataDownPath();   // 수신경로
	this.fvCoaDataBlindPath = this.udsfGetCoaDataBlindPath(); // 블라인드자료경로
	this.fvCoaDataDecrPath = this.udsfGetCoaDataDecrPath();   // 블라인드해제자료경로
}

/**
 * @description 전형자료로컬DB생성 Callback
 */
this.fnCoaDataLocalDbCrtCallback = function(){
	
}

/**
 * @description 평가단위코드 팝업 콜백
 */
this.fnCoaEvlUnitCallback = function(context, responseParams, sender){
	if(context.listCoaEvlUnitId.length == 0 || context.totalCnt == context.listCoaEvlUnitId.length){
		this.dsSearch.setColumn(0, 'coaEvlUnitId', '');
		this.dsSearch.setColumn(0, 'coaEvlUnitNm', '- 전체 -');
	}else{
		this.dsSearch.setColumn(0, 'coaEvlUnitId', context.listCoaEvlUnitId.join(','));
		if(context.listCoaEvlUnitId.length == 1){
			this.dsSearch.setColumn(0, 'coaEvlUnitNm', context.listCoaEvlUnitNm[0]);
		}else{
			this.dsSearch.setColumn(0, 'coaEvlUnitNm', context.listCoaEvlUnitNm[0] + '외 ' + (context.listCoaEvlUnitId.length - 1) + '건');
		}
	}
}

/**
 * @description 하이라이트 토글
 */
this.fnToggleHighlight = function(idx){
	//하이라이트 제거
	if(this.fvLastWrkIdx > -1){
		this.dsMain.setColumn(this.fvLastWrkIdx, 'highlight', '');
		this.dsMain.setColumn(this.fvLastWrkIdx, '_chk', '');
	}
	
	if(idx > -1){
		this.dsMain.setColumn(idx, 'highlight', '1');
		
		//row idx 이동 ( UI )
		this.grdMain.setCellPos(1, idx);
		this.grdMain.redrawExprCell();
	}
	
	this.fvLastWrkIdx = idx;
}

/**
 * @description 복호화진행상태 표시
 */
this.fnDrawProgras = function(){
	var ttlCnt = this.fvChkCnt;
	var cmptnCnt = this.fvChkCnt - this.fvQueIdxAll.length();
	var cmptnRate = ttlCnt == 0 ? 0 : (cmptnCnt / ttlCnt) * 100;
	this.divPrcsPrgSts.form.pgbCmptn.set_pos(cmptnRate);
	this.divPrcsPrgSts.form.pgbCmptn.set_text(Math.floor(cmptnRate) + "%");
	
	var decPrgSts = this.smfSetComma(cmptnCnt) + " / " + this.smfSetComma(ttlCnt);
	
	this.divPrcsPrgSts.form.edtDecPrgSts.set_value(decPrgSts);
}

/**
 * @description 그리드 순번 함수
 */
this.fnRowIndex = function(currow){
	return currow + 1;
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

/**
 * @description 그리드 헤더 클릭
*/
this.grdMain_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var columnName = obj.getCellProperty("body",e.cell,"text");
	if ("bind:_chk" == columnName){
		this.smfToggleChkHeader(obj, e, this.fnRenderGridCheckbox);
	}else{
		// 정렬
		this.smfCheckAndSort(obj, e);
	}
};

/**
 * @description 조회
 */
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsMain.clearData();
	this.dsPageInfo.setColumn(0, 'pageIndex', 1);
	
	this.fnSearch();
};

/**
 * @description 평가단위 선택
 */
this.divSearch_btnEvlUnit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var coaEvlUnitId = this.dsSearch.getColumn(0, 'coaEvlUnitId');
	var listCoaEvlUnitId = this.smfIsNull(coaEvlUnitId) ? [] : this.dsSearch.getColumn(0, 'coaEvlUnitId').split(',');
	
	// 팝업 파라메터
	var popupParams = {
		callback: this.fnCoaEvlUnitCallback, // 콜백함수 지정
		sender: obj, // sender 지정
		params: {
			procType : "save", // 처리타입 지정
			listCoaEvlUnitId : listCoaEvlUnitId
		},
	};

	// 모달팝업 실행
	this.smfDialog("uds_ueudd00_p09", "pa_uds_ueu_dd::uds_ueudd00_p10.xfdl", popupParams);
};

/**
 * @description 전형자료복호화
 */
this.btnExecute_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var ds = this.fnCurDataset();

	const chkList = ds.extractRows("_chk == 1");
	if(this.isNil(chkList) || ds.getRowCount() == 0){
		this.smfAlert("선택된 자료가 없습니다. 자료를 선택하여 주십시오.", function(){});
		return false;
	}
	
	this.smfConfirm((this.fnIsBldCrt() ? "블라인드자료" : "블라인드해제자료") + " 복호화를 실행하시겠습니까?", function(confirmParams){
		if(confirmParams.confirmResult){
			this.dsSearch.setColumn(0, 'bldRmvYn', this.fnIsBldCrt() ? 'N' : 'Y');
		
			this.fvQueIdxAll.clear();
			this.fvQueIdx.clear();									  // 데이터셋 인덱스 큐 버퍼
			this.fvQueFiles.clear();								  // 파일 큐 버퍼
			this.fvQueMergeFiles.clear();
			this.dsMainTrgt.clearData();
			
			this.fvQueIdxAll.init(chkList);
			this.fvChkCnt = this.fvQueIdxAll.length();
			
			this.fnDrawProgras();
			
			this.fnCheckFolder([this.udsfGetCoaDataPath(), this.fvCoaDataDownPath, this.fvCoaDataBlindPath, this.fvCoaDataDecrPath]);
		}else{
			return false;
		}
	});
};

/*
* @description 폴더 권한 확인 및 파일 쓰기
*/
this.VirtualFile00_onsuccess = function(obj:nexacro.VirtualFile,e:nexacro.VirtualFileEventInfo)
{
	if(this.fvPrcsType == 0){ //폴더 권한 확인
		if(e.reason == 10){
			if(e.fileisexist){
				if(this.fvQueFolders.isEmpty()){
					this.fnCheckFolderCallback(true);
				}else{
					obj.isExist(this.fvQueFolders.dequeue());
				}
			}else{
				this.fnExecuteEnable(true);
				this.smfAlert("전형자료경로가 존재하지 않습니다.", function(){
					this.fnCheckFolderCallback(false);
				});
			}
		}
	}else{ //파일 저장
		if(e.reason == 1){ //open complete
			var f = this.fvQueFiles.first();
			if(f.mode == 'R'){
				if(f.type == 'T') obj.read(e.filesize, 'utf-8');
				else obj.read();
			}else{
				//쓰기
				var cn = f['cn'];
				if(this.smfIsNull(cn)){
					obj.close();
				}else{
					if(f['type'] == 'T') obj.write(f['cn'], 'utf-8');
					else obj.write(f['cn']);
				}
			}
		}else if(e.reason == 2){ //close complete
			var f = this.fvQueFiles.first();
			if(f.mode == 'R'){
				this.fnVirtualFileCallbackR();
			}else{
				this.fnVirtualFileCallbackW();
			}
		}else if(e.reason == 3){ //read complete
			var f = this.fvQueFiles.first();
			if(f.type == 'T'){
				f.cn = e.textdata;
			}else{
				f.cn = e.binarydata;
			}
			obj.close();
		}else if(e.reason == 6){ //write complete
			//닫기
			obj.close();
		}
	}
};

/*
* @description 폴더권한 확인 및 파일 쓰기 오류
*/
this.VirtualFile00_onerror = function(obj:nexacro.VirtualFile,e:nexacro.VirtualFileErrorEventInfo)
{
	if(this.fvPrcsType == 0){ //폴더 권한 확인
		this.fnExecuteEnable(true);
		if(e.statuscode == '1102'){ //Permission Denied
			this.smfAlert("전형자료경로에 접근권한이 없습니다.", function(){
				this.fnCheckFolderCallback(false);
			});
		}else if(e.statuscode == '1105'){ //Does not exist
			this.smfAlert("전형자료경로가 존재하지 않습니다.", function(){
				this.fnCheckFolderCallback(false);
			});
		}
	}else if(this.fvPrcsType == 1){
		this.fnExecuteEnable(true);
	}
	
	trace('VirtualFile00_onerror : ' + JSON.stringify(e));
};

/*
* @description 전형자료경로설정
*/
this.btnCoaDataPath_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 팝업 파라메터
	var popupParams = {
