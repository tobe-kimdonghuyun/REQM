		sender: obj, // sender 지정
		params: {
			procType: "save" // 처리타입 지정
		},
	};

	// 모달팝업 실행
	this.smfDialog("uds_ueudd00_p09", "pa_uds_ueu_dd::uds_ueudd00_p09.xfdl", popupParams);
};

/*
* @description 수신기간 조회조건 min, max
*/
this.Calendar_canchange = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{
	//min, max 막기
	if(obj.id == 'calRcptnPrd1'){ //검색 수신 시작일자
		var minYmd = this.dsCoaCtrBsc.getColumn(0, 'rcritScByBgngYmd'); //대입기준기본 모집구분별시작일자
		var endYmd = this.divSearch.form.calRcptnPrd2.value;
		if (e.postvalue < minYmd || e.postvalue > endYmd){
			return false;
		}
	}else{ //검색 수신종료일자
		var bgngYmd = this.divSearch.form.calRcptnPrd1.value;
		if (e.postvalue < bgngYmd || e.postvalue > this.smfToday()){
			return false;
		}
	}
	
	return true;
};

/*
* @description 블라인드여부선택
*/
this.divSearch_rdoSeleDataScCd_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	var bldRmvYn = this.dsSearch.getColumn(0, "bldRmvYn");
	if(bldRmvYn == "Y"){
		this.btnExecute.set_enable(false);
		this.btnExecuteBldRmv.set_enable(true);
		this.grdMain.set_formatid("bldRmv");
		
		this.dsCoaApstStsCd.filter("unyCdValue == '' || unyCdValue == '70' || unyCdValue == '79' || unyCdValue == '80'");
		this.divSearch.form.cboApstScCd.set_index(0);
	} else {
		this.btnExecute.set_enable(true);
		this.btnExecuteBldRmv.set_enable(false);
		this.grdMain.set_formatid("default");
		
		this.dsCoaApstStsCd.filter("unyCdValue == '' || unyCdValue == '60' || unyCdValue == '69' || unyCdValue == '70' || unyCdValue == '79' || unyCdValue == '80'");
		this.divSearch.form.cboApstScCd.set_index(0);
	}
	this.dsMain.clearData();
};

/*
* @description 전형자료로컬DB생성
*/
this.btnCoaDataLocalDbCrt_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
