    <Script type="xscript5.1"><![CDATA[/**
 *	전형자료생성
 *	@MenuPath	대입전형-전형자료온라인수신-전형자료생성
 *	@FileName 	uds_ueudd00_m05.xfdl
 *	@Creator 	김동업
 *	@CreateDate	2022.09.30 
 *	@Desction	
 ************** 소스 수정 이력 ***********************************************
 *	date			Modifier			Description
 *******************************************************************************
 *	2022.09.30		김동업				최초 생성
 *  2022.01.11		김정민				개발
 *******************************************************************************
 */

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::uds_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
// 암호화키
this.fvKeyUserDn = '';

// ExtCmmon API
this.fvObjExtCommon = this.smfCreateExtCommonAPI();
this.fvCoaDataDownPath = this.udsfGetCoaDataDownPath();   // 수신경로
this.fvCoaDataBlindPath = this.udsfGetCoaDataBlindPath(); // 블라인드자료경로
this.fvCoaDataDecrPath = this.udsfGetCoaDataDecrPath();   // 블라인드해제자료경로
this.fvCoaDataPath = '';

this.fvPrcsType = 0;

this.fvQueFolders = null;								  // 권한 확인할 폴더 큐 버퍼

this.fvQueIdxAll = null;    						      // 파일 데이터셋 인덱스 그룹 큐 버퍼
this.fvQueIdx = null;									  // 파일 데이터셋 인덱스 큐 버퍼
this.fvQueFiles = null;									  // 파일 쓰기 큐 버퍼
this.fvQueMergeFiles = null;							  // 파일 쓰기 큐 버퍼
this.fvLastWrkIdx = -1;
this.fvMaxCnt = 100;								      //한번에 처리할 복호화 수량MAX

this.fvCoaWrkHstrService = null;						  //대업전형자료업무 히스토리

this.fvChkCnt = 0;									  	  // 복호화선택수량
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Div 초기화
	this.smfInitDiv(obj);
	
	// 대입서비스체크
	this.udsfCoaSvcChck(function(){
		// 초기화
		this.fnInit(obj); 
			
		// 공통코드 조회
		this.smfCodeList("code", [this.dsCddcScCd, this.dsCoaApstStsCd])
			.callback(function(callbackParams){
				if(callbackParams.errors) return;
				
				this.dsCoaApstStsCd.filter("unyCdValue == '' || unyCdValue == '60' || unyCdValue == '69' || unyCdValue == '70' || unyCdValue == '79' || unyCdValue == '80'");
				this.divSearch.form.cboApstScCd.set_index(0);
			})
			.run()
		;
		
		//this.fnExecuteEnable(false);
		//this.fnSearch(); // 조회
		
		// Grid Checkbox 활성화/활성화 제어
		// this.smfUpdateRednerGridCheckbox(this.grdDetail, 0, this.fnRenderGridCheckbox);
		
		// 조회 입력창에서 'Ctrl' + 'Enter' 키 입력시 조회수행 이벤트 설정
		this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
	});
};

/**
 * @description 폼 닫기전 이벤트
 */
this.fnOnbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	// 변경내역이 발생한 경우 종료전 confirm수행
	return this.smfCloseFormConfirm([this.dsMain]);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1){
		this.fnExecuteEnable(true);
		return;
	}
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/**
 * @description 조회
*/
this.fnSearch = function()
{
	// 조회 서비스
	this.smfSearchService("listCoaApstBldCrt")
		//.confirmIfModifiedGrid(this.grdMain) // 데이터가 변경되었으면 확인메시지
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			var pageIndex = this.dsPageInfo.getColumn(0, 'pageIndex');
			var pageSize  = this.dsPageInfo.getColumn(0, 'pageSize'); 
			var totalCount = this.dsPageInfo.getColumn(0, 'totalCount');
			
			this.dsMain.appendData(this.dsMain01);
			
			if(this.dsMain.getRowCount() > 0){
				this.grdMain.setCellPos(1, this.dsMain.getRowCount() - 1);
			}
			
			if(pageIndex * pageSize < totalCount){
				this.dsPageInfo.setColumn(0, 'pageIndex', pageIndex + 1);
				this.fnSearch();
			}else{
				if(this.dsMain.getRowCount() > 0){
					this.grdMain.setCellPos(2, 0);
				}
			}
			
			this.fnSelectCoaApstSts(); // 대입지원자상태 조회
			
			this.fvChkCnt = 0;
			this.fvQueIdxAll.clear();
			this.fnDrawProgras(); // 복호화진행상태 표시
		}); // 콜백
};

this.fnSelectCoaCtrBsc = function(){
	// 조회 서비스
	this.smfSearchService("selectCoaCtrBsc")
		//.showConfirm(false)
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			//this.fnRcptnFileCheck(this.fnCurDataset());
		}); // 콜백
}

/**
 * @description 대입지원자상태 조회
*/
this.fnSelectCoaApstSts = function(callback){
	// 조회 서비스
	this.smfSearchService("listCoaApstSts")
		//.showConfirm(false)
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			var decProcInfo = "      [전형자료복호화 진행상태별 대상건수] ";
			for(var i = 0; i < this.dsCoaApstSts.getRowCount(); i++){
				if(i != 0) decProcInfo = decProcInfo + ", ";
				decProcInfo = decProcInfo + this.dsCoaApstSts.getColumn(i, 'coaApstStsNm') + ": " + this.smfSetComma(this.dsCoaApstSts.getColumn(i, 'coaApstStsCnt'));
			}
			this.staDecProcInfo.set_text(decProcInfo);
			
			if(this.smfIsFunc(callback)) callback.call(this);
		}); // 콜백
}

this.fnExecuteBldCrt = function(callback){
	this.smfExecuteService('executeBldCrt')
		.showConfirm(false)
		.command(function(next) { 
			this.setWaitCursor(false);
			next();
		})
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.setWaitCursor(true);
			
			if(this.smfIsFunc(callback)) callback.call(this);
			
			this.dsMainTrgt.clearData();
			
			this.fnCopyDs00();
			
			//다음 프로세스 실행
			this.fnDoNext();
		}); // 콜백
}

this.fnExecuteBldCrtCmptn = function(callback){
	this.smfExecuteService('executeBldCrtCmptn')
		.showConfirm(false)
		.command(function(next) { 
			this.setWaitCursor(false);
			next();
		})
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.setWaitCursor(true);
			
			this.fnDrawProgras();
			
			if(this.smfIsFunc(callback)) callback.call(this);
			this.dsMainTrgt.clearData();
			this.fnCopyDs00();
			
			this.fnSelectCoaApstSts(function(){ // 대입지원자상태 조회
				//다음 프로세스 실행
				this.fnDoNext();
			});
		}); // 콜백
}

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/**
 * @description 초기화 FUNCTION
 */
this.fnInit = function(obj){
	this.dsSearch.setColumn(0, "coaAyr", this.udsv_coaAyr);
	this.dsSearch.setColumn(0, "coaRcritScCd", this.udsv_coaRcritScCd);
	this.dsSearch.setColumn(0, "coaRcritScNm", this.udsv_coaRcritScNm);
	
	this.dsSearch.setColumn(0, "coaEvlUnitId", "");
	this.dsSearch.setColumn(0, "coaEvlUnitNm", "- 전체 -");
	this.dsSearch.setColumn(0, "bldRmvYn", "N");
	
	this.dsSearch.setColumn(0, 'bgngYmd', this.smfToday());
	this.dsSearch.setColumn(0, 'endYmd', this.smfToday());
	
	//버퍼 생성
	this.fvQueFolders = this.udsfCreateQueue();
	this.fvQueFiles = this.udsfCreateQueue();
	this.fvQueMergeFiles = this.udsfCreateQueue();
	this.fvQueIdx = this.udsfCreateQueue();
	this.fvQueIdxAll = this.udsfCreateQueue();
	
	//nNum = 0, nIdx=3
	//0^2024^2^K100000530^.... -> 0^2024^2^^.... 으로 replace할 수 있음.
	String.prototype.replaceBld = function(nNum, nIdx){
		if(nIdx < 1) return this.valueOf();
		var next = Array(nIdx - 1).fill('[^\\^]{0,}\\^').join('');
		var sRegExp = `((^${nNum}|\\n${nNum})\\^${next})([^\\^]+)`;
		//trace('sRegExp---\n' + sRegExp);
		return this.valueOf().replace(new RegExp(sRegExp, 'gi'), '$1 ');
	}
	
	//마지막 작업 인덱스 초기화
	this.fvLastWrkIdx = -1;
	
	// 대입진원업무 히스토리
	this.fvCoaWrkHstrService = this.udsfCreateCoaWrkHstr('U0702', 'executeBldCrtCmptn');  
}

/**
 * @description  완료 콜백
 */
this.fnCompleteCallback = function(){
	//히스토리 완료 저장
	this.fvCoaWrkHstrService.send(true);

	if(this.fnIsBldCrt()){
		this.smfAlert("블라인드자료 복호화가 완료 되었습니다.");
	}else{
		this.smfAlert("블라인드해제자료 복호화가 완료 되었습니다.");
	}
	
	var ds = this.fnCurDataset();
	ds.applyChange();
	
	//하이라이트 제거
	this.fnToggleHighlight(-1);
	this.grdMain.setCellProperty('head', 0, 'expr', '0');
	
	this.fnExecuteEnable(true);
}

/**
 * @description  블라인드 생성여부
 */
this.fnIsBldCrt = function(){
	return this.dsSearch.getColumn(0, 'bldRmvYn') == 'N';
}

/**
 * @description  블라인드 생성여부에 따른 데이터셋
 */
this.fnCurDataset = function(is00){
	return is00 === true ? this.dsMain00 : this.dsMain;
}

/**
 * @description 폴터 권한확인
 * @param : folders - 권한을 확인할 폴더 배열
 */
this.fnCheckFolder = function(folders){
	this.fvPrcsType = 0;

	folders = Array.isArray(folders) ? folders : [folders];
	
	if(folders.some((v) => this.smfIsNull(v))){
		this.smfAlert("전형자료경로가 존재하지 않습니다.", function(){
			this.fnCheckFolderCallback(false);
		});
		return;
	}
	
	this.fvQueFolders.init(folders);
	this.VirtualFile00.isExist(this.fvQueFolders.dequeue());
}

/**
 * @description 폴더 권한확인 콜백
 * @param : isComplete - 완료 확인
 */
this.fnCheckFolderCallback = function(isComplete){
	this.fnExecuteEnable(true);
	if(!isComplete) return;
	
	//인증서 전자서명 실행
	this.udsfExecuteCert(function(eltsDataValue){
		this.fvKeyUserDn = eltsDataValue;
		this.fnRunDesc();
	});
}

