  <Form id="uds_ueudd00_m05" width="1200" height="817" titletext="전형자료생성" onload="fnOnload">
    <Layouts>
      <Layout height="817" width="1200" screenid="ScreenDeskTop">
        <Div id="divSearch" taborder="0" left="0" top="0" height="101" cssclass="div_WF_Search" right="0" initvalueid="ivDivAccessibilityOn" accessibilityrole="none" accessibilitylabel="조회영역">
          <Layouts>
            <Layout>
              <Static id="staCoaAyr" taborder="0" text="대입학년도" left="0" top="20" width="108" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtCoaAyr" taborder="1" left="staCoaAyr:0" width="80" height="30" top="20" initvalueid="ivEdtNormal" readonly="true"/>
              <Static id="staCoaRcritScNm" taborder="2" text="모집구분" left="edtCoaAyr:0" top="20" width="96" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtCoaRcritScNm" taborder="3" left="staCoaRcritScNm:0" width="120" height="30" top="20" initvalueid="ivEdtNormal" readonly="true" text="수시(사전운영)"/>
              <Static id="staCoaEvlUnitId" taborder="4" text="평가단위" left="edtCoaRcritScNm:0" top="20" width="96" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtCoaEvlUnitId" taborder="5" left="staCoaEvlUnitId:0" top="20" width="175" height="30" initvalueid="ivEdtNormal" readonly="true"/>
              <Button id="btnEvlUnit" taborder="6" text="선택" left="edtCoaEvlUnitId:5" top="20" width="48" height="30" cssclass="btn_WF_Custom" initvalueid="ivBtnAccessibilityLink" onclick="divSearch_btnEvlUnit_onclick"/>
              <Static id="staCddcScCd" taborder="7" text="시도" left="btnEvlUnit:0" top="20" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" width="73"/>
              <Combo id="cboCddcScCd" taborder="8" left="staCddcScCd:0" width="150" height="30" codecolumn="unyCdValue" index="0" text="전체" readonly="false" top="20" innerdataset="dsCddcScCd" datacolumn="unyCdValueNm" initvalueid="ivCmbNormal"/>
              <Static id="staShlNm" taborder="9" text="학교명" left="cboCddcScCd:0" top="20" width="80" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtShlNm" taborder="10" left="staShlNm:0" top="20" width="120" height="30" initvalueid="ivEdtNormal" imemode="hangul,full"/>
              <Button id="btnSearch" taborder="11" text="조회" width="74" height="30" cssclass="btn_WF_Search03" right="20" onclick="divSearch_btnSearch_onclick" initvalueid="ivBtnAccessibilityButton" top="60"/>
            </Layout>
          </Layouts>
        </Div>
        <ImageViewer id="img00_00_01_00" taborder="1" text="전형자료생성" left="0" top="121" width="140" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
        <Button id="btnSave" taborder="2" text="전형자료생성" top="121" height="30" width="105" cssclass="btn_WF_Crud" visible="true" right="0" initvalueid="ivBtnAccessibilityButton" onclick="btnSave_onclick"/>
        <Grid id="grdMain" taborder="3" left="0" binddataset="dsMain" autofittype="col" top="161" width="500" initvalueid="ivGrdAccessibilityOn" oncellclick="grdMain_oncellclick" cursor="auto" selecttype="cell" accessibilitylabel="전형자료생성" bottom="0">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="160" band="left"/>
                <Column size="70"/>
                <Column size="70"/>
                <Column size="70"/>
                <Column size="70"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head" accessibilityrole="none" accessibilitylabel="제목영역">
                <Cell text="시도"/>
                <Cell col="1" text="학교수"/>
                <Cell col="2" text="생성대상"/>
                <Cell col="3" text="미생성"/>
                <Cell col="4" text="생성완료" cssclass="LineNo"/>
              </Band>
              <Band id="body" accessibilityrole="none" accessibilitylabel="내용영역">
                <Cell displaytype="normal" edittype="none" text="bind:cddcScNm" textDecoration="underline"/>
                <Cell col="1" text="bind:shlCnt"/>
                <Cell col="2" text="bind:trgtCnt"/>
                <Cell col="3" text="bind:prcsCnt"/>
                <Cell col="4" text="bind:cmptnCnt"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Grid id="grdDetail" taborder="4" left="grdMain:30" top="161" binddataset="dsDetail" autofittype="col" right="0" initvalueid="ivGrdAccessibilityOn" selecttype="cell" onheadclick="grdMain_onheadclick" accessibilitylabel="전형자료생성 합계" bottom="0">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="40" band="left"/>
                <Column size="320" band="left"/>
                <Column size="70"/>
                <Column size="70"/>
                <Column size="70"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
                <Row size="40" band="summ"/>
              </Rows>
              <Band id="head" accessibilityrole="none" accessibilitylabel="내용영역">
                <Cell displaytype="checkboxcontrol" edittype="checkbox" accessibilityrole="checkbox"/>
                <Cell col="1" text="고등학교"/>
                <Cell col="2" text="생성대상"/>
                <Cell col="3" text="미생성"/>
                <Cell col="4" text="생성완료" cssclass="LineNo"/>
              </Band>
              <Band id="body" accessibilityrole="none" accessibilitylabel="내용영역">
                <Cell text="bind:_chk" displaytype="expr:prcsCnt == 0 ? &quot;none&quot; : &quot;checkboxcontrol&quot;" edittype="expr:prcsCnt == 0 ? &quot;none&quot; : &quot;checkbox&quot;" color="#333333" accessibilityrole="checkbox"/>
                <Cell col="1" text="bind:shlNm"/>
                <Cell col="2" text="bind:trgtCnt"/>
                <Cell col="3" text="bind:prcsCnt"/>
                <Cell col="4" text="bind:cmptnCnt" cssclass="LineNo"/>
              </Band>
              <Band id="summary" accessibilityrole="none" accessibilitylabel="합계영역">
                <Cell colspan="2" text="합계" displaytype="text"/>
                <Cell col="2" text="expr:dataset.getSum('trgtCnt')" textAlign="right" displaytype="number"/>
                <Cell col="3" text="expr:dataset.getSum('prcsCnt')" textAlign="right" displaytype="number"/>
                <Cell col="4" text="expr:dataset.getSum('cmptnCnt')" textAlign="right" displaytype="number"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="Static99_00_00_00_00_01_00" taborder="5" left="0" top="101" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_00_00" taborder="6" left="0" top="151" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_00_00_00_00" taborder="7" left="grdMain:0" top="157" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="0" initvalueid="ivStcAccessibilityOff"/>
