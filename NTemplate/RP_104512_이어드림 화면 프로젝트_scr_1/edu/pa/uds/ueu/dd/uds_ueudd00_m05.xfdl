    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
 *	전형자료생성
 *	@MenuPath	대입전형-전형자료온라인수신-전형자료생성
 *	@FileName 	uds_ueudd00_m05.xfdl
 *	@Creator 	김동업
 *	@CreateDate	2022.09.30  
 *	@Desction	
 ************** 소스 수정 이력 ***********************************************
 *	date			Modifier			Description
 *******************************************************************************
 *	2022.09.30		김동업				최초 생성
 *******************************************************************************
 */

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::uds_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Div 초기화
	this.smfInitDiv(obj);
	
	// 대입서비스체크
	this.udsfCoaSvcChck(function(){
		// 초기화
		this.fnInit(obj); 
		
		// 공통코드 조회
		this.smfCodeList("code", [this.dsCddcScCd])
			.callback(function(callbackParams){
				if(callbackParams.errors) return;
			})
			.run()
		;
		
		this.fnSearch(); // 조회
		
		// Grid Checkbox 활성화/활성화 제어
		// this.smfUpdateRednerGridCheckbox(this.grdDetail, 0, this.fnRenderGridCheckbox);
		
		// 조회 입력창에서 'Ctrl' + 'Enter' 키 입력시 조회수행 이벤트 설정
		this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
	});
};

/**
 * @description 폼 닫기전 이벤트
 */
this.fnOnbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	// 변경내역이 발생한 경우 종료전 confirm수행
	return this.smfCloseFormConfirm([this.dsMain, this.dsDetail]);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/**
 * @description 조회
*/
this.fnSearch = function()
{
	this.fnCddcSearch();
};

/**
 * @description 시도교육청 조회
*/
this.fnCddcSearch = function()
{
	// 조회 서비스
	this.smfSearchService("listCddc")
		.confirmIfModifiedGrid(this.grdMain) // 데이터가 변경되었으면 확인메시지
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.fnShlSearch();
		}); // 콜백
};

/**
 * @description 학교 조회
*/
this.fnShlSearch = function()
{
	// 조회 서비스
	this.smfSearchService("listShl")
		.confirmIfModifiedGrid(this.grdDetail) // 데이터가 변경되었으면 확인메시지
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		}); // 콜백
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/**
 * @description 초기화 FUNCTION
 */
this.fnInit = function(obj){
	this.dsSearch.setColumn(0, "coaAyr", this.udsv_coaAyr);
	this.dsSearch.setColumn(0, "coaRcritScCd", this.udsv_coaRcritScCd);
	this.dsSearch.setColumn(0, "coaRcritScNm", this.udsv_coaRcritScNm);
	
	this.dsSearch.setColumn(0, "coaEvlUnitId", "");
	this.dsSearch.setColumn(0, "coaEvlUnitNm", "- 전체 -");
}

/**
 * 그리드 체크박스 enable 처리
 * @param : ds - 데이터셋
 * @param : nRow - rowposition
 */
this.fnRenderGridCheckbox = function(ds, nRow){
	return true;
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

/**
 * @description 그리드 헤더 클릭
*/
this.grdMain_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var columnName = obj.getCellProperty("body",e.cell,"text");
	if ("bind:_chk" == columnName){
		this.smfToggleChkHeader(obj, e, this.fnRenderGridCheckbox);
	}else{
		// 정렬
		this.smfCheckAndSort(obj, e);
	}
};

/**
 * @description 조회
 */
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearch();
};

/**
 * @description 평가단위 선택
 */
this.divSearch_btnEvlUnit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfAlert("평가단위 선택 구현중.");
};

/**
 * @description 시도 선택
 */
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var cddcScCd = this.dsMain.getColumn(this.dsMain.rowposition, "cddcScCd");
	this.dsSearch.setColumn(0, "cddcScCd", cddcScCd);
	
	this.fnShlSearch();
};

/**
 * @description 전형자료요청
 */
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	/*
	var info = this.objKCASE.callMethod("SelectCertKM");
	var cert_temp = this.objKCASE.callMethod("GetCertInfoKM","").split("|");
	var dn = cert_temp[0];
	var sn = cert_temp[1];
	var strCertData = cert_temp[2];
	
	trace(" certDtcNm : " + dn);
	trace(" eltsCertNo : " + sn);
	trace(" eltsDataValue : " + strCertData);
	
	// dn : cn=SVRZ1234567094,ou=교육부,ou=Group of Server,o=Government of Korea,c=KR
	// sn : 00A4147670D14CADA23AD54C72BD0CE324A90473
	// strCertData : 
	
	// certDtcNm
	// eltsCertNo
	// eltsDataValue
	
	// dsPopMain.setColumn(0,"autceEsntlNm",dn); 인증서고유명
	// dsPopMain.setColumn(0,"eltrnSignAcn",sn); 전자서명인증서번호
	// dsPopMain.setColumn(0,"eltrnSignDataValue",strCertData); 전자서명자료값
		
	// 
	// 
	*/
	// 저장 서비스
	this.smfExecuteService("executePrcs")
		.messagePrefix(obj.text)
		.validateGrid(this.grdDetail, this.dsDetailValid, {_chkOption: "required"})
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		}); // 콜백
};


]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="inDatasets">dsSearch</Col>
            <Col id="outDatasets">dsMain=dsCddc</Col>
            <Col id="url">uds_ueu_dd00_501.do</Col>
            <Col id="id">listCddc</Col>
          </Row>
          <Row>
            <Col id="id">listShl</Col>
            <Col id="url">uds_ueu_dd00_502.do</Col>
            <Col id="inDatasets">dsSearch</Col>
            <Col id="outDatasets">dsDetail=dsShl</Col>
          </Row>
          <Row>
            <Col id="inDatasets">dsSearch dsShl=dsDetail:U</Col>
            <Col id="outDatasets"/>
            <Col id="url">uds_ueu_dd00_503.do</Col>
            <Col id="id">executePrcs</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" oncolumnchanged="dsSearch_oncolumnchanged">
        <ColumnInfo>
          <Column id="coaAyr" type="STRING" size="256"/>
          <Column id="coaRcritScCd" type="STRING" size="256"/>
          <Column id="coaRcritScNm" type="STRING" size="256"/>
          <Column id="cddcScCd" type="STRING" size="256"/>
          <Column id="shlNm" type="STRING" size="256"/>
          <Column id="coaEvlUnitId" type="STRING" size="256"/>
          <Column id="coaEvlUnitNm" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="cddcScCd" type="STRING" size="256"/>
          <Column id="cddcScNm" type="STRING" size="256"/>
          <Column id="shlCnt" type="BIGDECIMAL" size="10"/>
          <Column id="trgtCnt" type="BIGDECIMAL" size="10"/>
          <Column id="prcsCnt" type="BIGDECIMAL" size="10"/>
          <Column id="errCnt" type="BIGDECIMAL" size="10"/>
          <Column id="cmptnCnt" type="BIGDECIMAL" size="10"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsDetail" useclientlayout="true" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="_chk" type="STRING" size="256"/>
          <Column id="cddcScCd" type="STRING" size="256"/>
          <Column id="shlCd" type="STRING" size="256"/>
          <Column id="shlNm" type="STRING" size="256"/>
          <Column id="shlKndScCd" type="STRING" size="256"/>
          <Column id="trgtCnt" type="BIGDECIMAL" size="10"/>
          <Column id="prcsCnt" type="BIGDECIMAL" size="10"/>
          <Column id="errCnt" type="BIGDECIMAL" size="10"/>
          <Column id="cmptnCnt" type="BIGDECIMAL" size="10"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsDetailValid" useclientlayout="true" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="_chk" type="STRING" size="256"/>
          <Column id="shlCd" type="STRING" size="256"/>
          <Column id="shlNm" type="STRING" size="256"/>
          <Column id="trgtCnt" type="STRING" size="10"/>
          <Column id="prcsCnt" type="STRING" size="10"/>
          <Column id="errCnt" type="STRING" size="10"/>
          <Column id="cmptnCnt" type="STRING" size="10"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsCddcScCd" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="FirstCode" type="STRING" size="30" value="ALL" datapath=""/>
          <ConstColumn id="ClfCdValue" type="STRING" size="30" value="CDDC_SC_CD"/>
          <ConstColumn id="FilterExpr" type="STRING" size="30" value="unyCdValue != 'A00' &amp;&amp; unyCdValue != 'V10'"/>
          <ConstColumn id="UnyCdGrpId" type="STRING" size="30" value=""/>
          <ConstColumn id="BfrClfCdValue" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd1Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd2Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd3Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd4Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd5Value" type="STRING" size="30" value=""/>
          <Column id="pgeId" type="STRING" size="256"/>
          <Column id="clfCdValue" type="STRING" size="30"/>
          <Column id="clfCdValueNm" type="STRING" size="120"/>
          <Column id="clfCdUseYn" type="STRING" size="150"/>
          <Column id="unyCdValue" type="STRING" size="10"/>
          <Column id="unyCdValueNm" type="STRING" size="30"/>
          <Column id="userDfnCd1Value" type="STRING" size="100"/>
          <Column id="userDfnCd2Value" type="STRING" size="100"/>
          <Column id="userDfnCd3Value" type="STRING" size="100"/>
          <Column id="userDfnCd4Value" type="STRING" size="100"/>
          <Column id="userDfnCd5Value" type="STRING" size="100"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.edtCoaAyr" propid="value" datasetid="dsSearch" columnid="coaAyr"/>
      <BindItem id="item1" compid="divSearch.form.edtCoaRcritScNm" propid="value" datasetid="dsSearch" columnid="coaRcritScNm"/>
      <BindItem id="item2" compid="divSearch.form.cboCddcScCd" propid="value" datasetid="dsSearch" columnid="cddcScCd"/>
      <BindItem id="item3" compid="divSearch.form.edtShlNm" propid="value" datasetid="dsSearch" columnid="shlNm"/>
      <BindItem id="item4" compid="divSearch.form.edtCoaEvlUnitId" propid="value" datasetid="dsSearch" columnid="coaEvlUnitNm"/>
    </Bind>
  </Form>
</FDL>
