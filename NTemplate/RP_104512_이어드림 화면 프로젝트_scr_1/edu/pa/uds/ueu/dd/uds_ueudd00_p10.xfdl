    </Layouts>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listCoaEvlUnitId</Col>
            <Col id="url">uds_ueu_dd00_711.do</Col>
            <Col id="inDatasets">dsSearch</Col>
            <Col id="outDatasets">dsMain=dsCoaEvlUnitId</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" oncolumnchanged="dsSearch_oncolumnchanged">
        <ColumnInfo>
          <Column id="coaAyr" type="STRING" size="256"/>
          <Column id="coaRcritScCd" type="STRING" size="256"/>
          <Column id="coaRcritScNm" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true" canrowposchange="dsMain_canrowposchange" onrowposchanged="dsMain_onrowposchanged">
        <ColumnInfo>
          <Column id="_chk" type="STRING" size="1"/>
          <Column id="coaAyr" type="STRING" size="256"/>
          <Column id="coaRcritScCd" type="STRING" size="256"/>
          <Column id="uvstOrgCd" type="STRING" size="256"/>
          <Column id="coaEvlUnitId" type="STRING" size="256"/>
          <Column id="coaEvlUnitNm" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
 *	전형자료수신경로설정
 *	@MenuPath	대입전형-전형자료온라인수신-전형자료수신경로설정
 *	@FileName 	uds_ueudd00_m09.xfdl
 *	@Creator 	김동업
 *	@CreateDate	2022.08.22  
 *	@Desction	
 ************** 소스 수정 이력 ***********************************************
 *	date			Modifier			Description
 *******************************************************************************
 *	2022.08.22		김동업				최초 생성
 *******************************************************************************
 */

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::uds_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvParams = null;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	
	// 초기화
	this.fnInit(obj); 
	
	// 조회
	this.fnSearch();
};

/**
 * @description 폼 닫기전 이벤트
 */
this.fnOnbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	// 변경내역이 발생한 경우 종료전 confirm수행
	return this.smfCloseFormConfirm([this.dsMain]);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 조회
*/
this.fnSearch = function()
{
	this.fnListEvlUnitCd();
};

/**
 * @description 평가단위코드관리 조회
*/
this.fnListEvlUnitCd = function(){
	
	// 조회 서비스
	this.smfSearchService("listCoaEvlUnitId")
		.confirmIfModifiedGrid(this.grdMain) // 데이터가 변경되었으면 확인메시지
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.fvParams.listCoaEvlUnitId.length == 0){
				this.grdMain.setCellProperty('head', 0, 'expr', '1')
 				for(var i = 0; i < this.dsMain.getRowCount(); i++){
 					this.dsMain.setColumn(i, '_chk', '1');
 				}
			}else{
				this.fvParams.listCoaEvlUnitId.forEach((coaEvlUnitId) => {
					var nRow = this.dsMain.findRow('coaEvlUnitId', coaEvlUnitId);
					if(nRow > -1) this.dsMain.setColumn(nRow, '_chk', '1');
				});
			}
		}); // 콜백
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/**
 * @description 초기화 FUNCTION
 */
this.fnInit = function(obj){
	this.dsSearch.setColumn(0, "coaAyr", this.udsv_coaAyr);
	this.dsSearch.setColumn(0, "coaRcritScCd", this.udsv_coaRcritScCd);
	this.dsSearch.setColumn(0, "coaRcritScNm", this.udsv_coaRcritScNm);
	
	this.fvParams = this.smfGetPopupParams();
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

/**
 * @description 경로선택
 */
this.divMain_btnCoaDataPath_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objExtCommon = this.smfCreateExtCommonAPI();
	
	var coaDataPath = nexacro.getPrivateProfile(this.udsv_coaDataPathValue);
	if(this.smfIsNull(coaDataPath)){
		coaDataPath = objExtCommon._ext_getSystemDir("CSIDL_PERSONAL"); 
	}
	coaDataPath = objExtCommon._ext_selectFolderPath(coaDataPath);
	
	objExtCommon = null;
	
	if(!this.smfIsNull(coaDataPath)){
		this.divMain.form.edtCoaDataPath.set_value(coaDataPath);
		this.divMain.form.txtCoaDataDtlPath.set_value(this.udsfGetCoaDataDtlPath(coaDataPath));
		
		this.udsfSetCoaDataPath(coaDataPath);
	}
};

/**
 * @description 취소
 */
this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};

/**
 * @description 적용
 */
this.btnApply_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	const chkList = this.dsMain.extractRows("_chk == 1");

	var res = chkList.reduce((a, v, i) => {
		a.listCoaEvlUnitId.push(this.dsMain.getColumn(v, 'coaEvlUnitId'));
		a.listCoaEvlUnitNm.push(this.dsMain.getColumn(v, 'coaEvlUnitNm'));
		return a;
	}, {listCoaEvlUnitId:[], listCoaEvlUnitNm:[]});
	
	res.totalCnt = this.dsMain.getRowCount();

	this.smfSendResponseToOpener(res);
	
	this.close(true);
};

/**
 * @description 그리드 헤더 클릭
*/
this.grdMain_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var columnName = obj.getCellProperty("body",e.cell,"text");
	if ("bind:_chk" == columnName){
		this.smfToggleChkHeader(obj, e, (ds, nRow) => true);
	}else{
		// 정렬
		this.smfCheckAndSort(obj, e);
	}
};
]]></Script>
  </Form>
</FDL>
