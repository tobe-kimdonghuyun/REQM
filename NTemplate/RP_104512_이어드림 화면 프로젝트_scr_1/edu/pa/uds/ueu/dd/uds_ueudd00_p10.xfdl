<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="uds_ueudd00_p09" width="800" height="470" titletext="평가단위코드선택" onload="fnOnload">
    <Layouts>
      <Layout height="470" width="800" screenid="ScreenDeskTop">
        <ImageViewer id="imgTitle" taborder="0" text="평가단위코드선택" left="20" top="20" height="30" cssclass="img_WF_SubTit04" width="180" initvalueid="ivTitleAccessibilityOn"/>
        <Grid id="grdMain" taborder="1" left="20" top="imgTitle:13" right="20" bottom="80" binddataset="dsMain" onheadclick="grdMain_onheadclick" autofittype="col" selecttype="cell" initvalueid="ivGrdAccessibilityOn" accessibilitylabel="평가단위코드선택">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="40" band="left"/>
                <Column size="100"/>
                <Column size="300"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head" accessibilitylabel="제목영역">
                <Cell displaytype="checkboxcontrol" edittype="checkbox" autosizecol="default" text="0" checkboxtruevalue="1" accessibilityrole="checkbox"/>
                <Cell col="1" text="평가단위코드"/>
                <Cell col="2" text="평가단위명" cssclass="LineNo"/>
              </Band>
              <Band id="body" accessibilitylabel="내용영역">
                <Cell text="bind:_chk" displaytype="checkboxcontrol" edittype="checkbox" accessibilityrole="checkbox"/>
                <Cell col="1" text="bind:coaEvlUnitId"/>
                <Cell col="2" text="bind:coaEvlUnitNm"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="btnCancel" taborder="2" text="취소" height="30" width="50" left="42.7%" fittocontents="width" cssclass="btn_WF_Custom" initvalueid="ivBtnAccessibilityButton" bottom="20" onclick="btnCancel_onclick"/>
        <Button id="btnApply" taborder="3" text="적용" height="30" fittocontents="width" initvalueid="ivBtnAccessibilityButton" bottom="20" onclick="btnApply_onclick" left="btnCancel:8" width="50"/>
        <Static id="staPopupTitleAss" taborder="4" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Static id="Static99_00_00_00_00" taborder="5" left="0" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_00_00" taborder="6" left="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" height="20" bottom="0"/>
        <Static id="Static99_00_00_00_00_00_01" taborder="7" left="0" top="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="20" bottom="20"/>
        <Static id="Static99_00_00_00_00_00_01_00" taborder="8" top="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="20" bottom="20" right="0"/>
        <Static id="Static99_00_00_00_00_00" taborder="9" left="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" height="30" bottom="Static99_00_00_00_00_00_00_00:30"/>
      </Layout>
      <Layout name="Layout0" screenid="mobile" width="640" height="1833" mobileorientation="portrait" type="default" titletext="[M]팝업-학교행정/방과후학교-시간표조회p464(서치+그리드)">
        <Static id="Static99_00_00_00_00" left="20" top="0" height="70" right="20" text="70"/>
        <Static id="Static99_00_00_00_00_00_01" left="1010" top="5" width="20" bottom="35"/>
        <Static id="Static99_00_00_00_00_00_01_00" top="25" width="20" right="-480" bottom="15"/>
        <Static id="Static99_00_00_00_00_00_00_00" left="750" height="20" right="-750" bottom="-5"/>
