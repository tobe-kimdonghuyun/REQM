        </Radio>
        <Static id="sta00_01_00_01_00" taborder="3" text="개인정보의 수집·이용 동의" left="20" top="295" width="240" height="30" cssclass="sta_WF_Tit18" initvalueid="ivStcAccessibilityOn"/>
        <TextArea id="txt00_00" taborder="4" left="20" top="335" height="175" right="20" initvalueid="ivTxtReadOnly" readonly="true" value="&lt;개인정보의 수집·이용 동의&gt;&#10;1. 개인정보의 수집·이용 목적&#10; ○ 대입전형자료 업무 처리 안내&#10; ○ 대입전형자료 요청 및 수신 서비스 응대&#10; &#10;2. 개인정보의 내용&#10; ○ 개인식별정보(성명, 이메일, 휴대전화번호)"/>
        <Radio id="rdoAgre01" taborder="5" left="20" top="520" width="250" height="30" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" rowcount="-1" text="동의하지않음" index="1" initvalueid="ivRdoNormal" cssclass="essential">
