    <Script type="xscript5.1"><![CDATA[/**
 *	대입전형자료온라인제공
 *	@MenuPath	대입전형-대입전형자료온라인제공
 *	@FileName 	uds_ueudd00_p01.xfdl
 *	@Creator 	김동업
 *	@CreateDate	2022.08.22 
 *	@Desction	
 ************** 소스 수정 이력 ***********************************************
 *	date			Modifier			Description
 *******************************************************************************
 *	2022.08.22		김동업				최초 생성
 *******************************************************************************
 */

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::uds_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	this.fnInit();
};

/************************************************************************************************
 * TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnInit = function(){
	
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

/**
 * @description 신청
*/
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.rdoAgre00.value != '01'){
		this.smfAlert('대입전형자료 온라인 수신 서비스 이용 동의가 필요합니다. ');
		this.rdoAgre00.setFocus();
		return;
	}
	
	if(this.rdoAgre01.value != '01'){
		this.smfAlert('개인정보의 수집·이용 동의가 필요합니다.');
		this.rdoAgre01.setFocus();
		return;
	}
	
	var params = this.smfGetPopupParams();
	var that = this;
	if(!this.smfIsNull(params) && this.smfIsFunc(params.fnBeforeClose)){
		params.fnBeforeClose.call(this.opener, function(result){
			if(result){
				that.smfAlert('신청이 완료되었습니다.', null, function(){
					that.smfSendResponseToOpener({
						"retrunValue": true
					});
					that.close(true);
				});
			}
		});
	}
};

this.chkAgreAll_onchanged = function(obj:nexacro.CheckBox,e:nexacro.CheckBoxChangedEventInfo)
{
	if(obj.value){
		this.rdoAgre00.set_value("01");
		this.rdoAgre01.set_value("01");
	} else {
		this.rdoAgre00.set_value("02");
		this.rdoAgre01.set_value("02");
	}
};


/**
 * @description 취소
*/
this.btnRtrcn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};

]]></Script>
  </Form>
</FDL>
