  <Form id="uds_ueudd00_p01" width="800" height="680" titletext="대입전형자료온라인수신서비스신청" nHeight="754" onload="fnOnload">
    <Layouts>
      <Layout height="680" width="800" screenid="ScreenDeskTop">
        <Static id="sta00_01_00_01" taborder="0" text="대입전형자료 온라인 수신 서비스 이용 동의" left="20" top="20" width="420" height="30" cssclass="sta_WF_Tit18" initvalueid="ivStcAccessibilityOn"/>
        <TextArea id="txt00" taborder="1" left="20" top="60" height="175" right="20" initvalueid="ivTxtReadOnly" readonly="true" value="&lt;대입전형자료 온라인 수신 서비스 이용 동의&gt;&#10;&#10;1. 대입전형자료 온라인 수신 서비스 목적&#10; ○ 고등학교와 대학의 대입전형 업무 부담 감소 및 지원 서류 제출에 대한 학생·학부모의 불편 해소&#10; ○ 학교생활기록부(이하 '학생부') 사본 및 성적표 위·변조 등에 따른 부정행위 예방&#10; ○ 학생부 학생 사진 제공을 통한 대리 응시 등 부정행위 방지&#10; &#10;2. 대입전형자료 온라인 수신 서비스 이용"/>
        <Radio id="rdoAgre00" taborder="2" left="20" top="245" width="250" height="30" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" rowcount="-1" text="동의하지않음" index="1" initvalueid="ivRdoNormal" cssclass="essential">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row>
                <Col id="datacolumn">동의함</Col>
                <Col id="codecolumn">01</Col>
              </Row>
              <Row>
                <Col id="datacolumn">동의하지않음</Col>
                <Col id="codecolumn">02</Col>
