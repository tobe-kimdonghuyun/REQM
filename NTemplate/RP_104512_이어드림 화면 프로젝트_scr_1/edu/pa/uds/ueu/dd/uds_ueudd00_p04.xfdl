        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="ddl">CREATE TABLE IF NOT EXISTS StudentBaseInfo (Mogib1 VARCHAR(10), Mogib2 VARCHAR(60), IdentifyNumber VARCHAR(10), SocialNumber VARCHAR(13), SchoolCode VARCHAR(10), CollegeAdmissionYear VARCHAR(4), SeleScCode VARCHAR(1), ApplicantScCode VARCHAR(1), GraduateYear VARCHAR(4), GraduateGrade VARCHAR(1), MasterSchoolYN VARCHAR(1), SpecializedSchoolYN VARCHAR(1), CorrectionRegisterYN VARCHAR(1), ExamNumber VARCHAR(30), UniqueFileName VARCHAR(100), PictureFileName VARCHAR(100), CONSTRAINT sqlite_autoindex_StudentBaseInfo_1 PRIMARY KEY (Mogib1, Mogib2, IdentifyNumber))</Col>
            <Col id="itemNo">0</Col>
            <Col id="name">StudentBaseInfo</Col>
            <Col id="rmkCn">학생정보</Col>
          </Row>
          <Row>
            <Col id="itemNo">1</Col>
