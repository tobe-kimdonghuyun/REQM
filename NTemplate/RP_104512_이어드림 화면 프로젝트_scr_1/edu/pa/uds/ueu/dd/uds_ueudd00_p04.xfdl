            <Col id="ddl">CREATE TABLE IF NOT EXISTS ExperienceActivity(Mogib1 VARCHAR(10) ,Mogib2 VARCHAR(60) ,IdentifyNumber VARCHAR(10) ,SeqNumber INTEGER ,SocialNumber VARCHAR(13) ,SchoolCode VARCHAR(10) ,Year VARCHAR(4) ,Grade INTEGER ,Season VARCHAR(60) ,Place VARCHAR(90) ,strTime VARCHAR(60) ,Content TEXT ,CONSTRAINT sqlite_autoindex_ExperienceActivity_1 PRIMARY KEY (Mogib1 ,Mogib2 ,IdentifyNumber ,SeqNumber))</Col>
