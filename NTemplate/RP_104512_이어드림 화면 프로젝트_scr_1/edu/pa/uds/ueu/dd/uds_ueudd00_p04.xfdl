    <Script type="xscript5.1"><![CDATA[/**
 *	전형자료로컬DB생성
 *	@MenuPath	대입전형-전형자료복호화-전형자료로컬DB생성
 *	@FileName 	uds_ueudd00_p04.xfdl
 *	@Creator 	김동업
 *	@CreateDate	2023.07.28
 *	@Desction	
 ************** 소스 수정 이력 ***********************************************
 *	date			Modifier			Description
 *******************************************************************************
 *	2023.07.28		김동업				최초 생성
 *******************************************************************************
 */

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::uds_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvCoaDataDownPath = this.udsfGetCoaDataDownPath();   // 수신경로
this.fvCoaDataBlindPath = this.udsfGetCoaDataBlindPath(); // 블라인드자료경로
this.fvCoaDataDecrPath = this.udsfGetCoaDataDecrPath();   // 블라인드해제자료경로

this.fvAliveCnt = 0;
this.fvSems = 'SEMS'
this.fvDbNm = 'StudentCarrer.db3';
this.fvQueWrks = null;
this.fvPath = '';
this.fvLogPerPend = ''; //블라인드자료 or 블라인드해제자료;
this.fvIsBld = false;
this.fvBgngTime = null;
this.fvEndTime = null;
this.fvLog = [];

const JOB_TYPE = {
	EXECUTE_QUERY : 'executeQuery',
	EXECUTE_QUERY_CALLBACK : '7',
	EXECUTE_UPDATE : 'executeUpdate',
	EXECUTE_UPDATE_CALLBACK : '8',
	EXECUTE : 'execute',
	CONN_OPEN : 'connOpen',
	CONN_OPEN_CALLBACK : '5',
	CONN_BEGIN : 'connBegin',
	CONN_BEGIN_CALLBACK : '1',
	CONN_CLOSE : 'connClose',
	CONN_CLOSE_CALLBACK : '2',
	CONN_COMMIT : 'connCommit',
	CONN_COMMIT_CALLBACK : '3',
	STMT_CLOSE : 'stmtClose',
	STMT_CLOSE_CALLBACK : '9',
}
Object.freeze(JOB_TYPE);

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	
	// 초기화
	this.fnInit(obj); 
	
	// 조회
	this.fnSearch();
};

/**
 * @description 폼 닫기전 이벤트
 */
this.fnOnbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	// 변경내역이 발생한 경우 종료전 confirm수행
	return this.smfCloseFormConfirm([this.dsMain]);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 조회
*/
this.fnSearch = function()
{
	// this.fnListCoaPrge();
	// this.fnListEvlUnitCd();
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/**
 * @description 초기화 FUNCTION
 */
this.fnInit = function(obj){
	this.dsSearch.setColumn(0, "coaAyr", this.udsv_coaAyr);
	this.dsSearch.setColumn(0, "coaRcritScCd", this.udsv_coaRcritScCd);
	this.dsSearch.setColumn(0, "coaRcritScNm", this.udsv_coaRcritScNm);
	
	var coaDataPath = nexacro.getPrivateProfile(this.udsv_coaDataPathValue);
	if(this.smfIsNull(coaDataPath)) return false;
	
	this.divMain.form.edtCoaDataPath.set_value(coaDataPath);
	this.divMain.form.txtCoaDataDtlPath.set_value(this.udsfGetCoaDataDtlPath(coaDataPath));
	
	this.fvQueWrks = this.udsfCreateQueue();
}

/**
 * @description 문자열 확인
 */
this.fnIsStr = (s) => typeof s == 'string';

/**
 * @description 다음 작업 실행
 */
this.fnDoNext = function(){
	var wrk = this.fvQueWrks.first();
	if(!this.smfIsNull(wrk)){
		wrk.action();
	}else{
		this.setWaitCursor(false);
		//this.smfAlert(this.fvPath + '\n\n' + this.fvLogPerPend + ' 이관 작업이 완료되었습니다.')
		this.smfAlert(this.fvLogPerPend + ' 이관 작업이 완료되었습니다.')
	}
}

/**
 * @description 에러처리
 */
this.fnOnError = function(msg){
	this.setWaitCursor(false);
	this.fnShowLog(msg);
	this.smfAlert(msg);
}

this.fnShowLog = function(msg){
	if(Array.isArray(msg)){
		for(var i = 0; i < msg.length; i++){
			if(this.fvLog.length > 100) this.fvLog.shift();
			this.fvLog.push('[' + this.smfTodayTime().dateFormat('yyyy.MM.dd hh:mm:ss') + '] ' + msg[i]);
		}
	}else{
		if(this.fvLog.length > 100) this.fvLog.shift();
		this.fvLog.push('[' + this.smfTodayTime().dateFormat('yyyy.MM.dd hh:mm:ss') + '] ' + msg);	
	}

	this.divMain00.form.txtLog.set_value(this.fvLog.join('\n'));
	//this.divMain00.form.txtLog.vscrollbar.set_pos(this.divMain00.form.txtLog.vscrollbar.max);
}

/**
 * @description 세션 유지 시간 연장 ( 동기 )
*/
this.fnExecuteAlive = function(callback){
	this.smfExecuteService("executeAlive")
		.command(function(next) { 
 			this.setWaitCursor(false);
 			next();
 		})
		.messagePrefix(obj.text)
		.showConfirm(false)
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		}); // 콜백
		
	this.setWaitCursor(true);
}

this.fnGetVrfcQuery = function(mogib1, mogib2, identifyNumber){
	return `
	--학생정보
	SELECT '0'
		|| '^'
		|| IFNULL(CollegeAdmissionYear, '/NULL/')
		|| '^'
		|| IFNULL(SeleScCode, '/NULL/')
		|| '^'
		|| IFNULL(IdentifyNumber, '/NULL/')
		|| '^'
		|| IFNULL(ApplicantScCode, '/NULL/')
		|| '^'
		|| IFNULL(GraduateYear, '/NULL/')
		|| '^'
		|| IFNULL(GraduateGrade, '/NULL/')
		|| '^'
		|| IFNULL(MasterSchoolYN, '/NULL/')
		|| '^'
		|| IFNULL(SpecializedSchoolYN, '/NULL/')
		|| '^'
		|| IFNULL(CorrectionRegisterYN, '/NULL/')
		|| '^'
		|| IFNULL(ExamNumber, '/NULL/')
		|| '^'
		|| IFNULL(UniqueFileName, '/NULL/')
		|| '^'
		|| IFNULL(PictureFileName, '/NULL/')
		|| '^' AS CoaData
	  FROM StudentBaseInfo
	 WHERE Mogib1 = '${mogib1}'
	   AND Mogib2 = '${mogib2}'
	   AND IdentifyNumber = '${identifyNumber}'
	 UNION ALL
	--인적사항
	SELECT '1'
		|| '^'
		|| IFNULL(SchoolCode, '/NULL/')
		|| '^'
		|| IFNULL(CourseCode, '/NULL/')
		|| '^'
		|| IFNULL(SchoolClass, '/NULL/')
		|| '^'
		|| IFNULL(SchoolNumber, '/NULL/')
		|| '^'
		|| IFNULL(Name, '/NULL/')
		|| '^'
		|| IFNULL(SocialNumber, '/NULL/')
		|| '^'
		|| IFNULL(Specials, '/NULL/')
		|| '^'
		|| IFNULL(Term1_1, '/NULL/')
		|| '^'
		|| IFNULL(Term1_2, '/NULL/')
		|| '^'
		|| IFNULL(Term2_1, '/NULL/')
		|| '^'
		|| IFNULL(Term2_2, '/NULL/')
		|| '^'
		|| IFNULL(Term3_1, '/NULL/')
		|| '^'
		|| IFNULL(Term3_2, '/NULL/')
		|| '^' AS CoaData
	  FROM PersonalInfo
	 WHERE Mogib1 = '${mogib1}'
	   AND Mogib2 = '${mogib2}'
	   AND IdentifyNumber = '${identifyNumber}'
	 UNION ALL
	--학적사항
	 SELECT * FROM (
	 SELECT '2'
		 || '^'
		 || IFNULL(StudyCode, '/NULL/')
		 || '^'
		 || IFNULL(StudyCodeName, '/NULL/')
		 || '^'
		 || IFNULL(strDate, '/NULL/')
		 || '^'
		 || IFNULL(Description, '/NULL/')
		 || '^' AS CoaData
	 FROM StudyHistory
	 WHERE Mogib1 = '${mogib1}'
	   AND Mogib2 = '${mogib2}'
	   AND IdentifyNumber = '${identifyNumber}'
	 ORDER BY SeqNumber
	)
	 UNION ALL
	--출결상황
	SELECT * FROM (
	SELECT '3'
		|| '^'
		|| IFNULL(Year, '/NULL/')
		|| '^'
		|| IFNULL(Grade, '/NULL/')
		|| '^'
		|| IFNULL(StudyDayCount, '/NULL/')
		|| '^'
		|| IFNULL(Absence_Disease, '/NULL/')
		|| '^'
		|| IFNULL(Absence_Accident, '/NULL/')
		|| '^'
		|| IFNULL(Absence_Etc, '/NULL/')
		|| '^'
		|| IFNULL(Lateness_Disease, '/NULL/')
		|| '^'
		|| IFNULL(Lateness_Accident, '/NULL/')
		|| '^'
		|| IFNULL(Lateness_Etc, '/NULL/')
		|| '^'
		|| IFNULL(EarlyLeaving_Disease, '/NULL/')
		|| '^'
		|| IFNULL(EarlyLeaving_Accident, '/NULL/')
		|| '^'
		|| IFNULL(EarlyLeaving_Etc, '/NULL/')
		|| '^'
		|| IFNULL(Result_Disease, '/NULL/')
		|| '^'
		|| IFNULL(Result_Accident, '/NULL/')
		|| '^'
		|| IFNULL(Result_Etc, '/NULL/')
		|| '^'
		|| IFNULL(Specials, '/NULL/')
		|| '^' AS CoaData
	  FROM AttendingSchool
	 WHERE Mogib1 = '${mogib1}'
	   AND Mogib2 = '${mogib2}'
	   AND IdentifyNumber = '${identifyNumber}'
	 ORDER BY SeqNumber
	)
	 UNION ALL
	--국가직무능력표준 이수상황
	SELECT * FROM (
	SELECT '6'
		|| '^'
		|| IFNULL(Year, '/NULL/')
		|| '^'
		|| IFNULL(Grade, '/NULL/')
		|| '^'
		|| IFNULL(Term, '/NULL/')
		|| '^'
		|| IFNULL(DclsfNm, '/NULL/')
		|| '^'
		|| IFNULL(WklvlSbjtCode, '/NULL/')
		|| '^'
		|| IFNULL(AbltyUnitNm, '/NULL/')
		|| '^'
		|| IFNULL(AbltyUnitCode, '/NULL/')
		|| '^'
		|| IFNULL(strDate, '/NULL/')
		|| '^'
		|| IFNULL(OriginalScore, '/NULL/')
		|| '^'
		|| IFNULL(AchievementCode, '/NULL/')
		|| '^'
		|| IFNULL(Achievement, '/NULL/')
		|| '^'
		|| IFNULL(WklvlSbjtNm, '/NULL/')
		|| '^' AS CoaData
	  FROM NCSComptSittn
	 WHERE Mogib1 = '${mogib1}'
	   AND Mogib2 = '${mogib2}'
	   AND IdentifyNumber = '${identifyNumber}'
	 ORDER BY SeqNumber
	)
	UNION ALL
	--창의적재량활동상황
	SELECT * FROM (
	SELECT '8'
		|| '^'
		|| IFNULL(Year, '/NULL/')
		|| '^'
		|| IFNULL(Grade, '/NULL/')
		|| '^'
		|| IFNULL(Subject, '/NULL/')
		|| '^'
		|| IFNULL(CompleteTime, '/NULL/')
		|| '^'
		|| IFNULL(strDate, '/NULL/')
		|| '^'
		|| IFNULL(Specials, '/NULL/')
		|| '^' AS CoaData
	  FROM CreativeActivity
	 WHERE Mogib1 = '${mogib1}'
	   AND Mogib2 = '${mogib2}'
	   AND IdentifyNumber = '${identifyNumber}'
	 ORDER BY SeqNumber
	)
	UNION ALL
 	--특별활동상황
	SELECT * FROM (
	SELECT '9'
		|| '^'
		|| IFNULL(Year, '/NULL/')
		|| '^'
		|| IFNULL(Grade, '/NULL/')
		|| '^'
		|| IFNULL(Subject, '/NULL/')
		|| '^'
		|| IFNULL(strDate, '/NULL/')
		|| '^'
		|| IFNULL(Specials, '/NULL/')
		|| '^' AS CoaData
	  FROM SpecialActivity
	 WHERE Mogib1 = '${mogib1}'
	   AND Mogib2 = '${mogib2}'
	   AND IdentifyNumber = '${identifyNumber}'
	 ORDER BY SeqNumber
	)
	UNION ALL
	--창의적체험활동상황
	SELECT * FROM(
	SELECT '10'
		|| '^'
		|| IFNULL(Year, '/NULL/')
		|| '^'
		|| IFNULL(Grade, '/NULL/')
		|| '^'
		|| IFNULL(MAX(strDate0), '/NULL/')
		|| '^'
		|| IFNULL(MAX(Specials0), '/NULL/')
		|| '^'
		|| IFNULL(MAX(strDate1), '/NULL/')
		|| '^'
		|| IFNULL(MAX(Specials1), '/NULL/')
		|| '^'
		|| IFNULL(MAX(Specials21), '/NULL/')
		|| '^'
		|| IFNULL(MAX(strDate2), '/NULL/')
		|| '^'
		|| IFNULL(MAX(Specials2), '/NULL/')
		|| '^'
		|| IFNULL(MAX(strDate3), '/NULL/')
		|| '^'
		|| IFNULL(MAX(Specials3), '/NULL/')
		|| '^' AS CoaData
	  FROM (
	SELECT Mogib1, Mogib2, IdentifyNumber, Year, Grade
		 , CASE WHEN Subject IN ('자율활동', '자율·자치활동') THEN strDate END AS strDate0
		 , CASE WHEN Subject IN ('자율활동', '자율·자치활동') THEN Specials END AS Specials0
		 , CASE WHEN Subject = '동아리활동' THEN strDate END AS strDate1
		 , CASE WHEN Subject = '동아리활동' THEN Specials END Specials1
		 , CASE WHEN Subject = '동아리활동' THEN Specials2 END Specials21
		 , CASE WHEN Subject = '봉사활동' THEN strDate END AS strDate2
		 , CASE WHEN Subject = '봉사활동' THEN Specials END Specials2
		 , CASE WHEN Subject = '진로활동' THEN strDate END AS strDate3
		 , CASE WHEN Subject = '진로활동' THEN Specials END Specials3
	  FROM CreativeExperActivity
	 WHERE Mogib1 = '${mogib1}'
	   AND Mogib2 = '${mogib2}'
	   AND IdentifyNumber = '${identifyNumber}'
	 ORDER BY SeqNumber
	)
	GROUP BY Mogib1, Mogib2, IdentifyNumber, Year, Grade
	)
	UNION ALL
	--봉사활동실적
	SELECT * FROM (
	SELECT '11'
		|| '^'
		|| IFNULL(Year, '/NULL/')
		|| '^'
		|| IFNULL(Grade, '/NULL/')
		|| '^'
		|| IFNULL(Season, '/NULL/')
		|| '^'
		|| IFNULL(Place, '/NULL/')
		|| '^'
		|| IFNULL(Content, '/NULL/')
		|| '^'
		|| IFNULL(strTime, '/NULL/')
		|| '^' AS CoaData
	  FROM ServiceActivity
	 WHERE Mogib1 = '${mogib1}'
	   AND Mogib2 = '${mogib2}'
	   AND IdentifyNumber = '${identifyNumber}'
	 ORDER BY SeqNumber
	)
	UNION ALL
 	--교외체험학습상황
 	SELECT * FROM (
 	SELECT '12'
 		|| '^'
 		|| IFNULL(Year, '/NULL/')
 		|| '^'
 		|| IFNULL(Grade, '/NULL/')
 		|| '^'
 		|| IFNULL(Season, '/NULL/')
 		|| '^'
 		|| IFNULL(Place, '/NULL/')
 		|| '^'
 		|| IFNULL(Content, '/NULL/')
		|| '^'
 		|| IFNULL(strTime, '/NULL/')
 		|| '^' AS CoaData
 	  FROM ExperienceActivity
 	 WHERE Mogib1 = '${mogib1}'
 	   AND Mogib2 = '${mogib2}'
 	   AND IdentifyNumber = '${identifyNumber}'
 	 ORDER BY SeqNumber
 	)
 	UNION ALL
	--교과학습발달상황
	SELECT * FROM (
	SELECT '13'
		|| '^'
		|| IFNULL(Year, '/NULL/')
		|| '^'
		|| IFNULL(Grade, '/NULL/')
		|| '^'
		|| IFNULL(Term, '/NULL/')
		|| '^'
		|| IFNULL(OrganizationCode, '/NULL/')
		|| '^'
		|| IFNULL(OrganizationName, '/NULL/')
		|| '^'
		|| IFNULL(CourceCode, '/NULL/')
		|| '^'
		|| IFNULL(CourceName, '/NULL/')
		|| '^'
		|| IFNULL(SubjectCode, '/NULL/')
		|| '^'
		|| IFNULL(SubjectName, '/NULL/')
		|| '^'
		|| IFNULL(Unit, '/NULL/')
		|| '^'
		|| IFNULL(Assessment, '/NULL/')
		|| '^'
		|| IFNULL(Rank, '/NULL/')
		|| '^'
		|| IFNULL(SameRank, '/NULL/')
		|| '^'
		|| IFNULL(StudentCount, '/NULL/')
		|| '^'
		|| IFNULL(OriginalScore, '/NULL/')
		|| '^'
		|| IFNULL(AvgScore, '/NULL/')
		|| '^'
		|| IFNULL(StandardDeviation, '/NULL/')
		|| '^'
		|| IFNULL(RankingGrade, '/NULL/')
		|| '^'
		|| IFNULL(RankingGradeCode, '/NULL/')
		|| '^'
		|| IFNULL(Achievement, '/NULL/')
		|| '^'
		|| IFNULL(AchievementCode, '/NULL/')
		|| '^'
		|| IFNULL(AchievementRatio, '/NULL/')
		|| '^'
		|| IFNULL(SubjectSeparationCode, '/NULL/')
		|| '^'
		|| IFNULL(Note, '/NULL/')
		|| '^' AS CoaData
	  FROM SubjectScore
	 WHERE Mogib1 = '${mogib1}'
	   AND Mogib2 = '${mogib2}'
	   AND IdentifyNumber = '${identifyNumber}'
	 ORDER BY SeqNumber
	)
	UNION ALL
	--1995년이전성적
	SELECT * FROM (
	SELECT '14'
		|| '^'
		|| IFNULL(Year, '/NULL/')
		|| '^'
		|| IFNULL(Grade, '/NULL/')
		|| '^'
		|| IFNULL(Term, '/NULL/')
		|| '^'
		|| IFNULL(TotalScore, '/NULL/')
		|| '^'
		|| IFNULL(AvgScore, '/NULL/')
		|| '^'
		|| IFNULL(ClassGrade, '/NULL/')
		|| '^'
		|| IFNULL(ClassStudentNum, '/NULL/')
		|| '^'
		|| IFNULL(TotalGrade, '/NULL/')
		|| '^'
		|| IFNULL(TotalStudentNum, '/NULL/')
		|| '^' AS CoaData
	  FROM LastYearScore
	 WHERE Mogib1 = '${mogib1}'
	   AND Mogib2 = '${mogib2}'
	   AND IdentifyNumber = '${identifyNumber}'
	 ORDER BY SeqNumber
	)
	UNION ALL
	--세부능력 및 특기사항
	SELECT * FROM (
	SELECT '15'
		|| '^'
		|| IFNULL(Year, '/NULL/')
		|| '^'
		|| IFNULL(Grade, '/NULL/')
		|| '^'
		|| IFNULL(Content, '/NULL/')
		|| '^'
		|| IFNULL(Content2, '/NULL/')
		|| '^'
		|| IFNULL(Content3, '/NULL/')
		|| '^' AS CoaData
	  FROM DetailAbility
	 WHERE Mogib1 = '${mogib1}'
	   AND Mogib2 = '${mogib2}'
	   AND IdentifyNumber = '${identifyNumber}'
	 ORDER BY SeqNumber
	)
	UNION ALL
	--행동특성 및 종합의견
	SELECT * FROM (
	SELECT '17'
		|| '^'
		|| IFNULL(Year, '/NULL/')
		|| '^'
		|| IFNULL(Grade, '/NULL/')
		|| '^'
		|| IFNULL(Content, '/NULL/')
		|| '^' AS CoaData
	  FROM TeacherComment
	 WHERE Mogib1 = '${mogib1}'
	   AND Mogib2 = '${mogib2}'
	   AND IdentifyNumber = '${identifyNumber}'
	 ORDER BY SeqNumber
	)
	UNION ALL
	--학교폭력 조치상황 관리
	SELECT * FROM (
	SELECT '18'
		|| '^'
		|| IFNULL(Year, '/NULL/')
		|| '^'
		|| IFNULL(Grade, '/NULL/')
		|| '^'
		|| IFNULL(strDate, '/NULL/')
		|| '^'
		|| IFNULL(Content, '/NULL/')
		|| '^' AS CoaData
	  FROM SchoolViolence
	 WHERE Mogib1 = '${mogib1}'
	   AND Mogib2 = '${mogib2}'
	   AND IdentifyNumber = '${identifyNumber}'
	 ORDER BY SeqNumber
	)
	UNION ALL
	--정정대장
	SELECT * FROM (
	SELECT '50'
		|| '^'
		|| IFNULL(ChangeYear, '/NULL/')
		|| '^'
		|| IFNULL(ChangeDate, '/NULL/')
		|| '^'
		|| IFNULL(StudentInfo, '/NULL/')
		|| '^'
		|| IFNULL(Name, '/NULL/')
		|| '^'
		|| IFNULL(ChangeItemDescription, '/NULL/')
		|| '^'
		|| IFNULL(MistakeDescription, '/NULL/')
		|| '^'
		|| IFNULL(ChangeDescription, '/NULL/')
		|| '^'
		|| IFNULL(ChangeReason, '/NULL/')
		|| '^' AS CoaData
	  FROM CorrectionList
	 WHERE Mogib1 = '${mogib1}'
	   AND Mogib2 = '${mogib2}'
	   AND IdentifyNumber = '${identifyNumber}'
	 ORDER BY SeqNumber
	)
	UNION ALL
	--편제및시간배당
	SELECT * FROM (
	SELECT '60'
		|| '^'
		|| IFNULL(Year, '/NULL/')
		|| '^'
		|| IFNULL(Term, '/NULL/')
		|| '^'
		|| IFNULL(DayNightCode, '/NULL/')
		|| '^'
		|| IFNULL(DayNightName, '/NULL/')
		|| '^'
		|| IFNULL(TrackCode, '/NULL/')
		|| '^'
		|| IFNULL(TrackName, '/NULL/')
		|| '^'
		|| IFNULL(Grade, '/NULL/')
		|| '^'
		|| IFNULL(CourseCode, '/NULL/')
		|| '^'
		|| IFNULL(CourseName, '/NULL/')
		|| '^'
		|| IFNULL(OrganizationCode, '/NULL/')
		|| '^'
		|| IFNULL(OrganizationName, '/NULL/')
		|| '^'
		|| IFNULL(SubjectCode, '/NULL/')
		|| '^'
		|| IFNULL(SubjectName, '/NULL/')
		|| '^'
		|| IFNULL(LessonTime, '/NULL/')
		|| '^'
		|| IFNULL(Unit, '/NULL/')
		|| '^'
		|| IFNULL(CooperationCourseInfo, '/NULL/')
		|| '^' AS CoaData
	  FROM OrganizationList
	 WHERE Mogib1 = '${mogib1}'
	   AND Mogib2 = '${mogib2}'
	   AND IdentifyNumber = '${identifyNumber}'
	 ORDER BY SeqNumber
	)
	UNION ALL
	--과목별 평가정보
	SELECT * FROM (
	SELECT '61'
		|| '^'
		|| IFNULL(Year, '/NULL/')
		|| '^'
		|| IFNULL(Grade, '/NULL/')
		|| '^'
		|| IFNULL(Term, '/NULL/')
		|| '^'
		|| IFNULL(OrganizationCode, '/NULL/')
		|| '^'
		|| IFNULL(SubjectCode, '/NULL/')
		|| '^'
		|| IFNULL(Unit, '/NULL/')
		|| '^'
		|| IFNULL(SubjectName, '/NULL/')
		|| '^'
		|| IFNULL(EvaluationSeparation, '/NULL/')
		|| '^'
		|| IFNULL(ExamName, '/NULL/')
		|| '^'
		|| IFNULL(ExamRatio, '/NULL/')
		|| '^'
		|| IFNULL(EvaluationCode, '/NULL/')
		|| '^'
		|| IFNULL(GradeScoreA, '/NULL/')
		|| '^'
		|| IFNULL(GradeScoreB, '/NULL/')
		|| '^'
		|| IFNULL(GradeScoreC, '/NULL/')
		|| '^'
		|| IFNULL(GradeScoreD, '/NULL/')
		|| '^'
		|| IFNULL(GradeScoreE, '/NULL/')
		|| '^' AS CoaData
	  FROM SubjectEvaluationList
	 WHERE Mogib1 = '${mogib1}'
	   AND Mogib2 = '${mogib2}'
	   AND IdentifyNumber = '${identifyNumber}'
	 ORDER BY SeqNumber
	)
	`
}

/**
 * @description 데이터베이스 파일 생성
 */
this.fnWrkCreateDatabase = function(path){
	var _cmd = 'create_database';
	var _that = this;
	var _virf = this.VirtualFile;
	var _path = path;
	
	function complete(){
		_that.fnShowLog.call(_that, _that.fvLogPerPend + ' 로컬 데이터베이스 파일 생성이 완료되었습니다.');
		_that.fvQueWrks.dequeue();
		_that.fnDoNext.call(_that);
	}
	
	function error(e){
		var statuscode = (!_that.smfIsNull(e) && e.statuscode) ? e.statuscode : '9999';
		_that.fnOnError.call(_that, '(' + statuscode + ')' + _that.fvLogPerPend + ' 로컬 데이터베이스 파일 생성 중 오류가 발생하였습니다.');
	}
	
	function action(){
		_that.fnShowLog.call(_that, _that.fvLogPerPend +  ' 로컬 데이터베이스 파일 생성을 시작하였습니다.');
		_virf.isExist(_path);
	}
	
	function next(e){
		if(e.reason == '10'){ //isExist
			if(!e.fileisexist){
				_virf.open(_path, VirtualFile.openWrite);
			}else{
				complete();
			}
		}else if(e.reason == '1'){ //open
			_virf.close();
		}else if(e.reason == '2'){ //close
			complete();
		}else{
			error();
		}
	}
	
	return {cmd : () => _cmd, path : () => _path, action : action, next : next, error : error}
}

/**
 * @description 데이터베이스 테이블 생성
 */
this.fnWrkCreateTables = function(path){
	var _cmd = 'create_tables';
	var _that = this;
	var _conn = this.LiteDBConnection;
	var _stmt = this.LiteDBStatement;
	var _path = path;
	var _queTables = this.udsfCreateQueue();
	
	_queTables.init(JSON.parse(this.dsTables.saveJSON()).Rows);
	
	function complete(){
		_that.fnShowLog.call(_that, _that.fvLogPerPend + ' 로컬 데이터베이스 테이블 생성이 완료되었습니다.(' + _path + ')');
		_that.fvQueWrks.dequeue();
		_that.fnDoNext.call(_that);
	}
	
	function error(e){
		var statuscode = (!_that.smfIsNull(e) && e.statuscode) ? e.statuscode : '9999';
		var tableNm = _queTables.first() ? _queTables.first().rmkCn : '데이터베이스';
		
		var msg = '(' + statuscode + ')' +  _that.fvLogPerPend + ' ' + tableNm + ' 테이블 생성 중 오류가 발생하였습니다.';
		
		_that.fnOnError.call(_that, msg);
	}

	function action(){
		_that.fnShowLog.call(_that, _that.fvLogPerPend +  ' 로컬 데이터베이스 테이블 생성을 시작하였습니다.');
		_conn.set_datasource(_path);
		_stmt.set_ldbconnection(_conn);
		_conn.open(_path);
	}
	
	function executeUpdate(){
		_stmt.executeUpdate(_queTables.first().ddl);
	}
	
	function next(e){
		if(e.reason == '5'){ //open
			_conn.begin();
		}else if(e.reason == '1'){ //begin
			executeUpdate();
		}else if(e.reason == '8'){ //executeUpdate
			_queTables.dequeue();
			if(_queTables.isEmpty()){
				_stmt.close();
			}else{
				executeUpdate();
			}
		}else if(e.reason == '9'){ //close (statement)
			_conn.commit();
		}else if(e.reason == '3'){ //commit
			_conn.close();
		}else if(e.reason == '2'){ //close
			complete();
		}else{
			error();
		}
	}
	
	return {cmd : () => _cmd, path : () => _path, action : action, next : next, error : error}
}

/**
 * @description SEMS 파일을 데이터베이스에 저장
 */
this.fnWrkSemsToDatabase = function(path){
	var _cmd = 'sems_to_database';
	var _that = this;
	var _virf = this.VirtualFile;
	var _conn = this.LiteDBConnection;
	var _stmt = this.LiteDBStatement;
	var _path = path;
	var _idx = 0;
	var _tables = JSON.parse(this.dsTables.saveJSON()).Rows;
	var _tableSchema = null;
	var _folder = null;
	var _queStu = this.udsfCreateQueue();
	var _queJob = this.udsfCreateQueue();
	var _deletedTables = {}; //삭제한 테이블
	
	var _totCnt = 0; 	//총 학생수
	var _newCnt = 0;	//신규학생수
	var _modCnt = 0;	//변경학생수
	var _errCnt = 0;	//오류학생수
	
	function complete(){
		_that.fvEndTime = Date.now();
		
		var strTime = '';
		var sec = (_that.fvEndTime - _that.fvBgngTime) / 1000.0;
		if(sec >= 60){
			strTime = Math.floor(sec / 60) + '분 ' + Math.floor(sec % 60) + '초';
		}else{
			strTime = sec + '초';
		}
		
		_that.fnShowLog.call(_that, [_that.fvLogPerPend +  ' 로컬 데이터베이스 이관 및 검증 작업이 완료되었습니다.'
									, '처리파일갯수 : ' + (_newCnt + _modCnt + _errCnt)
									, '소요시간 : ' + strTime
									, '신규학생수 : ' + _newCnt
									, '수정학생수 : ' + _modCnt
									, '오류학생수 : ' + _errCnt
									]);
		
		_that.fvQueWrks.dequeue();
		_that.fnDoNext.call(_that);
	}
	
	function error(e, type){
		if(type == 'file') errorFile(e);
		else if(type == 'db'){
			
			if(e.statuscode == '1210' || e.statuscode == '1211') trace(_stmt.query);
		
			if(e.statuscode != '1207'){ //rollback 아닐때
				errorDb(e);
			}
		}
	}
	
	function errorFile(e){
		var statuscode = (!_that.smfIsNull(e) && e.statuscode) ? e.statuscode : '9999';
		
		var msg = ['(' + statuscode + ')'];
		if(!_that.smfIsNull(_virf.filename)){
			msg.push('(' + _virf.filename + ')');
		}
		
		msg.push(_that.fvLogPerPend);
		
		if(statuscode == '9999' && _that.fnIsStr(e)){
			msg.push(e);
		}else{
			msg.push(' 파일을 처리하는 중 오류가 발생하였습니다.');
		}
		
		_that.fnOnError.call(_that, msg.join(''));
	}
	
	function errorDb(e){
		_conn.rollback();
		
		var stu = _queStu ? _queStu.first() : null;
		var data = stu ? (stu.queData ? stu.queData.first() : null) : null;
		var statuscode = (!_that.smfIsNull(e) && e.statuscode) ? e.statuscode : '9999';
		var msg = [];
		
		if(statuscode == '1210' || statuscode == '1211'){ //executeQuery, executeUpdate관련 오류
			msg.push(e.ldberrormsg + '\n\n');
		}
		
		msg.push('(' + statuscode + ')');
		if(!_that.smfIsNull(_virf.filename)){
			msg.push('(' + _virf.filename + ')');
		}
		
		if(!_that.smfIsNull(data)){
			var table = findTable(data[0]);
			if(table != null) msg.push('(' + table.rmkCn + ')');
		}
		
		msg.push(_that.fvLogPerPend);
		
		if(statuscode == '9999' && _that.fnIsStr(e)){
			msg.push(e);
		}else{
			msg.push(' 이관 및 검증 중 오류가 발생하였습니다.');
		}
		
		if(!_that.smfIsNull(data)){
			_that.fnShowLog.call(_that, '오류데이터 : ' + data.join('^'));
		}
		
		_that.fnOnError.call(_that, msg.join(''));
	}

	function action(){
		_that.fnShowLog.call(_that, _that.fvLogPerPend +  ' 로컬 데이터베이스 이관 및 검증 작업을 시작하였습니다.');
		
		_conn.set_datasource(_path);
		_stmt.set_ldbconnection(_conn);
		
		_folder = _path.substring(0, _path.lastIndexOf('\\'));
		_virf.getFileList(_folder, '\\.' + _that.fvSems, VirtualFile.findFileOnly);
	}
	
	function mapping(table, stu){
		var columns = _tableSchema[table.name].columns;
		var pks = _tableSchema[table.name].pks;
		var data = stu.queData.first();
		var values = Array(columns.length).fill('null');
		
		function mappingBasePk(){
			values[0] = toParam(stu.mogib1);
			values[1] = toParam(stu.mogib2);
			values[2] = toParam(stu.identifyNumber);
		}
		
		function toParam(val){
			if(val == '/NULL/') return 'null';
			if(val == null) return 'null';
			
			if(_that.fnIsStr(val)){
				val = val.replace(/[']/g, '\'\'')
				val = val.replace(/\/EOR\//gi, '\n')
				return "'" + val + "'";
			}
			
			return val;
		}
		
		function mappingIndex(valIndex, dataIndex, cnt){
			for(var i = 0; i < cnt; i++){
				values[valIndex + i] = toParam(data[dataIndex + i]);
			}
		}
		
		function getQuerySeqNumber(val){
			if(typeof val != 'number') val = 1;
			if(val < 1) val = 1;
			
			var where = `${pks[0]} = '${stu.mogib1}' AND ${pks[1]} = '${stu.mogib2}' AND ${pks[2]} = '${stu.identifyNumber}'`;
			return `(SELECT IFNULL(MAX(SeqNumber), 0) + ${val} FROM ${table.name} WHERE ${where})`
		}
		
		//PK 매핑
		mappingBasePk();
		
		if(table.name == 'StudentBaseInfo'){ //---------------------학생정보
			values[3] = toParam(stu.socialNumber);//SocialNumber 주민등록번호
			values[4] = toParam(stu.schoolCode);//SchoolCode 고등학교코드
			mappingIndex(5, 1, 2);
			mappingIndex(7, 4, 9);
		}else if(table.name == 'PersonalInfo'){//---------------------인적사항
			values[3] = toParam(stu.socialNumber);//SocialNumber 주민등록번호
			values[4] = toParam(stu.schoolCode);//SchoolCode 고등학교코드
			mappingIndex(5, 2, 4);
			mappingIndex(9, 7, 7);
		}else if(table.name == 'StudyHistory'){ //---------------------학적사항
			values[3] = getQuerySeqNumber(); //SeqNumber 순번
			values[4] = toParam(stu.socialNumber); //SocialNumber 주민등록번호
			values[5] = toParam(stu.schoolCode); //SchoolCode 고등학교코드
			mappingIndex(6, 1, 4);
		}else if(table.name == 'AttendingSchool'){ //---------------------출결상황
			values[3] = getQuerySeqNumber(); //SeqNumber 순번
			values[4] = toParam(stu.socialNumber); //SocialNumber 주민등록번호
			values[5] = toParam(stu.schoolCode); //SchoolCode 고등학교코드
			mappingIndex(6, 1, 16);
		}else if(table.name == 'NCSComptSittn'){ //---------------------국가직무능력표준 이수상황
			values[3] = getQuerySeqNumber(); //SeqNumber 순번
			values[4] = toParam(stu.socialNumber); //SocialNumber 주민등록번호
			values[5] = toParam(stu.schoolCode); //SchoolCode 고등학교코드
			values[6] = toParam(data[1]); //Year 학년도
			values[7] = toParam(data[2]); //Grade 학년
			values[8] = toParam(data[3]); //Term 학기
			values[9] = toParam(data[4]); //DclsfNm 세분류명
			values[10] = toParam(data[7]); //AbltyUnitCode 능력단위코드
			values[11] = toParam(data[6]); //AbltyUnitNm 능력단위명
			values[12] = toParam(data[5]); //WklvlSbjtCode 실무과목코드
			values[13] = toParam(data[12]); //WklvlSbjtNm 실무과목명
			values[14] = toParam(data[8]); //strDate 이수시간
			values[15] = toParam(data[9]); //OriginalScore 원점수
			values[16] = toParam(data[11]); //Achievement 성취평가
			values[17] = toParam(data[10]); //AchievementCode 성취평가코드
		}else if(table.name == 'CreativeActivity'){ //---------------------창의적재량활동
			values[3] = getQuerySeqNumber(); //SeqNumber 순번
			values[4] = toParam(stu.socialNumber); //SocialNumber 주민등록번호
			values[5] = toParam(stu.schoolCode); //SchoolCode 고등학교코드
			values[6] = toParam(data[1]); //Year 학년도
			values[7] = toParam(data[2]); //Grade 학년
			values[8] = toParam(data[3]); //Subject 활동영역 또는 주제
			values[9] = toParam(data[4]); //CompleteTime 이수시간
			values[10] = toParam(data[5]); //strDate 이수시간단위
			values[11] = toParam(data[6]); //Specials 특기사항
			
		}else if(table.name == 'SpecialActivity'){ //---------------------특별활동상황
			values[3] = getQuerySeqNumber(); //SeqNumber 순번
			values[4] = toParam(stu.socialNumber); //SocialNumber 주민등록번호
			values[5] = toParam(stu.schoolCode); //SchoolCode 고등학교코드
			values[6] = toParam(data[1]); //Year 학년도
			values[7] = toParam(data[2]); //Grade 학년
			values[8] = toParam(data[3]); //Subject
			values[9] = toParam(data[4]);
			values[10] = toParam(data[5]);	
		}else if(table.name == 'CreativeExperActivity'){ //---------------------창의적체험활동상황
			var dvsValues = [];
			
			//자율활동,동아리활동,봉사활동,진로활동
			for(var i = 0; i < 4; i++){
				values = Array(columns.length).fill('null');
				mappingBasePk();
				
				values[3] = getQuerySeqNumber(i + 1); //SeqNumber 순번
				values[4] = toParam(stu.socialNumber); //SocialNumber 주민등록번호
				values[5] = toParam(stu.schoolCode); //SchoolCode 고등학교코드
				
				values[6] = toParam(data[1]); //Year 학년도
				values[7] = toParam(data[2]); //Grade 학년
				if(i == 0){ //자율활동
					var actNm = '자율활동';
					if(data[1] >= '2027' 
						|| (data[1] == '2025' && data[2] == '1')
						|| (data[1] == '2026' && data[2] == '1')
						|| (data[1] == '2026' && data[2] == '2')){
						actNm = '자율·자치활동';
					}
					
					values[8] = toParam(actNm); //Subject 활동 영역명(자율활동,동아리활동,봉사활동,진로활동)
					values[9] = toParam(data[3]); //strDate 이수시간
					values[10] = toParam(data[4]); //Specials 특기사항
				}else if(i == 1){ //동아리활동
					values[8] = toParam('동아리활동'); //Subject 활동 영역명(자율활동,동아리활동,봉사활동,진로활동)
					values[9] = toParam(data[5]); //strDate 이수시간
					values[10] = toParam(data[6]); //Specials 특기사항
					values[11] = toParam(data[7]); //Specials2 통합동아리 특기사항
				}else if(i == 2){ //봉사활동
					values[8] = toParam('봉사활동'); //Subject 활동 영역명(자율활동,동아리활동,봉사활동,진로활동)
					values[9] = toParam(data[8]); //strDate 이수시간
					values[10] = toParam(data[9]); //Specials 특기사항
				}else if(i == 3){ //진로활동
					values[8] = toParam('진로활동'); //Subject 활동 영역명(자율활동,동아리활동,봉사활동,진로활동)
					values[9] = toParam(data[10]); //strDate 이수시간
					values[10] = toParam(data[11]); //Specials 특기사항
				}
				
				dvsValues.push(values);
			}
			return dvsValues;
		}else if(table.name == 'ServiceActivity'){ //---------------------봉사활동실적
			values[3] = getQuerySeqNumber(); //SeqNumber 순번
			values[4] = toParam(stu.socialNumber); //SocialNumber 주민등록번호
			values[5] = toParam(stu.schoolCode); //SchoolCode 고등학교코드
			
			mappingIndex(6, 1, 4);
			
			values[10] = toParam(data[6]);
			values[11] = toParam(data[5]);
		}else if(table.name == 'ExperienceActivity'){ //---------------------교외체험학습상황
			values[3] = getQuerySeqNumber(); //SeqNumber 순번
			values[4] = toParam(stu.socialNumber); //SocialNumber 주민등록번호
			values[5] = toParam(stu.schoolCode); //SchoolCode 고등학교코드
			values[6] = toParam(data[1]); //Year 학년도
			values[7] = toParam(data[2]); //Grade 학년
			values[8] = toParam(data[3]); //Season 일자 또는 기간
			values[9] = toParam(data[4]); //Place 장소 또는 주관기관명
			values[10] = toParam(data[6]); //strTime 시간 또는 일수 
			values[11] = toParam(data[5]); //Content 내용
		}else if(table.name == 'SubjectScore'){ //---------------------교과학습발달상황
			values[3] = getQuerySeqNumber(); //SeqNumber 순번
			values[4] = toParam(stu.socialNumber); //SocialNumber 주민등록번호
			values[5] = toParam(stu.schoolCode); //SchoolCode 고등학교코드
			
			mappingIndex(6, 1, 2);
			mappingIndex(8, 4, 6);
			values[14] = toParam(data[3]);
			mappingIndex(15, 10, 15);
			
		}else if(table.name == 'LastYearScore'){ //---------------------1995년이전성적
			values[3] = getQuerySeqNumber(); //SeqNumber 순번
			values[4] = toParam(stu.socialNumber); //SocialNumber 주민등록번호
			values[5] = toParam(stu.schoolCode); //SchoolCode 고등학교코드
			
			mappingIndex(6, 1, 9);
			
		}else if(table.name == 'DetailAbility'){ //---------------------세부능력 및 특기사항
			values[3] = getQuerySeqNumber(); //SeqNumber 순번
			values[4] = toParam(stu.socialNumber); //SocialNumber 주민등록번호
			values[5] = toParam(stu.schoolCode); //SchoolCode 고등학교코드
			
			mappingIndex(6, 1, 5);
			
		}else if(table.name == 'TeacherComment'){ //---------------------행동특성 및 종합의견
			values[3] = getQuerySeqNumber(); //SeqNumber 순번
			values[4] = toParam(stu.socialNumber); //SocialNumber 주민등록번호
			values[5] = toParam(stu.schoolCode); //SchoolCode 고등학교코드
			
			mappingIndex(6, 1, 3);
		}else if(table.name == 'SchoolViolence'){ //---------------------학교폭력 조치사항 관리
			values[3] = getQuerySeqNumber(); //SeqNumber 순번
			values[4] = toParam(stu.socialNumber); //SocialNumber 주민등록번호
			values[5] = toParam(stu.schoolCode); //SchoolCode 고등학교코드
			
			mappingIndex(6, 1, 4);
		
		}else if(table.name == 'CorrectionList'){ //---------------------정정대장
			values[3] = getQuerySeqNumber(); //SeqNumber 순번
			values[4] = toParam(stu.socialNumber); //SocialNumber 주민등록번호
			values[5] = toParam(stu.schoolCode); //SchoolCode 고등학교코드
			
			mappingIndex(6, 1, 8);
		}else if(table.name == 'OrganizationList'){ //---------------------편제및시간배당
			values[3] = getQuerySeqNumber(); //SeqNumber 순번
			values[4] = toParam(stu.socialNumber); //SocialNumber 주민등록번호
			values[5] = toParam(stu.schoolCode); //SchoolCode 고등학교코드
			
			mappingIndex(6, 1, 16);
		}else if(table.name == 'SubjectEvaluationList'){ //---------------------과목별평가정보
			values[3] = getQuerySeqNumber(); //SeqNumber 순번
			values[4] = toParam(stu.socialNumber); //SocialNumber 주민등록번호
			values[5] = toParam(stu.schoolCode); //SchoolCode 고등학교코드
			
			mappingIndex(6, 1, 16);
		}
		
		return values;
	}
	
	//전형자료에서 항목 인덱스 찾기
	function findItem(itemNo){
		return _queStu.first().queData.find((v) => v[0] == itemNo);
	}
	
	//항목 인덱스로 테이블 찾기
	function findTable(itemNo){
		return _tables.find((v) => v.itemNo == itemNo);
	}
	
	//오류수량 증가 후 다음 학생으로 진행
	function errorAndNext(){
		_errCnt++;
		_queStu.dequeue();

		if(_queStu.isEmpty()) complete();
		else _virf.open(_queStu.first().path, VirtualFile.openRead);
	}

	//업무처리 실행
	function executeJob(){
		_queJob.clear(); //job 초기화
		
		//테이블 스키마 조회
		if(_tableSchema == null){
			_tableSchema = {};
			
			_queJob.enqueue({ type : JOB_TYPE.CONN_OPEN, execute : () => _conn.open() });
			_queJob.enqueue({ type : JOB_TYPE.CONN_OPEN_CALLBACK, execute : () => _queJob.dequeue().execute() });
			
			var tablenames = _tables.map((v) => v.name);
			for(var i = 0; i < tablenames.length; i++){
				//테이블 정보조회
				_queJob.enqueue(function(){
					var tablename = tablenames[i];
					return {
						type : JOB_TYPE.EXECUTE_QUERY,
						execute : () => {
							_stmt.executeQuery(`PRAGMA table_info('${tablename}')`);
						}
					}
				}());
				
				//테이블 정보조회 후처리
				_queJob.enqueue(function(){
					var tablename = tablenames[i];
					return {
						type : JOB_TYPE.EXECUTE_QUERY_CALLBACK,
						execute : (e) => {
							_tableSchema[tablename] = JSON.parse(e.returnvalue.saveJSON()).Rows.reduce((a, v, i) => {
								a.colCnt++;
								
								if(Number(v.pk) > 0){
									a.pkCnt++;
									a.pks.push(v.name);
								}
																
								a.columns.push(v.name);
								return a;
							}, {colCnt : 0, pkCnt : 0, pks : [], columns : []});
							
							//다음 job 호출
							_queJob.dequeue().execute();
						}
					}
				}());
			}
			
			_queJob.enqueue({ type : JOB_TYPE.CONN_CLOSE, execute : () => _conn.close() });
			_queJob.enqueue({ type : JOB_TYPE.CONN_CLOSE_CALLBACK, execute : () => executeJob() });
			
			_queJob.dequeue().execute();
			return;
		}
		
		var stu = _queStu.first();
		var item = stu.queData.first();
		var table = findTable(item[0]);
		
		if(_that.smfIsNull(table)){
			errorDb(' 항목번호 \'' + item[0] +'\'의 테이블은 존재하지 않습니다.');
			return;
		}
		
		var schema = _tableSchema[table.name];
	
		//학생정보 테이블
		if(table.name == 'StudentBaseInfo'){
			_queJob.enqueue({ type : JOB_TYPE.CONN_OPEN, execute : () => _conn.open() });
			_queJob.enqueue({ type : JOB_TYPE.CONN_OPEN_CALLBACK, execute : () => {
				_stmt.set_ldbconnection(_conn);
				_stmt.executeQuery(`PRAGMA synchronous=OFF`);
			}});
			
			_queJob.enqueue({type : JOB_TYPE.EXECUTE_QUERY_CALLBACK, execute : (e) => _stmt.executeQuery(`PRAGMA journal_mode=MEMORY`) });
			_queJob.enqueue({ type : JOB_TYPE.EXECUTE_QUERY_CALLBACK, execute : (e) => _stmt.executeQuery(`PRAGMA count_changes=OFF`) });
			
			_queJob.enqueue({ type : JOB_TYPE.EXECUTE_QUERY_CALLBACK, execute : () => _conn.begin() });
			_queJob.enqueue({ type : JOB_TYPE.CONN_BEGIN_CALLBACK, execute : () => _queJob.dequeue().execute() });
			
			//학생정보 수량 조회
			_queJob.enqueue(function(){
				return {
					type : JOB_TYPE.EXECUTE_QUERY,
					execute : () => {
						_stmt.executeQuery(`
							SELECT COUNT(*) AS cnt FROM ${table.name} WHERE Mogib1 = '${stu.mogib1}' AND Mogib2 = '${stu.mogib2}' AND IdentifyNumber = '${stu.identifyNumber}'
						`);
					}
				}
			}());

			//학생정보 수량 조회 후처리
			_queJob.enqueue(function(){
				return {
					type : JOB_TYPE.EXECUTE_QUERY_CALLBACK,
					execute : (e) => {
						var cnt = e.returnvalue.getColumn(0, 'cnt');
						if(cnt == 0) _newCnt++;
						else _modCnt++;
						
						//다음 job 호출
						_queJob.dequeue().execute();
					}
				}
			}());
			
			//학생정보 저장
			_queJob.enqueue(function(){
				var columns = schema.columns.join(', ');
				var mappedData = mapping(table, stu).join(', ');
				
				return {
					type : JOB_TYPE.EXECUTE_UPDATE,
					execute : (e) => {
						_stmt.executeUpdate(`
							INSERT OR REPLACE INTO ${table.name}(
							  ${columns}
							)VALUES(
							  ${mappedData}
							)
						`);
					}
				}
			}());
			
			//학생정보 저장 후처리
			_queJob.enqueue({ type : JOB_TYPE.EXECUTE_UPDATE_CALLBACK, execute : (e) => _queJob.dequeue().execute() });
			
		}else{
			if(_deletedTables[table.name]){ //이미 삭제한 테이블이면
				_queJob.enqueue({ type : JOB_TYPE.EXECUTE, execute : (e) => _queJob.dequeue().execute() });
			}else{ //삭제하지 않은 테이블이면
				_deletedTables[table.name] = table.name;
				
				//데이터 삭제
				_queJob.enqueue(function(){
					var pks = _tableSchema[table.name].pks;
					var where = `${pks[0]} = '${stu.mogib1}' AND ${pks[1]} = '${stu.mogib2}' AND ${pks[2]} = '${stu.identifyNumber}'`;
					
					return {
						type : JOB_TYPE.EXECUTE_UPDATE,
						execute : () => {
							_stmt.executeUpdate(`
								DELETE FROM ${table.name} WHERE ${where}
							`);
						}
					}
				}());
			}
			
			//데이터 삭제 후처리 ( 데이터 저장 )
			_queJob.enqueue(function(){
				var columns = schema.columns.join(', ');
				var valMap = mapping(table, stu);
				
				if(Array.isArray(valMap[0])){
					var mappedData = valMap.map((v) => 'SELECT ' + v.join(', ')).join(' UNION ALL\n');
					return {
						type : JOB_TYPE.EXECUTE_UPDATE_CALLBACK,
						execute : () => {
							_stmt.executeUpdate(`
								INSERT INTO ${table.name}(
								  ${columns}
								)
								${mappedData}
							`);
						}
					}
				}
				
				var mappedData =  valMap.join(', ');
				return {
					type : JOB_TYPE.EXECUTE_UPDATE_CALLBACK,
					execute : () => {
						_stmt.executeUpdate(`
							INSERT INTO ${table.name}(
							  ${columns}
							)VALUES(
							  ${mappedData}
							)
						`);
					}
				}
			}());
			
			//데이터 저장 후처리
			_queJob.enqueue({ type : JOB_TYPE.EXECUTE_UPDATE_CALLBACK, execute : (e) => _queJob.dequeue().execute() });
		}
		
		//업무 완료 되었는지 확인
		_queJob.enqueue({ type : JOB_TYPE.EXECUTE, execute : (e) => {
			//완료 항목 제거
			stu.queData.dequeue();
			if(stu.queData.isEmpty()){
				var cmptnRate = ((_newCnt + _modCnt + _errCnt) / _totCnt) * 100;
				_that.pgbCmptn.set_pos(cmptnRate);
				_that.pgbCmptn.set_text(Math.floor(cmptnRate) + "%");
				
				//커밋
				_queJob.enqueue({ type : JOB_TYPE.CONN_COMMIT, execute : () => _conn.commit() });
				
				_queJob.enqueue(function(){
					var mogib1 = stu.mogib1;
					var mogib2 = stu.mogib2;
					var identifyNumber = stu.identifyNumber;
					
					return {
						type : JOB_TYPE.CONN_COMMIT_CALLBACK,
						execute : (e) => {
							_stmt.executeQuery(_that.fnGetVrfcQuery(mogib1, mogib2, identifyNumber));
						}
					}
				}());
				
				//검증
				_queJob.enqueue(function(){
					var mogib1 = stu.mogib1;
					var mogib2 = stu.mogib2;
					var identifyNumber = stu.identifyNumber;
										
					return {
						type : JOB_TYPE.EXECUTE_QUERY_CALLBACK,
						execute : (e) => {
							var orgRows = _queStu.first().orgData.split('\r\n');
							var tarRows = [];
							
							for(var i = 0; i < e.returnvalue.getRowCount(); i++){
								 tarRows.push(e.returnvalue.getColumn(i, 'CoaData'));
							}
							
							for(var i = 0; i < orgRows.length; i++){
								var itemNo = orgRows[i].substring(0, orgRows[i].indexOf('^'));
								
								if(_that.fnIsStr(tarRows[i])){
									tarRows[i] = tarRows[i].replace(/\n/gi, '/EOR/');
								}
								
								if(orgRows[i] != tarRows[i]){
									//오류 학생 데이터 삭제
									_that.fnShowLog.call(_that, ['[' + findTable(itemNo).rmkCn +  '] 원본(SEMS) 데이터와 이관된 데이터가 일치하지 않아 해당 데이터를 모두 삭제 합니다.'
																, '원본 : ' + orgRows[i]
																, '이관 : ' + tarRows[i]
																]);
									_queJob.clear();
									
									for(var i = 0; i < _tables.length; i++){
										_queJob.enqueue(function(){
											var tableNm = _tables[i].name;
											var pks = _tableSchema[tableNm].pks;
											var where = `${pks[0]} = '${mogib1}' AND ${pks[1]} = '${mogib2}' AND ${pks[2]} = '${identifyNumber}'`;
											
											return {
												type : JOB_TYPE.EXECUTE_UPDATE,
												execute : () => {
													_stmt.executeUpdate(`
														DELETE FROM ${tableNm} WHERE ${where}
													`);
												}
											}
										}());
										
										_queJob.enqueue({ type : JOB_TYPE.EXECUTE_UPDATE_CALLBACK, execute : () => _queJob.dequeue().execute() });
									}
									
									_queJob.enqueue(function(){
										var rmkCn = findTable(itemNo).rmkCn;
										return {
											type : JOB_TYPE.EXECUTE,
											execute : () => errorDb(' [' + rmkCn + '] 원본(SEMS) 데이터와 이관된 데이터가 일치하지 않습니다.')
										}
									}());
									
									_queJob.dequeue().execute();
									return;
								}
							}
							
							_queStu.dequeue(); 	 //완료된 학생 제거
							_deletedTables = {}; //삭제된 테이블 초기화
							
							_queJob.dequeue().execute();
						}
					}
				}());
				
				_queJob.enqueue({ type : JOB_TYPE.CONN_CLOSE, execute : () => _conn.close() });
				_queJob.enqueue({ type : JOB_TYPE.CONN_CLOSE_CALLBACK, execute : () => {
					if(_queStu.isEmpty()) complete();
					else _virf.open(_queStu.first().path, VirtualFile.openRead);
				}});

				//실행
				_queJob.dequeue().execute();
				return;
			}
			
			executeJob();
		}});
		
		//실행
		_queJob.dequeue().execute();
	}
	
	function nextFile(e){
		if(e.reason == '8'){ //getFileList
			var stuInfos = e.fileattributelist.map((v) => {
				var stuInfo = v.filename.substring(0, v.filename.lastIndexOf('.')).split('_');
				return {
					path : _folder + '//' + v.filename,
					mogib1 : stuInfo[1],		  //모집시기
					mogib2 : stuInfo[2],    	  //평가단위코드
					identifyNumber : stuInfo[3],  //개인식별번호
					uniqueFileName : v.filename,  //전형파일명
				}
			});
			if(stuInfos.length > 0){
				_totCnt = stuInfos.length;
				_that.fnShowLog.call(_that, '처리해야할 파일건수는 총 ' + _totCnt + '건입니다.');
				_queStu.init(stuInfos);
				_virf.open(_queStu.first().path, VirtualFile.openRead);
			}else{
				errorFile('가 존재하지 않습니다.');
			}
		}else if(e.reason == '1'){ //open
			_virf.read();
		}else if(e.reason == '3'){ //read
			var stu = _queStu.first();
			stu.orgData = e.textdata;
			stu.queData = _that.udsfCreateQueue();
			
			_virf.close();
		}else if(e.reason == '2'){ //close
			var stu = _queStu.first();
			
			//파일 크기 검증
			if(stu.orgData.length == 0){
				_that.fnShowLog.call(_that, '(' + stu.uniqueFileName + ') 파일이 0KB 입니다.');
				errorAndNext();
				return;
			}
			
			//SEMS파일 마지막이 \r 이면 제거
			if(stu.orgData[stu.orgData.length - 1] == '\r'){
				stu.orgData = stu.orgData.substring(0, stu.orgData.length - 1);
			}
			
			//SEMS파일 마지막이 \r\n 이면 제거
			if(stu.orgData[stu.orgData.length - 1] == '\n' && stu.orgData[stu.orgData.length - 2] == '\r'){
				stu.orgData = stu.orgData.substring(0, stu.orgData.length - 2);
			}

			var orgRows = stu.orgData.split('\r\n');
			for(var i = 0; i < orgRows.length; i++){
				var rowData = orgRows[i];
				var firstSplitIdx = rowData.indexOf('^');
				//구분자 포멧 검증
				if(firstSplitIdx < 0){
					_that.fnShowLog.call(_that, '(' + stu.uniqueFileName + ') 파일의 형식이 맞지 않습니다.');
					errorAndNext();
					return;
				}
				
				var itemNo = rowData.substring(0, firstSplitIdx);
				var table = findTable(itemNo);
				
				//아이템번호 검증
				if(_that.smfIsNull(table)){
					_that.fnShowLog.call(_that, '(' + stu.uniqueFileName + ') 파일의 정의되지 않은 항목번호(' + itemNo + ')가 있습니다.');
					errorAndNext();
					return;
				}
			}
		
			stu.queData.init(orgRows.map((v) => v.split('^')));
			
			var item0 = findItem(0); //학생정보
			var item1 = findItem(1); //인적사항

			//학생정보 유무 검증
			if(!item0){
				_that.fnShowLog.call(_that, '(' + stu.uniqueFileName + ') 파일에 학생정보가 존재하지 않습니다.');
				errorAndNext();
				return;
			}

			//인적사항 유무 검증
			if(!item1){
				_that.fnShowLog.call(_that, '(' + stu.uniqueFileName + ') 파일에 인적사항이 존재하지 않습니다.');
				errorAndNext();
				return;
			}

			stu.identifyNumber = item0[3] //개인식별번호
			stu.socialNumber = item1[6];  //주민등록번호
			stu.schoolCode = item1[1];    //학교코드
			
			executeJob();
		}else{
			errorFile();
		}
	}
	
	function nextDb(e){
		if(e.reason != '6'){ //rollback
			var job = _queJob.dequeue();
			if(job == null || job.type != e.reason) errorDb();
			else job.execute(e);
		}
	}
	
	function next(e, type){
		if(type == 'file') nextFile(e);
		else if(type == 'db') nextDb(e);
	}
	
	return {cmd : () => _cmd, path : () => _path, action : action, next : next, error : error}
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

/**
 * @description 경로선택
 */
this.divMain_btnCoaDataPath_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objExtCommon = this.smfCreateExtCommonAPI();
	
	var coaDataPath = nexacro.getPrivateProfile(this.udsv_coaDataPathValue);
	if(this.smfIsNull(coaDataPath)){
		coaDataPath = objExtCommon._ext_getSystemDir("CSIDL_PERSONAL"); 
	}
	coaDataPath = objExtCommon._ext_selectFolderPath(coaDataPath);
	
	objExtCommon = null;
	
	if(!this.smfIsNull(coaDataPath)){
		this.divMain.form.edtCoaDataPath.set_value(coaDataPath);
		this.divMain.form.txtCoaDataDtlPath.set_value(this.udsfGetCoaDataDtlPath(coaDataPath));
		
		this.udsfSetCoaDataPath(coaDataPath);
		
		this.fvCoaDataDownPath = this.udsfGetCoaDataDownPath();   // 수신경로
		this.fvCoaDataBlindPath = this.udsfGetCoaDataBlindPath(); // 블라인드자료경로
		this.fvCoaDataDecrPath = this.udsfGetCoaDataDecrPath();   // 블라인드해제자료경로
	}
};

/**
 * @description 적용
 */
this.btnPrcs_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.setWaitCursor(true);

	this.fvQueWrks.clear();
	
	this.fvIsBld = obj.id == 'btnLocalDbBldCrt';
	this.fvLogPerPend = this.fvIsBld ? '블라인드자료' : '블라인드해제자료';
	this.fvPath = (this.fvIsBld ? this.fvCoaDataBlindPath : this.fvCoaDataDecrPath) + this.fvDbNm;
	
	this.pgbCmptn.set_pos(0);
	this.pgbCmptn.set_text("0%");
	this.divMain00.form.txtLog.set_value('');
	this.fvLog.length = 0;
	this.fvBgngTime = Date.now();
	
	//1. db파일 존재 확인 ( 없으면 생성 )
	this.fvQueWrks.enqueue(this.fnWrkCreateDatabase.call(this, this.fvPath));
	
	//2. 테이블 생성
	this.fvQueWrks.enqueue(this.fnWrkCreateTables.call(this, this.fvPath));
	
	//3. 테이블 이관 및 검증
	this.fvQueWrks.enqueue(this.fnWrkSemsToDatabase.call(this, this.fvPath));
	
	//시작
	this.fnDoNext();
};

this.VirtualFile_onerror = function(obj:nexacro.VirtualFile,e:nexacro.VirtualFileErrorEventInfo)
{
	if(this.fvQueWrks != null && !this.fvQueWrks.isEmpty()) this.fvQueWrks.first().error(e, 'file');
};

this.VirtualFile_onsuccess = function(obj:nexacro.VirtualFile,e:nexacro.VirtualFileEventInfo)
{
	if(this.fvQueWrks != null && !this.fvQueWrks.isEmpty()){
		if(e.reason == '1' && (++this.fvAliveCnt % 1000 == 0)){
			this.fvAliveCnt = 0;
			this.fnExecuteAlive();
		}
    
		this.fvQueWrks.first().next(e, 'file');
	}
};

this.LiteDB_onerror = function(obj:nexacro.LiteDBConnection,e:nexacro.LiteDBErrorEventInfo)
{
	if(this.fvQueWrks != null && !this.fvQueWrks.isEmpty()) this.fvQueWrks.first().error(e, 'db');
};

this.LiteDB_onsuccess = function(obj:nexacro.LiteDBConnection,e:nexacro.LiteDBEventInfo)
{
	if(this.fvQueWrks != null && !this.fvQueWrks.isEmpty()) this.fvQueWrks.first().next(e, 'db');
};

/**
 * @description 닫기
 */
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};]]></Script>
    <Bind>
      <BindItem id="item0" compid="pgbCmptn" propid="pos" datasetid="dsMainTtl" columnid="coaWrkPrcsPos"/>
    </Bind>
  </Form>
</FDL>
