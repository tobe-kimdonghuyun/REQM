            <Col id="rmkCn">인적사항</Col>
          </Row>
          <Row>
            <Col id="ddl">CREATE TABLE IF NOT EXISTS StudyHistory(Mogib1 VARCHAR(10), Mogib2 VARCHAR(60), IdentifyNumber VARCHAR(10), SeqNumber INTEGER, SocialNumber VARCHAR(13), SchoolCode VARCHAR(10), StudyCode VARCHAR(2), StudyCodeName VARCHAR(200), strDate VARCHAR(8), Description TEXT, CONSTRAINT sqlite_autoindex_StudyHistory_1 PRIMARY KEY (Mogib1, Mogib2, IdentifyNumber, SeqNumber))</Col>
            <Col id="name">StudyHistory</Col>
            <Col id="itemNo">2</Col>
            <Col id="rmkCn">학적사항</Col>
          </Row>
          <Row>
            <Col id="itemNo">3</Col>
            <Col id="ddl">CREATE TABLE IF NOT EXISTS AttendingSchool(Mogib1 VARCHAR(10), Mogib2 VARCHAR(60), IdentifyNumber VARCHAR(10), SeqNumber INTEGER, SocialNumber VARCHAR(13), SchoolCode VARCHAR(10), Year VARCHAR(4), Grade INTEGER, StudyDayCount INTEGER, Absence_Disease INTEGER, Absence_Accident INTEGER, Absence_Etc INTEGER, Lateness_Disease INTEGER, Lateness_Accident INTEGER, Lateness_Etc INTEGER, EarlyLeaving_Disease INTEGER, EarlyLeaving_Accident INTEGER, EarlyLeaving_Etc INTEGER, Result_Disease INTEGER, Result_Accident INTEGER, Result_Etc INTEGER, Specials TEXT, CONSTRAINT sqlite_autoindex_AttendingSchool_1 PRIMARY KEY (Mogib1, Mogib2, IdentifyNumber, SeqNumber))</Col>
