            <Col id="ddl">CREATE TABLE IF NOT EXISTS DetailAbility(Mogib1 VARCHAR(10), Mogib2 VARCHAR(60), IdentifyNumber VARCHAR(10), SeqNumber INTEGER, SocialNumber VARCHAR(13), SchoolCode VARCHAR(10), Year VARCHAR(4), Grade INTEGER, Content TEXT, Content2 TEXT, Content3 TEXT, CONSTRAINT sqlite_autoindex_DetailAbility_1 PRIMARY KEY (Mogib1, Mogib2, IdentifyNumber, SeqNumber))</Col>
