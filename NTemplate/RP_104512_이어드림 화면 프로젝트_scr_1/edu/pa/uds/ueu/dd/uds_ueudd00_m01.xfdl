/**
 * @description 양식다운로드
 */
this.btnFormDown_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsExcel.clearData();
	
	for(var i = 1; i <= 5; i++){
		var idx = this.dsExcel.addRow();
		this.dsExcel.setColumn(idx, "coaEvlUnitId", "Z1234-99"+i);
		this.dsExcel.setColumn(idx, "coaEvlUnitNm", "일반전형-ㅇㅇ학과(예시"+i+")");
	}
	
	var objOption = {	objGrid : this.grdExcel
					,	sheetname : "Sheet1"
					,   filename : "평가단위코드(양식)"
					};
	
	this.smfExcelExport(objOption);
};

