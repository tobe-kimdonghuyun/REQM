/**
 * @description 대입전형자료온라인수신서비스신청
 */
this.btnCoaSvcAply_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 팝업 파라메터
	var popupParams = {
		callback: this.fnCoaSvcAplyPopupCallback, // 콜백함수 지정
		sender: obj, // sender 지정
		params: {
			procType: "save", // 처리타입 지정
			fnBeforeClose: function(callback){
				// 저장 서비스
				this.dsCoaPrge.setColumn(0, "coaSvcAplyStsCd", "20");
				this.smfSaveService("saveSvcAply")
					.messagePrefix("대입전형자료 온라인 수신 서비스를 신청")
					.validateForm(this.divSearch)
					.requireExistsData(this.dsCoaPrge)   // 데이터 존재 필수
					.validateForm(this.divCoaPrge)       // 데이터 검증
					.requireModifredData(this.dsCoaPrge) // 데이터 변경 필수
					.run() // 실행
					.callback(function(callbackParams){
						if(callbackParams.errors) return;
						callback(true);
					}); // 콜백
			}
		},
	};

	// 모달팝업 실행
	this.smfDialog("uds_ueudd00_p01", "pa_uds_ueu_dd::uds_ueudd00_p01.xfdl", popupParams);
};

