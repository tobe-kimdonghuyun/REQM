this.edtPrgeTelno_onkillfocus = function(obj:nexacro.Edit,e:nexacro.KillFocusEventInfo)
{
	if(obj.value != null){
		var vsOld = obj.value;
		var vsNew = this.fnGetPttTelNo(obj.value);
		if(vsOld != vsNew) obj.set_value(vsNew);
	}
	
	if(this.smfIsNull(obj.value)){
		if(obj.id == 'edtPrgeTelno'){
			this.dsCoaPrge.setColumn(0, 'prgeTelno', '');
		}else if(obj.id == 'edtPrgeMblTelno'){
			this.dsCoaPrge.setColumn(0, 'prgeMblTelno', '');
		}
	}else{
		var val = obj.value.replace(/[^0-9]/g, "");
		if(obj.id == 'edtPrgeTelno'){
			this.dsCoaPrge.setColumn(0, 'prgeTelno', val);
		}else if(obj.id == 'edtPrgeMblTelno'){
			this.dsCoaPrge.setColumn(0, 'prgeMblTelno', val);
		}
	}
};

/**
 * @description 그리드입력 callback함수
 */
this.grdMain_oninput = function(obj:nexacro.Grid,e:nexacro.GridInputEventInfo)
{
	var columnName = obj.getCellProperty("body",e.cell,"text");
	if(columnName == 'bind:coaEvlUnitId'){ //평가단위코드
		var editmaxlength = obj.getCellProperty("body",e.cell,"editmaxlength");
		if(editmaxlength > -1){
			obj.setEditingValue(this.fnCutMaxlengthB(obj.getEditingText(), editmaxlength));
		}
	}else if(columnName == 'bind:coaEvlUnitNm'){ //평가단위명
		var editmaxlength = obj.getCellProperty("body",e.cell,"editmaxlength");
		if(editmaxlength > -1){
			obj.setEditingValue(this.fnCutMaxlengthB(obj.getEditingText(), editmaxlength));
		}
	}
};]]></Script>
