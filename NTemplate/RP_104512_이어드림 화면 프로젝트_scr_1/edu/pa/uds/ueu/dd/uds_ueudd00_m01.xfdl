};

this.fnYmdWithDot = function(sYmd){
    sYmd = this.smfStr(sYmd)
	if(!this.smfIsNull(sYmd) && sYmd.length >= 8){
		return [sYmd.substr(0, 4), sYmd.substr(4, 2), sYmd.substr(6, 2)].join(".") + ".";
	}
}

//특수문자 확인
this.fnValidateSpyChr = function(grid, rowIndex, columnIndex, datasetOfGrid){
	var rtn = true;
	
	var labelText = "평가단위코드";
	var str = this.smfStr(datasetOfGrid.getColumn(rowIndex,columnIndex)).trim();
	var objRegExp = /[\{\}\/\\\"\"<>#&:;*?|^_]/gi;
	
	// 특수문자 체크
	if(objRegExp.test(str)){
		rtn = labelText + "에 특수문자( < , > , { , } , # , & , \\ , / , ' , \" , : , ; , * , ? , | , ^ , _  )를 \n사용할 수 없습니다.";
	}
	
	return rtn;
}

this.fnGetPttTelNo = function(psValue) {
	if (this.smfIsNull(psValue)) return '';

	var vsPttTelNo = Array(3);
	vsPttTelNo[0] = "";
	vsPttTelNo[1] = "";
	vsPttTelNo[2] = "";
	
	psValue = psValue.trim().replace(/[^0-9]/g, "");
	psValue = psValue.substr(0, 11); //숫자 11자리만
	var vslength = psValue.length;
	var vsSeoulYn = false;
	
	/**
	 * 서울 02  경기 031 인천 032 강원 033
	 * 충남 041 대전 042 충북 043 부산 051
	 * 울산 052 대구 053 경북 054 경남 055
	 * 전남 061 광주 062 전북 063 제주 064
	 */
	//서울만 국번이 2자리
	if (psValue.substr(0, 2) == "02") vsSeoulYn = true;
	
	if (vsSeoulYn) {
		if (vslength <= 2) {
			vsPttTelNo[0] = psValue;
			vsPttTelNo[1] = "";
			vsPttTelNo[2] = "";
		} else if (vslength == 3) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 1);
			vsPttTelNo[2] = "";
		} else if (vslength == 4) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 2);
			vsPttTelNo[2] = "";
		} else if (vslength == 5) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 3);
			vsPttTelNo[2] = "";
		} else if (vslength == 6) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 4);
			vsPttTelNo[2] = "";
		} else if (vslength == 7) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 4);
			vsPttTelNo[2] = psValue.substr(6, 1);
		} else if (vslength == 8) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 2);
			vsPttTelNo[2] = psValue.substr(4, 4);
			//------------------------------------------
		} else if (vslength == 9) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 3);
			vsPttTelNo[2] = psValue.substr(5, 4);
		} else if (vslength == 10) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 4);
			vsPttTelNo[2] = psValue.substr(6, 4);
		} else if (vslength == 11) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 4);
			vsPttTelNo[2] = psValue.substr(7, 4);
		} else {
			vsPttTelNo[0] = "";
			vsPttTelNo[1] = "";
			vsPttTelNo[2] = "";
		}
	} else {
		if (vslength <= 2) {
			vsPttTelNo[0] = psValue;
			vsPttTelNo[1] = "";
			vsPttTelNo[2] = "";
		} else if (vslength == 3) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = "";
			vsPttTelNo[2] = "";
		} else if (vslength == 4) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 1);
			vsPttTelNo[2] = "";
		} else if (vslength == 5) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 2);
			vsPttTelNo[2] = "";
		} else if (vslength == 6) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 3);
			vsPttTelNo[2] = "";
		} else if (vslength == 7) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 4);
			vsPttTelNo[2] = "";
		} else if (vslength == 8) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 1);
			vsPttTelNo[2] = psValue.substr(4, 4);
		} else if (vslength == 9) { //없는전화번호
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 2);
			vsPttTelNo[2] = psValue.substr(5, 4);
		} else if (vslength == 10) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 3);
			vsPttTelNo[2] = psValue.substr(6, 4);
		} else if (vslength == 11) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 4);
			vsPttTelNo[2] = psValue.substr(7, 4);
		} else {
			vsPttTelNo[0] = "";
			vsPttTelNo[1] = "";
			vsPttTelNo[2] = "";
		}
	}
	
	
	return vsPttTelNo.filter((v) => !this.smfIsNull(v)) .join("-");
}
