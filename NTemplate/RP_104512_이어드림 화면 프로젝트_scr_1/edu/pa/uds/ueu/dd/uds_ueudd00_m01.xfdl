	if(this.isNil(uvstOrgCd) || this.isNil(coaSvcAplyStsCd) || coaSvcAplyStsCd == '00'){
		isEvlUnitProcPsl = false;
		isStepProcPsl = false;
		tooltiptext = "대입 담당자 정보 저장 후 업무처리를 할 수 있습니다.";
	}
	
	this.grdMain.set_enable(isEvlUnitProcPsl);
	this.btnFormDown.set_enable(isEvlUnitProcPsl);
	this.btnExcelUpload.set_enable(isEvlUnitProcPsl);
	this.btnExcelDown.set_enable(isEvlUnitProcPsl);
	this.btnAdd.set_enable(isEvlUnitProcPsl);
	this.btnSave.set_enable(isEvlUnitProcPsl);
	this.btnDelete.set_enable(isEvlUnitProcPsl);
	
	this.btnFormDown.set_tooltiptext(tooltiptext);
	this.btnExcelUpload.set_tooltiptext(tooltiptext);
	this.btnExcelDown.set_tooltiptext(tooltiptext);
	this.btnAdd.set_tooltiptext(tooltiptext);
	this.btnSave.set_tooltiptext(tooltiptext);
	this.btnDelete.set_tooltiptext(tooltiptext);
	
	this.getOwnerFrame().form.divAll.form.divWork.form.divStep.form.btnStep02.set_enable(isStepProcPsl);
	this.getOwnerFrame().form.divAll.form.divWork.form.divStep.form.btnStep03.set_enable(isStepProcPsl);
	this.getOwnerFrame().form.divAll.form.divWork.form.divStep.form.btnStep04.set_enable(isStepProcPsl);
	this.getOwnerFrame().form.divAll.form.divWork.form.divStep.form.btnStep06.set_enable(isStepProcPsl);
	this.getOwnerFrame().form.divAll.form.divWork.form.divStep.form.btnStep07.set_enable(isStepProcPsl);
	this.getOwnerFrame().form.divAll.form.divWork.form.divStep.form.btnStep08.set_enable(isStepProcPsl);
	
	this.getOwnerFrame().form.divAll.form.divWork.form.divStep.form.btnStep02.set_tooltiptext(tooltiptext);
	this.getOwnerFrame().form.divAll.form.divWork.form.divStep.form.btnStep03.set_tooltiptext(tooltiptext);
	this.getOwnerFrame().form.divAll.form.divWork.form.divStep.form.btnStep04.set_tooltiptext(tooltiptext);
	this.getOwnerFrame().form.divAll.form.divWork.form.divStep.form.btnStep06.set_tooltiptext(tooltiptext);
	this.getOwnerFrame().form.divAll.form.divWork.form.divStep.form.btnStep07.set_tooltiptext(tooltiptext);
	this.getOwnerFrame().form.divAll.form.divWork.form.divStep.form.btnStep08.set_tooltiptext(tooltiptext);
	
};

/**
 * @description 한글 3, 영문 1 byte로 계산하여 maxLen으로 자름
 */
this.fnCutMaxlengthB = function(sVal, maxLen){
	var len = 0;
	var i = 0;

    for (i=0; i<sVal.length; i++)
    {
		if (sVal.charCodeAt(i) > 127)
			len += 3;
		else
			len += 1;
			
		if(len > maxLen){
			break;
		}
    }
	
	return sVal.substr(0, i);
}
