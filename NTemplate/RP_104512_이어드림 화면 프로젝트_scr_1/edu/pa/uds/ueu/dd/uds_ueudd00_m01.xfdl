    <Script type="xscript5.1"><![CDATA[/**
 *	대입전형자료온라인수신서비스신청
 *	@MenuPath	대입전형-전형자료온라인수신-대입전형자료온라인수신서비스신청
 *	@FileName 	uds_ueudd00_m01.xfdl
 *	@Creator 	김동업
 *	@CreateDate	2022.08.22  
 *	@Desction
 ************** 소스 수정 이력 ***********************************************
 *	date			Modifier			Description
 *******************************************************************************
 *	2022.08.22		김동업				최초 생성
 *******************************************************************************
 */

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::uds_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Div 초기화
	this.smfInitDiv(obj);
	
	// 초기화
	this.fnInit(obj); 
	
	// 공통코드 조회
	this.smfCodeList("code", [this.dsLctnScCd])
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.fnSearch(); // 조회
		});
	
	// Grid Checkbox 활성화/활성화 제어 ( 공통 사용하면 체크박스 안보이게 처리 안됨 )
	//this.smfUpdateRednerGridCheckbox(this.grdMain, 0, this.fnRenderGridCheckbox);
	
	// 조회 입력창에서 'Ctrl' + 'Enter' 키 입력시 조회수행 이벤트 설정
	this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
	
	// 데이터 입력 창에서 'Ctrl' + 'Enter' 키 입력시 저장수행 이벤트 설정
	this.smfBindEnterKeyToSearch(this.divCoaPrge, this.btnCoaPrgeSave);
};

/**
 * @description 폼 닫기전 이벤트
 */
this.fnOnbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	// 변경내역이 발생한 경우 종료전 confirm수행
	return this.smfCloseFormConfirm([this.dsCoaPrge, this.dsMain]);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/**
 * @description 조회
*/
this.fnSearch = function()
{
	this.fnListCoaPrge();
	this.fnListEvlUnitCd();
};

/**
 * @description 대입담당자정보 조회
*/
this.fnListCoaPrge = function()
{
	// 조회 서비스
	this.smfSearchService("listCoaPrge")
		.confirmIfModifiedDataset(this.dsCoaPrge) // 데이터가 변경되었으면 확인메시지
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.divCoaPrge.form.edtPrgeTelno.set_value(this.fnGetPttTelNo(this.dsCoaPrge.getColumn(0, 'prgeTelno')));
			this.divCoaPrge.form.edtPrgeMblTelno.set_value(this.fnGetPttTelNo(this.dsCoaPrge.getColumn(0, 'prgeMblTelno')));
			
			this.fnCoaSvcAply();
		}); // 콜백
};	

/**
 * @description 평가단위코드관리 조회
*/
this.fnListEvlUnitCd = function(){
	
	// 조회 서비스
	this.smfSearchService("listEvlUnitCd")
		.confirmIfModifiedGrid(this.grdMain) // 데이터가 변경되었으면 확인메시지
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		}); // 콜백
};

this.fnListRcritPrd = function(){
	// 조회 서비스
	this.smfSearchService("listRcritPrd")
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.dsRcritPrd.getRowCount() > 0){
				var startDt = this.dsRcritPrd.getColumn(0, "startDt");
				var endDt = this.dsRcritPrd.getColumn(0, "endDt");
				var addStartDt = this.dsRcritPrd.getColumn(0, "addStartDt");
				var addEndDt = this.dsRcritPrd.getColumn(0, "addEndDt");
				var sRcritPrd = "";
				if(this.smfIsNum(startDt) && this.smfIsNum(endDt)){
					sRcritPrd += "※ " + this.dsSearch.getColumn(0, "coaRcritScNm") + "모집기간 : " + this.fnYmdWithDot(startDt) + " ~ " + this.fnYmdWithDot(endDt);
				}
				if(this.smfIsNum(addStartDt) && this.smfIsNum(addEndDt)){
					sRcritPrd += "\r\n※ 추가모집기간 : " + this.fnYmdWithDot(addStartDt) + " ~ " + this.fnYmdWithDot(addEndDt);
				}
				//모집기간표시
				this.staRcritPrd.set_text(sRcritPrd);
			}
		}); // 콜백
};

/**
 * @description 대입서비스신청
*/
this.fnCoaSvcAply = function(){
	var tooltiptext = "";
	var uvstOrgCd = this.dsCoaPrge.getColumn(0, "uvstOrgCd");
	var coaSvcAplyStsCd = this.dsCoaPrge.getColumn(0, "coaSvcAplyStsCd");
	
