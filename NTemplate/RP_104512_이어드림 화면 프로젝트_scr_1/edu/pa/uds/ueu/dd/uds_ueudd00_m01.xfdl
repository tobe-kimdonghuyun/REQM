/**
 * @description 엑셀업로드
 */
this.btnExcelUpload_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsExcel.clearData();
	
	var objOption = {	datasetname : "dsExcel"
					,   sheetname   : "Sheet1"
					,   startcell   : "A1"
					,   callback    : "fnExcelImportCallback"
					,   importId    : "excelUpload"
					,   objForm     : this
					};
					
	this.smfExcelImport(objOption);
};

/**
 * @description 엑셀업로드 callback함수
 */
this.fnExcelImportCallback = function(importId, bResult)
{
	if(bResult)
	{
		for(var i = 0; i < this.dsExcel.rowcount; i++){
			var coaEvlUnitId = this.smfTrim(this.dsExcel.getColumn(i, "coaEvlUnitId"));
			var coaEvlUnitNm = this.smfTrim(this.dsExcel.getColumn(i, "coaEvlUnitNm"));
			
			if(this.smfIsNull(coaEvlUnitId) && this.smfIsNull(coaEvlUnitNm)) continue;
			
			if(coaEvlUnitId != "평가단위코드" && coaEvlUnitNm != "평가단위명"){
				var idx = this.dsMain.addRow();
				this.dsMain.setColumn(idx, "coaEvlUnitId", coaEvlUnitId);
				this.dsMain.setColumn(idx, "coaEvlUnitNm", coaEvlUnitNm);
			}
		}
		this.smfLiteralAlert("엑셀파일 업로드가 완료되었습니다.", function(){});
	}
	else
	{
		trace("Import실패");
	}
}

