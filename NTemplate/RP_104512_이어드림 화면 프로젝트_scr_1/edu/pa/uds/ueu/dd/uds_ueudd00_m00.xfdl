<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="uds_ueudd00_m00" width="1200" height="1060" titletext="전형자료수신" onload="fnOnload" nHeight="754">
    <Layouts>
      <Layout height="1060" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="65" height="54" text="" right="750">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="전형자료(학생부)수신" left="0" top="0" height="54" cssclass="img_WF_SubTit01" width="380" initvalueid="ivTitleAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divStep" taborder="1" left="0" top="144" height="116" right="0" initvalueid="ivDivAccessibilityOff" formscrollbartype="none none" accessibilityrole="none">
          <Layouts>
            <Layout>
              <Button id="btnStep01" taborder="0" text="대학기본정보관리" left="0" top="0" width="17.6%" height="90" cssclass="btn_WF_NStep01S" initvalueid="ivBtnAccessibilityLink" onclick="btnStep_onclick" accessibilitylabel="대학기본정보관리"/>
              <Static id="sta00_01_00_00_00" taborder="1" left="btnStep01:10" top="20" width="18" height="51" cssclass="sta_WF_NextStep02" initvalueid="ivStcAccessibilityOn" text="" accessibilitylabel="다음 단계 지원학생등록"/>
              <Button id="btnStep02" taborder="2" text="지원학생등록" left="sta00_01_00_00_00:10" top="0" width="17.6%" height="90" cssclass="btn_WF_NStep02" initvalueid="ivBtnAccessibilityLink" onclick="btnStep_onclick" accessibilitylabel="지원학생등록"/>
              <Static id="sta00_01_00_00_00_00" taborder="3" left="btnStep02:10" top="20" width="18" height="51" cssclass="sta_WF_NextStep02" initvalueid="ivStcAccessibilityOn" text="" accessibilitylabel="다음 단계 전형자료일괄처리, 전형자료요청및생성, 전형자료재요청및생성"/>
              <Button id="btnStep08" taborder="10" text="전형자료일괄처리" top="0" height="36" cssclass="btn_WF_NStep07" initvalueid="ivBtnAccessibilityLink" onclick="btnStep_onclick" left="470" right="710" accessibilitylabel="전형자료일괄처리" visible="false"/>
              <Button id="btnStep03" taborder="4" text="전형자료요청및생성    " left="sta00_01_00_00_00_00:10" top="0" width="18%" height="40" cssclass="btn_WF_NStep03" initvalueid="ivBtnAccessibilityLink" onclick="btnStep_onclick" accessibilitylabel="전형자료요청및생성    "/>
              <Button id="btnStep04" taborder="5" text="전형자료재요청및생성" left="sta00_01_00_00_00_00:10" top="btnStep03:10" width="18%" height="40" cssclass="btn_WF_NStep04" initvalueid="ivBtnAccessibilityLink" onclick="btnStep_onclick" accessibilitylabel="전형자료재요청및생성"/>
              <Static id="sta00_01_00_00_00_00_01" taborder="6" left="btnStep03:10" top="20" width="18" height="51" cssclass="sta_WF_NextStep02" initvalueid="ivStcAccessibilityOn" text="" accessibilitylabel="다음 단계 전형자료수신"/>
              <Button id="btnStep06" taborder="7" text="전형자료수신" left="sta00_01_00_00_00_00_01:10" top="0" width="17.6%" height="90" cssclass="btn_WF_NStep06" initvalueid="ivBtnAccessibilityLink" onclick="btnStep_onclick" accessibilitylabel="전형자료수신"/>
              <Static id="sta00_01_00_00_00_00_00" taborder="8" left="btnStep06:10" top="20" width="18" height="51" cssclass="sta_WF_NextStep02" initvalueid="ivStcAccessibilityOn" text="" accessibilitylabel="다음 단계 전형자료복호화"/>
              <Button id="btnStep07" taborder="9" text="전형자료복호화" top="0" height="90" cssclass="btn_WF_NStep05" initvalueid="ivBtnAccessibilityLink" onclick="btnStep_onclick" left="sta00_01_00_00_00_00_00:10" right="0" accessibilitylabel="전형자료복호화"/>
