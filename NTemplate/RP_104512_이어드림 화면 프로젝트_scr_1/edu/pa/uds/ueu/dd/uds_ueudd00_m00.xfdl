        <Static id="Static99_00_00_00_00_01_01" taborder="4" left="0" top="divStep:-26" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Div id="divMain" taborder="2" left="0" top="Static99_00_00_00_00_01_01:0" cssclass="div_WF_Detail" url="pa_uds_ueu_dd::uds_ueudd00_m01.xfdl" text="" right="0" initvalueid="ivDivAccessibilityOff" accessibilitydesclevel="all" accessibilityrole="none" formscrollbartype="none none" height="766"/>
        <Static id="Static99_00_00_00_00" taborder="3" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
 *	대입전형자료온라인제공
 *	@MenuPath	대입전형-대입전형자료온라인제공 
 *	@FileName 	uds_ueudd00_m00.xfdl
 *	@Creator 	김동업
 *	@CreateDate	2022.08.22 
 *	@Desction	
 ************** 소스 수정 이력 ***********************************************
 *	date			Modifier			Description
 *******************************************************************************
 *	2022.08.22		김동업				최초 생성
 *******************************************************************************
 */

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::uds_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	// this.smfInitForm(obj);
};

/************************************************************************************************
 * TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 스텝 변경
 */
this.btnStep_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	// 초기화
	this.divStep.form.btnStep01.set_cssclass("btn_WF_NStep01");
	this.divStep.form.btnStep02.set_cssclass("btn_WF_NStep02");
	this.divStep.form.btnStep03.set_cssclass("btn_WF_NStep03");
	this.divStep.form.btnStep04.set_cssclass("btn_WF_NStep04");
	// this.divStep.form.btnStep05.set_cssclass("btn_WF_NStep05");
	this.divStep.form.btnStep06.set_cssclass("btn_WF_NStep06");
	this.divStep.form.btnStep07.set_cssclass("btn_WF_NStep05");
	this.divStep.form.btnStep08.set_cssclass("btn_WF_NStep07");
	
	if(obj.name == "btnStep01"){
		this.divStep.form.btnStep01.set_cssclass("btn_WF_NStep01S");
		this.divMain.set_url("pa_uds_ueu_dd::uds_ueudd00_m01.xfdl");
	}else if(obj.name == "btnStep02"){
		this.divStep.form.btnStep02.set_cssclass("btn_WF_NStep02S");
		this.divMain.set_url("pa_uds_ueu_dd::uds_ueudd00_m02.xfdl");
	}else if(obj.name == "btnStep03"){
		this.divStep.form.btnStep03.set_cssclass("btn_WF_NStep03S");
		this.divMain.set_url("pa_uds_ueu_dd::uds_ueudd00_m03.xfdl");
	}else if(obj.name == "btnStep04"){
		this.divStep.form.btnStep04.set_cssclass("btn_WF_NStep04S");
		this.divMain.set_url("pa_uds_ueu_dd::uds_ueudd00_m04.xfdl");
	}else if(obj.name == "btnStep06"){
		this.divStep.form.btnStep06.set_cssclass("btn_WF_NStep06S");
		this.divMain.set_url("pa_uds_ueu_dd::uds_ueudd00_m06.xfdl");
	}else if(obj.name == "btnStep07"){
		this.divStep.form.btnStep07.set_cssclass("btn_WF_NStep05S");
		this.divMain.set_url("pa_uds_ueu_dd::uds_ueudd00_m07.xfdl");
	}else if(obj.name == "btnStep08"){
		this.divStep.form.btnStep08.set_cssclass("btn_WF_NStep07S");
		this.divMain.set_url("pa_uds_ueu_dd::uds_ueudd00_m08.xfdl");
	}
};

]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
