        <Grid id="grdDetail" taborder="5" left="grdMain:30" top="Static99_00_00_00_00_01_00_00:0" binddataset="dsDetail" autofittype="col" right="0" initvalueid="ivGrdAccessibilityOn" selecttype="cell" onheadclick="grdMain_onheadclick" accessibilitylabel="전형자료수신 합계" height="399">
