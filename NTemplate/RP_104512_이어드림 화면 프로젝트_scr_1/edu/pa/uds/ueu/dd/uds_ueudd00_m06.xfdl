              <Static id="sta00_00_01_01_00" taborder="0" left="29" top="28" height="23" cssclass="sta_WF_InfoTit" text="전형자료수신 안내사항" wordWrap="char" width="1140" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00_01_01" taborder="1" left="30" top="67" height="23" cssclass="sta_WF_InfoTxt_Blue" text="전형자료수신 : &lt;fc v='#172f57'&gt;나이스 클라우드&lt;/fc&gt; 사서함에 생성된 암호화 대입전형자료를 다운로드&lt;fc v='#172f57'&gt;합니다.&lt;/fc&gt;" wordWrap="char" width="1140" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00_01_01_01" taborder="2" left="30" top="91" height="23" cssclass="sta_WF_InfoTxt_Blue" text="&lt;fc v='#172f57'&gt;전형자료 경로설정에서 지정된 경로의 하위 폴더 '1.전형자료수신'에 전형자료가 수신됩니다.&lt;/fc&gt;" wordWrap="char" width="1140" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00_01_01_01_00" taborder="3" left="30" top="115" cssclass="sta_WF_InfoTxt_Blue" text="'안전하지 않은 파일에 접근합니다. 계속 진행하시겠습니까?' &lt;fc v='#172f57'&gt;안내창이 나타날 경우&lt;/fc&gt; 반드시 '이 폴더 및 하위 폴더는 항상 허용'을 체크&lt;fc v='#172f57'&gt;하고 [Yes]를 클릭하여 합니다.&lt;/fc&gt;" wordWrap="char" width="1140" usedecorate="true" initvalueid="ivStcAccessibilityOn" bottom="20"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00" taborder="4" left="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff" top="0"/>
              <Static id="sta99_00_00_00_00_01_01" taborder="5" left="0" top="30" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="20" text="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_00" taborder="6" left="0" height="20" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" bottom="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta99_00_00_00_00_01_01_00" taborder="7" top="30" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="20" text="30" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_01" taborder="8" left="30" top="51" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_01_00" taborder="9" left="33" top="71" height="16" cssclass="sta_GD_Size" text="5" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="5" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="Static99_00_00_00_00_00_00_00_00_00" taborder="9" left="grdMain:0" top="Static99_00_00_00_00_01_00_00:0" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="divGuideInfo:0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
 *	전형자료생성
 *	@MenuPath	대입전형-전형자료온라인수신-전형자료생성
 *	@FileName 	uds_ueudd00_m05.xfdl
 *	@Creator 	김동업
 *	@CreateDate	2022.09.30  
 *	@Desction	
 ************** 소스 수정 이력 ***********************************************
 *	date			Modifier			Description
 *******************************************************************************
 *	2022.09.30		김동업				최초 생성
 *******************************************************************************
 */

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::uds_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
// ExtCmmon API
this.fvObjExtCommon = this.smfCreateExtCommonAPI();
this.fvCoaDataDownPath = this.udsfGetCoaDataDownPath();   // 수신경로

this.fvPrcsType = 0;

this.fvQueFolders = null;								  // 권한 확인할 폴더 큐 버퍼

this.fvQueIdx = null;									  // 파일 인덱스 큐 버퍼
this.fvQueFiles = null;									  // 파일 쓰기 큐 버퍼
this.fvQueShl = null;									  // 학교 인덱스 큐 버퍼
this.fvQueRcptnCmptn = null;							  // 수신완료 큐 버퍼

this.fvLastWrkIdx = -1 									  //마지막 업무처리 학교(dsDetail) 인덱스
this.fvMaxCnt = 100;									  //수신완료처리 MAX

this.fvCoaWrkHstrService = null;						  //대업전형자료업무 히스토리

this.fvRcptnRreqCnt = 3;								  //수신 재요청 횟수 (최초 1회 + 3)
this.fvRcptnEnviromentErrorCnt = 0; 					  //수신 재요청 실행 횟수 (통신오류)
this.fvRcptnServerErrorCnt = 0;							  //수신 재요청 실행 횟수 (서비스)
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Div 초기화
	this.smfInitDiv(obj);
	
	// 대입서비스체크
	this.udsfCoaSvcChck(function(){
		// 초기화
		this.fnInit(obj); 
		
		// 공통코드 조회
		this.smfCodeList("code", [this.dsCddcScCd])
			.callback(function(callbackParams){
				if(callbackParams.errors) return;
			})
			.run()
		;
		
		this.fnSearch(); // 조회
		
		// Grid Checkbox 활성화/활성화 제어
		// this.smfUpdateRednerGridCheckbox(this.grdDetail, 0, this.fnRenderGridCheckbox);
		
		// 조회 입력창에서 'Ctrl' + 'Enter' 키 입력시 조회수행 이벤트 설정
		this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
	});
};

/**
 * @description 폼 닫기전 이벤트
 */
this.fnOnbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	// 변경내역이 발생한 경우 종료전 confirm수행
	return this.smfCloseFormConfirm([this.dsMain, this.dsDetail]);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1){
		this.fnExecuteEnable(true);
		return;
	}
};

/**
 * @description Environment의 통신오류 인터셉터
 * @return boolean > true : Environment 오류 로직 종료, false : Environment 오류 로직 계속 실행
*/
this.fnEnviromentErrorInterceptor = function(errcd, url){
	trace('fnEnviromentOnError : (' + errcd + ') ' + url);
	if(errcd == 10408 && !this.smfIsNull(url) && url.indexOf('uds_ueu_dd00_603.do') > -1){
		if(this.fvRcptnEnviromentErrorCnt++ < this.fvRcptnRreqCnt){
			this.fnExecuteRcptn(); //재요청
			return true;
		}
	}
}

/**
 * @description 공통 서비스의 통신오류 인터셉터
 * @return boolean > true : 공통 서비스 오류 로직 종료, false : 공통 서비스 오류 로직 계속 실행
*/
this.fnServerErrorInterceptor = function(svcid,errcd,errmsg){
	trace('fnServerErrorInterceptor : (' + errcd + ') ' + svcid);
	if(errcd == -1 && svcid == 'executeRcptn'){
		if(this.fvRcptnServerErrorCnt++ < this.fvRcptnRreqCnt){
			return true;
		}
	}
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/**
 * @description 조회
*/
this.fnSearch = function()
{
	this.fnCddcSearch();
};

/**
 * @description 시도교육청 조회
*/
this.fnCddcSearch = function()
{
	// 조회 서비스
	this.smfSearchService("listCddc")
		.confirmIfModifiedGrid(this.grdMain) // 데이터가 변경되었으면 확인메시지
		.validateForm(this.divSearch) // 폼 유효성검사
		.command(function(next){
			this.dsDetail.clearData();
			next();
		})
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.fnShlSearch();
		}); // 콜백
};

/**
 * @description 학교 조회
*/
this.fnShlSearch = function()
{
	// 조회 서비스
	this.smfSearchService("listShl")
		.confirmIfModifiedGrid(this.grdDetail) // 데이터가 변경되었으면 확인메시지
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		}); // 콜백
};

/**
 * @description 요청 프로세스 실행
*/
this.fnExecuteRcptn = function(){
	// 저장 서비스
	this.smfExecuteService("executeRcptn")
		.showConfirm(false)
		.command(function(next) { 
			this.setWaitCursor(false);
			next();
		})
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.setWaitCursor(true);
			this.fnCopyDs00(true);
			//파일 인덱스 큐에 저장
			this.fvQueIdx.init(this.dsCoaUvstEncFile.getRowCount());
			this.fnDoNext();
		}); // 콜백
}

/**
 * @description 요청 프로세스 실행
*/
this.fnExecuteRcptnCmptn = function(){
	this.fvQueRcptnCmptn.init(this.dsCoaUvstEncFile.getRowCount());
	this.fnExecuteRcptnCmptnParts();
}

/**
 * @description 요청 프로세스 실행 (나누어)
*/
this.fnExecuteRcptnCmptnParts = function(){
	this.dsCoaUvstEncFile00.clearData();
	for(var i = 0; i < this.fvMaxCnt; i++){
		if(!this.fvQueRcptnCmptn.isEmpty()){
			var nRow = this.fvQueRcptnCmptn.dequeue();
			var nRow00 = this.dsCoaUvstEncFile00.addRow();
			this.dsCoaUvstEncFile00.copyRow(nRow00,  this.dsCoaUvstEncFile, nRow);
		}
	}

	// 저장 서비스
	this.smfExecuteService("executeRcptnCmptn")
		.showConfirm(false)
		.command(function(next) { 
			this.setWaitCursor(false);
			next();
		})
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.setWaitCursor(true);
			this.fnCopyDs00();
			
			if(this.fvQueRcptnCmptn.isEmpty()){
				this.fnDoNext();
			}else{
				this.fnExecuteRcptnCmptnParts();
			}
		}); // 콜백
}

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/**
 * @description 초기화 FUNCTION
 */
this.fnInit = function(obj) {
	this.dsSearch.setColumn(0, "coaAyr", this.udsv_coaAyr);
	this.dsSearch.setColumn(0, "coaRcritScCd", this.udsv_coaRcritScCd);
	this.dsSearch.setColumn(0, "coaRcritScNm", this.udsv_coaRcritScNm);
	
	this.dsSearch.setColumn(0, "coaEvlUnitId", "");
	this.dsSearch.setColumn(0, "coaEvlUnitNm", "- 전체 -");
	
	this.fvQueFolders = this.udsfCreateQueue();								       // 권한 확인할 폴더 큐 버퍼
	this.fvQueIdx = this.udsfCreateQueue();									       // 파일 인덱스 큐 버퍼
	this.fvQueFiles = this.udsfCreateQueue();								       // 파일 쓰기 큐 버퍼
	this.fvQueShl = this.udsfCreateQueue();									  	   // 학교 인덱스 보퍼 큐 버퍼
	this.fvQueRcptnCmptn = this.udsfCreateQueue();
	
	this.fvCoaWrkHstrService = this.udsfCreateCoaWrkHstr('U0602', 'executeRcptnCmptn');  // 대입진원업무 히스토리
}

/**
 * 그리드 체크박스 enable 처리
 * @param : ds - 데이터셋
 * @param : nRow - rowposition
 */
this.fnRenderGridCheckbox = function(ds, nRow){
	return true;
};

/**
 * @description 전형자료경로설정 콜백함수
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체 
 */
this.fnCoaDataPathCallback = function(e, sender){
	this.fvCoaDataPathNm = nexacro.getPrivateProfile(this.udsv_coaDataPathValue);
	//trace(" fvCoaDataPath : " + this.fvCoaDataPathNm);
}

/**
 * @description 폴터 권한확인
 * @param : folders - 권한을 확인할 폴더 배열
 */
this.fnCheckFolder = function(folders){
	this.fvPrcsType = 0;

	folders = Array.isArray(folders) ? folders : [folders];
	
	if(folders.some((v) => this.smfIsNull(v))){
		this.smfAlert("전형자료경로가 존재하지 않습니다.", function(){
			this.fnCheckFolderCallback(false);
		});
		return;
	}
	
	this.fvQueFolders.init(folders);
	this.VirtualFile00.isExist(this.fvQueFolders.dequeue());
}

/**
 * @description 폴더 권한확인 콜백
 * @param : isComplete - 완료 확인
 */
this.fnCheckFolderCallback = function(isComplete){
	if(!isComplete){
		this.fnExecuteEnable(true);
		return;
	}
	
	this.fnRunRcptn();
}

/**
 * @description 실행활성화
 * @param : ds - 데이터셋
 * @param : nRow - rowposition
 */
this.fnExecuteEnable = function(bEnable){
	this.setWaitCursor(!bEnable);
	this.divSearch.form.btnSearch.set_enable(bEnable);
	this.divSearch.form.btnEvlUnit.set_enable(bEnable);
	this.btnExecute.set_enable(bEnable);
	this.btnCoaDataPath.set_enable(bEnable);
};

/**
* @description coaWrkPrcsCd 에 따른 쓰기할 파일을 this.fvQueFiles에 담는다.
* 
*/
this.fnTakeFileInfo = function(i){
	var coaSeleFileCn = this.dsCoaUvstEncFile.getColumn(i, "coaSeleFileCn");
	var coaSeleFileNm = this.dsCoaUvstEncFile.getColumn(i, "coaSeleFileNm");
	var coaImageFileCn = this.dsCoaUvstEncFile.getColumn(i, "coaImageFileCn");
	var coaImageFileNm = this.dsCoaUvstEncFile.getColumn(i, "coaImageFileNm");

	this.fvQueFiles.enqueue({
		'idx' : i,
		'nm' : this.fvCoaDataDownPath + "\\" + coaSeleFileNm + '.enc',
		'cn' : coaSeleFileCn,
		'type' : 'T',
		'col' : 'coaSaleFilePrcsYn',
	});
	
	this.fvQueFiles.enqueue({
		'idx' : i,
		'nm' : this.fvCoaDataDownPath + "\\" + coaImageFileNm + '.enc',
		'cn' : coaImageFileCn,
		'type' : 'B', //binary
		'col' : 'coaImagepPrcsYn',
		'colChk' : ['coaSaleFilePrcsYn', 'coaImagepPrcsYn'],
		'colCmptn' : 'cmptnYn',
	});
}

/**
* @description VirtualFile 열기
*/
this.fnVirtualFileOpen = function(fileInfo){
	//trace('this.fnVirtualFileOpen : ' + fileInfo['nm']);
	this.VirtualFile00.open(fileInfo['nm'], fileInfo['type'] == 'T' ? VirtualFile.openText | VirtualFile.openWrite : VirtualFile.openBinary | VirtualFile.openWrite);
}

/**
 * @description d00을 ds으로 복사
 */
this.fnCopyDs00 = function(){
	//00데이터셋을 원본에 복사
	var dsFrom = this.dsMain00;
	var dsTo = this.dsMain;
	for(var i = 0; i <  dsFrom.getRowCount(); i++){
		var nRow = dsTo.findRow('cddcScCd',  dsFrom.getColumn(i, 'cddcScCd'));
		if(nRow > -1) dsTo.copyRow(nRow,  dsFrom, i);
	}
	dsTo.applyChange();
	
	dsFrom = this.dsDetail00;
	dsTo = this.dsDetail;
	for(var i = 0; i <  dsFrom.getRowCount(); i++){
		var con = this.udsfGetCondition(['cddcScCd', 'shlCd'], [dsFrom.getColumn(i, 'cddcScCd'), dsFrom.getColumn(i, 'shlCd')]);
		var nRow = dsTo.findRowExpr(con);
		if(nRow > -1){
			dsTo.copyRow(nRow,  dsFrom, i);
			dsTo.setColumn(nRow, '_chk', '1');
		}
	}
	dsTo.applyChange();
}

/**
 * @description 수신 실행
 */
this.fnRunRcptn = function(){
	this.fvPrcsType = 1;
	this.fvCoaWrkHstrService.send(false, function(){
		// 실행 비활성화
		this.fnExecuteEnable(false);
		
		// 다음 실행
		this.fnDoNext();
	});
}

/**
 * @description 다음 프로세스 실행
 */
this.fnDoNext = function(){
	if(this.fvQueIdx.isEmpty()){
		if(this.fvQueShl.isEmpty()){
			this.fnExecuteEnable(true);
			this.fnToggleHighlight(-1);
			this.grdDetail.setCellProperty('head', 0, 'expr', '0');
			
			//히스토리 완료 저장
			this.fvCoaWrkHstrService.send(true);
			this.smfAlert("대입전형자료수신이 완료 되었습니다.", function(){});
		}else{
			//dsDetail은 선택된 학교 하나를 dsDetailTrgt로 복사
			this.dsDetailTrgt.clearData();
			var nRow = this.fvQueShl.dequeue();
			
			//학교 로우 하이라이트
			this.fnToggleHighlight(nRow);
			
			var nRowTrgt = this.dsDetailTrgt.addRow();
			this.dsDetailTrgt.copyRow(nRowTrgt,  this.dsDetail, nRow);

			//수선 재요청 관련 초기화
			this.fvRcptnEnviromentErrorCnt = 0;
			this.fvRcptnServerErrorCnt = 0;
			
			this.fnExecuteRcptn();
		}
	}else{
		var idx = this.fvQueIdx.dequeue();
		this.fnTakeFileInfo(idx);
		this.fnVirtualFileOpen(this.fvQueFiles.first());
	}
}

/**
 * @description 파일쓰기 콜백
 */
this.fnVirtualFileCallback = function(){
	var f = this.fvQueFiles.dequeue();
	//로우의 부분 완료 설정 ( 전형자료 or 이미지 )
	if(!this.smfIsNull(f['cn'])){
		this.dsCoaUvstEncFile.setColumn(f['idx'], f['col'], 'Y');
	}

	//로우 완료 설정
	if(!this.smfIsNull(f['colChk'])){
		var chkCols = Array.isArray(f['colChk']) ? f['colChk'] : [f['colChk']];
		if(chkCols.every((col) => this.dsCoaUvstEncFile.getColumn(f['idx'], col) == 'Y')){
			this.dsCoaUvstEncFile.setColumn(f['idx'], f['colCmptn'], 'Y');
		}
	}
	
	if(this.fvQueFiles.isEmpty()){
		if(this.fvQueIdx.isEmpty()){
			this.fnExecuteRcptnCmptn();
		}else{
			this.fnDoNext();
		}
	}else{
		this.fnVirtualFileOpen(this.fvQueFiles.first());
	}
}

/**
 * @description 평가단위코드 팝업 콜백
 */
this.fnCoaEvlUnitCallback = function(context, responseParams, sender){
	if(context.listCoaEvlUnitId.length == 0 || context.totalCnt == context.listCoaEvlUnitId.length){
		this.dsSearch.setColumn(0, 'coaEvlUnitId', '');
		this.dsSearch.setColumn(0, 'coaEvlUnitNm', '- 전체 -');
	}else{
		this.dsSearch.setColumn(0, 'coaEvlUnitId', context.listCoaEvlUnitId.join(','));
		if(context.listCoaEvlUnitId.length == 1){
			this.dsSearch.setColumn(0, 'coaEvlUnitNm', context.listCoaEvlUnitNm[0]);
		}else{
			this.dsSearch.setColumn(0, 'coaEvlUnitNm', context.listCoaEvlUnitNm[0] + '외 ' + (context.listCoaEvlUnitId.length - 1) + '건');
		}
	}
}

/**
 * @description 하이라이트 토글
 */
this.fnToggleHighlight = function(idx){
	//하이라이트 제거
	if(this.fvLastWrkIdx > -1){
		this.dsDetail.setColumn(this.fvLastWrkIdx, 'highlight', '');
		this.dsDetail.setColumn(this.fvLastWrkIdx, '_chk', '');
	}
	
	if(idx > -1){
		//하이라이트
		this.dsDetail.setColumn(idx, 'highlight', '1');
		
		//row idx 이동 ( UI )
		this.grdDetail.setCellPos(1, idx);
		this.grdDetail.redrawExprCell();
	}
	
	if(this.fvLastWrkIdx > -1 || idx > -1){
		this.dsDetail.applyChange();
	}
	
	this.fvLastWrkIdx = idx;
}

/**
 * @description 공통에서 경로 가져오기
 */
this.fnCoaDataPathCallback = function(){
	this.fvCoaDataDownPath = this.udsfGetCoaDataDownPath();   // 수신경로
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

/**
 * @description 그리드 헤더 클릭
*/
this.grdMain_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var columnName = obj.getCellProperty("body",e.cell,"text");
	if ("bind:_chk" == columnName){
		// 선택가능한 항목만 토글
		this.smfToggleChkHeader(obj, e, function(ds, nRow){
			return ds.getColumn(nRow, 'prcsCnt') > 0;
		});
	}else{
		// 정렬
		this.smfCheckAndSort(obj, e);
	}
};

/**
 * @description 조회
 */
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsSearch.setColumn(0, 'cddcScCd', '');
	this.fnSearch();
};

/**
 * @description 평가단위 선택
 */
this.divSearch_btnEvlUnit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var coaEvlUnitId = this.dsSearch.getColumn(0, 'coaEvlUnitId');
	var listCoaEvlUnitId = this.smfIsNull(coaEvlUnitId) ? [] : this.dsSearch.getColumn(0, 'coaEvlUnitId').split(',');
	
	// 팝업 파라메터
	var popupParams = {
		callback: this.fnCoaEvlUnitCallback, // 콜백함수 지정
		sender: obj, // sender 지정
		params: {
			procType : "save", // 처리타입 지정
			listCoaEvlUnitId : listCoaEvlUnitId
		},
	};

	// 모달팝업 실행
	this.smfDialog("uds_ueudd00_p09", "pa_uds_ueu_dd::uds_ueudd00_p10.xfdl", popupParams);
};

/**
 * @description 시도 선택
 */
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var cddcScCd = this.dsMain.getColumn(this.dsMain.rowposition, "cddcScCd");
	this.dsSearch.setColumn(0, "cddcScCd", cddcScCd);
	
	this.fnShlSearch();
};

/**
 * @description 대입수신자료 조회
 */
this.btnExecute_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
/*
	this.fvcoaDataPathNm = nexacro.getPrivateProfile(this.udsv_coaDataPathValue);
	if(this.smfIsNull(this.fvCoaDataPathNm)) {
		// 팝업 파라메터
		var popupParams = {
			callback: this.fnCoaDataPathCallback, // 콜백함수 지정
			sender: obj, // sender 지정
			params: {
				procType: "save" // 처리타입 지정
			},
		};

		// 모달팝업 실행
		this.smfDialog("uds_ueudd00_p09", "pa_uds_ueu_dd::uds_ueudd00_p09.xfdl", popupParams);
		return false;
	}
*/

	const chkList = this.dsDetail.extractRows("_chk == 1");
	if(this.isNil(chkList) || this.dsDetail.getCount() == 0){
		this.smfAlert("선택된 학교가 없습니다. 학교를 선택하여 주십시오.", function(){
		});
		return false;
	}
	
	this.smfConfirm("전형자료수신을 실행하시겠습니까? ", function(confirmParams){
		if(!confirmParams.confirmResult) return;
		
		this.fvQueFolders.clear();
		this.fvQueIdx.clear();
		this.fvQueFiles.clear();
		this.fvQueShl.clear();
		this.fvQueRcptnCmptn.clear();
		
		this.dsDetailTrgt.clearData();
		
		this.fnToggleHighlight(-1);
		
		//버퍼에 선택학교 추가
		this.fvQueShl.init(chkList);
		
		//폴더 권한확인
		this.fnCheckFolder([this.udsfGetCoaDataPath(), this.fvCoaDataDownPath]);
	})
};

this.VirtualFile00_onsuccess = function(obj:nexacro.VirtualFile,e:nexacro.VirtualFileEventInfo)
{
	if(this.fvPrcsType == 0){ //폴더 권한 확인
		if(e.reason == 10){
			if(e.fileisexist){
				if(this.fvQueFolders.isEmpty()){
					this.fnCheckFolderCallback(true);
				}else{
					obj.isExist(this.fvQueFolders.dequeue());
				}
			}else{
				this.fnExecuteEnable(true);
				this.smfAlert("전형자료경로가 존재하지 않습니다.", function(){
					this.fnCheckFolderCallback(false);
				});
			}
		}
	}else{ //파일 저장
		if(e.reason == 1){ //open complete
			//쓰기
			var f = this.fvQueFiles.first();
			var cn = f['cn'];
			if(this.smfIsNull(cn)){
				obj.close();
			}else{
				if(f['type'] == 'T') obj.write(f['cn'], 'utf-8');
				else obj.write(f['cn']);
			}
		}else if(e.reason == 2){ //close complete
			this.fnVirtualFileCallback();
		}else if(e.reason == 6){ //write complete
			//닫기
			obj.close();
		}
	}
};

this.VirtualFile00_onerror = function(obj:nexacro.VirtualFile,e:nexacro.VirtualFileErrorEventInfo)
{
	if(this.fvPrcsType == 0){ //폴더 권한 확인
		this.fnExecuteEnable(true);
		if(e.statuscode == '1102'){ //Permission Denied
			this.smfAlert("전형자료경로에 접근권한이 없습니다.", function(){
				this.fnCheckFolderCallback(false);
			});
		}else if(e.statuscode == '1105'){ //Does not exist
			this.smfAlert("전형자료경로가 존재하지 않습니다.", function(){
				this.fnCheckFolderCallback(false);
			});
		}
	}else if(this.fvPrcsType == 1){
		this.fnExecuteEnable(true);
	}
};

this.btnCoaDataPath_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 팝업 파라메터
	var popupParams = {
		callback: this.fnCoaDataPathCallback, // 콜백함수 지정
		sender: obj, // sender 지정
		params: {
			procType: "save" // 처리타입 지정
		},
	};

	// 모달팝업 실행
	this.smfDialog("uds_ueudd00_p09", "pa_uds_ueu_dd::uds_ueudd00_p09.xfdl", popupParams);
};
