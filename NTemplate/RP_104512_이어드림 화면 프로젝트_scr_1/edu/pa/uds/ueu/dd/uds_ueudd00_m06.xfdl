                <Column size="70"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
                <Row size="40" band="summ"/>
              </Rows>
              <Band id="head" accessibilitylabel="제목 영역" accessibilityrole="none">
                <Cell displaytype="checkboxcontrol" edittype="checkbox" accessibilityrole="checkbox"/>
                <Cell col="1" text="고등학교"/>
                <Cell col="2" text="수신대상"/>
                <Cell col="3" text="미수신"/>
                <Cell col="4" text="수신완료" cssclass="LineNo"/>
              </Band>
              <Band id="body" accessibilityrole="none" accessibilitylabel="내용 영역">
                <Cell text="bind:_chk" displaytype="expr:prcsCnt == 0 ? &quot;none&quot; : &quot;checkboxcontrol&quot;" edittype="expr:prcsCnt == 0 ? &quot;none&quot; : &quot;checkbox&quot;" color="#333333" accessibilityrole="checkbox" cssclass="expr:highlight == '1' ? 'cell_WF_BgColorYelw' : ''"/>
                <Cell col="1" text="bind:shlNm" cssclass="expr:highlight == '1' ? 'cell_WF_BgColorYelw' : ''"/>
                <Cell col="2" text="bind:trgtCnt" cssclass="expr:highlight == '1' ? 'cell_WF_BgColorYelw' : ''"/>
