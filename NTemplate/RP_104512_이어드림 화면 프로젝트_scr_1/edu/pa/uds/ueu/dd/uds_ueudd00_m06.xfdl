        <Static id="Static99_00_00_00_00_01_00" taborder="7" left="0" top="divSearch:0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <ImageViewer id="img00_00_01_00" taborder="1" text="전형자료수신" left="0" top="Static99_00_00_00_00_01_00:0" width="129" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
        <Button id="btnExecute" taborder="3" text="전형자료수신" top="divSearch:20" height="30" width="108" cssclass="btn_WF_Crud" visible="true" right="0" initvalueid="ivBtnAccessibilityButton" onclick="btnExecute_onclick"/>
        <Button id="btnCoaDataPath" taborder="2" text="전형자료경로설정" height="30" width="136" cssclass="btn_WF_Custom" visible="true" initvalueid="ivBtnAccessibilityButton" right="btnExecute:8" onclick="btnCoaDataPath_onclick" top="90"/>
        <Static id="Static99_00_00_00_00_01_00_00" taborder="8" left="0" top="img00_00_01_00:0" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Grid id="grdMain" taborder="4" left="0" binddataset="dsMain" autofittype="col" top="Static99_00_00_00_00_01_00_00:0" width="500" initvalueid="ivGrdAccessibilityOn" oncellclick="grdMain_oncellclick" cursor="auto" selecttype="cell" accessibilitylabel="전형자료수신" height="399">
