        <Grid id="grdMain" taborder="4" left="0" binddataset="dsMain" autofittype="col" top="Static99_00_00_00_00_01_00_00_00_00:0" selecttype="cell" width="500" initvalueid="ivGrdAccessibilityOn" accessibilitylabel="전형자료재요청 합계" oncellclick="grdMain_oncellclick" height="265">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="160" band="left"/>
                <Column size="70"/>
                <Column size="70"/>
                <Column size="70"/>
                <Column size="70"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head" accessibilityrole="none" accessibilitylabel="제목 영역">
                <Cell text="시도"/>
                <Cell col="1" text="학교수"/>
                <Cell col="2" text="재요청대상"/>
                <Cell col="3" text="재요청오류"/>
                <Cell col="4" text="재요청완료" cssclass="LineNo"/>
              </Band>
              <Band id="body" accessibilityrole="none" accessibilitylabel="내용영역">
                <Cell displaytype="normal" edittype="none" text="bind:cddcScNm" textDecoration="underline"/>
                <Cell col="1" text="bind:shlCnt"/>
                <Cell col="2" text="bind:trgtCnt"/>
                <Cell col="3" text="expr:comp.parent.fnNumFormat(errCnt + '(' + exclCnt + ')');" textAlign="right" tooltiptext="expr:comp.parent.fnErrTooltip(errCnt, exclCnt);"/>
                <Cell col="4" text="bind:cmptnCnt"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Grid id="grdDetail" taborder="5" left="grdMain:30" top="Static99_00_00_00_00_01_00_00_00_00:0" binddataset="dsDetail" autofittype="col" right="0" initvalueid="ivGrdAccessibilityOn" selecttype="cell" accessibilitylabel="전형자료재요청 합계" onheadclick="grdDetail_onheadclick" height="265">
          <Formats>
