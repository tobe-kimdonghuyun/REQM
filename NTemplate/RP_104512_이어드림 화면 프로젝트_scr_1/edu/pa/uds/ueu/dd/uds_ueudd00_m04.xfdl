                <Cell col="1" displaytype="normal" edittype="none" text="bind:shlCd" textAlign="center" cssclass="expr:highlight == '1' ? 'cell_WF_BgColorYelw' : ''"/>
                <Cell col="2" displaytype="mask" edittype="none" text="bind:stuRrno" textAlign="center" expr="comp.parent.fnGetRrno(stuRrno)" cssclass="expr:highlight == '1' ? 'cell_WF_BgColorYelw' : ''"/>
                <Cell col="3" text="bind:uvstExmtNo" textAlign="center" cssclass="expr:highlight == '1' ? 'cell_WF_BgColorYelw' : ''"/>
