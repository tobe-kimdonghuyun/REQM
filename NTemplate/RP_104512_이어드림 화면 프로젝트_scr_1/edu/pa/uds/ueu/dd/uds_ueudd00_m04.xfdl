                <Column size="320" band="left"/>
                <Column size="70"/>
                <Column size="70"/>
                <Column size="70"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
                <Row size="40" band="summ"/>
              </Rows>
              <Band id="head" accessibilityrole="none" accessibilitylabel="제목영역">
                <Cell displaytype="checkboxcontrol" edittype="checkbox" accessibilityrole="checkbox"/>
                <Cell col="1" text="고등학교"/>
                <Cell col="2" text="재요청대상"/>
                <Cell col="3" text="재요청오류"/>
                <Cell col="4" text="재요청완료" cssclass="LineNo"/>
              </Band>
              <Band id="body" accessibilityrole="none" accessibilitylabel="내용 영역">
                <Cell text="bind:_chk" displaytype="expr:trgtCnt == 0 ? &quot;none&quot; : &quot;checkboxcontrol&quot;" edittype="expr:trgtCnt == 0 ? &quot;none&quot; : &quot;checkbox&quot;" color="#333333" accessibilityrole="checkbox" cssclass="expr:highlight == '1' ? 'cell_WF_BgColorYelw' : ''"/>
                <Cell col="1" text="bind:shlNm" cssclass="expr:highlight == '1' ? 'cell_WF_BgColorYelw' : ''"/>
                <Cell col="2" text="bind:trgtCnt" cssclass="expr:highlight == '1' ? 'cell_WF_BgColorYelw' : ''"/>
                <Cell col="3" text="expr:comp.parent.fnNumFormat(errCnt + '(' + exclCnt + ')');" textAlign="right" cssclass="expr:highlight == '1' ? 'cell_WF_BgColorYelw' : ''" tooltiptext="expr:comp.parent.fnErrTooltip(errCnt, exclCnt);"/>
                <Cell col="4" text="bind:cmptnCnt" cssclass="expr:highlight == '1' ? 'cell_WF_BgColorYelw LineNo' : 'LineNo'"/>
              </Band>
              <Band id="summary" accessibilitylabel="합계영역">
                <Cell colspan="2" text="합계" displaytype="text"/>
                <Cell col="2" text="expr:dataset.getSum('trgtCnt')" textAlign="right" displaytype="number"/>
                <Cell col="3" text="expr:comp.parent.fnNumFormat(dataset.getSum('errCnt') + '(' + dataset.getSum('exclCnt')  + ')')" textAlign="right" displaytype="normal"/>
                <Cell col="4" text="expr:dataset.getSum('cmptnCnt')" textAlign="right" displaytype="number"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Grid id="grdMainFile" taborder="6" left="0" top="Static99_00_00_00_00_01_00_00_00_00:0" binddataset="dsMainFile" autofittype="col" right="0" initvalueid="ivGrdAccessibilityOn" visible="false" autoenter="select" selecttype="row" onheadclick="grdMainFile_onheadclick" height="265">
