		//인적.학적사항 훈령280호(시스템훈령:765) 이후 
		report.mandatory()
			.select('$0=1')
			.take(2
				,  stuIdfNo //식별번호
				, '$1' //학교코드
				, '$2' //학과코드
				, '$3' //반
				, '$4' //번호
				, '$5' //성명
				, '$6' //주민등록번호
				, coaImageFileCn //이미지 파일 base64
			)
			.select('$0=2', '$0=2', -1) //뒤에 추가
			.modify(function(sel){ //선택된 원본을 조작
				//하나의 row로 합침
				var tmp = sel.reduce(function(a,v,i){
					
					if(blindYn == "Y"){ // 해제일떄
						//전출 09, 유급 10, 휴학 11, 면제 12, 유예 13, 제적 14, 자퇴 15, 퇴학 16
						if(v[1] != '09' && v[1] != '10' && v[1] != '11' && v[1] != '12' && v[1] != '13' && v[1] != '14' && v[1] != '15' && v[1] != '16'){
							if(i != 0){
								a.push('/EOR/'); // 맨처음행은 줄을 바꾸지않는다
							}
						
							a.push(v[3].substr(0, 4) + '년 ' + v[3].substr(4, 2) + '월 ' + v[3].substr(6, 2) + '일  ' + v[4]);
						
						}else{
							a.push("("+v[3].substr(0, 4) + '년 ' + v[3].substr(4, 2) + '월 ' + v[3].substr(6, 2) + '일  ' + v[4]+")");
						}
					}else{ //블라인드 자료일떄
						if(i != 0){
							a.push('/EOR/'); // 맨처음행은 줄을 바꾸지않는다
						}
						a.push(+v[3].substr(0, 4) + '년 ' + v[3].substr(4, 2) + '월 ' + v[3].substr(6, 2) + '일  ' + v[2]);
					}
					return a;
				}, []).join('');
				return [[2, tmp]];
			})
			.trace('학적사항 원본=====\n').org().selected().end()
			.take('$1')
			.selectOrg('$0=1').selectTarCol(-1) //뒤에 추가
			.take('$7');
			
		report.trace("인적.학정사항=====\n").tar().end();
				
		//전공과정 훈령280호(시스템훈령:765) 이후
		report.mandatory()
			.select('$0=1')
			.take(3, '1', (v) => this.getIsNullToString(v[8]), (v) => this.getIsNullToString(v[9]))
			.take(3, '2', (v) => this.getIsNullToString(v[10]), (v) => this.getIsNullToString(v[11]))
			.take(3, '3', (v) => this.getIsNullToString(v[12]), (v) => this.getIsNullToString(v[13]));
			
		report.trace("전공과정=====\n").tar().end();
			
		//출결사항 훈령280호(시스템훈령:765) 이후
		report.mandatory()
			.select('$0=3')
			.take(4, ...Array(15).fill().map((v, i) => '$' + (i + 2)));
			
		report.trace("출결사항=====\n").tar().end();
			
		//수상경력 ( 데이터 없음 ) 훈령280호(시스템훈령:765) 이후
		report.mandatory()
			.select('$0=4')
			.take(5, '', '$4', '$5', '$6', '$7', '$8', '$2', '$3');
			
		report.trace("수상경력=====\n").tar().end();
			
		//국가직무 훈령280호(시스템훈령:765) 이후
		report.mandatory()
			.select('$0=6')
			.take( 6     //SEMS 파일 정보명 / 오즈변수명
				 , '$2'  //학년 / j1
				 , '$3'  //학기 / j2 
				 , '$4'  //세분류 / j3 
				 ,  (v) => [v[6], '\n(', v[7], ')'].join('') //능력단위명\n(능력단위 코드) / j4
				 , '$7'  //능력단위 코드 / j5
				 , '$8'  //이수시간 / j6
				 , '$9'  //원점수 / j7
				 , '$11' //성취도 / j8
				 , '$12' //비고 / j9
				 );
		
		//창의적체험활동 훈령280호(시스템훈령:765) 이후
		var unySlctlYnArr = []; // 통합자율동아리활동 특기사항 여부

		for(var i = 0; i < 3; i++){
			var grd = i + 1; //1,2,3 학년
			
			unySlctlYnArr = report.select(`$0=10 && $2=${grd}`).getSelectOrg();	
			
			if(unySlctlYnArr != ''){
				if(unySlctlYnArr[0][7] != ' ' && unySlctlYnArr[0][7] != null && unySlctlYnArr[0][7] != '' && unySlctlYnArr[0][7] != 'undefined'){
					report.optional()
						.select(`$0=10 && $2=${grd}`)
						.take( 7
							 , '$2' // 학년 l1
							 , (v) => {
								if(v[1] >= '2027'
									|| (v[1] == '2025' && v[2] == '1')
									|| (v[1] == '2026' && v[2] == '1')
									|| (v[1] == '2026' && v[2] == '2')){
									return '자율·자치활동';
								} else {
									return '자율활동';
								}
							 } // 자율활동
							 , '$3' // 자율활동 이수시간 l3
							 , '$4' // 자율활동 특기사항 l4
							 , 'N'
							 )
						.take( 7
							 , '$2' // 학년 l1
							 , '동아리활동' //l2
							 , '$5' // 동아리활동 이수시간 l3
							 , '$6' // 동아리활동 특기사항 l4
							 , 'N'
							 )
						.take( 7
							 , '$2' // 학년 l1
							 , '동아리활동' //l2
							 , '$5' // 동아리활동 이수시간 l3
							 , '$7' // 통합자율동아리활동 특기사항 l4
							 , 'Y' // 통합자율동아리활동 특기사항 여부
							 )
						.take( 7
							 , '$2' // 학년 l1
							 , '진로활동' // l2
							 , '$10' // 진로활동 이수시간 l3
							 , '$11' // 진로활동 특기사항 l4
							 , 'N'
							 );
				}else{
					report.optional()
						.select(`$0=10 && $2=${grd}`)
						.take( 7
							 , '$2' // 학년 l1
							 , (v) => {
								if(v[1] >= '2027'
									|| (v[1] == '2025' && v[2] == '1')
									|| (v[1] == '2026' && v[2] == '1')
									|| (v[1] == '2026' && v[2] == '2')){
									return '자율·자치활동';
								} else {
									return '자율활동';
								}
							 } // 자율활동
							 , '$3' // 자율활동 이수시간 l3
							 , '$4' // 자율활동 특기사항 l4
							 , 'N'
							 )
						.take( 7
							 , '$2' // 학년 l1
							 , '동아리활동' //l2
							 , '$5' // 동아리활동 이수시간 l3
							 , '$6' // 동아리활동 특기사항 l4
							 , 'N'
							 )
						.take( 7
							 , '$2' // 학년 l1
							 , '진로활동' // l2
							 , '$10' // 진로활동 이수시간 l3
							 , '$11' // 진로활동 특기사항 l4
							 , 'N'
							 );
				}
			}
		}					 
			
			
		//봉사활동실적	훈령280호(시스템훈령:765) 이후
		report.mandatory()
			.select('$0=11')
			.take( 8
				 , '$2' // 학년
				 , '$3' // 봉사활동기간
				 , ''  
				 , '$4' // 장소 또는 주관기관명
				 , '$5' // 활동내용
				 , '$6' //시간
				 );
			
		//교과학습발달상황 훈령280호(시스템훈령:765) 이후
		for(var i = 0; applyYn504 == "N" && i < 3; i++){
			var grd = i + 1; //1,2,3 학년
			var stdN = 9;	 //Oz의 교과학습발당상황 시작 데이터셋 번호
			var n = stdN + 0 + (i * 8);
			var screScCode = "";
			
			report
				//과목
				.optional()
				.select(`$0=13 && $2=${grd} && $3=1 && -$3=01`) //학목코드=13 && 학년=1 && 학기=1 && 과목구분코드=01
				.take( n
				     , '$3'  // 학기
					 , '$5'  // 교과 
					 , '$9'  // 과목
					 , '$10' // 단위수 or 학점수
					 , (v) => {
						screScCode = this.getScreScCode(v[1], v[2]);//성적구분코드
						
						if(screScCode == '02' && v[19] == '15' && v[21] == '15'){ // 학교밖교육여부(OOSCH_YN) 컬럼 미존재로 성취도, 석차등급 코드 기준 학교밖교육 처리
							return '·';
						}else if(screScCode == '02'){
							return [v[15], '/', v[16], '(', v[17], ')'].join('');
						}else{
							return v[11];
						}
					 }// 원점수/과목평균(표준편차)
				     , (v) => {
						if(screScCode == '02' && v[19] == '15' && v[21] == '15'){ // 학교밖교육여부(OOSCH_YN) 컬럼 미존재로 성취도, 석차등급 코드 기준 학교밖교육 처리
							return '·';
						}else if(screScCode == '02'){
							return [v[20], '(', v[14], ')'].join('');
						}else{
							if((v[13] != null && v[13] != '')){
								if(!this.smfIsNull(v[14])){
									return v[12]+'('+v[13]+')/'+v[14];
								}else{
									return v[12]+'('+v[13]+')';
								}
							}else if((v[13] == null || v[13] == '')){
								if(!this.smfIsNull(v[14])){
									return v[12]+'('+'.'+')/'+v[14];
								}else{
									return v[12]+'('+'.'+')';
								}
							}
						}
					 }// 성취도(수강자수)
					 , '$18' // 석차등급
					 , '$20' // 성취도 
					 )
				.select(`$0=13 && $2=${grd} && $3=2 && -$3=01`) //학목코드=13 && 학년=1 && 학기=2 && 과목구분코드=01
				.take( n
				     , '$3'  // 학기
					 , '$5'  // 교과 
					 , '$9'  // 과목
					 , '$10' // 단위수 or 학점수
					 , (v) => {
						screScCode = this.getScreScCode(v[1], v[2]);//성적구분코드
						
						if(screScCode == '02' && v[19] == '15' && v[21] == '15'){ // 학교밖교육여부(OOSCH_YN) 컬럼 미존재로 성취도, 석차등급 코드 기준 학교밖교육 처리
							return '·';
						}else if(screScCode == '02'){
							return [v[15], '/', v[16], '(', v[17], ')'].join('');
						}else{
							return v[11];
						}
					 }// 원점수/과목평균(표준편차)
					 , (v) => {
						if(screScCode == '02' && v[19] == '15' && v[21] == '15'){ // 학교밖교육여부(OOSCH_YN) 컬럼 미존재로 성취도, 석차등급 코드 기준 학교밖교육 처리
							return '·';
						}else if(screScCode == '02'){
							return [v[20], '(', v[14], ')'].join('');
						}else{
							if((v[13] != null && v[13] != '')){
								if(!this.smfIsNull(v[14])){
									return v[12]+'('+v[13]+')/'+v[14];
								}else{
									return v[12]+'('+v[13]+')';
								}
							}else if((v[13] == null || v[13] == '')){
								if(!this.smfIsNull(v[14])){
									return v[12]+'('+'.'+')/'+v[14];
								}else{
									return v[12]+'('+'.'+')';
								}
							}
						}
					 }// 성취도(수강자수)
					 , '$18' // 석차등급
					 , '$20' // 성취도
					 )
				.select().selectTar(`$0=${n}`, (r, v) => { if(v.length == 0) r.take(n, ...Array(8).fill('')) }) //데이터가 없으면 추가
				
				//1995년 이전자료(과년도) 환산총점 훈령280호(시스템훈령:765) 이후
				.mandatory()
				.select(`$0=14 && $2=${grd}`).groupBy('$1 $2', function(r, v){
					//trace('groupBy callback : ' + JSON.stringify(v));
					
					var tmp = [];
					
					//1학기
					tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => this.getIntVal(item[4]))); // 환산총점 gr1
					tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => this.getIntVal(item[5]))); // 환산평균 gr2
					tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => {
							if(!this.smfIsNull(item[6]) && item[6] != " "){
								return [item[6], '/', item[7]].join('')
							}else{
								return ''
							}
						})); //학급석차/재적수 gr2
					tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => {
							if(!this.smfIsNull(item[8]) && item[8] != " "){
								return [item[8], '/', item[9]].join('')
							}else{
								return ''
							}
						})); //계열(학년)석차/재적수 gr3	

					//2학기
					tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => this.getIntVal(item[4]))); // 환산총점 gr1
					tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => this.getIntVal(item[5]))); // 환산평균 gr2
					tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => {
							if(!this.smfIsNull(item[6]) && item[6] != " "){
								return [item[6], '/', item[7]].join('')
							}else{
								return ''
							}
						})); //학급석차/재적수 gr2
					tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => {
							if(!this.smfIsNull(item[8]) && item[8] != " "){
								return [item[8], '/', item[9]].join('')
							}else{
								return ''
							}
						})); //계열(학년)석차/재적수 gr3	
					return tmp;	
				})
				.take( ++n  
					, '$0'      
					, '$1'  // 1학기 환산총점
					, '$2'  // 1학기 환산평균
					, '$3'  // 1학기 학급석차/재적수 
					, '$4'  // 1학기 계열(학년)석차/재적수
					, '$5'  // 2학기 환산총점
					, '$6'  // 2학기 환산평균
					, '$7'  // 2학기 학급석차/재적수
					, '$8'  // 2학기 계열(학년)석차/재적수
					, ''
					, ''
					, ''
					, ''
				)
				
				//세부능력 및 특기사항 ( 과목 ) 훈령280호(시스템훈령:765) 이후
				.mandatory()
				.select(`$0=15 && $2=${grd}`)
				.take(++n, '$3')
				
				//진로선택과목 훈령280호(시스템훈령:765) 이후
				.optional()
				.select(`$0=13 && $2=${grd} && $3=1 && -$3=02`) //학목코드=13 && 학년=1 && 학기=1 && 과목구분코드=02
				.take( ++n
				     , '$3'  // 학기
					 , '$5'  // 교과
					 , '$9'  // 과목
					 , '$10' // 단위수 or 학점수
					 , (v) => {
								if(v[19] == '15'){
									return '·';
								} else {
									return [v[15], '/', v[16]].join('');
								}
						} // 원점수/과목평균
					 , '$14' // 수강자수
					 , (v) => {
								if(v[19] == '15'){
									return '·';
								} else {
									return v[22];
								}
						} // 성취도별 분포비율
					 , (v) => {
								if(v[19] == '15'){
									return '·';
								} else {
									return [v[20], '(', v[14], ')'].join('');
								}
						} // 성취도(수강자수)
					 )
				.select(`$0=13 && $2=${grd} && $3=2 && -$3=02`) //학목코드=13 && 학년=1 && 학기=2 && 과목구분코드=02
				.take( n
				     , '$3'  // 학기
					 , '$5'  // 교과
