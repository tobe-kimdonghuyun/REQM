						//1학기
						tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => item[10])); //단위수
						tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => {
							/* 성적구분(2004이전 입학생:02, 2005이후 입학생:01)   2008관련 : 02
						     * 2004년 이전의 입학생일지라도 2005년 이후에 복학했을 경우 이전자료를 조회하도록 과목별로 성적구분 정보를 가짐.
						     */
							screScCode = this.getScreScCode(item[1], item[2]);//성적구분코드
							
							if(screScCode == '02'){
								if(!this.smfIsNull(item[15]) && !this.smfIsNull(item[16]) && !this.smfIsNull(item[17])){
									return [item[15], '/', item[16], '(', item[17], ')'].join('')
								}else if (this.smfIsNull(item[15]) && this.smfIsNull(item[16]) && this.smfIsNull(item[17])){
									return ''
								}
							}else{
								return item[11];
							}
							
						})); //원점수/과목평균(표준편차)
						tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => {
							if(screScCode == '02'){
								if(!this.smfIsNull(item[18]) && !this.smfIsNull(item[14])){
									return [item[18], '(', item[14], ')'].join('');
								}else if(!this.smfIsNull(item[18])){
									return item[18]
								}else if(!this.smfIsNull(item[14])){
									return '('+item[14]+')'
								}else{
									return ''
								}
							}else{
								//item[12] CURR_LRN_RAK_VALUE
								//item[13] CURR_LRN_SRK
								if(item[12] == null || item[12] == ''){
									return ''
								}else{
									if((item[13] != null && item[13] != '')){
										if(!this.smfIsNull(item[14])){
											return item[12]+'('+item[13]+')/'+item[14];
										}else{
											return item[12]+'('+item[13]+')';
										}
									}else if((item[13] == null || item[13] == '')){
										if(applyYn616 == 'Y'){
											if(!this.smfIsNull(item[14])){
												return item[12]+'( )/'+item[14];
											}else{
												return item[12]+'( )';
											}
										}else{
											if(!this.smfIsNull(item[14])){
												return item[12]+'('+'.'+')/'+item[14];
											}else{
												return item[12]+'('+'.'+')';
											}
										}
									}
								}
 							}
							
						})); //석차등급(수강자수)
							
						//2학기
						tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => item[10])); //단위수
						tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => {
							/* 성적구분(2004이전 입학생:02, 2005이후 입학생:01)   2008관련 : 02
						     * 2004년 이전의 입학생일지라도 2005년 이후에 복학했을 경우 이전자료를 조회하도록 과목별로 성적구분 정보를 가짐.
						     */
							screScCode = this.getScreScCode(item[1], item[2]);//성적구분코드
							
							if(screScCode == '02'){
								if(!this.smfIsNull(item[15]) && !this.smfIsNull(item[16]) && !this.smfIsNull(item[17])){
									return [item[15], '/', item[16], '(', item[17], ')'].join('')
								}else if (this.smfIsNull(item[15]) && this.smfIsNull(item[16]) && this.smfIsNull(item[17])){
									return ''
								}
							}else{
								return item[11];
							}
							
						})); //원점수/과목평균(표준편차)
						tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => {
							if(screScCode == '02'){
								if(!this.smfIsNull(item[18]) && !this.smfIsNull(item[14])){
									return [item[18], '(', item[14], ')'].join('');
								}else if(!this.smfIsNull(item[18])){
									return item[18]
								}else if(!this.smfIsNull(item[14])){
									return '('+item[14]+')'
								}else{
									return ''
								}
							}else{
								//item[12] CURR_LRN_RAK_VALUE
								//item[13] CURR_LRN_SRK
								if(item[12] == null || item[12] == ''){
									return ''
								}else{
									if((item[13] != null && item[13] != '')){
										if(!this.smfIsNull(item[14])){
											return item[12]+'('+item[13]+')/'+item[14];
										}else{
											return item[12]+'('+item[13]+')';
										}
									}else if((item[13] == null || item[13] == '')){
										if(applyYn616 == 'Y'){
											if(!this.smfIsNull(item[14])){
												return item[12]+'( )/'+item[14];
											}else{
												return item[12]+'( )';
											}
										}else{
											if(!this.smfIsNull(item[14])){
												return item[12]+'('+'.'+')/'+item[14];
											}else{
												return item[12]+'('+'.'+')';
											}
										}
									}
								}
 							}
							
						})); //석차등급(수강자수)
						
						tmp.push('');
						tmp.push('');
							
					}else{
						//1학기
						tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => item[10])); //단위수
						tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => {
						
							/* 성적구분(2004이전 입학생:02, 2005이후 입학생:01)   2008관련 : 02
						     * 2004년 이전의 입학생일지라도 2005년 이후에 복학했을 경우 이전자료를 조회하도록 과목별로 성적구분 정보를 가짐.
						     */
							screScCode = this.getScreScCode(item[1], item[2]);//성적구분코드
							
							if(screScCode == '02'){
								if(!this.smfIsNull(item[15]) && !this.smfIsNull(item[16]) && !this.smfIsNull(item[17])){
									return [item[15], '/', item[16], '(', item[17], ')'].join('')
								}else if (this.smfIsNull(item[15]) && this.smfIsNull(item[16]) && this.smfIsNull(item[17])){
