		}
		
		//봉사활동실적	 훈령280호(시스템훈령:765) 이전
		report.mandatory()
			.select('$0=11')
			.take( 8
				 , '$2' // 학년
				 , '$3' // 봉사활동 기간
				 , ''  
				 , '$4' // 장소 또는 주관기관명
				 , '$5' // 활동내용
				 , '$6' // 시간
				 );
				
		//교과학습발달상황  훈령280호(시스템훈령:765) 이전
		for(var i = 0; i < 3; i++){
			var grd = i + 1; //1,2,3 학년
			var stdN = 9;	 //Oz의 교과학습발당상황 시작 데이터셋 번호
			var n = stdN + 0 + (i * 6);
				
			report.optional()
				//과목
				.select(`$0=13 && $2=${grd} && -$3=01`).groupBy('$4 $6 $8', function(r, v){
					//trace('교과 이전 groupBy callback : ' + JSON.stringify(v));
					
					var tmp = [];
					var screScCode = "";
					
					tmp.push(v[0][0]); 
					tmp.push(v[0][1]); //학년도
					tmp.push(v[0][2]); //학년
					tmp.push(v[0][5]); //교과
					tmp.push(v[0][9]); //과목
					
