    <Script type="xscript5.1"><![CDATA[/**
 *	전형자료생성
 *	@MenuPath	대입전형-전형자료온라인수신-전형자료생성
 *	@FileName 	uds_ueudd00_m05.xfdl
 *	@Creator 	김정민
 *	@CreateDate	2022.09.30 
 *	@Desction	
 ************** 소스 수정 이력 ***********************************************
 *	date			Modifier			Description
 *******************************************************************************
 *	2022.09.30		김동업				최초 생성 
 *******************************************************************************
 */

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::uds_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
// ExtCmmon API
this.fvObjExtCommon = this.smfCreateExtCommonAPI();
this.fvCoaDataBlindPath = this.udsfGetCoaDataBlindPath(); // 블라인드자료경로
this.fvCoaDataDecrPath = this.udsfGetCoaDataDecrPath();   // 블라인드해제자료경로 
this.fvCoaDataPath = '';

this.fvQueFiles = null;	  //파일 큐 버퍼
this.fvQueRawData = null; //리포트 원시 데이터 큐 버퍼
this.fvQueIdx = null;	  //선택된 데이터 인덱스 큐 버퍼
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Div 초기화
	this.smfInitDiv(obj);
	
	this.fnClear();
	
	// 대입서비스체크
	this.udsfCoaSvcChck(function(){
		// 초기화
		this.fnInit(obj);
				
		this.fnSearch(this.divSearch.form.btnSearch, e); // 조회
		 
		// 조회 입력창에서 'Ctrl' + 'Enter' 키 입력시 조회수행 이벤트 설정
		this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
	});
	
};

/**
 * @description 폼 닫기전 이벤트
 */
this.fnOnbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	// 변경내역이 발생한 경우 종료전 confirm수행
	return this.smfCloseFormConfirm([this.dsMain]);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/**
 * @description 조회
*/
this.fnSearch = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 조회 서비스
	this.smfSearchService("listCoaApst")
		.paginator(this.grdMain, this.divPaginator, this.divPageSummary, this.dsPageInfo, obj, e) // 페이징처리
		.confirmIfModifiedGrid(this.grdMain) // 데이터가 변경되었으면 확인메시지
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			/*
			//모든데이터 연속해서 계속 불러오기
			var pageIndex = this.dsPageInfo.getColumn(0, 'pageIndex');
			var pageSize  = this.dsPageInfo.getColumn(0, 'pageSize'); 
			var totalCount = this.dsPageInfo.getColumn(0, 'totalCount');
			
			this.dsMain.appendData(this.dsMain01);
			if(pageIndex * pageSize < totalCount){
				this.dsPageInfo.setColumn(0, 'pageIndex', pageIndex + 1);
				this.fnSearch();
			}
			*/
		}); // 콜백
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/**
 * @description 초기화 FUNCTION
 */
this.fnInit = function(obj){
	this.dsSearch.setColumn(0, "coaAyr", this.udsv_coaAyr);
	this.dsSearch.setColumn(0, "coaRcritScCd", this.udsv_coaRcritScCd);
	this.dsSearch.setColumn(0, "coaRcritScNm", this.udsv_coaRcritScNm);
	
	this.dsSearch.setColumn(0, "coaEvlUnitId", "");
	this.dsSearch.setColumn(0, "coaEvlUnitNm", "- 전체 -");
	
	this.dsSearch.setColumn(0, "bldRmvYn", "N");
	
	this.dsSearch.setColumn(0, "prtOpt", "1");
	this.dsSearch.setColumn(0, "prtOrgaOpt", "N");
	
	this.fvQueFiles = this.udsfCreateQueue();
	this.fvQueRawData = this.udsfCreateQueue();
	this.fvQueIdx = this.udsfCreateQueue();
	
	// 과목별 평가정보 출력옵션, 대입학년도 2027학년도 이후 표시.
	if(this.udsv_coaAyr >= "2027"){
		this.divPrintOpt.form.chkPrtSbjtEvlInfoOpt.set_visible(true);
	} else {
		this.divPrintOpt.form.chkPrtSbjtEvlInfoOpt.set_visible(false);
	}
}

/**
 * @description 페이지 네이션 클리어 FUNCTION
 */
this.fnClear = function(){
	this.dsPageInfo.setColumn(0, "totalCount", "0");
	
	this.divPaginator.form.fnInit(
			  this.grdMain
			, this.dsPageInfo
			, this.divPageSummary
			, this.btnSearch
			, this);
}

/**
 * 그리드 체크박스 enable 처리
 * @param : ds - 데이터셋
 * @param : nRow - rowposition
 */
this.fnRenderGridCheckbox = function(ds, nRow){
	return true;
};

/**
 * @description  블라인드여부
 */
this.fnIsBld = function(){
	return this.dsSearch.getColumn(0, 'bldRmvYn') == 'N';
}

/**
 * @description  오즈레포트 생성
 * @param : data - 대입전형자료
 * @return : report - 대입전형자료 오즈 공통
 */
this.fnCreateReport = function(data){
	var _that = this;
	var _report = {};
	
	var _dataOrg = data.split('\r\n');
	
	var _selectOrg = [];
	var _selectTar = [];
	var _selectTarCol = 0;
	var _selectOrgCon = null;
	var _selectTarCon = null;
	var _takeType = 0; //0:mandatory, 1:optional
	var _trim = false;
	
	var _sepField = '^'; //원본 데이터의 필드 구분자
	var _dataTar = [];
	
	var fnIsStr = (s) => typeof s == 'string';
	
	//조건식
	var fnPass = (v, condition) => {
		if(_that.smfIsNull(condition)) return false;
		var strFn = 'var _v = arguments[0];'
		strFn += 'return ' + condition.replace(/\s/gi, '').replace(/\$([0-9]+)/gi, '_v[$1]').replace(/\={1,}/gi, '==').replace(/-_v\[([0-9]+)\]/gi, '_v[_v.length - $1]') + ';';
		return Function(strFn)(v);
	}
	
	//매핑 인덱스를 분리하여 원본데이터 push
 	var fnDoMapng = (tar, input, org) => {
 		var t = 1;
 		input = input.replace(/\s/gi, '').replace(/\$([0-9]+)/gi, '$1');
 		if(input[0] == '-') {
 			t = -1;
 			input = input.replace(/^-/, '');
 		}
 		if(_that.smfIsNull(input.match(/[^0-9]/))){
 			if(_that.smfIsNull(org)){
 				tar.push('');
 			}else{
 				var orgValue = org[(t < 0 ? org.length + (input * t) : input)];
 				if(_trim == true && fnIsStr(orgValue)) orgValue = orgValue.trim();
 				tar.push(orgValue);
 			}
 		}else{
 			tar.push(input);
 		}
 	}
	
	//문자열의 인덱스만 분리하여 배열로 변환
	//'$1 $2 -$3' -> [1,2,-3]
	function sepIdxs(str, max){
		var rtnIdxs = [];
		var idxs = str.replace(/\s/gi, '').match(/(\$[0-9]+)|(-\$[0-9]+)/gi);
		if(idxs != null && idxs.length > 0){
			idxs.forEach((v, i) => {
				var n = Number(v.replace(/\$/gi, ''));
				if(n < 0) n = max - n;
				rtnIdxs.push(n);
			})
		}
		return rtnIdxs;
	}
	
	//...^\n숫자^ 형식이 아니면 하나의 데이터로 보고 newLine을 추가하여 합친다.
	_report.adjustNewline = function(newLine){
		_dataOrg = _dataOrg.reduce((a,v,i) => {
			if(_that.smfIsNull(v.match(/^[0-9]+\^/gi))){
				if(a.length > 0) a[a.length - 1] += newLine + v;
			}else{
				a.push(v);
			}
			return a;
		}, []);
		
		return _report;
	}
	
	//2차원 데이터로 분리
	_report.seprate = function(sep){
		_dataOrg = _dataOrg.map((v) => v.split(sep));
		return _report;
	}
	
	//원본, 타겟, 타켓 Col 선택
	_report.select = function(conOrg, conTar, tarCol){
		this.selectOrg(conOrg);
		this.selectTar(conTar);
		return this.selectTarCol(tarCol);
	}
	
	//원본데이터 선택
	_report.selectOrg = function(condition, callback){
		_selectOrg.length = 0;
		if(!_that.smfIsNull(condition)){
			_dataOrg.forEach((v, row) => {
				if(fnPass(v, condition)) _selectOrg.push(v);
			});
		}
		_selectOrgCon = condition;
		if(_that.smfIsFunc(callback)) callback(_report, _selectOrg);
		return _report;
	}
	
	//타겟테이터 선택
	_report.selectTar = function(condition, callback){
		_selectTar.length = 0;
		if(!_that.smfIsNull(condition)){
			_dataTar.forEach((v, row) => {
				if(fnPass(v, condition)) _selectTar.push(v);
			});
		}
		_selectTarCon = condition;
		if(_that.smfIsFunc(callback)) callback(_report, _selectTar);
		return _report;
	}
	
	//타켓컬럼위치 선택 : 음수이면 맨뒤에부터
	_report.selectTarCol = function(nColIdx){
		if(_that.smfIsNull(nColIdx)) nColIdx = 0;
		_selectTarCol = nColIdx < 0 ? (_selectTar[0].length + 1) + nColIdx : nColIdx;
		return _report;
	}
	
	//선택된 원본데이터를 조작
	_report.modify = function(callback){
		if(_that.smfIsFunc(callback)){
			var tmp = callback(_selectOrg);
			_selectOrg.length = 0;
			_selectOrg.push(...tmp);
		}
	
		return _report;
	}
	
	//선택된 선택된 원본데이터 그룹
	//callback의 결과 값에 따라 원본데이터를 변경
	//@param : string - groupCols '$1 $2 $3 -$5'
	//@param : callback - group된 3차원 데이터를 그룹단위로 전달하여 결과 값을 원본데이터에 넣는다
	_report.groupBy = function(groupCols, callback){
		if(_selectOrg.length > 0){
			var groupIdxs = sepIdxs(groupCols)
			var group =_selectOrg.reduce((a, v) => {
				var key = v.filter((v, i) => groupIdxs.includes(i) ? true : false).join('');
				if(!a[key]) a[key] = [];
				a[key].push(v);
				return a;
			}, {});
			
			if(_that.smfIsFunc(callback)){
				var vals = Array.from(Object.values(group));
				_selectOrg.length = 0;
				
				vals.forEach((v) => {
					var tmp = callback.call(_that, _report, v);
					_selectOrg.push(tmp);
				});
			}
		}
		return _report;
	}
	
	_report.groupUtils = {
		max : (arr, idx) => {
			return Math.max(...arr.reduce((a, v) => {
				a.push(v.filter((v, i) => i == idx ? true : false));
				return a;
			}, []));
		},
		min : (arr, idx) => {
			return Math.min(...arr.reduce((a, v) => {
				a.push(v.filter((v, i) => i == idx ? true : false));
				return a;
			}, []));
		},
		caseWhen : (arr, cond, callbck) =>{
			for(var i = 0; i < arr.length; i++){
				if(fnPass(arr[i], cond)){
					if(_that.smfIsFunc(callbck)) return callbck.call(_that, arr[i]);
				}
			}
			return '';
		},
	}
	
	//원본데이터가 없으면
	//$부분은 빈값, 직접 입력 부분은 값이 들어감
	_report.mandatory = function(){
		_takeType = 0;
		return _report;
	}
	
	//원본데이터가 없으면 입력 안함.
	_report.optional = function(){
		_takeType = 1;
		return _report;
	}
	
	//타겟 테이터를 넣을때 trim 처리.
	_report.trim = function(bFlg){
		_trim = bFlg;
		return _report;
	}
	
	//org -> tar 데이터 이동 복사
	//1. 원본 select 상태가 있고 원본 select 결과 데이터가 없을때 컬럼번호('$') 부분은 ''로 넣어진다.
	//2. 원본 select 상태가 없을때 value값을 그냥 넣는다.
	//3. 원본 select 상태가 있고 원본 select 결과 데이터가 있을때
	//		> value 값이 없으면 원본데이터 row 전체를 타겟 데이터에 추가. ( copy all )
	//		> 타겟 select 결과 데이터가 있으면 _selectTarCol 인덱스 부터 데이터를 추가. ( append )
	//		> 타켓 select 결과 데이터가 없으면 타겟 데이터에 추가. ( add )
	_report.take = function(...value){
		if(_selectOrg.length > 0 || !_that.smfIsNull(_selectOrgCon)){
			if(_selectOrg.length == 0){
				//optional 이면 리턴
				if(_takeType == 1) return _report;
				//선택했는데 원본데이터가 없으면 ''로 넣는다.
				var vals = value.reduce((a, val) =>{
					if(_that.smfIsFunc(val)){
						a.push('');
					}else if(fnIsStr(val) && val.indexOf('$') > -1){
						fnDoMapng(a, val);
					}else{
						a.push(val);
					}
					return a;
				}, []);
			
				if(_selectTar.length == 0){
					_dataTar.push(vals); //타겟이터 추가
				}else{
					//선택타겟데이터의 선택컬럼위치부터 넣어준다.
					_selectTar.forEach((v) => {
						v.splice(_selectTarCol, 0, ...vals);
					});
				}
			}else{
				_selectOrg.forEach((v, row) => {
					if(_that.smfIsNull(value)){
						if(_selectTar.length == 0){
							_dataTar.push(v); //타겟이터 추가
						}else{
							//선택타겟데이터의 선택컬럼위치부터 넣어준다.
							//_selectOrg와 _selectTar의 rowIdx 데이터 매핑 일치 해야함
							_selectTar[row].splice(_selectTarCol, 0, ...v);
						}
					}else{
						var vals = value.reduce((a, val) =>{
							if(_that.smfIsFunc(val)){
								a.push(val(v));
							}else if(fnIsStr(val) && val.indexOf('$') > -1){
								fnDoMapng(a, val, v);
							}else{
								a.push(val);
							}
							return a;
						}, []);
						
						if(_selectTar.length == 0){
							_dataTar.push(vals); //타겟이터 추가
						}else{
							//선택타겟데이터의 선택컬럼위치부터 넣어준다.
							//TODO : select 에서 원본의 수량이 많을때 에러가남
							_selectTar[row].splice(_selectTarCol, 0, ...vals);
						}
					}
				});
			}
		} else {
			if(_selectTar.length == 0){
				_dataTar.push(value); //타겟데이터 추가
			}else{
				//선택타겟데이터의 선택컬럼위치부터 넣어준다.
				_selectTar.forEach((v) => {
					v.splice(_selectTarCol, 0, ...value);
				});
			}
		}
		
		return _report;
	}
	
	//oz의 csv 파일로 만든다.
	//필드구분, 로우구분, 데이터셋 종료구분
	//'#$!', '^&*', '//EOR//'
	_report.toOzCSV = function(field, row, dsEnd){
		return _dataTar.reduce((a,v,i) => {
			var itmNo = v[0];
			v.splice(0, 1); //아이템 번호 제거
			
 			for(var j = 0; j < v.length; j++){
 				if(!_that.smfIsNull(v[j]) && typeof v[j] == 'string'){
 					v[j] = v[j].replace(/\/EOR\//gi, '\n');
 				}
 			}
			
			if(a.n == itmNo && a.d.length > 0){
				 a.d[a.d.length - 1] += row + v.join(field);
			}else{
				a.n = itmNo;
				a.d.push(v.join(field));
			}
			
			return a;
		}, {n:null, d:[]}).d.map((v) => v.length == 0 ? field : v).join(row + dsEnd + row);
	}
	
	//값을 가져온다.
	_report.getOrg = function(row, col){
		if(_that.smfIsNull(col)){
			return _dataOrg[row < 0 ? _dataOrg.length + row : row];
		}
		return _dataOrg[row < 0 ? _dataOrg.length + row : row][col < 0 ? _dataOrg[row].length + col : col];
	}
	
	//_selectOrg 값을 가져온다. 선택된 원본의 로우배열
	_report.getSelectOrg = function(){
	
		return _selectOrg;
	}
	
	/////////////////////////////
	//콘솔 출력
	////////////////////////////
	var _tracer = {
		prefix : '',
		sel : '' ,
		data : null,
		enable : false
	};
	
	_tracer.org = function(){
		if(!_tracer.enable) return _tracer;
		
		_tracer.data = _dataOrg;
		_tracer.sel = 'org';
		
		return _tracer;
	}
	
	_tracer.tar = function(){
		if(!_tracer.enable) return _tracer;
		_tracer.data = _dataTar;
		_tracer.sel = 'tar';
		return _tracer;
	}
	
	_tracer.selected = function(){
		if(!_tracer.enable) return _tracer;
		
		if(_tracer.sel == 'org') _tracer.data = _selectOrg;
		else if(_tracer.sel == 'tar') _tracer.data = _selectTar;
		
		return _tracer;
	}
	
	_tracer.end = function(){
		if(!_tracer.enable) return _report;
		trace(_tracer.prefix + JSON.stringify(_tracer.data));
		return _report;
	}
	
	_report.trace = function(prefix){
		if(!_tracer.enable) return _tracer;
		_tracer.prefix = prefix;
		return _tracer;
	}
	
	_report.enableTrace = function(flg){
		_tracer.enable = _that.smfIsNull(flg) ? true : flg;
		return _report;
	}

	return _report;
}

/**
 * @description 오즈 데이터 생성
 */
this.fnDoOzReport = function(){
	var ozDatas = [];
	this.dsReportNm.clearData(); //리포트명 데이터셋 클리어
	
	var nCnt = this.fvQueRawData.length();
	for(var i = 0; i < nCnt; i++){
		var rawData = this.fvQueRawData.dequeue();
		var coaEvlUnitNm = this.dsMain.getColumn(rawData.idx, 'coaEvlUnitNm');
		var stuIdfNo = this.dsMain.getColumn(rawData.idx, 'stuIdfNo');
		
		var prcsSn = this.dsMain.getColumn(rawData.idx, 'prcsSn');
		var rreqNts = this.dsMain.getColumn(rawData.idx, 'rreqNts');
		
		if(rawData.sele.cn == null || rawData.sele.cn.trim().length == 0){
			this.setWaitCursor(false);
			
			//row idx 이동 ( UI )
			if(!this.grdMain.setCellPos(1, rawData.idx)) this.grdMain.setCellPos(2, rawData.idx);
			this.grdMain.redrawExprCell();
			
			this.dsMain.setColumn(rawData.idx, '_chk', '');
			
			this.fnClearQueue();
			
			this.smfAlert("식별번호 '" +  this.dsMain.getColumn(rawData.idx, 'stuIdfNo') +"'의 전형자료 파일 크기가 0KB 입니다.");
			return;
		}
		
		ozDatas.push({
			'title' : coaEvlUnitNm + '-' + stuIdfNo,
			'csv' : this.fnTransOzData(rawData.shlNm, rawData.sele.cn, rawData.image ? rawData.image.cn : '', rawData.idx),
			'prcsSn' : prcsSn,
			'rreqNts' : rreqNts
		});
	}
	
	this.fnShowOzReport(ozDatas);
}

this.fnScrgOfodAplcnYn = function(ayr, shlCrseSc, grd, dgr) {

		// 
		// 728호 - 초 : 초등학교는 728호 훈령 적용대상 아님
		// 중,고 : 2009년도 1학년 2010년도 1,2학년 2011년도 모두
		// 학교과정구분 2:초등, 3:중등, 4:고등
		// 사용법 getOfodAplcnYn(학년도, 학교과정구분, 학년, 훈령차수))
		
		if ("" == ayr || ayr == null) {
			return ""; // 학년도 없음
		}
		if ("" == shlCrseSc || shlCrseSc == null) {
			return ""; // 학교과정구분 없음
		}
		if ("" == grd || grd == null) {
			return ""; // 학년 없음
		}
		if ("" == dgr || dgr == null) {
			return ""; // 훈령차수 없음
		}
		
		var shlCrseScCd = shlCrseSc;
		if ("4" == shlCrseSc) {
			shlCrseScCd = "3"; // 중,고는 동일
		}

		var ayrShlCrseScGrd = ayr + shlCrseScCd + grd;

		if ("616" == dgr) {
			if ("200231" == ayrShlCrseScGrd) {
				return "Y"; // 2002년도 고1학년
			} else if ("200331" == ayrShlCrseScGrd || "200332" == ayrShlCrseScGrd) {
				return "Y"; // 2003년도 고1,2학년
			} else if (parseInt(ayr) == 2004) {
				return "Y"; // 2004년도는 모두
			} else if ("200532" == ayrShlCrseScGrd || "200533" == ayrShlCrseScGrd) {
				return "Y"; // 2005년도 고2,3학년
			} else if ("200633" == ayrShlCrseScGrd) {
				return "Y"; // 2006년도 고3학년
			} else {
				return "N";
			}
		}else if ("676" == dgr) {
			if ("200531" == ayrShlCrseScGrd) {
				return "Y"; // 2005년도 고1학년
			} else if ("200631" == ayrShlCrseScGrd || "200632" == ayrShlCrseScGrd) {
				return "Y"; // 2006년도 고1,2학년
			} else if ("200732" == ayrShlCrseScGrd || "200733" == ayrShlCrseScGrd) {
				return "Y"; // 2007년도 고2,3학년
			} else if ("200833" == ayrShlCrseScGrd) {
				return "Y"; // 2008년도 고3학년
			} else {
				return "N";
			}
		}else if ("719" == dgr) {
			if ("200731" == ayrShlCrseScGrd) {
				return "Y"; // 2007년도 고1학년
			} else if ("200831" == ayrShlCrseScGrd || "200832" == ayrShlCrseScGrd) {
				return "Y"; // 2008년도 고1,2학년
			} else if (parseInt(ayr) >= 2009) {
				return "Y"; // 2009년도 부터는 모두
			} else {
				return "N";
			}
		} else if ("728" == dgr) {
			if ("200931" == ayrShlCrseScGrd) {
				return "Y"; // 2009년도 중1학년
			} else if ("201031" == ayrShlCrseScGrd || "201032" == ayrShlCrseScGrd) {
				return "Y"; // 2010년도 중1,2학년
			} else if (parseInt(ayr) >= 2011) {
				return "Y"; // 2011년도 부터는 모두
			} else {
				return "N";
			}
		} else if ("205" == dgr) { // Add By 이병규(2012.04.06) 훈령 205호 체크 추가
			if ("201131" == ayrShlCrseScGrd) {
				return "Y"; // 2011년도 중1학년
			} else if ("201231" == ayrShlCrseScGrd || "201232" == ayrShlCrseScGrd) {
				return "Y"; // 2012년도 중1,2학년
			} else if (parseInt(ayr) >= 2013) {
				return "Y"; // 2013년도 부터는 모두
			} else {
				return "N";
			}
		} else if ("239" == dgr) // Add By 이병규(2013.01.22) 훈령 239호 체크 추가
		{
			if ("201231" == ayrShlCrseScGrd) {
				return "Y"; // 2012년도 중1학년
			} else if ("201331" == ayrShlCrseScGrd || "201332" == ayrShlCrseScGrd) {
				return "Y"; // 2013년도 중1,2학년
			} else if (parseInt(ayr) >= 2014) {
				return "Y"; // 2014년도 부터는 모두
			} else {
				return "N";
			}
		} else if ("29_1" == dgr) // Add By 이병규(2014.04.04) 훈령 29_1호 체크 추가
		{
			// if (parseInt(ayr) >= 2015) { return "Y"; //2015년도 부터는 모두 } else { return "N"; }
			// [2020 유지보수] 2020.09.02 대입전형에서 29호 전면적용 사항에 대하여 학생부와 동일하게 단계별적용되도록 수정
			if ("201431" == ayrShlCrseScGrd) {
				return "Y"; // 2014년도 중1학년
			} else if ("201531" == ayrShlCrseScGrd || "201532" == ayrShlCrseScGrd) {
				return "Y"; // 2015년도 중1,2학년
			} else if (parseInt(ayr) >= 2016) {
				return "Y"; // 2016년도 부터는 모두
			} else {
				return "N";
			}
		} else if ("29_2" == dgr) // Add By 이병규(2014.04.04) 훈령 29_2호 체크 추가
		{
			if ("201431" == ayrShlCrseScGrd) {
				return "Y"; // 2014년도 중1학년
			} else if ("201531" == ayrShlCrseScGrd || "201532" == ayrShlCrseScGrd) {
