			} else {
				return "N";
			}
		} else if ("169" == dgr) // Add By 김진철(2017.01.17) 훈령 169호 체크 추가
		{
			if (parseInt(ayr) >= 2016) {
				return "Y"; // 2016년도 부터는 모두
			} else {
				return "N";
			}
		} else if ("195" == dgr) // Add By 김휘섭(2017.06.29) 훈령 195호 체크 추가
		{
			if ("201731" == ayrShlCrseScGrd) {
				return "Y"; // 2017년도 중1학년
			} else if ("201831" == ayrShlCrseScGrd || "201832" == ayrShlCrseScGrd) {
