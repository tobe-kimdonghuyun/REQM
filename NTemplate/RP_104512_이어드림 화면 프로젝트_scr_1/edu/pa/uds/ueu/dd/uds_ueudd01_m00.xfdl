	var applyYn29A = this.dsOfodIdnty.getColumn(0,"hr29AApplyYn"); //훈령29-1호적용여부
	var applyYn29B = this.dsOfodIdnty.getColumn(0,"hr29BApplyYn"); //훈령29-2호적용여부 (교과학습발달상황 폼 변경)
	var applyYn169 = this.dsOfodIdnty.getColumn(0,"hr169ApplyYn"); //훈령169호적용여부  (Y => 국가직무)
	var applyYn195 = this.dsOfodIdnty.getColumn(0,"hr195ApplyYn"); //훈령195호적용여부
	var applyYn243 = this.dsOfodIdnty.getColumn(0,"hr243ApplyYn"); //훈령243호적용여부  (<체육ㆍ예술> 여부)
	var applyYn280 = this.dsOfodIdnty.getColumn(0,"hr280ApplyYn"); //훈령280호적용여부
	var applyYn321 = this.dsOfodIdnty.getColumn(0,"hr321ApplyYn"); //훈령321호적용여부 단위수 학점수로 명칭이 바뀜 (마이스터고)
	var applyYn365 = this.dsOfodIdnty.getColumn(0,"hr365ApplyYn"); //훈령365호적용여부
