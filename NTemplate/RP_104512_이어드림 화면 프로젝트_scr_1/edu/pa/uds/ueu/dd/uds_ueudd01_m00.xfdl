					, '$4'  // 과목, 과목
					, '$5'  // 1학기 단위수, 1학기 단위수
					, '$6'  // 1학기 원점수/과목평균(표준편차), 1학기 원점수/과목평균(표준편차) 
					, '$7'  // 1학기 성취도(수강자수), 1학기 석차등급(수강자수)
					, '$8'  // 1학기 석차등급, 2학기 단위수
					, '$9'  // 2학기 단위수, 2학기 원점수/과목평균(표준편차)
					, '$10' // 2학기 원점수/과목평균(표준편차), 2학기 석차등급(수강자수)
					, '$11' // 2학기 성취도(수강자수), 공백 
					, '$12' // 2학기 석차등급, 공백
					)
				.select().selectTar(`$0=${n}`, (r, v) => { if(v.length == 0) r.take(n, ...Array(13).fill('')) }) //데이터가 없으면 추가
					
				//1995년 이전자료(과년도) 환산총점 훈령280호(시스템훈령:765) 이전
				.mandatory()
				.select(`$0=14 && $2=${grd}`).groupBy('$1 $2', function(r, v){
					//trace('1995 280이전 groupBy callback : ' + JSON.stringify(v));
					
					var tmp = [];
					
					//1학기
					tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => this.getIntVal(item[4]))); // 환산총점 gr1
					tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => this.getIntVal(item[5]))); // 환산평균 gr2
					tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => {
							if(!this.smfIsNull(item[6]) && item[6] != " "){
								return [item[6], '/', item[7]].join('')
							}else{
								return ''
							}
						})); //학급석차/재적수 gr2
					tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => {
							if(!this.smfIsNull(item[8]) && item[8] != " "){
								return [item[8], '/', item[9]].join('')
							}else{
								return ''
							}
						})); //계열(학년)석차/재적수 gr3	

					//2학기
					tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => this.getIntVal(item[4]))); // 환산총점 gr1
					tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => this.getIntVal(item[5]))); // 환산평균 gr2
					tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => {
							if(!this.smfIsNull(item[6]) && item[6] != " "){
								return [item[6], '/', item[7]].join('')
							}else{
								return ''
							}
						})); //학급석차/재적수 gr2
					tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => {
							if(!this.smfIsNull(item[8]) && item[8] != " "){
								return [item[8], '/', item[9]].join('')
							}else{
								return ''
							}
						})); //계열(학년)석차/재적수 gr3	
					return tmp;	
				})
				.take( ++n  
					, '$0'      
					, '$1'  // 1학기 환산총점
					, '$2'  // 1학기 환산평균
					, '$3'  // 1학기 학급석차/재적수 
					, '$4'  // 1학기 계열(학년)석차/재적수
					, '$5'  // 2학기 환산총점
					, '$6'  // 2학기 환산평균
					, '$7'  // 2학기 학급석차/재적수
					, '$8'  // 2학기 계열(학년)석차/재적수
					, ''
					, ''
					, ''
					, ''
				)
				
				//세부능력 및 특기사항 ( 과목 ) 훈령280호(시스템훈령:765) 이전
				.mandatory()
				.select(`$0=15 && $2=${grd}`)
				.take(++n, '$3')

				//체육예술과목 훈령280호(시스템훈령:765) 이전
				.optional()
				.select(`$0=13 && $2=${grd} && -$3=03`).groupBy('$4 $6 $8', function(r, v){
					//trace('groupBy callback : ' + JSON.stringify(v));
					
					var tmp = [];
					
					tmp.push(v[0][0]); 
					tmp.push(v[0][1]); //학년도
					tmp.push(v[0][2]); //학년
					tmp.push(v[0][5]); //교과
					tmp.push(v[0][9]); //과목
					
					//1학기
					tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => item[10])); //단위수
					tmp.push(r.groupUtils.caseWhen(v, '$3=1',(item) => [item[20].trim() || item[18]])); //성취도
					
					//2학기
					tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => item[10])); //단위수
					tmp.push(r.groupUtils.caseWhen(v, '$3=2',(item) => [item[20].trim() || item[18]])); //성취도
					
					return tmp;
				}).take( ++n
					   , '$0'
					   , '$1' // 학년도
					   , '$2' // 학년
					   , '$3' // 교과
					   , '$4' // 과목
					   , '$5' // 1학기 단위수
					   , '$6' // 1학기 성취도 or 등급   
					   , '$7' // 2학기 단위수
					   , '$8' // 2학기 성취도 or 등급
					   )
				.select().selectTar(`$0=${n}`, (r, v) => { if(v.length == 0) r.take(n, ...Array(9).fill('')) }) //데이터가 없으면 추가
				
				//세부능력 및 특기사항 ( 체육예술과목 ) 훈령280호(시스템훈령:765) 이전
				.mandatory()
				.select(`$0=15 && $2=${grd}`)
				.take(++n, '$4')
				
				//자료
				.select()
				.take(++n, '해당 학년의 자료가 없습니다.') //자료(?)
				
				//alert("n :" +n);
			}
			
			//독서활동상황 훈령280호(시스템훈령:765) 이전
			report.mandatory().select('$0=16').take(27, '학년', '과목또는영역', '독서활동상황');
			
			report.trace("독서활동상황=====\n").tar().end();
				
			//행동특성 및 종합의견 훈령280호(시스템훈령:765) 이전
			var atteArr = report.select(`$0=3`).getSelectOrg()// 출결 배열;
			
			var atteArrLength = report.select(`$0=3`).getSelectOrg().length; // 출결 배열길이
			var grdArr = [];
			
			for(var i = 0; i < atteArrLength; i++){ //출결배열 갯수 만큼 행특이 나와야함 예) 출결이 3개 행특이 2개면 빈칸을 채워줘야함
				grdArr[i] = atteArr[i][2];
			}
			
			for(var i = 0; i < atteArrLength; i++){ //출결배열 갯수 만큼 행특이 나와야함 예) 출결이 3개 행특이 2개면 빈칸을 채워줘야함
				var ghvrChrtrYn = report.select(`$0=17 && $2=`+ grdArr[i]).getSelectOrg() == '' ? 'N' : 'Y';
				if(ghvrChrtrYn == 'Y'){
					report.mandatory().select(`$0=17 && $2=`+ grdArr[i]).take(28, '$2', '$3'); //행특 배열의 길이 만큼 출력
				}else if(ghvrChrtrYn == 'N'){
					report.mandatory().select().take(28, grdArr[i], '');
				}
			}
			
			report.trace("행동특성=====\n").tar().end();
			
			//정정대장 훈령280호(시스템훈령:765) 이전
			report.mandatory()
				.select('$0=50')
				.take( 29
					 , '$2' // 정정대장 연월일
					 , '$3' // 학년도 학년 반 번호 졸업대장번호
					 , '$4' // 성명
					 , '$5' // 항목
					 , '$6' // 오류 내용
					 , '$7' // 정정 내용
					 , '$8' // 정정 사유 내용
					 )
					 ;
			
			//편제 및 시간배당 훈령280호(시스템훈령:765) 이전
			report.mandatory()
				.select('$0=60')
				.take( 30
					 , '$1' // 학년도
					 , '$7' // 학년
					 , '$2' // 학기
					 , '$6' // 계열구분명
					 , '$4' // 주야과정 구분명
					 , '$9' // 학과명
					 , '$11' // 편제명
					 , '$13' // 과목명
					 , '$14' // 시수
					 , '$15' //단위수
					 , '$16' //비고
					 );

			// 창의적재량활동
			report.mandatory()
				.select('$0=8')
				.take( 31
					 , '$2' // 학년
					 , '$3' // 활동영역 또는 주제
					 ,  (v) => [v[4], v[5]].join('') // 이수시간
					 , '$6' // 특기사항
					 );
			
			// 특별활동
			report.mandatory()
				.select('$0=9')
				.take( 32
					 , '$2' // 학년
					 , '$3' // 영역
					 , '$4' // 시간
					 , '$5' // 특기사항
					 );
			// 체험활동
			report.mandatory()
				.select('$0=12')
				.take( 33
					 , '$2' // 학년
				     , '$3' // 봉사활동 기간
				     , ''  
				     , '$4' // 장소 또는 주관기관명
				     , '$5' // 활동내용
				     , '$6' // 시간
					 );
	}
	
	//디버그
	report.trace('ret ==============================> \n').tar().end();
	
	var csvdata = report.toOzCSV('#$!', '^&*', '//EOR//')
						.replace(/\n+\^\&\*/gi, '^&*');
	
// 	var csvdata = report.toOzCSV('#$!', '^&*', '//EOR//') //OZ 디자인의 설정과 동일하게
// 						.replace(/\/EOR\/\/EOR\/\^\&\*/gi, '^&*') // /EOR//EOR/^&* 을 ^&*로 변경
// 						.replace(/\/EOR\/\^\&\*/gi, '^&*')        // /EOR/^&* 을 ^&*로 변경
// 						.replace(/\/EOR\/\/EOR\//gi, '\n\n')      // /EOR//EOR/ 을 \n로 변경
// 						.replace(/(?<=[^\/])\/EOR\/(?=[^\/]|$)/gi, '\n'); // /EOR/ 줄바꿈으로 변경 (//EOR//아님)
						
	//var csvdata = report.toOzCSV('#$!', '^&*', '//EOR//') //OZ 디자인의 설정과 동일하게
	//					.replace(/(?<=[^\/])\/EOR\/(?=[^\/]|$)/gi, '\n'); // /EOR/ 줄바꿈으로 변경 (//EOR//아님)	
	
	//trace(" csvdata : " + csvdata);
	
	return csvdata;
}

this.fnReportLoadCallback = function (obj,sReportName)
{
	//trace("====> fnReportLoadCallback - reportName=[" + sReportName + "]");
	this.setWaitCursor(false);
}

/**
 * @description 오즈 뷰 호출
 * @param : aData - 오즈 데이터 배열 ( csv )
 */
this.fnShowOzReport = function(aData){

	//양면출력
	var prtOpt = (this.dsSearch.getColumn(0, 'prtOpt') == '1') ? 'none' : 'duplexvertical';
	
	var objButton = { "toolbar.save"              : "false"    // 저장 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)       
                    , "toolbar.pdf"           	  : "true"    // PDF 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
	                , "toolbar.addmemo"           : "false"    // 메모 추가 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
	                , "toolbar.savedm"            : "false"    // 데이터 모듈 저장 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
					, "viewer.usemenubar"         : "false"
					, "print.duplex"              : prtOpt     //duplexvertical 긴쪽, duplexhorizontal 짧은쪽 
					, "global.concatpage"         : "false"
	                }

	//훈령에따른 reportName 분기

	var reportName = "";

	var reports = aData.reduce((a,v,i) => {
	
		var childNum =  i + 1; 
		objButton["child" + childNum + ".toolbar.save" ]    = false;
		objButton["child" + childNum + ".toolbar.pdf" ]     = true;
		objButton["child" + childNum + ".toolbar.addmemo" ] = false;
		objButton["child" + childNum + ".toolbar.savedm" ]  = false;
		objButton["child" + childNum + ".print.duplex" ]    = prtOpt;
		
		var reportIdx = this.dsReportNm.findRowExpr(this.udsfGetCondition(['prcsSn','rreqNts'], [v.prcsSn, v.rreqNts]));
		
		reportName = this.dsReportNm.getColumn(i, "reportName");
		a.push({
			// 기본데이터
			  displayname	: v.title   // [필수] 멀티리포트시 Tree에 보여줄 이름
			, reportname	: reportName // [필수] 리포트명  "/jsonsample.ozr"
			, jsonParam	: ["viewerType=HTML5 Canvas Viewer 1"]
			, csvData    : v.csv                               // [선택] csv데이터
			, security		: "N"	// [선택] 위변조방지 삽입   ("Y"(default):표시,"N":비표시)
			, voiceBarcode	: "N"	// [선택] 보이스바코드 삽입 ("Y"(default):표시,"N":비표시)		
			, zoom : "100"   // [선택] 보고서 화면의 비율을 백분율로 설정(default:"100")
		});
		return a;
	}, []);
	
	var oOzOption = {
		  'reports' : reports
		, 'zoom' : 100
		, 'reportloadevent' : this.fnReportLoadCallback    // [선택] 레포트 로드된 이후 불려지는 함수(인쇄시에도 발생)
		, button : objButton    // [선택] 버튼의 표시 비표시를 통제
	}
	
	this.smfReportView(this, "embedded", oOzOption, this.divReportViewer);
}

/**
 * @description 평가단위코드 팝업 콜백
 */
this.fnCoaEvlUnitCallback = function(context, responseParams, sender){
	if(context.listCoaEvlUnitId.length == 0 || context.totalCnt == context.listCoaEvlUnitId.length){
		this.dsSearch.setColumn(0, 'coaEvlUnitId', '');
		this.dsSearch.setColumn(0, 'coaEvlUnitNm', '- 전체 -');
	}else{
		this.dsSearch.setColumn(0, 'coaEvlUnitId', context.listCoaEvlUnitId.join(','));
		if(context.listCoaEvlUnitId.length == 1){
			this.dsSearch.setColumn(0, 'coaEvlUnitNm', context.listCoaEvlUnitNm[0]);
		}else{
			this.dsSearch.setColumn(0, 'coaEvlUnitNm', context.listCoaEvlUnitNm[0] + '외 ' + (context.listCoaEvlUnitId.length - 1) + '건');
		}
	}
}

/**
* @description coaWrkPrcsCd 에 따른 읽기할 파일을 this.fvQueFiles에 담는다.
*/
this.fnTakeFileInfo = function(i){
	var ds = this.dsMain;

	var coaSeleFileNm = ds.getColumn(i, "coaSeleFileNm");
	var coaImageFileNm = ds.getColumn(i, "coaImageFileNm");
	var shlNm = ds.getColumn(i, "shlNm");
	
	var coaSeleFilePath = this.fvCoaDataPath + "\\" + coaSeleFileNm;
	this.fvQueFiles.enqueue({
		'idx' : i,
		'nm' : coaSeleFilePath,
		'cn' : '',
		'type' : 'T', //text
		'attr' : 'F', //file
		'shlNm' : shlNm
	});
	
	if(!this.fnIsBld()){
		var coaImagePath = this.fvCoaDataPath + "\\" + coaImageFileNm;
		this.fvQueFiles.enqueue({
			'idx' : i,
			'nm' : coaImagePath,
			'cn' : '',
			'type' : 'B', //binary
			'attr' : 'I', //image
			'shlNm' : shlNm
		});
	}
}

/**
* @description VirtualFile 열기
*/
this.fnVirtualFileOpen = function(fileInfo){
	this.VirtualFile00.open(fileInfo['nm'], fileInfo['type'] == 'T' ? VirtualFile.openText | VirtualFile.openRead : VirtualFile.openBinary | VirtualFile.openRead);
}

/**
* @description VirtualFile 콜백
*/
this.fnVirtualFileCallback = function(){
	var f = this.fvQueFiles.dequeue();
	var firstRawData = this.fvQueRawData.first(-1);
	
	if(this.smfIsNull(firstRawData) || firstRawData.idx != f.idx){
		coaData = { idx : f.idx, shlNm : f.shlNm };
		if(f.attr == 'F'){
			coaData.sele = { cn : f.cn };
		}else if(f.attr == 'I'){
			coaData.image = { cn : f.cn};
		}
		this.fvQueRawData.enqueue(coaData);
	}else{
		if(f.attr == 'F'){
			firstRawData.sele = { cn : f.cn };
		}else if(f.attr == 'I'){
			firstRawData.image = { cn : f.cn};
		}
	}
	
	//비지니스 로직
	if(this.fvQueFiles.isEmpty()){
		this.fnDoNext();
	}else{
		this.fnVirtualFileOpen(this.fvQueFiles.first());
	}
}

/**
* @description 큐 버퍼 클리어
*/
this.fnClearQueue = function(){
	this.fvQueFiles.clear();
	this.fvQueRawData.clear();
	this.fvQueIdx.clear();
}


/**
* @description 다음작업 실행
*/
this.fnDoNext = function(){
	if(this.fvQueIdx.isEmpty()){
		if(!this.fvQueRawData.isEmpty()){
			this.fnDoOzReport();
			this.setWaitCursor(false);
		}
	}else{
		this.fnTakeFileInfo(this.fvQueIdx.dequeue());
		this.fnVirtualFileOpen(this.fvQueFiles.first());
	}
}

/**
 * @description 그리드 순번 함수
 */
this.fnRowIndex = function(currow){

	var pageIndex = this.dsPageInfo.getColumn(0, 'pageIndex');
	var pageSize  = this.dsPageInfo.getColumn(0, 'pageSize'); 

	return currow + 1 + ((pageIndex - 1) * pageSize );
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

/**
 * @description 그리드 헤더 클릭
*/
this.grdMain_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var columnName = obj.getCellProperty("body",e.cell,"text");
	if ("bind:_chk" == columnName){
		this.smfToggleChkHeader(obj, e, this.fnRenderGridCheckbox);
	}else{
		// 정렬
		this.smfCheckAndSort(obj, e);
	}
};

/**
 * @description 조회
 */
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//this.dsMain.clearData();
	//this.dsPageInfo.setColumn(0, 'pageIndex', 1);
	this.fnSearch(obj, e);
};

/**
 * @description 평가단위 선택
 */
this.divSearch_btnEvlUnit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var coaEvlUnitId = this.dsSearch.getColumn(0, 'coaEvlUnitId');
	var listCoaEvlUnitId = this.smfIsNull(coaEvlUnitId) ? [] : this.dsSearch.getColumn(0, 'coaEvlUnitId').split(',');
	
	// 팝업 파라메터
	var popupParams = {
		callback: this.fnCoaEvlUnitCallback, // 콜백함수 지정
		sender: obj, // sender 지정
		params: {
			procType : "save", // 처리타입 지정
			listCoaEvlUnitId : listCoaEvlUnitId
		},
	};

	// 모달팝업 실행
	this.smfDialog("uds_ueudd00_p09", "pa_uds_ueu_dd::uds_ueudd00_p10.xfdl", popupParams);
};

/**
 * @description 출력
 */
this.btnReportView_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.fvQueIdx.isEmpty()){
		const chkList = this.dsMain.extractRows("_chk == 1");
		if(this.isNil(chkList) || this.dsMain.getRowCount() == 0){
			this.smfAlert("선택된 학생이 없습니다. 학생을 선택하여 주십시오.", function(){
			});
			return false;
		}
		
		this.fnClearQueue();
		this.setWaitCursor(true);
		
		this.fvQueIdx.enqueue(chkList);
		
		this.fnDoNext();
	}
}

/**
 * @description 그리드 클릭하여 전형자료출력
 */
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if(e.cell > 0 && e.cell != 8){
		this.fnClearQueue();
		this.setWaitCursor(true);
		this.fvQueIdx.enqueue(e.row);
		this.fnDoNext();
	}
};

/**
 * @description 블라인드, 블라인드해제에 따른 조회조건 비활성화 처리
 */
this.dsSearch_onvaluechanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	if(e.columnid == 'bldRmvYn'){
		var isbldRmvYn = e.newvalue == 'Y';
		if(!isbldRmvYn){
			this.divSearch.form.edtShlnm.set_value();
			this.divSearch.form.cboApstScCd.set_value();
			this.divSearch.form.edtStuFlnm.set_value();
			this.divSearch.form.mskStuRrno.set_value();
			this.divSearch.form.edtUvstExmtNo.set_value();
		}
		
		this.divSearch.form.edtShlnm.set_enable(isbldRmvYn);
		this.divSearch.form.cboApstScCd.set_enable(isbldRmvYn);
		this.divSearch.form.edtStuFlnm.set_enable(isbldRmvYn);
		this.divSearch.form.mskStuRrno.set_enable(isbldRmvYn);
		this.divSearch.form.edtUvstExmtNo.set_enable(isbldRmvYn);
	}
};

/**
 * @description 대입전형파일 읽기
 */
this.VirtualFile00_onsuccess = function(obj:nexacro.VirtualFile,e:nexacro.VirtualFileEventInfo)
{
	if(e.reason == 1){ //open complete
		obj.read();
	}else if(e.reason == 2){ //close complete
		this.fnVirtualFileCallback();
	}else if(e.reason == 3){ //read complete
		var f = this.fvQueFiles.first();
		if(f.type == 'T'){
			f.cn = e.textdata;
		}else if(f.type == 'B'){
			f.cn = e.binarydata;
		}
		
		obj.close();
	}
};

this.VirtualFile00_onerror = function(obj:nexacro.VirtualFile,e:nexacro.VirtualFileErrorEventInfo)
{
	this.setWaitCursor(false);
	if(e.statuscode == '1105'){
		var oFile = this.fvQueFiles.first();
		
		//row idx 이동 ( UI )
		if(!this.grdMain.setCellPos(1, oFile.idx)) this.grdMain.setCellPos(2, oFile.idx);
		this.grdMain.redrawExprCell();
		
		this.dsMain.setColumn(oFile.idx, '_chk', '');
	
		this.smfAlert("식별번호 '" +  this.dsMain.getColumn(oFile.idx, 'stuIdfNo') +"'의 전형자료 파일이 존재하지 않습니다.");
	}
	
	this.fnClearQueue();
	
	trace('file error(' + e.errortype + ') : ' + e.errormsg + ' (' + obj.fullpath + ')');
};

/**
 * @description 블라인드해제여부에 따른 출력데이터 위치 설정
 */
this.dsSearch_cancolumnchange = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	if(e.columnid == 'bldRmvYn'){
		this.fvCoaDataPath = e.newvalue == 'Y' ? this.fvCoaDataDecrPath : this.fvCoaDataBlindPath;
	}
};

/*
* @description 전형자료경로설정
*/
this.btnCoaDataPath_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 팝업 파라메터
	var popupParams = {
		callback: function(){
			this.fvCoaDataBlindPath = this.udsfGetCoaDataBlindPath(); // 블라인드자료경로
			this.fvCoaDataDecrPath = this.udsfGetCoaDataDecrPath();   // 블라인드해제자료경로
			this.fvCoaDataPath = this.dsSearch.getColumn(0, 'bldRmvYn') == 'Y' ? this.fvCoaDataDecrPath : this.fvCoaDataBlindPath;
		}, // 콜백함수 지정
		sender: obj, // sender 지정
		params: {
			procType: "save" // 처리타입 지정
		},
	};

	// 모달팝업 실행
	this.smfDialog("uds_ueudd00_p09", "pa_uds_ueu_dd::uds_ueudd00_p09.xfdl", popupParams);
};

/*
* @description 블라인드자료 라디오 버튼 변경시 초기화
*/
this.divSearch_rdoSeleDataScCd_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	this.dsMain.clearData();
	this.divPageSummary.form.fnInitValues();
};]]></Script>
