				, applyYn728                //훈령728호적용여부
				, applyYn205                //훈령205호적용여부
				, applyYn239                //훈령239호적용여부
				, applyYn29A                //훈령29-1호적용여부
				, applyYn29B                //훈령29-2호적용여부
				, applyYn169                //훈령169호적용여부 (Y => 국가직무)
				, applyYn195                //훈령195호적용여부
				, applyYn243                //훈령243호적용여부
				, applyYn280                //훈령280호적용여부
				, applyYn321                //훈령321호적용여부
				, applyYn365                //훈령365호적용여부
				, applyYn393                //훈령393호적용여부
				, applyYn433                //훈령433호적용여부
				, applyYn477                //훈령477호적용여부
				, applyYn504                //훈령504호적용여부
				, '$3'                      //식별번호
