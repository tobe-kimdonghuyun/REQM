				return "Y"; // 2019년도 고1,2학년
			} else if (parseInt(ayr) >= 2020) {
				return "Y"; // 2020년도 부터는 모두
			} else {
				return "N";
			}
		} else if ("280" == dgr) // Add By 박종명(2019.4.24) 훈령 280호 체크 추가
		{
			if ("201931" == ayrShlCrseScGrd) {
				return "Y"; // 2019년도 고1학년
			} else if ("202031" == ayrShlCrseScGrd || "202032" == ayrShlCrseScGrd) {
				return "Y"; // 2020년도 고1,2학년
			} else if (parseInt(ayr) >= 2021) {
				return "Y"; // 2021년도 부터는 모두
			} else {
				return "N";
			}
		}else if ("321" == dgr)
		{
			if ("202031" == ayrShlCrseScGrd) {
				return "Y"; // 2020년도 고1학년
			} else if ("202131" == ayrShlCrseScGrd || "202132" == ayrShlCrseScGrd) {
				return "Y"; // 2021년도 고1,2학년
			} else if (parseInt(ayr) >= 2022) {
				return "Y"; // 2022년도 부터는 모두
			} else {
				return "N";
			}
		}else if ("365" == dgr)
		{
			if ("202131" == ayrShlCrseScGrd) {
				return "Y"; // 2021년도 고1학년
			} else if ("202231" == ayrShlCrseScGrd || "202232" == ayrShlCrseScGrd) {
				return "Y"; // 2022년도 고1,2학년
			} else if (parseInt(ayr) >= 2023) {
				return "Y"; // 2023년도 부터는 모두
			} else {
				return "N";
			}
		}else if ("393" == dgr)
		{
			if ("202231" == ayrShlCrseScGrd) {
				return "Y"; // 2022년도 고1학년
			} else if ("202331" == ayrShlCrseScGrd || "202332" == ayrShlCrseScGrd) {
				return "Y"; // 2023년도 고1,2학년
			} else if (parseInt(ayr) >= 2024) {
				return "Y"; // 2024년도 부터는 모두
			} else {
				return "N";
			}
		}else if ("433" == dgr)
		{
			if ("202331" == ayrShlCrseScGrd) {
				return "Y"; // 2023년도 고1학년
			} else if ("202431" == ayrShlCrseScGrd || "202432" == ayrShlCrseScGrd) {
				return "Y"; // 2024년도 고1,2학년
			} else if (parseInt(ayr) >= 2025) {
				return "Y"; // 2025년도 부터는 모두
			} else {
				return "N";
			}
		}else if ("477" == dgr)
		{
			if ("202431" == ayrShlCrseScGrd) {
				return "Y"; // 2024년도 고1학년
			} else if ("202531" == ayrShlCrseScGrd || "202532" == ayrShlCrseScGrd) {
				return "Y"; // 2025년도 고1,2학년
			} else if (parseInt(ayr) >= 2026) {
				return "Y"; // 2026년도 부터는 모두
			} else {
				return "N";
			}
		}else if ("504" == dgr)
		{
			if ("202531" == ayrShlCrseScGrd) {
				return "Y"; // 2025년도 고1학년
			} else if ("202631" == ayrShlCrseScGrd || "202632" == ayrShlCrseScGrd) {
				return "Y"; // 2026년도 고1,2학년
			} else if (parseInt(ayr) >= 2027) {
				return "Y"; // 2027년도 부터는 모두
			} else {
				return "N";
			}
		}  else {
			return "해당차수없음";
		}
}

