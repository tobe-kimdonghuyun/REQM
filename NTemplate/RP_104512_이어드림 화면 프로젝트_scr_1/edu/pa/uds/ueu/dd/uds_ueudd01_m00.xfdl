								 , 'N'
								 )
							.take( 7
								 , '$2' // 학년 l1
								 , '동아리활동' //l2
								 , '$5' // 동아리활동 이수시간 l3
								 , '$6' // 동아리활동 특기사항 l4
								 , 'N'
								 )
							.take( 7
								 , '$2' // 학년 l1
								 , '동아리활동' //l2
								 , '$5' // 동아리활동 이수시간 l3
								 , '$7' // 통합자율동아리활동 특기사항 l4
								 , 'Y' // 통합자율동아리활동 특기사항 여부
