              <Static id="Static65" taborder="11" text="~" left="calRcptnPrd1:0" top="51" width="15" height="30" cssclass="sta_WF_AC" initvalueid="ivStcAccessibilityOn" accessibilitylabel="부터"/>
              <Calendar id="calRcptnPrd2" taborder="12" left="Static65:0" top="51" width="120" height="30" value="20190308" dateformat="yyyy.MM.dd." readonly="false" editformat="yyyy.MM.dd." accessibilitylabel="수시기간종료" initvalueid="ivCalEssential"/>
              <Static id="staCoaApstStsCd" taborder="13" text="진행상황" left="calRcptnPrd2:0" top="51" width="96" cssclass="sta_WF_Searchtxt01" height="30" initvalueid="ivStcAccessibilityOn"/>
              <Combo id="cboCoaApstStsCd" taborder="14" left="staCoaApstStsCd:0" width="136" height="30" codecolumn="unyCdValue" index="0" text="전체" readonly="false" top="51" innerdataset="dsCoaApstStsCd" datacolumn="unyCdValueNm" initvalueid="ivCmbNormal" accessibilitylabel="시도"/>
              <Button id="btnSearch" height="30" taborder="15" text="조회" tooltiptext="조회" onclick="divSearch_btnSearch_onclick" cssclass="btn_WF_Search03" right="20" width="74" bottom="11"/>
