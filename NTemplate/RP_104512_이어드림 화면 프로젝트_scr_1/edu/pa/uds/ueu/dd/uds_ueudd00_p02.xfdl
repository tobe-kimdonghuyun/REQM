              <Static id="staCoaEvlUnitNm" taborder="0" text="평가단위" left="0" top="11" width="96" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtCoaEvlUnitNm" taborder="1" left="staCoaEvlUnitNm:0" top="11" width="202" height="30" initvalueid="ivEdtReadOnly" readonly="true"/>
              <Button id="btnEvlUnit" taborder="2" text="선택" left="edtCoaEvlUnitNm:5" top="11" width="52" height="30" cssclass="btn_WF_Custom" initvalueid="ivBtnAccessibilityLink" onclick="divSearch_btnEvlUnit_onclick"/>
              <Static id="staCddcScCd" taborder="3" text="시도" left="btnEvlUnit:0" top="11" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" width="80"/>
              <Combo id="cboCddcScCd" taborder="4" left="staCddcScCd:0" width="150" height="30" codecolumn="unyCdValue" index="0" text="전체" readonly="false" top="11" innerdataset="dsCddcScCd" datacolumn="unyCdValueNm" initvalueid="ivCmbNormal" accessibilitylabel="시도"/>
              <Static id="staShlNm" taborder="5" text="학교명" left="cboCddcScCd:0" top="11" width="83" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
