    <Script type="xscript5.1"><![CDATA[/**
 *	지원학생조회
 *	@MenuPath	대입전형-지원학생조회
 *	@FileName 	ues_ueudd00_p02.xfdl
 *	@Creator 	김동업
 *	@CreateDate	2023.03.14  
 *	@Desction	
 ************** 소스 수정 이력 ***********************************************
 *	date			Modifier			Description
 *******************************************************************************
 *	2023.03.14		김동업				최초 생성
 *******************************************************************************
 */

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::uds_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvIsDelNreqData = false; //미요청학생 삭제 여부

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Div 초기화
	this.smfInitDiv(obj);
	
	// 초기화
	this.fnInit(obj);
	
	// 공통코드 조회
	this.smfCodeList("code", [this.dsCddcScCd, this.dsCoaApstStsCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			var nRow = this.dsCoaApstStsCd.findRow('unyCdValue', '50');
			if(nRow > -1) this.dsCoaApstStsCd.setColumn(nRow, 'unyCdValueNm', '요청및생성완료');
		})
		.run();
	
	//this.fnSearch(); // 조회
	 
	// 조회 입력창에서 'Ctrl' + 'Enter' 키 입력시 조회수행 이벤트 설정
	this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 미요청자료 삭제
 */
this.fnDeleteNreqData = function(){
	this.smfDeleteService('deleteNreqData')
	    .messagePrefix(["미요청자료를 삭제"])
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.fvIsDelNreqData = true;
			this.smfAlert("PA020", [],  function(){	// 삭제가 완료되었습니다.
				this.dsMain.clearData();
				this.dsPageInfo.setColumn(0, 'pageIndex', 1);
				this.fnSearch();
			});
		})
}

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 초기화 FUNCTION
 */
this.fnInit = function(obj){
	this.dsSearch.setColumn(0, "coaAyr", this.udsv_coaAyr);
	this.dsSearch.setColumn(0, "coaRcritScCd", this.udsv_coaRcritScCd);
	this.dsSearch.setColumn(0, "coaRcritScNm", this.udsv_coaRcritScNm);
	// 대입자료처리코드
	this.dsSearch.setColumn(0, "coaDataPrcsCd", "SPRT_STU_INQ");
	
	this.dsSearch.setColumn(0, "coaEvlUnitId", "");
	this.dsSearch.setColumn(0, "coaEvlUnitNm", "- 전체 -");
	
	this.dsSearch.setColumn(0, 'bgngYmd', this.smfToday());
	this.dsSearch.setColumn(0, 'endYmd', this.smfToday());
}

/**
 * @description 주민번호
 */
this.fnGetRrno = function(psValue){
	return psValue.substr(0, 6) + "-" + psValue.substr(6, 1) + "******";
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

/**
 * @description 조회
 */
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsMain.clearData();
	this.dsPageInfo.setColumn(0, 'pageIndex', 1);
	
	this.fnSearch();
};

this.fnSearch = function(obj, e)
{
 	// 조회 서비스
	this.smfSearchService("listCoaSprtStu")
		.paginator(this.grdMain, this.divPaginator, this.divPageSummary, this.dsPageInfo, this.fnSearch, e) // 페이징처리
		.confirmIfModifiedGrid(this.grdMain) // 데이터가 변경되었으면 확인메시지
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			if(this.dsMain.getRowCount() > 0){
				this.btnExcel.set_enable(true);
			}else{
				this.btnExcel.set_enable(false);
			}
		}); // 콜백
};


/**
 * @description 엑셀다운로드
 */
this.btnExcel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSearchService("listCoaSprtStuExcel")
		.validateForm(this.divSearch)
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			var grdMainExcel = this.grdMainExcel;
			var objOption = {	objGrid : grdMainExcel
							,	sheetname : "Sheet1"
							,   filename : "지원학생조회"
							};
	
			this.smfExcelExport(objOption);
		}) // 콜백
	;
};

this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};

/**
 * @description 평가단위 선택
 */
this.divSearch_btnEvlUnit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var coaEvlUnitId = this.dsSearch.getColumn(0, 'coaEvlUnitId');
	var listCoaEvlUnitId = this.smfIsNull(coaEvlUnitId) ? [] : this.dsSearch.getColumn(0, 'coaEvlUnitId').split(',');
	
	// 팝업 파라메터
	var popupParams = {
		callback: this.fnCoaEvlUnitCallback, // 콜백함수 지정
		sender: obj, // sender 지정
		params: {
			procType : "save", // 처리타입 지정
			listCoaEvlUnitId : listCoaEvlUnitId
		},
	};

	// 모달팝업 실행
	this.smfDialog("uds_ueudd00_p09", "pa_uds_ueu_dd::uds_ueudd00_p10.xfdl", popupParams);
};

/**
 * @description 평가단위코드 팝업 콜백
 */
this.fnCoaEvlUnitCallback = function(context, responseParams, sender){
	if(context.listCoaEvlUnitId.length == 0 || context.totalCnt == context.listCoaEvlUnitId.length){
		this.dsSearch.setColumn(0, 'coaEvlUnitId', '');
		this.dsSearch.setColumn(0, 'coaEvlUnitNm', '- 전체 -');
	}else{
		this.dsSearch.setColumn(0, 'coaEvlUnitId', context.listCoaEvlUnitId.join(','));
		if(context.listCoaEvlUnitId.length == 1){
			this.dsSearch.setColumn(0, 'coaEvlUnitNm', context.listCoaEvlUnitNm[0]);
		}else{
			this.dsSearch.setColumn(0, 'coaEvlUnitNm', context.listCoaEvlUnitNm[0] + '외 ' + (context.listCoaEvlUnitId.length - 1) + '건');
		}
	}
}

this.divSearch_mskStuRrno_onchanged = function(obj:nexacro.MaskEdit,e:nexacro.ChangeEventInfo)
{
	trace(" obj.value : " + obj.value);
};

/**
 * @description 미요청자료삭제
 */
this.btnDelNreqData_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnDeleteNreqData();
};

this.ues_ueudd00_p02_onbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	this.smfSendResponseToOpener({"isDelNreqData": this.fvIsDelNreqData});
};
]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listCoaSprtStu</Col>
            <Col id="url">/uds_ueu_dd00_021.do</Col>
            <Col id="inDatasets">dsSearch dsPageInfo</Col>
            <Col id="outDatasets">dsMain=dsCoaSprtStu dsPageInfo</Col>
          </Row>
