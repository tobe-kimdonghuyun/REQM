              <Static id="sta00_00_01_01" taborder="1" left="30" top="71" height="23" cssclass="sta_WF_InfoTxt" text="지원학생등록 엑셀파일 작성시 다음과 같은 형식으로 작성하셔야 합니다." wordWrap="char" right="400" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00_01_01_01" taborder="2" left="35" top="95" height="23" cssclass="sta_WF_Black14" text="※ 작성형식)" wordWrap="char" initvalueid="ivStcAccessibilityOn" width="94"/>
              <Static id="sta00_00_01_01_01_00" taborder="3" left="111" top="95" height="23" cssclass="sta_WF_Red14" text="고등학교코드, 주민등록번호, 수험번호, 모집시기, 평가단위코드" wordWrap="char" initvalueid="ivStcAccessibilityOn" width="670"/>
              <Static id="sta00_00_01_01_01_01" taborder="4" left="55" top="119" height="67" cssclass="sta_WF_Black14" text="- 엑셀파일 확장자는 .xlsx 또는 .xls 입니다.&#13;&#10;- 파일내에 빈행은 제거하여 주십시오.&#13;&#10;- 수험번호는 반드시 각 학생별로 유일해야 합니다.(중복체크 실시)" wordWrap="char" initvalueid="ivStcAccessibilityOn" width="699"/>
              <Static id="sta00_00_01_01_03" taborder="5" left="35" top="211" height="23" cssclass="sta_WF_Blue14" text="※ 엑셀자료의 유효성 검증 : &lt;fc v='#172f57'&gt;엑셀자료 필수, 최대값, 데이터형식, 특수문자사용 검증, 엑셀자료 중 주민등록번호중복 및 수험번호중복 검증&lt;/fc&gt;" wordWrap="char" width="1140" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00_01_01_01_02" taborder="6" left="35" height="23" cssclass="sta_WF_Blue14" text="※ 지원학생 검증 : &lt;fc v='#172f57'&gt;지원학생 주민등록번호중복, 수험번호중복, 모집시기오류, 미존재학교, 평가단위코드불일치 검증&lt;/fc&gt;" wordWrap="char" width="1140" usedecorate="true" initvalueid="ivStcAccessibilityOn" top="235"/>
              <Static id="sta00_00_01_01_01_00_00" taborder="7" left="30" top="sta00_00_01_01_01_01:1" cssclass="sta_WF_InfoTxt" text="엑셀자료의 유효성 검증 및 지원학생 검증 중 오류가 있는 경우, 확인 후 다시 지원학생등록 바랍니다." wordWrap="char" width="1140" usedecorate="true" initvalueid="ivStcAccessibilityOn" height="23"/>
