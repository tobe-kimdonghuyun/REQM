    <Script type="xscript5.1"><![CDATA[/**
 *	지원학생등록
 *	@MenuPath	대입전형-대입전형자료온라인제공-지원학생등록
 *	@FileName 	uds_ueudd00_m02.xfdl
 *	@Creator 	김동업
 *	@CreateDate	2022.08.22  
 *	@Desction	
 ************** 소스 수정 이력 ***********************************************
 *	date			Modifier			Description
 *******************************************************************************
 *	2022.08.22		김동업				최초 생성
 *  2022.12.26      김정민             개발
 *******************************************************************************
 */

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::uds_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvColTitle = {}; //컬럼타이틀

this.fvLastWrkIdx = -1; 						//마지막 업무처리 학교(dsDetail) 인덱스
this.fvTimerId = 1000;							//파일 처리 타이머 아이디
this.fvTimerElapse = 1;							//파일 처리 타이머 대기 시간
this.fvWorker = null;						    //파일 처리 워커
this.fvQueFile = null;							//파일 처리 큐

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Div 초기화
	this.smfInitDiv(obj);
	
	// 대입서비스체크
	this.udsfCoaSvcChck(function(){
		// 초기화
		this.fnInit(obj);
		
		// 조회 입력창에서 'Ctrl' + 'Enter' 키 입력시 조회수행 이벤트 설정
		this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
		
		// 데이터 입력 창에서 'Ctrl' + 'Enter' 키 입력시 저장수행 이벤트 설정
		this.smfBindEnterKeyToSearch(this.divMain, this.btnPrcs);
	});
};

/**
 * @description 폼 닫기전 이벤트
 */
this.fnOnbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	// 변경내역이 발생한 경우 종료전 confirm수행
	//return this.smfCloseFormConfirm([this.dsMain]);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1){
		this.fnExecuteEnable(true)
		return;
	}
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/**
 * @description 조회
*/
this.fnSearch = function()
{
	// 초기화
	this.fnInit(obj);
};

/**
 * @description 다음(MAX) 파일차수 조회
*/
this.fnSearchFileDgr = function(callback){
	// 조회 서비스
	this.smfSearchService("listFileDgr")
		//.confirmIfModifiedGrid(this.grdDetail) // 데이터가 변경되었으면 확인메시지
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			if(this.dsFileDgr.getRowCount() == 1){
				this.dsSearch.setColumn(0, 'fileDgr', this.dsFileDgr.getColumn(0, 'nextFileDgr'));
				if(this.smfIsFunc(callback)) callback.call(this);
			}
		}); // 콜백
}

/**
 * @description 엑셀파일 검증
*/
this.fnExecuteSprtStuRegVrfcFile = function(){
	// 저장 서비스
	this.smfExecuteService("executeSprtStuRegVrfcFile")
		.command(function(next) { 
 			this.setWaitCursor(false);
 			next();
 		})
		.messagePrefix(obj.text)
		.showConfirm(false)
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.setWaitCursor(true);
			this.dsSearch.setColumn(0, 'bgngYn', 'N');
			this.fnCopyDs00();
			this.fnDoNextVrfcFile();
		}); // 콜백
}

/**
 * @description 엑셀파일 등록 ( 53을 55 )
*/
this.fnSaveSprtStuReg = function(callback){
	// 서비스 객체 생성 
	this.smfSaveService("saveSprtStuReg")
		.command(function(next) { 
			this.setWaitCursor(false);
			next();
		})
		.showConfirm(false)
		.messagePrefix(["지원학생등록"])
		.run() // 실행
		.callback(function(callbackParams){ // 콜백
			if(callbackParams.reason == -1) return; 
			this.setWaitCursor(true);
			if(this.smfIsFunc(callback)) callback.call(this);
		});
}

/**
 * @description 세션 유지 시간 연장 ( 동기 )
*/
this.fnExecuteAlive = function(callback){
	this.smfExecuteService("executeAlive")
		.command(function(next) { 
 			this.setWaitCursor(false);
 			next();
 		})
		.messagePrefix(obj.text)
		.showConfirm(false)
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return; //동기 호출이라서 콜백 안됨
		}); // 콜백
	this.setWaitCursor(true);
}

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/**
 * @description 초기화 FUNCTION
 */
this.fnInit = function(obj){
	this.dsSearch.setColumn(0, "coaAyr", this.udsv_coaAyr);
	this.dsSearch.setColumn(0, "coaRcritScCd", this.udsv_coaRcritScCd);
	this.dsSearch.setColumn(0, "coaRcritScNm", this.udsv_coaRcritScNm);
	
	//컬럼 타이틀
	this.fvColTitle = this.udsfGetColTitle(this.grdMain, this.dsExcelValid);
	//Object.keys(this.fvColTitle).forEach((key) => trace(key + ' : ' + this.fvColTitle[key]));
	
	this.fvQueFile = this.udsfCreateQueue();
	this.fvLastWrkIdx = -1;
	
	this.smfClearSort(this.grdMain);
	
	this.dsMain.clearData();
	
	//필터초기화
	this.fnInitFilter();
}

/**
 * 그리드 체크박스 enable 처리
 * @param : ds - 데이터셋
 * @param : nRow - rowposition
 */
this.fnRenderGridCheckbox = function(ds, nRow){
	return true;
};

/**
 * @description d00을 ds으로 복사
 */
this.fnCopyDs00 = function(){
	var dsFrom = this.dsMain00;
	var dsTo = this.dsMain;
	for(var i = 0; i <  dsFrom.getRowCount(); i++){
		//var con = this.udsfGetCondition('regSn', dsFrom.getColumn(i, 'regSn'));
		//var nRow = dsTo.findRowExpr(con);
		var nRow = parseInt(dsFrom.getColumn(i, 'regSn')) - 1
		if(nRow != Number.NaN && nRow > -1){
			dsTo.copyRow(nRow,  dsFrom, i);
		}
	}
	dsTo.applyChange();
}

//숫자인지확인
this.fnValidateNum = function(grid, rowIndex, columnIndex, datasetOfGrid){
	var rtn = true;

	var bindCol = datasetOfGrid.getColID(columnIndex);
	var labelText = this.fvColTitle[bindCol];
	var str = this.smfStr(datasetOfGrid.getColumn(rowIndex, columnIndex));
	
	var objRegExp = /[^0-9]/gi;
	var rtnExp = objRegExp.exec(str)
	if(Array.isArray(rtnExp)){
		rtn = labelText + '에 숫자만 입력가능합니다.';
	}
	
	return rtn;
}

//특수문자 확인
this.fnValidateSpyChr = function(grid, rowIndex, columnIndex, datasetOfGrid){
	var rtn = true;
	
	var bindCol = datasetOfGrid.getColID(columnIndex);
	var labelText = this.fvColTitle[bindCol];
	var str = this.smfStr(datasetOfGrid.getColumn(rowIndex, columnIndex));
	var objRegExp = /[\{\}\/\\\'\"<>#&:;*?|^_]/gi;
	
	// 특수문자 체크
	var rtnExp = objRegExp.exec(str);
	if(Array.isArray(rtnExp)){
		rtn = labelText + '에 문자[' + rtnExp[0] + ']이 존재합니다.';
	}
	
	return rtn;
}

//3byte 코드 체크
this.fnValidateCdChr = function(grid, rowIndex, columnIndex, datasetOfGrid){
	var rtn = true;
	
	var bindCol = datasetOfGrid.getColID(columnIndex);
	var labelText = this.fvColTitle[bindCol];
	var str = this.smfStr(datasetOfGrid.getColumn(rowIndex, columnIndex));
	if(!this.smfIsNull(str)){
		str.split('').forEach(function(chr){
			if(chr.charCodeAt(0) > 127){
				rtn = labelText + '에 문자[' + chr + ']이 존재합니다.';
				return false;
			}
		});
	}
	
	return rtn;
}

//필터 초기화
this.fnInitFilter = function(){
	this.dsMain.set_filterstr('');
	this.dsExcelUpload.set_filterstr('');
	// this.divExcelVrfc.form.rdoVrfcSc.set_value(0);
}

/**
 * @description 주민번호
 */
this.fnGetRrno = function(psValue){
	return psValue.substr(0, 6) + "-" + psValue.substr(6, 1) + "******";
}

/**
 * 실행활성화
 * @param : bEnable 
 * @param : prcsType
 */
this.fnExecuteEnable = function(bEnable){
	this.setWaitCursor(!bEnable);
	
	this.divSearch.form.btnInit.set_enable(bEnable);
	this.btnPrcs.set_enable(bEnable);
	this.btnFormDown.set_enable(bEnable);
	this.btnSprtStuMng.set_enable(bEnable);
}

/**
 * @description 하이라이트 토글
 */
this.fnToggleHighlight = function(idx){
	var ds = this.dsMain;
	var grd = this.grdMain;

	//하이라이트 제거
	if(this.fvLastWrkIdx > -1){
		ds.setColumn(this.fvLastWrkIdx, 'highlight', '');
		ds.setColumn(this.fvLastWrkIdx, '_chk', '');
	}
	
	if(idx > -1){
		//하이라이트
		ds.setColumn(idx, 'highlight', '1');
		
		//row idx 이동 ( UI )
		grd.setCellPos(1, idx);
		grd.redrawExprCell();
	}
	
	if(this.fvLastWrkIdx > -1 || idx > -1){
		ds.applyChange();
	}
	
	this.fvLastWrkIdx = idx;
}

/**
 * @description 그리드 cssclass
 */
this.fnGrdCssclass = function(highlight, val){
	var cssclass = [];
	
	if(!this.smfIsNull(val)){
		cssclass.push(val.indexOf('오류') > -1 ? 'cell_WF_Red' : (val.indexOf('정상') > -1 ? 'cell_WF_Blue' : ''));
	}
	
	if(highlight == '1'){
		cssclass.push('cell_WF_BgColorYelw');
	}
	
	return cssclass.join(' ');
}

/**
 * @description 그리드의 상태컬컬(6)이 오류 이면 상위로 올수 있도록 정렬
 */
this.fnSortErrToTop = function(dir){
	this.smfClearSort(this.grdMain);
	
	//대기, 오류 일때 클리어후 정렬 ( asc )
	//오류, 정상 일때 asc로 변경후 정렬 ( desc )	
	if(dir == 0){
		//요류, 정상
		var strHeadText = this.grdMain.getCellProperty("head", 6,"text") + this.smvAscMark;
		this.grdMain.setCellProperty("head", 6, "text", strHeadText);
	}
	
	this.smfProcGrdSort(this.grdMain, 6);
}

/**
 * @description 재요청 파일단위 실행
 */
this.fnRunSprtStuRegVrfcFile = function(){
	this.fvQueFile.clear();
	this.fvQueFile.init(this.dsMain.getRowCount());
	
	this.dsExcelUploadParts.clearData();
	
	this.dsSearch.setColumn(0, 'bgngYn', 'Y');
	
	this.fnDoNextVrfcFile();
}

/**
 * @description 재요청 파일단위 다음 실행
 */
this.fnDoNextVrfcFile = function(){
	if(this.fvQueFile.isEmpty()){
		this.fnSaveSprtStuReg(function(){
			this.fnShowResult();
		});
	}else{
		this.dsExcelUploadParts.clearData();
		
		var prcsUnit = this.dsPageInfo.getColumn(0, 'pageSize');
		for(var i = 0; i < prcsUnit; i++){
			if(this.fvQueFile.isEmpty()) break;
			var nRow = this.fvQueFile.dequeue();
			
			//오류가 아닌 학생만 서버에서 검증
			if(this.dsMain.getColumn(nRow, 'stsNm') != '오류'){
				var nRowTrgt = this.dsExcelUploadParts.addRow();
				this.dsExcelUploadParts.copyRow(nRowTrgt,  this.dsMain, nRow);
			}
		
			//하이라이트
			if(i == 0) this.fnToggleHighlight(nRow);
		}
		
		if(this.dsExcelUploadParts.getRowCount() > 0){
			this.fnExecuteSprtStuRegVrfcFile();
		}else{
			var bgngYn = this.dsSearch.getColumn(0, 'bgngYn');
			if(bgngYn == 'Y'){ //bgngYn == 0 && this.dsExcelUploadParts.getRowCount() == 0 이면 등록할 학생이 없다.
				this.fnShowResult();
			}else{
				this.fnDoNextVrfcFile();
			}
		}
	}
}

/**
 * @description 재요청 파일단위 종료
 */
this.fnShowResult = function(){
	this.fnExecuteEnable(true);
	this.fnToggleHighlight(-1);
	this.fnSortErrToTop();

	var nNgCnt = 0;
	var nOkCnt = 0;
	var arrMsg = [];
	arrMsg.push("지원학생등록이 완료 되었습니다.\n");

	for(var i = 0; i < this.dsMain.getRowCount(); i++){
		if(this.dsMain.getColumn(i, 'stsNm') == '정상') nOkCnt++;
		else nNgCnt++;
	}

	arrMsg.push('- 대상 : ' + this.dsMain.getRowCount() + ', ' + '오류 : ' + nNgCnt + ', 정상 : ' + nOkCnt);

	this.smfLiteralAlert(arrMsg.join('\n'), function(){});
}

/**
 * @description 엑셀업로드 callback함수
 */
this.fnExcelUploadCallback = function(importId, bResult, sFilename)
{
	if(!bResult) return false;

	this.smfClearSort(this.grdMain);
	
	this.dsMain.clearData();
	
	//필터초기화
	this.fnInitFilter();
	
	var regSn = 1;
	// 첫번째행 check - 첫번째행이 양식 타이틀이면 삭제한다.
	var coaRcritMmntCd = this.smfTrim(this.dsExcelUpload.getColumn(0, "coaRcritMmntCd"));
	var shlCd = this.smfTrim(this.dsExcelUpload.getColumn(0, "shlCd"));
	var stuRrno = this.smfTrim(this.dsExcelUpload.getColumn(0, "stuRrno"));
	var coaEvlUnitId = this.smfTrim(this.dsExcelUpload.getColumn(0, "coaEvlUnitId"));
	var uvstExmtNo = this.smfTrim(this.dsExcelUpload.getColumn(0, "uvstExmtNo"));
	if(coaRcritMmntCd == "모집시기" || shlCd == "고등학교코드" || stuRrno == "주민등록번호" || coaEvlUnitId == "평가단위코드" || uvstExmtNo == "수험번호"){
		this.dsExcelUpload.deleteRow(0);
		//22.12.26 액셀 로우넘으로 안하고 1부터 시작
		//regSn++;
	}
	
	this.dsExcelUpload.addColumn("regSn", "INT", 10);
	this.dsExcelUpload.addColumn('stsNm');
	this.dsExcelUpload.addColumn('rmkCn');
	
  	this.fvWorker = this.udsfCreateStepWorker(this.grdMain, this.dsExcelUpload, this.dsExcelValid, this.dsMain)
						.errorChecker((val) => val.error === true)
						.complete(function(error){
							this.fnRunSprtStuRegVrfcFile();
						})
						.command(this.udsfStepWorkCommandEmptyCols, ['shlCd', 'stuRrno', 'uvstExmtNo', 'coaRcritMmntCd', 'coaEvlUnitId'])
						.command(this.udsfStepWorkCommandValidate)
						.command(this.udsfStepWorkCommandDup, { cond : 'uvstExmtNo == {0} || ( stuRrno == {1} && coaEvlUnitId == {2} )', msg : '주민등록번호 또는 수험번호' })
						.command(this.udsfStepWorkCommandObserver, { cnt: 1000, callback: this.fnExecuteAlive })
						;
	
	this.fnExecuteEnable(false);
	this.fnSearchFileDgr(function(){
		this.setTimer(this.fvTimerId, this.fvTimerElapse);	
	});
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

/**
 * @description 그리드 헤더 클릭
*/
this.grdMain_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var columnName = obj.getCellProperty("body",e.cell,"text");
	if ("bind:_chk" == columnName){
		this.smfToggleChkHeader(obj, e, this.fnRenderGridCheckbox);
	}else{
		// 정렬
		this.smfCheckAndSort(obj, e);
	}
};

/**
 * @description 조회
 */
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearch();
};

/**
 * @description 초기화
 */
this.divSearch_btnInit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 초기화
	this.fnInit(obj);
	
	this.smfLiteralAlert("초기화 되었습니다.", function(){});
};

/**
 * @description 지원학생등록 엑셀업로드
 */
this.btnPrcs_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//clear하고 컬럼을 새로 만들어주지 않으면 비정상적인 포멧이후 정상포멧 업로드 시 오류가 발생함.
	this.dsExcelUpload.clear();
	
	this.dsExcelUpload.addColumn('shlCd');
	this.dsExcelUpload.addColumn('stuRrno');
	this.dsExcelUpload.addColumn('uvstExmtNo');
	this.dsExcelUpload.addColumn('coaRcritMmntCd');
	this.dsExcelUpload.addColumn('coaEvlUnitId');
	
	var objOption = {	datasetname : "dsExcelUpload"
					,   sheetname   : "Sheet1"
					,   startcell   : "A1"
					,   callback    : "fnExcelUploadCallback"
					,   importId    : "excelUpload"
					,   objForm     : this
					};
	
	this.smfExcelImport(objOption);
};

/**
 * @description 양식다운로드
 */
this.btnFormDown_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objOption = {	objGrid : this.grdExcelForm
					,	sheetname : "Sheet1"
					,   filename : "지원학생등록(양식)"
					};
	
	this.smfExcelExport(objOption);
};

/**
 * @description 대입전형자료 경로선택
 */
this.divMain_btnCoaDataPath_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objExtCommon = this.smfCreateExtCommonAPI();
	
	var coaDataPath = nexacro.getPrivateProfile(this.udsv_coaDataPathValue);
	if(this.smfIsNull(coaDataPath)){
		coaDataPath = objExtCommon._ext_getSystemDir("CSIDL_PERSONAL"); 
	}
	coaDataPath = objExtCommon._ext_selectFolderPath(coaDataPath);
	
	objExtCommon = null;
	if(!this.smfIsNull(coaDataPath)){
		this.divMain.form.edtCoaDataPath.set_value(coaDataPath);
		this.divMain.form.txtCoaDataDtlPath.set_value(this.udsfGetCoaDataDtlPath(coaDataPath));
		
		this.udsfSetCoaDataPath(coaDataPath);
	}
};

/**
 * @description 전체, 정상, 오류 필터
 */
this.divExcelVrfc_rdoVrfcSc_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	var ds = this.grdMain.getBindDataset();
	if(!this.smfIsNull(ds)){
		if(e.postvalue == 0) ds.set_filterstr();
		else ds.set_filterstr("stsNm == '" + e.posttext + "'")
	}
};

/**
 * @description 지원학생관리
 */
this.btnSprtStuMng_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 팝업 파라메터
	var popupParams = {
		callback: function(context, responseParams, sender){
			if(context.isDelNreqData == true){
				this.fnInit(obj);
			}
		}, // 콜백함수 지정
		sender: obj, // sender 지정
		params: {
			procType: "search" // 처리타입 지정
		},
	};

	// 지원학생관리 모달팝업 실행
	this.smfDialog("uds_ueudd00_p02", "pa_uds_ueu_dd::uds_ueudd00_p02.xfdl", popupParams);
};

/**
 * @description 오류내역조회
 */
this.btnSprtStuErr_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 팝업 파라메터
	var popupParams = {
		callback: function(importId, bResult){}, // 콜백함수 지정
		sender: obj, // sender 지정
		params: {
			procType: "search" // 처리타입 지정
		},
	};

	// 지원학생관리 모달팝업 실행
	this.smfDialog("uds_ueudd00_p03", "pa_uds_ueu_dd::uds_ueudd00_p03.xfdl", popupParams);
};

this.uds_ueudd00_m02_ontimer = function(obj:nexacro.Form,e:nexacro.TimerEventInfo)
{
	if(e.timerid == this.fvTimerId){
		this.killTimer(e.timerid);

		if(this.fvWorker.next()){
			this.setTimer(e.timerid);
		}
	}
};
