        <Static id="Static99_00_00_00_00_01_00" taborder="7" left="0" top="divSearch:0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <ImageViewer id="img00_00_01_00" taborder="1" text="지원학생등록" left="0" top="Static99_00_00_00_00_01_00:0" width="140" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn"/>
        <Button id="btnFormDown" taborder="2" text="양식다운로드" top="90" width="126" height="30" cssclass="btn_WF_FileDown" right="232" initvalueid="ivBtnAccessibilityLink" onclick="btnFormDown_onclick"/>
        <Button id="btnSprtStuMng" taborder="3" text="지원학생조회" top="90" height="30" visible="true" initvalueid="ivBtnAccessibilityButton" onclick="btnSprtStuMng_onclick" width="108" cssclass="btn_WF_Custom" right="116"/>
        <Button id="btnPrcs" taborder="4" text="지원학생등록" top="90" height="30" visible="true" initvalueid="ivBtnAccessibilityButton" onclick="btnPrcs_onclick" cssclass="btn_WF_Crud" right="0" width="108"/>
        <Grid id="grdMain" taborder="5" left="0" top="130" binddataset="dsMain" autofittype="col" right="0" selecttype="cell" onheadclick="grdMain_onheadclick" autoenter="select" initvalueid="ivGrdAccessibilityOn" visible="true" height="290">
