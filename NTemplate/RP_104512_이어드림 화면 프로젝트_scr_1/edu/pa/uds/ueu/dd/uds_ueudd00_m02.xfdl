              <Edit id="edtCoaRcritScNm" taborder="3" left="staCoaRcritScNm:0" width="135" height="30" top="20" initvalueid="ivEdtReadOnly" readonly="true" text="수시(사전운영)"/>
              <Button id="btnSearch" taborder="4" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="10" onclick="divSearch_btnSearch_onclick" initvalueid="ivBtnAccessibilityButton" visible="false"/>
              <Button id="btnInit" taborder="5" text="초기화" top="20" width="88" height="30" cssclass="btn_WF_Refresh03" onclick="divSearch_btnInit_onclick" right="10" initvalueid="ivBtnAccessibilityButton"/>
            </Layout>
          </Layouts>
