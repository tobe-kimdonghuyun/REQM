                <Cell col="3" displaytype="date" edittype="none" text="bind:regDt" calendardateformat="yyyy.MM.dd." calendareditformat="yyyy.MM.dd." cssclass="expr:imptYn==&quot;Y&quot;?&quot;cell_bgGray&quot;:&quot;&quot;" cursor="pointer"/>
                <Cell col="4" text="bind:ntcMteInqCnt" displaytype="text" cssclass="expr:imptYn==&quot;Y&quot;?&quot;cell_bgGray,LineNo&quot;:&quot;LineNo&quot;" cursor="pointer"/>
              </Band>
