/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::uds_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvIntCoaAyr = 0;
this.fvCoaDataYyCnt = 9; // 대입 최대 자료년수
/************************************************************************************************
 * FORM EVENT 영역(onload)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	this.fnClear();
	
	// 대입서비스체크
	this.udsfCoaSvcChck(function(){
		this.fnSelectCoaCtr(obj);	//기준정보 조회 
		
		// 공통코드 조회
		this.smfCodeList("code", [this.dsHshScCd])
			.callback(function(callbackParams){
				if(callbackParams.errors) return;
			})
			.run();
	});
};

/************************************************************************************************
 * TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 대입기준 조회
 */
this.fnSelectCoaCtr = function(obj){

	// 대입기준 조회
	this.smfSearchService("selectCoaCtrBsc")
		
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.fnInit(obj); // 초기화
		});	
}

/**
 * @description 조회 버튼 클릭
 */
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 서비스 객체 생성
	this.smfSearchService("listCoaPrge")
		.paginator(this.grdMain, this.divPaginator, this.divPageSummary, this.dsPageInfo, obj, e) // 페이징처리
		// .confirmIfModifiedGrid(this.grdMain) // 데이터가 변경되었으면 확인메시지
		.validateForm(this.divSearch) // 폼 유효성검사
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.dsMain.getRowCount() > 0){
				this.btnExcel.set_enable(true);
			}else{
				this.btnExcel.set_enable(false);
			}
			
			//엑셀 전체 다운로드 추가 2024.09.26
			var pageIndex = this.dsPageInfo.getColumn(0,'pageIndex');
			if(pageIndex == 1){
				this.smfSearchService("listCoaPrgeExcel")
				.validateForm(this.divSearch) // 폼 유효성검사
				.run() // 실행
				.callback(function(callbackParams){
				}) // 콜백
			}
			
		}) // 콜백
	;
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
	
	var action = {
		listCddcOrgCd : () => this.divSearch.form.cboCddcCd.set_value(""),
		//listCoaPrge : () => this.fnDisplayTotalText(this.dsMain, this.staTotalCount),
	}
	
	if(this.smfIsFunc(action[svcid])) action[svcid]();
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * 그리드 체크박스 enable 처리
 * @param : ds - 데이터셋
 * @param : nRow - rowposition
 */
this.fnRenderGridCheckbox = function(ds, nRow){
	return true;
};

/**
 * @description 초기화 FUNCTION
 */
this.fnInit = function(obj){
	this.divSearch.form.edtCoaAyr.set_value(this.udsv_coaAyr);
	this.divSearch.form.edtCoaRcritNm.set_value(this.udsv_coaRcritScNm);
	
	this.dsSearch.setColumn(0, "coaAyr", this.udsv_coaAyr);
	this.dsSearch.setColumn(0, "coaRcritScCd", this.udsv_coaRcritScCd);
	
	this.fvIntCoaAyr = nexacro.toNumber(this.udsv_coaAyr); // 그리드 head의 가변적인 년도 표시를 위해
	
	this.grdMain.redrawExprCell();
	this.grdOnlInfo.redrawExprCell();
	
	//시도교육청목록 조회
	this.smfSearchService("listCddcOrgCd")
		.validateForm(this.divSearch) // 데이터 검증
		.run() // 실행
		.callback(function(callbackParams){ // 콜백
			if(callbackParams.errors) return;
		})
	;
	
	// 조회 입력창에서 'Ctrl' + 'Enter' 키 입력시 조회수행 이벤트 설정
	this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
	
	var grsDataSbmsnYyCnt = this.dsCoaCtrBsc.getColumn(0,"grsDataSbmsnYyCnt"); // 대입자료년수
	for (var i = this.fvCoaDataYyCnt; i > nexacro.toNumber(grsDataSbmsnYyCnt); i--){
		var grdMainStartIdx = 6;
		this.grdMain.deleteContentsCol(i + grdMainStartIdx); // 제출년한에 포함되지않는 학년도 삭제
		
		var grdOnlInfoStartIdx = -1;
		this.grdOnlInfo.deleteContentsCol(i + grdOnlInfoStartIdx); // 제출년한에 포함되지않는 학년도 삭제
	}
}

/**
 * @description 토탈
 */
this.fnDisplayTotalText = function(grd, staTotal)
{
	var nTotalCnt = grd.getRowCount();
	var sTotalText = "Total : " + this.fnToCommaNumber(nTotalCnt);
	staTotal.set_text(sTotalText);
}

/**
 * @description 숫자에 콤마
 * this.fnToCommaNumber(1000) -> 1,000
 */
this.fnToCommaNumber = function(nNumber, separate = ',')
{
	if(this.smfIsNum(nNumber)) return nNumber.toString().replace(/\B(?=(\d{3})+(?!\d))/g, separate);
	return nNumber;
}

/**
 * @description 제공정보 expr
 * OXOXXXXXX -> 총 2개년도 제출
 */
this.getSeleDataSbmsnYnSum = function(){
	var nTotal = [...Array(this.grdOnlInfo.getCellCount('head.row1')).keys()].reduce((a, c) => {
		return a + (this.grdOnlInfo.getCellValue(0, c) == '제공' ? 1 : 0);
	}, 0);
	
	return '총 ' + nTotal + '개년도 온라인제공';
}

/**
 * @description 전화번호
 */
this.fnGetTelno = function(psValue){
	var vsPttTelNo = Array(3);
	vsPttTelNo[0] = "";
	vsPttTelNo[1] = "";
	vsPttTelNo[2] = "";
	
	if (this.isNil(psValue)) return "";
	psValue = psValue.trim().replace(/[\-]/g, "");
	var vslength = psValue.length;
	var vsSeoulYn = false;
	
	/**
	 * 서울 02  경기 031 인천 032 강원 033
	 * 충남 041 대전 042 충북 043 부산 051
	 * 울산 052 대구 053 경북 054 경남 055
	 * 전남 061 광주 062 전북 063 제주 064
	 */
	//서울만 국번이 2자리
	if (psValue.substr(0, 2) == "02") vsSeoulYn = true;
	
	if (vsSeoulYn) {
		if (vslength <= 2) {
			vsPttTelNo[0] = psValue;
			vsPttTelNo[1] = "";
			vsPttTelNo[2] = "";
			return vsPttTelNo;
		} else if (vslength == 3) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 1);
			vsPttTelNo[2] = "";
			return vsPttTelNo;
		} else if (vslength == 4) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 2);
			vsPttTelNo[2] = "";
			return vsPttTelNo;
		} else if (vslength == 5) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 3);
			vsPttTelNo[2] = "";
			return vsPttTelNo;
		} else if (vslength == 6) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 4);
			vsPttTelNo[2] = "";
			return vsPttTelNo;
		} else if (vslength == 7) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 4);
			vsPttTelNo[2] = psValue.substr(6, 1);
		} else if (vslength == 8) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 2);
			vsPttTelNo[2] = psValue.substr(4, 4);
			//------------------------------------------
		} else if (vslength == 9) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 3);
			vsPttTelNo[2] = psValue.substr(5, 4);
		} else if (vslength == 10) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 4);
			vsPttTelNo[2] = psValue.substr(6, 4);
		} else if (vslength == 11) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 4);
			vsPttTelNo[2] = psValue.substr(7, 4);
		} else {
			vsPttTelNo[0] = "";
			vsPttTelNo[1] = "";
			vsPttTelNo[2] = "";
		}
	} else {
		if (vslength <= 2) {
			vsPttTelNo[0] = psValue;
			vsPttTelNo[1] = "";
			vsPttTelNo[2] = "";
			return vsPttTelNo;
		} else if (vslength == 3) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = "";
			vsPttTelNo[2] = "";
			return vsPttTelNo;
		} else if (vslength == 4) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 1);
			vsPttTelNo[2] = "";
			return vsPttTelNo;
		} else if (vslength == 5) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 2);
			vsPttTelNo[2] = "";
			return vsPttTelNo;
		} else if (vslength == 6) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 3);
			vsPttTelNo[2] = "";
			return vsPttTelNo;
		} else if (vslength == 7) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 4);
			vsPttTelNo[2] = "";
		} else if (vslength == 8) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 1);
			vsPttTelNo[2] = psValue.substr(4, 4);
		} else if (vslength == 9) { //없는전화번호
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 2);
			vsPttTelNo[2] = psValue.substr(5, 4);
		} else if (vslength == 10) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 3);
			vsPttTelNo[2] = psValue.substr(6, 4);
		} else if (vslength == 11) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 4);
			vsPttTelNo[2] = psValue.substr(7, 4);
		} else {
			vsPttTelNo[0] = "";
			vsPttTelNo[1] = "";
			vsPttTelNo[2] = "";
		}
	}
	
	return vsPttTelNo.join("-");
}

/**
 * @description 페이지 네이션 클리어 FUNCTION
 */
this.fnClear = function(){
	this.dsPageInfo.setColumn(0, "totalCount", 0);
	this.dsMain.clearData();
	
	if(!this.smfIsNull(this.getOwnerFrame().form.fv_workPageWidth)) this.divPaginator.form.setOffsetWidth(this.getOwnerFrame().form.fv_workPageWidth);
	this.divPaginator.form.fnInit(
			  this.grdMain
			, this.dsPageInfo
			, this.divPageSummary
			, this.btnSearch
			, this);
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 그리드 헤더 클릭
 */
this.grdMain_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var columnName = obj.getCellProperty("body",e.cell,"text");
	if ("bind:_chk" == columnName){
		this.smfToggleChkHeader(obj, e, this.fnRenderGridCheckbox);
	}else{
		// 정렬
		this.smfCheckAndSort(obj, e);
	}
};
/**
 * @description 그리드의 로우선택이 바꼈을때 대입담당자 정보를 뿌려줌
 */
this.dsMain_onrowposchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSRowPosChangeEventInfo)
{	
	var shlKndScCd = obj.getColumn(obj.rowposition, "shlKndScCd");
	if(shlKndScCd == "05") {//특수
		this.divCoaWrkPrgeInfo.form.edtShlKndScCdNm.set_value("특수학교");
		this.divCoaWrkPrgeInfo.form.cboHshScCd.set_visible(false);
	} else if(shlKndScCd == "17") {//평생
		this.divCoaWrkPrgeInfo.form.edtShlKndScCdNm.set_value("평생학교");
		this.divCoaWrkPrgeInfo.form.cboHshScCd.set_visible(false);
	} else { //고등
		this.divCoaWrkPrgeInfo.form.edtShlKndScCdNm.set_value("고등학교");
		this.divCoaWrkPrgeInfo.form.cboHshScCd.set_visible(true);
	}
	
	var prgeMblTelno = obj.getColumn(obj.rowposition, "prgeMblTelno");
	var shlTelno = obj.getColumn(obj.rowposition, "shlTelno");
	//this.divCoaWrkPrgeInfo.form.edtPrgeMblTelno.set_value(this.fnGetTelno(prgeMblTelno));
	this.divCoaWrkPrgeInfo.form.edtShlTelno.set_value(this.fnGetTelno(shlTelno));
};

/**
 * @description 엑셀다운로드
 */
this.btnExcel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//var grd = this.grdMain;
	var grd = this.grdMainExcel; //엑셀 전체 다운로드 추가 2024.09.26
	
	var objOption = {	objGrid : grd
					,	sheetname : "Sheet1"
					,   filename : this.divTitle.form.imgTitle.text
					};

	this.smfExcelExport(objOption);
};

/**
 * @description 그리드 선택
 */
this.grdMain_onselectchanged = function(obj:nexacro.Grid,e:nexacro.GridSelectEventInfo)
{
	this.dsMainSel.clearData();
	this.smfGridMultiSelectCopyRow(obj, this.dsMainSel, '_chk');	
};
