        <TextArea id="txt00" taborder="1" left="20" top="60" width="610" height="339" readonly="true" value="원격근무 보안서약서&#10;&#10;본인은 원격근무를 수행함에 있어 다음 사항을 준수할 것을 엄숙히 서약합니다.&#10;&#10;1. 나는 부여받은 인증관련 정보 및 매체를 타인에게 유출하지 아니한다.&#10;&#10;2. 나는 원격근무 중 작성˙저장˙열람˙출력한 문서는 업무 목적에만 활용하고 타인에게 유출하지 아니한다.&#10;&#10;3. 나는 원격근무용 소프트웨어 및 전산장비를 업무목적에만 활용하며 바이러스 백신 프로그램 및 &#10;   기타 보안 프로그램을 설치하여 최신 상태로 유지한다.&#10;&#10;4. 나는 여타 보안사항들을 성실히 준수하며 위반시 관련규정에 따라 처벌도 감수한다."/>
        <Static id="Static99_00_00_00_00_01_00_00_00_00" taborder="10" left="Static99_00_00_00_00_01_00_00_00_01_00_00_00:0" top="txt00:0" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="Static99_00_00_00_00_01_00_00_00_01_00_00_00_00:0" initvalueid="ivStcAccessibilityOff"/>
        <CheckBox id="chkScrtyWpldgAgreYn" taborder="2" text="동의" left="289" width="75" height="29" top="Static99_00_00_00_00_01_00_00_00_00:0" readonly="false" validate="required" accessibilitylabel="보안서약서동의" cssclass="essential" textAlign="center"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
 *	대입전형자료원격업무신청서비스
 *	@MenuPath	대입전형-전형자료원격업무신청서비스-전형자료원격업무신청서비스신청
 *	@FileName 	uds_ueuum00_p00.xfdl
 *	@Creator 	김정민
 *	@CreateDate	2023.05.03
 *	@Desction	
 ************** 소스 수정 이력 ***********************************************
 *	date			Modifier			Description
 *******************************************************************************
 *	2023.05.03		김정민				최초 생성 
 *******************************************************************************
 */

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::uds_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/


/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Div 초기화
	this.smfInitPopup(obj);
	
	// 초기화
	this.fnInit(obj);
	
	// 조회
	this.fnSearch();
};

/**
 * @description 폼 닫기전 이벤트
 */
this.fnOnbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/**
 * @description 조회
 */
this.fnSearch = function()
{



// 조회 하지 않고 고정으로 한다.
/*
	this.smfSearchService('selectScrtyWpldg')
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});
*/
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/**
 * @description 초기화 FUNCTION
 */
this.fnInit = function(obj){
	var params = this.smfGetPopupParams();
	
	this.dsSearch.setColumn(0, 'userId', params.userId);
	this.dsSearch.setColumn(0, 'aplcnBgngYmd', params.aplcnBgngYmd);
	
	this.chkScrtyWpldgAgreYn.set_value(params.scrtyWpldgAgreYn == true)
}


/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 
//동의
this.btnAgre_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.chkScrtyWpldgAgreYn.value != true){
		this.smfLiteralAlert('보안서약서 동의가 필요합니다.');
		this.chkScrtyWpldgAgreYn.setFocus();
		return;
	}
	
	this.smfSendResponseToOpener({
		"retrunValue": this.smfRowToObject(this.dsMain)
	});
	
	this.close(true);
};

//취소
this.btnRtrcn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};
]]></Script>
