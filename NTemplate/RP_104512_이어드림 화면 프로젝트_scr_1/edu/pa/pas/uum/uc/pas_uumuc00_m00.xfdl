/**
 * @description 마감 / 마감취소
 */
this.btnDdln_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.dsMain.rowposition > -1){
		//마감 가능여부 확인
		var remWrkAplySn = this.dsMain.getColumn(this.dsMain.rowposition, 'remWrkAplySn');
		var fileRefrnId = this.dsMain.getColumn(this.dsMain.rowposition, 'fileRefrnId');
		var atrzStsCd = this.dsMain.getColumn(this.dsMain.rowposition, 'atrzStsCd');
		var ddlnYn = this.dsMain.getColumn(this.dsMain.rowposition, 'ddlnYn');
		
		if(!this.smfIsNull(remWrkAplySn) && !this.smfIsNull(fileRefrnId) && ddlnYn != 'Y' && this.smfIsNull(atrzStsCd)){
			this.fnExecuteRemWrkReqsDdln();
		}
	}
};

/**
 * @description 신청서 저장
 */
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnValidate(function(){
		this.smfConfirm('원격업무 신청서를 저장하시겠습니까?', function(confirmParams){
			if(confirmParams.confirmResult){
				if(this.divFileUpload.form.fnIsExistUploadFile()){
					var rowType = this.dsMain.getRowType(this.dsMain.rowposition);
					if(rowType != '2' && rowType != '4'){
						this.dsMain.set_updatecontrol(false);
						this.dsMain.setRowType(this.dsMain.rowposition, "U");
						this.dsMain.set_updatecontrol(true);
					}
				
					this.divFileUpload.form.fnFileUpload();
				}else{
					this.fnSaveRemWrkReqs(function(){
						if(this.dsMain.rowposition > -1){
							var ddlnYn = this.dsMain.getColumn(this.dsMain.rowposition, 'ddlnYn');
							var fileRefrnId = this.dsMain.getColumn(this.dsMain.rowposition, 'fileRefrnId');
							
							if(ddlnYn != 'Y' && !this.smfIsNull(fileRefrnId)){
								this.fnExecuteRemWrkReqsDdln(true);
							}else{
								this.fnSearch();
							}
						}
					});
				}
			}
		});				
	});
};

/**
 * @description 삭제
 */
this.btnDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.dsMain.rowposition > -1){
		if(this.dsMain.getColumn(this.dsMain.rowposition, 'ddlnYn') != 'Y'){
			this.fnDeleteRemWrkReqs();
		}else{
			this.smfLiteralAlert('마감된 신청서는 삭제할 수 없습니다.');
		}
	}else{
		this.smfLiteralAlert('삭제할 데이터가 없습니다.');
	}
};

/**
 * @description 신청서조회 OZ
 */
this.divCoaPrge_btnReqsInq_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var offmTelno = this.fnGetPttTelNo(this.dsMain.getColumn(this.dsMain.rowposition, 'offmTelno'));
	var mblTelno = this.fnGetPttTelNo(this.dsMain.getColumn(this.dsMain.rowposition, 'mblTelno'));

	var ozDatas = [];
	var ozData = {
		'title' : '원격업무지원신청서',
		'csv' : [
					this.dsMain.getColumn(this.dsMain.rowposition, 'coaAyr'),
					this.dsMain.getColumn(this.dsMain.rowposition, 'coaRcritScCd'),
					this.dsMain.getColumn(this.dsMain.rowposition, 'vpnPswd'),
					this.dsCoaCtr.getColumn(0, 'coaSvcAplyBgngYmd'),
					this.dsCoaCtr.getColumn(0, 'coaSvcAplyEndYmd'),
					this.dsCoaCtr.getColumn(0, 'rcritScByBgngYmd'),
					this.dsCoaCtr.getColumn(0, 'rcritScByEndYmd'),
					this.dsCoaCtr.getColumn(0, 'rcritScByBgngYmdNsche'),
					this.dsCoaCtr.getColumn(0, 'rcritScByEndYmdNsche'),
					this.dsCoaCtr.getColumn(0, 'rcritScByBgngYmdSche'),
					this.dsCoaCtr.getColumn(0, 'rcritScByEndYmdSche'),
					this.smfToday(),
					this.smfToday(),
					this.dsMain.getColumn(this.dsMain.rowposition, 'userId'),
					this.dsMain.getColumn(this.dsMain.rowposition, 'userDtcNo'),
					this.fnGetUserScCd(),
					this.fnGetOrgCd(),
					this.fnGetOrgNm(),
					this.dsMain.getColumn(this.dsMain.rowposition, 'userNm'),
					this.dsMain.getColumn(this.dsMain.rowposition, 'jbgdNm'),
					this.dsMain.getColumn(this.dsMain.rowposition, 'dptNm'),
					offmTelno,
					mblTelno,
					this.dsMain.getColumn(this.dsMain.rowposition, 'mnrNm'),
					this.dsMain.getColumn(this.dsMain.rowposition, 'mnrJbgdNm'),
					this.dsMain.getColumn(this.dsMain.rowposition, 'mnrDptNm'),
				].join('#$!')
	};
	
	ozDatas.push(ozData);

	this.fnShowOzReport(ozDatas);
};

