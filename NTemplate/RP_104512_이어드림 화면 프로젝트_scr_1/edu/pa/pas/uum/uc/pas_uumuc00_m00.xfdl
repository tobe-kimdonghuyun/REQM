			this.btnDdln.set_enable(false);
		}
	}
};

/**
 * @description 보안서약서 팝업
 */
this.divCoaPrge_btnScrtyWpldg_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 팝업 파라메터
	var popupParams = {
		callback: function(e, sender){ // 콜백함수 지정
			if(!this.divCoaPrge.form.chkScrtyWpldgAgreYn.value){
				this.divCoaPrge.form.chkScrtyWpldgAgreYn.set_value(true);
			}
		}, 
		sender: obj, // sender 지정
		params: {
			procType : "none", // "none","search","insert","update","delete"
			scrtyWpldgAgreYn : this.divCoaPrge.form.chkScrtyWpldgAgreYn.value,
			userId : this.fvUserId,
			aplcnBgngYmd : this.smfToday(),
		},
	};

	// 모달팝업 실행
	this.smfDialog("pas_uumuc00_p00", "pa_pas_uum_uc::pas_uumuc00_p00.xfdl", popupParams);
};

/**
 * @description 신청서 변경사항 확인
 */
this.dsMain_canrowposchange = function(obj:nexacro.NormalDataset,e:nexacro.DSRowPosChangeEventInfo)
{
	var rowType = this.dsMain.getRowType(e.oldrow);
	if(rowType == '2' || rowType == '4'){
		this.smfConfirm("화면에 변경된 값이 저장되지 않았습니다.\n선택을 변경하면 작성된 내용이 초기화됩니다.\n\n선택을 변경하시겠습니까?",  function(confirmParams){
			if(confirmParams.confirmResult){
				this.dsMain.reset();
			
				//row idx 이동 ( UI )
				this.grdMain.setCellPos(1, e.newrow);
				this.grdMain.redrawExprCell();
			}
		});
		
		return false;
	}

	return true;
};

/**
 * @description 신청서 선택 변경
 */
this.dsMain_onrowposchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSRowPosChangeEventInfo)
{
	//파일 초기화
	this.dsOutFileinfo.clearData();
	this.divFileUpload.form.fnResetUpload();
	this.divCoaPrge.form.divUpload.form.staFile.set_text('');
	this.divCoaPrge.form.divUpload.form.edtFile.set_value('');
	this.divCoaPrge.form.divUpload._FileRefrnId = null;
	this.divCoaPrge.form.divUpload._FileGbnValue = null;

	this.divCoaPrge.form.edtVpnPswdIdnty.set_value(this.dsMain.getColumn(e.newrow, 'vpnPswd'));
	
	var offmTelno = this.dsMain.getColumn(e.newrow, 'offmTelno');
	if(this.smfIsNull(offmTelno)){
		this.divCoaPrge.form.edtOffmTelno.set_value('');
	}else{
		this.divCoaPrge.form.edtOffmTelno.set_value(this.fnGetPttTelNo(offmTelno));
	}
	
	var mblTelno = this.dsMain.getColumn(e.newrow, 'mblTelno');
	if(this.smfIsNull(mblTelno)){
		this.divCoaPrge.form.edtMblTelno.set_value('');
	}else{
		this.divCoaPrge.form.edtMblTelno.set_value(this.fnGetPttTelNo(mblTelno));
	}
	
	if(this.dsMain.getRowType(e.newrow) == '2' || e.newrow == -1){
		this.divCoaPrge.form.chkScrtyWpldgAgreYn.set_value(false);
	}else{
		this.divCoaPrge.form.chkScrtyWpldgAgreYn.set_value(true);
	}
	
	if(this.fnCheckPasswordPattern(this.dsMain.getColumn(e.newrow, 'vpnPswd'), true)){
		this.divCoaPrge.form.staVpnPswd01.set_text('적합');
	}else{
		this.divCoaPrge.form.staVpnPswd01.set_text('부적합');
	}
	this.divCoaPrge.form.staVpnPswdIdnty01.set_text('일치');

	var fileRefrnId = this.dsMain.getColumn(e.newrow, 'fileRefrnId');
	
	if(!this.smfIsNull(fileRefrnId)){
		this.fnSearchFile(fileRefrnId);
	}
	
	var isDdln = this.dsMain.getColumn(e.newrow, 'ddlnYn') == 'Y';
	var atrzStsCd = this.dsMain.getColumn(e.newrow, 'atrzStsCd');

	if(isDdln == false && !this.smfIsNull(fileRefrnId) && this.smfIsNull(atrzStsCd)){
		//마감
		this.btnDdln.set_enable(true);
	}else{
		this.btnDdln.set_enable(false);
	}
	
	//저장
	this.btnSave.set_enable(!isDdln);
	//삭제
	this.btnDelete.set_enable(!isDdln);
	//신청서조회
	this.divCoaPrge.form.btnReqsInq.set_enable(!isDdln);
	//파일추가
	this.divCoaPrge.form.divUpload.form.btnReqsAdd.set_enable(!isDdln);
	//파일삭제
	this.divCoaPrge.form.btnReqsDel.set_enable(!isDdln);

	//new버튼 활성화
	var nRow = this.dsMain.findRowExpr(this.udsfGetConditionFormat('lastYn == {0}', 'Y'));
	if(nRow > -1){
		var atrzStsCd = this.dsMain.getColumn(nRow, 'atrzStsCd');
		//4: 승인, 3: 반려 상태일 때 신규 버튼 활성화
		if(atrzStsCd == '4' || atrzStsCd == '3'){
			this.btnNew.set_enable(true);
		}
	}
	

	var isLast = this.dsMain.getColumn(e.newrow, 'lastYn') == 'Y';
	var isReadonly = !isLast || isDdln;
	
	//Dataset.ROWTYPE_INSERT 2 추가된 행의 상태 
	if(this.dsMain.getRowType(e.newrow) == '2'){
		isReadonly = false;
	}
	
	//this.divCoaPrge.form.rdoCoaRcritScCd.set_readonly(isReadonly);
	this.divCoaPrge.form.edtUserNm.set_readonly(isReadonly);
	this.divCoaPrge.form.edtDptNm.set_readonly(isReadonly);
	this.divCoaPrge.form.edtJbgdNm.set_readonly(isReadonly);
	this.divCoaPrge.form.edtOffmTelno.set_readonly(isReadonly);
	this.divCoaPrge.form.edtMblTelno.set_readonly(isReadonly);
	this.divCoaPrge.form.edtVpnPswd.set_readonly(isReadonly);
	this.divCoaPrge.form.edtVpnPswdIdnty.set_readonly(isReadonly);
	this.divCoaPrge.form.edtDmndRsnCn.set_readonly(isReadonly);
	this.divCoaPrge.form.edtMnrNm.set_readonly(isReadonly);
	this.divCoaPrge.form.edtMnrJbgdNm.set_readonly(isReadonly);
	this.divCoaPrge.form.edtMnrDptNm.set_readonly(isReadonly);
	
	this.divCoaPrge.form.btnScrtyWpldg.set_enable(true);
};

/**
 * @description 전화번호 포멧
 */
this.divCoaPrge_edtOffmTelno_onkillfocus = function(obj:nexacro.Edit,e:nexacro.KillFocusEventInfo)
{
	if(obj.value != null){
		var vsOld = obj.value;
		//var val = obj.value.replaceAll("-", "");
		//var vsNew = val.replace(/(^02.{0}|^01.{1}|[0-9]{3})([0-9]+)([0-9]{4})/,"$1-$2-$3");
		var vsNew = this.fnGetPttTelNo(obj.value);
		if(vsOld != vsNew) obj.set_value(vsNew);
	}
	
	if(this.smfIsNull(obj.value)){
		if(obj.id == 'edtOffmTelno'){
			this.dsMain.setColumn(this.dsMain.rowposition, 'offmTelno', '');
		}else if(obj.id == 'edtMblTelno'){
			this.dsMain.setColumn(this.dsMain.rowposition, 'mblTelno', '');
		}
	}else{
		var val = obj.value.replaceAll("-", "");
		if(obj.id == 'edtOffmTelno'){
			this.dsMain.setColumn(this.dsMain.rowposition, 'offmTelno', val);
		}else if(obj.id == 'edtMblTelno'){
			this.dsMain.setColumn(this.dsMain.rowposition, 'mblTelno', val);
		}
	}
};

/**
 * @description 셀클릭
 */
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if(e.cell == 3){
	    var fileRefrnId = obj.getBindDataset().getColumn(e.row, 'fileRefrnId');
		if(!this.smfIsNull(fileRefrnId)){
			this.fnDownload(obj);
		}
	}
};

/**
 * @description 파일 다운로드
 */
this.divCoaPrge_divUpload_staFile_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	this.fnDownload(obj);
};
]]></Script>
