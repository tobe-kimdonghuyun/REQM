/**
 * @description 파일 업로드 다운로드 초기화 FUNCTION
 */
this.fnInitFile = function(obj){
	this.divFileUpload.UPLOAD_CreateComplete = this.fnEventUploadCreateComplete;  // 필요한 경우만 세팅
	this.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;        // 필요한 경우만 세팅(세팅권장)
	this.divFileUpload.UPLOAD_OnError        = this.fnEventUploadError;           // 필요한 경우만 세팅(세팅권장)
	this.divFileUpload.UPLOAD_AfterAddFile   = this.fnEventAfterAddFile;           // 필요한 경우만 세팅(세팅권장)
	this.divFileUpload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)
	
	// 삭제버튼 클릭시 처리를 할 div를 세팅(샘플을 진행하기 위해)
	this.divCoaPrge.form.btnReqsDel._divUploadObj = this.divCoaPrge.form.divUpload;

	// 다운로드버튼 클릭시 처리를 할 div를 세팅(샘플을 진행하기 위해)
	this.divCoaPrge.form.divUpload.form.staFile._divUploadObj = this.divCoaPrge.form.divUpload;
	this.grdMain._divUploadObj = this.divCoaPrge.form.divUpload;
}

/**
 * KUpload를 생성시 지정할 property값을 지정
 * @param  : N/A
 * @return : N/A
 */
this.fnSetRaonProp = function()
{
	// 설정할 property
	var objAddRaonProps = {
		  DisableAlertMessage	: { DisableDeleteConfirm: "1" } // "1"로 설정시 파일 삭제시 confirm창 비활성.
		, ExtensionAllowOrLimit : "1"        // 업로드 할 파일 확장자를 허용 또는 제한 설정("0":지정된 확장자를 제한(선택 금지) , "1":지정된 확장자만 허용(선택가능))
		, ExtensionArr          : "pdf"      // 제한 및 허용할 확장자명을 ",(콤마)"로 구분하여 설정
		, AllowedZeroFileSize   : "1"        // 0byte 파일의 업로드를 허용 할지 설정합니다.(기본값은 "0" 허용안함이고, "1"로 설정시 허용입니다.)
		, MaxTotalFileCount	    : "1"		 //업로드 할 최대 파일 개수 제한값을 설정합니다.
		, MaxOneFileSize		: "8MB"	     //업로드할 때 파일당 용량제한을 설정합니다.
	};
	
	return objAddRaonProps;
}

this.fnEventUploadComplete = function(obj,paramObj,objResultDataset)
{
	this.dsOutFileinfo.copyData(objResultDataset);
	
	// 업로드 성공 후, newfile에 있는 파일들을 webfile로 옮긴다.
	this.divFileUpload.form.fnSetUploadCompleteState(obj,paramObj);	
	
	// 업로드한 file을 가져오는 법(샘플 가이드)
	if(objResultDataset)
	{
		var sFileRefrnId = objResultDataset.getColumn(0,"fileRefrnId");
		
		// 나중에 다운로드하기 위해 관련 정보 세팅
		this.divCoaPrge.form.divUpload._FileRefrnId = sFileRefrnId;
		
		if(this.dsMain.rowposition > -1){
			if(this.divFileUpload.form.fnGetTotalFileCount() > 0){
				this.dsMain.setColumn(this.dsMain.rowposition, 'fileRefrnId', sFileRefrnId);
			}
			
			this.fnSaveRemWrkReqs(function(){
				var ddlnYn = this.dsMain.getColumn(this.dsMain.rowposition, 'ddlnYn');
				var fileRefrnId = this.dsMain.getColumn(this.dsMain.rowposition, 'fileRefrnId');
				var remWrkAplySn = this.dsMain.getColumn(this.dsMain.rowposition, 'remWrkAplySn');
				
				if(ddlnYn != 'Y' && !this.smfIsNull(fileRefrnId)){
					this.fnExecuteRemWrkReqsDdln(true);
				}else{
					this.fnSearch();
				}
			});
		}
	}
	return;
}

this.fnEventUploadError = function(obj,paramObj)
{
	this.smfLiteralAlert('첨부파일 업로드가 실패하였습니다.');
}

this.fnEventAfterAddFile = function(obj,paramObj,sCustomValue,sFileName,nFileSize)
{
	var sFileGbnValue    = sFileName;
	var objdivFormObj    = obj.parent.parent._divFormObj;
	var sFileGbnValueOrg = objdivFormObj.parent._FileGbnValue;
	
	if(!this.smfIsNull(sFileGbnValueOrg))
	{
		obj.parent.fnDeleteFileFromFileGbnValue(sFileGbnValueOrg);
	}
	
	objdivFormObj.parent._FileGbnValue = sFileGbnValue;
	objdivFormObj.staFile.set_text(sFileName + ' ');
	objdivFormObj.edtFile.set_value(sFileName);
	objdivFormObj.staFile.set_cssclass('sta_WF_Txt14');
	objdivFormObj.resetScroll();
	
	//기존 파일 아이디 초기화 ( 테스트 )
	if(this.dsMain.rowposition > -1){
		this.dsMain.setColumn(this.dsMain.rowposition, 'fileRefrnId', '');
	}
}

this.fnSearchFile = function(sFileSn){
	// 업로드 초기화
	this.dsOutFileinfo.clearData();
	this.divFileUpload.form.fnResetUpload();
	
	this.transaction("fn_filesearch" // serviceId
				,"baseUrl::/cm_cmc_file_upload_001.do" // url
				,"" // inDataset
				,"dsOutFileinfo=atchFileinfo" // outDataset
				,"fileRefrnId='"+sFileSn+"'"
				, function(){
				} // callbackFunction
				,false // true: 비동기, false:동기
   );
   
   //for문이지만 파일은 하나!!
   for (var i = 0; i < this.dsOutFileinfo.rowcount; i++) {
		//trace("=== Sample : fnEventUploadComplete"+this.smfUploadInfoFileSn(jsonNew.responseCustomValue[i],0));	
		var responseCustomValue = "";
		var sDownloadUrl       = "";   // 
		var sPrivInfoFiltYn    = "";   // 항목 관리안함
		var sFileInfSaveYn     = "Y";  // 업무에 맞게 개발자가 세팅(Y/N)
		var sHandlerCode       = "PA.PAS.UUM";  //this.smfUploadInfoFileSn(jsonWebFile.customValue[i],0);
		//var fileSn           = "476";  //this.smfUploadInfoFileSn(jsonWebFile.customValue[i],1);
		var sFileSn            = this.dsOutFileinfo.getColumn(i,"fileRefrnId"   );
		var sFileSeq           = this.dsOutFileinfo.getColumn(i,"fileId"        );
		var sFileSize          = this.dsOutFileinfo.getColumn(i,"atchFileMg"    );
		var sBackendFilename   = this.dsOutFileinfo.getColumn(i,"atchFileGuid"  );
		var sForntendFilename  = this.dsOutFileinfo.getColumn(i,"atchFileNm"    );
		var sFileEncryptYn     = this.dsOutFileinfo.getColumn(i,"fileEncryptYn" );
		var sFileSaveStg       = this.dsOutFileinfo.getColumn(i,"fileSaveStg"   );
		
		this.divFileUpload.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sForntendFilename, sFileSeq, sDownloadUrl
												  ,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn );		
		
		// 이 부분에서 해당하는 원래 DB값에 있는 값과 비교하여 해당 div에 넣는다.
		var objDiv = this.divCoaPrge.form.divUpload;
		objDiv._FileRefrnId  = sFileSn;
		objDiv._FileGbnValue = sForntendFilename;  //fileSn+"_"+fileSeq;
		
		objDiv.form.staFile.set_text(sForntendFilename + ' ');
		objDiv.form.staFile.set_cssclass('sta_WF_Blue14Link');
		objDiv.form.resetScroll();
		
		objDiv.form.edtFile.set_value(sForntendFilename);
		
		trace("[" + responseCustomValue + "] [" + sHandlerCode + "]  [" + sFileSn + "]  [" + sBackendFilename + "]  [" + sForntendFilename+ "]  [" + sFileSize+"]");
	}
}

/**
 * @description 파일 다운로드
 */
this.fnDownload = function(obj){
	var objDiv = obj._divUploadObj;
	var sFileGbnValueOrg = objDiv._FileGbnValue;
	var sFileRefrnId     = objDiv._FileRefrnId; //업로드(저장이) 되어야 표기가됨
	
	if((!this.smfIsNull(sFileGbnValueOrg))&&(!this.smfIsNull(sFileRefrnId)))
	{
		var nIndex = this.divFileUpload.form.fnGetMatchFileIndex(sFileGbnValueOrg);
		this.divFileUpload.form.fnDownloadByIndex(nIndex);
	}
}

/**
 * @description Ymd에 점추가
 * @param : sYmd			- 년원일 ( ex. 20230504 )
 * @return 	: String        - YYYY.MM.DD (ex. 2023.05.04. )
 */
this.fnYmdWithDot = function(sYmd){
    sYmd = this.smfStr(sYmd)
	if(!this.smfIsNull(sYmd) && sYmd.length >= 8){
		return [sYmd.substr(0, 4), sYmd.substr(4, 2), sYmd.substr(6, 2)].join(".") + ".";
	}
}

/**
 * @description 비밀번호 패턴 확인
 * @param : password			- 비밀번호
 * @param : bNoShowMessage		- 오류 메시지 출력 여부
 * @return : boolean
 */
this.fnCheckPasswordPattern = function(password, bNoShowMessage){
	password = this.smfStr(password);
	if(this.smfIsNull(bNoShowMessage)) bNoShowMessage = false;
	
	message = "VPN패스워드는 숫자,영문자,특수문자 조합하여 입력하세요.";

	if(!this.fnPswdFilter(password, bNoShowMessage)){
		return false;
	}
	
	//영문자찾기
	if(!password.match(/[a-z]|[A-Z]/g)){
		if(bNoShowMessage == false){
			this.smfLiteralAlert(message);
		}
		return false;
	}

	//숫자찾기
	if(!password.match(/[0-9]/g)){
		if(bNoShowMessage == false){
			this.smfLiteralAlert(message);
		}
		return false;
	}

	//특수문자 찾기
	if(!password.match(/[^\w]/g)){
		if(bNoShowMessage == false){
			this.smfLiteralAlert(message);
		}
		return false;
	}

	return true;
}

/**
 * @description 비밀번호 필터
 * @param : password			- 비밀번호
 * @param : bNoShowMessage		- 오류 메시지 출력 여부
 * @return : boolean
 */
this.fnPswdFilter = function(password, bNoShowMessage){
	password = this.smfStr(password);
	if(this.smfIsNull(bNoShowMessage)) bNoShowMessage = false;
	
	if(password.indexOf("%") != -1){
		if(bNoShowMessage == false){
			this.smfLiteralAlert('비밀번호에 "%" 문자는 사용할 수 없습니다.');
		}
		return false;
	}
	
	if(password.indexOf('\'') != -1 || password.indexOf('\"') != -1){
		if(bNoShowMessage == false){
			this.smfLiteralAlert('비밀번호에 작은따옴표 [\'] 또는 큰따옴표 [\"]는 사용할 수 없습니다.');
		}
		return false;
	}
	
	return true;
}

/**
 * @description 비밀번호 확인
 * @param : obj			- 비밀번호 입력 및 확인 오브젝트
   */
this.fnPswdChk = function(obj){
	var ret = false;
	if(obj.id == 'edtVpnPswd'){
		if(obj.value && obj.value.length > 0){
			var lastChr = this.smfRight(obj.value, 1);
			if(this.fnCheckPasswordPattern(obj.value, true)){
				this.divCoaPrge.form.staVpnPswd01.set_text('적합');
				ret = true;
			}else{
 				if(!this.fnPswdFilter(obj.value)) obj.set_value(this.fvPswdOld);
				this.divCoaPrge.form.staVpnPswd01.set_text('부적합');
			}
			this.divCoaPrge.form.staVpnPswd00.set_text(lastChr);
		}else{
			this.divCoaPrge.form.staVpnPswd00.set_text('');
		}
		
		if(this.divCoaPrge.form.edtVpnPswdIdnty.value == obj.value){
			this.divCoaPrge.form.staVpnPswdIdnty01.set_text('일치');
		}else{
			this.divCoaPrge.form.staVpnPswdIdnty01.set_text('불일치');
		}
	}else if(obj.id == 'edtVpnPswdIdnty'){
		if(obj.value && obj.value.length > 0){
			if(this.divCoaPrge.form.edtVpnPswd.value == obj.value){
				this.divCoaPrge.form.staVpnPswdIdnty01.set_text('일치');
				ret = true;
			}else{
				this.divCoaPrge.form.staVpnPswdIdnty01.set_text('불일치');
			}
			this.divCoaPrge.form.staVpnPswdIdnty00.set_text(this.smfRight(obj.value, 1));
		}else{
			this.divCoaPrge.form.staVpnPswdIdnty00.set_text('');
		}
	}
	
	return ret;
}

