    <Script type="xscript5.1"><![CDATA[/**
 *	대입전형자료원격업무신청서비스
 *	@MenuPath	대입전형-전형자료원격업무신청서비스-전형자료원격업무신청서비스신청
 *	@FileName 	uds_ueuum00_p00.xfdl
 *	@Creator 	김정민
 *	@CreateDate	2023.05.03 
 *	@Desction	
 ************** 소스 수정 이력 ***********************************************
 *	date			Modifier			Description
 *******************************************************************************
 *	2023.05.03		김정민				최초 생성
 *******************************************************************************
 */

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::uds_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvIsCoaSvcAplyPsl = false;
this.fvPswdOld = '';
this.fvParams = null;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Div 초기화
	this.smfInitForm(obj);

	// 초기화
	this.fnInit(obj);

	// 공통코드 조회
	this.smfCodeList("code", [this.dsRcritScCd])
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			//수시, 정시 순서로 sort
			this.dsRcritScCd.set_keystring('S:-unyCdValue');
			
			//전체 추가
			var nRow = this.dsRcritScCd.addRow();
			this.dsRcritScCd.setColumn(nRow, 'unyCdValue', 0);
			this.dsRcritScCd.setColumn(nRow, 'unyCdValueNm', '전체');
			this.dsRcritScCd.applyChange();
			
			//파일 업로드 다운로드 초기화
			this.fnInitFile(obj);
		});
	
	// 조회 입력창에서 'Ctrl' + 'Enter' 키 입력시 조회수행 이벤트 설정
	this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
};

/**
 * @description 폼 닫기전 이벤트
 */
this.fnOnbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	// 변경내역이 발생한 경우 종료전 confirm수행
	return this.smfCloseFormConfirm([this.dsMain]);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/**
 * @description 조회
 */
this.fnSearch = function(callback)
{
	this.smfSearchService('listRemWrkReqs')
		.confirmIfModifiedDataset(this.dsMain)   // 데이터가 변경되었으면 확인메시지
		.validateForm(this.divSearch)            // 폼 유효성검사
		.command(function(next){
			this.btnNew.set_enable(false);
			next();
		})
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			//마지막 신청서가 승인, 반려일 때 신규 버튼 활성화
			if(this.dsMain.getRowCount() == 0){
				this.btnNew.set_enable(true);
				this.btnDdln.set_enable(false);
				this.divCoaPrge.form.btnScrtyWpldg.set_enable(false);
				this.divCoaPrge.form.btnReqsInq.set_enable(false);
				this.divCoaPrge.form.divUpload.form.btnReqsAdd.set_enable(false);
				this.divCoaPrge.form.btnReqsDel.set_enable(false);
			}else{
				var nRow = this.dsMain.findRowExpr(this.udsfGetConditionFormat('lastYn == {0}', 'Y'));
				if(nRow > -1){
					var atrzStsCd = this.dsMain.getColumn(nRow, 'atrzStsCd');
					//4: 승인, 3: 반려 상태일 때 신규 버튼 활성화
					if(atrzStsCd == '4' || atrzStsCd == '3'){
						this.btnNew.set_enable(true);
					}
					
					//row idx 이동 ( UI )
					this.grdMain.setCellPos(1, nRow);
					this.grdMain.redrawExprCell();
				}
			}
			
			if(this.smfIsFunc(callback)) callback.call(this);
		});
};

/**
 * @description 대입기준 기본조회
 */
this.fnSelectCoaCtr = function(callback)
{
	this.smfSearchService('selectCoaCtr')
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.smfIsFunc(callback)) callback.call(this);
		});
};

/**
 * @description 신청서 저장 유효성 확인
 */
this.fnValidate = function(callback){
	if(!this.smfValidate(this.divCoaPrge)) return false;
	
	if(!this.fnCheckPasswordPattern(this.dsMain.getColumn(this.dsMain.rowposition, 'vpnPswd'))){
		this.divCoaPrge.form.edtVpnPswdIdnty.setFocus(true, false);
		return false;
	}
	
	if(this.dsMain.getColumn(this.dsMain.rowposition, 'vpnPswd') != this.divCoaPrge.form.edtVpnPswdIdnty.value){
		this.smfAlert('VPN패스워드와 VPN패스워드확인이 일치하지 않습니다.');
		return false;
	}
	
	if(this.dsMain.rowcount == 0){
		this.smfAlert('원격업무 신청서를 저장할 데이터가 없습니다.')
		return false;
	}
	
	if(this.smfIsUpdate(this.dsMain) != true && !this.divFileUpload.form.fnIsExistUploadFile()){
		//변경없음
		this.smfAlert('변경된 데이터가 없어서 원격업무 신청서를 저장할 수 없습니다.')
		return false;
	}
	
	if(this.smfIsNull(this.dsMain.getColumn(this.dsMain.rowposition, 'useBgngYmd')) || this.smfIsNull(this.dsMain.getColumn(this.dsMain.rowposition, 'useEndYmd'))){
		this.smfAlert('VPN이용기간은 필수입니다.')
		return false;
	}
	
	if(this.smfIsFunc(callback)) callback.call(this);
	
	return true;
}

/**
 * @description 신청서 저장
 */
this.fnSaveRemWrkReqs = function(callback){
	//사용기간 설정
	/*
	var coaRcritScCd = this.dsMain.getColumn(this.dsMain.rowposition, 'coaRcritScCd');
	if(coaRcritScCd == '0'){ //전체
		this.dsMain.setColumn(this.dsMain.rowposition, 'useBgngYmd', this.dsCoaCtr.getColumn(0, 'rcritScByBgngYmd'));
		this.dsMain.setColumn(this.dsMain.rowposition, 'useEndYmd', this.dsCoaCtr.getColumn(0, 'rcritScByEndYmd'));
	}else if(coaRcritScCd == '1'){ //수시
		this.dsMain.setColumn(this.dsMain.rowposition, 'useBgngYmd', this.dsCoaCtr.getColumn(0, 'rcritScByBgngYmdNsche'));
		this.dsMain.setColumn(this.dsMain.rowposition, 'useEndYmd', this.dsCoaCtr.getColumn(0, 'rcritScByEndYmdNsche'));			
	}else if(coaRcritScCd == '2'){ //정시
