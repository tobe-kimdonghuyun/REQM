{
	var objDiv = obj._divUploadObj;
	var sFileGbnValueOrg = objDiv._FileGbnValue;
	
	if(!this.smfIsNull(sFileGbnValueOrg))
	{
		// 2022-12-23 삭제처리가 실패시(유저의 취소 포함) 삭제를 피하기 위해 내부에서 작세하도록 변경
		this.divFileUpload.form.fnDeleteFileFromFileGbnValue(sFileGbnValueOrg, objDiv);

		if(this.dsMain.rowposition > -1){
			this.dsMain.setColumn(this.dsMain.rowposition, 'fileRefrnId', '');
