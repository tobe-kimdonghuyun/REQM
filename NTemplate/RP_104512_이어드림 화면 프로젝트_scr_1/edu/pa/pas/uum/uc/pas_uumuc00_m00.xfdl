/**
 * @description 새로운 신청서 만든다.
 * @return String
 */ 
this.fnNewReqs = function(){
	var ds = this.dsMain;
	var today = this.smfToday();
	var nRow = ds.addRow();
	
	this.divCoaPrge.form.chkScrtyWpldgAgreYn.set_value(false);
	
	ds.setColumn(nRow, 'userDtcNo', this.fnGetUserDtcNo());
	//ds.setColumn(nRow, 'remWrkAplySn', '1');
	ds.setColumn(nRow, 'userId', this.fnGetUserId());
	ds.setColumn(nRow, 'usePslYn', 'Y');
	//접속그룹코드 - 3이 대학 인데, LDAP에 1이라고 해야 접속가능
	ds.setColumn(nRow, 'userCntnGrpCd', '1'); 
	ds.setColumn(nRow, 'pswdChgCtrValue', '90'); //90일	
	ds.setColumn(nRow, 'pswdLastChgYmd', today);
	
	//ds.setColumn(nRow, 'useBgngYmd', today);
	//ds.setColumn(nRow, 'useEndYmd', this.smfAddDate(today, 90));
	ds.setColumn(nRow, 'useBgngYmd', this.dsCoaCtr.getColumn(0, 'coaSvcAplyBgngYmd'));
	ds.setColumn(nRow, 'useEndYmd', this.dsCoaCtr.getColumn(0, 'coaSvcAplyEndYmd'));
	
	ds.setColumn(nRow, 'apsDtcNo', this.fnGetUserDtcNo());
	ds.setColumn(nRow, 'atrzStsCd', '');
	ds.setColumn(nRow, 'coaAyr', this.dsSearch.getColumn(0, 'coaAyr'));
	ds.setColumn(nRow, 'userNm', this.fnGetUserNm());
	ds.setColumn(nRow, 'orgNm', this.fnGetOrgNm());
	
	this.btnNew.set_enable(false);
}


/**
 * @description 오즈 뷰 호출
 * @param : aData - 오즈 데이터 배열 ( csv )
 */
this.fnShowOzReport = function(aData){
	var objButton = { "toolbar.save"              : "true"    // 저장 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)           
	                , "toolbar.addmemo"           : "false"    // 메모 추가 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
	                , "toolbar.savedm"            : "false"    // 데이터 모듈 저장 아이콘의 표시 여부 및 비활성화 여부를 설정합니다.(true,false,disable)
	                }

	//훈령에따른 reportName 분기

	var reportName = "edu/pa/pas/uum/uc/pas_uumuc00_r00.ozr";
	var reports = aData.reduce((a,v,i) => {
		a.push({
			// 기본데이터
			  displayname	: "원격업무(VPN)신청서 및 보안서약서"   // [필수] 멀티리포트시 Tree에 보여줄 이름
			, reportname	: reportName // [필수] 리포트명  "/jsonsample.ozr"
			, jsonParam	: ["viewerType=HTML5 Canvas Viewer 1"]
			, csvData    : v.csv                               // [선택] csv데이터
			, security		: "N"	// [선택] 위변조방지 삽입   ("Y"(default):표시,"N":비표시)
			, voiceBarcode	: "N"	// [선택] 보이스바코드 삽입 ("Y"(default):표시,"N":비표시)		
			, zoom : "100"   // [선택] 보고서 화면의 비율을 백분율로 설정(default:"100")
		});
		return a;
	}, []);
		
	var oOzOption = {
		  'reports' : reports
		, 'zoom' : 75
		, 'reportloadevent' : function(obj,sDisplayName){
		
		}    // [선택] 레포트 로드된 이후 불려지는 함수(인쇄시에도 발생)
		, button : objButton    // [선택] 버튼의 표시 비표시를 통제
		, addParam : [
						{"paramkey":"export.format"      ,"paramvalue":"pdf"           }   // 저장하려는 머지PDF파일의 종류
						,{"paramkey":"export.filename"    ,"paramvalue":"원격업무(VPN)신청서 및 보안서약서" }   // 저장하려는 머지PDF파일명
					 ]
	}
	
	this.smfReportView(this, "popup", oOzOption, function(){ trace("===> popupcallback"); });
}

this.fnGetPttTelNo = function(psValue) {
	if (this.smfIsNull(psValue)) return '';

	var vsPttTelNo = Array(3);
	vsPttTelNo[0] = "";
	vsPttTelNo[1] = "";
	vsPttTelNo[2] = "";
	
	psValue = psValue.trim().replace(/[^0-9]/g, "");
	psValue = psValue.substr(0, 11); //숫자 11자리만
	var vslength = psValue.length;
	var vsSeoulYn = false;
	
	/**
	 * 서울 02  경기 031 인천 032 강원 033
	 * 충남 041 대전 042 충북 043 부산 051
	 * 울산 052 대구 053 경북 054 경남 055
	 * 전남 061 광주 062 전북 063 제주 064
	 */
	//서울만 국번이 2자리
	if (psValue.substr(0, 2) == "02") vsSeoulYn = true;
	
	if (vsSeoulYn) {
		if (vslength <= 2) {
			vsPttTelNo[0] = psValue;
			vsPttTelNo[1] = "";
			vsPttTelNo[2] = "";
		} else if (vslength == 3) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 1);
			vsPttTelNo[2] = "";
		} else if (vslength == 4) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 2);
			vsPttTelNo[2] = "";
		} else if (vslength == 5) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 3);
			vsPttTelNo[2] = "";
		} else if (vslength == 6) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 4);
			vsPttTelNo[2] = "";
		} else if (vslength == 7) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 4);
			vsPttTelNo[2] = psValue.substr(6, 1);
		} else if (vslength == 8) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 2);
			vsPttTelNo[2] = psValue.substr(4, 4);
			//------------------------------------------
		} else if (vslength == 9) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 3);
			vsPttTelNo[2] = psValue.substr(5, 4);
		} else if (vslength == 10) {
			vsPttTelNo[0] = psValue.substr(0, 2);
			vsPttTelNo[1] = psValue.substr(2, 4);
			vsPttTelNo[2] = psValue.substr(6, 4);
		} else if (vslength == 11) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 4);
			vsPttTelNo[2] = psValue.substr(7, 4);
		} else {
			vsPttTelNo[0] = "";
			vsPttTelNo[1] = "";
			vsPttTelNo[2] = "";
		}
	} else {
		if (vslength <= 2) {
			vsPttTelNo[0] = psValue;
			vsPttTelNo[1] = "";
			vsPttTelNo[2] = "";
		} else if (vslength == 3) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = "";
			vsPttTelNo[2] = "";
		} else if (vslength == 4) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 1);
			vsPttTelNo[2] = "";
		} else if (vslength == 5) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 2);
			vsPttTelNo[2] = "";
		} else if (vslength == 6) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 3);
			vsPttTelNo[2] = "";
		} else if (vslength == 7) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 4);
			vsPttTelNo[2] = "";
		} else if (vslength == 8) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 1);
			vsPttTelNo[2] = psValue.substr(4, 4);
		} else if (vslength == 9) { //없는전화번호
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 2);
			vsPttTelNo[2] = psValue.substr(5, 4);
		} else if (vslength == 10) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 3);
			vsPttTelNo[2] = psValue.substr(6, 4);
		} else if (vslength == 11) {
			vsPttTelNo[0] = psValue.substr(0, 3);
			vsPttTelNo[1] = psValue.substr(3, 4);
			vsPttTelNo[2] = psValue.substr(7, 4);
		} else {
			vsPttTelNo[0] = "";
			vsPttTelNo[1] = "";
			vsPttTelNo[2] = "";
		}
	}
	
	
	return vsPttTelNo.filter((v) => !this.smfIsNull(v)) .join("-");
}

