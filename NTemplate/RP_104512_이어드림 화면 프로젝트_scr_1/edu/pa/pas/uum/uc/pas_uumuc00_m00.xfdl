		this.dsMain.setColumn(this.dsMain.rowposition, 'useEndYmd', this.dsCoaCtr.getColumn(0, 'rcritScByEndYmdSche'));			
	}
	*/
	
	this.dsMain.set_updatecontrol(false);
	this.dsMain.setRowType(this.dsMain.rowposition, "U");
	this.dsMain.set_updatecontrol(true);

	this.smfSaveService('saveRemWrkReqs')
		.showConfirm(false)
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			var remWrkAplySn = this.dsRemWrkReqsRlt.getColumn(0, 'remWrkAplySn');
			this.dsMain.setColumn(this.dsMain.rowposition, 'remWrkAplySn', remWrkAplySn);
			this.dsMain.applyChange();
			
			this.smfAlert("자료의 저장이 완료되었습니다.",  function(){
				if(this.smfIsFunc(callback)) callback.call(this);
			});
		});
}

/**
 * @description 신청서 삭제
 */
this.fnDeleteRemWrkReqs = function(callback){
	this.smfConfirm("원격업무 신청서를 삭제하시겠습니까?",  function(confirmParams){
		if(confirmParams.confirmResult){
			this.dsMain.setColumn(this.dsMain.rowposition, '_chk', '1');
			this.dsMain.set_updatecontrol(false);
			this.dsMain.setRowType(this.dsMain.rowposition, "U");
			this.dsMain.set_updatecontrol(true);
			
			var rowType = this.dsMain.getRowType(this.dsMain.rowposition)
			
			// 삭제 서비스
			this.smfDeleteService("deleteRemWrkReqs")
				.showConfirm(false)
				.requireExistsData(this.dsMain) //데이터 존재 필수
				.validateGridDelete(this.grdMain) // 그리드삭제처리
				.run()
				.callback(function(callbackParams){
					if(callbackParams.errors) return;
					this.fnSearch(function(){
						this.smfAlert("PA020", [],  function(){
							
						}); // 삭제가 완료되었습니다.
					});
				}); // 콜백
				
			if(rowType == '2'){ //Dataset.ROWTYPE_INSERT 2 추가된 행의 상태
				this.fnSearch();
			}
		}
	});
}

/**
 * @description 신청서 마감
 */
this.fnExecuteRemWrkReqsDdln = function(searchForce){
	this.smfConfirm("마감하시겠습니까?",  function(confirmParams){
		if(confirmParams.confirmResult){
			this.dsMain.set_updatecontrol(false);
			this.dsMain.setRowType(this.dsMain.rowposition, "U");
			this.dsMain.set_updatecontrol(true);
			this.smfSaveService('executeRemWrkReqsDdln')
				.showConfirm(false)
				.requireExistsData(this.dsMain)   // 데이터 존재 필수
				.run()
				.callback(function(callbackParams){
					if(callbackParams.errors){
						this.dsMain.set_updatecontrol(false);
						this.dsMain.setRowType(this.dsMain.rowposition, 1); //Dataset.ROWTYPE_NORMAL 1 초기 행의 상태 
						this.dsMain.set_updatecontrol(true);
						return;
					}
					
					this.smfAlert("마감되었습니다.",  function(){
						this.fnSearch();
					});
				});
		}else{
			if(searchForce) this.fnSearch();
		}
	});
}

