    <Script type="xscript5.1"><![CDATA[/**
 *	대입전형자료원격업무신청서비스
 *	@MenuPath	대입전형-전형자료원격업무신청서비스-전형자료원격업무신청서비스신청
 *	@FileName 	uds_ueuum00_p00.xfdl
 *	@Creator 	김정민
 *	@CreateDate	2023.05.03
 *	@Desction	
 ************** 소스 수정 이력 ***********************************************
 *	date			Modifier			Description
 *******************************************************************************
 *	2023.05.03		김정민				최초 생성
 *******************************************************************************
 */

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::uds_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvUserId = '';		//조회한 사용자 아이디
this.fvCertUserId = ''; //인증서 선택한 사용자 아이디

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Div 초기화
	this.smfInitPopup(obj);
	
	// 초기화
	this.fnInit(obj);
};

/**
 * @description 폼 닫기전 이벤트
 */
this.fnOnbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
};

/**
 * 팝업의 콜백함수 지정한다 (공동인증서)
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	var sLog = "";
	var obj = sender.divCoaPrge.form;

	if(e.result){
		if(this.isNotNil(e.data.certDtcNm)){
			this.fnCallbackConfirmAuth(obj, e.data);
		}
	} else {
		var alertMsg = e.data.resMsg;
		if(this.isNotNil(e.data.resultCode)){
			alertMsg += "\n(" + e.data.resultCode + ")";
		}
		
		if(this.isNotNil(alertMsg)){
			this.smfLiteralAlert(alertMsg);
		}
	}
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/**
 * @description 조회
 */
this.fnSearch = function()
{
// 조회 하지 않고 고정으로 한다.
	this.smfSearchService('selectUserInfo')
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.dsMain.getRowCount() > 0){
				this.smfAlert('정상적으로 조회되었습니다.');
				
				this.fvUserId = this.dsMain.getColumn(0, 'userId');
				//사용자 정보 저장
				this.dsSearch.setColumn(0, 'brno', this.dsMain.getColumn(0, 'brno'));
				this.dsSearch.setColumn(0, 'userDtcNo', this.dsMain.getColumn(0, 'userDtcNo'));
			}else{
				this.divCoaPrge.form.edtUserId.setFocus();
				this.smfAlert('등록되지 않았거나 사용기간이 종료 혹은 사용중지된 사용자입니다.');
			}
		});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/**
 * @description 초기화 FUNCTION
 */
this.fnInit = function(obj){
}

/**
 * @class 로그인(공동인증서)를 실행한다.	
 * @example
 */
// prForm.smfExecNpkiAuth = function(objParam)
this.fnExecNpkiAuth = function(objParam){
	var objFuncCallback   = objParam.popupcallback;
	var objForm = objParam.objForm;
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: objFuncCallback, // 콜백함수 지정
		sender: objForm, // sender 지정
		titlebar:false,  // 타이틀바를 표시하지 않는다.
		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정(필수)
			procType : "none",  // "none","search","insert","update","delete"
			loginInfo : objParam.loginInfo
		}
	};

	// 모달팝업 실행
	this.smfDialog("_auto", "pa_pas_uum_cm::pas_uumcm00_m01.xfdl", popupParams);
};

/**
 * 인증후처리
 * @param : obj
 */
this.fnCallbackConfirmAuth = function(obj, data){
	this.dsSearch.setColumn(0, "certDtcNmTmpr", data.certDtcNm);
	this.dsSearch.setColumn(0, "serialNumberTmpr", data.serialNumber);
	this.dsSearch.setColumn(0, "reqChannelAndLgnMsg", data.reqChannelAndLgnMsg);

	//인증서 검증
	this.smfExecuteService('executeCertVrfc')
 		.showConfirm(false)
		.run()
 		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.dsCertVrfc.getColumn(0, 'resultCode') == 'success'){
				this.dsSearch.setColumn(0, "certDtcNm", data.certDtcNm);
				this.dsSearch.setColumn(0, "serialNumber", data.serialNumber);
				
				this.smfAlert('변경할 인증서 정보조회 성공하였습니다.');
			}else{
				this.smfAlert(this.dsCertVrfc.getColumn(0, 'errorMesg'));
			}
 		});
		
	//obj.btnCertChc.set_enable(true);

};

this.fnUserIdChc = function(){
	if (this.smfIsNull(this.fvUserId) || this.fvUserId != this.dsSearch.getColumn(0, "userId")){
		this.divCoaPrge.form.edtUserId.setFocus();
		this.smfAlert('인증서를 변경할 사용자 아이디를 조회 후 선택하십시오.');
		return false;
	}
	
	return true;
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
//아이디 조회
this.divCoaPrge_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (this.smfIsNull(this.dsSearch.getColumn(0, "userId"))){
		this.divCoaPrge.form.edtUserId.setFocus();
		this.smfAlert("CM006", ["사용자 아이디"]);
		return;
	}
	
	//인증서 정보 초기화
	this.dsSearch.setColumn(0, 'certDtcNm', null);
	this.dsSearch.setColumn(0, 'serialNumber', null);
	this.dsSearch.setColumn(0, 'certDtcNmTmpr', null);
	this.dsSearch.setColumn(0, 'serialNumberTmpr', null);
	this.dsSearch.setColumn(0, 'reqChannelAndLgnMsg', null);

	this.fnSearch();
};

//인증서 선택
this.divCoaPrge_btnCertChc_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(!this.fnUserIdChc()) return;
	
	var sBaseUrl = nexacro.getEnvironment().services["baseUrl"].url;
	var sInitUrl  = sBaseUrl + "/pas_uum_cm00_001.do";
	var sLoginUrl = sBaseUrl + "/pas_uum_cm00_002.do";
	var objLoginInfo = {	initUrl  : sInitUrl    // init시 사용하는 서비스명(앞에 "/"을 붙일 것)
						,   loginUrl : sLoginUrl   // login시 사용하는 서비스명(앞에 "/"을 붙일 것)
						//,	userId : userId
					   };
	var objParam = {objForm:this, popupcallback :this.fnPopupCallback, loginInfo:objLoginInfo};
	this.fnExecNpkiAuth(objParam);
};

//인증서변경실행
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(!this.fnUserIdChc()) return;
	
	if(this.smfIsNull(this.dsSearch.getColumn(0, 'certDtcNm'))){
		this.smfAlert('변경할 인증서를 선택하십시오.');
		return;
	}

	//인증서변경실행
	this.smfExecuteService('executeCertChg')
 		.showConfirm(false)
		.run()
 		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.smfAlert('인증서변경에 성공하였습니다.', function(){
				this.close(true);
			});
 		});
};

//취소
this.btnRtrcn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};

this.divCoaPrge_edtUserId_onkeyup = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if (e.keycode == 13){
		this.divCoaPrge_btnSearch_onclick(null, null);
	}
};
]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">selectUserInfo</Col>
            <Col id="url">/pas_uum_cm00_200.do</Col>
            <Col id="inDatasets">dsSearch</Col>
            <Col id="outDatasets">dsMain</Col>
          </Row>
          <Row>
            <Col id="id">executeCertVrfc</Col>
            <Col id="url">/pas_uum_cm00_201.do</Col>
            <Col id="inDatasets">dsSearch</Col>
            <Col id="outDatasets">dsCertVrfc</Col>
          </Row>
          <Row>
            <Col id="id">executeCertChg</Col>
            <Col id="url">/pas_uum_cm00_202.do</Col>
            <Col id="inDatasets">dsSearch</Col>
            <Col id="outDatasets">dsCertChg</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" oncolumnchanged="dsSearch_oncolumnchanged" useclientlayout="false">
        <ColumnInfo>
          <Column id="userId" type="STRING" size="256"/>
          <Column id="userDtcNo" type="STRING" size="256"/>
          <Column id="certDtcNm" type="STRING" size="256"/>
          <Column id="serialNumber" type="STRING" size="256"/>
          <Column id="certDtcNmTmpr" type="STRING" size="256"/>
          <Column id="serialNumberTmpr" type="STRING" size="256"/>
          <Column id="reqChannelAndLgnMsg" type="STRING" size="256"/>
          <Column id="brno" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true" onload="dsMain_onload">
        <ColumnInfo>
          <Column id="_chk" type="STRING" size="1"/>
          <Column id="userId" type="STRING" size="256"/>
          <Column id="userDtcNo" type="STRING" size="256"/>
          <Column id="brno" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsCertVrfc" useclientlayout="true" onload="dsMain_onload">
        <ColumnInfo>
          <Column id="resultCode" type="STRING" size="256"/>
          <Column id="newCertKey" type="STRING" size="256"/>
          <Column id="newEltsCertValue" type="STRING" size="256"/>
          <Column id="newEltsCn" type="STRING" size="256"/>
          <Column id="serverCert" type="STRING" size="256"/>
          <Column id="errorMesg" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsCertChg" useclientlayout="true" onload="dsMain_onload">
        <ColumnInfo>
          <Column id="resultCode" type="STRING" size="256"/>
          <Column id="newCertKey" type="STRING" size="256"/>
          <Column id="newEltsCertValue" type="STRING" size="256"/>
          <Column id="newEltsCn" type="STRING" size="256"/>
          <Column id="serverCert" type="STRING" size="256"/>
          <Column id="errorMesg" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
