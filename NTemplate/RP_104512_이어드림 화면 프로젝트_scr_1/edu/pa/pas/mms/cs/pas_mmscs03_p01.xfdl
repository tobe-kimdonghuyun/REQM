    <Script type="xscript5.1"><![CDATA[// 화면 로딩 
this.pas_mmscs03_p02_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	var initValue = this.smfGetPopupParams();
	if(!this.smfIsNull(initValue.result) && !initValue.result){
		this.div00.form.titleResult.set_text("발급한 사실이 없습니다.");
	}
	this.div00.form.staCvlcptOfcrkNm.set_text(initValue.crtfNm);
	this.div00.form.mskIssuNum.set_value(initValue.vrcrMngIssuNo);
	this.div00.form.mskIssuDate.set_value(initValue.issuDt);
	this.div00.form.staIssuInstNm.set_text(initValue.issuInstNm);
	this.div00.form.edtIssuPrgeTelno.set_value(initValue.issuPrgeTelno);
};

// 확인
this.div00_btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
