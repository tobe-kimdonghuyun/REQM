  <Form id="pas_mmscs03_m04" width="1200" height="930" titletext="바코드스캐너로 확인방법" onload="pas_mmscs03_m04_onload" onsize="pas_mmscs03_m04_onsize">
    <Layouts>
      <Layout height="930" width="1200" screenid="ScreenDeskTopP">
        <Static id="sta00" taborder="0" text="바코드 스캐너로 확인방법" left="0" top="0" width="400" height="60" cssclass="font34B" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divSearch01" taborder="1" left="0" top="95" height="140" cssclass="div_SA" initvalueid="ivDivAccessibilityOff" right="0" formscrolltype="none">
          <Layouts>
            <Layout>
              <Static id="label00" taborder="0" text="해상도 300dpi 이상 지원이 가능한 평판 스캐너를 통하여 발급받은 증명서의 원본문서를 통해 진위여부 확인이 가능합니다." left="30" top="31" width="882" height="30" cssclass="sta_WF_HangTxt_blue" initvalueid="ivStcAccessibilityOn"/>
              <Static id="label00_02" taborder="1" text="평판 스캐너를 PC와 연결한 후 스캐너용 진위확인 프로그램을 다운로드하여 설치하고 발급받은 증명서를 스캔하여 원본문서와 대조합니다." left="30" top="73" width="972" height="30" cssclass="sta_WF_HangTxt_blue" initvalueid="ivStcAccessibilityOn" onclick="divSearch00_label00_02_onclick"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="label00" cssclass="sta_WF_HangTxt_blue_M" fittocontents="height" left="30" top="31" height="140" right="30"/>
              <Static id="label00_02" cssclass="sta_WF_HangTxt_blue_M" fittocontents="height" left="30" top="label00:13" height="140" right="30"/>
            </Layout>
          </Layouts>
        </Div>
