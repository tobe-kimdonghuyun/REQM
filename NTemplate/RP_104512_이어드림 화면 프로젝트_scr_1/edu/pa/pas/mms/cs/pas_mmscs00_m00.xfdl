    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 온라인 민원현황
*  @MenuPath    pa_pas_mms_cs
*  @FileName 	pas_mmscs02_m01.xfdl
*  @Creator 	최민진
*  @CreateDate 	2022.8.18
*  @Desction    공지사항 목록조회
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.5.12     	홍길동 	        최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs";

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
var sPostfix= "";
var eHeight = 10;
var statSelected1 = true;
var statSelected2 = false;
var statSelected3 = false;
var statSelected4 = false;
this.pa_pas_mmscs00_m00_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	if(this.smfIsMobile()){
		sPostfix = "_M";
	}
	
	statSelected1 = true;
	statSelected2 = false;
	statSelected3 = false;
	statSelected4 = false;
	this.setTabBtnSelected();
	
	var nHeight = this.divTabpage.form.grd00.getOffsetBottom();
	this.divTabpage.setOffsetHeight(nHeight+eHeight);
	
	this.divTabpage.form.grd00.clearSelect();
};

this.divTab_btnTab1_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divTabpage.set_url("pa_pas_mms_cs::pas_mmscs00_m01.xfdl");
	this.divTabpage.form.grd00.clearSelect();
	
	this.divTab.form.btnTab1.set_cssclass("btn_WF_tab"+sPostfix+"_S");
	this.divTab.form.btnTab2.set_cssclass("btn_WF_tab"+sPostfix);
	this.divTab.form.btnTab3.set_cssclass("btn_WF_tab"+sPostfix);
	this.divTab.form.btnTab4.set_cssclass("btn_WF_tab"+sPostfix);
	
	statSelected1 = true;
	statSelected2 = false;
	statSelected3 = false;
	statSelected4 = false;
	this.setTabBtnSelected();
	
	var nHeight = this.divTabpage.form.grd00.getOffsetBottom();
	this.divTabpage.setOffsetHeight(nHeight+eHeight);
	this.smfResetScroll(this);
};

this.divTab_btnTab2_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divTabpage.set_url("pa_pas_mms_cs::pas_mmscs00_m02.xfdl");
	this.divTabpage.form.grd00.clearSelect();
	
	this.divTab.form.btnTab1.set_cssclass("btn_WF_tab"+sPostfix);
	this.divTab.form.btnTab2.set_cssclass("btn_WF_tab"+sPostfix+"_S");
	this.divTab.form.btnTab3.set_cssclass("btn_WF_tab"+sPostfix);
	this.divTab.form.btnTab4.set_cssclass("btn_WF_tab"+sPostfix);
	
	statSelected1 = false;
	statSelected2 = true;
	statSelected3 = false;
	statSelected4 = false;
	this.setTabBtnSelected();
		
	var nHeight = this.divTabpage.form.grd00.getOffsetBottom();
	this.divTabpage.setOffsetHeight(nHeight+eHeight);
	this.smfResetScroll(this);
};

this.divTab_btnTab3_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divTabpage.set_url("pa_pas_mms_cs::pas_mmscs00_m03.xfdl");
	this.divTabpage.form.grd00.clearSelect();
	
	this.divTab.form.btnTab1.set_cssclass("btn_WF_tab"+sPostfix);
	this.divTab.form.btnTab2.set_cssclass("btn_WF_tab"+sPostfix);
	this.divTab.form.btnTab3.set_cssclass("btn_WF_tab"+sPostfix+"_S");
	this.divTab.form.btnTab4.set_cssclass("btn_WF_tab"+sPostfix);

	statSelected1 = false;
	statSelected2 = false;
	statSelected3 = true;
	statSelected4 = false;
	this.setTabBtnSelected();

	var nHeight = this.divTabpage.form.grd00.getOffsetBottom();
	this.divTabpage.setOffsetHeight(nHeight+eHeight);
	this.smfResetScroll(this);
};

this.divTab_btnTab4_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divTabpage.set_url("pa_pas_mms_cs::pas_mmscs00_m04.xfdl");
	this.divTabpage.form.grd00.clearSelect();
	
	this.divTab.form.btnTab1.set_cssclass("btn_WF_tab"+sPostfix);
	this.divTab.form.btnTab2.set_cssclass("btn_WF_tab"+sPostfix);
	this.divTab.form.btnTab3.set_cssclass("btn_WF_tab"+sPostfix);
	this.divTab.form.btnTab4.set_cssclass("btn_WF_tab"+sPostfix+"_S");
	
	statSelected1 = false;
	statSelected2 = false;
	statSelected3 = false;
	statSelected4 = true;
	this.setTabBtnSelected();
	
	var nHeight = this.divTabpage.form.grd00.getOffsetBottom();
	this.divTabpage.setOffsetHeight(nHeight+eHeight);
	this.smfResetScroll(this);
};

this.btnLink_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//nexacro.open("link", "https://www.gov.kr", this.getOwnerFrame()); // todo 링크 잘 뜨는지 확인 
	system.execBrowser("https://www.gov.kr");
};

this.divTab_btnTab_onkillfocus = function(obj:nexacro.Button,e:nexacro.KillFocusEventInfo)
{
	this.setTabBtnSelected();
};

this.divTab_btnTab_onmouseleave = function(obj:nexacro.Button,e:nexacro.MouseEventInfo)
{
	this.setTabBtnSelected();
};

this.divTab_btnTab_onmousemove = function(obj:nexacro.Button,e:nexacro.MouseEventInfo)
{
	this.setTabBtnSelected();
};

this.divTab_btnTab_onsetfocus = function(obj:nexacro.Button,e:nexacro.SetFocusEventInfo)
{
	this.setTabBtnSelected();
};

this.setTabBtnSelected = function() {
	this.divTab.form.btnTab1._setAccessibilityStatSelected(statSelected1);
	this.divTab.form.btnTab2._setAccessibilityStatSelected(statSelected2);
	this.divTab.form.btnTab3._setAccessibilityStatSelected(statSelected3);
	this.divTab.form.btnTab4._setAccessibilityStatSelected(statSelected4);
};
]]></Script>
