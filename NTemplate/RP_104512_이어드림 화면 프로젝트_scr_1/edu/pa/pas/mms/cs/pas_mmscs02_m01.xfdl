    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 민원실 목록조회
*  @MenuPath    pa_pas_mms_cs
*  @FileName 	pas_mmscs02_m01.xfdl
*  @Creator 	최민진
*  @CreateDate 	2022.8.18
*  @Desction    민원실 목록조회
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.8.18     	최민진				최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs";

//0501 CF 일괄등록
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.DivInfo = {};     // Q & A 항목 정보 
this.fvTitleHeight = this.smfIsMobile()?104:79; // 디폴트 높이
this.fvContentsHeight = this.smfIsMobile()?292:150; // 디폴트 높이
this.fvContentsWidth = this.smfIsMobile()?400:747; // 디폴트 높이

this.fv_prefixIdTitleDiv = "divTitle";
this.fv_prefixIdAreaStatic = "staArea";
this.fv_prefixIdTitleButton = "btnTitle";
this.fv_prefixIdOpenButton = "btnOpen";
this.fv_prefixIdHomeButton = "btnHome";
this.fv_prefixIdContentsDiv = "divContents";
this.fv_prefixIdContentsAddr = "staAddr";
this.fv_prefixIdContentsHmpgAddr = "staHmpgAddr";
this.fv_prefixIdContentsTelno = "staTelno";
this.fv_prefixIdContentsFxno = "staFxno";
this.fv_mofile = "";
if(this.smfIsMobile()){
	this.fv_mofile = "_M";
}

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.pas_mmscs02_m01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);

	// 공통코드의 코드구분
	this.smfCodeList("code", [this.dsLctnScCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;		
			this.dsLctnScCd.insertRow(0);
			this.dsLctnScCd.setColumn(0,"unyCdValue", "");
			this.dsLctnScCd.setColumn(0,"unyCdValueNm", "전체");
			
			this.divSearch.form.cboLctnScCd.set_index(0);
			// 페이지를 조회한다.
			this.fnSearch(obj, e);
		})		
		.run()
	;	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(obj, e)
{
	this.fnDeleteDiv();
	this.dsSearch.setColumn(0,"cddcScCd" , this.divSearch.form.cboLctnScCd.value);
	
	var sServiceId = "select";
	if(this.smfIsMobile()){
		sServiceId = "selectTemp";
	}

 	// 서비스 객체 생성
	this.smfSearchService(sServiceId)
		// 페이징처리
		.paginator(this.dsList, this.divPaging, this.divTotal, this.dsPageInfo, this.fnSearch, e)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(this.smfIsMobile()){
				this.dsList.appendData(this.dsListTemp);
				// 총 검색결과와 현재 검색 결과 수가 일치할 경우 [더보기]버튼 숨김 (TODO)
				if(this.dsPageInfo.getColumn(0, "totalCount")==this.dsList.getRowCount()){
					this.divPaging.set_visible(false);
				}else{
					this.divPaging.set_visible(true);
				}
			}
			var objTargetDivForm =  this.divGrid.form;
			for(var i=0;i<this.dsList.rowcount;i++){
				this.fnAppendDiv(objTargetDivForm,this.dsList, i);
			}
			this.smfResetScroll(this.divGrid.form);
			if(callbackParams.errors) return;
		});	
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * 하나의 게시글을 추가한다.
 * @param : {object}   scope  대상Form
 * @param : {object}   objDs  추가할 데이터셋
 * @param : {Number}   nRow   추가할 데이터셋의 row
 */
this.fnAppendDiv = function(scope,objDs,nRow)
{
	// 추가될 index를 구한다.
	// (기본적으로는 부모 Div에 있는 _count 유저프로퍼티 사용. 없으면 0으로 초기화)
	// todo 버튼 번호 다시 변경 
	var nIdx = 0;
	if(this.smfIsNull(scope.parent._count))
	{  // 세팅이 안되어 있으면 0으로 세팅
		nIdx = 0;
		scope.parent._count = 0;
	}
	else
	{
		nIdx = scope.parent._count;
	}
	
	// 타이틀 Div 만들기
	var objTitleDiv = this.fnAddTitleDiv(scope,nIdx,objDs,nRow);
	// 상세 Div만들기
	var objContentsDiv = this.fnAddContentsDiv(scope,nIdx,objDs,nRow);

	// 카운트 갯수를 증가시킨다.
	scope.parent._count++;
}

/**
 * TitleDiv를 추가한다.
 * @param : {object}   scope  대상Form
 * @param : {Number}   nIdx   추가할 div Index
 * @param : {object}   objDs  추가할 데이터셋
 * @param : {Number}   nRow   추가할 데이터셋의 row
 */
this.fnAddTitleDiv = function (scope,nIdx,objDs,nRow)
{
	var sDivId = this.fv_prefixIdTitleDiv + nIdx;
	var sKornOrgNm = objDs.getColumn(nRow,"kornOrgNm");
	var sUnyCdValueAbrvNm = objDs.getColumn(nRow,"unyCdValueAbrvNm");
	
	//===================================================================
	// Div 생성
	//===================================================================
	var nHeight = this.fvTitleHeight;
	var sBeforeContentsId = "divContents"+(nIdx-1);
	var sChildId = "divContents"+nIdx;
	var sDivCssClass = "div_grid_row"+this.fv_mofile;
	var sDivArrow = "btn_WF_iconClose"; // 버튼 
	
	var objDiv = scope[sDivId];
	
	if(!objDiv)
	{
		objDiv = new Div();
		if( nIdx==0 )
		{	// 최초의 오브젝트는 위의 Div의 Top을 0으로 한다
			objDiv.init(sDivId, 0, 0, null, nHeight, 0, null);	
		}else
		{   // 최초 Div이외의 것은 바로위의 오브젝트 바로아래에 생성한다. 
			objDiv.init(sDivId, 0, sBeforeContentsId +":"+ 0, null, nHeight, 0, null);
			//objDiv.init(sDivId, 0, (nIdx*nHeight), null, nHeight, 0, null);
		}

		// 만들어진 Div를 부모에 추가
		// Add Object to Parent Form  
		scope.addChild(sDivId, objDiv); 
		
		// Div의 속성을 세팅
		objDiv.set_cssclass(sDivCssClass);
		objDiv.set_initvalueid("ivDivAccessibilityOff");
		objDiv.childId = sChildId;
		objDiv.dirArrow = sDivArrow;
		
		// Div를 보이게 설정(addChild()하면 반드시 show()를 해주어야 실제로 화면에 보임)  
		objDiv.show(); 
	}
	
	// 지역명 버튼 넣기
	var areaButton = new Static();
	if(this.smfIsMobile()){
		areaButton.init("area"+nIdx, 18, 31, 90, 40, null, 0);		
	} else {
		areaButton.init("area"+nIdx, 30, 24, 70, 30, null, 0);		
	}
	areaButton.set_cssclass("sta_WF_roundBox_blue"+this.fv_mofile);
	areaButton.set_initvalueid("ivStcAccessibilityOn");
	areaButton.set_text(sUnyCdValueAbrvNm);
	objDiv.form.addChild("area"+nIdx, areaButton); 
	areaButton.show();
	
	//===================================================================
	// 타이틀문장(Static) 생성
	//===================================================================
	var sStaticId = this.fv_prefixIdTitleButton+nIdx;
	var objStatic = objDiv.form[sStaticId];
	if(!objStatic)
	{
		objStatic = new Button();
		if(this.smfIsMobile()){
			objStatic.init(sStaticId, 132, 27, 270, 48, null, 0);		
		} else {
			objStatic.init(sStaticId, 120, 24, 180, 30, null, 0);		
		}
		
		// 만들어진 Static을 Div에 추가
		objDiv.form.addChild(sStaticId, objStatic); 
		
		// Static의 속성 설정
		objStatic.set_initvalueid("ivBtnAccessibilityButton");
		objStatic.set_verticalAlign("middle");	
		if(this.smfIsMobile()){
			objStatic.set_cssclass("btn_font28M");
		} else {
			objStatic.set_cssclass("btn_font16M");
		}
		
		objStatic.dirArrow = sDivArrow;
		objStatic.childId = sChildId;
		
		// Static에 클릭이벤트 추가
		objStatic.addEventHandler("onclick",function(obj,e){
										this.fnReDraw(scope,obj,e,nIdx);
									}
									,this);
		objStatic.show();
	}
	objStatic.set_text(sKornOrgNm);
	objDiv.set_visible(true);
	
	// 홈 버튼 추가 
	this.fnCreateBtnHome(objDiv.form,sChildId,nIdx);
	
	// 질문Div에 오측 화살표버튼을 추가한다.
	this.fnCreateBtnOpen(objDiv.form,sChildId,nIdx);
};

/**
 * Contents Div를 추가한다.
 * @param : {object}   scope  대상Form
 * @param : {Number}   nIdx   추가할 div Index
 * @param : {object}   objDs  추가할 데이터셋
 * @param : {Number}   nRow   추가할 데이터셋의 row
 */
this.fnAddContentsDiv = function (scope,nIdx,objDs,nRow)
{
	var sDivId = this.fv_prefixIdContentsDiv + nIdx;
	var sPbsrcAddr = objDs.getColumn(nRow,"roadNmAddr");
	var sPbsrcHmpgAddr = objDs.getColumn(nRow,"hmpgAddr");
	var sPbsrcTelno = objDs.getColumn(nRow,"pbsrcTelno");
	var sPbsrcFxno = objDs.getColumn(nRow,"pbsrcFxno");

	//===================================================================
	// Div 생성
	//===================================================================
	var nHeight = this.fvContentsHeight;
	var sBeforeContentsId = this.fv_prefixIdTitleDiv + nIdx;
	var sChildId = this.fv_prefixIdContentsDiv+nIdx;
	var sDivCssClass = "div_grid_row_detail"+this.fv_mofile;	
	var sDivArrow = "btn_WF_iconOpen"+this.fv_mofile;

	// Create Object  
	var objDiv = scope[sDivId];
	if(!objDiv)
	{
		objDiv = new Div();
		//if(this.smfIsMobile()){
		//	objDiv.init(sDivId, 0, sBeforeContentsId +":"+ 0, null, nHeight, 0, null);
		//} else {
			objDiv.init(sDivId, 0, sBeforeContentsId +":"+ 0, null, nHeight, 0, null);
		//}
		

		// 만들어진 Div를 부모에 추가
		// Add Object to Parent Form  
		scope.addChild(sDivId, objDiv); 
		
		// Div의 속성을 세팅
		objDiv.set_cssclass(sDivCssClass);
		objDiv.set_initvalueid("ivDivAccessibilityOff");
		objDiv.childId = sChildId;
		objDiv.dirArrow = sDivArrow;
		
