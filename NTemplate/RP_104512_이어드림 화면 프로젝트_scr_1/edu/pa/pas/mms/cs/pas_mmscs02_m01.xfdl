/**
 * 홈 버튼 생성 (pc: 전화번호, mobile: 홈 버튼)
 * @param : scope ( Div.form)
 * @param : divInfo 
 */
this.fnCreateBtnHome = function(scope,sChildId,nIdx)
{
	if(!this.smfIsMobile()){
		//전화 번호 라벨 생성
		var sBtnTelno = "labelTelno"+nIdx;
		var objLabel = new Button();
		
		objLabel.init(sBtnTelno, null, 24, 31, 30, 260, null);
		
		objLabel.set_cssclass("btn_WF_labelCall"+this.fv_mofile);
		objLabel.set_initvalueid("ivBtnAccessibilityOff");
		objLabel.set_text("전화번호");
		scope.addChild(sBtnTelno, objLabel); 
		objLabel.show();
	
		//전화번호 입력
		var sBtnId = "staTelno"+nIdx;
		var objButton = new Static();
		
		objButton.init(sBtnId, null, 24, 127, 30, 122, 0);
	
		objButton.set_cssclass("font16R");
		objButton.set_initvalueid("ivStcAccessibilityOn");
		//objButton.set_accessibilitylabel("홈페이지이동");
		scope.addChild(sBtnId, objButton); 
	
// 		objButton.addEventHandler("onclick",function(obj,e){
// 			nexacro.open("cmmGridFilter", this.dsList.getColumn(nIdx,"pbsrcHmpgAddr")); // todo 화면 잘 뜨는지 테스트 
// 		},this);
	
		objButton.show();
		objButton.set_text(this.dsList.getColumn(nIdx,"pbsrcTelno"));
		
	}else{
		var sBtnId = "btnHome"+nIdx;
		var objButton = new Button();
		
		objButton.init(sBtnId, null, 36, 30, 30, 152, 0);
	
		objButton.set_cssclass("btn_WF_iconHome");
		objButton.set_initvalueid("ivBtnAccessibilityLink");
		objButton.set_accessibilitylabel("홈페이지이동");
		scope.addChild(sBtnId, objButton); 
	
		var sUrl = this.dsList.getColumn(nIdx,"hmpgAddr");
		trace("sUrl: " + sUrl);
	
		objButton.addEventHandler("onclick",function(obj,e){
			//nexacro.open("cmmGridFilter", this.dsList.getColumn(nIdx,"hmpgAddr")); // todo 화면 잘 뜨는지 테스트 
			if(!this.smfIsNull(sUrl))
			{
				system.execBrowser(sUrl);
			}
			
		},this);
	
		objButton.show();
	}
	
};

/**
 * open 버튼 생성
 * @param : scope ( Div.form)
 * @param : divInfo 
 */
this.fnCreateBtnOpen = function(scope,sChildId,nIdx)
{
	var sBtnId = this.fv_prefixIdOpenButton+nIdx;
	var sDivArrow = "btn_WF_iconOpen"+this.fv_mofile;
	
	// 버튼을 생성
	var objButton = scope[sBtnId];
	if(!objButton)
	{
		objButton = new Button(); 
		objButton.init(sBtnId, null, 0, 80, null, 0, 0);
		
		// 만들어진 Button을 Div에 추가
		scope.addChild(sBtnId, objButton);
		
		// 버튼의 속성을 설정
		objButton.set_initvalueid("ivBtnAccessibilityButton");	
		objButton.childId = sChildId;
		objButton.dirArrow = sDivArrow;
		
		// Button에 클릭이벤트 추가
		var sStaticId = this.fv_prefixIdTitleButton+nIdx;
		objButton.addEventHandler("onclick",function(obj,e){
			this.fnReDraw(scope.parent.parent, scope[sStaticId], e, nIdx);
		},this);
		
		// Button을 보이게 설정(addChild()하면 반드시 show()를 해주어야 실제로 화면에 보임)  
		objButton.show();  
	}
	objButton.set_cssclass("btn_WF_iconOpen"+this.fv_mofile);
	objButton.set_accessibilitylabel("정보열기");
};

/**
 * 생성 컴포넌트 재 설정 및 reDraw 함
 * @param : obj - Static
 * @param : e   - Static eventInfo
 */
this.fnReDraw = function(scope,obj,e, nIdx)
{
	// 상태값 추가 
	var openFlag = true;
	if(obj.parent.parent.form[this.fv_prefixIdOpenButton+nIdx].cssclass == "btn_WF_iconClose"){
		openFlag = false;
	}
	// class 초기화 
	for(var i=0;i < scope.components.length;i++)
	{	
		if(scope.components[i] instanceof nexacro.Div )
		{
			// titleDiv 이면
			if(scope.components[i].id.substr(0,this.fv_prefixIdTitleDiv.length) == this.fv_prefixIdTitleDiv)
			{
				scope.components[i].set_cssclass("div_grid_row"+this.fv_mofile);
				scope.components[i].form[this.fv_prefixIdOpenButton+(scope.components[i].id.substr(this.fv_prefixIdTitleDiv.length, scope.components[i].id.length))].set_cssclass("btn_WF_iconOpen"+this.fv_mofile);
				if(this.smfIsMobile()){
					scope.components[i].form[this.fv_prefixIdTitleButton+(scope.components[i].id.substr(this.fv_prefixIdTitleDiv.length, scope.components[i].id.length))].set_cssclass("btn_font28M");
				} else {
					scope.components[i].form[this.fv_prefixIdTitleButton+(scope.components[i].id.substr(this.fv_prefixIdTitleDiv.length, scope.components[i].id.length))].set_cssclass("btn_font16M");
				}
				
				
			}
			// contentsDiv 이면
			if(scope.components[i].id.substr(0,this.fv_prefixIdContentsDiv.length) == this.fv_prefixIdContentsDiv)
			{
				scope.components[i].setOffsetHeight(0);
				scope.components[i].set_visible(false);
				if(!this.smfIsNull(scope.components[i+1])){
					scope.components[i+1].setOffsetHeight(this.fvTitleHeight);
				}
			}
		}
	}

	// 민원실 정보를 서랍형으로 오픈 
	if(!this.smfIsNull(obj.childId) && openFlag){
		var objTitleDiv = obj.parent.parent;
		var objTitleNm = objTitleDiv.form[this.fv_prefixIdTitleButton+nIdx];
		var objTitleButton = objTitleDiv.form[this.fv_prefixIdOpenButton+nIdx];
		var objContentsDiv = scope[objTitleDiv.childId];
		objTitleDiv.set_cssclass("div_grid_row"+this.fv_mofile+"_S");
		objContentsDiv.setOffsetHeight(this.fvContentsHeight);
		objTitleButton.set_cssclass("btn_WF_iconClose");
		objTitleButton.set_accessibilitylabel("정보닫기");
		objContentsDiv.set_visible(true);
		if(this.smfIsMobile()){
			objTitleNm.set_cssclass("btn_font28M_blue");
		}
	}
	this.smfResetScroll(scope);
};

// div 삭제 
this.fnDeleteDiv = function()
{
	var objComps = this.divGrid.form.components;
	var nCount = objComps.length
	for(var i=nCount-1;i>=0;i--)
	{
		var objComp = objComps[i];
		var objDelete = this.divGrid.removeChild(objComp.id);
		if(objDelete)
		{
			trace(i + " - success : " + objDelete.id);
			objDelete.destroy();
		}
		else
		{
			trace(i + " - false : " + objComp.id);
		}
	}
	
	this.divGrid._count = 0;
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.divSearch_cboLctnScCd_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.fnSearch(obj, e);
};

this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearch(obj, e);
};
