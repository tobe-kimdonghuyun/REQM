    <Script type="xscript5.1"><![CDATA[//0501 CF 일괄등록

this.pas_mmscs03_m01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	this.smfResetScroll(this);
	// 컨텐츠 리사이징
	this.fnSetResize();
};

this.pas_mmscs03_m01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnSetResize();
};

this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//발급번호 유효성검사
	let checkArr = ['A', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'I', 'J', 'K', 'M', 'N', 'P', 'Q', 'R', 'S', 'T', 'V'];
	var checkFirstChar = this.divSearch.form.edtIssuNum1.value.substr(0,1);
	trace("checkFirstChar: " + checkFirstChar);
	trace("check: "+ checkArr.includes(checkFirstChar));
	
	if(this.smfIsNull(this.divSearch.form.edtIssuNum1.value)
		|| this.smfIsNull(this.divSearch.form.edtIssuNum2.value)
		|| this.smfIsNull(this.divSearch.form.edtIssuNum3.value)
		|| this.divSearch.form.edtIssuNum1.value.length != 10
		|| this.divSearch.form.edtIssuNum2.value.length != 4
		|| this.divSearch.form.edtIssuNum3.value.length != 6
		|| !checkArr.includes(checkFirstChar)){
		this.smfAlert("정확한 발급번호를 입력해주세요.");
		this.divSearch.form.edtIssuNum1.setFocus();
		return;
	}
	if(this.smfIsNull(this.divSearch.form.calDate.value)
		|| this.divSearch.form.calDate.value.length != 8){
		this.smfAlert("정확한 발급일자를 입력해주세요.");
		this.divSearch.form.calDate.setFocus();
		return;
	}
	this.dsSearch.setColumn(0, "vrcrMngIssuNo", this.divSearch.form.edtIssuNum1.value
													+ this.divSearch.form.edtIssuNum2.value
													+ this.divSearch.form.edtIssuNum3.value);
	// 서비스 객체 생성
	this.smfSearchService("select")
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			var result = false;
			console.log("1 = " + this.divSearch.form.calDate.value);
			console.log("2 = " + this.dsResult.getColumn(0, "issuDt"));
			console.log("3 = " + this.divSearch.form.calDate.value == this.dsResult.getColumn(0, "issuDt"));
			if(this.divSearch.form.calDate.value == this.dsResult.getColumn(0, "issuDt")){
				result = true;
			}
			var popupParams = {callback: this.fnPopupCallback
					  , sender	: obj 
					  , titlebar : false
					  , params	: {"vrcrMngIssuNo" : this.divSearch.form.edtIssuNum1.value
													+ this.divSearch.form.edtIssuNum2.value
													+ this.divSearch.form.edtIssuNum3.value
								, "issuDt" : this.divSearch.form.calDate.value
								, "issuInstNm" : this.dsResult.getColumn(0, "issuInstNm")
								, "issuPrgeTelno" : this.dsResult.getColumn(0, "issuPrgeTelno")
								, "cvlcptOfcrkNm" : this.dsResult.getColumn(0, "cvlcptOfcrkNm")
								, "result" : result
								, procType : "search"} 
					   };		
			this.smfDialog("_auto", "pa_pas_mms_cs::pas_mmscs03_p01.xfdl", popupParams);
			this.close();
	});	

};

this.divSearch_M_btnSearchM_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.smfIsNull(this.divSearch_M.form.edtIssuNum.value)
		|| this.divSearch_M.form.edtIssuNum.value.length != 20){
		this.smfAlert("정확한 발급번호를 입력해주세요.");
		this.divSearch_M.form.edtIssuNum.setFocus();
		return;
	}
	if(this.smfIsNull(this.divSearch_M.form.calDate.value)
		|| this.divSearch_M.form.calDate.value.length != 8){
		this.smfAlert("정확한 발급일자를 입력해주세요.");
		this.divSearch_M.form.calDate.setFocus();
		return;
	}
	this.dsSearch.setColumn(0, "vrcrMngIssuNo", this.divSearch_M.form.edtIssuNum.value);
	
	// 서비스 객체 생성
	this.smfSearchService("select")
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			var result = false;
			if(this.divSearch_M.form.calDate.value == this.dsResult.getColumn(0, "issuDt")){
				result = true;
			}
			var popupParams = {callback: this.fnPopupCallback
					  , sender	: obj 
					  , titlebar : false
					  , params	: {"vrcrMngIssuNo" : this.divSearch_M.form.edtIssuNum.value
								, "issuDt" : this.divSearch_M.form.calDate.value
								, "issuInstNm" : this.dsResult.getColumn(0,"issuInstNm")
								, "issuPrgeTelno" : this.dsResult.getColumn(0,"issuPrgeTelno")
								, "cvlcptOfcrkNm" : this.dsResult.getColumn(0,"cvlcptOfcrkNm")
								, "result" : result
								, procType : "search"} 
					   };		
			this.smfDialog("_auto", "pa_pas_mms_cs::pas_mmscs03_p01.xfdl", popupParams);
			this.close();
	});	
};


/**
 * 발급일자 팝업 콜백
 */
this.fnPopupCallback = function(context, responseParams, sender){
	console.log("context = " + context);
	console.log("responseParams = " + responseParams);
	console.log("sender = " + sender);
	
	this.smfSearchService("select")
		.validateForm(this.divMain)
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
	});	
};

this.divSearch_btnReset_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divSearch.form.edtIssuNum1.set_value("");
	this.divSearch.form.edtIssuNum2.set_value("");
	this.divSearch.form.edtIssuNum3.set_value("");
};

this.divHang1_00_btnDownload1_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//구글 플레이 스토어로 연결
	var url = "play.google.com/store/apps/details?id=com.markany.marcode";
	trace("url: " + url);
	system.execBrowser(url);
};

this.divHang1_00_btnDownload2_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//앱 스토어로 연결
	var url = "itunes.apple.com/kr/app/apple-store/id1140689862";
	trace("url: " + url);
	system.execBrowser(url);
};

//컨텐츠 리사이징
this.fnSetResize = function(){
	this.divSearch01.form.resetScroll();
	this.divSearch01.setOffsetHeight(parseInt(this.divSearch01.form.label00.getOffsetBottom(),10)+40);
	this.smfResetScroll(this.divSearch01);
	this.resetScroll();
}

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

};
]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">select</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResult=dsResult</Col>
            <Col id="svctp">R</Col>
            <Col id="url">pas_mms_cs03_001.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="message">조회</Col>
            <Col id="asynctp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="vrcrMngIssuNo" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsResult" useclientlayout="true">
        <ColumnInfo>
          <Column id="issuDt" type="string" size="256"/>
          <Column id="issuInstNm" type="STRING" size="256"/>
          <Column id="issuPrgeTelno" type="STRING" size="256"/>
          <Column id="cvlcptOfcrkNm" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
  </Form>
</FDL>
