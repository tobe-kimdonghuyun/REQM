this.fnSetResize = function(){
	this.divHang1.form.resetScroll();
	this.divHang1.setOffsetHeight(parseInt(this.divHang1.form.hang4_00.getOffsetBottom(),10)+40);
	this.smfResetScroll(this.divHang1);
	this.resetScroll();
}

