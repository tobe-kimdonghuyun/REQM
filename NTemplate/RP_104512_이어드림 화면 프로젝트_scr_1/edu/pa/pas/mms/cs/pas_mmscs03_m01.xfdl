this.divArea_btn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.div00.set_url("pa_pas_mms_cs::pas_mmscs03_m02.xfdl");
	
	var objId = obj.id.slice(-1);
	
	switch(objId) {
	case '1': 
		this.div00.set_url("pa_pas_mms_cs::pas_mmscs03_m02.xfdl");
		this.divArea.form.btn01.set_cssclass("btn_WF_area_S");
		this.divArea.form.btn02.set_cssclass("btn_WF_area");
		this.divArea.form.btn03.set_cssclass("btn_WF_area");
		this.divArea.form.btn04.set_cssclass("btn_WF_area");
		break;
	case '2':
		this.div00.set_url("pa_pas_mms_cs::pas_mmscs03_m03.xfdl");
		this.divArea.form.btn01.set_cssclass("btn_WF_area");
		this.divArea.form.btn02.set_cssclass("btn_WF_area_S");
		this.divArea.form.btn03.set_cssclass("btn_WF_area");
		this.divArea.form.btn04.set_cssclass("btn_WF_area");
		break;
	case '3':
		this.div00.set_url("pa_pas_mms_cs::pas_mmscs03_m04.xfdl");
		this.divArea.form.btn01.set_cssclass("btn_WF_area");
		this.divArea.form.btn02.set_cssclass("btn_WF_area");
		this.divArea.form.btn03.set_cssclass("btn_WF_area_S");
		this.divArea.form.btn04.set_cssclass("btn_WF_area");
		break;
	case '4':
		this.div00.set_url("pa_pas_mms_cs::pas_mmscs03_m05.xfdl");
		this.divArea.form.btn01.set_cssclass("btn_WF_area");
		this.divArea.form.btn02.set_cssclass("btn_WF_area");
		this.divArea.form.btn03.set_cssclass("btn_WF_area");
		this.divArea.form.btn04.set_cssclass("btn_WF_area_S");
		break;	
	default:
	}
	
	
};

this.cboArea_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	var code = this.cboArea.value;
	
	switch(code) {
	case '01':
		this.div00.set_url("pa_pas_mms_cs::pas_mmscs03_m02.xfdl");
		break;
	case '02':
		this.div00.set_url("pa_pas_mms_cs::pas_mmscs03_m03.xfdl");
		break;
	case '03':
		this.div00.set_url("pa_pas_mms_cs::pas_mmscs03_m04.xfdl");
		break;
	case '04':
		this.div00.set_url("pa_pas_mms_cs::pas_mmscs03_m05.xfdl");
		break;
	default:
	}
};

this.divHang1_hang4_00_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
