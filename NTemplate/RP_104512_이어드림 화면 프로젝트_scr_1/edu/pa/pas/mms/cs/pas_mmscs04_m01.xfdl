    </Objects>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.cboCddcScCd" propid="value" datasetid="dsSearch" columnid="cddcScCd"/>
      <BindItem id="item1" compid="divSearch.form.cboShlKndScCd" propid="value" datasetid="dsSearch" columnid="shlKndScCd"/>
      <BindItem id="item2" compid="divSearch.form.edtKornOrgNm" propid="value" datasetid="dsSearch" columnid="kornOrgNm"/>
    </Bind>
    <Script type="xscript5.1"><![CDATA[
/**
*   대국민 - 폐지학교 관리기관조회
*  @MenuPath    pa_pas_mms_cs
*  @FileName 	pas_mmscs04_m01.xfdl
*  @Creator 	최민진
*  @CreateDate 	2022.8.18
*  @Desction    폐지학교 관리기관조회
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.8.18     	최민진 	        최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs"

//0501 CF 일괄등록

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.pas_mmscs04_m01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	// 공통코드의 코드구분
	this.smfCodeList("code", [this.dsCddcScCd, this.dsShlKndScCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;		
			this.dsCddcScCd.setColumn(0,"unyCdValue", "");
			this.dsCddcScCd.setColumn(0,"unyCdValueNm", "전체");
			this.divSearch.form.cboCddcScCd.set_index(0);

			this.dsShlKndScCd.filter("unyCdValue=='01'||unyCdValue =='02'||unyCdValue=='03'||unyCdValue=='04'||unyCdValue=='05'")
			this.dsShlKndScCd.insertRow(0);
			this.dsShlKndScCd.setColumn(0,"unyCdValue", "");
			this.dsShlKndScCd.setColumn(0,"unyCdValueNm", "선택");
			this.divSearch.form.cboShlKndScCd.set_index(0);
			
			// 페이지를 조회한다.
			this.divSearch.form.btnSearch.click();
		})		
		.run()
	;	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(obj, e)
{
	var sServiceId = "select";
	if(this.smfIsMobile()){
		sServiceId = "selectTemp";
	}
	
 	// 서비스 객체 생성
	this.smfSearchService(sServiceId)
		// 페이징처리
		.paginator(this.grdMain, this.divPaging, this.divTotal, this.dsPageInfo, obj, e)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(this.smfIsMobile()){
				this.smfDataAppend(this, this.grdMain, this.dsListTemp);
				
				// 총 검색결과와 현재 검색 결과 수가 일치할 경우 [더보기]버튼 숨김 (TODO)
				if(this.dsPageInfo.getColumn(0, "totalCount")==this.dsList.getRowCount()){
					this.divPaging.set_visible(false);
				}else{
					this.divPaging.set_visible(true);
				}
			}
			if(!this.smfIsMobile()){
				//this.parent.parent.scrollTo(0,0);

				//검색 결과가 없는 경우 페이징 숨김
				if(this.dsList.getRowCount() == 0){	
					this.divPaging.set_visible(false);
				}else{
					this.divPaging.set_visible(true);
					this.grdMain.clearSelect();
				}
			}
			
			if(callbackParams.errors) return;
			
			var nGridHeight = this.grdMain.getRealRowFullSize();
			this.grdMain.setOffsetHeight(nGridHeight+2);
			this.smfResetScroll(this);
		});	
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//  페이지를 조회한다.
	this.fnSearch(obj, e);
};

this.divSearch_edtKornOrgNm_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode == 13){
		this.dsSearch.setColumn(0, "kornOrgNm", this.divSearch.form.edtKornOrgNm.value);
		this.divSearch.form.btnSearch.click();
	}
};
]]></Script>
  </Form>
</FDL>
