            <Col id="message">조회</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="id">selectTemp</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsPageInfo=dsPageInfo</Col>
            <Col id="outDatasets">dsListTemp=dsList dsPageInfo=dsPageInfo</Col>
            <Col id="svctp">R</Col>
            <Col id="url">pas_mms_cs04_001.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="message">조회</Col>
            <Col id="asynctp"/>
          </Row>
        </Rows>
