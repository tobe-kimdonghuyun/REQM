      <Layout name="Layout0" screenid="mobileP,tabletP" width="640" height="1433" mobileorientation="portrait" type="default">
        <Div id="divArea" visible="false" top="109" left="660" height="277" width="640" taborder="2"/>
        <Grid id="grdMain" top="523" left="20" height="913" right="20" cssclass="grd_WF_M" formatid="mobile" taborder="3" autosizingtype="row"/>
        <ImageViewer id="title1" cssclass="font48B_C" left="55" top="53" height="80" right="55"/>
        <Combo id="cboArea" cssclass="cbo_WF_M" visible="true" left="20" top="204" height="100" right="20" innerdataset="dsLctnScCd" datacolumn="unyCdValueNm" codecolumn="unyCdValue" taborder="1"/>
        <Button id="btnTmp" left="10" top="452" width="0" height="0"/>
        <Div id="divTab" left="20" top="393" height="70" right="0"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 온라인민원 발급 기준연도
*  @MenuPath    pa_pas_mms_cs
*  @FileName 	pas_mmscs01_m01.xfdl
*  @Creator 	최민진
*  @CreateDate 	2022.5.12
*  @Desction    온라인민원 발급 기준연도
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.8.18     	최민진				최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs";

//0501 CF 일괄등록
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvBtnFocus ="N";
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.pas_mmscs01_m01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{  
	// 폼 초기화
	this.smfInitForm(obj);
	
	// 공통코드의 코드구분
	this.smfCodeList("code", [this.dsLctnScCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;		
			
			if(this.smfIsMobile()){
				this.dsSearch.setColumn(0, "cvlCptOfcdcCd", "04");
				this.cboArea.set_index(0);
				this.cboArea.setFocus();
		
			} else {
				this.dsSearch.setColumn(0, "cvlCptOfcdcCd", "04");
				this.dsSearch.setColumn(0, "ogdpOfcdcCd", "B10");
				this.fnSearch();
				
				this.divArea.form.btn00.set_cssclass("btn_WF_area_S");
				this.divArea.form.btn00.set_accessibilitylabel("선택된 "+ this.divArea.form.btn00.text);
			}
			
			// 페이지를 조회한다.
			//this.fnSearch(obj, e);
		})		
		.run()
	;
	
	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(ogdpOfcdcCd)
{
	if(!this.smfIsNull(ogdpOfcdcCd)) this.dsSearch.setColumn(0,"ogdpOfcdcCd", ogdpOfcdcCd);
	
	trace("fnSearch(): " + this.dsSearch.getColumn(0,"ogdpOfcdcCd") + ", " + this.dsSearch.getColumn(0,"cvlCptOfcdcCd"));
	
	// 서비스 객체 생성(목록조회)
	this.smfSearchService("select")
	// 실행
	.run()
	// 콜백
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		if(!this.smfIsMobile()){
			this.grdMain.clearSelect();
		}
		
		var nHeight = this.grdMain.getRealRowFullSize();
		this.grdMain.setOffsetHeight(nHeight+5);
		this.smfResetScroll(this);
		
		//if (this.fvBtnFocus != "N") this.btnTmp.setFocus();
		//this.fvBtnFocus = "Y";
		
	});
	
	
	// 서비스 객체 생성(목록 개수 조회)
	this.smfSearchService("selectCnt")
	// 실행
	.run()
	// 콜백
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		// 초기화
		this.divTab.form.btnTab1.set_text("학생(0)");
		this.divTab.form.btnTab2.set_text("검정고시(0)");
		this.divTab.form.btnTab3.set_text("인사(0)");
		
		// 세팅
		for(var i=0; i<this.dsCntList.rowcount; i++)
		{
			var name = this.dsCntList.getColumn(i,"cvlcptSysSc");
			switch(name) {
			case '학생':
				this.divTab.form.btnTab1.set_text("학생("+this.dsCntList.getColumn(i,"cvlcptSysScCnt")+")");
				break;
			case '검정고시':
				this.divTab.form.btnTab2.set_text("검정고시("+this.dsCntList.getColumn(i,"cvlcptSysScCnt")+")");
				break;
			case '인사':
				this.divTab.form.btnTab3.set_text("인사("+this.dsCntList.getColumn(i,"cvlcptSysScCnt")+")");
				break;
			}
		}
			
	});
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.Button_onsetfocus = function(obj:nexacro.Button,e:nexacro.SetFocusEventInfo)
{
};

this.divAreaButton_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	trace("코드: " + obj.ogdpOfcdcCd);
	this.dsSearch.setColumn(0, "ogdpOfcdcCd", obj.ogdpOfcdcCd);
	this.fnSearch();

	var objComps = this.divArea.form.components;
	for(var i=0;i<objComps.length;i++)
	{
		var objComp = objComps[i];
		objComp.set_cssclass("btn_WF_area");
		objComp.set_accessibilitylabel(objComp.text);
	}
	obj.set_cssclass("btn_WF_area_S");
	obj.set_accessibilitylabel("선택된 "+ obj.text);
};

this.cboArea_onsetfocus = function(obj:nexacro.Combo,e:nexacro.SetFocusEventInfo)
{
	this.fnSearch(obj.value);
};

this.cboArea_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.fnSearch(obj.value);
};


this.div_tab_btnTabCtrl_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sPostfix ="";
	if(this.smfIsMobile()){
		sPostfix = "_M";
	}
	
	var tabNo = String(obj.id).substr(String(obj.id).length-1);
	if (tabNo=="1") this.dsSearch.setColumn(0,"cvlCptOfcdcCd","04"); // 학생
	if (tabNo=="2")	this.dsSearch.setColumn(0,"cvlCptOfcdcCd","01"); // 검정고시
	if (tabNo=="3")	this.dsSearch.setColumn(0,"cvlCptOfcdcCd","02"); // 인사
	
	this.divTab.form.btnTab1.set_cssclass("btn_WF_tab"+sPostfix);
	this.divTab.form.btnTab2.set_cssclass("btn_WF_tab"+sPostfix);
	this.divTab.form.btnTab3.set_cssclass("btn_WF_tab"+sPostfix);
	
	this.divTab.form["btnTab"+tabNo].set_cssclass("btn_WF_tab"+sPostfix+"_S");
	
	this.fnSearch();
};



]]></Script>
    <Objects>
      <Dataset id="dsList" useclientlayout="true">
        <ColumnInfo>
          <Column id="cptfNm" type="string" size="256"/>
          <Column id="ctrYr" type="string" size="256"/>
          <Column id="bgo" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows/>
      </Dataset>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">select</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsList=dsList</Col>
            <Col id="url">pas_mms_cs01_001.do</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="id">selectCnt</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsCntList=dsCntList</Col>
            <Col id="url">pas_mms_cs01_004.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="ogdpOfcdcCd" type="STRING" size="256"/>
          <Column id="cvlCptOfcdcCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsCntList" useclientlayout="true">
        <ColumnInfo>
          <Column id="cvlcptSysSc" type="string" size="256"/>
          <Column id="cvlcptSysScCnt" type="string" size="256"/>
        </ColumnInfo>
        <Rows/>
      </Dataset>
      <Dataset id="dsLctnScCd" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="ClfCdValue" type="STRING" size="30" value="CDDC_SC_CD"/>
          <ConstColumn id="FilterExpr" type="STRING" size="30" value="unyCdValue!='A00' &amp;&amp; unyCdValue!='V10'"/>
          <ConstColumn id="UnyCdGrpId" type="STRING" size="30" value=""/>
          <ConstColumn id="BfrClfCdValue" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd1Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd2Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd3Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd4Value" type="STRING" size="30" value=""/>
          <ConstColumn id="UserDfnCd5Value" type="STRING" size="30" value=""/>
          <Column id="pgeId" type="STRING" size="256"/>
          <Column id="clfCdValue" type="STRING" size="30"/>
          <Column id="clfCdValueNm" type="STRING" size="120"/>
          <Column id="clfCdUseYn" type="STRING" size="150"/>
          <Column id="unyCdValue" type="STRING" size="10"/>
          <Column id="unyCdValueNm" type="STRING" size="30"/>
          <Column id="userDfnCd1Value" type="STRING" size="100"/>
          <Column id="userDfnCd2Value" type="STRING" size="100"/>
          <Column id="userDfnCd3Value" type="STRING" size="100"/>
          <Column id="userDfnCd4Value" type="STRING" size="100"/>
          <Column id="userDfnCd5Value" type="STRING" size="100"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
  </Form>
</FDL>
