              </Band>
            </Format>
            <Format id="mobile">
              <Columns>
                <Column size="200"/>
                <Column size="200"/>
                <Column size="200"/>
              </Columns>
              <Rows>
                <Row size="90" band="head"/>
                <Row size="100"/>
              </Rows>
              <Band id="head">
                <Cell text="민원사무명"/>
                <Cell col="1" text="발급기준년도"/>
                <Cell col="2" text="비고" cssclass="cell_end"/>
              </Band>
              <Band id="body">
                <Cell text="bind:cptfNm" autosizerow="limitmin" wordWrap="char" controlautosizingtype="both"/>
                <Cell col="1" text="bind:ctrYr" autosizerow="limitmin" wordWrap="char"/>
                <Cell col="2" text="expr:(bgo == '' || bgo == null) ? '-' : bgo" autosizerow="limitmin" wordWrap="char" border="2px solid #eaeaea,0px none,2px solid #eaeaea"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
