              <ImageViewer id="img02" taborder="2" text="교육의 대한 열정, 미래를 향한 나의 꿈, 교육의 꿈을 이루어 드립니다." left="30" top="202" width="580" height="33" cssclass="font20R_W" initvalueid="ivTitleAccessibilityOn" tabstop="false"/>
