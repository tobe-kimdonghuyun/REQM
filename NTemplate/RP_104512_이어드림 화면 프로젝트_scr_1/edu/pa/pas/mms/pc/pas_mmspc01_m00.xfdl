          <Column id="editUseYn" type="STRING" size="256"/>
          <Column id="useYn" type="STRING" size="256"/>
          <Column id="rgtrNm" type="STRING" size="256"/>
          <Column id="rgtrDptNm" type="STRING" size="256"/>
          <Column id="mdfrNm" type="STRING" size="256"/>
          <Column id="mdfrDptNm" type="STRING" size="256"/>
          <Column id="rgtrId" type="STRING" size="256"/>
          <Column id="regDt" type="STRING" size="256"/>
          <Column id="mdfrId" type="STRING" size="256"/>
          <Column id="mdfcnDt" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsRecmList" useclientlayout="true">
        <ColumnInfo>
          <Column id="recmSrchSn" type="STRING" size="256"/>
          <Column id="recmSrchNm" type="STRING" size="256"/>
          <Column id="useYn" type="STRING" size="256"/>
          <Column id="rgtrId" type="STRING" size="256"/>
          <Column id="regDt" type="STRING" size="256"/>
          <Column id="mdfrId" type="STRING" size="256"/>
          <Column id="mdfcnDt" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 통합검색
*  @MenuPath    pa_pas_mms_pc
*  @FileName 	pas_mmspc01_m00.xfdl
*  @Creator 	최영아
*  @CreateDate 	2022.11.14
*  @Desction    통합검색 조회
*
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.11.14     	최영아 	        최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs";

//0501 CF 일괄등록

/************************************************************************************************
 * 메모
 
 this.btnTab5, this.btnTab6 은 현재 사용되지 않는 메뉴라 visible을 false 처리 해놓았음.
 추후에 사용될 경우 true 처리 필요.
 
 ************************************************************************************************/


/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.searchKeyword = "";
this.totalCnt = 0;
this.reQueryCheck = false;

this.recmMax = 10; //화면에 보여줄 추천검색어 최대 건수

this.pas_mmspc01_m00_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	this.smfResetScroll(this.divTabpage.form);
	
	var pvParams = this.getOwnerFrame().form.fv_workPageParams;
	this.divCondtion.form.edtSearchKeyword.set_value(pvParams.schKeyword);
	
	//추천검색어
	this.smfSearchService("selectRecm")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			// 추천검색어
			if(this.dsRecmList.getRowCount() > 0){
				this.fnSetRecmList();
			}

		});
	
	//검색
	this.reQueryCheck = false;
	this.searchKeyword = this.fnSetSearchKeyword(this.divCondtion.form.edtSearchKeyword.value);
	trace("통합검색 fnSetSearchKeyword 후: " + this.searchKeyword);
	this.dsSearch.setColumn(0,"query",encodeURIComponent(this.searchKeyword));

	this.totalCnt = 0;
	this.dsSearch.setColumn(0,"reQuery", this.divCondtion.form.chkReQuery.value);
	
	this.cbo00.set_value("ALL");
	this.btnTab1_onclick();
	
};
 
this.btnTab1_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsMenuList.clearData();
	this.dsNoticeList.clearData();
	this.dsFaqList.clearData();
	this.dsEduNewsList.clearData();
	this.dsEvnList.clearData();
	
	this.dsMenuListTemp.clearData();
	this.dsNoticeListTemp.clearData();
	this.dsFaqListTemp.clearData();
	this.dsEduNewsListTemp.clearData();
	this.dsEvnListTemp.clearData();
	
	this.divTabpage.set_url("pa_pas_mms_pc::pas_mmspc01_m01.xfdl");
	
	if(!this.smfIsMobile()){
		//선택되는 버튼에 css 재설정
		this.fnSetTabclass(this.btnTab1);
	}
	
	this.dsSearch.setColumn(0,"collections","ALL");  // 전체 검색
	
	this.smfResetScroll(this);
	this.dsPageInfo.setColumn(0,"pageIndex",1);
	this.fnSearch(obj, e);		//조회
};



this.btnTab2_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsMenuList.clearData();
	this.dsMenuListTemp.clearData();	
	
	this.divTabpage.set_url("pa_pas_mms_pc::pas_mmspc01_m02.xfdl");

	if(!this.smfIsMobile()){
		//선택되는 버튼에 css 재설정
		this.fnSetTabclass(this.btnTab2);
	}
	
	this.dsSearch.setColumn(0,"collections","ntn_menu");  //서비스메뉴 검색
	
	this.smfResetScroll(this);
	this.dsPageInfo.setColumn(0,"pageIndex",1);
	this.fnSearch(obj, e);		//조회
};

this.btnTab3_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsNoticeList.clearData();
	this.dsNoticeListTemp.clearData();	
	
	this.divTabpage.set_url("pa_pas_mms_pc::pas_mmspc01_m03.xfdl");

	if(!this.smfIsMobile()){
		//선택되는 버튼에 css 재설정
		this.fnSetTabclass(this.btnTab3);
    }
	
	this.dsSearch.setColumn(0,"collections","ntn_notice");  //공지사항 검색
	
	this.smfResetScroll(this);
	this.dsPageInfo.setColumn(0,"pageIndex",1);
	this.fnSearch(obj, e);		//조회
};

this.btnTab4_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsFaqList.clearData();
	this.dsFaqListTemp.clearData();	
		
	this.divTabpage.set_url("pa_pas_mms_pc::pas_mmspc01_m04.xfdl");

	if(!this.smfIsMobile()){
		//선택되는 버튼에 css 재설정
		this.fnSetTabclass(this.btnTab4);
	}
	
	this.dsSearch.setColumn(0,"collections","ntn_faq");		//자주묻는질문 검색

	this.smfResetScroll(this);
	this.dsPageInfo.setColumn(0,"pageIndex",1);
	this.fnSearch(obj, e);		//조회
};

	
this.btnTab5_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsEvnList.clearData();
	this.dsEvnListTemp.clearData();
	
	this.divTabpage.set_url("pa_pas_mms_pc::pas_mmspc01_m05.xfdl");

	if(!this.smfIsMobile()){
		//선택되는 버튼에 css 재설정
		this.fnSetTabclass(this.btnTab5);
	}
	
	this.dsSearch.setColumn(0,"collections","ntn_evnPubcn");   //이벤트공모전 검색

	this.smfResetScroll(this);
	this.dsPageInfo.setColumn(0,"pageIndex",1);
	this.fnSearch(obj, e);		//조회
};

this.btnTab6_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsEduNewsList.clearData();
	this.dsEduNewsListTemp.clearData();	
	
	this.divTabpage.set_url("pa_pas_mms_pc::pas_mmspc01_m06.xfdl");
	
	if(!this.smfIsMobile()){
		//선택되는 버튼에 css 재설정
		this.fnSetTabclass(this.btnTab6);
	}
	
	this.dsSearch.setColumn(0,"collections","ntn_eduNews");   //교육소식 검색

	this.smfResetScroll(this);
	this.dsPageInfo.setColumn(0,"pageIndex",1);
	this.fnSearch(obj, e);		//조회
};

this.divCondtion_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.divCondtion.form.chkReQuery.isChecked()){	//재검색의 경우 realQuery에 설정
		this.reQueryCheck = true;
		this.dsSearch.setColumn(0,"query",encodeURIComponent(this.searchKeyword));
		this.dsSearch.setColumn(0,"realQuery",encodeURIComponent(this.divCondtion.form.edtSearchKeyword.value));
	}else{ //검색어 세팅
		this.reQueryCheck = false;
		this.searchKeyword = this.fnSetSearchKeyword(this.divCondtion.form.edtSearchKeyword.value); 
		trace("통합검색 fnSetSearchKeyword 후: " + this.searchKeyword);
		this.dsSearch.setColumn(0,"query",encodeURIComponent(this.searchKeyword));
	}
	this.totalCnt = 0;
	this.dsSearch.setColumn(0,"reQuery", this.divCondtion.form.chkReQuery.value);
	
	this.cbo00.set_value("ALL");
	this.btnTab1_onclick();
};

this.divCondtion_edtSearchKeyword_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode == 13){
		this.divCondtion_btnSearch_onclick();
	}
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnSetSearchKeyword = function(keyword)
{
	keyword = keyword.replace("<", "&lt;");
	keyword = keyword.replace(">", "&gt;");
	
	return keyword
}

this.fnSetTabVisible = function(vVisible){		// 텝영역 활성화 설정
	if(this.smfIsMobile()){
		this.cbo00.set_visible(vVisible);
	}else{
		this.btnTab1.set_visible(vVisible);
		this.btnTab2.set_visible(vVisible);
		this.btnTab3.set_visible(vVisible);
		this.btnTab4.set_visible(vVisible);
		//this.btnTab5.set_visible(vVisible);
		//this.btnTab6.set_visible(vVisible);
	}
};

this.fnSetTabclass = function(oComp){		// 텝영역 css설정
	var tgtNo = String(oComp.id).substr(String(oComp.id).length-1);
	var basCss = "btn_SA_Result";

	for(var i=1;i<=6;i++) {
		this["btnTab"+i].set_cssclass(basCss);
		
		if (i==tgtNo) this["btnTab"+i].set_cssclass("btn_SA_ResultS");
	}
};
	
this.fnSearch = function(obj, e){
	var sServiceId = "select";
	if(this.smfIsMobile()){
		sServiceId = "selectTemp";
		
		this.dsMenuListTemp.clearData();
		this.dsNoticeListTemp.clearData();
		this.dsFaqListTemp.clearData();
		this.dsEduNewsListTemp.clearData();
		this.dsEvnListTemp.clearData();
	}
	

	// 서비스 객체 생성
	this.smfSearchService(sServiceId)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;	
			
			this.parent.parent.scrollTo(0,0);
					
			this.sta01.set_visible(true);
				
			// 조회결과가 있는 경우
			if(this.dsPageInfo.getColumn(0,"totalCount") > 0){
				this.fnSetTabVisible(true);	//텝버튼 활성화
				
				if(this.smfIsMobile()){
					this.dsMenuList.appendData(this.dsMenuListTemp);
					this.dsNoticeList.appendData(this.dsNoticeListTemp);
					this.dsFaqList.appendData(this.dsFaqListTemp);
					this.dsEduNewsList.appendData(this.dsEduNewsListTemp);
					this.dsEvnList.appendData(this.dsEvnListTemp);
				}

				var vKeyword = this.searchKeyword;

				this.divCondtion.form.chkReQuery.set_value("N");		// 재검색 체크 해제
				
				if(this.reQueryCheck){	//재검색의 경우
					this.divCondtion.form.chkReQuery.set_visible(false);  //재검색 비활성화
					vKeyword += ", " + this.divCondtion.form.edtSearchKeyword.value;
				}else{
					this.divCondtion.form.chkReQuery.set_visible(true);  //재검색 활성화
				}

				if(this.dsSearch.getColumn(0,"collections") == "ALL"){	//전체 조회일 경우
					this.totalCnt = this.dsPageInfo.getColumn(0,"totalCount");
				}
						
				var vText = "'<fc v='#2b72de'>"+vKeyword+"</fc>'에 대한 총 <fc v='#2b72de'>"+ this.totalCnt +"</fc>건의 검색결과를 찾았습니다. ";
				this.sta01.set_text(vText);
				this.smfResetScroll(this.sta01);
				
				this.divTabpage.form.initForm();	//텝 화면에 데이터 세팅

			}else{		//조회결과가 없는 경우
				if(this.dsSearch.getColumn(0,"collections") == "ALL"){	//전체 조회일 경우
					this.fnSetTabVisible(false);	//텝버튼 비활성화

					this.divTabpage.set_url("");
					this.sta01.set_text("검색결과가 없습니다.");
				}else{
					this.divTabpage.form.initForm();	//텝 화면에 데이터 세팅
				}
			}
			this.smfResetScroll(this.divTabpage.form);
	});
};

this.divCondtion_chkReQuery_onchanged = function(obj:nexacro.CheckBox,e:nexacro.CheckBoxChangedEventInfo)
{
	this.divCondtion.form.edtSearchKeyword.set_value("");
};

this.recmSrchWord_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	this.divCondtion.form.edtSearchKeyword.set_value(obj.text);
};

// 모바일_콤보박스
this.cbo00_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	switch(obj.value)
	{
		case "ALL": // 전체 
			this.btnTab1_onclick();
			break;
		case "ntn_menu": // 서비스·메뉴 
			this.btnTab2_onclick();
			break;
		case "ntn_notice": // 공지사항 
			this.btnTab3_onclick();
			break;
		case "ntn_faq": // 자주묻는질문 
			this.btnTab4_onclick();
			break;
		case "ntn_evnPubcn": // 이벤트·공모전 
			this.btnTab5_onclick();
			break;
		case "ntn_eduNews": // 교육소식
			this.btnTab6_onclick();
			break;
	}
	
};

// 추천검색어 생성
this.fnSetRecmList = function(){
	var recmDiv = this.divCondtion.form.div00;
	var recmCnt = this.dsRecmList.getRowCount();
	var recmId = "staRecmSrchWord";
	var sCssClass = "sta_SA_Word";
	var leftPadding = this.smfIsMobile()?"20":"6";	//글상자간 간격 
	var pTop = this.smfIsMobile()?"0":"8";	//top위치 
	var pWidth = this.smfIsMobile()?"70":"100";	//가로사이즈 (가변이라 초기값)
	var pHeigth=this.smfIsMobile()?"50":"27";	//세로사이즈 
	var mgTop = this.smfIsMobile()?"20":"10";	//top 간격
	var floorLevel = 1;		// 추천검색어 층
	
	if(this.smfIsMobile()){
		sCssClass += "_M";
	}
	
	if(recmCnt > this.recmMax){	//화면에 보여줄 추천검색어 수
		recmCnt = this.recmMax;
	}
	
	var totalWidth=this.divCondtion.form.div00.getOffsetWidth(); 
	var textWidth=0;
	
	for(var i=0; i<recmCnt; i++){
		var sStaticId = recmId+i;
		var sLeft = 0;
		var vText = this.dsRecmList.getColumn(i, "recmSrchNm");
		
		if(i>0){
			var indx = i-1;
			textWidth += parseInt(leftPadding); //검색어 사이즈에 간격 더하기

			sLeft = recmId + indx + ":" + leftPadding;	//두번째 검색어는 첫번째 검색어의 left 간격 필요
		}

		var objStatic = new Static();  
		objStatic.init(sStaticId, sLeft, pTop, pWidth, pHeigth);
	
		recmDiv.form.addChild(sStaticId, objStatic); 
		
		// Static을 보이게 설정(addChild()하면 반드시 show()를 해주어야 실제로 화면에 보임)  
		objStatic.show();
		
		//속성 설정
		objStatic.set_text(vText);
		objStatic.set_initvalueid("ivStcAccessibilityOn");
		objStatic.set_cssclass(sCssClass);
		objStatic.set_fittocontents("width");
			
		// Static에 클릭이벤트 추가
		objStatic.addEventHandler("onclick",this.recmSrchWord_onclick,this);
		objStatic.set_verticalAlign("middle");

		textWidth += objStatic.getOffsetWidth(); //생성된 검색어 사이즈 더하기
		
		if(textWidth > totalWidth){  //검색어들이 부모창크기를 넘으면 줄바꿈하기
			textWidth= objStatic.getOffsetWidth();
			pTop = parseInt(pTop) + parseInt(pHeigth) + parseInt(mgTop); 
			sLeft = 0;
			
			objStatic.set_left(sLeft);
			objStatic.set_top(pTop);
			floorLevel++;
		}
	}
	
	// 추천검색어 층 레벨에 맞춰 높이 수정
	if(floorLevel >2)
	{
		this.smfResetScroll(this.divCondtion.form.div00.form);
	}
	
};
this.pas_mmspc01_m00_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	if(this.smfIsMobile()){	// 모바일인 경우 추천 검색어 다시 그리기
		var objComps = this.divCondtion.form.div00.form.components;
		var nCount = objComps.length

		for(var i=nCount-1;i>=0;i--)
		{
			var objComp = objComps[i];
			var objDelete = this.divCondtion.form.div00.removeChild(objComp.id);
			if(objDelete)
			{
				//trace(i + " - success : " + objDelete.id);
				objDelete.destroy();
			}
			else
			{
				//trace(i + " - false : " + objComp.id);
			}
		}
	
		this.divCondtion.form.div00._count = 0;
	
		this.fnSetRecmList();
	}
};

]]></Script>
  </Form>
</FDL>
