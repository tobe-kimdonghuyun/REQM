    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 통합검색-이벤트공모전 검색
*  @MenuPath    pa_pas_mms_pc
*  @FileName 	pas_mmspc01_m05.xfdl
*  @Creator 	최영아
*  @CreateDate 	2022.11.15
*  @Desction    통합검색 조회
*
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.11.15     	최영아 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs";

//0501 CF 일괄등록

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 this.divEvn_div01_grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	// 클릭한 셀을 구한다
	var nRow = e.row;
	var nCell = e.cell;
	
	if(nCell == 1){ // 제목 클릭시 상세페이지로 이동
	
		var objDs = obj.getBindDataset();
		var seventId = objDs.getColumn(nRow,"eventId");
		var params = {pafrBbsId:seventId
			};
		
		var seventScCd = objDs.getColumn(nRow,"eventScCd");
		
		//이벤트인지 공모전인지 구분해서 각 구분에 맞는 화면으로 이동
		if(seventScCd == "1"){
			this.smfSetWorkPage("pa_pas_mms_cn::pas_mmscn03_m02.xfdl", params);
		}else{
			this.smfSetWorkPage("pa_pas_mms_cn::pas_mmscn03_m03.xfdl", params);
		}
	}
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.initForm = function(){

	//데이터셋 세팅
	if(this.smfIsMobile()){
		this.dsEvnListTemp.copyData(this.parent.parent.dsEvnListTemp);
		this.smfDataAppend(this, this.divEvn.form.div01.form.grdMain, this.dsEvnListTemp);
		this.smfResetScroll(this.divEvn.form.div01.form);
	}else {
		this.dsEvnList.copyData(this.parent.parent.dsEvnList);
	}

	//조회 결과 카운트
	var evnListCnt = this.parent.parent.dsCount.getColumn(0,"ntn_evnPubcn");
	
	//4. 이벤트·공모전
	this.divEvn.form.staEvnCnt.set_text("이벤트·공모전 <fc v='#2b72de'>" + evnListCnt + "</fc>건");	
	var vGrid = this.divEvn.form.div01.form.grdMain;
	var vDsPageInfo = this.parent.parent.dsPageInfo;
	var vFunction = this.parent.parent.fnSearch;
	
	if(vDsPageInfo.getColumn(0, "pageIndex") == 1 && this.dsEvnList.getRowCount() > 0){
		this.divPaging.form.fnInit(vGrid, vDsPageInfo, null, vFunction, this.parent.parent);
	}
	
	// 총 검색결과와 현재 검색 결과 수가 일치할 경우 [더보기]버튼 숨김 
	if(this.smfIsMobile()){
		if(this.dsEvnList.getRowCount() == evnListCnt){	
			this.divPaging.set_visible(false);
		}
	}else{
		//검색 결과가 없는 경우 페이징 숨김
		if(this.dsEvnList.getRowCount() == 0){	
			this.divPaging.set_visible(false);
		}
	}
	
	this.smfResetScroll(this);
};

this.fnDisplayText = function(obj,nCell,nRow,sLongText)
{
	var sFont = 'normal 400 18px/normal "Noto Sans KR","NotoSansKR-Regular"';
	//var objFont = new nexacro._PaddingObject(sFont);
	var nPadding = 30;

	if(this.smfIsMobile())
	{
		sFont = 'normal 400 28px/normal "Noto Sans KR","NotoSansKR-Regular"';
		nPadding = 90;
	}

	return this.smfDispLongTextGridDecorate(obj,nCell,nRow,sLongText,sFont,nPadding);
};]]></Script>
