    <Script type="xscript5.1"><![CDATA[/**
*  대국민포탈 - 메인
*  @MenuPath    pa_pas_mms_pc 
*  @FileName 	pas_mmspc00_m01.xfdl 
*  @Creator 	TOBESOFT
*  @CreateDate 	2022.08.04
*  @Desction    Main
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.08.04     		TOBESOFT		 	  	  최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

//0501 CF 일괄등록

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.wHost;
 
this.frameSubMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);

	//앙카 설정
	this.topInfo[0] = this.divSubMain1;
	this.topInfo[1] = this.divSubMain2;
	this.topInfo[2] = this.divSubMain3;
	this.topInfo[3] = this.getOwnerFrame().form.divAll.form.divBottom;
	
	//수직스크롤이동시 페이지표시하는 동적버튼 생성하지 않음
	//this.addEventHandler("onmousewheel",this.smfMainOnMouseWheel,this);
	
	//모바일인 경우 검색조건 모바일로 변경
	if(this.smfIsMobile()){
		this.dsSearch.setColumn(0,"cntnDvcsClfCd","30");
	}

	//팝업 설정
	this.popInfo = {};
	this.popInfo.id = "commNoticeAll";
	this.popInfo.pUrl = "commP::commNoticeAll.xfdl";
	
	this.popInfo.callbackScope = this;
	this.popInfo.callbackFunc = "fncommNoticeAll";

	
	//중간 서비스 소개란 안보이게 처리
	//고객요청으로 삭제. 혹시 추후에 사용될 경우를 생각해서 화면에서만 안보이게 설정해놈
	this.divSubMain2.set_height(0);


	this.smfSearchService("select")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			// 팝업
			if(this.dsListPopup.getRowCount() > 0){
				this.popInfo.dsListPopup =this.dsListPopup;
				this.smfDivPop(this.popInfo);
			}
			
			// 배너	
			if(this.smfIsMobile()){
				if(this.dsBannM.getRowCount() > 0){
					this.divSubMain3.form.initBann();
				}
			}else{
				if(this.dsBannP.getRowCount() > 0){
					this.divSubMain3.form.initBann();
				}
			}
			
			// 공지사항
			if(this.dsListNotice.getRowCount() > 0){
				this.divSubMain3.form.initNotice();
			}

		});
};

this.fncommNoticeAll = function( pObj )
{
	if ( pObj instanceof nexacro.NormalDataset ){

		if(pObj.rowcount > 0){
			var vLnkTypCd = pObj.getColumn(0,"lnkTypCd");
			var vLnkUrl = pObj.getColumn(0,"lnkUrl");
			
			this.fnLinkPrcs(vLnkTypCd, vLnkUrl);
		}
	}
};

this.fnLinkPrcs = function(lnkTypCd, lnkUrl){
	if(lnkTypCd == 1){ //url 링크
		this.smfSetServiceLink(lnkUrl,"redirect");		//해당 url로 이동
		
	}else{		//게시물 링크
		var vBbsScCd = lnkUrl.substring(0,3);	//게시물 ID 앞 3자리가 게시판 코드
		var params = {pafrBbsId:lnkUrl};	
		
		switch(vBbsScCd)
		{
			case "NTC": // 공지사항 
				this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn00_m02.xfdl", "open", params);
				break;
			case "FAQ": // 자주묻는질문 TO-DO 목록으로 되어 있어서 어떻게 처리할지 고민 필요!!!
				this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn01_m01.xfdl","open", params);
				break;
			case "PUB": // 공모전
				this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn03_m03.xfdl", "open", params);
				break;
			case "EVT": // 이벤트
				this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn03_m02.xfdl", "open", params);
				break;
		}
	}

};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

};

this.fnPopupCallback = function(svcid,errcd,errmsg){
	
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

//화면 닫기 전 divAll 공통 요소 삭제
this.frameSubMain_onbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	this.smfOnbeforeClose();
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
]]></Script>
  </Form>
</FDL>
