    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 통합검색-서비스 · 메뉴검색
*  @MenuPath    pa_pas_mms_pc
*  @FileName 	pas_mmspc01_m02.xfdl
*  @Creator 	최영아
*  @CreateDate 	2022.11.15
*  @Desction    통합검색 조회
*
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.11.15     	최영아 	        최초 생성 
*******************************************************************************
*/

//0501 CF 일괄등록

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.divMenu_div01_grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	
	var objDs = obj.getBindDataset();
	var sMenuUrl = objDs.getColumn(e.row,"menuUrlAddr"); //메뉴URL
	var menuId = objDs.getColumn(e.row,"menuId"); //메뉴
	var upMenuId = objDs.getColumn(e.row,"upMenuId"); //상위메뉴
	var sType = "open";  
	var sServer ="local";
	var param = {};
	
	if(this.smfContainsStr(window.location.host, "local")){		//로컬인 경우
		sServer = "local";
	}else if (this.smfContainsStr(window.location.host, "dev")){	//개발인 경우
		sServer = "dev";
	}else if (this.smfContainsStr(window.location.host, "tst")){	//시험인 경우
		sServer = "test";
	}else if (!this.smfContainsStr(window.location.host, "local") && 
			  !this.smfContainsStr(window.location.host, "dev") &&
			  !this.smfContainsStr(window.location.host, "tst")){	//운영인 경우
		sServer = "prod";
	}

	if(menuId == "8011"){  // 원격지원서비스인 경우 팝업으로 오픈, 모바일은 제공X
		if(this.smfIsMobile()){
			this.smfAlert("모바일은 지원하지 않는 기능입니다.")
			return;
		}
		sMenuUrl = this.getOwnerFrame().form.divTop.form.dsMenu.lookup("menuId",menuId,"menuUrlAddr");
		//param.options = "width=600,height=600,scrollbars=yes";
		system.execBrowser(sMenuUrl);
		
		return;
	}

	if(upMenuId == "8000"){ //서비스링크인 경우
		sType = "link";
		
		if(sMenuUrl.length == 3){	//서비스 코드인 경우 url 받아오기
			sMenuUrl = this._smfGoNexacro(sServer,sUrl);
		}
		this.smfSetServiceLink(sMenuUrl,sType,param);

	} else {	// 메뉴링크인 경우
		this.smfSetWorkPage(sMenuUrl);
	}
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.initForm = function(){
	
	//조회 결과 카운트
	var menuListCnt = this.parent.parent.dsCount.getColumn(0,"ntn_menu");
	
	//1. 서비스 · 메뉴
	this.divMenu.form.staMenuCnt.set_text("서비스 · 메뉴 <fc v='#2b72de'>" + menuListCnt + "</fc>건");
	
	var vGrid = this.divMenu.form.div01.form.grdMain;
	var vDsPageInfo = this.parent.parent.dsPageInfo;
	var vFunction = this.parent.parent.fnSearch;
	
	//데이터셋 세팅
	if(this.smfIsMobile()){
		this.dsMenuListTemp.copyData(this.parent.parent.dsMenuListTemp);
		this.smfDataAppend(this, this.divMenu.form.div01.form.grdMain, this.dsMenuListTemp);
		this.smfResetScroll(this.divMenu.form.div01.form);
	}else {
		this.dsMenuList.copyData(this.parent.parent.dsMenuList);
	}
	
	if(vDsPageInfo.getColumn(0, "pageIndex") == 1 && this.dsMenuList.getRowCount() > 0){
		this.divPaging.form.fnInit(vGrid, vDsPageInfo, null, vFunction, this.parent.parent);
	}
	if(this.smfIsMobile()){
	// 총 검색결과와 현재 검색 결과 수가 일치할 경우 [더보기]버튼 숨김 
		if(this.dsMenuList.getRowCount() == menuListCnt){	
			this.divPaging.set_visible(false);
		}
	}else{
		//검색 결과가 없는 경우 페이징 숨김
		if(this.dsMenuList.getRowCount() == 0){	
			this.divPaging.set_visible(false);
		}
	}
	
	this.smfResetScroll(this);
};

]]></Script>
  </Form>
</FDL>
