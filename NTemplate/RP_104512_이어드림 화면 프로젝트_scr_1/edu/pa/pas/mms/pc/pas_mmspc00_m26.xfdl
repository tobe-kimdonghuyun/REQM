<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Main_sub0_btnGroup" width="1200" height="100" titletext="버튼순서" scrolltype="none" onload="Main_sub0_btnGroup_onload">
    <Layouts>
      <Layout height="100" width="1200" screenid="ScreenDeskTopP">
        <Static id="staLine0" taborder="0" left="199" top="10" width="2" height="80" cssclass="sta_main_sub0_line" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staLine2" taborder="1" left="399" top="10" width="2" height="80" cssclass="sta_main_sub0_line" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staLine3" taborder="2" left="599" top="10" width="2" height="80" cssclass="sta_main_sub0_line" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staLine4" taborder="3" left="799" top="10" width="2" height="80" cssclass="sta_main_sub0_line" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staLine5" taborder="4" left="999" top="10" width="2" height="80" cssclass="sta_main_sub0_line" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staLine6" taborder="5" left="1199" top="10" width="2" height="80" cssclass="sta_main_sub0_line" initvalueid="ivStcAccessibilityOff"/>
        <Button id="btnNice_" taborder="6" text="나이스플러스" left="0" top="0" width="200" cssclass="btn_main_sub0_service1_S" height="100" initvalueid="ivBtnAccessibilityButton" onclick="btn_onclick" visible="false"/>
        <Button id="btnParents_" taborder="7" text="학부모서비스" left="200" top="0" width="200" cssclass="btn_main_sub0_service2" height="100" initvalueid="ivBtnAccessibilityButton" onclick="btn_onclick" visible="false"/>
        <Button id="btnExam_" taborder="8" text="검정고시" left="400" top="0" width="200" cssclass="btn_main_sub0_service4" height="100" initvalueid="ivBtnAccessibilityButton" onclick="btn_onclick" visible="false"/>
        <Button id="btnComplaint_" taborder="9" text="학원서비스" left="600" top="0" width="200" cssclass="btn_main_sub0_service5" height="100" initvalueid="ivBtnAccessibilityButton" onclick="btn_onclick" visible="false"/>
        <Button id="btnNonProfitCo_" taborder="10" text="비영리법인" left="800" top="0" width="200" cssclass="btn_main_sub0_service5" height="100" initvalueid="ivBtnAccessibilityButton" onclick="btn_onclick" visible="false"/>
        <Button id="btnApply_" taborder="11" text="대학지원용&#13;&#10;학교생활기록부 신청" left="1000" top="0" width="200" cssclass="btn_main_sub0_service6" height="100" initvalueid="ivBtnAccessibilityButton" onclick="btn_onclick" visible="false"/>
        <Button id="btn01S" taborder="12" text="나이스플러스" left="0" top="130" width="200" cssclass="btn_main_sub0_service1" height="100" initvalueid="ivBtnAccessibilityOff" visible="false"/>
        <Button id="btn02S" taborder="13" text="학부모서비스" left="200" top="130" width="200" cssclass="btn_main_sub0_service2_S" height="100" initvalueid="ivBtnAccessibilityOff" visible="false"/>
        <Button id="btn03S" taborder="14" text="검정고시" left="400" top="130" width="200" cssclass="btn_main_sub0_service4_S" height="100" initvalueid="ivBtnAccessibilityOff" visible="false"/>
        <Button id="btn04S" taborder="15" text="학원서비스" left="600" top="130" width="200" cssclass="btn_main_sub0_service5_S" height="100" initvalueid="ivBtnAccessibilityOff" visible="false"/>
        <Button id="btn05S" taborder="16" text="비영리법인" left="800" top="130" width="200" height="100" initvalueid="ivBtnAccessibilityOff" visible="false" cssclass="btn_main_sub0_service6_S"/>
        <Button id="btn06S" taborder="17" text="대학지원용&#13;&#10;학교생활기록부 신청" left="1000" top="130" width="200" cssclass="btn_main_sub0_service6_S" height="100" initvalueid="ivBtnAccessibilityOff" visible="false"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[this.preFix = "btn_mySetting";
this.arrCssClass = ["_nice","_parents","_exam","_complaint", "_nonProfitCo", "_apply"];
this.arrUnSelectedCssClass = ["_no1","_no2","_no3","_no4","_no5","_no6"];
this.arrSelectedCssClass = [];


this.Main_sub0_btnGroup_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.fnChange();
};

this.fnChange = function()
{
	if ( !this.isNil( nexacro.getPrivateProfile("neis")) )
	{
		this.dsSaveProfile.loadCSV(nexacro.getPrivateProfile("neis"));
	}else
	{
		this.fnDataLoad();
	}
};

this.dsSaveProfile_onload = function(obj:nexacro.NormalDataset,e:nexacro.DSLoadEventInfo)
{	
	if ( e.reason == 0 )
	{
		this.fnDataLoad();
	}
};

this.fnDataLoad = function()
{	
	this.dsSaveProfile.set_keystring("S:compClass");
	this.fvLeftMargin = 0;
		
	for(var i=0;i<this.dsSaveProfile.rowcount;i++)
	{
		var compId = this.dsSaveProfile.getColumn(i,"compId");
		var refClass = this.dsSaveProfile.getColumn(i,"refClass");
		var compClass = this.dsSaveProfile.getColumn(i,"compClass");
		var sTitle = this.dsSaveProfile.getColumn(i,"sTitle");
		if ( this[compId] )
		{
			var objDel = this.removeChild(compId);
			objDel.destroy();
			objDel = null;
		}
			
		var objBtn = new Button();
		objBtn.init(compId,this.fvLeftMargin,0,200,100);
		this.fvLeftMargin = this.fvLeftMargin + 200;

		this.addChild(objBtn.name, objBtn);
		objBtn.userRefClass = refClass;
		objBtn.set_cssclass(refClass);
		objBtn.set_text(sTitle + (sTitle == "대학지원용" ? "\n학교생활기록부 신청" : "")); // 메뉴명 표시 수정. 대입전형자료\n(학교생활기록부)
		objBtn.setEventHandler("onclick", this.fnSubMainLink, this);
		objBtn.set_visible(true);
		objBtn.show();
		
/*		대국민포털 메인이미지를 먼저 보여주기 위해 제거	
		if ( i == ( this.dsSaveProfile.rowcount - 1) ) 
		{
			refClass = refClass + "_S";
			var compId = this.dsSaveProfile.getColumn(0,"compId");
			this.fnSubMainLink(this[compId]);
		}		
*/	
	}

	// 대국민포털 메인이미지를 먼저 보여주기
	//this.parent.parent.divSub0.bringToFront();
	//this.parent.parent.div00.bringToFront();	

	
	//this.parent.parent.imgMouse.bringToFront();
	//this.parent.parent.divStep.bringToFront();
	//this.parent.parent.btnMysetting.bringToFront();
	//this.parent.parent.staTooltip.bringToFront();
};

// SubMenu버튼 css와 화면순서를 초기화
this.fnSubmenuResetCss = function(pObj) 
{
	for(var c=0;c<this.dsSaveProfile.rowcount;c++) {
		var compId = this.dsSaveProfile.getColumn(c,"compId");
		var refClass = this.dsSaveProfile.getColumn(c,"refClass");
		if ( this[compId] )
		{
			this[compId].set_cssclass(refClass);
		}

		this.parent.parent["divSub"+(c+1)].set_visible(false);
		this.parent.parent["divSub"+(c+1)].bringToPrev();		
	}
	
	pObj.set_cssclass(pObj.userRefClass +"_S");		//선택
};

//
this.fnSubMainLink = function(pBtnObj)
{
	this.fnSubmenuResetCss(pBtnObj);

	if ( pBtnObj.id == "btnNice")				//"pa_pas_mms_pc::pas_mmspc00_m21.xfdl"
	{
		//pBtnObj.set_cssclass(pBtnObj.userRefClass +"_S"); //"btn_main_sub0_service1_S"
		this.parent.parent.divSub1.set_visible(true);
		this.parent.parent.divSub1.bringToFront();
		this.parent.parent.divSub1.setFocus();

	}else if (pBtnObj.id == "btnParents" )		//"pa_pas_mms_pc::pas_mmspc00_m22.xfdl"
	{
		//pBtnObj.set_cssclass("btn_main_sub0_service2_S");
 		this.parent.parent.divSub2.set_visible(true);
		this.parent.parent.divSub2.bringToFront();
		this.parent.parent.divSub2.setFocus();
	}else if ( pBtnObj.id == "btnExam")		//"pa_pas_mms_pc::pas_mmspc00_m24.xfdl"
	{
		//pBtnObj.set_cssclass("btn_main_sub0_service4_S");		
		this.parent.parent.divSub3.set_visible(true);
		this.parent.parent.divSub3.bringToFront();
		this.parent.parent.divSub3.setFocus();
	}else if ( pBtnObj.id == "btnComplaint" ) 	//"pa_pas_mms_pc::pas_mmspc00_m25.xfdl"
	{
		//pBtnObj.set_cssclass("btn_main_sub0_service5_S");		
		this.parent.parent.divSub4.set_visible(true);
		this.parent.parent.divSub4.bringToFront();
		this.parent.parent.divSub4.setFocus();
	}else if ( pBtnObj.id == "btnNonProfitCo" ) //"pa_pas_mms_pc::pas_mmspc00_m28.xfdl"
	{
		//pBtnObj.set_cssclass("btn_main_sub0_service6_S");		
		this.parent.parent.divSub5.set_visible(true);
		this.parent.parent.divSub5.bringToFront();
		this.parent.parent.divSub5.setFocus();
	}else if ( pBtnObj.id == "btnApply" ) //"pa_pas_mms_pc::pas_mmspc00_m29.xfdl"
	{
		//pBtnObj.set_cssclass("btn_main_sub0_service6_S");		
		this.parent.parent.divSub6.set_visible(true);
		this.parent.parent.divSub6.bringToFront();
		this.parent.parent.divSub6.setFocus();
	}	

	this.parent.parent.staTooltip.bringToFront();
	this.parent.parent.btnMysetting.bringToFront();

	this.parent.parent.div00.bringToFront();
};

this.btn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSubMainLink(obj);
};
]]></Script>
    <Objects>
      <Dataset id="dsSaveProfile" onload="dsSaveProfile_onload">
        <ColumnInfo>
          <Column id="key" type="STRING" size="256"/>
          <Column id="compId" type="STRING" size="256"/>
          <Column id="compClass" type="STRING" size="256"/>
          <Column id="refClass" type="STRING" size="256"/>
          <Column id="sTitle" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="compId">btnNice</Col>
            <Col id="refClass">btn_main_sub0_service1</Col>
            <Col id="sTitle">나이스플러스</Col>
            <Col id="compClass">no1</Col>
          </Row>
          <Row>
            <Col id="compId">btnParents</Col>
            <Col id="refClass">btn_main_sub0_service2</Col>
            <Col id="sTitle">학부모서비스</Col>
            <Col id="compClass">no2</Col>
          </Row>
          <Row>
            <Col id="compId">btnExam</Col>
            <Col id="refClass">btn_main_sub0_service4</Col>
            <Col id="sTitle">검정고시</Col>
            <Col id="compClass">no3</Col>
          </Row>
          <Row>
            <Col id="compId">btnComplaint</Col>
            <Col id="refClass">btn_main_sub0_service5</Col>
            <Col id="sTitle">학원서비스</Col>
            <Col id="compClass">no4</Col>
          </Row>
          <Row>
            <Col id="compId">btnNonProfitCo</Col>
            <Col id="refClass">btn_main_sub0_service6</Col>
            <Col id="sTitle">비영리법인</Col>
            <Col id="compClass">no5</Col>
          </Row>
          <Row>
            <Col id="compId">btnApply</Col>
            <Col id="refClass">btn_main_sub0_service6</Col>
            <Col id="sTitle">대학지원용</Col>
            <Col id="compClass">no6</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
  </Form>
</FDL>
