    <Script type="xscript5.1"><![CDATA[/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.bannCnt=0;		//롱배너 갯수
this.bannWidth = nexacro.getEnvironmentVariable("ev_isMobile") == "Y" ? 600:1200;
this.bannHeight = nexacro.getEnvironmentVariable("ev_isMobile") == "Y" ? 400:250;
this.fvWidth = this.smfIsMobile()?30:26; //일시정지 버튼 너비
this.fvAddWidth = this.smfIsMobile()?38:24; //각 버튼 너비

//터치 이벤트를 위한 정보
this.bannClientX = 0;     //처음 눌렸을때의 x좌표
this.bannMvSize = 300;      //x좌표가 어느만큼 움직여야 이미지 전환을 할지 지정

// 공지를 표시하기 위한 정보
this.arrImptYn=[];		//공지_중요여부
this.arrCn=[];			//공지_공지사항내용
this.arrRegDt=[];		//공지_등록일시
this.arrNtcMteId=[]; 	//공지_공지ID

this.maxNoticeCount = 10;  // 표시할 최대 공지 갯수
this.fv_noticeCount = 0;   // 표시하고 있는 공지의 전체 갯수
this.fv_noticeCurPos = -1;  // 표시하고 있는 공지의 현재위치(0부터시작)

this.divLeftStart = nexacro.getEnvironmentVariable("ev_isMobile") == "Y" ? 0:11;
this.divLeft = nexacro.getEnvironmentVariable("ev_isMobile") == "Y" ? 460:299;
this.divTop = nexacro.getEnvironmentVariable("ev_isMobile") == "Y" ? 0:10;
this.divWidth = nexacro.getEnvironmentVariable("ev_isMobile") == "Y" ? 440:280;


/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.Main_sub4_new_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.parent.divmargin = 110;
};

this.Main_sub4_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	var nAllWidth = this.width;  // 전체 form의 사이즈
	var nMaxWidth = this.div00.getOffsetWidth();
	//var nBannWidth = this.div00.form.divSupport.getOffsetWidth();
	var nBannWidth = 600;
	var nStepWidth = this.divSupport.form.divSteps.getOffsetWidth();
	var nLeft,nLeft2,nLeft3;
	trace("nBannWidth(함수): " + this.divSupport.getOffsetWidth());
	trace("nAllWidth: " + nAllWidth + " nMaxWidth: " + nMaxWidth + " nBannWidth: " + nBannWidth + " nStepWidth: " + nStepWidth);
		
	nLeft  = parseInt((nAllWidth - nMaxWidth) / 2);	
	this.div00.setOffsetLeft(nLeft);
	this.divSupport.setOffsetLeft(nLeft);
	
	if(this.smfIsMobile()){
		nLeft2 = parseInt((nAllWidth - nBannWidth) / 2) ;	//배너 위치 조절
		nLeft3 = parseInt((nBannWidth - nStepWidth ) / 2);	//배너 스탭 위치 조절
		this.divSupport.setOffsetLeft(nLeft2);
		this.divSupport.form.divSteps.setOffsetLeft(nLeft3);
		
		var fvWidth = this.fvWidth + this.bannCnt * this.fvAddWidth;
			
		this.divSupport.form.divSteps.setOffsetWidth(fvWidth);		//버튼수에 맞춰서 DIV길이 조절
		this.divSupport.form.divSteps.form.resetScroll();
	}
	
	this.resetScroll();
	
};

this.divSupport_ontouchmove = function(obj:nexacro.Div,e:nexacro.TouchEventInfo)
{

};

this.divSupport_ontouchstart = function(obj:nexacro.Div,e:nexacro.TouchEventInfo)
{
	this.bannClientX = e.touchinputinfos[0].clientx;	//현재 위치 저장
};

this.divSupport_ontouchend = function(obj:nexacro.Div,e:nexacro.TouchEventInfo)
{
	var newClientX = e.touchinputinfos[0].clientx;
	var moveX = 0;
	
	if(newClientX > this.bannClientX){		// 왼쪽에서 오른쪽으로 이동 (앞페이지)
		moveX = newClientX - this.bannClientX;
		if(moveX > this.bannMvSize){ 		//페이지 이동할 만큼 움직인 경우
			this.btnPrev_onclick();
		}
		
	}else{	// 오른쪽에서 왼쪽으로 이동 (다음페이지)
		moveX = this.bannClientX - newClientX;
		if(moveX > this.bannMvSize){ //페이지 이동할 만큼 움직인 경우
			this.btnNext_onclick();
		}
	}

};




/*****************************
 *    배너 설정
 *****************************/

this.initBann = function(){

	//롱배너 버튼 생성
	this.bannCnt = this.smfIsMobile()?this.parent.parent.dsBannM.rowcount:this.parent.parent.dsBannP.rowcount;
	
	var fvWidth = this.fvWidth + this.bannCnt * this.fvAddWidth;
			
	this.divSupport.form.divSteps.setOffsetWidth(fvWidth);		//버튼수에 맞춰서 DIV길이 조절
	this.divSupport.form.divSteps.form.resetScroll();
	
	this.divSupport.form.divSteps.form.fnCreateBtn(this.bannCnt, this);
	
	//배너 생성
	var vForm = this.divSupport.form;
	var vDs = this.smfIsMobile()?this.parent.parent.dsBannM:this.parent.parent.dsBannP;
	var objLeft = i*this.bannWidth;
	
	for(var i=0; i<this.bannCnt; i++){
		var objNm = "imgBanner"+i;
		var objLeft = i*this.bannWidth;

		var imgViw = new ImageViewer(objNm, objLeft, 0, this.bannWidth, this.bannHeight);
		vForm.addChild(objNm, imgViw);
			
		imgViw.set_textAlign("center middle");
		imgViw.setEventHandler("onclick", function(obj,e){
			this.fnClikEvt(obj,e);
		}, this);
		
		var sUrl = this.smfGetImageUrl(vDs.getColumn(i,"fileRefrnId"),0);
		imgViw.image = sUrl;
//		imgViw.image = "imagerc::main_M/bg_main_sub4_supportM.jpg";
		imgViw.set_initvalueid("ivImgAccessibilityOn");
		imgViw.set_accessibilitylabel(vDs.getColumn(i,"rplcText"));	//이미지 대체 텍스트
		imgViw.set_cssclass("display");
		imgViw.set_imagealign("left top");
		imgViw.show();
	}
	
	vForm.divSteps.bringToFront();
	vForm.btnPrev.bringToFront();
	vForm.btnNext.bringToFront();
};

this.fnStepClik = function(objNo){
	var vForm = this.divSupport.form;
	
	for(var i=0;i<this.bannCnt;i++)
	{
		if(objNo == i){
			vForm.components["imgBanner"+i].set_visible(true);
			vForm.components["imgBanner"+i].move(0,0);	//div이동
		}else{
			vForm.components["imgBanner"+i].set_visible(false);
		}
	}

};

this.fnClikEvt = function(obj,e){
	var vForm = this.divSupport.form;
	var vDs = this.smfIsMobile()?this.parent.parent.dsBannM:this.parent.parent.dsBannP;
	
	var objNo = String(obj.name).substr(obj.name.length-1);

	var lnkTypCd = vDs.getColumn(objNo,"lnkTypCd");
	var lnkUrl;
	
	if(lnkTypCd == 1){	//링크타입 (1:url, 2:게시물)
		lnkUrl = vDs.getColumn(objNo,"bannUrl");
	}else{
		lnkUrl = vDs.getColumn(objNo,"pafrBbsId");
	}
	
	if(vDs.getColumn(objNo,"newinYn")=='Y'){	//새창
		if(lnkTypCd == 1){	//새창URL
		 var win = window.open(lnkUrl,"_blank");
		}else{		// 새창게시물
			var pageUrl = null;
			var type = "link";
			var param = {};

			var vBbsScCd = vDs.getColumn(objNo,"pafrBbsScCd");
			var vBbsId = vDs.getColumn(objNo,"pafrBbsId");
			switch(vBbsScCd)
			{
				case "NTC": // 공지사항 
					param.menuId = "3011";
					param.pafrBbsId = vBbsId;	//게시물ID
					break;
				case "FAQ": // 자주묻는질문
					param.menuId = "4001";
					param.pafrBbsId = vBbsId;	//게시물ID
					break;
				case "PUB": // 공모전
					param.menuId = "3022";
					param.pafrBbsId = vBbsId;	//게시물ID
					break;
				case "EVT": // 이벤트
					param.menuId = "3021";
					param.pafrBbsId = vBbsId;	//게시물ID
					break;
			}
			if(this.smfContainsStr(window.location.host, "local")){		//로컬인 경우
				param.server = "local";
			}else if (this.smfContainsStr(window.location.host, "dev")){	//개발인 경우
				param.server = "dev";
			}else if (this.smfContainsStr(window.location.host, "tst")){	//시험인 경우
				param.server = "test";
			}else if (!this.smfContainsStr(window.location.host, "local") && 
					  !this.smfContainsStr(window.location.host, "dev") &&
					  !this.smfContainsStr(window.location.host, "tst")){	//운영인 경우
				param.server = "prod";
			}
			
			
			
			param.subSys = "PAS";
			this.smfSetServiceLink(pageUrl,type,param); 
		}
	}else{	//
		this.parent.parent.fnLinkPrcs(lnkTypCd, lnkUrl);	
	}

};


//이전 배너 보기아이콘 클릭
this.btnPrev_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var vForm = this.divSupport.form.divSteps.form;
	
	//현재 선택된 배너 번호
	var bannNo = vForm.stepNo;
	
	
	//step 같이 이동
	vForm.btnStepMv(bannNo-1);
};


//다음 배너 보기아이콘 클릭
this.btnNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var vForm = this.divSupport.form.divSteps.form;
	
	//현재 선택된 배너 번호
	var bannNo = vForm.stepNo;
	
	//step 같이 이동
	vForm.btnStepMv(bannNo+1);
};

/*****************************
 *    공지 설정
 *****************************/
this.initNotice = function(){
	var dslist = this.parent.parent.dsListNotice;
	var noticeCnt = dslist.rowcount
	this.fv_noticeCount = noticeCnt;
	if(noticeCnt > this.maxNoticeCount){
		this.fv_noticeCount = this.maxNoticeCount;
	}

	for(var i=0; i<this.fv_noticeCount; i++ ){
		this.arrImptYn[i] = dslist.getColumn(i,"imptYn");		//공지_중요여부
		this.arrCn[i] = dslist.getColumn(i,"ntcMteTitlNm");		//공지_공지사항내용
		this.arrRegDt[i] = dslist.getColumn(i,"regDt");			//공지_등록일시
		this.arrNtcMteId[i] = dslist.getColumn(i,"ntcMteId"); 	//공지_공지ID
	}
	
	if(this.smfIsMobile() && this.fv_noticeCount > 4){	//5번째 박스 부터는 그려야 함
		for(var j=4; j<this.fv_noticeCount; j++){	
			var noticeForm = this.div00.form.divTabpage.form;
			var objNm = "divSurvey"+j;
			var vLeft = "divSurvey"+ parseInt(j-1) +":"+ 20;
			var divCssCnt = (j+1)%4;
			if(divCssCnt == 0) divCssCnt = 4;
			
			// 공지 사각형 div 그리기
			var objDiv = new Div();
			objDiv.init(objNm,vLeft,0,440,440);
			noticeForm.addChild(objNm, objDiv);
			objDiv.set_cssclass("div_main_sub4_part0" + divCssCnt+"_M");
			objDiv.set_initvalueid("ivDivAccessibilityOff");
			objDiv.show();
			
			// 공지 내부 중요여부 그리기
			var objSta = new Static();
			objSta.init("staPart",33,58,82,41);
			noticeForm.components[j].form.addChild("staPart", objSta);
			objSta.set_initvalueid("ivStcAccessibilityOn");
            objSta.set_taborder("0");
            objSta.set_text("중요");
            objSta.set_cssclass("sta_main_sub_teg02_M");
            objSta.set_visible("false");
			objSta.show();
			
			// 공지 타이틀 버튼 그리기
			var objBtn = new Button();
			objBtn.init("btnTitle",23,122,null,127,23);
			noticeForm.components[j].form.addChild("btnTitle", objBtn);
			objBtn.set_initvalueid("ivBtnAccessibilityLink");
            objBtn.set_taborder("1");
            //objBtn.set_text("대국민 포털서비스 나이스 소식을 전해드립니다.");
            objBtn.set_cssclass("btn_main_sub4_title_M");
            //objBtn.set_fittocontents("height");
            objBtn.set_wordWrap("char");
            objBtn.set_visible("false");
			objBtn.show();

			// 공지 날짜 그리기
			var objSta2 = new Static();
			objSta2.init("staDate",32,348,164,40);
			noticeForm.components[j].form.addChild("staDate", objSta2);
			objSta2.set_initvalueid("ivStcAccessibilityOn");
            objSta2.set_taborder("2");
            objSta2.set_text("");
            objSta2.set_cssclass("font22M");
            objSta2.set_color("#888888");
            objSta2.set_letterSpacing("0px");
            objSta2.set_visible("false");
			objSta2.show();
		}
	}
	
	//공지사항 그리기
	this.fv_noticeCurPos = 0;
	this.fnCreateNotice();
	
	if(!this.smfIsMobile()){
		if(noticeCnt > 4){  // 5건 이상이면 다음 버튼 활성화
			this.btnNext.set_visible(true);
		}else{
			this.btnNext.set_visible(false);
		}
	}
	
	this.smfResetScroll(this.div00.form.divTabpage.form);
};
 
// 롤링 공지사항 그리기 
this.fnCreateNotice = function(){
	var showCnt = this.smfIsMobile()? this.fv_noticeCount:4;	//모바일은 전체 공지사항 스크롤
	for(var i=0; i<showCnt; i++){
		if(i < this.fv_noticeCount){	
			if(this.arrImptYn[i] == "Y"){
				this.div00.form.divTabpage.form.components["divSurvey"+i].form.staPart.set_visible(true);
			}else{
				this.div00.form.divTabpage.form.components["divSurvey"+i].form.staPart.set_visible(false);
			}
			this.div00.form.divTabpage.form.components["divSurvey"+i].form.btnTitle.set_visible(true);
			this.div00.form.divTabpage.form.components["divSurvey"+i].form.staDate.set_visible(true);
			
			var sText = this.dispLongText(this.div00.form.divTabpage.form.components["divSurvey"+i].form.btnTitle,String(this.arrCn[i]));
			this.div00.form.divTabpage.form.components["divSurvey"+i].form.btnTitle.set_text(sText);
			this.div00.form.divTabpage.form.components["divSurvey"+i].form.btnTitle.setEventHandler("onclick", function(obj,e){
				var objNo = String(obj.parent.parent.name).substr(9);
				var params = {pafrBbsId:this.arrNtcMteId[objNo]};
				this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn00_m02.xfdl", "open", params);
			}, this);
				
			var sRegDate = String(this.arrRegDt[i]);
			sRegDate = sRegDate.substr(0,4)+"."+sRegDate.substr(4,2)+"."+sRegDate.substr(6,2)+".";
			this.div00.form.divTabpage.form.components["divSurvey"+i].form.staDate.set_text(sRegDate);
		}
	}
 };
 

//이전 공지 보기아이콘 클릭
this.notice_btnPrev_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fv_noticeCurPos--;

	if(this.fv_noticeCurPos <= 0){		// 첫번째 공지일 경우 이전 버튼 비활성화
		this.btnPrev.set_visible(false);	
	}

	if((this.fv_noticeCurPos + 3) < this.fv_noticeCount){
		this.btnNext.set_visible(true);	// max보다 적은 경우 다음 버튼 활성화
	}

	this.arrImptYn.unshift(this.arrImptYn.pop(0));
	this.arrCn.unshift(this.arrCn.pop(0));
	this.arrRegDt.unshift(this.arrRegDt.pop(0));
	this.arrNtcMteId.unshift(this.arrNtcMteId.pop(0));

	this.fnCreateNotice();
};


//다음 공지 보기아이콘 클릭
this.notice_btnNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fv_noticeCurPos ++;

	if((this.fv_noticeCurPos + 4) >= this.fv_noticeCount){
		this.btnNext.set_visible(false);	// max를 넘어갈 경우 다음 버튼 비활성화
	}
	
	if(this.fv_noticeCurPos > 0){	
		this.btnPrev.set_visible(true);		// 처음 공지가 아닌경우 이전 버튼 활성화
	}

	this.arrImptYn.push(this.arrImptYn[0]);
	this.arrImptYn.shift();
	this.arrCn.push(this.arrCn[0]);
	this.arrCn.shift();
	this.arrRegDt.push(this.arrRegDt[0]);
	this.arrRegDt.shift();
	this.arrNtcMteId.push(this.arrNtcMteId[0]);
	this.arrNtcMteId.shift();

	this.fnCreateNotice();
};


this.dispLongText = function(obj,sLongText)
{
	var sFont = 'normal 400 16px/normal "Noto Sans KR","NotoSansKR-Regular"';
	var objFont = new nexacro._PaddingObject(sFont);
	var nPadding = this.smfIsMobile()?40:80;
	
	var selected = true;
	
	var objFont = this.smfNvl(sFont,obj._getCurrentStyleInheritValue("font", this._status));

	var wordspace = obj._getCurrentStyleInheritValue("wordSpacing");
	var letterspace = obj._getCurrentStyleInheritValue("letterSpacing");

	var nObjWidth = parseInt(obj.getOffsetWidth()) + parseInt(obj.getOffsetWidth() - nPadding );
	var plusWidth = this.smfIsMobile() ? 400 : 180;
	var nMaxTextWidth = nObjWidth-nPadding + plusWidth;

	var textHeightB = nexacro.getTextSize(sLongText,objFont,true,nObjWidth,"char",wordspace,letterspace);
	var nTextWidthB = parseInt(textHeightB.nx,10);


	//모바일-물리픽셀은 논리픽셀보다 2배의 밀도를 가진다.
	if ( this.smfIsMobile() ) {
		nMaxTextWidth = parseInt(nMaxTextWidth*0.55, 10);
	}

	if(nTextWidthB>=nMaxTextWidth)
	{
		var tailText = nexacro.getTextSize("...",objFont);	
		nMaxTextWidth = nMaxTextWidth-tailText.nx;	//"..."를 뺀 width

		var sTextTemp = "";
		for (var i=0;i<sLongText.length;i++)
		{
			sTextTemp += sLongText.charAt(i);
			var nTextWidth = nexacro.getTextSize(sTextTemp,objFont,true,nObjWidth,"char",wordspace,letterspace).nx;
			
			if (nTextWidth>=nMaxTextWidth)
			{
				//trace("sTextTemp=["+sTextTemp+"..."+"] - "+nTextWidth, nMaxTextWidth);

				return sTextTemp+"...";
			}else {
				if (i==sLongText.length-1){
					return sTextTemp;
				}
			}
		}
	}else
	{
		return sLongText; 
	}
};
this.btnMore_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSetServiceLink("pa_pas_mms_cn::pas_mmscn00_m01.xfdl");
};
]]></Script>
    <Objects/>
  </Form>
</FDL>
