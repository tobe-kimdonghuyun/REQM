    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민포탈메인
*  @MenuPath    commP
*  @FileName 	myServiceSetting.xfdl
*  @Creator 	TOBESOFT
*  @CreateDate 	2022.08.09
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.8.09     	TOBESOFT 	        최초 생성 
*******************************************************************************
*/

//0501 CF 일괄등록

this.fvWidth = 50;
this.fvAddWidth = 36;

this.divCnt = 6;	//서비스 이미지 수

//터치 이벤트를 위한 정보
this.mainClientX = 0;     //처음 눌렸을때의 x좌표
this.mainMvSize = 300;    //x좌표가 어느만큼 움직여야 이미지 전환을 할지 지정


this.Main_sub0_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	var nMaxHeight = this.smfResetScroll(this);
	
	var fvWidth = this.fvWidth + (this.divCnt-1) * this.fvAddWidth;		//버튼 5개에 맞는 너비 세팅 
			
	this.divStep.setOffsetWidth(fvWidth);
	this.divStep.form.resetScroll();
	
	//모바일일때 첫 화면 '학부모서비스' (추후삭제)
	if(this.smfIsMobile())
	{
		this.divSub2.set_visible(true);
	}
	
	this.divStep.form.fnCreateBtn(this.divCnt, this);	//버튼 생성
	/*
	this.divSub0.bringToFront();	//최초에 대국민포털의 메인을 보여주기 위해 설정
	this.div00.bringToFront();
	*/
	
	this.imgMouse.bringToFront();
	//this.divStep.bringToFront();
	this.btnMysetting.bringToFront();
	this.staTooltip.bringToFront();
	

	
	if(nexacro.getEnvironmentVariable("ev_isMobile") == "Y"){
		this.divStep.form.btnStep0.set_cssclass("btn_main_pop_step");
		this.divStep.form.stepNo= -1;
	}
	
	this.resetScroll();
};

/**
 * @description 사이즈 변경시 위치변경(컴포넌트 아이디 변경 시 수정)
*/
this.Main_sub0_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	var nAllWidth = this.width;  // 전체 form의 사이즈
	var nMaxWidth = this.div00.getOffsetWidth();
	var nLeft,nLeft2,nLeft3,nWidth;
		
	nLeft  = parseInt((nAllWidth - nMaxWidth) / 2);	
	nLeft2 = parseInt((nAllWidth - this.imgMouse.getOffsetWidth()) / 2);
	nLeft3 = parseInt((nAllWidth - this.divContents.getOffsetWidth()) / 2);
	nLeft4 = parseInt((nAllWidth - this.divStep.getOffsetWidth()) / 2);
	this.divContents.setOffsetLeft(nLeft3);
	this.div00.setOffsetLeft(nLeft);
	
	this.imgMouse.setOffsetLeft(nLeft2);
	this.divStep.setOffsetLeft(nLeft4);
	
	//PC일때만 적용
	if(!this.smfIsMobile()){
		nLeft = parseInt((nAllWidth - this.div01.getOffsetWidth()) /2);
		this.divSub0.setOffsetLeft(nLeft);
		this.divSub1.setOffsetLeft(nLeft);
		this.divSub2.setOffsetLeft(nLeft);
		this.divSub3.setOffsetLeft(nLeft);
		this.divSub4.setOffsetLeft(nLeft);
		this.divSub5.setOffsetLeft(nLeft);
		this.divSub6.setOffsetLeft(nLeft);
		this.div01.setOffsetLeft(nLeft);
	}
	
	this.resetScroll();
};

//나의 서비스 설정
this.btnMysetting_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.popInfo = {};
	this.popInfo.id = "myServiceSetting";
	this.popInfo.pUrl = "commP::commmyServiceSetting.xfdl";
	this.popInfo.callbackScope = this;
	this.popInfo.callbackFunc = "fnNoticeAll";
	this.smfDivPop(this.popInfo,false);
};

//commP::myServiceSetting.xfdl 콜백함수
this.fnNoticeAll = function(obj)
{
    trace("fnNoticeAll" + obj );
};


this.fnStepClik = function(stepNo){
	this.arrCompId = ["btnNice","btnParents","btnExam","btnComplaint", "btnNonProfitCo", "btnApply"];
	
	var sltDiv = this.arrCompId.indexOf(this.div00.form.dsSaveProfile.getColumn(stepNo,"compId"));

	for (var i=1;i<this.divCnt+1;i++){		
		if(sltDiv+1 == i){
			this.components["divSub"+i].set_visible(true);
			this.components["divSub"+i].bringToFront();
		}else{
			this.components["divSub"+i].set_visible(false);
			this.components["divSub"+i].bringToPrev();
		}

		this.divStep.bringToFront();

	}

};
this.Main_sub0_ontouchstart = function(obj:nexacro.Form,e:nexacro.TouchEventInfo)
{
	this.mainClientX = e.touchinputinfos[0].clientx;	//현재 위치 저장
};

this.Main_sub0_ontouchend = function(obj:nexacro.Form,e:nexacro.TouchEventInfo)
{
	var newClientX = e.touchinputinfos[0].clientx;
	var moveX = 0;
	var vForm = this.divStep.form;
	//현재 선택된 화면 번호
	var mainNo = vForm.stepNo;
	
	if(newClientX > this.mainClientX){		// 왼쪽에서 오른쪽으로 이동 (앞페이지)
		moveX = newClientX - this.mainClientX;
		if(moveX > this.mainMvSize){ //페이지 이동할 만큼 움직인 경우
			//step 같이 이동
			vForm.btnStepMv(mainNo-1);
		}
		
	}else{	// 오른쪽에서 왼쪽으로 이동 (다음페이지)
		moveX = this.mainClientX - newClientX;
		if(moveX > this.mainMvSize){ //페이지 이동할 만큼 움직인 경우
			//step 같이 이동
			vForm.btnStepMv(mainNo+1);
		}
	}
};
]]></Script>
  </Form>
</FDL>
