    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    대국민포탈메인사이즈 테스트
*  @FileName 	samplePortalResize
*  @Creator 	투비소프트
*  @CreateDate 	2022.07.21
*  @Desction    대국민포탈메인사이즈 테스트
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.07.21     	TOBESOFT 	               최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/


/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/

this.fnMiddleAlign = function()
{
	var nAllWidth = this.width;  // 전체 form의 사이즈
	var nMaxWidth = 1200; // 가운데정렬되는 Div의 가로사이즈
	var nLeft,nWidth;
	
	if(nAllWidth >= nMaxWidth)	//1280 사용
	{
		nLeft = parseInt((nAllWidth - nMaxWidth) / 2);
		if(nLeft < 0) nLeft = 0;
		
		nWidth = nMaxWidth;
	}
	else
	{
		nLeft = 0;
		nWidth = nAllWidth;
	}
	// 1번째 
	this.div00.setOffsetLeft(nLeft);
	this.div00.setOffsetWidth(nWidth);	
	// 2번째 
//	this.div00_00.setOffsetLeft(nLeft);
//	this.div00_00.setOffsetWidth(nWidth);		
}

this.samplePortalResize_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnMiddleAlign();		
};

// 서비스 바로가기 
this.btnServiceLink_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sBtnKey = String(obj.id).substr(String(obj.id).length-1);
	var type = "link";	//새창
	var pageUrl = "";
	var param = {};
	
	if(this.smfContainsStr(window.location.host, "local")){		//로컬인 경우
			param.server = "local";
	}else if (this.smfContainsStr(window.location.host, "dev")){	//개발인 경우
			param.server = "dev";
	}else if (this.smfContainsStr(window.location.host, "tst")){	//시험인 경우
			param.server = "test";
	}else if (!this.smfContainsStr(window.location.host, "local") && 
			  !this.smfContainsStr(window.location.host, "dev") &&
			  !this.smfContainsStr(window.location.host, "tst")){	//운영인 경우
			param.server = "prod";
	}
	
	trace("window.location.host: " + window.location.host);
	trace("param.server: " + param.server);
		
	if(sBtnKey=="1") {
		//교육제증명
		type = "open";	//메뉴이동
		pageUrl = "pa_pas_mms_cs::pas_mmscs00_m00.xfdl";
	
	}else if(sBtnKey=="2") {
		//테스트 
		param.subSys = this.getOwnerFrame().form.divTop.form.dsMenu.lookup("menuId","8007","menuUrlAddr");
		trace("menuUrlAddr: " + param.subSys);
		
		//교육비원클릭
		//param.subSys = "EWS";
	}else if(sBtnKey=="3") {
		//학부모서비스(임시버튼 생성. 추후삭제)
		param.subSys = this.getOwnerFrame().form.divTop.form.dsMenu.lookup("menuId","8003","menuUrlAddr");
		
	}else if(sBtnKey=="4") {
		//업무지원
		param.subSys = "AFS";
	
	}else if(sBtnKey=="5") {
		//에듀로 : 학생학부모 참여 교육설문
		param.subSys = "EDS";

	}else if(sBtnKey=="6") {
		//교육정보개방
		pageUrl = this.getOwnerFrame().form.divTop.form.dsMenu.lookup("menuId","8010","menuUrlAddr");
	}
	
	this.smfSetServiceLink(pageUrl,type,param);
	
};
]]></Script>
    <Objects/>
  </Form>
