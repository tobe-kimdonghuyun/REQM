      <Layout name="Layout0" screenid="mobileP,tabletP" width="640" height="946" mobileorientation="portrait" type="default">
        <ImageViewer id="img00" height="946" left="0" top="0" image="url('imagerc::main_M/main_bg_neisParents_1024_N.gif')" right="0" imagealign="right middle"/>
