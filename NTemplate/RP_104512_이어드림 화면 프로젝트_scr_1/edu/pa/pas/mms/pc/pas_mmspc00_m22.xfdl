        <ImageViewer id="img00" taborder="0" left="0" top="0" image="url('imagerc::main/main_bg_neisParents_1920_N1.gif')" cssclass="display" height="727" accessibilitylabel="학부모서비스 소개" onclick="img00_onclick" initvalueid="ivImgAccessibilityOn" text="" right="0"/>
        <Div id="div00" taborder="1" width="1200" height="453" top="225" left="17.19%" initvalueid="ivDivAccessibilityOff" formscrolltype="none">
          <Layouts>
            <Layout>
              <ImageViewer id="img00" taborder="0" text="자녀 교육의 징검다리" left="30" top="50" width="444" height="80" cssclass="font52R_W" initvalueid="ivTitleAccessibilityOn" tabstop="false"/>
              <ImageViewer id="img01" taborder="1" text="학부모서비스" left="30" top="120" width="304" height="80" cssclass="font52B_W" initvalueid="ivTitleAccessibilityOn" tabstop="false"/>
              <ImageViewer id="img02" taborder="2" text="가정과 학교를 연결하는 학부모서비스에 오신 것을 환영합니다." left="30" top="202" width="540" height="33" cssclass="font20R_W" initvalueid="ivTitleAccessibilityOn" tabstop="false"/>
              <Button id="btnShortcuts" taborder="3" text="바로가기" left="30" top="250" width="160" height="50" cssclass="btn_WF_shortcuts" initvalueid="ivBtnAccessibilityLink" onclick="div00_btnShortcuts_onclick" accessibilitydescription="새창열림"/>
            </Layout>
            <Layout name="Layout0">
              <Button id="btnShortcuts" cssclass="btn_main_shortcuts" top="380" left="10" width="210" height="70"/>
              <ImageViewer id="img02" cssclass="font28R_W_M" left="10" top="238" height="100" right="20"/>
