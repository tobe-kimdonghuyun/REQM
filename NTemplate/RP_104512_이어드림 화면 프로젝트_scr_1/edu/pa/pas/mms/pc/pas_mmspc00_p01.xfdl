  <Form id="pas_mmscs03_p02" width="538" height="609" titletext="학부모서비스 알림창" cssclass="frm_Pop_bgTrsprt" onload="pas_mmscs03_p02_onload">
    <Layouts>
      <Layout height="609" width="538" screenid="ScreenDeskTopP">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="div00" taborder="1" left="0" top="44" width="538" height="564" cssclass="div_Pop_shadowBox_C" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Button id="btnClose" taborder="0" text="확인" left="60" top="444" height="60" cssclass="btn_WF_popup" width="418" initvalueid="ivBtnAccessibilityButton" onclick="div00_btnClose_onclick"/>
              <Static id="label00_00_00" taborder="1" text="안녕하세요.&#13;&#10;&lt;b v='true'&gt;나이스 학부모서비스가 새롭게 개편되었습니다.&lt;/b&gt;&#13;&#10;현재 학부모서비스는 안정적으로 서비스를 제공하기위해 다양한 방법으로 최종 점검을 진행하고 있습니다. 다소 불편하시더라도 양해 부탁드리며, 더 좋은 서비스로 찾아 뵙겠습니다. 감사합니다." left="64" top="73" width="416" height="170" cssclass="font18R" initvalueid="ivStcAccessibilityOn" onclick="div00_label00_00_onclick" verticalAlign="top" usedecorate="true"/>
              <Static id="label00_00_01" taborder="2" text="▣ 서비스 개통 예정일: 2023년 7월 20일" left="64" top="263" width="416" height="40" cssclass="font20B" initvalueid="ivStcAccessibilityOn" onclick="div00_label00_00_onclick" textAlign="left"/>
              <Static id="label00_00_00_00_00" taborder="3" text="자녀의 학교생활기록은 정부24에서 제증명 발급 또는 나이스플러스(neisplus.kr)에서 학생의 학교생활 메뉴를 확인할 수 있습니다." left="84" top="328" width="396" height="98" cssclass="font18R" initvalueid="ivStcAccessibilityOn" onclick="div00_label00_00_onclick" verticalAlign="top"/>
              <Static id="label00_00_00_00_01" taborder="4" text="※" left="64" top="328" width="24" height="33" cssclass="font18R" initvalueid="ivStcAccessibilityOn" onclick="div00_label00_00_onclick" verticalAlign="top"/>
            </Layout>
