              <ImageViewer id="subTitle1" taborder="0" text="대입전형자료(학교생활기록부)" left="10" top="0" width="480" height="62" cssclass="font40B" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00" taborder="1" text="고등학교 졸업생이 대입전형자료(학교생활기록부)를 온라인으로 직접 생성신청하여 대학에 제공하는 서비스입니다." left="10" top="82" width="533" height="54" cssclass="sta_WF_HangTxt_blue" initvalueid="ivStcAccessibilityOn"/>
