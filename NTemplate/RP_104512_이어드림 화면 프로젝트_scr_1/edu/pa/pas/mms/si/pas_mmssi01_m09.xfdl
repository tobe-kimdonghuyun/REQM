    <Script type="xscript5.1"><![CDATA[this.btnServiceLink_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var pageUrl = null;
	var param = {};

	if(this.smfContainsStr(window.location.host, "local")){		//로컬인 경우
		param.server = "local";
	}else if (this.smfContainsStr(window.location.host, "dev")){	//개발인 경우
		param.server = "dev";
	}else if (this.smfContainsStr(window.location.host, "tst")){	//시험인 경우
		param.server = "test";
	}else if (!this.smfContainsStr(window.location.host, "local") && 
			  !this.smfContainsStr(window.location.host, "dev") &&
			  !this.smfContainsStr(window.location.host, "tst")){	//운영인 경우
		param.server = "prod";
	}

	param.subSys = "UDA";
	var type = "link";
	
	this.smfSetServiceLink(pageUrl,type,param);
};

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Div 초기화
	this.smfInitForm(obj);

	this.smfSearchService('selectCoaCtr')
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.dsCoaCtr.getRowCount() > 0){
				var vsCoaAyr = this.dsCoaCtr.getColumn(0, "coaAyr");
				var vsAplcnBgngAyr = this.dsCoaCtr.getColumn(0, "aplcnBgngAyr");
				var vsAplcnEndAyr = this.dsCoaCtr.getColumn(0, "aplcnEndAyr");
				
				var vsAplcnBgngAyrByGrdtn = this.smfStr(parseInt(vsAplcnBgngAyr) + 1).substr(2, 2);
				var vsAplcnEndAyrByGrdtn = this.smfStr(parseInt(vsAplcnEndAyr) + 1).substr(2, 2);
				
				var vsCoaGudnCn01 = "※ "+vsCoaAyr+"학년도 대입 신청 대상자";
				var vsCoaGudnCn02 = ": "+vsAplcnEndAyr+"학년도 졸업자('"+vsAplcnEndAyrByGrdtn+".2.졸업) ~ "+vsAplcnBgngAyr+"학년도 졸업자('"+vsAplcnBgngAyrByGrdtn+".2.졸업)";
				
				if(this.smfIsMobile()){
					this.divGroup3.form.staCoaGudnCn01.set_text(vsCoaGudnCn01 + " " + vsCoaGudnCn02);
				} else {
					this.divGroup3.form.staCoaGudnCn01.set_text(vsCoaGudnCn01);
					this.divGroup3.form.staCoaGudnCn02.set_text(vsCoaGudnCn02);
				}
			}
			
		});
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
};
]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">selectCoaCtr</Col>
            <Col id="url">/pas_uum_uc00_001.do</Col>
            <Col id="inDatasets">dsSearch</Col>
            <Col id="outDatasets">dsCoaCtr</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" oncolumnchanged="dsSearch_oncolumnchanged" useclientlayout="false">
        <ColumnInfo>
          <Column id="coaAyr" type="STRING" size="256"/>
          <Column id="coaRcritScCd" type="STRING" size="256"/>
          <Column id="coaRcritScNm" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsCoaCtr" useclientlayout="true">
        <ColumnInfo>
          <Column id="coaAyr" type="STRING" size="4"/>
          <Column id="coaRcritScCd" type="STRING" size="1"/>
          <Column id="rcritNm" type="STRING" size="1"/>
          <Column id="coaSvcAplyBgngYmd" type="STRING" size="8"/>
          <Column id="coaSvcAplyEndYmd" type="STRING" size="8"/>
          <Column id="rcritScByBgngYmd" type="STRING" size="1"/>
          <Column id="rcritScByEndYmd" type="STRING" size="8"/>
          <Column id="rcritScByBgngYmdNsche" type="STRING" size="8"/>
          <Column id="rcritScByEndYmdNsche" type="STRING" size="8"/>
          <Column id="rcritScByBgngYmdSche" type="STRING" size="8"/>
          <Column id="rcritScByEndYmdSche" type="STRING" size="8"/>
          <Column id="aplcnBgngAyr" type="STRING" size="256"/>
          <Column id="aplcnEndAyr" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
  </Form>
</FDL>
