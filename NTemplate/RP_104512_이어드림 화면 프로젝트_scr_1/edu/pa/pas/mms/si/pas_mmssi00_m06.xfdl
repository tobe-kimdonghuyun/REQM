        <Static id="sta02" left="20" top="160" height="70" cssclass="font44B" text="대한민국 교육의 내일을 연결하다" taborder="1" right="20" textAlign="center"/>
        <Static id="sta03" left="20" top="259" height="103" cssclass="font32B,color3772" text="나이스 (교육행정정보시스템 : National Education Information System)" right="20" fittocontents="height" font="normal 700 32px/1.2 &quot;Noto Sans KR,NotoSansKR-Regular,Malgun Gothic,Arial,MS PGothic&quot;" taborder="2"/>
        <Static id="sta04" left="20" top="sta03:10" height="230" cssclass="font28R" text="교육부와 17개 시도교육청, 교육지원청, 유·초중등학교 및 특수학교가 모든 교육행정 정보를 전자적으로 연계 처리하며, 국민 편의증진을 위해 행정안전부, 대법원 등 유관기관의 행정정보를 이용하는 종합 교육행정정보시스템입니다." right="20" taborder="3" fittocontents="height"/>
