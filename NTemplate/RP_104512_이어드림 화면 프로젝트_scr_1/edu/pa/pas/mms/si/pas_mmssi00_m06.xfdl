        <Static id="sta03" taborder="2" text="나이스 (교육행정정보시스템 , National &#13;Education Information System)" left="479" top="70" width="718" height="30" cssclass="font22B,color2b72" initvalueid="ivStcAccessibilityOn" wordSpacing="-3px"/>
        <Static id="sta04" taborder="3" text="교육부와 17개 시도교육청, 교육지원청, 유·초중등학교 및 특수학교가 모든 교육행정 정보를 &#13;&#10;전자적으로 연계 처리하며, 국민 편의증진을 위해 행정안전부, 대법원 등 유관기관의 행정정보를 &#13;&#10;이용하는 종합 교육행정정보시스템입니다." left="479" top="105" width="718" height="90" cssclass="font18R" initvalueid="ivStcAccessibilityOn" onclick="sta04_onclick"/>
        <Static id="sta00" taborder="4" left="0" top="224" height="3" right="0" border="1px solid #d9d9d9,0px solid #d9d9d9,0px solid #d9d9d9" initvalueid="ivStcAccessibilityOff"/>
        <Div id="divContents" taborder="5" left="0" top="237" height="3390" width="1200" url="pa_pas_mms_si::pas_mmssi00_m03.xfdl" initvalueid="ivDivAccessibilityOff" background="#ffffff" text=""/>
