include "lib::cm_script.xjs";

this.pas_mmssi00_m00_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	//0501 CF 일괄등록
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.divTab_btnTabCtrl_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sPostfix ="";
	if(this.smfIsMobile()){
		sPostfix = "_M";
	}

 	var sContUrl = "pa_pas_mms_si::pas_mmssi00_m01.xfdl";
	var tabNo = String(obj.id).substr(String(obj.id).length-1);	
	if (tabNo=="2")	sContUrl = "pa_pas_mms_si::pas_mmssi00_m02.xfdl";
	if (tabNo=="3")	sContUrl = "pa_pas_mms_si::pas_mmssi00_m03.xfdl";

	this.divContents.set_url(sContUrl);
	this.divTab.form.btnTab1.set_cssclass("btn_WF_tab"+sPostfix);
	this.divTab.form.btnTab2.set_cssclass("btn_WF_tab"+sPostfix);
	this.divTab.form.btnTab3.set_cssclass("btn_WF_tab"+sPostfix);
	
	this.divTab.form["btnTab"+tabNo].set_cssclass("btn_WF_tab"+sPostfix+"_S");
};



this.sta04_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	
};
]]></Script>
