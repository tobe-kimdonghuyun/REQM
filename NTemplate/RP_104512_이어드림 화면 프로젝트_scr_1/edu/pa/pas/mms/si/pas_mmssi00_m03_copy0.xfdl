<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="pas_mmssi00_m03" width="1200" height="2470" titletext="나이스 홍보자료" onload="pas_mmssi00_m03_onload" onsize="pas_mmssi00_m03_onsize">
    <Layouts>
      <Layout height="2470" width="1200" screenid="ScreenDeskTopP">
        <ImageViewer id="title2" taborder="0" text="홍보영상" left="0" top="50" width="133" height="50" cssclass="font34B" initvalueid="ivTitleAccessibilityOn"/>
        <Div id="div_video" taborder="1" left="0" top="135" width="1200" height="718" background="url('imagerc::pas_mmssi00/sub_pr_video1B.jpg') no-repeat center center" initvalueid="iv_DivVideoPlayerOn"/>
        <ImageViewer id="img01" taborder="3" text="나이스 홍보영상소개" left="0" top="875" height="35" cssclass="font26B" initvalueid="ivTitleAccessibilityOn" width="230"/>
        <Static id="sta00" taborder="4" text="종합교육행정정보시스템 나이스! 전국 1만여 학교, 17개 시도교육청과 교육부를 네트워크로 연결하였습니다. 나이스 대국민서비스를 통해 학생은 스스로 성적과 학사일정을&#13;&#10;확인할 수 있고, 학교에서는 학생성적관리와 생활기록부, 교무업무를 편리하게, 교육청에서는 인사, 급여 등 일반행정업무를 스마트하게! 고품질 교육서비스로 여는 스마트한&#13;&#10;교육세상 나이스!" left="0" top="921" height="80" cssclass="font18R" wordWrap="char" initvalueid="ivStcAccessibilityOn" right="0"/>
        <Grid id="grd_video" taborder="5" left="1330" top="1056" height="423" cssclass="grd_videoList" binddataset="ds_prVideo" right="-1330" autofittype="col" formatid="default" selecttype="cell" initvalueid="ivGrdAccessibilityOn" accessibilitylabel="홍보영상 목록" visible="false">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="225"/>
                <Column size="881"/>
                <Column size="96"/>
              </Columns>
              <Rows>
                <Row size="141"/>
              </Rows>
              <Band id="body">
                <Cell displaytype="imagecontrol" text="bind:video" accessibilitylabel="홍보영상소개이미지" accessibilityenable="false"/>
                <Cell col="1" text="bind:title" cssclass="cell_txt24B" textAlign="left" padding="0px 0px 0px 29px" wordWrap="char"/>
                <Cell col="2" displaytype="buttoncontrol" cssclass="cell_btnMovie" edittype="normal" accessibilitylabel="재생버튼"/>
              </Band>
            </Format>
            <Format id="mobile">
              <Columns>
                <Column size="194"/>
                <Column size="336"/>
                <Column size="71"/>
              </Columns>
              <Rows>
                <Row size="141"/>
              </Rows>
              <Band id="body">
                <Cell text="bind:videoM" displaytype="imagecontrol"/>
                <Cell col="1" text="bind:titleM" cssclass="cell_txt28M" textAlign="left" padding="0px 0px 0px 29px" wordWrap="char"/>
                <Cell col="2" cssclass="cell_btnMovie_M" displaytype="buttoncontrol" edittype="button" accessibilitylabel="플레이버튼"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <ImageViewer id="title1_00" taborder="6" text="홍보 캐릭터" left="0" top="1053" width="162" height="50" cssclass="font34B" initvalueid="ivTitleAccessibilityOn"/>
        <Div id="div00" taborder="7" left="0" top="1131" width="720" height="690" cssclass="div_WF_shadowBox" initvalueid="ivDivAccessibilityOff" text="">
          <Layouts>
            <Layout>
              <Static id="sta00_00" taborder="0" text="Story" left="40" top="116" width="173" height="40" cssclass="font20B" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta01" taborder="1" text="최첨단 기술을 가진 과학 행성 '알파오'에서 온 우주인. 우주 여행 중 나이스 중학교에 불시착&#13;했다가 친절한 친구들, 선생님, 학부모님의 도움에 감격하여 지구에 정착하기로 마음 먹는다. 자신이 가진 기술로 자신을 도와준 사람들을 위해 해줄 수&#13;있는 일을 찾다가 '나이스'를 개발하게 된다." left="40" top="160" width="597" height="117" cssclass="font18R,color7676" initvalueid="ivStcAccessibilityOn" letterSpacing="0px" verticalAlign="top"/>
              <Static id="sta00_00_00" taborder="2" text="성격" left="40" top="289" width="173" height="40" cssclass="font20B" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta01_00" taborder="3" text="부끄러움이 좀 많지만 스마트하고 솔직하다. 항상 &#13;새로운 생각을 듣는 것을 &#13;&#10;좋아하고 좋은 아이디어를 시스템에 반영하는 걸 즐긴다." left="40" top="332" width="577" height="60" cssclass="font18R,color7676" initvalueid="ivStcAccessibilityOn" letterSpacing="0px" verticalAlign="top"/>
              <Static id="sta00_00_00_00" taborder="4" text="특징" left="40" top="403" width="173" height="40" cssclass="font20B" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta01_00_00" taborder="5" text="머리의 뾰족한 부분의 아이콘으로 감정을&#13; 표현하고 의견을 들을 땐 안테나 모양으로도&#13; 바뀐다." left="40" top="447" width="629" height="60" cssclass="font18R,color7676" initvalueid="ivStcAccessibilityOn" letterSpacing="0px" verticalAlign="top"/>
              <Static id="sta00_00_00_00_00" taborder="6" text="네이밍 컨셉" left="40" top="510" width="173" height="40" cssclass="font20B" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta01_00_00_00" taborder="7" text="&lt;우주&gt;의 의미와 &lt;나이스(NEIS)가 관할하는 완벽한 교육행정 세상&gt;을 의미하는&#13;&#10; 'Universe'에서 착안하였다." left="40" top="554" width="607" height="60" cssclass="font18R,color7676" initvalueid="ivStcAccessibilityOn" letterSpacing="0px" verticalAlign="top" onclick="div00_sta01_00_00_00_onclick"/>
              <ImageViewer id="img00_00" taborder="8" left="20" top="16" width="132" cssclass="display" image="url('imagerc::pas_mmssi00/sub_content_image_unilogo.png')" initvalueid="ivTitleAccessibilityOff" onclick="img00_00_onclick" stretch="fixaspectratio" text="" bottom="sta00_00:10"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="sta01" left="40" top="sta00_00:6" height="296" cssclass="font28R" text="최첨단 기술을 가진 과학 행성 '알파오'에서 온 우주인. 우주 여행 중 나이스 중학교에 불시착&#13;했다가 친절한 친구들, 선생님, 학부모님의 도움에 감격하여 지구에 정착하기로 마음 먹는다. 자신이 가진 기술로 자신을 도와준 사람들을 위해 해줄 수&#13;있는 일을 찾다가 '나이스'를 개발하게 된다." right="36" fittocontents="height"/>
              <Static id="sta00_00_00" left="40" top="sta01:30" width="173" height="40" cssclass="font28B"/>
