              <Button id="btnTab2" taborder="1" text="추진배경 및 경과" left="211" top="0" width="157" height="40" cssclass="btn_WF_tab" initvalueid="ivBtnAccessibilityButton" onclick="divTab_btnTabCtrl_onclick"/>
              <Button id="btnTab3" taborder="2" text="홍보자료" left="378" top="0" width="105" height="40" cssclass="btn_WF_tab" initvalueid="ivBtnAccessibilityButton" onclick="divTab_btnTabCtrl_onclick"/>
