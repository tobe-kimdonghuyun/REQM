        <Static id="sta03" taborder="5" text="나이스 (교육행정정보시스템 : National &#13;Education Information System)" left="479" top="666" width="598" height="30" cssclass="font18B,color2b72" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta04" taborder="6" text="교육부와 17개 시도교육청, 178개 교육지원청, 전국&#13;1만여개 초중고 및 특수학교가 모든 교육행정 정보를&#13; 전자적으로 연계 처리하며, 국민 편의증진을 위해 &#13;행정안전부(G4C), 대법원 등 유관기관의 행정정보를 &#13;이용하는 종합 교육행정정보시스템입니다." left="479" top="691" width="718" height="90" cssclass="font16R" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00" taborder="7" left="0" top="860" height="3" right="0" border="1px solid #d9d9d9,0px solid #d9d9d9,0px solid #d9d9d9" initvalueid="ivStcAccessibilityOff"/>
        <Div id="divTab" taborder="8" left="0" top="913" height="40" right="0" initvalueid="ivDivAccessibilityOn" accessibilitylabel="탭 버튼 그룹박스">
