<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="NP11M1" width="1200" height="350" titletext="비영리법인">
    <Layouts>
      <Layout height="350" width="1200" screenid="ScreenDeskTopP">
        <ImageViewer id="img01" taborder="0" left="0" top="0" width="530" height="350" cssclass="Roundbox20" image="url('imagerc::pas_mmssi00/sub_serviceReport6_N.gif')" initvalueid="ivImgAccessibilityOn" accessibilitylabel="비영리법인 소개"/>
        <Div id="divGroup6" taborder="1" text="div00" left="600" top="0" height="350" width="600" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="subTitle1" taborder="0" text="비영리법인" left="10" top="0" width="190" height="62" cssclass="font40B" initvalueid="ivTitleAccessibilityOn"/>
              <Static id="sta00" taborder="1" text="전국 3천 여 개의 비영리법인 운영자가 임원취임 승인 외 4종(정관변경허가, &#13;&#10;이사회 소집승인, 상근직원정수승인, 수익사업승인)의 허가 및 승인사항 처리를 &#13;&#10;온라인으로 실시하여 기존의 방문 접수에 따른 민원인 불편사항을 해소하고 &#13;&#10;편익과 행정 만족도를 높일 수 있는 서비스입니다. " left="10" top="82" width="570" height="128" cssclass="sta_WF_HangTxt_blue" initvalueid="ivStcAccessibilityOn" onclick="divGroup6_sta00_onclick"/>
              <Button id="btnServiceLink" taborder="2" text="서비스 바로가기" left="10" top="290" width="240" height="60" cssclass="btn_WF_serviceLink_blue" initvalueid="ivBtnAccessibilityLink" onclick="btnServiceLink_onclick" accessibilitydescription="새창열림"/>
            </Layout>
            <Layout name="Layout0">
              <ImageViewer id="subTitle1" cssclass="font42B" left="0" top="0" width="200" height="62"/>
              <Static id="sta00" cssclass="sta_WF_HangTxt_blue_M" left="0" top="subTitle1:17" height="211" text="전국 3천 여 개의 비영리법인 운영자가 임원취임 승인&#13;외 4종(정관변경허가, 이사회소집승인, 상근직원정&#13;수승인, 수익사업승인)의 허가 및 승인사항 처리를 &#13;온라인으로 실시하여 기존의 방문 접수에 따른 &#13;민원인 불편사항을 해소하고 편익과 행정 만족도를&#13; 높일 수 있는 서비스입니다." right="0" fittocontents="height"/>
              <Button id="btnServiceLink" cssclass="btn_WF_serviceLink_blue_M" left="0" right="0" top="sta00:43" height="120" text="서비스 바로가기"/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
      <Layout name="Layout0" screenid="mobileP,tabletP" width="640" height="1150" mobileorientation="portrait" type="default">
        <ImageViewer id="img01" left="20" top="0" height="600" image="url('imagerc::pas_mmssi00_M/sub_serviceReport6_M_N.gif')" cssclass="Roundbox16" right="20" imagealign="right middle"/>
        <Div id="divGroup6" left="20" top="img01:41" height="507" right="20"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[this.btnServiceLink_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var pNum = String(obj.parent.parent.name).substr(8);
	var pageUrl = null;
	var param = {};

	if(this.smfContainsStr(window.location.host, "local")){		//로컬인 경우
		param.server = "local";
	}else if (this.smfContainsStr(window.location.host, "dev")){	//개발인 경우
		param.server = "dev";
	}else if (this.smfContainsStr(window.location.host, "tst")){	//시험인 경우
		param.server = "test";
	}else if (!this.smfContainsStr(window.location.host, "local") && 
			  !this.smfContainsStr(window.location.host, "dev") &&
			  !this.smfContainsStr(window.location.host, "tst")){	//운영인 경우
		param.server = "prod";
	}

	param.subSys = "BDM";
	var type = "link";
	
	this.smfSetServiceLink(pageUrl,type,param);
};
]]></Script>
  </Form>
</FDL>
