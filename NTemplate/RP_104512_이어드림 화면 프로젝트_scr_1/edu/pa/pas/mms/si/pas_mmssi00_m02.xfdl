<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="pas_mmssi00_m02" width="1200" height="1860" titletext="나이스 추진배경 및 경과" onload="pas_mmssi00_m02_onload" onsize="pas_mmssi00_m02_onsize">
    <Layouts>
      <Layout height="1860" width="1200" screenid="ScreenDeskTopP">
        <ImageViewer id="title1" taborder="0" text="나이스 추진배경" left="0" top="60" width="226" height="50" cssclass="font34B" initvalueid="ivTitleAccessibilityOn"/>
        <Div id="div00" taborder="1" left="0" top="138" width="1200" height="236" cssclass="div_WF_hang" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="hang00" taborder="0" text="학생 성장 중심의 교육정책 도입을 위한 빅데이터, 인공지능 등을 활용 온·오프라인 융합교육지원" left="30" top="21" width="994" height="30" cssclass="sta_WF_HangTxt_Skyblue" initvalueid="ivStcAccessibilityOn"/>
              <Static id="hang01" taborder="1" text="교육기관, 교육행정기관 등 다양한 교육현장의 요구 수렴 및 공통 프레임워크 적용을 위한 사용자 친화적인 소통 채널 마련 및 유기적 서비스 구축" left="30" top="65" width="986" height="30" cssclass="sta_WF_HangTxt_Skyblue" initvalueid="ivStcAccessibilityOn"/>
              <Static id="hang02" taborder="2" text="법·제도 제·개정에 따라 공공데이터 개방 대비 및 과학적 행정 업무 구현을 위한 업무 프로그램 개발" left="30" top="109" width="908" height="30" cssclass="sta_WF_HangTxt_Skyblue" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00" taborder="3" text="※ 데이터 3법 개정, 데이터 기반 행정 활성화에 관한 법률 등재·개정" left="47" top="136" width="516" height="27" cssclass="font14M_gray" initvalueid="ivStcAccessibilityOn"/>
              <Static id="hang02_00" taborder="4" text="지능형 멀티 크라우드 기반의 운영 인프라 환경에 적합한 마이크로 서비스 아키텍처 기반의 업무 프로그램 설계 및 구현" left="30" top="179" width="908" height="30" cssclass="sta_WF_HangTxt_Skyblue" initvalueid="ivStcAccessibilityOn"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="hang00" cssclass="sta_WF_HangTxt_blue_M" left="20" top="44" height="89" right="10" text="학생 성장 중심의 교육정책 도입을 위한 빅데이터, 인공지능 등을 활용 온·오프라인 융합교육지원" fittocontents="height"/>
              <Static id="hang01" cssclass="sta_WF_HangTxt_blue_M" left="21" top="hang00:29" height="135" right="10" fittocontents="height"/>
              <Static id="hang02" cssclass="sta_WF_HangTxt_blue_M" left="21" top="hang01:28" height="87" right="10" fittocontents="height"/>
              <Static id="hang02_00" left="21" top="sta00:30" height="140" right="10" cssclass="sta_WF_HangTxt_blue_M"/>
              <Static id="sta00" left="41" top="hang02:0" width="546" height="70" cssclass="font24R,color7676" text="※ 데이터 3법 개정, 데이터 기반 행정 활성화에 관한 법률 등재·개정"/>
            </Layout>
          </Layouts>
        </Div>
        <ImageViewer id="title2" taborder="2" text="나이스 추진경과" left="0" top="477" width="226" height="50" cssclass="font34B" initvalueid="ivTitleAccessibilityOn"/>
        <Grid id="grd00" taborder="3" left="0" top="562" height="1278" cssclass="grd_history" binddataset="ds_grd00" autofittype="col" width="1200" initvalueid="ivGrdAccessibilityOn" selecttype="cell" scrollbartype="none none" scrolltype="none" extendsizetype="row" autosizingtype="row">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="200"/>
                <Column size="824"/>
              </Columns>
              <Rows>
                <Row size="116"/>
              </Rows>
              <Band id="body">
                <Cell cssclass="cell_txt30B,cell_lineB" autosizerow="limitmin" text="bind:year"/>
                <Cell col="1" textAlign="left" text="expr:nexacro.replaceAll(contents ,&quot;\\n&quot;,String.fromCharCode(10))"/>
              </Band>
            </Format>
            <Format id="mobile">
              <Columns>
                <Column size="105"/>
                <Column size="392"/>
              </Columns>
              <Rows>
                <Row size="106"/>
              </Rows>
              <Band id="body">
                <Cell text="bind:year" cssclass="cell_txt30B,cell_lineB" verticalAlign="top" padding="30px 0px"/>
                <Cell col="1" text="expr:nexacro.replaceAll(contents ,&quot;\\n&quot;,String.fromCharCode(10))" textAlign="left" wordWrap="char" padding="32px 10px" verticalAlign="top"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
      </Layout>
      <Layout name="Layout0" screenid="mobileP,tabletP" width="640" height="2600" mobileorientation="portrait" type="default">
        <ImageViewer id="title2" visible="true" left="26" top="div00:75" width="286" height="70" cssclass="font42B"/>
        <Grid id="grd00" visible="true" left="20" top="title2:24" height="1547" formatid="mobile" autosizingtype="row" cssclass="grd_history_M" extendsizetype="row" right="20"/>
        <ImageViewer id="title1" cssclass="font42B_C" left="140" top="50" height="62" right="140"/>
        <Div id="div00" text="" left="20" top="title1:24" height="686" right="20" formscrolltype="none" cssclass="div_WF_SummaryBox"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="ds_grd00">
        <ColumnInfo>
          <Column id="year" type="STRING" size="256"/>
          <Column id="date" type="STRING" size="256"/>
          <Column id="contents" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="year">2023</Col>
            <Col id="date">00. 00</Col>
            <Col id="contents">4세대 지능형 나이스 및 지능형 나이스 유치원 업무 교육현장 적용</Col>
          </Row>
          <Row>
            <Col id="year">2022</Col>
            <Col id="date">00. 00</Col>
            <Col id="contents">4세대 지능형 나이스 구축(인프라 1~3단계) 기본계획 수립</Col>
          </Row>
          <Row>
            <Col id="year">2021</Col>
            <Col id="date">00. 00</Col>
            <Col id="contents">4세대 지능형 나이스 구축(응용SW 개발 2단계) 기본계획 수립</Col>
          </Row>
          <Row>
            <Col id="year">2020</Col>
            <Col id="date">00. 00</Col>
            <Col id="contents">4세대 지능형 나이스 구축(응용SW 개발 1단계) 기본계획 수립\n\n지능형 나이스 유치원 업무 구축 기본계획 수립</Col>
          </Row>
          <Row>
            <Col id="year">2019</Col>
            <Col id="date">00. 00</Col>
            <Col id="contents">4세대 지능형 나이스 구축(응용SW 개발) 기본계획 수립</Col>
          </Row>
          <Row>
            <Col id="year">2018</Col>
            <Col id="date">00. 00</Col>
            <Col id="contents">나이스 학생∙학부모 모바일서비스 시범운영</Col>
          </Row>
          <Row>
            <Col id="year">2017</Col>
            <Col id="date">00. 00</Col>
            <Col id="contents">4세대 나이스 ISP(정보화전략계획) 수립 기본계획 수립</Col>
          </Row>
          <Row>
            <Col id="year">2015</Col>
            <Col id="date">00. 00</Col>
            <Col id="contents">교육정보시스템 통합재해복구체계 구축 기본계획 수립</Col>
          </Row>
          <Row>
            <Col id="year">2014</Col>
            <Col id="date">00. 00</Col>
            <Col id="contents">나이스 대국민서비스 확대 개편</Col>
          </Row>
          <Row>
            <Col id="year">2012</Col>
            <Col id="date">00. 00</Col>
            <Col id="contents">학생서비스 개통, 모바일앱 시범운영</Col>
          </Row>
          <Row>
            <Col id="year">2011</Col>
            <Col id="date">00. 00</Col>
            <Col id="contents">차세대 나이스 개통</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[
this.pas_mmssi00_m02_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.fnSetResize();
};


this.pas_mmssi00_m02_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnSetResize();

};

this.fnSetResize = function(){
	this.div00.form.resetScroll();
	this.div00.setOffsetHeight(parseInt(this.div00.form.hang02_00.getOffsetBottom(),10)+40);
	this.smfResetScroll(this.div00);
	this.resetScroll();
}]]></Script>
  </Form>
</FDL>
