    </Layouts>
    <Script type="xscript5.1"><![CDATA[this.btnServiceLink_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var pNum = String(obj.parent.parent.name).substr(8);
	var pageUrl = null;
	var param = {};

	if(this.smfContainsStr(window.location.host, "local")){		//로컬인 경우
		param.server = "local";
	}else if (this.smfContainsStr(window.location.host, "dev")){	//개발인 경우
		param.server = "dev";
	}else if (this.smfContainsStr(window.location.host, "tst")){	//시험인 경우
		param.server = "test";
	}else if (!this.smfContainsStr(window.location.host, "local") && 
			  !this.smfContainsStr(window.location.host, "dev") &&
			  !this.smfContainsStr(window.location.host, "tst")){	//운영인 경우
		param.server = "prod";
	}

	param.subSys = "AFS";
	var type = "link";
	
	this.smfSetServiceLink(pageUrl,type,param);
};

//0501 CF 일괄등록]]></Script>
  </Form>
</FDL>
