<FDL version="2.1">
  <Form id="NP11M1" width="1200" height="350" titletext="업무지원">
    <Layouts>
      <Layout height="350" width="1200" screenid="ScreenDeskTopP">
        <ImageViewer id="img01" taborder="0" left="0" top="0" width="530" height="350" cssclass="Roundbox20" image="url('imagerc::pas_mmssi00/sub_serviceReport9_N.gif')" initvalueid="ivImgAccessibilityOn" accessibilitylabel="업무지원소개"/>
        <Div id="divGroup9" taborder="1" text="div00" left="600" top="0" height="350" width="600" initvalueid="ivDivAccessibilityOff" visible="true">
          <Layouts>
            <Layout>
              <ImageViewer id="subTitle1" taborder="0" text="업무지원" left="10" top="0" width="150" height="62" initvalueid="ivTitleAccessibilityOn" cssclass="font40B"/>
              <Static id="sta00" taborder="1" text="업무지원 서비스는 교직원 및 대외 사용자의 효율적인&#13; 교육(행정)기관 &#13;&#10;업무 처리를 지원합니다." left="10" top="92" width="534" height="60" cssclass="sta_WF_HangTxt_blue" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta01" taborder="2" text="방과후학교 프로그램 운영, 식재료 검사·검수, 위생점검결과 등록 등의 &#13;&#10;서비스를 제공합니다." left="10" top="172" width="574" height="60" cssclass="sta_WF_HangTxt_blue" initvalueid="ivStcAccessibilityOn"/>
              <Button id="btnServiceLink" taborder="3" text="서비스 바로가기" left="10" top="290" width="240" height="60" cssclass="btn_WF_serviceLink_blue" initvalueid="ivBtnAccessibilityLink" onclick="btnServiceLink_onclick" accessibilitydescription="새창열림"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="sta00" left="0" top="subTitle1:17" height="85" cssclass="sta_WF_HangTxt_blue_M" text="업무지원 서비스는 교직원 및 대외 사용자의 효율적인 교육(행정)기관 업무 처리를 지원합니다." right="0" fittocontents="height"/>
              <Static id="sta01" left="0" top="sta00:11" height="85" cssclass="sta_WF_HangTxt_blue_M" text="방과후학교 프로그램 운영, 식재료 검사·검수, &#13;위생점검결과 등록 등의 서비스를 제공합니다." right="0" fittocontents="height"/>
              <Button id="btnServiceLink" cssclass="btn_WF_serviceLink_blue_M" left="0" height="120" right="0" top="sta01:43" text="서비스 바로가기"/>
              <ImageViewer id="subTitle1" left="0" top="0" width="175" height="62"/>
