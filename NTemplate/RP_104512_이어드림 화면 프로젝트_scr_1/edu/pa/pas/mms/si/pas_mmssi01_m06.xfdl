              <ImageViewer id="subTitle1" taborder="0" text="교육비 원클릭 신청시스템" left="10" top="0" width="400" height="62" initvalueid="ivTitleAccessibilityOn" cssclass="font40B"/>
              <Static id="sta00" taborder="1" text="교육비 원클릭 신청시스템은 초중고 학생 교육급여 및 교육비지원 기준을 &#13;&#10;확인할 수 있는 기능을 제공합니다." left="10" top="82" width="564" height="60" cssclass="sta_WF_HangTxt_blue" initvalueid="ivStcAccessibilityOn" onclick="divGroup7_sta00_onclick"/>
              <Static id="sta01" taborder="2" text="교육비 원클릭 신청시스템을 통해 전년도 교육비지원 대상자의 납부유예 &#13;&#10;대상 여부를 확인할 수 있습니다." left="10" top="152" width="564" height="60" cssclass="sta_WF_HangTxt_blue" initvalueid="ivStcAccessibilityOn" onclick="divGroup7_sta01_onclick"/>
              <Button id="btnServiceLink" taborder="3" text="서비스 바로가기" left="10" top="290" width="240" height="60" cssclass="btn_WF_serviceLink_blue" initvalueid="ivBtnAccessibilityLink" onclick="btnServiceLink_onclick" accessibilitydescription="새창열림"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="sta00" cssclass="sta_WF_HangTxt_blue_M" left="0" top="subTitle1:17" height="85" text="교육비 원클릭 신청시스템은 초중고 학생 교육급여 및 교육비지원기준을 확인할 수 있는 기능을 제공합니다." right="0" fittocontents="height"/>
              <Static id="sta01" cssclass="sta_WF_HangTxt_blue_M" left="0" top="sta00:11" height="85" text="교육비 원클릭 신청시스템을 통해 전년도 교육비지원 대상자의 납부유예 대상여부를 확인 할 수 있습니다." right="0" fittocontents="height"/>
