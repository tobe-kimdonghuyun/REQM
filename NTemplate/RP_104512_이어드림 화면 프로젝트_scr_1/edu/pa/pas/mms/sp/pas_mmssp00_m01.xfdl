        <ImageViewer id="suTitle1" taborder="9" text="웹접근성품질마크" left="1212" top="355" width="182" height="40" cssclass="font24B" initvalueid="ivTitleAccessibilityOn" visible="false"/>
        <Div id="div01" taborder="10" left="1212" top="suTitle1:35" height="156" cssclass="div_roundBox20_BG" right="-1212" initvalueid="ivDivAccessibilityOff" visible="false">
          <Layouts>
            <Layout>
              <ImageViewer id="imgWA" taborder="0" left="30" top="32" width="138" height="91" image="url('imagerc::common/sub_common_wa.png')" cssclass="display" initvalueid="ivImgAccessibilityOn" accessibilitylabel="접근성품질마크" visible="false"/>
              <Static id="hang1" taborder="1" text="장애인 및 고령자가 웹사이트 이용에 불편이 없도록 웹접근성 표준지침을 준수한 우수 사이트에 대해 웹접근성 수준을 인정하고, 이를 상징하는 품질마크를 부여하는 인증 제도&#13;&#10;&#13;&#10;나이스 대국민서비스는 표준지침을 준수하여 품질마크를 부여받았습니다." left="200" top="28" height="96" cssclass="font16R" right="30" initvalueid="ivStcAccessibilityOn" visible="false"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="hang1" cssclass="font28R" left="10" top="277" height="313" text="장애인 및 고령자가 웹사이트 이용에 불편이 없도록 &#13;&#10;웹접근성 표준지침을 준수한 우수 사이트에 대해 &#13;&#10;웹접근성 수준을 인정하고, 이를 상징하는 품질마크를&#13;&#10;부여하는 인증 제도&#13;&#10; &#13;&#10;나이스 대국민서비스는 표준지침을 준수하여 품질마크를 부여받았습니다." textAlign="center" verticalAlign="top" right="10"/>
              <ImageViewer id="imgWA" left="164" top="70" height="178" image="url('imagerc::common_M/sub_common_wa_M.png')" right="164" minwidth="272"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="hang00" taborder="11" text="&lt;b v=&quot;true&quot;&gt;바로접근(Accessibility)링크&lt;/b&gt; : 서비스 문서 시작 부분에 반복되는 메뉴등의 링크가 많은 페이지를 이동시켜 본문을 효율적으로 이동할 수 있도록 &#13;&#10;스킵 네비게이션(바로가기)링크를 제공하고 있습니다. " left="1242" top="div01:26" height="48" cssclass="sta_WF_HangTxt_black" usedecorate="true" right="-1182" initvalueid="ivStcAccessibilityOn" visible="false"/>
        <Static id="hang01" taborder="12" text="&lt;b v=&quot;true&quot;&gt;문서 제목(title)태그&lt;/b&gt; : 모든 문서마다 문서의 제목(&amp;lt;title&amp;gt;)을 제공하고, 문서의 제목은 문서의 특징을 잘 나타내도록 간단명료하게 기술하고 있습니다." left="1242" top="hang00:24" height="30" initvalueid="ivStcAccessibilityOn" right="-1182" cssclass="sta_WF_HangTxt_black" usedecorate="true" visible="false"/>
        <Static id="hang03" taborder="13" text="&lt;b v=&quot;true&quot;&gt;문서의 구조화&lt;/b&gt; : 문서는 논리적인 접근 및 키보드 접근이 가능하도록 헤딩(&amp;lt;h1&amp;gt;~&amp;lt;h6&amp;gt;),문단(&amp;lt;p&amp;gt;),목록(&amp;lt;ul&amp;gt;,&amp;lt;ol&amp;gt;,&amp;lt;dl&amp;gt;) 등의 태그를 사용하였습니다. &#13;&#10;또한 디자인요소를 css를 사용하여 분리하고 있으며 스타일시트를 제거하더라도 콘텐츠를 이해할 수 있습니다." left="1242" top="hang01:25" height="50" right="-1182" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_HangTxt_black" usedecorate="true" visible="false"/>
        <Static id="hang04" taborder="14" text="&lt;b v=&quot;true&quot;&gt;이미지 정보&lt;/b&gt; : 텍스트가 아닌 콘텐츠에는 모두 대체 텍스트가 제공되고 있으며, 대체 텍스트 제공이 어려운 도형이미지는 별도의 텍스트정보를 제공하고 있습니다." left="1242" top="hang03:25" height="25" cssclass="sta_WF_HangTxt_black" usedecorate="true" right="-1182" initvalueid="ivStcAccessibilityOn" visible="false"/>
      </Layout>
      <Layout name="Layout0" screenid="mobileP,tabletP" width="640" height="4245" mobileorientation="portrait" type="default">
        <Static id="hang06" left="20" top="suTitle3:19" height="428" cssclass="font28R" right="20" fittocontents="height" verticalAlign="top" text="나이스 대국민서비스는 시각장애인을 위한 별도의 홈페이지를 구축하지 않고 이용할 수 있도록 하였습니다. 시각쟁애인 사용자가 나이스 대국민서비스를 이용하기 위해서는 화면을 읽어주는 별도의 스크린 리더 프로그램이 필요합니다. 스크린리더 및 기타 보조기기에 대한 안내는 정보통신보조기기 &lt;l v='http://at4u.or.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;(www.at4u.or.kr)&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;  웹사이트에서 안내 받으실 수 있으며, 중앙보조기구센터 &lt;l v='http://knat.go.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;(www.knat.go.kr)&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt; 에서 장애인보조기구 지원사업에 대한 각종 정보를 확인하실 수 있습니다." usedecorate="true"/>
