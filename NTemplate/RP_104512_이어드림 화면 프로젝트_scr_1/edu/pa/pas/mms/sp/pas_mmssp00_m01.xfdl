              <Static id="sta01" left="200" top="70" height="71" right="0" cssclass="sta_webGuide_detailBG_M"/>
            </Layout>
          </Layouts>
        </Div>
        <ImageViewer id="suTitle3" taborder="5" text="장애인이용안내" left="0" top="divDetail00:60" width="163" height="40" cssclass="font24B" initvalueid="ivTitleAccessibilityOn" tabstop="false"/>
        <Static id="hang06" taborder="6" text="나이스 대국민서비스는 시각장애인을 위한 별도의 홈페이지를 구축하지 않고 이용할 수 있도록 하였습니다. 시각장애인 사용자가 나이스 대국민서비스를 이용하기 위해서는 화면을 읽어주는 별도의 스크린 리더 프로그램이 필요합니다. 스크린리더 및 기타 보조기기에 대한 안내는 정보통신보조기기" left="0" top="suTitle3:8" height="72" cssclass="font16R" width="1200" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
        <Button id="btn00" taborder="6" text="(www.at4u.or.kr)" left="592" top="suTitle3:45" width="140" height="24" onclick="btn00_onclick" accessibilitylabel="정보통신보조기기 사이트 새창열기" color="#2b72de" textDecoration="underline" background="transparent"/>
        <Static id="hang06_00" taborder="6" text="웹사이트에서 안내 받으실 수 있으며, 중앙보조기구센터" left="725" top="suTitle3:44" height="24" cssclass="font16R" width="340" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
        <Button id="btn00_00" taborder="6" text="(www.knat.go.kr)" left="1053" top="suTitle3:45" width="140" height="24" onclick="btn00_00_onclick" accessibilitylabel="중앙보조기구센터 사이트 새창열기" textDecoration="underline" color="#2b72de" background="transparent"/>
        <Static id="hang06_00_00" taborder="6" text="에서 장애인보조기구 지원사업에 대한 각종 정보를 확인하실 수 있습니다." left="0 " top="suTitle3:69" height="24" cssclass="font16R" width="1200" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
        <ImageViewer id="suTitle3_00" taborder="7" text="키보드 사용법" left="0" top="hang06:61" width="155" height="40" cssclass="font24B" initvalueid="ivTitleAccessibilityOn" tabstop="false"/>
