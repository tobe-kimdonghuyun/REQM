<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="pas_mmssp00_m01" width="1200" height="1734" titletext="웹접근성 정책" onload="pas_mmssp00_m01_onload" onsize="pas_mmssp00_m01_onsize">
    <Layouts>
      <Layout height="1734" width="1200" screenid="ScreenDeskTopP">
        <ImageViewer id="title1" taborder="0" text="웹접근성 정책" left="0" top="54" width="195" height="50" cssclass="font34B" initvalueid="ivTitleAccessibilityOn" tabstop="false"/>
        <Div id="div00" taborder="1" left="0" top="139" height="156" cssclass="div_roundBox20_line" initvalueid="ivDivAccessibilityOff" right="0">
          <Layouts>
            <Layout>
              <Static id="hang1" taborder="0" text="나이스 대국민 서비스는 장애인, 노인 등의 정보취약계층의 사용자가 전문적인 능력없이도 웹 사이트에서 제공하는 정보에 접근할 수 있도록 최선의 노력을 기울이고 있습니다.&#13;&#10;&#13;&#10;정보취약계층의 인터넷 정보 접근을 보장하기 위해 국가표준(KICS)으로 제정된 &quot;한국형 웹 콘텐츠 접근성 지침2.1&quot;과 &quot;전자정부서비스 호환성 준수지침(행정자치부 고시 제1호)&quot;을 준수하여 제작되어 있습니다." left="30" top="28" height="96" cssclass="font16R" right="30" initvalueid="ivStcAccessibilityOn"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="hang1" cssclass="font28R" left="20" top="0" height="504" textAlign="center" verticalAlign="top" right="20" text="나이스 대국민 서비스는 장애인, 노인 등의&#13;&#10;정보취약계층의 사용자가 전문적인 능력없이도&#13;&#10;웹 사이트에서 제공하는 정보에 접근할 수 있도록&#13;&#10;최선의 노력을 기울이고 있습니다.&#13;&#10;&#13;&#10;정보취약계층의 인터넷 정보 접근을 보장하기 위해&#13;&#10;국가표준(KICS)으로 제정된&#13;&#10;&quot;한국형 웹 콘텐츠 접근성 지침2.1&quot;과&#13;&#10;&quot;전자정부서비스 호환성 준수지침&#13;&#10;(행정자치부 고시 제1호)&quot;을 준수하여&#13;&#10;제작되어 있습니다." fittocontents="height"/>
            </Layout>
          </Layouts>
        </Div>
        <ImageViewer id="suTitle2" taborder="2" text="지원 가능한 OS 및 브라우저" left="0" top="div00:59" width="270" height="40" cssclass="font24B" initvalueid="ivTitleAccessibilityOn" tabstop="false"/>
        <Static id="hang05" taborder="3" text="나이스 대국민서비스에서는 마이크로소프트사 윈도우, 애플사 맥 OS 등의 운영체제와 크롬, 엣지, 파이어폭스, 사파리 등의 다양한 브라우저에서 동일한 서비스 화면을 제공하고 있습니다. &#13;&#10;(일부 운영체제 및 브라우저에서 특정 기능이 제한될 수 있습니다.)" left="0" top="suTitle2:8" height="48" cssclass="font16R" initvalueid="ivStcAccessibilityOn" right="0" onclick="hang05_onclick"/>
        <Div id="divDetail00" taborder="4" left="0" top="hang05:31" height="115" cssclass="div_webGuide_detail" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="label00" taborder="0" text="운영체제(OS)" left="0" top="0" width="240" height="57" cssclass="sta_webGuide_detailLabel" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00" taborder="1" text="윈도우 10, 11" left="240" top="0" height="57" cssclass="sta_webGuide_detailBG" initvalueid="ivStcAccessibilityOn" right="0"/>
              <Static id="label01" taborder="2" text="브라우저" left="0" top="57" width="240" height="57" cssclass="sta_webGuide_detailLabel" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta01" taborder="3" text="크롬, 엣지, 파이어폭스, 오페라" left="240" top="57" height="57" cssclass="sta_webGuide_detailBG" initvalueid="ivStcAccessibilityOn" right="0"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="label00" cssclass="sta_webGuide_detailLabel_M" width="200" left="0" top="0" height="70"/>
              <Static id="label01" cssclass="sta_webGuide_detailLabel_M" width="200" left="0" top="70" height="71"/>
