<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="pas_mmssp00_m02" width="1200" height="1860" titletext="저작권 보호정책" onload="pas_mmssp00_m02_onload" onsize="pas_mmssp00_m02_onsize">
    <Layouts>
      <Layout height="1860" width="1200" screenid="ScreenDeskTopP">
        <ImageViewer id="title1" taborder="0" text="나이스 대국민서비스 저작권 보호정책" left="0" top="54" width="490" height="50" cssclass="font34B" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00" taborder="1" text="저작권법 제24조의2에 의하여 나이스 대국민서비스 홈페이지를 통해 제공하는 모든 서비스가 공개하는 자료 중 각 서비스가 저작재산권의 전부를 보유한 저작물(이하 저작물)의 경우, 별도의 이용허락 없이 지유 이용이 가능합니다.&#13;&#10;&#13;&#10;단, 자유이용이 가능한 저작물은 공공저작물 자유이용허락 표시 기준(공공누리, KOGL) 제1유형을 부착하여 공개된 자료입니다. 이용자께서는 반드시 저작물의 출처를 구체적으로 표시해주십시오. 공공누리가 부착되지 않은 경우 혹은 저작물로 수익을 얻는 등 혜택을 누리고자 하는 경우, 해당 서비스 담당자와 사전 협의 후 이용하여 주시기 바랍니다.&#13;&#10;&#13;&#10;저작물은 저작권법에 의해 보호를 받으므로 무단 변경·복제·배포·사용(홈페이지 링크 연결 등)&#13;할 경우, 저작권법에 의하여 저작재산권 침해 죄에 해당될 수 있습니다.&#13;적법한 절차에 따라 저작물을 사용하는 경우에도 위의 사항을 어길시 처벌 받을 수 있습니다. " left="0" top="title1:35" height="192" cssclass="font16R" width="1200" initvalueid="ivStcAccessibilityOn" onclick="sta00_onclick"/>
        <Static id="subTitle00" taborder="2" text="출처표시" left="0" top="sta00:59" width="110" height="50" cssclass="font24B" initvalueid="ivStcAccessibilityOn"/>
        <ImageViewer id="img00" taborder="3" left="0" top="subTitle00:16" height="252" image="url('imagerc::common/img_webGuide_policy3.png')" accessibilitylabel="공공누리, 공공저작물 자유이용허락 마크" initvalueid="ivImgAccessibilityOn" text="" right="0"/>
        <Button id="btnFormDownload1" taborder="4" text="공공누리 마크 다운로드" top="607" width="235" height="50" cssclass="btn_WF_formDownload" initvalueid="ivBtnAccessibilityButton" onclick="btnFormDownload1_onclick" left="483"/>
        <Div id="divHang1" taborder="5" left="0" top="img00:40" height="230" cssclass="div_WF_hang" initvalueid="ivDivAccessibilityOff" right="0" formscrolltype="none" text="" accessibilitylabel="진위확인서비스 설명박스입니다.">
          <Layouts>
            <Layout>
              <Static id="subTitle00" taborder="0" text="공공누리란?" left="50" top="33" width="129" height="50" cssclass="font24B" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00" taborder="1" text="- 공공누리는 공공저작물 자유이용 허락 표시&#13;제도(Korea OpenGovernment License)&#13;서비스 입니다. &#13;&#10;- 국가, 지방자치단체, 공공기관&#13;이 4가지 공공누리 유형마크를 통해 개방한&#13;공공저작물 정보를 통합 제공하는 서비&#13;입니다.&#13;&#13;&#10;- 공공누리는 저작물별로 적용된 유형별&#13;이용조건 에 따라 저작권 침해의 부담 없이,&#13;무료로 자유롭게 이용가능합니다.&#13;&#13;&#10;- 홈페이지: &lt;l v='http://www.kogl.or.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;www.kogl.or.kr&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;" left="50" height="96" cssclass="font16R" initvalueid="ivStcAccessibilityOn" right="50" top="subTitle00:-1" usedecorate="true"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="subTitle00" cssclass="font40B" left="50" top="38" width="249" height="55"/>
              <Static id="sta00" left="50" height="420" cssclass="font28R" top="subTitle00:6" fittocontents="height" right="50" text="- 공공누리는 공공저작물 자유이용 허락 표시&#13;제도(Korea OpenGovernment License)&#13;서비스 입니다. &#13;&#10;- 국가, 지방자치단체, 공공기관&#13;이 4가지 공공누리 유형마크를 통해 개방한&#13;공공저작물 정보를 통합 제공하는 서비&#13;입니다.&#13;&#13;&#10;- 공공누리는 저작물별로 적용된 유형별&#13;이용조건 에 따라 저작권 침해의 부담 없이,&#13;무료로 자유롭게 이용가능합니다.&#13;&#13;&#10;- 홈페이지: www.kogl.or.kr"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta00_00" taborder="6" text="1) 출처표시 준수사항" left="0" top="divHang1:28" width="173" height="40" cssclass="font18B" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
        <Static id="sta00_01" taborder="7" text="- 출처표시 예시를 활용하여 작성연도 및 해당 기관명,&#13;  홈페이지 주소, 작성자명을 기입합니다.&#13;&#10;- 온라인에서 출처 웹사이트에 대한 하이퍼링크를&#13;  제공하는 것이 가능한 경우, 반드시 링크를&#13;  제공합니다.&#13;&#13;&#10;- 제3자의 입장에서 이용자와 본 기관이 특수한 관계에&#13;  놓여있다는 여지를 두는 등의 오인 가능성이 있는&#13;  표시를 해서는 안됩니다." left="0" top="sta00_00:-2" height="72" cssclass="font16R" width="1200" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divHang1_00" taborder="8" left="0" top="sta00_01:46" height="165" cssclass="div_WF_hang" initvalueid="ivDivAccessibilityOff" right="0" formscrolltype="none" text="" accessibilitylabel="진위확인서비스 설명박스입니다.">
          <Layouts>
            <Layout>
              <Static id="sta00_00" taborder="1" text="출처표시 예시" left="50" top="33" width="129" height="40" cssclass="font18B" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00" taborder="1" text="본 저작물은 나이스 대국민서비스(교육부)에서&#13;공공누리 제1유형으로 개방한 저작물입니다.&#13; &lt;fc v=&quot;#2b72de&quot;&gt;저작물명(작성자:      )&lt;/fc&gt;을 이용하였으며, 해당&#13;저작물은 &lt;fc v=&quot;#2b72de&quot;&gt;(작성년도)&lt;/fc&gt;년에 나이스 대국민&#13;서비스(교육부)에서 작성된 게시물로 &lt;fc v=&quot;#2b72de&quot;&gt;https://www.neis.go.kr&lt;/fc&gt;에서 무료로 다운받으실 수&#13;있습니다." left="50" height="48" cssclass="font16R" initvalueid="ivStcAccessibilityOn" width="1098" top="72" usedecorate="true" onclick="divHang1_00_sta00_onclick"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="sta00" left="50" top="sta00_00:6" height="305" cssclass="font28R" text="본 저작물은 나이스 대국민서비스(교육부)에서&#13;공공누리 제1유형으로 개방한 저작물입니다.&#13; &lt;fc v=&quot;#2b72de&quot;&gt;저작물명(작성자:      )&lt;/fc&gt;을 이용하였으며, 해당&#13;저작물은 &lt;fc v=&quot;#2b72de&quot;&gt;(작성년도)&lt;/fc&gt;년에 나이스 대국민&#13;서비스(교육부)에서 작성된 게시물로 &lt;fc v=&quot;#2b72de&quot;&gt;&#13;홈페이지(URL주소)&lt;/fc&gt;에서 무료로 다운받으실 수&#13;있습니다." right="50" fittocontents="height"/>
              <Static id="sta00_00" left="50" top="42" width="209" height="40" cssclass="font28B"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="subTitle00_01" taborder="9" text="법적근거" left="1223" top="divHang1_00:63" width="110" height="50" cssclass="font24B" initvalueid="ivStcAccessibilityOn" visible="false"/>
        <Static id="sta00_00_00" taborder="10" text="1) 저작권법" left="1223" top="subTitle00_01:14" width="115" height="40" cssclass="font18B" usedecorate="true" initvalueid="ivStcAccessibilityOn" visible="false"/>
        <Static id="sta00_01_00" taborder="11" text="1. 제24조의 2(공공저작물의 자유이용)&#13;&#10;2. 제136조(벌칙)" left="1253" top="sta00_00_00:8" height="48" cssclass="font16R" initvalueid="ivStcAccessibilityOn" right="-1193" visible="false"/>
        <Static id="sta00_00_00_00" taborder="12" text="2) 저작권법 시행령" left="1223" top="sta00_01_00:20" width="173" height="40" cssclass="font18B" usedecorate="true" initvalueid="ivStcAccessibilityOn" visible="false"/>
        <Static id="sta00_01_00_00" taborder="13" text="1. 제1조의3(공공저작물 이용활성화 시책 등)" left="1253" top="sta00_00_00_00:8" height="24" cssclass="font16R" initvalueid="ivStcAccessibilityOn" right="-1193" visible="false"/>
        <Static id="sta00_00_00_00_00" taborder="14" text="3) 정보통신망 이용촉진 및 정보보호 등에 관한 법률(정보통신망법)" left="1223" top="sta00_01_00_00:20" width="540" height="40" cssclass="font18B" usedecorate="true" initvalueid="ivStcAccessibilityOn" visible="false"/>
        <Static id="sta00_01_00_00_00" taborder="15" text="1. 제42조의 2(청소년유해매체물의 광고금지)&#13;&#13;&#10;2. 제44조(정보통신망에서의 권리보호)&#13;&#13;&#10;3. 제44조의 2(정보의 삭제요청 등)&#13;&#10;4. 제44조의 3(임의의 임시조치)&#13;&#13;&#10;5. 제44조의 4(자율규제)&#13;&#13;&#10;6. 제44조의 7(불법정보의 유통금지 등)" left="1253" height="144" cssclass="font16R" initvalueid="ivStcAccessibilityOn" width="1140" top="sta00_00_00_00_00:8" visible="false"/>
        <Div id="divFileUpload" taborder="16" text="div00" left="1220" top="1060" width="60" height="52" url="comm::comm_fileAdd.xfdl" Mode="upload" uploadLocation="PA.PAS.MMS" addProp="fnSetRaonProp" privInfoFiltYn="N" fileEncryptYn="N" fileSaveStg="OS" fileInfSaveYn="Y" visible="false"/>
      </Layout>
      <Layout name="Layout0" screenid="mobileP,tabletP" width="640" height="4110" mobileorientation="portrait" type="default">
        <ImageViewer id="title1" cssclass="font48B_C" top="53" left="118" height="140" text="나이스 대국민서비스&#13;&#10;저작권 보호정책" right="118" taborder="0"/>
        <Static id="sta00" left="20" top="title1:52" height="835" verticalAlign="top" cssclass="font28R" right="20" taborder="1" text="저작권법 제24조의2에 의하여 나이스 대국민서비스 홈페이지를 통해 제공하는 모든 서비스가 공개하는 자료 중 각 서비스가 저작재산권의 전부를 보유한 저작물 (이하 저작물)의 경우, 별도의 이용허락 없이 자유 이용이 가능합니다.&#13;&#10;&#13;&#10;단, 자유이용이 가능한 저작물은 공공저작물 자유이용허락 표시 기준(공공누리, KOGL) 제1유형을 부착하여 공개된 자료입니다. 이용자께서는 반드시 저작물의 출처를 구체적으로 표시해주십시오.&#13;&#10;공공누리가 부착되지 않은 경우 혹은 저작물로 수익을 얻는 등 혜택을 누리고자 하는 경우, 해당 서비스 담당자와 사전 협의 후 이용하여 주시기 바랍니다.&#13;&#10;&#13;&#10;저작물은 저작권법에 의해 보호를 받으므로 무단 변경·복제·배포·사용(홈페이지 링크 연결 등) 할 경우, 저작권법에 의하여 &#13;저작재산권 침해 죄에 해당될 수 있습니다.&#13;&#10;적법한 절차에 따라 저작물을 사용하는 경우에도 위의 사항을 어길시 처벌 받을 수 있습니다. &#13;&#10;&#13;&#10;" textAlign="left" border="0px none,0px none,2px solid #eaeaea" fittocontents="height"/>
        <Static id="subTitle00" left="20" top="sta00:78" height="56" cssclass="font40B" verticalAlign="bottom" taborder="2" right="20"/>
        <ImageViewer id="img00" left="20" top="subTitle00:63" height="352" image="url('imagerc::common_M/img_webGuide_policy3_M.png')" right="20" text="" taborder="3"/>
        <Button id="btnFormDownload1" top="img00:-108" height="50" taborder="4" left="203" minwidth="" width="236"/>
        <Div id="divHang1" left="20" top="img00:40" right="20" taborder="5" height="560"/>
