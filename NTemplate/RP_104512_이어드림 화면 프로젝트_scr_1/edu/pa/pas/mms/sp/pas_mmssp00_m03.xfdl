<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="pas_mmssp00_m03" width="1200" height="2670" titletext="저작권 신고서비스" onload="pas_mmssp00_m03_onload" onsize="pas_mmssp00_m03_onsize">
    <Layouts>
      <Layout height="2670" width="1200" screenid="ScreenDeskTopP">
        <ImageViewer id="title1" taborder="0" text="저작권 신고 서비스" left="0" top="54" width="280" height="50" cssclass="font34B" initvalueid="ivTitleAccessibilityOn"/>
        <Static id="sta00" taborder="1" text="본 서비스는 정보통신망 이용촉진 및 정보보호 등에 관한 법률에 의하여 저작권자의 동의&#13;없이 게시(혹은 중단)된 저작물에 대하여 저작권을 침해&#13;받은 경우 이를 신고하기 위한 서비스입니다.&#13;&#13;&#13;&#10;&#13;&#10;저작권 신고의 대상이 되는 게시물은&#13; &lt;fc v=&quot;#2b72de&quot;&gt;나이스 대국민서비스&lt;/fc&gt; 홈페이지를 통해&#13; 제공하는 서비스에 게시된 저작물에 한하여 저작물을 무단으로 이용하였거나 또는 저작자의 명예를 훼손한다고 생각되는 게시물입니다.&#13;&#13;&#13;&#10;&#13;&#10;저작권 신고 서비스 페이지 및 양식은 한국교육학술정보원(&lt;l v='http://www.keris.or.kr'&gt;&lt;u v='true'&gt;&lt;fc v='#2b72de'&gt;www.keris.or.kr&lt;/fc&gt;&lt;/u&gt;&lt;/l&gt;)에서 제공합니다.&#13; 신고 시 관련양식과 소명자료를 저작권 신고 담당자에게&#13; 전자우편 혹은 방문 신청합니다. 정당한 권리 없이&#13;요청할 경우, 법에 의해 손해배상의 책임이 있습니다." left="0" top="139" height="168" cssclass="font16R" initvalueid="ivStcAccessibilityOn" usedecorate="true" right="0" fittocontents="height"/>
        <Static id="subTitle00" taborder="2" text="1. 게시중단요청 신청" left="0" top="sta00:76" width="200" height="50" cssclass="font24B" initvalueid="ivStcAccessibilityOn"/>
        <Button id="btnFormDownload1" taborder="4" text="양식 다운로드" top="sta00:76" width="180" height="50" cssclass="btn_WF_formDownload" initvalueid="ivBtnAccessibilityButton" onclick="btnFormDownload1_onclick" right="0"/>
        <ImageViewer id="img00" taborder="3" left="0" top="btnFormDownload1:40" height="353" cssclass="display_border" image="url('imagerc::common/img_webGuide_policy4.png')" accessibilitylabel="게시중단 승인통보 절차. 첫 번째로 신청서 소명자료와 함께 저작권 권리주장자가 신청을 합니다.  두 번째 신고 수령인이 접수를 하고 게시중단 불가 통보를 합니다. 세 번째로 검토 후, 승인 처리가 나면 게시중단 처리가 되고 불가 처리가 나면 다시 신청을 해야합니다" initvalueid="ivImgAccessibilityOn" text="" right="0"/>
        <Static id="subTitle00_00" taborder="5" text="2. 재게시 요청" left="0" top="img00:80" width="150" height="50" cssclass="font24B" initvalueid="ivStcAccessibilityOn"/>
        <Button id="btnFormDownload2" taborder="7" text="양식 다운로드" top="img00:80" width="180" height="50" cssclass="btn_WF_formDownload" initvalueid="ivBtnAccessibilityButton" onclick="btnFormDownload2_onclick" right="0"/>
        <ImageViewer id="img00_00" taborder="6" left="0" top="btnFormDownload2:40" height="353" cssclass="display_border" image="url('imagerc::common/img_webGuide_policy5.png')" initvalueid="ivImgAccessibilityOn" text="" right="0" accessibilitylabel="게시중단 승인통보 절차. 첫 번째로 신청서 소명자료와 함께 저작권 권리주장자가 신청을 합니다.  두 번째 신고 수령인이 접수를 하고 게시중단 불가 통보를 합니다. 세 번째로 검토 후, 승인 처리가 나면 게시중단 처리가 되고 불가 처리가 나면 다시 신청을 해야합니다"/>
        <Static id="subTitle00_00_00" taborder="8" text="3. 저작권 신고 서비스 담당자" left="0" top="img00_00:80" width="280" height="50" cssclass="font24B" initvalueid="ivStcAccessibilityOn"/>
