<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="pas_mmscn01_m01" width="1200" height="1104" titletext="자주묻는 질문" onload="pas_mmscn01_m01_onload" onsize="pas_mmscn01_m01_onsize">
    <Layouts>
      <Layout height="1104" width="1200" screenid="ScreenDeskTopP">
        <ImageViewer id="title1" taborder="0" text="자주묻는 질문" left="0" top="64" width="190" height="50" cssclass="font34B" initvalueid="ivTitleAccessibilityOn" visible="false"/>
        <Div id="divTotal" taborder="1" top="83" width="205" height="30" url="comm::comp_pageSummary2.xfdl" initvalueid="ivDivAccessibilityOff" left="0"/>
        <Edit id="edtSearchKeyword" taborder="2" top="58" width="350" height="50" initvalueid="ivEdtNormal" displaynulltext="검색어를 입력해 주세요." maxlength="30" right="92" onkeydown="edtSearchKeyword_onkeydown" accessibilitylabel="검색어를 입력해 주세요"/>
        <Button id="btnSearch" taborder="3" text="조회" top="58" width="80" height="50" cssclass="btn_SA_search" initvalueid="ivBtnAccessibilityButton" onclick="btnSearch_onclick" onkeydown="btnSearch_onkeydown" right="0"/>
        <Div id="divFAQ" taborder="4" left="0" top="edtSearchKeyword:20" height="806" right="0" divmargin="2" text="" accessibilitylabel="자주묻는질문 목록" initvalueid="ivDivAccessibilityOn" cssclass="div_FAQ">
          <Layouts>
            <Layout/>
            <Layout name="Layout0"/>
          </Layouts>
        </Div>
        <Div id="divPaging" taborder="5" left="0" top="divFAQ:50" height="30" right="0" url="comm::comp_paginator2.xfdl" initvalueid="ivDivAccessibilityOn" accessibilitylabel="페이징그룹박스"/>
      </Layout>
      <Layout name="Layout0" screenid="mobileP,tabletP" width="640" height="1991" mobileorientation="portrait" type="default">
        <ImageViewer id="title1" cssclass="font48B_C" top="53" left="144" height="80" taborder="0" right="146" visible="true"/>
        <Div id="divTotal" top="344" height="40" visible="true" enable="true" left="0" right="0" taborder="3"/>
        <Button id="btnSearch" width="188" top="title1:51" height="100" right="20" cssclass="btn_SA_search_M" taborder="2"/>
        <Edit id="edtSearchKeyword" left="20" top="title1:51" height="100" cssclass="edt_WF_M" taborder="1" right="220"/>
        <Div id="divFAQ" left="20" top="399" height="1402" right="20" cssclass="div_FAQ_M" taborder="4" accessibilitylabel="FAQ목록"/>
        <Div id="divPaging" top="divFAQ:70" left="0" height="120" right="0" formscrolltype="none" taborder="5" text=""/>
      </Layout>
    </Layouts>
