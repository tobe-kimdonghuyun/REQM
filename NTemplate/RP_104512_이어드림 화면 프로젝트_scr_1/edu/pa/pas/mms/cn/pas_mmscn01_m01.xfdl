    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 자주묻는 질문 
*  @MenuPath    pa_pas_mms_cs
*  @FileName 	pas_mmscn01_m01.xfdl
*  @Creator 	김지환
*  @CreateDate 	2022.8.19
*  @Desction   자주묻는 질문 
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.8.19     	김지환				최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.DivInfo = {};     // Q & A 항목 정보 
this.fvTitleHeight = this.smfIsMobile()?104:79; 	// 디폴트 높이
this.fvContentsHeight = this.smfIsMobile()?292:193; // 디폴트 높이
this.fvContentsWidth = this.smfIsMobile()?400:747; 	// 디폴트 높이

this.fv_prefixIdTitleDiv = "divTitle";
this.fv_prefixIdAreaStatic = "staArea";
this.fv_prefixIdTitleButton = "btnTitle";
this.fv_prefixIdOpenButton = "btnOpen";
this.fv_prefixIdHomeButton = "btnHome";
this.fv_prefixIdContentsDiv = "divContents";
this.fv_prefixIdContentsAnswer = "staAnswer";
this.fv_mofile = "";
if(this.smfIsMobile()){
	this.fv_mofile = "_M";
}

this.fvFormObject;
this.fvSelIdx;
this.fvObjclick;

this.pafrBbsId="";
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.pas_mmscn01_m01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	//모바일화면일 경우 페이징 처리가 5개씩 되도록
	if(this.smfIsMobile()){
		//  페이지를 조회한다.
		this.divTotal.form.fnSetInitPageSize(5);
		this.dsPageInfo.setColumn(0, "pageSize",5);
	}
	
	// 파라메터 세팅
	this.pv_params = this.smfGetFormParams();

	if(!this.smfIsNull(this.pv_params)){
		this.pafrBbsId = this.pv_params.pafrBbsId;
		
		var sFaqTitlNm = this.pv_params.searchKeyword;
		this.edtSearchKeyword.set_value(sFaqTitlNm);
	}
	
	// 페이지를 조회한다.
	this.btnSearch.click();
	
	this.divFAQ.fv_DIV_MARGIN = 0;	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
//목록검색
this.fnSearch = function(obj, e)
{
	this.fnDeleteDiv();
	
	var vSearchKeyword = this.edtSearchKeyword.value;
	var objRegExp = /[$]/gi;
	if(!this.smfIsNull(vSearchKeyword)){
		vSearchKeyword = vSearchKeyword.replace(objRegExp,"");	//특수문자 제거
	}
	this.dsSearch.setColumn(0,"searchKeyword" , vSearchKeyword);
	this.dsSearch.setColumn(0,"pafrBbsId" , this.pafrBbsId);
	
	var sServiceId = "select";
	if(this.smfIsMobile()){
		sServiceId = "selectTemp";
	}
	
	
 	// 서비스 객체 생성
	this.smfSearchService(sServiceId)
		// 데이터 검증
		//.validateForm(this.edtSearchKeyword)
		// 페이징처리
		.paginator(this.dsList, this.divPaging, this.divTotal, this.dsPageInfo, obj, e)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.smfIsMobile()){
				this.dsList.appendData(this.dsListTemp);
				// 총 검색결과와 현재 검색 결과 수가 일치할 경우 [더보기]버튼 숨김 (TODO)
				if(this.dsPageInfo.getColumn(0, "totalCount")==this.dsList.getRowCount()){
					this.divPaging.set_visible(false);
				}else{
					this.divPaging.set_visible(true);
				}
			}else{
				if(this.dsList.getRowCount() == 0){
					this.divPaging.set_visible(false);
					
					var sDivId = this.fv_prefixIdTitleDiv + 0;
			
					var objDiv = new Div();
					// 최초의 오브젝트는 위의 Div의 Top을 0으로 한다
					objDiv.init(sDivId, 0, 0, null, 350, 0, null);	

					// 만들어진 Div를 부모에 추가
					this.divFAQ.form.addChild(sDivId, objDiv); 
			
					// Div의 속성을 세팅
					objDiv.set_initvalueid("ivDivAccessibilityOff");
			
					objDiv.show(); 
					
					//문구 
					var sStaName = "staRsult";
					var objStatic = new Static();
					
					objStatic.init(sStaName, 0, 0, null, 350, 0, null);
					objStatic.set_initvalueid("ivStcAccessibilityOn");
					objStatic.set_cssclass("font18R_2");
					objStatic.set_textAlign("center");
					objStatic.set_text("조회된 데이터가 없습니다.");
					objDiv.form.addChild(sStaName, objStatic); 
					objStatic.show();
					
				}else{
					this.divPaging.set_visible(true);
				}
			}
			
			var objTargetDivForm =  this.divFAQ.form;
			
			for(var i=0;i<this.dsList.rowcount;i++)
			{
				this.fnAppendDiv(objTargetDivForm,this.dsList, i);
				//첨부파일 셋팅
				if(!this.smfIsNull(this.dsList.getColumn(i,"fileRefrnId"))){
					this.fnGetFileInfo(this.dsList.getColumn(i,"fileRefrnId"), i);
				}
			}
			this.smfResetScroll(this.divFAQ.form);
			
			this.pafrBbsId=""; //사용한 FAQID 초기화
		});
};

//조회수 증가
this.fnSearchDtl = function(faqId)
{
	this.dsSearchDtl.setColumn(0,"faqId",faqId);

 	// 서비스 객체 생성
	this.smfSearchService("selectDtl")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

this.fnGetFileInfo = function(fileRefrnId, cnt){
	
	// 파일 데이터셋 초기화
	this.dsOutFileinfo.clearData();

	// 업로드 초기화
	this.transaction("fn_filesearch"
		,"baseUrl::/cm_cmc_file_upload_001.do"
		,""
		,"dsOutFileinfo=atchFileinfo" 
		,"fileRefrnId='"+fileRefrnId+"'"
		,this.btnUpload_FileSearch_callback
		,false // 동기
	);
	var objform = this.divFAQ.form["divContents"+cnt].form["divFile"+cnt];
		
	if(this.dsOutFileinfo.rowcount > 1){
		var addHeight = this.smfIsMobile()? (this.dsOutFileinfo.rowcount - 1)*62:(this.dsOutFileinfo.rowcount - 1)*30;
		objform.set_height(parseInt(objform.height) + parseInt(addHeight));
	}
	
	for (var i = 0; i < this.dsOutFileinfo.rowcount; i++) {
		var responseCustomValue = "";
		var sDownloadPath = "";
		var handlerCode       = "PA.PAS.MMS";
		var fileSn            = this.dsOutFileinfo.getColumn(i,"fileRefrnId");
		var fileId            = this.dsOutFileinfo.getColumn(i,"fileId");
		var fileSize          = this.dsOutFileinfo.getColumn(i,"atchFileMg");
		var backendFilename   = this.dsOutFileinfo.getColumn(i,"atchFileGuid");
		var filename  = this.dsOutFileinfo.getColumn(i,"atchFileNm");
		var sFileEncryptYn    = "N";
		var sPrivInfoFiltYn   = "N";
		var sFileSaveStg      = this.dsOutFileinfo.getColumn(i,"fileSaveStg");
		var sFileInfSaveYn    = "Y";		
		
		if(objform)
		{
			objform.form.fnAddUploadedFile(handlerCode, fileSn, fileSize, backendFilename, filename, fileId
												, sDownloadPath, sFileEncryptYn, sPrivInfoFiltYn, sFileSaveStg, sFileInfSaveYn);	
		}
	}
};

this.btnUpload_FileSearch_callback = function()
{
	for (var i = 0; i < this.dsOutFileinfo.rowcount; i++) {
		var responseCustomValue = "";
		var sDownloadPath = "";
		var handlerCode       = "PA.PAS.MMS";
		var fileSn            = this.dsOutFileinfo.getColumn(i,"fileRefrnId");
		var fileId            = this.dsOutFileinfo.getColumn(i,"fileId");
		var fileSize          = this.dsOutFileinfo.getColumn(i,"atchFileMg");
		var backendFilename   = this.dsOutFileinfo.getColumn(i,"atchFileGuid");
		var forntendFilename  = this.dsOutFileinfo.getColumn(i,"atchFileNm");
		var sFileEncryptYn    = this.dsOutFileinfo.getColumn(i,"fileEncryptYn");
		var sPrivInfoFiltYn   = this.dsOutFileinfo.getColumn(i,"privInfoFiltYn");
		var sFileSaveStg      = this.dsOutFileinfo.getColumn(i,"fileSaveStg");
		var sFileInfSaveYn    = this.dsOutFileinfo.getColumn(i,"fileInfSaveYn");
		
		var objform = this.divFAQ.form["divContents"+cnt].form["divFile"+cnt];

		if(objform)
		{
			objform.form.fnAddUploadedFile(handlerCode, fileSn, fileSize, backendFilename, filename, fileId
												, sDownloadPath, sFileEncryptYn, sPrivInfoFiltYn, sFileSaveStg, sFileInfSaveYn);	
		}
	}
};
 
/**
 * 하나의 게시글을 추가한다.
 * @param : {object}   scope  대상Form
 * @param : {object}   objDs  추가할 데이터셋
 * @param : {Number}   nRow   추가할 데이터셋의 row
 */
this.fnAppendDiv = function(scope,objDs,nRow)
{
	// 추가될 index를 구한다.
	// (기본적으로는 부모 Div에 있는 _count 유저프로퍼티 사용. 없으면 0으로 초기화)
	var nIdx = 0;
	if(this.smfIsNull(scope.parent._count))
	{  // 세팅이 안되어 있으면 0으로 세팅
		nIdx = 0;
		scope.parent._count = 0;
	}
	else
	{
		nIdx = scope.parent._count;
	}
	
	// 타이틀 Div 만들기
	var objTitleDiv = this.fnAddTitleDiv(scope,nIdx,objDs,nRow);
	// 상세 Div만들기
	var objContentsDiv = this.fnAddContentsDiv(scope,nIdx,objDs,nRow);

	// 카운트 갯수를 증가시킨다.
	scope.parent._count++;
}

/**
 * TitleDiv를 추가한다.
 * @param : {object}   scope  대상Form
 * @param : {Number}   nIdx   추가할 div Index
 * @param : {object}   objDs  추가할 데이터셋
 * @param : {Number}   nRow   추가할 데이터셋의 row
 */
this.fnAddTitleDiv = function (scope,nIdx,objDs,nRow)
{
	var sDivId = this.fv_prefixIdTitleDiv + nIdx;
	var sFaqTitlNm = objDs.getColumn(nRow,"faqTitlNm");
	
	//===================================================================
	// Div 생성
	//===================================================================
	var nHeight = this.fvTitleHeight;
	var sBeforeContentsId = "divContents"+(nIdx-1);
	var sChildId = "divContents"+nIdx;
	var sDivCssClass = "div_FAQ_question"+this.fv_mofile;	// div_FAQ_question (클릭되지않은 타이틀)
	var sDivArrow = "btn_FAQ_open"+this.fv_mofile; // 버튼 (V 열림버튼)
	
	var objDiv = scope[sDivId];
	
	if(!objDiv)
	{
		objDiv = new Div();
		if( nIdx==0 )
		{	// 최초의 오브젝트는 위의 Div의 Top을 0으로 한다
			objDiv.init(sDivId, 0, 0, null, nHeight, 0, null);				//마지막에 높이 재조정하기 때문에 크게 상관x 
		}
		else
		{   // 최초 Div이외의 것은 바로위의 오브젝트 바로아래에 생성한다. 
			objDiv.init(sDivId, 0, sBeforeContentsId +":"+ 0, null, nHeight, 0, null);
			//objDiv.init(sDivId, 0, (nIdx*nHeight), null, nHeight, 0, null);
		}

		// 만들어진 Div를 부모에 추가
		// Add Object to Parent Form  
		scope.addChild(sDivId, objDiv); 
		
		//마지막행일때 css변경
		if(nRow == this.dsList.rowcount -1) sDivCssClass = "div_FAQ_question_end"+this.fv_mofile;
		
		// Div의 속성을 세팅
		objDiv.set_cssclass(sDivCssClass);
		objDiv.set_initvalueid("ivDivAccessibilityOff");
		objDiv.childId = sChildId;
		objDiv.dirArrow = sDivArrow;
		
		
		
		// Div를 보이게 설정(addChild()하면 반드시 show()를 해주어야 실제로 화면에 보임)  
		objDiv.show(); 
	}
	
	// 질문 버튼(Q) 넣기
	var questionButton = new Static();
	var sQuestionButtonId = "question"+nIdx;
	// PC일때랑 모바일일때 구분해서 생성
	if(this.smfIsMobile()){
		questionButton.init(sQuestionButtonId, 28, 31, 34, 34, null, 0);
	} else {
		questionButton.init(sQuestionButtonId, 20, 19, 35, 30, null, 0);
	}
	questionButton.set_cssclass("sta_FAQ_Q"+this.fv_mofile);
	questionButton.set_initvalueid("ivStcAccessibilityOn");
	questionButton.set_accessibilitylabel("질문내용");
	//questionButton.set_text("Q");
	objDiv.form.addChild(sQuestionButtonId, questionButton); 
	questionButton.show();
	
	//===================================================================
	// 타이틀문장(Static) 생성
	//===================================================================
	// =======문장을 표시하는 Static을 생성
	var sStaticId = this.fv_prefixIdTitleButton+nIdx;
	
	// 질문영역(Question) 생성
	var objStatic = objDiv.form[sStaticId];
	if(!objStatic)
	{
		objStatic = new Static();
		
		//right 값 btnOpen 에 참조할수 있도록 변경필요
		if(this.smfIsMobile()){
			objStatic.init(sStaticId, sQuestionButtonId + ":"+0, 0, null, null, 55, 0);				
		}else {
			objStatic.init(sStaticId, sQuestionButtonId + ":"+0, 0, null, null, 55, 0);
		}
		
		// 만들어진 Static을 Div에 추가
		objDiv.form.addChild(sStaticId, objStatic); 
		
		// Static의 속성 설정
		objStatic.set_initvalueid("ivStcAccessibilityOn");
		objStatic.set_verticalAlign("middle");
		objStatic.set_cssclass("sta_FAQ_hang"+this.fv_mofile);
		objStatic.dirArrow = sDivArrow;
		objStatic.childId = sChildId;
		
		// Static에 클릭이벤트 추가
		objStatic.addEventHandler("onclick",function(obj,e){
		
										this.fnReDraw(scope,obj,e,nIdx);
										
										var tgtDivNm = String(objDiv.childId);
										//this.fvFormObject = objDiv.parent.parent.form[tgtDivNm];
										this.fvFormObject = scope;
										this.fvSelIdx = nIdx;
										this.fvObjclick = obj;

									}
									,this);
		objStatic.show();
	}
	objStatic.set_text(sFaqTitlNm);
	
	//입력값 높이 구하기
	var expandtextHeight = this.fnGetContentsHeight(objStatic);
	
	// PC랑 모바일이랑 나눠서 패딩값 줘야함(변수로 설정)
	var plusHeight = this.smfIsMobile()?10:7;
	objDiv.setOffsetHeight(expandtextHeight+plusHeight);
	
	objDiv.set_visible(true);
	
	// 질문Div에 우측 화살표버튼을 추가한다.
	this.fnCreateBtnOpen(objDiv.form,sChildId,nIdx);
	
	//여기 이후에 타이틀 right값 참조해야 할듯?
	
};

/**
 * Contents Div를 추가한다.
 * @param : {object}   scope  대상Form
 * @param : {Number}   nIdx   추가할 div Index
 * @param : {object}   objDs  추가할 데이터셋
 * @param : {Number}   nRow   추가할 데이터셋의 row
 */
this.fnAddContentsDiv = function (scope,nIdx,objDs,nRow)
{
	var sDivId = this.fv_prefixIdContentsDiv + nIdx;
	var sFaqCn = objDs.getColumn(nRow,"faqCn");		// 답변
	var sFileRefrnId = objDs.getColumn(nRow,"fileRefrnId");		// 첨부 파일

	//===================================================================
	// Div 생성
	//===================================================================
	var nHeight = this.fvContentsHeight;
	var sBeforeContentsId = this.fv_prefixIdTitleDiv + nIdx;
	var sChildId = this.fv_prefixIdContentsDiv+nIdx;
	var sDivCssClass = "div_FAQ_answer"+this.fv_mofile;	
	var sDivArrow = "btn_FAQ_open"+this.fv_mofile;
	
	//마지막행일때 css변경(추후 변경필요)
	if(nRow == this.dsList.rowcount -1) sDivCssClass = "div_FAQ_answer_end"+this.fv_mofile;
	
	// Create Object  
	var objDiv = scope[sDivId];
	if(!objDiv)
	{
		objDiv = new Div();
		
		if(this.smfIsMobile()){
			objDiv.init(sDivId, 0, sBeforeContentsId +":0", null, nHeight, 0, null);
		} else {
			objDiv.init(sDivId, 0, sBeforeContentsId +":0", null, nHeight, 0, null);
		}
		
		// 만들어진 Div를 부모에 추가
		// Add Object to Parent Form  
		scope.addChild(sDivId, objDiv); 
		
		// Div의 속성을 세팅
		objDiv.set_cssclass(sDivCssClass);
		objDiv.set_initvalueid("ivDivAccessibilityOff");
		objDiv.childId = sChildId;
		objDiv.dirArrow = sDivArrow;
		objDiv.divmargin = "12";
		
		// Div를 보이게 설정(addChild()하면 반드시 show()를 해주어야 실제로 화면에 보임)  
		objDiv.show(); 
	}
	
	//===================================================================
	// Contents문장(Static) 생성
	//===================================================================
	var sStaticCssClass = "sta_FAQ_answer"+this.fv_mofile;
	
	// 1-1. 답변 버튼(A) 생성 
	var sBtnQuestion = "labelQuestion"+nIdx;
	var objButton = new Static();
	
	if(this.smfIsMobile()){
		objButton.init(sBtnQuestion, 38, 20, 86, 81, null, null);
	} else {
		objButton.init(sBtnQuestion, 26, 19, 86, 81, null, null);
	}
	objButton.set_cssclass("sta_FAQ_A"+this.fv_mofile);
	objButton.set_initvalueid("ivStcAccessibilityOn");
	objButton.set_accessibilitylabel("답변내용");
	objDiv.form.addChild(sBtnQuestion, objButton); 
	objButton.show();
	
	// 1-2. 답변 내용 입력
	var sStaticAnswer = this.fv_prefixIdContentsAnswer+nIdx;
	var objStaticAnswer = objDiv.form[sStaticAnswer];
	if(!objStaticAnswer)
	{
		objStaticAnswer = new Div();  
		if(this.smfIsMobile()){
			objStaticAnswer.init(sStaticAnswer, sBtnQuestion + ":0", 13, null, null, 20, 31);
		} else {
			objStaticAnswer.init(sStaticAnswer, sBtnQuestion + ":0", 19, null, 10, 53, null);		
		}
		
		objDiv.form.addChild(sStaticAnswer, objStaticAnswer); 

		// Div의 속성 설정
		objStaticAnswer.set_initvalueid("ivDivAccessibilityOff");
		
		objStaticAnswer.set_async(false);
		objStaticAnswer.set_url("comm::comp_webEditor.xfdl");
		//trace("답변값: ", sFaqCn);
		objStaticAnswer.form.fnInit(this, this.fnWebEditorCallback, this.fnWebEditorSetHtmlCallback);
		
		objStaticAnswer.autoHeight = "Y";
		
		objStaticAnswer._html = sFaqCn;
		objStaticAnswer.dirArrow = sDivArrow;	
		objStaticAnswer.childId = "";
		
		objStaticAnswer.show();
	}
	objStaticAnswer.set_cssclass(sStaticCssClass);
	

	// 1-3. 파일 DIV 추가
	if(!this.smfIsNull(sFileRefrnId))
	{
		var sDivFile = "divFile" + nIdx;
		var divFile = new Div();
		var nHeight = 45;
		if(this.smfIsMobile())	nHeight = 62;

		divFile.init(sDivFile, 20, sStaticAnswer + ":20", null, nHeight, 10);
		
		//divFile.set_cssclass("btn_WF_labelMap"+this.fv_mofile);
		divFile.set_url("comm::comp_fileDownload.xfdl");
		divFile.set_initvalueid("ivDivAccessibilityOff");
		objDiv.form.addChild(sDivFile, divFile); 
		divFile.set_async(false);
		
		divFile.show();
	}
	
	// 답변(Answer)은 처음에는 안보이게 처리(높이를 0, visible=false)
	objDiv.setOffsetHeight(0);
	objDiv.set_visible(false);
}


/*
*	웹에디터가 onload된 이후 호출되는 callback
*   obj : 웹에디터 Div오브젝트
*/
this.fnWebEditorCallback = function(obj)
{
	// 일반적으로는 데이터를 세팅
	obj.form.fnSetHtml(obj._html);
};


/*
*	웹에디터가 text를 변경 할 경우 호출하는 callback
*   obj : 웹에디터 Div오브젝트
*/
this.fnWebEditorSetHtmlCallback = function(obj,contentHeight)
{
	trace("***  웹에디터에 Text를 세팅했습니다.["+obj.id+"] contentHeight[=" + contentHeight + "]");
	
	// 일반적으로는 WebEditor Div를 resetScroll해줌.
	//  (Web Editor의 높이가 변경이 되어 있음(autoHeight="Y"인 경우))
	//this.smfResetScroll(this.divDetail.form.divWebEditor);
};



/**
 * open 버튼 생성
 * @param : scope ( Div.form)
 * @param : divInfo 
 */
this.fnCreateBtnOpen = function(scope,sChildId,nIdx)
{
	var sBtnId = this.fv_prefixIdOpenButton+nIdx;
	var sDivArrow = "btn_FAQ_open"+this.fv_mofile;
	
	// 버튼을 생성
	var objButton = scope[sBtnId];
	if(!objButton)
	{
		objButton = new Button(); 
		if(this.smfIsMobile()){
			objButton.init(sBtnId, null, 0, 36, null, 30, 0);
		} else {
			objButton.init(sBtnId, null, 0, 30, null, 23, 0);
		}
		
		
		// 만들어진 Button을 Div에 추가
		scope.addChild(sBtnId, objButton);
		
		// 버튼의 속성을 설정
		objButton.set_initvalueid("ivBtnAccessibilityButton");
		objButton.set_accessibilitylabel("답변내용열기");
		objButton.childId = sChildId;
		objButton.dirArrow = sDivArrow;
		
		// Button에 클릭이벤트 추가
		var sStaticId = this.fv_prefixIdTitleButton+nIdx;
		objButton.addEventHandler("onclick",function(obj,e){
		
			this.fnReDraw(scope.parent.parent, scope[sStaticId], e, nIdx);

			var tgtDivNm = String(scope[sStaticId].childId);
			//this.fvFormObject = scope.parent.parent.parent.form[tgtDivNm];
			this.fvFormObject = scope.parent.parent;
			this.fvSelIdx = nIdx;
			this.fvObjclick =scope[sStaticId];

		},this);
		
		// Button을 보이게 설정
		objButton.show();  
	}
	objButton.set_cssclass("btn_FAQ_open"+this.fv_mofile);
	
};


/**
 * 생성 컴포넌트 재 설정 및 reDraw 함
 * @param : obj - Static
 * @param : e   - Static eventInfo
 */
this.fnReDraw = function(scope,obj,e, nIdx)
{
	// 상태값 추가 
	var openFlag = true;
	if(obj.parent.parent.form[this.fv_prefixIdOpenButton+nIdx].cssclass == "btn_FAQ_close"+this.fv_mofile){
		openFlag = false;
	}

	// class 초기화 
	for(var i=0;i < scope.components.length;i++)
	{	
		if(scope.components[i] instanceof nexacro.Div )
		{
			// titleDiv 이면
			if(scope.components[i].id.substr(0,this.fv_prefixIdTitleDiv.length) == this.fv_prefixIdTitleDiv)
			{
			//trace(" 타이틀 DIv:: "+this.fv_prefixIdTitleDiv  +"   "+ this.fv_prefixIdContentsDiv +"  "+ this.fv_mofile);
			
				scope.components[i].set_cssclass("div_FAQ_question"+this.fv_mofile);
				scope.components[i].form[this.fv_prefixIdOpenButton+(scope.components[i].id.substr(this.fv_prefixIdTitleDiv.length))].set_accessibilitylabel("답변내용열기");
				scope.components[i].form[this.fv_prefixIdOpenButton+(scope.components[i].id.substr(this.fv_prefixIdTitleDiv.length))].set_cssclass("btn_FAQ_open"+this.fv_mofile);
				//다른 질문 클릭했을 때 타이틀 강조 해제
				scope.components[i].form[this.fv_prefixIdTitleButton+(scope.components[i].id.substr(this.fv_prefixIdTitleDiv.length))].set_cssclass("sta_FAQ_hang"+this.fv_mofile);
			}
			// contentsDiv 이면
			if(scope.components[i].id.substr(0,this.fv_prefixIdContentsDiv.length) == this.fv_prefixIdContentsDiv)
			{
				scope.components[i].setOffsetHeight(0);
				scope.components[i].set_visible(false);
				if(!this.smfIsNull(scope.components[i+1])){
					//scope.components[i+1].setOffsetHeight(79);
				}
			}
			
		}
	}
	
	//답변 열고 닫을 때, 화면 재조정
	this.smfResetScroll(this.divFAQ.form);
	
	var objTitleDiv = obj.parent.parent;
	var objTitleStatic = objTitleDiv.form[this.fv_prefixIdTitleButton+nIdx];
	var objTitleButton = objTitleDiv.form[this.fv_prefixIdOpenButton+nIdx];
	var objContentsDiv = scope[objTitleDiv.childId];
	var objContentsStatic = objContentsDiv.form[this.fv_prefixIdContentsAnswer+nIdx];
	
	// 자주묻는질문 정보를 서랍형으로 오픈 
	if(!this.smfIsNull(obj.childId) && openFlag){
		
		trace("데이터셋 확인 : " + this.dsList.getColumn(nIdx,"faqTitlNm"));
		
		this.fnSearchDtl(this.dsList.getColumn(nIdx,"faqId"));
		
		if(this.smfIsMobile()){
			objTitleDiv.set_cssclass("div_FAQ_question_M");
		}
		


		//서랍형으로 오픈되었을 때 타이틀 강조
		objTitleStatic.set_cssclass("sta_FAQ_hang_S"+this.fv_mofile);
		
		//objContentsDiv.setOffsetHeight(193);
		objTitleButton.set_cssclass("btn_FAQ_close"+this.fv_mofile);
		objTitleButton.set_accessibilitylabel("답변내용닫기");
		objContentsDiv.set_visible(true);
		
		var expandtextHeight = this.fnGetContentsHeight(objContentsStatic);

		objContentsStatic.setOffsetHeight(expandtextHeight);
		this.smfResetScroll(objContentsDiv.form);
	}
	this.smfResetScroll(scope);
};


//다시 조회할때, 미리 조회되어있는 값들을 지우는 함수
this.fnDeleteDiv = function()
{
	var objComps = this.divFAQ.form.components;
	var nCount = objComps.length
	for(var i=nCount-1;i>=0;i--)
	{
		var objComp = objComps[i];
		//objComp.set_visible(false);
		var objDelete = this.divFAQ.removeChild(objComp.id);
		if(objDelete)
		{
			//trace(i + " - success : " + objDelete.id);
			objDelete.destroy();
		}
		else
		{
			//trace(i + " - false : " + objComp.id);
		}
	}
	
	this.divFAQ._count = 0;
}

//높이 값 구하는 함수(에디터 사용할때는 안씀)
this.fnGetContentsHeight = function(objContentsStatic)
{
	var nContentsHeight = 0;
	if(objContentsStatic instanceof nexacro.Div)
	{  // 웹에디터 사용한 경우
		var nHeightPadding = 38;	
		nContentsHeight = objContentsStatic.form.fnGetHeight()+nHeightPadding;
	}
	else
	{   // Static 사용한 경우
		var strFont = 'bold 16px/1.5 "NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic"';
		var strMFont = '28px/1.5 "NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic"';
		var Font = this.smfIsMobile()?strMFont:strFont;
		var nHeightPadding = 38;		//19 X 2 (템플릿에 19px)	
		
		
		var staText = objContentsStatic.text;
		var staWidth = objContentsStatic.getOffsetWidth();
		var nTextHeight = nexacro.getTextSize(staText,Font,staWidth,"char");
		
		nContentsHeight = nTextHeight.ny+nHeightPadding;
	}
	return nContentsHeight ;
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 

this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearch(obj, e);
};


this.btnSearch_onkeydown = function(obj:nexacro.Button,e:nexacro.KeyEventInfo)
{
	if(e.keycode == 13){
		this.dsSearch.setColumn(0, "searchKeyword", this.edtSearchKeyword.value);
		this.btnSearch.click();
	}
};

this.edtSearchKeyword_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode == 13){
		this.dsSearch.setColumn(0, "searchKeyword", this.edtSearchKeyword.value);
		this.btnSearch.click();
	}
};

this.pas_mmscn01_m01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	if (this.smfIsMobile() && !this.smfIsNull(this.fvFormObject)) {
		/*	
		var objContentsStatic = this.fvFormObject.form["staAnswer"+this.fvSelIdx];
		//objContentsStatic.setOffsetWidth(this.fvFormObject.getOffsetWidth()-140);

		var expandtextHeight = this.fnGetContentsHeight(objContentsStatic);
		objContentsStatic.setOffsetHeight(expandtextHeight);
		
		//this.smfResetScroll(this.fvFormObject.form["staAnswer"+this.fvSelIdx]);
		this.smfResetScroll(this.fvFormObject.form);	
		*/

		var objTitleDiv = this.fvObjclick.parent.parent;
		var objContentsDiv = this.fvFormObject[objTitleDiv.childId];
		var objContentsStatic = objContentsDiv.form[this.fv_prefixIdContentsAnswer+this.fvSelIdx];
		var expandtextHeight = this.fnGetContentsHeight(objContentsStatic);
		objContentsStatic.setOffsetHeight(expandtextHeight);

		this.smfResetScroll(objContentsDiv.form);
		this.smfResetScroll(this.fvFormObject.form);
	}
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="edtSearchKeyword" propid="value" datasetid="dsSearch" columnid="searchKeyword"/>
    </Bind>
  </Form>
</FDL>
