    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 공모전상세
*  @MenuPath    pa_pas_mns_cn
*  @FileName 	pas_mnscn03_m03.xfdl
*  @Creator 	홍길동
*  @CreateDate 	2022.5.12
*  @Desction    공모전 상세 조회
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.5.12     	홍길동 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs";

//0501 CF 일괄등록

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.pafrBbsId = "";
this.dsSearchParam;
this.dsPagingParam;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.pas_mmscn03_m03_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);
	
	// 파라메터 세팅
	this.pv_params = this.smfGetFormParams();
	
	if(!this.smfIsNull(this.pv_params)){
		this.pafrBbsId = this.pv_params.pafrBbsId;
		this.dsSearchParam = this.pv_params.dsSearchParam;
		this.dsPagingParam = this.pv_params.dsPagingParam;
		this.dsListParam = this.pv_params.dsListParam;
		
		// 웹 에디터 셋팅 
		//this.divDetail.form.divWebEditor.form.fnInit(this,this.fnWebEditorCallback);
	}

	this.fnSearch(this.pafrBbsId);

};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	
}

/*
*	웹에디터가 onload된 이후 호출되는 callback
*   obj : 웹에디터 Div오브젝트

this.fnWebEditorCallback = function(obj)
{
	// 일반적으로는 데이터를 세팅
	this.fnSearch(this.eventId);
};
*/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(pafrBbsId,rownum)
{
	this.divFileDownload.set_url("");
	this.divFileDownload.set_height(0);
	this.divFileDownload.set_url("comm::comp_fileDownload.xfdl");

	this.dsSearch.setColumn(0,"eventId",pafrBbsId);
	
 	// 서비스 객체 생성
	this.smfSearchService("select")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.parent.parent.scrollTo(0,0);
			
			this.divTitle.form.staView.set_text(this.smfSetComma(this.dsResult.getColumn(0,"inqCnt")));
			
			//날짜 셋팅
			var eventDate = this.dsResult.getColumn(0,"eventBgngYmd") + this.dsResult.getColumn(0,"eventEndYmd");
			this.divTitle.form.mskDate.set_value(eventDate);
			
			//제목 div 크기 조정
			var title = this.smfIsMobile()?this.divTitle.form.staTitle : this.divTitle.form.txtTitle;
			var textHeight = this.fnGetTitleHeight(title);
			this.divTitle.form.txtTitle.setOffsetHeight(textHeight-10);
			this.divTitle.setOffsetHeight(textHeight);
			this.smfResetScroll(this.divTitle.form);
			
			// 첨부파일 셋팅 
			if(!this.smfIsNull(this.dsResult.getColumn(0,"fileRefrnId"))){
				this.fnGetFileInfo(this.dsResult.getColumn(0,"fileRefrnId"));
			}
			
			// 첨부파일 셋팅(포스터) 
			var sUrl = this.smfGetImageUrl(this.dsResult.getColumn(0,"imageFileRefrnId"),0);
			this.divContent.form.img00.set_image(sUrl);
			
			if(this.smfIsNull(this.dsResult.getColumn(0,"nextEventTitlNm"))){
				//버튼 비활성화
				this.divNext.form.btnNext.set_enable(false);
				this.divNext.form.edtNextTitlNm.set_value("다음 글이 없습니다.");
				this.divNext.form.edtNextTitlNm.set_enable(false);
				this.divNext.form.edtNextTitlNm.set_cursor("auto");
			}else{
				//버튼 활성화
				this.divNext.form.btnNext.set_enable(true);
				this.divNext.form.edtNextTitlNm.set_enable(true);
				this.divNext.form.edtNextTitlNm.set_cursor("pointer");
				this.divNext.form.edtNextTitlNm.set_value(this.smfDispLongText(this.divNext.form.edtNextTitlNm, this.dsResult.getColumn(0,"nextEventTitlNm")));
			}
			
			if(this.smfIsNull(this.dsResult.getColumn(0,"preEventTitlNm"))){
				//버튼 비활성화
				this.divPrev.form.btnPrev.set_enable(false);
				this.divPrev.form.edtPreTitlNm.set_value("이전 글이 없습니다.");
				this.divPrev.form.edtPreTitlNm.set_enable(false);
				this.divPrev.form.edtPreTitlNm.set_cursor("auto");
			}else{
				//버튼 활성화
				this.divPrev.form.btnPrev.set_enable(true);
				this.divPrev.form.edtPreTitlNm.set_enable(true);
				this.divPrev.form.edtPreTitlNm.set_cursor("pointer");
				this.divPrev.form.edtPreTitlNm.set_value(this.smfDispLongText(this.divPrev.form.edtPreTitlNm, this.dsResult.getColumn(0,"preEventTitlNm")));
			}
			
			//this.divDetail.form.divWebEditor.form.fnSetHtml(this.dsResult.getColumn(0,"eventCn"));
			
			//그리드 생성
			this.fnCheckTxtContent();

			
			//기타내용 높이 조절
			var textHeight = this.fnGetContentsHeight(this.divContent.form.divEtcCn.form.txtEtcCn);		
			this.divContent.form.divEtcCn.setOffsetHeight(textHeight);
			this.smfResetScroll(this.divContent.form.divEtcCn.form);
			this.smfResetScroll(this.divContent.form);
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
//빈값 체크
this.fnCheckTxtContent = function ()
{
	var grid = this.divContent.form.grdMain;
	var objDs = this.divContent.form.grdMain.getBindDataset();		//dsGridSet
	
	//dsResult ->dsGridSet (label,data)
	var objColIdList = [
	                      { title:"주제",			colid:"pubcnThmCn"}
	                    , { title:"기간 및 일정",	colid:"pubcnFxCn"}
	                    , { title:"홈페이지",		colid:"hmpgAddr"}
					    , { title:"분야",			colid:"pubcnRealmCn"}
					    , { title:"주최",			colid:"opmtInstNm"}
					    , { title:"주관",			colid:"mngtInstNm"}
						, { title:"문의처",		colid:"qustCttpcCn"}
						, { title:"참가대상",		colid:"pubcnPtptTrgtCn"}
						, { title:"참가방법",		colid:"pubcnPtptMthCn"}
						, { title:"응모분야",		colid:"sprtRealmCn"}
						, { title:"작품규격",		colid:"atwSdrqCn"}
						, { title:"시상내용",		colid:"awdCn"}
						, { title:"심사기준",		colid:"srngCtrCn"}
					   ];
	
	//데이터셋에 이벤트해제(Row 생성될때 실행되는 이벤트제거)
	objDs.set_enableevent(false);				   
	//본페이지는 한번 호출하기 때문에 필요없지만 혹시나해서
	objDs.clearData();
	
	//Row 생성
	for(var i=0;i<objColIdList.length;i++)
	{
		var sColTitle = objColIdList[i].title;
		var sColId = objColIdList[i].colid;
		//dsGridSet 에 넣을 데이터(dsResult에서 뽑아오기)
		var sColValue = this.dsResult.getColumn(0,sColId);
		
		//trace('sColTitle: ' + sColTitle);
		//trace('sColId: ' + sColId);
		//trace('sColValue: ' + sColValue);
		
		
		//뽑아온 데이터가 있는지 없는지 확인
		var bInsert = this.smfIsNull(sColValue);
		
		//있을 경우만 데이터셋에 넣어서, 없는 경우는 화면에 보이지 않게 
		if(!bInsert)
		{			
			var nRow = objDs.addRow();
			objDs.setColumn(nRow,"label",sColTitle);
			objDs.setColumn(nRow,"data" ,sColValue);
			
			//trace('objDs:' + objDs.getColumn(nRow,"label") + " " + objDs.getColumn(nRow,"data"));
		}
	}

	//Row 추가 끝났으니 다시 이벤트 활성화
	objDs.set_enableevent(true);				   
	
	trace(objDs.saveXML());
	
	//그리드 최소 길이 설정
	var gridHeigt = grid.getRealRowFullSize();
	if(!this.smfIsMobile() && grid.getRealRowFullSize() < 470){
		gridHeigt = 470;
	}
	
	//그리드 화면 높이 조정
	grid.setOffsetHeight(gridHeigt+2);
	
	//그리드를 담고있는 div 높이 조정
	//this.smfResetScroll(this.divContent.form);
};

//높이 값 구하는 함수(타이틀)
this.fnGetTitleHeight = function(objContentsStatic)
{
	var strFont = 'bold 16px/1.5 "NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic"';
	var strMFont = '36px/1.4 "NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic"';
	var Font = this.smfIsMobile()?strMFont:strFont;
	var nHeightPadding = 20;		
	
	var staText = objContentsStatic.text;
	var staWidth = objContentsStatic.getOffsetWidth();
	var nTextHeight = nexacro.getTextSize(staText,Font,staWidth,"char");
	trace("nTextHeight: " + (nTextHeight.ny+nHeightPadding ) );
	
	return nTextHeight.ny+nHeightPadding ;
};

//높이 값 구하는 함수(기타내용)
this.fnGetContentsHeight = function(objContentsStatic)
{
	var strFont = 'bold 16px/normal "NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic"';
	var strMFont = '28px/normal "NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic"';
	var Font = this.smfIsMobile()?strMFont:strFont;
	var nHeightPadding = 20;		
	
	var staText = objContentsStatic.text;
	var staWidth = objContentsStatic.getOffsetWidth();
	var nTextHeight = nexacro.getTextSize(staText,Font,staWidth,"char");
	trace("nTextHeight: " + (nTextHeight.ny+nHeightPadding ) );
	
	return nTextHeight.ny+nHeightPadding ;
};

this.fnGetFileInfo = function(fileRefrnId){

	// 업로드 초기화
	this.transaction("fn_filesearch"
		,"baseUrl::/cm_cmc_file_upload_001.do"
		,""
		,"dsOutFileinfo=atchFileinfo" 
		,"fileRefrnId='"+fileRefrnId+"'"
		,this.btnUpload_FileSearch_callback
		,false // 동기
	);

	if(this.dsOutFileinfo.rowcount > 0){
		var addHeight = this.smfIsMobile()? (65 + (this.dsOutFileinfo.rowcount-1)*50) : (45 + (this.dsOutFileinfo.rowcount-1)*30);
		this.divFileDownload.set_height(parseInt(this.divFileDownload.height) + parseInt(addHeight));
	} else {
		this.divFileDownload.set_height(-1);
	}
	for (var i = 0; i < this.dsOutFileinfo.rowcount; i++) {
		var responseCustomValue = "";
		var sDownloadPath = "";
		var handlerCode       = "PA.PAS.MMS";
		var fileSn            = this.dsOutFileinfo.getColumn(i,"fileRefrnId");
		var fileId            = this.dsOutFileinfo.getColumn(i,"fileId");
		var fileSize          = this.dsOutFileinfo.getColumn(i,"atchFileMg");
		var backendFilename   = this.dsOutFileinfo.getColumn(i,"atchFileGuid");
		var filename  		  = this.dsOutFileinfo.getColumn(i,"atchFileNm");
		var sFileEncryptYn    = "N";
		var sPrivInfoFiltYn   = "N";
		var sFileSaveStg      = this.dsOutFileinfo.getColumn(i,"fileSaveStg");
		var sFileInfSaveYn    = "Y";

		this.divFileDownload.form.fnAddUploadedFile(handlerCode, fileSn, fileSize, backendFilename, filename, fileId
												, sDownloadPath, sFileEncryptYn, sPrivInfoFiltYn, sFileSaveStg, sFileInfSaveYn);	
	}
};

this.btnUpload_FileSearch_callback = function()
{
	for (var i = 0; i < this.dsOutFileinfo.rowcount; i++) {
		var responseCustomValue = "";
		var sDownloadPath = "";
		var handlerCode       = "PA.PAS.MMS";
		var fileSn            = this.dsOutFileinfo.getColumn(i,"fileRefrnId");
		var fileId            = this.dsOutFileinfo.getColumn(i,"fileId");
		var fileSize          = this.dsOutFileinfo.getColumn(i,"atchFileMg");
		var backendFilename   = this.dsOutFileinfo.getColumn(i,"atchFileGuid");
		var forntendFilename  = this.dsOutFileinfo.getColumn(i,"atchFileNm");
		var sFileEncryptYn    = this.dsOutFileinfo.getColumn(i,"fileEncryptYn");
		var sPrivInfoFiltYn   = this.dsOutFileinfo.getColumn(i,"privInfoFiltYn");
		var sFileSaveStg      = this.dsOutFileinfo.getColumn(i,"fileSaveStg");
		var sFileInfSaveYn    = this.dsOutFileinfo.getColumn(i,"fileInfSaveYn");
		this.divFileDownload.form.fnAddUploadedFile(handlerCode, fileSn, fileSize, backendFilename, forntendFilename, fileId
												, sDownloadPath, sFileEncryptYn, sPrivInfoFiltYn, sFileSaveStg, sFileInfSaveYn);
	}
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// [목록]버튼클릭 처리
this.btnList_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var params = {"dsSearchParam":this.dsSearchParam
				, "dsPagingParam":this.dsPagingParam
				, "dsListParam" : this.dsListParam
				};
	this.smfSetWorkPage("pa_pas_mms_cn::pas_mmscn03_m01.xfdl", params);
};

// 이전 게시물
this.divPrev_btnPrev_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var seventId = this.dsResult.getColumn(0,"preEventId");
	
	if(this.dsResult.getColumn(0,"preEventScCd") == "1")
	{
		var params = {pafrBbsId:seventId};
		this.smfSetWorkPage("pa_pas_mms_cn::pas_mmscn03_m02.xfdl", params);
	}
	else
	{
		this.fnSearch(seventId);
	}
};

// 다음 게시물
this.divNext_btnNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var seventId = this.dsResult.getColumn(0,"nextEventId");
	
	if(this.dsResult.getColumn(0,"nextEventScCd") == "1")
	{
		var params = {pafrBbsId:seventId};
		this.smfSetWorkPage("pa_pas_mms_cn::pas_mmscn03_m02.xfdl", params);
	}
	else
	{
		this.fnSearch(seventId);
	}
};

]]></Script>
    <Bind>
      <BindItem id="item1" compid="divTitle.form.mskView" propid="value" datasetid="dsResult" columnid="inqCnt"/>
      <BindItem id="item3" compid="divPrev.form.edtPreTitlNm" propid="value" datasetid="dsResult" columnid="preEventTitlNm"/>
      <BindItem id="item4" compid="divNext.form.edtNextTitlNm" propid="value" datasetid="dsResult" columnid="nextEventTitlNm"/>
      <BindItem id="item2" compid="divContent.form.divEtcCn.form.txtEtcCn" propid="value" datasetid="dsResult" columnid="eventEtcCn"/>
      <BindItem id="item5" compid="divTitle.form.staTitle" propid="text" datasetid="dsResult" columnid="eventTitlNm"/>
      <BindItem id="item6" compid="divTitle.form.txtTitle" propid="value" datasetid="dsResult" columnid="eventTitlNm"/>
    </Bind>
  </Form>
</FDL>
