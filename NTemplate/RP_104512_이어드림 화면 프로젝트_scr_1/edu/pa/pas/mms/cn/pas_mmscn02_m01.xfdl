                <Cell col="4" displaytype="imagecontrol" edittype="none" cssclass="expr:imptYn==&quot;Y&quot; ? &quot;cell_CountBGGray&quot;:&quot;cell_CountBG&quot;" padding="0px" accessibilitylabel="조회수"/>
