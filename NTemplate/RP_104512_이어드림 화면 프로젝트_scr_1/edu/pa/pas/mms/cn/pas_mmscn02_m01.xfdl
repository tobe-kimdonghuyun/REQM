      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="edtSearchKeyword" propid="value" datasetid="dsSearch" columnid="searchKeyword"/>
    </Bind>
    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 교육소식마당 목록조회
*  @MenuPath    TEMPLATE
*  @FileName 	Temp01.xfdl
*  @Creator 	김지환
*  @CreateDate 	2022.5.12
*  @Desction    공지사항 목록조회
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.5.12     	김지환 	        최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::cm_script.xjs";


/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.paramDsList;	//모바일에서 파라메터로 넘길 조회결과
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.pas_mmscn02_m01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	// 파라메터 세팅
	this.pv_params = this.smfGetFormParams();
	
	if(!this.smfIsNull(this.pv_params.dsSearchParam)){
		this.dsSearch.loadXML(this.pv_params.dsSearchParam);
	}
	if(!this.smfIsNull(this.pv_params.dsPagingParam)){
		this.dsPageInfo.loadXML(this.pv_params.dsPagingParam);
		if(this.dsPageInfo.getConstColIndex("initIsUsePageInfo") < 0){
			this.dsPageInfo.addConstColumn("initIsUsePageInfo","Y");
		} else {
			this.dsPageInfo.setConstColumn("initIsUsePageInfo","Y");
		}
	}

	//모바일 상세페이지에서 되돌아온 경우, 목록 유지
	if(!this.smfIsNull(this.pv_params.dsListParam) && this.smfIsMobile()){
		this.dsListTemp.loadXML(this.pv_params.dsListParam);
		this.smfDataAppend(this, this.grdMain, this.dsListTemp);
		var pageIdx = this.dsPageInfo.getColumn(0,"pageIndex");
		this.dsPageInfo.setColumn(0,"pageIndex", pageIdx-1);
		this.divPaging.form.fnInit(this.grdMain, this.dsPageInfo, this.divTotal, this.fnSearch, this);
		this.divTotal.form.fnInit(this.grdMain, this.dsPageInfo, this.divTotal, this.fnSearch, this);
		this.divPaging.form.btnAppendData_onclick();
	}else{
		//  페이지를 조회한다.
		this.btnSearch.click();
	}
	
	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(obj, e)
{
	var vSearchKeyword = this.edtSearchKeyword.value;
	var objRegExp = /[$]/gi;
	if(!this.smfIsNull(vSearchKeyword)){
		vSearchKeyword = vSearchKeyword.replace(objRegExp,"");	//특수문자 제거
	}
	this.dsSearch.setColumn(0,"searchKeyword" , vSearchKeyword);
	
	var sServiceId = "select";
	if(this.smfIsMobile()){
		sServiceId = "selectTemp";
	}
	
 	// 서비스 객체 생성
	this.smfSearchService(sServiceId)
		// 페이징처리
		.paginator(this.grdMain, this.divPaging, this.divTotal, this.dsPageInfo, this.fnSearch, e)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
		
			if(this.smfIsMobile()){
				this.paramDsList = this.dsList.saveXML();
				this.smfDataAppend(this, this.grdMain, this.dsListTemp);
				// 총 검색결과와 현재 검색 결과 수가 일치할 경우 [더보기]버튼 숨김 
				if(this.dsPageInfo.getColumn(0, "totalCount")==this.dsList.getRowCount()){
					this.divPaging.set_visible(false);
				}else{
					this.divPaging.set_visible(true);
				}
			}
			if(!this.smfIsMobile()){
				this.parent.parent.scrollTo(0,0);
				
				if(this.dsList.getRowCount() == 0){
					this.divPaging.set_visible(false);
				}else{
					this.divPaging.set_visible(true);
				}
			}
			this.smfResetScroll(this);
			
			if(callbackParams.errors) return;
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnDisplayText = function(obj,nCell,nRow,sLongText,sImptYn)
{
	var sFont = (sImptYn=="Y"?'normal 700 18px/normal "Noto Sans KR","NotoSansKR-Bold"':'normal 400 18px/normal "Noto Sans KR","NotoSansKR-Regular"');
	//var objFont = new nexacro._PaddingObject(sFont);
	var nPadding = (sImptYn=="Y"?180:50);

	if(this.smfIsMobile())
	{
		sFont = (sImptYn=="Y"?'normal 700 28px/normal "Noto Sans KR","NotoSansKR-Bold"':'normal 400 28px/normal "Noto Sans KR","NotoSansKR-Regular"');	
		nPadding = (sImptYn=="Y"?220:90);
	}
	return this.smfDispLongTextGrid(obj,nCell,nRow,sLongText,sFont,nPadding);
};

// imptYn :중요여부, fileRefrnId:파일존재여부
this.fnSetCssFileYN = function(imptYn, fileRefrnId) {
	var cssRtn = "cell_bgGray";

	if (imptYn=="Y") {
		if (this.smfIsNull(fileRefrnId)){
			cssRtn = "cell_bgGray";
		}else {
			cssRtn = "cell_FileAddGray";
		}
	}else {
		if (this.smfIsNull(fileRefrnId)){
			cssRtn = "";
		}else {
			cssRtn = "cell_FileAdd";
		}	
	}
	
	if (this.smfIsMobile()) {
		if (!this.smfIsNull(cssRtn))	cssRtn = cssRtn+"_M";
	}
	
	return cssRtn;
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.smfIsMobile()){
		this.dsPageInfo.setColumn(0,"pageIndex", 1);
		this.dsPageInfo.setColumn(0,"totalCount", 0);
	}
	this.fnSearch(obj, e);
};

this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	// 클릭한 셀을 구한다
	var nRow = e.row;
	var nCell = e.cell;
	
	var titlNo = 0;
	if(this.smfIsMobile()){
		titlNo = 1;
	}
	
	if(nCell == e.cell) // 제목 클릭
	{
		var objDs = obj.getBindDataset();
		var seduNewsId = objDs.getColumn(nRow,"eduNewsId");
		var params = {"eduNewsId":seduNewsId
				, "dsSearchParam":this.dsSearch.saveXML()
				, "dsPagingParam":this.dsPageInfo.saveXML()
				, "dsListParam" : this.paramDsList
			};
			
		this.smfSetWorkPage("pa_pas_mms_cn::pas_mmscn02_m02.xfdl", params);
	}
};
this.edtSearchKeyword_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode == 13){
		this.btnSearch.click();
	}
};

this.pas_mmscn02_m01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.grdMain.set_enableredraw(false);
	
	this.grdMain.set_enableredraw(true);
};
]]></Script>
  </Form>
</FDL>
