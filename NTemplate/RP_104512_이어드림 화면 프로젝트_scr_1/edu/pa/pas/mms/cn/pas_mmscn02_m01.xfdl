        <Div id="divPaging" taborder="5" left="0" top="grdMain:50" height="30" right="0" url="comm::comp_paginator2.xfdl" initvalueid="ivDivAccessibilityOn" accessibilitylabel="페이징그룹박스"/>
      </Layout>
      <Layout name="Layout0" screenid="mobileP,tabletP" width="640" height="2005" mobileorientation="portrait" type="default">
        <Div id="divPaging" height="120" left="20" top="grdMain:70" right="20" formscrolltype="none" taborder="5"/>
