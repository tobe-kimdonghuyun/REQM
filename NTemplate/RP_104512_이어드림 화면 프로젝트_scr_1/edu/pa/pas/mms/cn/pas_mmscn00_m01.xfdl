        <Grid id="grdMain" taborder="4" left="0" top="edtSearchKeyword:20" height="672" autofittype="col" autoenter="select" binddataset="dsList" fillareatype="none" cssclass="grd_notice" selecttype="cell" scrollbartype="none none" scrolltype="none" initvalueid="ivGrdAccessibilityOn" formatid="default" oncellclick="grdMain_oncellclick" nodatatext="조회된 데이터가 없습니다." right="0" accessibilitylabel="공지사항목록" onkeyup="grdMain_onkeyup">
