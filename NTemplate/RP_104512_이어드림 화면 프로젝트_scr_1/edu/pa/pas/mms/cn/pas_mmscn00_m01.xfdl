                <Cell col="1" displaytype="imagecontrol" edittype="none" padding="0px" cssclass="expr:comp.parent.fnSetCssFileYN(imptYn, fileRefrnId)" accessibilitylabel="expr:(fileRefrnId != undefined &amp;&amp; fileRefrnId != &quot;&quot;) ?&quot;첨부파일 존재함&quot;:&quot;첨부파일 존재하지 않음&quot;"/>
                <Cell cssclass="cell_WF_LinkBtn emptyCellButton" col="2" displaytype="buttoncontrol" edittype="button" text="" accessibilitylabel="expr:imptYn==&quot;Y&quot;?&quot;중요 &quot;+ntcMteTitlNm+&quot; 상세 바로가기&quot;:ntcMteTitlNm+&quot; 상세 바로가기&quot;"/>
                <Cell col="3" text="bind:regDt" displaytype="date" calendardateformat="yyyy.MM.dd." cssclass="expr:imptYn==&quot;Y&quot;?&quot;cell_bgGray01&quot;:&quot;cell_bgGray02&quot;" calendareditformat="yyyy.MM.dd."/>
              </Band>
