                <Cell row="1" colspan="3" border="0px none" cssclass="expr:imptYn==&quot;Y&quot;?&quot;cell_ImpNoti_M&quot;:&quot;cell_ImpTit_M&quot;" expr="expr:comp.parent.fnDisplayText(comp,0,currow,ntcMteTitlNm,imptYn)" accessibilitylabel="expr:imptYn==&quot;Y&quot;?&quot;중요 &quot;+ntcMteTitlNm:ntcMteTitlNm" textAlign="left"/>
                <Cell row="1" col="3" border="0px none" edittype="none" cssclass="expr:comp.parent.fnSetCssFileYN(imptYn, fileRefrnId)" padding="0px 14px 0px 0px" accessibilitylabel="expr:(fileRefrnId != undefined &amp;&amp; fileRefrnId != &quot;&quot;) ?&quot;첨부파일 존재함&quot;:&quot;첨부파일 존재하지 않음&quot;"/>
                <Cell row="2" colspan="4" border="0px none" cssclass="expr:imptYn==&quot;Y&quot;?&quot;cell_txt24R,cell_color5959,cell_bgGray_M&quot;:&quot;cell_txt24R,cell_color5959&quot;" text="bind:regDt" displaytype="date" textAlign="left" padding="0px 0px 0px 20px" color="#595959" calendardateformat="yyyy.MM.dd." calendareditformat="yyyy.MM.dd." letterSpacing="0px" font="normal 400 24px/normal &quot;Noto Sans KR&quot;,&quot;NotoSansKR-Regular&quot;"/>
                <Cell row="3" colspan="4" cssclass="expr:imptYn==&quot;Y&quot;?&quot;cell_bgGray_M&quot;:&quot;&quot;" accessibilityenable="false"/>
