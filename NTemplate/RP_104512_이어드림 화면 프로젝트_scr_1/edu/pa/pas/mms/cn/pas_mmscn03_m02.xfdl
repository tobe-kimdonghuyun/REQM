              <TextArea id="txtTitle" taborder="1" left="20" top="28" height="50" cssclass="txt_noticeTit" onchanged="div_title_txt00_onchanged" wordWrap="char" right="369" value="2023학년도 정부 재정지원제한대학 평가 및 2022~2024년 일반재정지원 대학 추가 선정 가결과 발표" readonly="true" initvalueid="ivTxtNormal"/>
