    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResult=dsResult</Col>
            <Col id="asynctp"/>
            <Col id="url">pas_mms_cn00_004.do</Col>
            <Col id="id">select</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="ntcMteId" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsResult" useclientlayout="true">
        <ColumnInfo>
          <Column id="ntcMteId" type="string" size="256"/>
          <Column id="ntcMteTitlNm" type="string" size="256"/>
          <Column id="ntcMteCn" type="string" size="256"/>
          <Column id="pafrSysClfCd" type="string" size="256"/>
          <Column id="cddcScCd" type="STRING" size="256"/>
          <Column id="wrtCddcScCd" type="string" size="256"/>
          <Column id="fileRefrnId" type="string" size="256"/>
          <Column id="ntcMteInqCnt" type="BIGDECIMAL" size="256"/>
          <Column id="aplcnBgngYmd" type="DATE" size="8"/>
          <Column id="aplcnEndYmd" type="DATE" size="8"/>
          <Column id="imptYn" type="string" size="256"/>
          <Column id="prdLmttYn" type="string" size="256"/>
          <Column id="etcCn" type="string" size="256"/>
          <Column id="rgtrNm" type="STRING" size="256"/>
          <Column id="rgtrDptNm" type="STRING" size="256"/>
          <Column id="mdfrNm" type="STRING" size="256"/>
          <Column id="mdfrDptNm" type="STRING" size="256"/>
          <Column id="rgtrId" type="STRING" size="256"/>
          <Column id="regDt" type="DATETIME" size="256"/>
          <Column id="mdfrId" type="STRING" size="256"/>
          <Column id="mdfcnDt" type="DATETIME" size="256"/>
          <Column id="preNtcMteId" type="STRING" size="256"/>
          <Column id="preNtcMteTitlNm" type="STRING" size="256"/>
          <Column id="preRegDt" type="DATETIME" size="256"/>
          <Column id="nextNtcMteId" type="STRING" size="256"/>
          <Column id="nextNtcMteTitlNm" type="STRING" size="256"/>
          <Column id="nextRegDt" type="DATETIME" size="256"/>
        </ColumnInfo>
        <Rows/>
      </Dataset>
      <Dataset id="dsOutFileinfo">
        <ColumnInfo>
          <Column id="fileRefrnId" type="STRING" size="256" description="파일SEQ ID"/>
          <Column id="fileId" type="STRING" size="256" description="파일 아이디"/>
          <Column id="suc" type="STRING" size="256"/>
          <Column id="atchFileNm" type="STRING" size="256" description="파일명"/>
          <Column id="atchFileGuid" type="STRING" size="256" description="파일 GUID"/>
          <Column id="atchFileMg" type="STRING" size="256"/>
          <Column id="fileExtsnNm" type="STRING" size="256" description="파일확장자"/>
          <Column id="minTypeNm" type="STRING" size="256" description="파일의 mime type"/>
          <Column id="fileCoursNm" type="STRING" size="256" description="서버파일저장위치"/>
          <Column id="fileObjKey" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 공지사항 상세조회
*  @MenuPath    pa_pas_mns_cn
*  @FileName 	pas_mnscn00_m02.xfdl
*  @Creator 	
*  @CreateDate 	2022.5.12
*  @Desction    공지사항 상세 조회
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.5.12     	홍길동 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs";

//0501 CF 일괄등록

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.pafrBbsId = "";
this.dsSearchParam;
this.dsPagingParam;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.pas_mmscn00_m02_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Form의 default 초기처리를 한다.
	this.smfInitForm(obj);
	
	// 파라메터 세팅
	this.pv_params = this.smfGetFormParams();

	if(!this.smfIsNull(this.pv_params)){
		this.pafrBbsId = this.pv_params.pafrBbsId;
		this.dsSearchParam = this.pv_params.dsSearchParam;
		this.dsPagingParam = this.pv_params.dsPagingParam;
		this.dsListParam = this.pv_params.dsListParam;
		
		// 웹 에디터 셋팅 
		this.divDetail.form.divWebEditor.form.fnInit(this,this.fnWebEditorCallback,this.fnWebEditorSetHtmlCallback);
	}
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

}

/*
*	웹에디터가 onload된 이후 호출되는 callback
*   obj : 웹에디터 Div오브젝트
*/
this.fnWebEditorCallback = function(obj)
{
	// 일반적으로는 데이터를 세팅
	this.fnSearch(this.pafrBbsId);
};

/*
*	웹에디터가 text를 변경 할 경우 호출하는 callback
*   obj : 웹에디터 Div오브젝트
*/
this.fnWebEditorSetHtmlCallback = function(obj,contentHeight)
{
	//trace("***  웹에디터에 Text를 세팅했습니다.["+obj.id+"] contentHeight[=" + contentHeight + "]");
	
	// 일반적으로는 WebEditor Div를 resetScroll해줌.
	//  (Web Editor의 높이가 변경이 되어 있음(autoHeight="Y"인 경우))
	this.smfResetScroll(this.divDetail.form.divWebEditor);
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(pafrBbsId)
{
	this.divFileDownload.set_url("");
	this.divFileDownload.set_height(0);
	this.divFileDownload.set_url("comm::comp_fileDownload.xfdl");
	
	this.dsSearch.setColumn(0,"ntcMteId",pafrBbsId);

 	// 서비스 객체 생성
	this.smfSearchService("select")
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.parent.parent.scrollTo(0,0);
			
			this.divTitle.form.staView.set_text(this.smfSetComma(this.dsResult.getColumn(0,"ntcMteInqCnt")));

			// 제목 div 크기 조절
			this.fnSetResize();

			//제목 div 크기 조정
// 			var title = this.smfIsMobile()?this.divTitle.form.staTitle : this.divTitle.form.txtTitle;
// 			var textHeight = this.fnGetContentsHeight(title);
// 			
// 			this.divTitle.setOffsetHeight(textHeight);
// 			this.divTitle.form.txtTitle.setOffsetHeight(textHeight-10);
// 			this.smfResetScroll(this.divTitle.form);
			
			// 첨부파일 셋팅 
			if(!this.smfIsNull(this.dsResult.getColumn(0,"fileRefrnId"))){
				this.fnGetFileInfo(this.dsResult.getColumn(0,"fileRefrnId"));
			}
			
			// 웹 에디터 셋팅 
			if(this.dsResult.getColumn(0,"nextNtcMteTitlNm") == null){
				this.divNext.form.edtNextTitlNm.set_value("다음 글이 없습니다.");
				this.divNext.form.btnNext.set_enable(false);
				this.divNext.form.edtNextTitlNm.set_cursor("auto");
			} else {
				this.divNext.form.btnNext.set_enable(true);
				this.divNext.form.edtNextTitlNm.set_cursor("pointer");
				this.divNext.form.edtNextTitlNm.set_value(this.smfDispLongText(this.divNext.form.edtNextTitlNm, this.dsResult.getColumn(0,"nextNtcMteTitlNm")));
			}
			if(this.dsResult.getColumn(0,"preNtcMteTitlNm") == null){
				this.divPrev.form.edtPreTitlNm.set_value("이전 글이 없습니다.");
				this.divPrev.form.btnPrev.set_enable(false);
				this.divPrev.form.edtPreTitlNm.set_cursor("auto");
			} else {
				this.divPrev.form.btnPrev.set_enable(true);
				this.divPrev.form.edtPreTitlNm.set_cursor("pointer");
				this.divPrev.form.edtPreTitlNm.set_value(this.smfDispLongText(this.divPrev.form.edtPreTitlNm, this.dsResult.getColumn(0,"preNtcMteTitlNm")));
			}
			this.divDetail.form.divWebEditor.form.fnSetHtml(this.dsResult.getColumn(0,"ntcMteCn"));
			//this.smfResetScroll(this.divDetail.form.divWebEditor);
			
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
//컨텐츠 리사이징
this.fnSetResize = function(){
	
	//제목 div 크기 조정
	var title = this.smfIsMobile()?this.divTitle.form.staTitle : this.divTitle.form.txtTitle;
	var textHeight = this.fnGetContentsHeight(title);
	
	this.divTitle.setOffsetHeight(textHeight);
	this.divTitle.form.txtTitle.setOffsetHeight(textHeight-10);
	this.smfResetScroll(this.divTitle.form);
}


this.fnGetFileInfo = function(fileRefrnId){

	// 업로드 초기화
	this.transaction("fn_filesearch"
		,"baseUrl::/cm_cmc_file_upload_001.do"
		,""
		,"dsOutFileinfo=atchFileinfo" 
		,"fileRefrnId='"+fileRefrnId+"'"
		,this.btnUpload_FileSearch_callback
		,false // 동기
	);

	if(this.dsOutFileinfo.rowcount > 0){
		var addHeight = this.smfIsMobile()? (65 + (this.dsOutFileinfo.rowcount-1)*50) : (45 + (this.dsOutFileinfo.rowcount-1)*30);
		this.divFileDownload.set_height(parseInt(this.divFileDownload.height) + parseInt(addHeight));
	}
	for (var i = 0; i < this.dsOutFileinfo.rowcount; i++) {
		var responseCustomValue = "";
		var sDownloadPath = "";
		var handlerCode       = "PA.PAS.MMS";
		var fileSn            = this.dsOutFileinfo.getColumn(i,"fileRefrnId");
		var fileId            = this.dsOutFileinfo.getColumn(i,"fileId");
		var fileSize          = this.dsOutFileinfo.getColumn(i,"atchFileMg");
		var backendFilename   = this.dsOutFileinfo.getColumn(i,"atchFileGuid");
		var filename  = this.dsOutFileinfo.getColumn(i,"atchFileNm");
		var sFileEncryptYn    = "N";
		var sPrivInfoFiltYn   = "N";
		var sFileSaveStg      = this.dsOutFileinfo.getColumn(i,"fileSaveStg");
		var sFileInfSaveYn    = "Y";

		this.divFileDownload.form.fnAddUploadedFile(handlerCode, fileSn, fileSize, backendFilename, filename, fileId
												, sDownloadPath, sFileEncryptYn, sPrivInfoFiltYn, sFileSaveStg, sFileInfSaveYn);	
	}
};

this.btnUpload_FileSearch_callback = function()
{
	for (var i = 0; i < this.dsOutFileinfo.rowcount; i++) {
		var responseCustomValue = "";
		var sDownloadPath = "";
		var handlerCode       = "PA.PAS.MMS";
		var fileSn            = this.dsOutFileinfo.getColumn(i,"fileRefrnId");
		var fileId            = this.dsOutFileinfo.getColumn(i,"fileId");
		var fileSize          = this.dsOutFileinfo.getColumn(i,"atchFileMg");
		var backendFilename   = this.dsOutFileinfo.getColumn(i,"atchFileGuid");
		var forntendFilename  = this.dsOutFileinfo.getColumn(i,"atchFileNm");
		var sFileEncryptYn    = this.dsOutFileinfo.getColumn(i,"fileEncryptYn");
		var sPrivInfoFiltYn   = this.dsOutFileinfo.getColumn(i,"privInfoFiltYn");
		var sFileSaveStg      = this.dsOutFileinfo.getColumn(i,"fileSaveStg");
		var sFileInfSaveYn    = this.dsOutFileinfo.getColumn(i,"fileInfSaveYn");
		this.divFileDownload.form.fnAddUploadedFile(handlerCode, fileSn, fileSize, backendFilename, forntendFilename, fileId
												, sDownloadPath, sFileEncryptYn, sPrivInfoFiltYn, sFileSaveStg, sFileInfSaveYn);
	}
};

//높이 값 구하는 함수
this.fnGetContentsHeight = function(objContentsStatic)
{
	var strFont = 'bold 16px/1.5 "NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic"';
	var strMFont = '36px/1.4 "NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic"';
	var Font = this.smfIsMobile()?strMFont:strFont;
	var nHeightPadding = 20;		
	
	
	var staText = objContentsStatic.text;
	var staWidth = objContentsStatic.getOffsetWidth();
	var nTextHeight = nexacro.getTextSize(staText,Font,staWidth,"char");
	
	return nTextHeight.ny+nHeightPadding ;
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// [목록]버튼클릭 처리
this.btnList_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var params = {"dsSearchParam":this.dsSearchParam
				, "dsPagingParam":this.dsPagingParam
				, "dsListParam" : this.dsListParam
				};
	this.smfSetWorkPage("pa_pas_mms_cn::pas_mmscn00_m01.xfdl", params);
};

// 이전 게시물
this.divPrev_btnPrev_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(!this.smfIsNull(this.dsResult.getColumn(0,"preNtcMteId"))){
		this.fnSearch(this.dsResult.getColumn(0,"preNtcMteId"));
	}
};

// 다음 게시물
this.divNext_btnNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(!this.smfIsNull(this.dsResult.getColumn(0,"nextNtcMteId"))){
		this.fnSearch(this.dsResult.getColumn(0,"nextNtcMteId"));
	}
};

this.pas_mmscn00_m02_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	// 제목 div 크기 조절
	this.fnSetResize();
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="divTitle.form.txtTitle" propid="value" datasetid="dsResult" columnid="ntcMteTitlNm"/>
      <BindItem id="item1" compid="divTitle.form.staTitle" propid="text" datasetid="dsResult" columnid="ntcMteTitlNm"/>
      <BindItem id="item2" compid="divTitle.form.mskView" propid="value" datasetid="dsResult" columnid="ntcMteInqCnt"/>
      <BindItem id="item3" compid="divTitle.form.mskDate" propid="value" datasetid="dsResult" columnid="regDt"/>
      <BindItem id="item4" compid="divPrev.form.edtPreTitlNm" propid="value" datasetid="dsResult" columnid="preNtcMteTitlNm"/>
      <BindItem id="item5" compid="divNext.form.edtNextTitlNm" propid="value" datasetid="dsResult" columnid="nextNtcMteTitlNm"/>
    </Bind>
  </Form>
</FDL>
