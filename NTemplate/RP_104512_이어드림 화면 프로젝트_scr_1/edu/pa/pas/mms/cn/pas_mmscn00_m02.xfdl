              <MaskEdit id="mskDate" left="0" top="staTitle:34" width="152" height="34" cssclass="msk_notice_date_M" textAlign="left" taborder="2"/>
              <TextArea id="txtTitle" left="190" top="57" height="75" right="15" enable="false" visible="false" taborder="1"/>
              <Static id="staView" left="259" top="staTitle:34" width="135" height="34" cssclass="sta_WF_notice_counter_M" taborder="3" text="23"/>
              <Static id="sta00" left="182" top="staTitle:34" width="77" height="34" font="normal 500 24px/normal &quot;Noto Sans KR&quot;,&quot;NotoSansKR-Medium&quot;,&quot;Malgun Gothic&quot;,&quot;Arial&quot;,&quot;MS PGothic&quot;" color="#595959"/>
