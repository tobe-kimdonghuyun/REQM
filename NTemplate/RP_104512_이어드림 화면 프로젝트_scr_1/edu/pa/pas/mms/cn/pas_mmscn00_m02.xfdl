              <Static id="staTitle" taborder="0" text="제목" left="26" top="8" width="120" height="60" cssclass="sta_notice_Title_M" visible="false" enable="false" initvalueid="ivStcAccessibilityOn"/>
              <TextArea id="txtTitle" taborder="1" left="20" top="28" height="50" cssclass="txt_noticeTit" onchanged="div_title_txt00_onchanged" wordWrap="char" right="282" value="2023학년도 정부 재정지원제한대학 평가 및 2022~2024년 일반재정지원 대학 추가 선정 가결과 발표20232023학년도 정부 재정지원제한대학 평가 및 2022~2024년 일반재정지원 대학 추가 선정결과 발표2023학학 가결결과 발표202" readonly="true" initvalueid="ivTxtNormal"/>
