    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    체육인력서비스(교육공공클라우드) > 스포츠클럽 활동내역 관리
*  @FileName 	phe_phesm19_m00.xfdl 
*  @Creator 	Kangchaeyoon
*  @CreateDate 	2022.09.27 
*  @Desction    체육인력서비스(교육공공클라우드) > 스포츠클럽 활동내역 관리
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.09.27            Kangchaeyoon                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	this.dsSearch.setColumn(0, 'cddcCd', this.smfGetCddcCode());
	
	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
			url : "/phe_phe_sm19_000.do",
		})
		.mappingRulesetToForm(this.divSearch, "search")
		.callback(function(callbackParams) {
		})
		.run();
	
	// 현재년도 자동설정
	this.fnYearSet(this.divSearch.form.cboAyr);
	// 활동상태 (-전체-) 세팅
	this.divSearch.form.cboActScCd.set_index(0);
	//그리드 상단 텍스트 세팅
	this.grdNmStng();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 활동내역 등록/수정 팝업 CALLBACK
 */
this.fnPopupCallback = function(e, sender){
	if(e.type == 'insert'){
		this.fnSearchCompeList();
	}
};

/**
 * 메세지 CALLBACK
 */
this.fnMessageCallback = function(){
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 활동내역관리 목록 조회 Transaction
 */
this.fnSearchList = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("listAct")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){
				//학교과정구분코드 세팅
				this.fnSetShlKndScCd();
				//그리드 상단 텍스트 세팅
				this.grdNmStng();
				if (this.dsActList.getRowCount() != 0){
					this.fnSearchCompeList();
				}
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')], this.fnMessageCallback);
			}
		});
};

/**
 * @description 활동내역목록 조회 Transaction
 */
this.fnSearchCompeList = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("listCompe")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){
				//그리드 상단 텍스트 세팅
				this.grdNmStng();
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')], this.fnMessageCallback);
			}
		});
};

/**
 * @description 활동내역목록 삭제 Transaction
 */
this.fndeleteListCompe = function()
{
 	// 서비스 객체 생성
	this.smfDeleteService("deleteCompe")
		// 데이터 변경 필수 
		.requireExistsData(this.dsCompeList)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){
				//활동내역관리 목록 조회
				this.fnSearchList();
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')], this.fnMessageCallback);
			}
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 그리드 상단 텍스트 세팅 (학년도 / 클럽명)
*/
this.grdNmStng = function()
{
	var ayr = this.dsSearch.getColumn(0, "ayr");
	var pheSscNm = this.dsActList.getColumn(this.dsActList.rowposition, "pheSscNm");
	
	//그리드 상단 텍스트 설정
	this.edtAyr.set_value(ayr);
	this.edtSsc.set_value(pheSscNm);
};

/**
 * @description 콤보박스 년도 선택
*/
this.fnYearSet = function(cmb)
{
	var ds = cmb.getInnerDataset();
	for(var i = 0; i < 3; i++){
		var nRow = ds.addRow();
		ds.setColumn(nRow, cmb.codecolumn, new Date().getFullYear()-i);
		ds.setColumn(nRow, cmb.datacolumn, new Date().getFullYear()-i);
	}
	cmb.set_index(0);
};

/**
 * @description 학교과정구분 설정
*/
this.fnSetShlKndScCd = function(){
	var shlKndScCd = this.dsSearch.getColumn(0, 'shlKndScCd');
	
	if(shlKndScCd == '02' || shlKndScCd == '06' || shlKndScCd == '19'){ // 초등
		this.dsSearch.setColumn(0, 'shlCrseScCd', 2);
	}else if(shlKndScCd == '03' || shlKndScCd == '07' || shlKndScCd == '09' || shlKndScCd == '25'){ // 중등
		this.dsSearch.setColumn(0, 'shlCrseScCd', 3);
	}else if(shlKndScCd == '04' || shlKndScCd == '08' || shlKndScCd == '10' || shlKndScCd == '11' || shlKndScCd == '18'){ // 고등
		this.dsSearch.setColumn(0, 'shlCrseScCd', 4);
	}else if(shlKndScCd == '05' || shlKndScCd == '26'){ // 특수
		this.dsSearch.setColumn(0, 'shlCrseScCd', 5);
	}else{
		this.dsSearch.setColumn(0, 'shlCrseScCd', 0);
	}
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 조회 버튼 클릭
*/
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 스포츠클럽 목록 조회
	this.fnSearchList();
};

/**
 * @description 등록 버튼 클릭
*/
this.btnReg_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	if (this.dsActList.getRowCount() == 0){
		this.smfAlert('PA003',['학교스포츠클럽 정보가']);
		return false;
	}
	
	var popupParams = {
		sender: obj,								// sender 지정
		callback: this.fnPopupCallback,				// 콜백함수 지정
		params: {
			procType: 'insert', 						// 처리타입 지정
			dataset: this.smfRowToObject(this.dsActList, this.dsActList.rowposition),
			shlCrseScCd: this.dsSearch.getColumn(0, 'shlCrseScCd'),
			cddcCd: this.dsSearch.getColumn(0, 'cddcCd'),
			ayr : this.edtAyr.value,
			btnType : 'reg',
		},
	};
	
	//모달팝업 실행
	this.smfDialog("_auto", "pa_phe_phe_sm::phe_phesm19_p00.xfdl", popupParams, null, null, this.smfIsMobile() ? 640 : null, this.smfIsMobile() ? 1200 : null);
};

/**
 * @description 삭제 버튼 클릭
*/
this.btnDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var rowCnt = this.dsCompeList.extractRows("_chk == 1");
	
	// 선택된 목록이 없을 때
	if(this.isNil(rowCnt)){
		//선택된 {0}이(가) 없습니다. {0}을(를) 선택하여 주십시오.
		this.smfAlert('CM013', ['행']);
		return false;
	}
	
	this.dsSearch.setColumn(0, "trnCd", 'D');
	// 삭제 처리 
	this.fndeleteListCompe();
};

/**
 * @description 그리드(활동명/대회명) 클릭
*/
this.grdMain2_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{	
	//활동명/대회명 클릭 시
	if(e.col == 4){		
		var popupParams = {
			sender: obj,								// sender 지정
			callback: this.fnPopupCallback,				// 콜백함수 지정
			params: {
				procType: 'update', 						// 처리타입 지정
				dataset: this.smfRowToObject(obj.getBindDataset(), e.row),
				shlCrseScCd: this.dsSearch.getColumn(0, 'shlCrseScCd'),
				cddcCd: this.dsSearch.getColumn(0, 'cddcCd'),
				ayr: this.edtAyr.value,
				btnType : 'modify'
			},
		};
		//모달팝업 실행
		this.smfDialog("_auto", "pa_phe_phe_sm::phe_phesm19_p00.xfdl", popupParams, null, null, this.smfIsMobile() ? 640 : null, this.smfIsMobile() ? 1200 : null);
	}
};

/**
  * @description 그리드 체크박스 헤드 클릭 (전체선택/부분선택)
*/
this.grdMain2_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var columnName = obj.getCellProperty("body",e.cell,"text");
		if("bind:_chk"==columnName){
			this.smfToggleChkHeader(obj, e, this.fnRenderGridCheckbox);
		}
};

/**
 * @description 종목 데이터셋 행 변경 시
*/
this.dsActList_onrowposchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSRowPosChangeEventInfo)
{
	if (this.dsActList.getRowCount() != 0){			//데이터가 있을 때 작동
		this.dsActListSearch.copyRow(0, this.dsActList, e.newrow);
		this.dsSearch.setColumn(0, 'sscItemCd', this.dsActListSearch.getColumn(0, 'sscItemCd'));
		this.dsSearch.setColumn(0, 'pheSscSn', this.dsActListSearch.getColumn(0, 'pheSscSn'));
	}else{
		this.dsCompeList.clearData();
	}
};

/**
 * @description 종목 그리드 행 클릭 시
*/
this.grdPheSsc_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	this.fnSearchCompeList();
};]]></Script>
