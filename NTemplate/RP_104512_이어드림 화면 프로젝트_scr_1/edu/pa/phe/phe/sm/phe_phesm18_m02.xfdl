    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    체육인력서비스(교육공공클라우드) > 스포츠클럽 강사 수정
*  @FileName 	phe_phesm18_m02.xfdl 
*  @Creator 	Kangchaeyoon
*  @CreateDate 	2022.09.27 
*  @Desction    체육인력서비스(교육공공클라우드) > 스포츠클럽 강사 수정
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.09.27            Kangchaeyoon                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
		url : "/phe_phe_sm18_000.do",
		})
		.mappingRulesetToForm(this.divInsrInfo, "save")
		.callback(function(callbackParams) {
		})
		.run()
	;
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 주소찾기 팝업 CALLBACK
 */
this.fnCommpopRdnZip = function(e, sender){
	this.divInsrInfo.form.edtPostNo.set_value(e.row.newPostNo);
	this.divInsrInfo.form.edtAddr.set_value(e.row.roadNmAddr);
	this.divInsrInfo.form.edtAddrDtl.set_value(e.row.roadNmDtl);
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 강사 정보 저장 Transaction
 */
this.fnSave = function()
{
 	// 서비스 객체 생성
	this.smfSaveService("save")
		// (권장) 데이터 존재 필수
		.requireExistsData(this.dsInsrInfo)
		// 데이터 변경 필수 
		.requireModifredData(this.dsInsrInfo)
		// 데이터 검증 
		.validateForm(this.divInsrInfo)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			//강사 정보 조회
			this.fnSelect();
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 캘린더 오늘 이전 선택 막기
*/
this.ymd_canchange = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{
	//오늘 이후 선택 안됨
	if ( e.postvalue > this.smfToday() ){
		return false;
	}	
};

/**
 * @description 전화번호 값 세팅/ sc 변수- spe : 분리, cnnc : 합체
 */
this.fnTelNumSpeCnnc = function(sc){
	var frm = this.divInsrInfo.form;
	var separator = '-';
	
	if (sc == 'spe'){
		var sprtsInsrTelno = this.dsInsrInfo.getColumn(0, 'sprtsInsrTelno');			//연락처
		var sprtsInsrMblTelno = this.dsInsrInfo.getColumn(0, 'sprtsInsrMblTelno');		//휴대전화
		
		if(!this.isNil(sprtsInsrTelno)){
			var telList = this.smfExpressionToList(sprtsInsrTelno, separator);
			frm.edtCttpc1.set_value(telList[0]);
			frm.edtCttpc2.set_value(telList[1]);
			frm.edtCttpc3.set_value(telList[2]);
		}
		if(!this.isNil(sprtsInsrMblTelno)){
			var mblTelList = this.smfExpressionToList(sprtsInsrMblTelno, separator);
			frm.edtMblTelno1.set_value(mblTelList[0]);
			frm.edtMblTelno2.set_value(mblTelList[1]);
			frm.edtMblTelno3.set_value(mblTelList[2]);
		}
	}else{
		var telNo = frm.edtCttpc1.value + separator + frm.edtCttpc2.value + separator + frm.edtCttpc3.value;
		var MbltelNo = frm.edtMblTelno1.value + separator + frm.edtMblTelno2.value + separator + frm.edtMblTelno3.value;
		
		if(!this.isNil(frm.edtCttpc1.value) || !this.isNil(frm.edtCttpc2.value) || !this.isNil(frm.edtCttpc3.value)){
			this.dsInsrInfo.setColumn(0, "sprtsInsrTelno", telNo);
		}
		if(!this.isNil(frm.edtMblTelno1.value) || !this.isNil(frm.edtMblTelno2.value) || !this.isNil(frm.edtMblTelno3.value)){
			this.dsInsrInfo.setColumn(0, "sprtsInsrMblTelno", MbltelNo);
		}
	}
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 주소찾기 버튼 클릭
*/
this.divInsrInfo_btnAddr_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var popupParams = {
		callback: this.fnCommpopRdnZip, // 콜백함수 지정
		sender: obj, // sender 지정

		// 팝업 전달 파라메터 지정
		params: {
			procType: 'search'	// 처리타입 지정
		},
	};

	// 모달팝업 실행
	this.smfDialog("_auto", "commpop::commpop_rdn_zip.xfdl", popupParams);
};

/**
 * @description 저장 버튼 클릭
*/
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//전화번호 합체
	this.fnTelNumSpeCnnc('cnnc');
	
	// 저장 처리
	this.fnSave();
};

/**
 * @description 목록 버튼 클릭
*/
this.btnBfr_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.parent.parent.fnDivShowSet(false);
};
]]></Script>
    <Bind>
