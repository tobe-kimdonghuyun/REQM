      <BindItem id="item20" compid="divInsrInfo.form.calCttprd1" propid="value" datasetid="dsInsrInfo" columnid="cTTEnfcYmdBgng"/>
      <BindItem id="item21" compid="divInsrInfo.form.calCttprd2" propid="value" datasetid="dsInsrInfo" columnid="cTTEnfcYmdEnd"/>
