    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    환경관리 > 운동부훈련일지 등록/상세/수정
*  @FileName 	phe_pheam34_p00.xfdl 
*  @Creator 	김민성
*  @CreateDate 	2022.10.11
*  @Desction    운동부훈련일지 등록/상세/수정
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.10.11            김민성                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.pv_params;	// 파라메터 세팅
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);

	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	
	// 전달받은 파라메터 설정
	for(var i = 0; i < this.dsSearch.getColCount(); i++){
		this.dsSearch.setColumn(0, this.dsSearch.getColID(i), this.pv_params.dataset[this.dsSearch.getColID(i)]);
		this.dsArListSearch.setColumn(0, this.dsArListSearch.getColID(i), this.pv_params.dataset[this.dsArListSearch.getColID(i)]);
	}
	this.dsSearch.setColumn(0, 'cddcCd', this.smfGetCddcCode());
	this.dsSearch.setColumn(0, 'shlCrseScCd', this.pv_params.shlCrseScCd);
	this.dsSearch.setColumn(0, "procType", this.pv_params.procType);
	
	if (this.pv_params.procType == 'insert'){
		this.dsSearch.setColumn(0, "disciYmd", this.pv_params.disciYmd);
		this.dsDisciDetail.copyRow(0, this.dsSearch, 0);
		this.fnValidateMain();
		this.fnDisciDetail();
		this.fnSetInit();
		this.fnSetBtnStaticSc();
		this.fnSetPheAtndNmprCnt();
		this.fnSearchListDisci();
	}else{
		this.fnSearchSelect();
	}
	
	//=======================================
	// 업로드관련 초기설정을 한다.
	//=======================================
	// 업로드시 저장위치등을 판별할 정보 세팅(대문자 : 시스템코드(2)+"."+서브시스템코드(3)+"."+대분류코드(3))
	this.divFileUpload.UPLOAD_CreateComplete = this.fnEventUploadCreateComplete;  // 필요한 경우만 세팅
	this.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;        // 필요한 경우만 세팅(세팅권장)
	this.divFileUpload.UPLOAD_OnError        = this.fnEventUploadError;           // 필요한 경우만 세팅(세팅권장)
	this.divFileUpload.UPLOAD_AfterAddFile   = this.fnEventUploadAfterAddFile;
	this.divFileUpload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
};

/**
 * raonkupload가 화면을 생성된 이후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @return : N/A
 */
this.fnEventUploadCreateComplete = function(obj,paramObj)
{
}

/**
 * raonkupload가 파일을upload한 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @param : objResultDataset
 * @return : N/A
 */
this.fnEventUploadComplete = function(obj,paramObj,objResultDataset)
{
	// 업로드 성공 후, newfile에 있는 파일들을 webfile로 옮긴다.
	this.divFileUpload.form.fnSetUploadCompleteState(obj,paramObj);
	if(objResultDataset != null){
		this.dsDisciDetail.setColumn(0, "fileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
		for(var i = 0; i < objResultDataset.getRowCount(); i++){
			var row = this.dsOutFileinfo.addRow();
			this.dsOutFileinfo.copyRow(row, objResultDataset, i);
		}
		
		var sFileRefrnId = objResultDataset.getColumn(0,"fileRefrnId");
		
		// 나중에 다운로드하기 위해 관련 정보 세팅
		this.divBscInfo.form.divUpload00._FileRefrnId = sFileRefrnId;
		this.divBscInfo.form.divUpload01._FileRefrnId = sFileRefrnId;
		this.divBscInfo.form.divUpload02._FileRefrnId = sFileRefrnId;
	}
	
	this.fnSave();
}

/**
 * raonkupload가 파일을upload실패 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @return : N/A
 */
this.fnEventUploadError = function(obj,paramObj)
{
}

/**
 * raonkupload가 파일을 추가 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @param : sCustomValue
 * @param : sFileName
 * @param : nFileSize
 * @return : N/A
 */
this.fnEventUploadAfterAddFile = function(obj,paramObj,sCustomValue,sFileName,nFileSize)
{
	var sFileGbnValue    = sFileName;
	var objdivFormObj    = obj.parent.parent._divFormObj;
	
	objdivFormObj.parent._FileGbnValue = sFileGbnValue;
	objdivFormObj.edtFile.set_value(sFileGbnValue);
	
	var num = +objdivFormObj.parent.id.substr(10) + 1;
	this.dsDisciDetail.setColumn(0, 'fileUpdateYn' + num, 'Y');
}
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 유효성체크서비스
 * @param : N/A
 * @param : N/A
 */
this.fnValidateMain = function()
{
	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
		url : "/phe_phe_am34_000.do",
		})
		.mappingRulesetToForm(this.divBscInfo, "saveMain")
		.callback(function(callbackParams) {
			if (this.pv_params.procType == 'update'){
				this.divBscInfo.form.staDisciYmd.set_text(this.divBscInfo.form.staDisciYmd.text.replace('*', ''));
				this.divBscInfo.form.staDisciYmd.set_cssclass("sta_WF_Input01");
			}
		})
		.run()
	;
};

/**
 * 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchSelect = function()
{
	this.dsOutFileinfo.clearData();
	
 	// 서비스 객체 생성
	this.smfSearchService("select")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){
				this.fnSetBtnStaticSc();
				this.fnDisciDetail();
			
				this.dsDisciDetail.setColumn(0, 'fileNm', null);
				this.dsDisciDetail.setColumn(0, 'no2AtchFileNm', null);
				this.dsDisciDetail.setColumn(0, 'no3AtchFileNm', null);
				this.dsDisciDetail.setColumn(0, 'no4AtchFileNm', null);
				this.dsDisciDetail.setColumn(0, 'no5AtchFileNm', null);
				
				if (!this.smfIsNull(this.dsOutFileinfo.getColumn(0, 'fileRefrnId'))){
					this.fnListFileInfo();
				}
				
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')], this.fnMessageCallback);
			}
		});
};

/**
 * 조회서비스(일지목록)
 * @param : N/A
 * @param : N/A
 */
this.fnSearchListDisci = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("listDisci")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')], this.fnMessageCallback);
			}
		});
};

/**
 * 저장서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSave = function()
{
	// 서비스 객체 생성
	this.smfSaveService("save")
		// (권장) 데이터 존재 필수
		.requireExistsData([this.dsDisciDetail, this.dsArStdntList, this.dsTmList])
		// 데이터 변경 필수
		.requireModifredData([this.dsDisciDetail, this.dsArStdntList, this.dsTmList, this.dsOutFileinfo])
		// 데이터 검증
		.validateForm(this.divBscInfo)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){
				this.smfAlert('CM002', [], this.fnMessageCallback); // 저장이 완료되었습니다.
				if (this.pv_params.procType == 'update'){
					this.pv_params.procType = 'search';
					this.fnSearchSelect();
				}else if(this.pv_params.procType == 'insert'){
					this.smfSendResponseToOpener({
						"type": 'insert'
					});
					this.close(true);
				}
			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')], this.fnMessageCallback);
			}
		});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * 등록, 상세, 수정에 따른 버튼 및 목록 문구 설정 - 단순하게 컴포넌트 나열로 수정
 * @param  : N/A
 * @return : N/A
 */
this.fnSetBtnStaticSc = function(){
 	var isSearch = this.pv_params.procType == 'search' ? true : false;
	var btnSaveTxt = this.pv_params.procType == 'search' ? '수정' : '저장';
	var staBackCss = this.pv_params.procType == 'search' ? (this.smfIsMobile() ? "sta_WF_DtlLabel01": "sta_WF_Input01") : (this.smfIsMobile() ? "sta_WF_DtlLabel01": "sta_WF_Essential");
	var mobileTxtColor = this.pv_params.procType == 'search' ? "#172f57" : "#d32850";
	
	if (this.pv_params.procType == 'search'){
		if (this.smfIsMobile()){
			this.btnSave.set_left(+this.sta05.getOffsetWidth());
		}
		this.divBscInfo.form.edtWter.set_value(this.smfNvl(this.dsDisciDetail.getColumn(0, 'userNm'), '') +  ' (' + this.smfNvl(this.dsDisciDetail.getColumn(0, 'mdfrId'), '') + ')');
		this.divBscInfo.form.staDisciYmd.set_text(this.divBscInfo.form.staDisciYmd.text.replace('*', ''));
		this.divBscInfo.form.staPrrcpNmLst.set_text(this.divBscInfo.form.staPrrcpNmLst.text.replace('*', ''));
		this.divBscInfo.form.staDisciYm.set_text(this.divBscInfo.form.staDisciYm.text.replace('*', ''));
		this.divBscInfo.form.staDisciPlace.set_text(this.divBscInfo.form.staDisciPlace.text.replace('*', ''));
		this.divBscInfo.form.staDisciCn.set_text(this.divBscInfo.form.staDisciCn.text.replace('*', ''));
	}else{
		this.divBscInfo.form.edtWter.set_value(this.smfGetKornFlnm() +  ' (' + this.smfGetUserId() + ')');
		this.divBscInfo.form.staPrrcpNmLst.set_text('*' + this.divBscInfo.form.staPrrcpNmLst.text);
		this.divBscInfo.form.staDisciYm.set_text('*' + this.divBscInfo.form.staDisciYm.text);
		this.divBscInfo.form.staDisciPlace.set_text('*' + this.divBscInfo.form.staDisciPlace.text);
		this.divBscInfo.form.staDisciCn.set_text('*' + this.divBscInfo.form.staDisciCn.text);
		
		if (this.smfIsMobile()){
			this.btnSave.setOffsetLeft(+this.btnCancel.getOffsetRight() + this.sta05.getOffsetWidth());
			if (this.pv_params.procType == 'insert'){
				this.divBscInfo.form.staDisciYmd.set_text('*' + this.divBscInfo.form.staDisciYmd.text);
				this.divBscInfo.form.staDisciYmd.set_color(mobileTxtColor);
			}
		}
	}
	
	this.divBscInfo.form.staPrrcpNmLst.set_color(mobileTxtColor);
	this.divBscInfo.form.staDisciYm.set_color(mobileTxtColor);
	this.divBscInfo.form.staDisciPlace.set_color(mobileTxtColor);
	this.divBscInfo.form.staDisciCn.set_color(mobileTxtColor);
			
	this.divTitle.form.imgTitle.set_text(this.titletext + (this.pv_params.procType == 'search' ? ' 상세' : (this.pv_params.procType == 'update' ? ' 수정' : ' 등록')));

	this.divBscInfo.form.staDisciPlaceCn.set_text(this.pv_params.procType == 'search' ? this.dsDisciDetail.getColumn(0, 'disciPlaceNm') : null);
	this.divBscInfo.form.staDisciCnCn.set_text(this.pv_params.procType == 'search' ? this.dsDisciDetail.getColumn(0, 'disciCn') : null);
	this.divBscInfo.form.staPtclrMteCn.set_text(this.pv_params.procType == 'search' ? this.dsDisciDetail.getColumn(0, 'ptclrMteCn') : null);
	this.divBscInfo.form.staDlivMteCn.set_text(this.pv_params.procType == 'search' ? this.dsDisciDetail.getColumn(0, 'dlivMteCn') : null);

	this.divBscInfo.form.staPrrcpNmLst.set_cssclass(staBackCss);
	this.divBscInfo.form.staDisciYm.set_cssclass(staBackCss);
	this.divBscInfo.form.staDisciPlace.set_cssclass(staBackCss);
	this.divBscInfo.form.staDisciCn.set_cssclass(staBackCss);
	
	this.divBscInfo.form.calDisciYmd.set_visible(!isSearch);
	this.divBscInfo.form.div00.set_visible(!isSearch);
	this.divBscInfo.form.btnAdd.set_visible(!isSearch);
	this.divBscInfo.form.btnDelete.set_visible(!isSearch);
	this.divBscInfo.form.div01.form.grdPrrcpNmLst.set_readonly(isSearch);
	this.divBscInfo.form.div02.form.grdDisciYm.set_readonly(isSearch);
	this.divBscInfo.form.edtDisciPlace.set_visible(!isSearch);
	this.divBscInfo.form.txtDisciCn.set_visible(!isSearch);
	this.divBscInfo.form.txtPtclrMteCn.set_visible(!isSearch);
	this.divBscInfo.form.txtDlivMteCn.set_visible(!isSearch);
	this.divBscInfo.form.divUpload00.set_enable(!isSearch);
	this.divBscInfo.form.divUpload01.set_enable(!isSearch);
	this.divBscInfo.form.divUpload02.set_enable(!isSearch);
	this.divBscInfo.form.btnDeleteFile00.set_enable(!isSearch);
	this.divBscInfo.form.btnDeleteFile01.set_enable(!isSearch);
	this.divBscInfo.form.btnDeleteFile02.set_enable(!isSearch);
	this.btnSave.set_text(btnSaveTxt);
	this.btnCancel.set_visible(false);
	
	if (this.pv_params.procType == 'update'){
		this.divBscInfo.form.calDisciYmd.set_visible(isSearch);
		this.btnCancel.set_visible(!isSearch);
	}
};

/**
 * 선수총원과 훈련참가현황 텍스트 세팅
 * @param  : N/A
 * @return : N/A
 */
this.fnDisciDetail = function(){
	var disciTmd = this.dsDisciDetail.getColumn(0, 'disciYmd');
	
	this.divBscInfo.form.staDisciYmdCn.set_text(disciTmd.substr(0,4) + "년 " + disciTmd.substr(4,2) + "월 " + disciTmd.substr(6,2) + "일");
	this.divBscInfo.form.staDisciPnsta1.set_text('참가선수 : ' + this.nvl(this.dsDisciDetail.getColumn(0, 'pheAtndNmprCnt'), 0) + '명');
	this.divBscInfo.form.staDisciPnsta2.set_text('불참선수 : ' + this.nvl(this.dsDisciDetail.getColumn(0, 'nadcNmprCnt'), 0) + '명');

	var cnt = this.dsSearch.getColumn(0, 'shlCrseScCd') == '2' ? 6 : 3;
	for(var i = 0; i < cnt; i++){
		this.divBscInfo.form['staPrrcpTotl'+(i+1)].set_text(
			(i+1) + '학년 '	+ this.dsArStdntList.getCaseCount('grdCd == ' + (i+1)) + '명'
			+ '(남 ' + this.dsArStdntList.getCaseCount('grdCd == ' + (i+1) + ' && sxdsScCd == 1')+'명'
			+ ',여 ' + this.dsArStdntList.getCaseCount('grdCd == ' + (i+1) + ' && sxdsScCd == 2') + '명)');
	}
	this.divBscInfo.form.staPrrcpTotl.set_text('선수총원\n(총 ' + this.dsArStdntList.rowcount + '명)');
};

/**
 * 총 시간 세팅
 * @param  :disciBgngDt	- 훈련시작일시(2022-04-25-00.57.00.000000 or 2022-04-25-00:57:00)
 * @param  :disciEndDt	- 훈련종료일시(2022-04-25-00.57.00.000000 or 2022-04-25-00:57:00)
 * @return : 총 시간 정보
 */
this.fnTotlHrSet = function(disciBgngDt, disciEndDt){
	if (this.smfIsNull(disciBgngDt) || this.smfIsNull(disciEndDt)) return 0;

	return parseInt((new Date(disciEndDt.substr(0,10) +' '+ disciEndDt.substr(11,5).replace('.',':')) - 
					 new Date(disciBgngDt.substr(0,10) +' '+ disciBgngDt.substr(11,5).replace('.',':')))/(1000*60));
};

/**
 * KUpload를 생성시 지정할 property값을 지정
 * @param  : N/A
 * @return : N/A
 */
this.fnSetRaonProp = function()
{
	// 설정할 property
	var objAddRaonProps = {
							MaxOneFileSize			: '10MB'								    // 파일당 최대 사이즈*/
							,ExtensionAllowOrLimit	: '1'										// 설정값이 "0" 이면 설정한 파일 확장자명만 "제한"으로 설정되며, "1"로 설정시 "허용"으로 설정*/
							,ExtensionArr           : 'pdf,png,jpg,jpeg,PDF,PNG,JPG,JPEG'		// 제한 또는 허용할 확장자 (,)로 구분*/
							,MaxTotalFileCount      : '3'                                       //업로드 할 최대 파일 개수 제한값을 설정합니다.
							,DisableAlertMessage	: {
								DisableDeleteConfirm: "1" 										// "1"로 설정시 파일 삭제시 confirm창 비활성.
							}
							,ButtonBarEdit			: "add,remove,remove_all,download,download_all"
							,UseDbclickOpen			: '1'										// 더블클릭으로 파일열기 0: 사용안함 1:사용
							};
	return objAddRaonProps;
}

/**
 * 파일 조회
 * @param : N/A
 * @param : N/A
 */
this.fnListFileInfo = function(){	
	// 업로드 초기화
	this.divFileUpload.form.fnResetUpload();
	
	for (var i = 0; i < this.dsOutFileinfo.rowcount; i++) {
		var handlerCode       = "PA.PHE.PHE";
		var atchFileSn        = this.dsOutFileinfo.getColumn(i, "fileRefrnId");
		var fileSize          = this.dsOutFileinfo.getColumn(i, "atchFileMg"); 
		var backendFilename   = this.dsOutFileinfo.getColumn(i, "atchFileGuid");
		var frontendFilename  = this.dsOutFileinfo.getColumn(i, "atchFileNm");
		var fileId            = this.dsOutFileinfo.getColumn(i, "fileId");
		if(this.isNotNil(atchFileSn)){
			this.divFileUpload.form.fnAddUploadedFile(handlerCode, atchFileSn, fileSize, backendFilename, frontendFilename, fileId);
		}
		this.divBscInfo.form["divUpload0" + i]._FileRefrnId  = atchFileSn;
		this.divBscInfo.form["divUpload0" + i]._FileGbnValue = frontendFilename;
		this.divBscInfo.form["divUpload0" + i].form.edtFile.set_value(frontendFilename);
	}
};

/**
 * 등록/수정 일 때 초기설정
 * @param : N/A
 * @param : N/A
 */
this.fnSetInit = function(){
	this.dsDisciDetail.set_updatecontrol(false);
	this.dsDisciDetail.setColumn(0, 'prrcpTotlNmprCnt', this.dsArStdntList.rowcount);
	this.dsDisciDetail.setColumn(0, 'atchFileCn', null);
	this.dsDisciDetail.setColumn(0, 'no2AtchFileCn', null);
	this.dsDisciDetail.setColumn(0, 'no3AtchFileCn', null);
	this.dsDisciDetail.setColumn(0, 'no4AtchFileCn', null);
	this.dsDisciDetail.setColumn(0, 'no5AtchFileCn', null);
	this.dsDisciDetail.setColumn(0, 'fileUpdateYn1', 'N');
	this.dsDisciDetail.setColumn(0, 'fileUpdateYn2', 'N');
	this.dsDisciDetail.setColumn(0, 'fileUpdateYn3', 'N');
	this.dsDisciDetail.setColumn(0, 'fileUpdateYn4', 'N');
	this.dsDisciDetail.setColumn(0, 'fileUpdateYn5', 'N');
	this.dsDisciDetail.setColumn(0, 'searchYm', this.dsDisciDetail.getColumn(0, 'disciYmd'));
	this.dsDisciDetail.setRowType(0, 1);
	this.dsDisciDetail.set_updatecontrol(true);
}

/**
 * 참가/불참 선수 설정
 * @param : ds		- 데이터 셋
 * @param : N/A
 */
this.fnSetPheAtndNmprCnt = function(){
	var pheAtndNmprCnt = this.dsArStdntList.getCaseCount("partiYn == 1");
	var nadcNmprCnt = this.dsArStdntList.rowcount - this.dsArStdntList.getCaseCount("partiYn == 1");
	this.dsDisciDetail.setColumn(0, 'pheAtndNmprCnt', pheAtndNmprCnt);
	this.dsDisciDetail.setColumn(0, 'nadcNmprCnt', nadcNmprCnt);
	
	this.divBscInfo.form.staDisciPnsta1.set_text('참가선수 : ' + pheAtndNmprCnt + '명');
	this.divBscInfo.form.staDisciPnsta2.set_text('불참선수 : ' + nadcNmprCnt + '명');
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 훈련시간 추가 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		   - [string]ClickEventInfo
 * @return : N/A
 */
this.divBscInfo_btnAdd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var stHr = this.divBscInfo.form.div00.form.edtStHr;
	var stMn = this.divBscInfo.form.div00.form.edtStMn;
	var endHr = this.divBscInfo.form.div00.form.edtEndHr;
	var endMn = this.divBscInfo.form.div00.form.edtEndMn;
	
	if (stHr.value > 24 || endHr.value > 24){
		this.smfAlert('CM104', ["0", "24"], this.fnMessageCallback); // {0}에서 {1} 사이의 값을 입력하세요
		return;
	}
	
	if (stMn.value > 59 || endMn.value > 59){
		this.smfAlert('CM104', ["0", "59"], this.fnMessageCallback); // {0}에서 {1} 사이의 값을 입력하세요
		return;
	}
	
	if ((stHr.value + stMn.value) >= (endHr.value + endMn.value)){
		this.smfAlert('PA058', ["종료시간을 시작시간 이후로 입력"], this.fnMessageCallback); // {0}해주세요.
		return;
	}
	
	if((stHr.value + stMn.value) < (this.dsTmList.getColumn(this.dsTmList.rowcount - 1, 'disciEndHh') + this.dsTmList.getColumn(this.dsTmList.rowcount - 1, 'disciEndMi'))
	&& (this.dsTmList.getColumn(0, 'disciEndHh') != "00" || this.dsTmList.getColumn(0, 'disciEndMi') != "00")) {
		this.smfAlert('PA058', ["마지막 종료시간 이후로 입력"], this.fnMessageCallback); // {0}해주세요.
		return;
	}
	
	var rowIndex = this.dsTmList.addRow();
	this.dsTmList.setColumn(rowIndex, 'disciBgngHh', this.smfLPad(this.divBscInfo.form.div00.form.edtStHr.value, 0 ,2));
	this.dsTmList.setColumn(rowIndex, 'disciBgngMi', this.smfLPad(this.divBscInfo.form.div00.form.edtStMn.value, 0 ,2));
	this.dsTmList.setColumn(rowIndex, 'disciEndHh', this.smfLPad(this.divBscInfo.form.div00.form.edtEndHr.value, 0 ,2));
	this.dsTmList.setColumn(rowIndex, 'disciEndMi', this.smfLPad(this.divBscInfo.form.div00.form.edtEndMn.value, 0 ,2));
	
	for(var i = 0; i < this.dsTmList.rowcount; i++){
		if (Number(this.dsTmList.getColumn(i, "totlHr")) <= 0){
			this.smfAlert('CM020', ["훈련시작시간", "훈련종료시간"], this.fnMessageCallback);
			return;
		}
		this.dsTmList.setColumn(i, "disciBgngDt", this.dsDisciDetail.getColumn(0, "disciYmd") + this.dsTmList.getColumn(i, "disciBgngHh") + this.dsTmList.getColumn(i, "disciBgngMi"));
		this.dsTmList.setColumn(i, "disciEndDt", this.dsDisciDetail.getColumn(0, "disciYmd") + this.dsTmList.getColumn(i, "disciEndHh") + this.dsTmList.getColumn(i, "disciEndMi"));
	}
};

/**
 * 훈련시간 삭제 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		   - [string]ClickEventInfo
 * @return : N/A
 */
this.divBscInfo_btnDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var rowList = this.dsTmList.extractRows('_chk == 1');
	if (rowList == -1 || rowList.length == 0){
		this.smfAlert('CM012', [], this.fnMessageCallback); // 삭제할 자료를 먼저 선택하여 주십시오.
		return;
	}
	for(var i = rowList.length-1; i > -1; i--){
		this.dsTmList.deleteRow(rowList[i]);
	}
};

/**
 * 저장(수정) 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		   - [string]ClickEventInfo
 * @return : N/A
 */
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (this.pv_params.procType == 'search'){
		this.pv_params.procType = 'update';
		this.fnSetBtnStaticSc();
		this.fnSetInit();
	}else{
		if (this.dsArStdntList.rowcount == 0){
			this.smfAlert('PA003', ["선수명단 자료가"], this.fnMessageCallback); // {0} 없습니다.
			return;
		}
		
		if (this.dsTmList.rowcount == 0){
			this.smfAlert('PA003', ["훈련시간 자료가"], this.fnMessageCallback); // {0} 없습니다.
			return;
		}
		
		if (this.smfIsNull(this.dsDisciDetail.getColumn(0, 'disciPlaceNm'))){
			this.smfAlert('PA003', ["훈련장소가"], this.fnMessageCallback); // {0} 없습니다.
			return;
		}
		
		if (this.smfIsNull(this.dsDisciDetail.getColumn(0, 'disciCn'))){
			this.smfAlert('PA003', ["훈련내용이"], this.fnMessageCallback); // {0} 없습니다.
			return;
		}

		this.pv_params.procType == 'insert' ? this.dsSearch.setColumn(0, 'trnCd', 'I') : this.dsSearch.setColumn(0, 'trnCd', 'U');
		if (this.dsDisciDetail.getColumn(0, 'fileUpdateYn1') == 'N' && this.dsDisciDetail.getColumn(0, 'fileUpdateYn2') == 'N'
		 && this.dsDisciDetail.getColumn(0, 'fileUpdateYn3') == 'N' && this.dsDisciDetail.getColumn(0, 'fileUpdateYn4') == 'N'
		 && this.dsDisciDetail.getColumn(0, 'fileUpdateYn5') == 'N'){
			this.fnSave();
		}else{
			this.divFileUpload.form.fnFileUpload();
		}
	}
};

/**
 * 취소 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		   - [string]ClickEventInfo
 * @return : N/A
 */
this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.pv_params.procType = 'search';
	this.fnSearchSelect();
};

/**
 * 닫기 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		   - [string]ClickEventInfo
 * @return : N/A
 */
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};

/**
 * 선수명단 데이터셋 컬럼 값 변경 시
 * @param  : obj		   - [object]NormalDataset
 * @param  : e		       - [string]DSColChangeEventInfo
 * @return : N/A
 */
this.dsArStdntList_oncolumnchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	if (e.columnid == 'partiYn'){
		this.fnSetPheAtndNmprCnt();
		if (e.newvalue == 1){
			obj.setColumn(e.row, 'nadcRsnCn', null);
		}
	}
};

/**
 * 훈련시간 데이터셋 컬럼 값 변경 시
 * @param  : obj		   - [object]NormalDataset
 * @param  : e		   - [string]DSColChangeEventInfo
 * @return : N/A
 */
this.dsTmList_oncolumnchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	var disciBgngDt = (obj.getColumn(e.row, "disciYmd") || this.dsSearch.getColumn(0, 'disciYmd')) + obj.getColumn(e.row, "disciBgngHh") + obj.getColumn(e.row, "disciBgngMi") + '00';
	var disciEndDt = (obj.getColumn(e.row, "disciYmd") || this.dsSearch.getColumn(0, 'disciYmd')) + obj.getColumn(e.row, "disciEndHh") + obj.getColumn(e.row, "disciEndMi") + '00';

	obj.setColumn(e.row, "totlHr", this.fnTotlHrSet(disciBgngDt.dateFormat('yyyy-MM-dd-hh:mm:ss'), disciEndDt.dateFormat('yyyy-MM-dd-hh:mm:ss')));
};

/**
 * 훈련시간 데이터셋 로딩이 완료 시
 * @param  : obj		   - [object]NormalDataset
 * @param  : e		   - [string]DSLoadEventInfo
 * @return : N/A
 */
this.dsTmList_onload = function(obj:nexacro.NormalDataset,e:nexacro.DSLoadEventInfo)
{
	obj.set_updatecontrol(false);
 	for(var i = 0; i < obj.rowcount; i++){
 		obj.setColumn(i, "totlHr", this.fnTotlHrSet(obj.getColumn(i, "disciBgngDt"), obj.getColumn(i, "disciEndDt")));
 	}
	obj.set_updatecontrol(true);
}

/**
 * 파일 선택 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.divBscInfo_divUpload_btnFileSelect_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divFileUpload._divFormObj   = obj.parent;
	this.divFileUpload._FileGbnValue = obj.parent._FileGbnValue;
	this.divFileUpload.form.fnAddFile();
};

/**
 * 파일 삭제 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.divBscInfo_btnDeleteFile_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objDiv = obj.parent[obj._divUploadObj];
	var sFileGbnValueOrg = objDiv._FileGbnValue;
	
	if(this.smfIsNull(sFileGbnValueOrg)) {
		this.smfAlert('CM012', [], this.fnMessageCallback); // 삭제할 자료를 먼저 선택하여 주십시오.
	}else{
		// 2022-12-23 삭제처리가 실패시(유저의 취소 포함) 삭제를 피하기 위해 내부에서 삭제하도록 변경
		this.divFileUpload.form.fnDeleteFileFromFileGbnValue(sFileGbnValueOrg, objDiv);
	}
	
	for(var i = 0; i<this.dsOutFileinfo.rowcount; i++){
		if(this.dsOutFileinfo.getColumn(i, 'atchFileNm') == sFileGbnValueOrg){
			this.dsOutFileinfo.deleteRow(i);
		}
	}
	
	if (this.dsOutFileinfo.rowcount == 0 || this.dsOutFileinfo.findRow('useYn', '') == -1){
		this.dsDisciDetail.setColumn(0, "fileRefrnId", null);
	}
	
	var num = +objDiv.id.substr(10) + 1;
	this.dsDisciDetail.setColumn(0, 'fileUpdateYn' + num, 'Y');
};

/**
 * 파일 다운로드 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.ButtonDownload_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objDiv = obj.parent[obj._divUploadObj];
	var sFileGbnValueOrg = objDiv._FileGbnValue;
	var sFileRefrnId     = objDiv._FileRefrnId;

	if((!this.smfIsNull(sFileGbnValueOrg)) && (!this.smfIsNull(sFileRefrnId))) {
		var nIndex = this.divFileUpload.form.fnGetMatchFileIndex(sFileGbnValueOrg);
		this.divFileUpload.form.fnDownloadByIndex(nIndex);
	}else{
		this.smfAlert('PA065', ["자료가 존재하지 "], this.fnMessageCallback); // {0}않습니다.
	}
};

/**
 * 캘랜더 날짜가 변경 시
 * @param  : obj		   - [object]Calendar
 * @param  : e		       - [string]ChangeEventInfo
 * @return : N/A
 */
this.divBscInfo_calDisciYmd_onchanged = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{
	this.dsDisciDetail.setColumn(0, 'searchYm', obj.value);
};
]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
