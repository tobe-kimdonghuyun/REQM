    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    체육인력서비스 > 운동부 지도자 수정
*  @FileName 	phe_pheam33_m00.xfdl 
*  @Creator 	김민성
*  @CreateDate 	2022.10.04
*  @Desction    운동부 지도자 수정화면
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.10.04            김민성                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
var fv_shlCd;
var fv_cddcCd;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);

	//임시 학교코드 셋팅
	//const fv_shlCd = this.smfSubSysCode();
	fv_cddcCd = this.smfGetCddcCode();
	fv_shlCd = 'K100000783';
	
	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
		url : "/phe_phe_am33_000.do",
		})
		.mappingRulesetToForm(this.divBscInfo, "save")
		.callback(function(callbackParams) {
		})
		.run()
	;

	// 공통코드의 코드구분
	this.smfCodeList("code", [this.dsLedrAahrScCd])
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		})
	;
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
};

/**
 * 도로명 주소찾기 팝업 콜백
 * @param : e
 * @return : sender
 */
this.fnCommpopRdnZip = function(e, sender){
	this.divBscInfo.form.edtPostNo.set_value(e.row.newPostNo);
	this.divBscInfo.form.edtAddr.set_value(e.row.roadNmAddr);
	this.divBscInfo.form.edtAddrDtl.set_value(e.row.roadNmDtl);
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 저장 서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSave = function()
{
	this.smfSaveService("save")
		// (권장) 데이터 존재 필수
		.requireExistsData(this.dsMain)
		// 데이터 변경 필수
		.requireModifredData(this.dsMain)
		// 데이터 검증
		.validateForm(this.divBscInfo)
		// (필수) 실행
		.run()
		// (필수) 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.smfAlert('CM002', [], this.fnMessageCallback); // 저장이 완료되었습니다.
		})
	;
}
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * 전화번호 분리 및 합체
* @param  : sc		    - 분리(spe)인지 합체(cnnc)인지 구분
* @return : N/A
 */
this.fnTelNumSpeCnnc = function(sc){
	var frm = this.divBscInfo.form;
	var separator = '-'
	
	if (sc == 'spe'){
		var mblTelList = this.smfExpressionToList(this.dsMain.getColumn(0, 'asstnCochMblTelno'), separator);
		var telList = this.smfExpressionToList(this.dsMain.getColumn(0, 'asstnCochTelno'), separator);
		
		frm.edtMblTelno1.set_value(mblTelList[0]);
		frm.edtMblTelno2.set_value(mblTelList[1]);
		frm.edtMblTelno3.set_value(mblTelList[2]);
		
		frm.edtTelno1.set_value(telList[0]);
		frm.edtTelno2.set_value(telList[1]);
		frm.edtTelno3.set_value(telList[2]);
		
	}else{
		var telNo = frm.edtTelno1.value + separator + frm.edtTelno2.value + separator + frm.edtTelno3.value;
		var MbltelNo = frm.edtMblTelno1.value + separator + frm.edtMblTelno2.value + separator + frm.edtMblTelno3.value;
		this.dsMain.setColumn(0, "asstnCochTelno", telNo);
		this.dsMain.setColumn(0, "asstnCochMblTelno", MbltelNo);
	}
	
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 저장 버튼 클릭 시
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnTelNumSpeCnnc('cnnc');
	this.fnSave();
};

/**
 * 목록 버튼 클릭 시
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
this.btnReturn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.parent.parent.fnDivShowSet(false);
};


/**
 * 주소찾기 버튼 클릭 시
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
this.divBscInfo_btnAddrSrch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var popupParams = {
		callback: this.fnCommpopRdnZip, // 콜백함수 지정
		sender: obj, // sender 지정

		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: 'search'
		},
	};

	// 모달팝업 실행
	this.smfDialog("_auto", "commpop::commpop_rdn_zip.xfdl", popupParams);
};]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
