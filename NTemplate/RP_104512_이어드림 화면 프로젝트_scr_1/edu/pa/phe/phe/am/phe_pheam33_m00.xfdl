          <Column id="userDfnCd4Value" type="STRING" size="100"/>
          <Column id="userDfnCd5Value" type="STRING" size="100"/>
          <Column id="chk" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.cboItem" propid="value" datasetid="dsSearch" columnid="itemCd"/>
      <BindItem id="item1" compid="divSearch.form.cboAsort" propid="value" datasetid="dsSearch" columnid="asortCd"/>
      <BindItem id="item2" compid="divSearch.form.cboLedrDism" propid="value" datasetid="dsSearch" columnid="ledrDismScCd"/>
      <BindItem id="item3" compid="divSearch.form.cboAprvYn" propid="value" datasetid="dsSearch" columnid="pheDmndAprvCd"/>
      <BindItem id="item4" compid="divSearch.form.cboAahr" propid="value" datasetid="dsSearch" columnid="leadrAahrScCd"/>
      <BindItem id="item5" compid="divSearch.form.edtNm" propid="value" datasetid="dsSearch" columnid="nm"/>
    </Bind>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    체육인력서비스 > 운동부 지도자 관리화면
*  @FileName 	phe_pheam33_m00.xfdl 
*  @Creator 	김민성
*  @CreateDate 	2022.10.04
*  @Desction    운동부 지도자 관리화면
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.10.04            김민성                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
var fv_shlCd;
var fv_cddcCd;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);

	//임시 학교코드 셋팅
	//var fv_shlCd = this.smfSubSysCode();
	fv_cddcCd = this.smfGetCddcCode();
	fv_shlCd = 'K100000783';
	this.dsSearch.setColumn(0, "shlCd", fv_shlCd);
	
	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
		url : "/phe_phe_am33_000.do",
		})
		.mappingRulesetToForm(this.divSearch, "search")
		.callback(function(callbackParams) {
		})
		.run()
	;

	// 공통코드의 코드구분
	this.smfCodeList("code", [this.dsAsortCd, this.dsItemCd, this.dsLedrDismScCd, this.dsLedrAahrScCd, this.dsPheDmndAprvCd])
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		})
	;
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
}
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchList = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("list")
		// 데이터가 변경되었으면 확인메시지
		//.confirmIfModifiedGrid(this.grdPaging)
		// 데이터 검증
		.validateForm(this.divSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});
};

/**
 * 요청 서비스
 * @param : N/A
 * @param : N/A
 */
this.fnTrancseResult = function()
{
	this.smfExecuteService("execute")
		// 메시지 prefix 지정
		.messagePrefix("요청")
		// 데이터 변경 필수
		.requireModifredData(this.dsMain)
		// (필수) 실행
		.run() 
		// (필수) 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.smfAlert('CM201', ["요청"], this.fnMessageCallback);
		})
	;
}
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 /**
 * 수정화면(DIV) 제어
 * @param : statusValue - 수정화면 보여주기(true), 숨기기(false)
 * @param : N/A
 */
this.fnDivShowSet = function(statusValue){
	if (statusValue){
		this.divTitle.form.imgTitle.set_text(this.div00.form.titletext);
	}else{
		this.divTitle.form.imgTitle.set_text(this.titletext);
	}
	this.div00.set_visible(statusValue);
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 조회 버튼 클릭 시
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearchList();
};

/**
 * 변경요청 버튼 클릭 시
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
this.btnDmnd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 나중에 API에서 어떻게 처리할지 변경요청
};

/**
 * 그리드 성명 클릭 시
* @param  : obj		   - [object]Grid
* @param  : e		   - [string]GridClickEventInfo
* @return : N/A
 */
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if (e.col == 4){
		this.div00.form.dsMain.copyRow(0, this.dsMain, e.row);
		this.div00.form.fnTelNumSpeCnnc('spe');
		this.fnDivShowSet(true);
	}
};
]]></Script>
  </Form>
</FDL>
