    <Layouts>
      <Layout height="913" width="1340" screenid="desktopScr">
        <Static id="Static00" taborder="0" text="서비스소개" left="20" top="0" height="95" cssclass="sta_WF_Title" accessibilityrole="heading" right="0"/>
        <Static id="Static00_00" taborder="1" text="학부모 소통서비스 “이어드림”은 " left="20" top="105" height="43" cssclass="sta_WF_Txt36M" accessibilityrole="heading" right="0" letterSpacing="-1px"/>
        <Static id="Static00_00_00" taborder="2" text="‘귀 귀울여듣다(Ear)’와 ‘소통으로 희망을 드리다(Dream)’ 의미를 담아&#13;&#10;학부모가 학교 선생님 및 교직원과 &lt;fc v='#21409A'&gt;상담할 수 있도록 돕는 예약서비스&lt;/fc&gt;입니다. &#13;&#10;상담을 예약 하기 전, 반드시 &lt;fs v='18'&gt;&lt;b v='true'&gt;나이스 학부모 서비스에 가입&lt;/b&gt;&lt;/fs&gt;하고 &lt;fs v='18'&gt;&lt;b v='true'&gt;자녀를 등록&lt;/b&gt;&lt;/fs&gt;한 후 이용하여 주시기 바랍니다. " left="20" top="Static00_00:28" height="120" cssclass="sta_WF_Txt20M32L,sta_WF_Col333" accessibilityrole="heading" right="0" fittocontents="height" letterSpacing="-1px" usedecorate="true"/>
        <ImageViewer id="ImageViewer00" taborder="3" left="20" top="453" width="360" height="461" image="url('theme::neisScr/images/sta_MF_IntroImg07.svg')" stretch="fixaspectratio" imagealign="left bottom" accessibilityenable="false"/>
        <ImageViewer id="ImageViewer00_00" taborder="4" top="361" width="321" height="227" image="url('theme::neisScr/images/sta_MF_IntroImg08.svg')" stretch="fixaspectratio" imagealign="right top" right="0" accessibilityenable="false"/>
