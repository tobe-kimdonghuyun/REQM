    <Script type="xscript5.1"><![CDATA[/**
*  학부모소통시스템 
*  @MenuPath    공통
*  @FileName 	scr_mricl01_m01.xfdl
*  @Creator 	tobesoft
*  @CreateDate 	2025.04.02
*  @Desction    상시상담신청상세
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2025.04.02     	psj 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::scr_script.xjs";
this.paramDsList;	// 모바일에서 파라메터로 넘길 조회결과
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.scrInitForm(obj);	//필수(화면초기화)

	var pv_params = this.smfGetFormParams();	// 이전창의 Parameter 가져오기

	// 전달받은 파라메터 설정
	this.dsDscsnListParam.loadJSON(pv_params.dsDscsnListParam);
	this.dsPageInfo.loadJSON(pv_params.dsPageInfo);
	
	this.dsListParam = pv_params.dsListParam;
	
	this.selectDscsnDtl(pv_params);	// 집중상세내역 조회
};

this.btnListPage_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var dsDscsnListParam = this.dsDscsnListParam.saveJSON();
	var dsPageInfo = this.dsPageInfo.saveJSON();

	var params = {
		menu : "3020"
		,_url : "pa_scr_mri_cl::scr_mricl01_m00.xfdl"
		, dsDscsnParam : dsDscsnListParam
		, dsPageInfo : dsPageInfo
		, listFlag : "Y"
		, dsListParam : this.dsListParam
	};
	this.smfSetWorkPage(params._url, params, null, null);
};

this.btnRsvtCancle_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//확인메시지
	this.scrConfirm("PA060", ["예약취소"], function (result){
		if(result.confirmResult){
			this.saveDscsnCancle();
		}
	});
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 this.selectDscsnDtl = function(obj, e){
 
	this.dsDscsnParam.addRow()
	this.dsDscsnParam.setColumn(0, "schpaDscsnDtcNo", obj.schpaDscsnDtcNo);
	this.dsDscsnParam.setColumn(0, "schpaDscsnMmntScCd", "02");
	
	// 서비스 객체 생성
	this.smfSearchService("selectDscsnDtl")	
		.showConfirm(false)
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;	
			this.resetScroll(); // 줄바꿈이 일어나는 부분 안짤리게 조치
			this.fnDataFormatting();
			
			trace("상담번호 : " + this.dsDscsn.getColumn(0, "schpaDscsnDtcNo"));
			
			if(this.dsDscsn.getColumn(0, "dscsnRsvtPrgStsCd") == "60" || this.dsDscsn.getColumn(0, "dscsnRsvtPrgStsCd") == "50" ){
				this.btnRsvtCancle.set_visible(false);
			}else {
				this.btnRsvtCancle.set_visible(true);
			}
			
			//예약 확정일시가 지난 시점에선 예약취소 불가
			var today = new Date();
			var year = today.getFullYear();
			var month = today.getMonth() + 1;
			var date = today.getDate();
			var hours = today.getHours();
			var min = today.getMinutes();
			var todayDt = year + (month < 10 ? "0" + month : month) + (date < 10 ? "0" + date : date) + (hours < 10 ? "0" + hours : hours) + (min < 10 ? "0" + min : min);
			
			var dscsnDt = this.divMain.form.staDscsnDt.text;
			dscsnDt = nexacro.replaceAll(nexacro.replaceAll(nexacro.replaceAll(nexacro.replaceAll(dscsnDt, "~", ""),":", ""),".", "")," ", "");
			dscsnDt = dscsnDt.substr(0, 12);
			
			if(dscsnDt < todayDt){
				this.btnRsvtCancle.set_visible(false);
			}
			
			// 취소 사유 추가
			if(this.dsDscsn.getColumn(0, "dscsnRsvtPrgStsCd") == "60" && this.dsDscsn.getColumn(0, "prgPrcsRsnCn") != null){
				this.divMain.form.staPrgStsCd.set_text("취소(담당자)");
			}
			this.smfInitForm(this);
		});	

}


 this.saveDscsnCancle = function(obj, e){
 
	// 서비스 객체 생성
	this.smfSaveService("saveDscsnCancle")	
		.showConfirm(false)
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;	
			this.scrAlert("PA072", ["예약취소"], function (result){ // PA072 ::: {0}이 완료되었습니다.
				var schpaDscsnDtcNo = this.dsDscsn.getColumn(0, "schpaDscsnDtcNo")
				var params = {menu : "3010",_url : "pa_scr_mri_cl::scr_mricl01_m00.xfdl"};
				this.smfSetWorkPage(params._url, params, null, null);
			});
		});	
}
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 // 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 
 // 포맷팅이 필요한 항목에 대해 각각 포맷팅 한뒤 해당 컴포넌트에 넣어준다.
 this.fnDataFormatting = function()
 {
	// 예약확정일시 
	var dscsnDmndYmd = this.dsDscsn.getColumn(0, "dscsnDmndYmd");
	var dscsnDmndHm = this.dsDscsn.getColumn(0, "dscsnDmndHm");
	var dscsnDmndEndParngHm = this.dsDscsn.getColumn(0, "dscsnDmndEndParngHm");
	
	var fmtDscsnDmndDtStr = "";
	
	if(dscsnDmndYmd != null){
		var fmtDscsnDmndYmd = dscsnDmndYmd.substr(0, 4) + "." + dscsnDmndYmd.substr(4, 2) + "." + dscsnDmndYmd.substr(6, 2)
		var fmtDscsnDmndHm = dscsnDmndHm.substr(0, 2) + ":" + dscsnDmndHm.substr(2, 2);
		var fmtDscsnDmndEndParngHm = dscsnDmndEndParngHm.substr(0, 2) + ":" + dscsnDmndEndParngHm.substr(2, 2);
		fmtDscsnDmndDtStr = fmtDscsnDmndYmd + " " + fmtDscsnDmndHm + "~" + fmtDscsnDmndEndParngHm;	
	}
	
	// 처리상태
	var dscsnRsvtPrgStsCd = this.dsDscsn.getColumn(0, "dscsnRsvtPrgStsCd");
	var dscsnRsvtPrgStsNm = "";
	if(dscsnRsvtPrgStsCd == "10"){
		dscsnRsvtPrgStsNm = "저장";
	}else if(dscsnRsvtPrgStsCd == "20"){
		dscsnRsvtPrgStsNm = "신청";
	}else if(dscsnRsvtPrgStsCd == "30"){
		dscsnRsvtPrgStsNm = "확인완료";
	}else if(dscsnRsvtPrgStsCd == "40"){
		dscsnRsvtPrgStsNm = "확정";
	}else if(dscsnRsvtPrgStsCd == "50"){
		dscsnRsvtPrgStsNm = "완료";
	}else if(dscsnRsvtPrgStsCd == "60"){
		dscsnRsvtPrgStsNm = "취소";
	}
 
	// 상담방법
 	var dscsnDmndMthCd = this.dsDscsn.getColumn(0, "dscsnDmndMthCd");
	var dscsnDmndMthNm = "";
	if(dscsnDmndMthCd == "01"){
		dscsnDmndMthNm = "대면";
	}else if(dscsnDmndMthCd == "02"){
		dscsnDmndMthNm = "유선";
	}
	
	// 컴포넌트에 값 넣기
	this.divMain.form.staDscsnDt.set_text(fmtDscsnDmndDtStr);
	this.divMain.form.staPrgStsCd.set_text(dscsnRsvtPrgStsNm);
	this.divMain.form.staDscsnMth.set_text(dscsnDmndMthNm);
 }
 
 
 
 
 
 ]]></Script>
  </Form>
</FDL>
