                <Cell col="6" text="진행상태"/>
              </Band>
              <Band id="body">
                <Cell text="bind:rownum" displaytype="text"/>
                <Cell col="1" cssclass="cell_WF_TxtLink" accessibilitydescription="새창열기" displaytype="buttoncontrol" edittype="button" accessibilityrole="button" tooltiptext="bind:dscsnAplyTitlNm" expr="comp.parent.fnDisplayText(comp,0,currow,dscsnAplyTitlNm) "/>
                <Cell col="2" text="bind:dscsnDmndThtsFlnm" displaytype="text"/>
                <Cell col="3" text="bind:dscsnAplyDt" displaytype="mask" calendareditformat="yyyy.MM.dd" calendardateformat="yyyy.MM.dd" maskeditformat="####.##.## ##:##" maskedittype="string" cssclass="cell_WF_TxtC"/>
                <Cell col="4" text="expr:dscsnDmndYmd != null ? dataset.parent.fnYmdFormatting(dscsnDmndYmd) + &quot; &quot; +  dataset.parent.fnHrFormatting(dscsnDmndHm) + &quot;~&quot; + dataset.parent.fnHrFormatting(dscsnDmndEndParngHm) : &quot;-&quot;" displaytype="text" calendardateformat="yyyy.MM.dd" calendareditformat="yyyy.MM.dd" maskeditformat="####.##.## ##:##" maskedittype="string" cssclass="cell_WF_TxtC"/>
                <Cell col="5" text="bind:dscsnDmndMthCd" displaytype="combotext" combodataset="dsDscsnMthCdList" combocodecol="value" combodatacol="label"/>
                <Cell col="6" text="bind:dscsnRsvtPrgStsCd" displaytype="combotext" cssclass="EXPR(dscsnRsvtPrgStsCd=='40'?&quot;cell_WF_IngCancle&quot;:dscsnRsvtPrgStsCd=='30'?&quot;cell_WF_IngOk&quot;:dscsnRsvtPrgStsCd=='20'?&quot;cell_WF_IngReceipt&quot;:dscsnRsvtPrgStsCd=='10'?&quot;cell_WF_IngApply&quot;:&quot;&quot;)" combodataset="dsDscsnRsvtPrgStsCdList" combocodecol="value" combodatacol="label"/>
              </Band>
            </Format>
            <Format id="format00">
              <Columns>
                <Column size="12" band="left"/>
                <Column size="136"/>
                <Column size="70"/>
                <Column size="100"/>
                <Column size="100"/>
