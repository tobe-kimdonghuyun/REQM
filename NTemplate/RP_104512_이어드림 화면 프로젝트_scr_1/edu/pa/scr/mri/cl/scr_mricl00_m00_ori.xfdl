    <Script type="xscript5.1"><![CDATA[/**
*  학부모소통시스템 
*  @MenuPath    공통
*  @FileName 	scr_mricl00_m00.xfdl
*  @Creator 	tobesoft
*  @CreateDate 	2025.03.17
*  @Desction    상시상담신청목록조회
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2025.03.17     	tobesoft 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::scr_script.xjs";
this.objApp = nexacro.getApplication();
this.paramDsList;	// 모바일에서 파라메터로 넘길 조회결과
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/


/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.scrInitForm(obj);	//필수(화면초기화)
	this.fnSearchFormDateInit();	// 날짜 조건 설정
	
	var pv_params = this.smfGetFormParams();	// 이전창의 Parameter 가져오기
	
	if(pv_params.listFlag == "Y"){
		// 전달받은 파라메터 설정
		this.dsDscsnParam.loadJSON(pv_params.dsDscsnParam);
		this.dsPageInfo.loadJSON(pv_params.dsPageInfo);
		
		if(this.dsPageInfo.getConstColIndex("initIsUsePageInfo") < 0){
			this.dsPageInfo.addConstColumn("initIsUsePageInfo","Y");
		} else {
			this.dsPageInfo.setConstColumn("initIsUsePageInfo","Y");
		}
		// 목록 개수 자동으로 처리 안되서 수동 SET
		this.divPageSummary.form.fnSetInitPageSize(this.dsPageInfo.getColumn("0","pageSize"));
		
		this.divSearch.form.calFromDt.set_value(this.dsDscsnParam.getColumn(0, "bgngYmd"));
		this.divSearch.form.calToDt.set_value(this.dsDscsnParam.getColumn(0, "endYmd"));
		this.divSearch.form.editTiltNm.set_value(this.dsDscsnParam.getColumn(0, "dscsnAplyTitlNm"));
		this.fnSearchFormSetPrgStsCd(this.dsDscsnParam.getColumn(0, "dscsnRsvtPrgStsCd"));
		
		// 모달팝업 실행
		if ( this.objApp.gv_appScreenType == "M" ) {
			// 모바일일 경우 검색결과 유지
			this.dsDscsnListMobile.loadXML(pv_params.dsListParam);
			this.smfDataAppend(this, this.grdMain, this.dsDscsnListMobile);
			
			this.divPaginator.form.fnInit(this.grdMain, this.dsPageInfo, this.divPageSummary, this.selectDscsnList, this);
 			this.divPageSummary.form.fnInit(this.grdMain, this.dsPageInfo, this.divPageSummary, this.selectDscsnList, this);
			
			this.fnResetScreenHeight(this.grdMain);
		}else {
			this.divSearch.form.btnSearch.click();//화면진입시 검색 실행
		}
	}else{
		this.divSearch.form.btnSearch.click();//화면진입시 검색 실행
	}
};


this.btnSearch_onclick= function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var dscsnRsvtPrgStsCd = this.fnSearchFormGetPrgStsCd();
	var bgngYmd = this.divSearch.form.calFromDt.value;
	var endYmd = this.divSearch.form.calToDt.value;
	var dscsnAplyTitlNm = this.divSearch.form.editTiltNm.value;
	
	dscsnRsvtPrgStsCd = this.smfReplace(dscsnRsvtPrgStsCd, " ", "");
	
	this.dsDscsnParam.addRow();
	this.dsDscsnParam.setColumn(0, 'bgngYmd', bgngYmd);
	this.dsDscsnParam.setColumn(0, 'endYmd', endYmd);
	this.dsDscsnParam.setColumn(0, 'dscsnRsvtPrgStsCd', dscsnRsvtPrgStsCd);
	this.dsDscsnParam.setColumn(0, 'dscsnAplyTitlNm', dscsnAplyTitlNm);
	this.dsDscsnParam.setColumn(0, 'schpaDscsnMmntScCd', '01');
	
	// self Validation
	if(bgngYmd > endYmd) {
		this.scrAlert("CM000", ["신청일자의 종료일자는 시작일자보다 크거나 같아야합니다"], function (result){ // CM000 ::: {0}
		});
		return false;
	}
	
	this.selectDscsnList(obj,e);
}

this.fngrdCellClick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if(this.objApp.gv_appScreenType != "M"){
		if(e.cell != 1){
			return false;
		}
	}

	var schpaDscsnDtcNo = this.dsDscsnList.getColumn(e.row, "schpaDscsnDtcNo")

	var params = {
		menu : "3011"
		,_url : "pa_scr_mri_cl::scr_mricl00_m01.xfdl"
		, schpaDscsnDtcNo : schpaDscsnDtcNo
		, dsDscsnListParam : this.dsDscsnParam.saveJSON()
		, dsPageInfo : this.dsPageInfo.saveJSON()
		, dsListParam : this.dsDscsnList.saveXML()
	};
	
	this.smfSetWorkPage(params._url, params, null, String(obj.text));
};

this.btnAplyDscsn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var params = {
		menu : "2010"
		, _url : "pa_scr_ctr_cr::scr_ctrcr00_m00.xfdl"
		, beforePageCd : "SP" // 메인화면 : MP , 목록화면 : SP
		, dsDscsnListParam : this.dsDscsnParam.saveJSON()
		, dsPageInfo : this.dsPageInfo.saveJSON()
	};
	this.smfSetWorkPage(params._url, params, null, String(obj.text));
};

// 진행상태 [전체] 클릭 이벤트
this.checkBoxPrgSts01_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	if(obj.isChecked()){
		this.divSearch.form.checkBoxPrgSts02.set_value(true);
		this.divSearch.form.checkBoxPrgSts03.set_value(true);
		this.divSearch.form.checkBoxPrgSts04.set_value(true);
		this.divSearch.form.checkBoxPrgSts05.set_value(true);
		this.divSearch.form.checkBoxPrgSts06.set_value(true);
	}else{
		this.divSearch.form.checkBoxPrgSts02.set_value(false);
		this.divSearch.form.checkBoxPrgSts03.set_value(false);
		this.divSearch.form.checkBoxPrgSts04.set_value(false);
		this.divSearch.form.checkBoxPrgSts05.set_value(false);
		this.divSearch.form.checkBoxPrgSts06.set_value(false);
	}
	//this.smfInitDiv(this.divSearch);
};

// 진행상태 [신청, 확정, 완료, 취소] 클릭 이벤트
this.checkBox_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	if(!obj.isChecked()){
		this.divSearch.form.checkBoxPrgSts01.set_value(false);
	}else if(
		this.divSearch.form.checkBoxPrgSts02.isChecked() && 
		this.divSearch.form.checkBoxPrgSts03.isChecked() &&
		this.divSearch.form.checkBoxPrgSts04.isChecked() &&
		this.divSearch.form.checkBoxPrgSts05.isChecked() &&
		this.divSearch.form.checkBoxPrgSts06.isChecked() 
	){
		this.divSearch.form.checkBoxPrgSts01.set_value(true);
	}
	//this.smfInitDiv(this.divSearch);
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 this.selectDscsnList = function(obj, e){
	// 서비스 객체 생성
	this.smfSearchService("listDscsn")
		.paginator(this.grdMain, this.divPaginator, this.divPageSummary, this.dsPageInfo, obj, e)
		.showConfirm(false)
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.fnResetScreenHeight(this.grdMain);
			//this.smfInitForm(this);
		});	
}

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 this.fnDisplayText = function(obj,nCell,nRow,sLongText)
{	
//	trace("=============================================================================================================");
//	trace("obj.get_id() ::: " + obj.id );
//	trace("sLongText ::: " + sLongText );
//	trace("sLongText.length ::: " + sLongText.length );
//	trace("=============================================================================================================");

	var objId = obj.id;
	var sSize;

	if ( this.objApp.gv_appScreenType == "M" ) { // 모바일
			sSize = 20;		
	}else if ( this.objApp.gv_appScreenType == "T" ) { // 태블릿
			sSize = 25;	
	}else {
			sSize = 25;	
	}		

	return this.scrDisplayText(sLongText, sSize);
};
 
 
 // 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
	var pageIndex = this.dsPageInfo.getColumn(0,"pageIndex");
	var pageSize = this.dsPageInfo.getColumn(0,"pageSize");
	var totalCount = this.dsPageInfo.getColumn(0,"totalCount");
	var lastPage = Math.ceil(totalCount / pageSize);
	
	// 더보기 숨김
	if(this.dsDscsnList.getRowCount() == 0 || lastPage == pageIndex){
		this.btnViewMore.set_visible(false);
	}else{
		this.btnViewMore.set_visible(true);
	}
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

// 검색조건에 오늘날짜를 설정한다.
this.fnSearchFormDateInit = function()
{
	var sToday = this.smfToday();	//오늘 날짜
	eDay = this.smfAddDate(sToday, -30);
	
	var sToday1 = this.smfSubStr(sToday, 0, 4)
	var sToday2 = this.smfSubStr(sToday, 4, 6)
	var sToday3 = this.smfSubStr(sToday, 6, 8)

	var eDay1 = this.smfSubStr(eDay, 0, 4)
	var eDay2 = this.smfSubStr(eDay, 4, 6)
	var eDay3 = this.smfSubStr(eDay, 6, 8)

	this.divSearch.form.calToDt.set_value(sToday1 + "." + sToday2 + "." + sToday3);
	this.divSearch.form.calFromDt.set_value(eDay1 + "." + eDay2 + "." + eDay3);
}

// 현재 체크된 진행상태를 [,] 를 기준으로 문자열로 변환
this.fnSearchFormGetPrgStsCd = function()
{
	var dscsnPrgStsCd = ""; //검색조건용 전역변수 선언

	var dscsnPrgStsCd00 = this.divSearch.form.checkBoxPrgSts01.value;
	var dscsnPrgStsCd01 = this.divSearch.form.checkBoxPrgSts02.value;
	var dscsnPrgStsCd02 = this.divSearch.form.checkBoxPrgSts03.value;
	var dscsnPrgStsCd03 = this.divSearch.form.checkBoxPrgSts04.value;
	var dscsnPrgStsCd04 = this.divSearch.form.checkBoxPrgSts05.value;
	var dscsnPrgStsCd05 = this.divSearch.form.checkBoxPrgSts06.value;
	
	if(dscsnPrgStsCd01) {
		if(this.smfContainsStr(dscsnPrgStsCd, "20")){
			return;
		}else{
			dscsnPrgStsCd += "20, ";
		}
	}
	if(dscsnPrgStsCd02) {
		if(this.smfContainsStr(dscsnPrgStsCd, "30")){
			return;
		}else{
			dscsnPrgStsCd += "30, ";
		}
	}
	if(dscsnPrgStsCd03) {
		if(this.smfContainsStr(dscsnPrgStsCd, "40")){
			return;
		}else{
			dscsnPrgStsCd += "40, ";
		}
	}
	if(dscsnPrgStsCd04) {
		if(this.smfContainsStr(dscsnPrgStsCd, "50")){
			return;
		}else{
			dscsnPrgStsCd += "50, ";
		}
	}
	if(dscsnPrgStsCd05) {
		if(this.smfContainsStr(dscsnPrgStsCd, "60")){
			return;
		}else{
			dscsnPrgStsCd += "60, ";
		}
	}

	// 마지막 , 지우기
	var strDscsnPrgStsCd = dscsnPrgStsCd;

	var commaIndex = strDscsnPrgStsCd.length - 2;
	dscsnPrgStsCd = this.smfSubStr(dscsnPrgStsCd, 0, commaIndex);
	
	return dscsnPrgStsCd;
	
	/*
	if(!dscsnPrgStsCd00){
		this.dsSearch.setColumn(0, "dscsnPrgStsCd", this.dscsnPrgStsCd);
	}
	*/
}

// 현재 체크된 진행상태를 [,] 를 기준으로 입력
this.fnSearchFormSetPrgStsCd = function(dscsnPrgStsCd)
{
	this.divSearch.form.checkBoxPrgSts01.set_value(false);
	this.divSearch.form.checkBoxPrgSts02.set_value(false);
	this.divSearch.form.checkBoxPrgSts03.set_value(false);
	this.divSearch.form.checkBoxPrgSts04.set_value(false);
	this.divSearch.form.checkBoxPrgSts05.set_value(false);
	this.divSearch.form.checkBoxPrgSts06.set_value(false);
	
	var prgStsCdArray = dscsnPrgStsCd.split(",");
	for(idx = 0; idx < prgStsCdArray.length; idx++){
		if(prgStsCdArray.length == 5){
			this.divSearch.form.checkBoxPrgSts01.set_value(true);		
		}

		if(prgStsCdArray[idx] == "20"){
			this.divSearch.form.checkBoxPrgSts02.set_value(true);
		}else if(prgStsCdArray[idx] == "30"){
			this.divSearch.form.checkBoxPrgSts03.set_value(true);			
		}else if(prgStsCdArray[idx] == "40"){
			this.divSearch.form.checkBoxPrgSts04.set_value(true);		
		}else if(prgStsCdArray[idx] == "50"){
			this.divSearch.form.checkBoxPrgSts05.set_value(true);		
		}else if(prgStsCdArray[idx] == "60"){
			this.divSearch.form.checkBoxPrgSts06.set_value(true);		
		}
	}

}

// 시간포맷팅
this.fnHrFormatting = function(paramHrStr)
{
	var hStr = this.smfSubStr(paramHrStr, 0, 2);
	var mStr = this.smfSubStr(paramHrStr, 2, 4);
	return hStr + ":" + mStr;
};

// 날짜포맷팅
this.fnYmdFormatting = function(paramYmdStr)
{
	var yStr = this.smfSubStr(paramYmdStr, 0, 4);
	var mStr = this.smfSubStr(paramYmdStr, 4, 6);
	var dStr = this.smfSubStr(paramYmdStr, 6, 8);
	return yStr + "." + mStr + "." + dStr;
};

// 상담방법명 구하기
this.fnDscsnDmndMthNm = function(dscsnDmndMthCd)
{
	var resultValue = "";
	if(dscsnDmndMthCd == "01"){
		resultValue = "대면";
	}else if(dscsnDmndMthCd == "02"){
		resultValue = "유선";
	}else{
		resultValue = "코드명없음";
	};
	return resultValue;
};

this.fnResetScreenHeight = function(objGrd)
{
	// 그리드 사이즈 변경
	var grdHeight = (objGrd.getRealRowFullSize("body") == null ? 0 : objGrd.getRealRowFullSize("body")  == 0 ? 386 :objGrd.getRealRowFullSize("body"))
					+ (objGrd.getRealRowFullSize("head") == null ? 0 : objGrd.getRealRowFullSize("head"))
					+ (objGrd.getRealRowFullSize("summary") == null ? 0 : objGrd.getRealRowFullSize("summary"))
					+ 2;
	objGrd.setOffsetHeight(grdHeight);
	// divWork(frame영역) 사이즈 계산
	var nFormHeight = this.getOwnerFrame().form.divAll.form.divWork.form.staTitle.getOffsetHeight()
					+ this.grdMain.getOffsetBottom()+50;
	
	// frameAll의 fnAfter_onlayoutchanged에서 divWork 높이 변경하는데 처리 순서가 고르지 않아 일단 여기서 셋팅
	this.getOwnerFrame().form.divAll.form.fv_WorkFormHeight = nFormHeight; 
	
	// divWork(frame영역) 사이즈 변경
	this.getOwnerFrame().form.divAll.form.divWork.setOffsetHeight(nFormHeight);
	
	this.resetScroll();
	this.getOwnerFrame().form.divAll.form.resetScroll();
}

// 진행상태명 구하기
this.fnDscsnPrgStsNm = function(dscsnPrgStsCd)
{
	var resultValue = "";
	if(dscsnPrgStsCd == "01"){
		resultValue = "임시저장";
	}else if(dscsnPrgStsCd == "02"){
		resultValue = "신청";
	}else if(dscsnPrgStsCd == "03"){
		resultValue = "접수";
	}else if(dscsnPrgStsCd == "04"){
		resultValue = "처리중";
	}else if(dscsnPrgStsCd == "05"){
		resultValue = "완료";
	}else if(dscsnPrgStsCd == "06"){
		resultValue = "취소";
	}else{
		resultValue = "코드명없음";
	};
	return resultValue;
};

this.btnViewMore_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 더보기 조회
	this.fnDscsnListMore(obj, e);
};
this.fnDscsnListMore = function(obj, e){
	// 초기값 설정
	var serviceId = "listDscsnMobile";
	
	var dscsnRsvtPrgStsCd = this.fnSearchFormGetPrgStsCd();
	var bgngYmd = this.divSearch.form.calFromDt.value;
	var endYmd = this.divSearch.form.calToDt.value;
	var dscsnAplyTitlNm = this.divSearch.form.editTiltNm.value;
	
	dscsnRsvtPrgStsCd = this.smfReplace(dscsnRsvtPrgStsCd, " ", "");

	this.dsDscsnParam.addRow();
	this.dsDscsnParam.setColumn(0, 'bgngYmd', bgngYmd);
	this.dsDscsnParam.setColumn(0, 'endYmd', endYmd);
	this.dsDscsnParam.setColumn(0, 'dscsnRsvtPrgStsCd', dscsnRsvtPrgStsCd);
	this.dsDscsnParam.setColumn(0, 'dscsnAplyTitlNm', dscsnAplyTitlNm);
	this.dsDscsnParam.setColumn(0, 'schpaDscsnMmntScCd', '01');
	
	// self Validation
	if(bgngYmd > endYmd) {
		this.scrAlert("CM000", ["신청일자의 종료일자는 시작일자보다 크거나 같아야합니다"], function (result){ // CM000 ::: {0}
		});
		return false;
	}
	
	var pageIndex = this.dsPageInfo.getColumn(0,"pageIndex")+1;
	var pageSize = this.dsPageInfo.getColumn(0,"pageSize");
	var totalCount = this.dsPageInfo.getColumn(0,"totalCount");
	var lastPage = Math.ceil(totalCount / pageSize);

	if(lastPage >= pageIndex){
		this.dsPageInfo.setColumn(0,"pageIndex",pageIndex);
	}
	
	//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// 서브밋 시작
	//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// 서비스 객체 생성
	this.smfSearchService(serviceId)
	// 페이징처리
	//.paginator(this, this.divPaginator, this.divPageSummary, this.dsPageInfo, obj, e)
	.showConfirm(false)
	// 실행
	.run()
	// 콜백
	.callback(function(callbackParams){
		if(callbackParams.errors){
			return;
		}
		this.dsDscsnList.appendData(this.dsDscsnListMobile);
		
		// 더보기 숨김
		if(this.dsDscsnList.getRowCount() == 0 || lastPage == pageIndex){
			this.btnViewMore.set_visible(false);
		}else{
			this.btnViewMore.set_visible(true);
		}
	
		//화면높이조정
		this.fnResetScreenHeight(this.grdMain);
		
	});
	//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// 서브밋 종료
	//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
};]]></Script>
  </Form>
</FDL>
