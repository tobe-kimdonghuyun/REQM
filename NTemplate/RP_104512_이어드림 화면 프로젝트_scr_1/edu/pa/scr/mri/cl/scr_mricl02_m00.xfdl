    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  학부모소통시스템 
*  @MenuPath    공통
*  @FileName 	scr_mricl02_m00.xfdl
*  @Creator 	tobesoft
*  @CreateDate 	2025.03.17
*  @Desction    온라인(서면)상담신청목록조회
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2025.03.17     	tobesoft 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::scr_script.xjs";
this.objApp = nexacro.getApplication();
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.scrInitForm(obj);	//필수(화면초기화
	this.fnSearchFormDateInit();
	
	var pv_params = this.smfGetFormParams();	// 이전창의 Parameter 가져오기
	
	
	if(pv_params.listFlag == "Y"&& !(this.smfIsMobile() || this.objApp.gv_appScreenType == "M")){
		// 전달받은 파라메터 설정
	
	
	
		this.dsParam.loadXML(pv_params.dsParam);		
		this.dsPageInfo.loadXML(pv_params.dsPageInfo);
		if(this.dsPageInfo.getConstColIndex("initIsUsePageInfo") < 0){
			this.dsPageInfo.addConstColumn("initIsUsePageInfo","Y");
		} else {
			this.dsPageInfo.setConstColumn("initIsUsePageInfo","Y");
		}
		// 목록 개수 자동으로 처리 안되서 수동 SET
		this.divPageSummary.form.fnSetInitPageSize(this.dsPageInfo.getColumn("0","pageSize"));
		
		this.divSearch.form.calFromValue.set_value(this.dsParam.getColumn(0, "fromValue"));
		this.divSearch.form.calTovalue.set_value(this.dsParam.getColumn(0, "toValue"));
		this.divSearch.form.edtTitle.set_value(this.dsParam.getColumn(0, "dscsnAplyTitlNm"));
		this.fnSearchFormSetPrgStsCd(this.dsParam.getColumn(0, "dscsnPrgStsCd"));
		
		this.divSearch.form.btnSearch.click();
	}else if(pv_params.listFlag == "Y"&& (this.smfIsMobile() || this.objApp.gv_appScreenType == "M")&&pv_params.mainYn != "Y"){
	
	
	
	
			// 전달받은 파라메터 설정
		this.dsParam.loadXML(pv_params.dsParam);		
		this.dsPageInfo.loadXML(pv_params.dsPageInfo);

		this.dsResultMore.loadXML(pv_params.dsResult);
		
		this.divSearch.form.calFromValue.set_value(this.dsParam.getColumn(0, "fromValue"));
		this.divSearch.form.calTovalue.set_value(this.dsParam.getColumn(0, "toValue"));
		this.divSearch.form.edtTitle.set_value(this.dsParam.getColumn(0, "dscsnAplyTitlNm"));
		this.fnSearchFormSetPrgStsCd(this.dsParam.getColumn(0, "dscsnPrgStsCd"));
		
		this.dsResult.appendData(this.dsResultMore);
		var totalCount = this.dsPageInfo.getColumn(0,"totalCount");
		var pageIndex = this.dsPageInfo.getColumn(0,"pageIndex");
		var pageSize = this.dsPageInfo.getColumn(0,"pageSize");
		
	
	
	
		var lastPage = Math.ceil(totalCount / pageSize);
		
		// 더보기 숨김
		if(this.dsResult.getRowCount() == 0 || lastPage == pageIndex){
			this.btnViewMore.set_visible(false);
		}else{
			this.btnViewMore.set_visible(true);
		}
		
		this.divPaginator.form.fnInit(this.grd1, this.dsPageInfo, this.divPageSummary, this.listOtsDscsnAply, this);
		this.divPageSummary.form.fnInit(this.grd1, this.dsPageInfo, this.divPageSummary, this.listOtsDscsnAply, this);	
		
		this.fnResetScreenHeight(this.grd1);
	}else if(pv_params.listFlag == "Y"&& (this.smfIsMobile() || this.objApp.gv_appScreenType == "M")&&pv_params.mainYn=="Y"){
	
			// 전달받은 파라메터 설정
		this.dsParam.loadXML(pv_params.dsParam);		
		this.dsPageInfo.loadXML(pv_params.dsPageInfo);
		this.divSearch.form.calFromValue.set_value(this.dsParam.getColumn(0, "fromValue"));
		this.divSearch.form.calTovalue.set_value(this.dsParam.getColumn(0, "toValue"));
		this.divSearch.form.edtTitle.set_value(this.dsParam.getColumn(0, "dscsnAplyTitlNm"));
		this.fnSearchFormSetPrgStsCd(this.dsParam.getColumn(0, "dscsnPrgStsCd"));
		
		var totalCount = this.dsPageInfo.getColumn(0,"totalCount");
		var pageIndex = this.dsPageInfo.getColumn(0,"pageIndex");
		var pageSize = this.dsPageInfo.getColumn(0,"pageSize");
		
		var lastPage = Math.ceil(totalCount / pageSize);
		
		// 더보기 숨김
		if(this.dsResult.getRowCount() == 0 || lastPage == pageIndex){
			this.btnViewMore.set_visible(false);
		}else{
			this.btnViewMore.set_visible(true);
		}
		
		this.divPaginator.form.fnInit(this.grd1, this.dsPageInfo, this.divPageSummary, this.listOtsDscsnAply, this);
		this.divPageSummary.form.fnInit(this.grd1, this.dsPageInfo, this.divPageSummary, this.listOtsDscsnAply, this);	
		
		this.fnResetScreenHeight(this.grd1);
		
		this.divSearch.form.btnSearch.click();
	}else{
		this.divSearch.form.btnSearch.click();
	}
	
	
};

this.DivSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var dscsnPrgStsCd = this.fnSearchFormGetPrgStsCd();
	var fromValue = this.divSearch.form.calFromValue.value;
	var toValue = this.divSearch.form.calTovalue.value;
	var dscsnAplyTitlNm = this.divSearch.form.edtTitle.value;
	
	dscsnPrgStsCd = this.smfReplace(dscsnPrgStsCd, " ", "");

	// self Validation
	if(fromValue > toValue) {
		this.scrAlert("CM000", ["신청일자의 종료일자는 시작일자보다 크거나 같아야합니다"], function (result){ // CM000 ::: {0}
		});
		return false;
	}
	this.dsParam.setColumn(0, 'fromValue', fromValue);
	this.dsParam.setColumn(0, 'toValue', toValue);
	this.dsParam.setColumn(0, 'dscsnPrgStsCd', dscsnPrgStsCd);
	this.dsParam.setColumn(0, 'dscsnAplyTitlNm', dscsnAplyTitlNm);
	this.dsParam.setColumn(0, 'from', 'INDI');
	this.dsParam.setColumn(0, 'cteOrgCd', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'cteOrgCd'));
	this.dsParam.setColumn(0, 'instCd', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'shlCd'));

	this.listOtsDscsnAply(obj,e);
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 this.listOtsDscsnAply = function(obj, e)
{
	// 서비스 객체 생성
	this.smfSearchService("selectOnlDcmDscscnList")	
		// 데이터 검증
		.validateForm(this.divSearch)
		// 페이징처리
		.paginator(this.grd1, this.divPaginator, this.divPageSummary, this.dsPageInfo, obj, e)
		.showConfirm(false)
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		if(this.dsResult.getRowCount() == 0 ){
			this.dsPageInfo.setColumn(0,"totalCount",0);
			this.divPageSummary.form.fnInit(this.grd1, this.dsPageInfo, this.divPageSummary, this.listOtsDscsnAply, this);
			this.divPaginator.form.fnInit(this.grd1, this.dsPageInfo, this.divPageSummary, this.listOtsDscsnAply, this);
		}
			this.fnResetScreenHeight(this.grd1);
		});	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 // 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
	var pageIndex = this.dsPageInfo.getColumn(0,"pageIndex");
	var pageSize = this.dsPageInfo.getColumn(0,"pageSize");
	var totalCount = this.dsPageInfo.getColumn(0,"totalCount");
	var lastPage = Math.ceil(totalCount / pageSize);

	// 더보기 숨김
	if(this.dsResult.getRowCount() == 0 ||lastPage == pageIndex){
		this.btnViewMore.set_visible(false);
	}else{
		this.btnViewMore.set_visible(true);
	}
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

// 진행상태 [전체] 클릭 이벤트
this.checkBoxPrgSts01_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	if(obj.isChecked()){
		this.divSearch.form.chk01.set_value(true);
		this.divSearch.form.chk02.set_value(true);
		this.divSearch.form.chk03.set_value(true);
		this.divSearch.form.chk04.set_value(true);
		this.divSearch.form.chk05.set_value(true);
		this.divSearch.form.chk06.set_value(true);
	}else{
		this.divSearch.form.chk01.set_value(false);
		this.divSearch.form.chk02.set_value(false);
		this.divSearch.form.chk03.set_value(false);
		this.divSearch.form.chk04.set_value(false);
		this.divSearch.form.chk05.set_value(false);
		this.divSearch.form.chk06.set_value(false);
	}
	//this.smfInitDiv(this.divSearch);
};

// 진행상태 [신청, 확정, 완료, 취소] 클릭 이벤트
this.checkBox_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	if(!obj.isChecked()){
		this.divSearch.form.chk00.set_value(false);
	}else if(
		this.divSearch.form.chk01.isChecked() && 
		this.divSearch.form.chk02.isChecked() &&
		this.divSearch.form.chk03.isChecked() &&
		this.divSearch.form.chk04.isChecked() &&
		this.divSearch.form.chk05.isChecked() &&
		this.divSearch.form.chk06.isChecked()
	){
		this.divSearch.form.chk00.set_value(true);
	}
	//this.smfInitDiv(this.divSearch);
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 /*
this.getDscsnStsCd = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 공통코드의 코드구분
	this.smfCodeList("code", [this.dsDscsnPrgStsCdForList])
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			

		});	

};

*/
this.fnSearchFormDateInit = function()
{
	this.smfInitForm(this);
	var sToday = this.smfToday();	//오늘 날짜
	eDay = this.smfAddDate(sToday, -30);
	
	var sToday1 = this.smfSubStr(sToday, 0, 4)
	var sToday2 = this.smfSubStr(sToday, 4, 6)
	var sToday3 = this.smfSubStr(sToday, 6, 8)

	var eDay1 = this.smfSubStr(eDay, 0, 4)
	var eDay2 = this.smfSubStr(eDay, 4, 6)
	var eDay3 = this.smfSubStr(eDay, 6, 8)
	
	this.divSearch.form.calTovalue.set_value(sToday1 + "." + sToday2 + "." + sToday3);
	this.divSearch.form.calFromValue.set_value(eDay1 + "." + eDay2 + "." + eDay3);
	
	// 페이지 데이터 초기화
	this.dsPageInfo.setColumn(0,"pageIndex",1);
	this.dsPageInfo.setColumn(0,"pageSize",10);
	this.dsPageInfo.setColumn(0,"totalCount",0);

	// 페이지 레코드 size SET
	this.divPageSummary.form.fnSetInitPageSize(10);
	
	
	
	// validation SET
	this.divSearch.form.edtTitle.validate = "maxlengthB:100";
	
};


// 현재 채크된 진행상태를 [,] 를 기준으로 문자열로 변환
this.fnSearchFormGetPrgStsCd = function()
{
	var dscsnPrgStsCd = "99, "; //검색조건용 전역변수 선언
	
	var dscsnPrgStsCd00 = this.divSearch.form.chk00.value;
	var dscsnPrgStsCd01 = this.divSearch.form.chk01.value;
	var dscsnPrgStsCd02 = this.divSearch.form.chk02.value;
	var dscsnPrgStsCd03 = this.divSearch.form.chk03.value;
	var dscsnPrgStsCd04 = this.divSearch.form.chk04.value;
	var dscsnPrgStsCd05 = this.divSearch.form.chk05.value;
	var dscsnPrgStsCd06 = this.divSearch.form.chk06.value;
	
	if(dscsnPrgStsCd01) {
		if(this.smfContainsStr(dscsnPrgStsCd, "10")){
			return;
		}else{
			dscsnPrgStsCd += "10, ";
		}
	}
	if(dscsnPrgStsCd02) {
		if(this.smfContainsStr(dscsnPrgStsCd, "20")){
			return;
		}else{
			dscsnPrgStsCd += "20, ";
		}
	}
	if(dscsnPrgStsCd03) {
		if(this.smfContainsStr(dscsnPrgStsCd, "21")){
			return;
		}else{
			dscsnPrgStsCd += "21, ";
		}
	}
	if(dscsnPrgStsCd04) {
		if(this.smfContainsStr(dscsnPrgStsCd, "30")){
			return;
		}else{
			dscsnPrgStsCd += "30, ";
		}
	}
	if(dscsnPrgStsCd05) {
		if(this.smfContainsStr(dscsnPrgStsCd, "50")){
			return;
		}else{
			dscsnPrgStsCd += "50, ";
		}
	}
	if(dscsnPrgStsCd06) {
		if(this.smfContainsStr(dscsnPrgStsCd, "60")){
			return;
		}else{
			dscsnPrgStsCd += "60, ";
		}
	}
	/*
	if(dscsnPrgStsCd00){
		dscsnPrgStsCd += "10, 20, 21, 30, 50, ";
	}
	*/
	// 마지막 , 지우기
	var strDscsnPrgStsCd = dscsnPrgStsCd;
	
	var commaIndex = strDscsnPrgStsCd.length - 2;
	
	dscsnPrgStsCd = this.smfSubStr(dscsnPrgStsCd, 0, commaIndex);
	return dscsnPrgStsCd;
	
	/*
	if(!dscsnPrgStsCd00){
		this.dsSearch.setColumn(0, "dscsnPrgStsCd", this.dscsnPrgStsCd);
	}
	*/

}


this.fndDcsnPrcsTermDd = function(dscsnPrcsTermDdCnt,rcptDt)
{

	if(rcptDt == null || dscsnPrcsTermDdCnt == null){
	 return "-"
	}else{
		
		var tempDate1 = this.smfSubStr(rcptDt, 0, 4);
		var tempDate2 = this.smfSubStr(rcptDt, 5, 7);
		var tempDate3 = this.smfSubStr(rcptDt, 8, 10);
		var hhMm = this.smfSubStr(rcptDt, 11, 16);
		var ymdDate = tempDate1+tempDate2+tempDate3;
		ymdDate = this.smfAddDate(ymdDate,parseInt(dscsnPrcsTermDdCnt));
		tempDate1 = this.smfSubStr(ymdDate, 0, 4);
		tempDate2 = this.smfSubStr(ymdDate, 4, 6);
		tempDate3 = this.smfSubStr(ymdDate, 6, 8);
		var result = tempDate1+"."+tempDate2+"."+tempDate3;
		
		return result;
		
	}
	
	
}

// 진행상태명 구하기
this.fnDscsnPrgStsNm = function(dscsnPrgStsCd)
{
	var resultValue = "";
	if(dscsnPrgStsCd == "10"){
		resultValue = "작성중";
	}else if(dscsnPrgStsCd == "11"){
		resultValue = "처리자변경요청";
	}else if(dscsnPrgStsCd == "20"){
		resultValue = "신청";
	}else if(dscsnPrgStsCd == "21"){
		resultValue = "접수";
	}else if(dscsnPrgStsCd == "30"){
		resultValue = "처리중";
	}else if(dscsnPrgStsCd == "50"){
		resultValue = "완료";
	}else if(dscsnPrgStsCd == "60"){
		resultValue = "취소";
	}else{
		resultValue = "코드명없음";
	};
	return resultValue;
};



this.grd1Oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{	
	var nRow = e.row;
	var nCell = e.cell;
	
	var titlNo = 1;
	if(this.smfIsMobile()){
		titlNo = "ALL";
	}
	if(nCell ==titlNo||titlNo== "ALL"){	
		var onlDscsnAplyNo = this.dsResult.getColumn(e.row, "onlDscsnAplyNo");
		var dscsnPrgStsCd = this.dsResult.getColumn(e.row,"dscsnPrgStsCd");
		if(dscsnPrgStsCd != "10") {
			var params = {menu : "2041"
						  ,_url : "pa_scr_mri_cl::scr_mricl02_m01.xfdl"
						  ,onlDscsnAplyNo : onlDscsnAplyNo
						  ,from : "INDI"
						  ,dsListParam : this.dsParam.saveXML()
						  ,dsPageInfo :this.dsPageInfo.saveXML()
						  ,dsResult : this.dsResult.saveXML()
						  };
			this.smfSetWorkPage(params._url, params, null, null);
		}else{
			var params = {menu : "2030"
						  ,_url : "pa_scr_ctr_oc::scr_ctroc00_m00.xfdl"
						  , onlDscsnAplyNo : onlDscsnAplyNo 
						  , flag : "OLD"
						  ,dsListParam : this.dsParam.saveXML()
						  ,dsPageInfo :this.dsPageInfo.saveXML()
						  ,dsResult : this.dsResult.saveXML()
						  };
			this.smfSetWorkPage(params._url, params, null, null);
		}
	
	}
};

this.btnDscsnAply_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
		var dscsnPrgStsCd = this.dsResult.getColumn(e.row,"dscsnPrgStsCd");
		var params = {menu : "2030"
					  ,_url : "pa_scr_ctr_oc::scr_ctroc00_m00.xfdl"
					  ,flag : "NEW"
					  ,dsListParam : this.dsParam.saveXML()
					  ,dsPageInfo :this.dsPageInfo.saveXML()
					  ,dsResult : this.dsResult.saveXML()
					  };
		this.smfSetWorkPage(params._url, params, null, null);
};



this.fnDscsnListMore = function(obj, e){
	// 초기값 설정

	
	var serviceId = "selectOnlDcmDscscnListViewMore";
	
	var dscsnPrgStsCd = this.fnSearchFormGetPrgStsCd();
	var fromValue = this.divSearch.form.calFromValue.value;
	var toValue = this.divSearch.form.calTovalue.value;
	var dscsnAplyTitlNm = this.divSearch.form.edtTitle.value;
	
	dscsnPrgStsCd = this.smfReplace(dscsnPrgStsCd, " ", "");


	this.dsParam.setColumn(0, 'fromValue', fromValue);
	this.dsParam.setColumn(0, 'toValue', toValue);
	this.dsParam.setColumn(0, 'dscsnPrgStsCd', dscsnPrgStsCd);
	this.dsParam.setColumn(0, 'dscsnAplyTitlNm', dscsnAplyTitlNm);
	this.dsParam.setColumn(0, 'from', 'INDI');
	this.dsParam.setColumn(0, 'cteOrgCd', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'cteOrgCd'));
	this.dsParam.setColumn(0, 'instCd', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'shlCd'));
	
	var pageIndex = this.dsPageInfo.getColumn(0,"pageIndex")+1;
	var pageSize = this.dsPageInfo.getColumn(0,"pageSize");
	var totalCount = this.dsPageInfo.getColumn(0,"totalCount");
	var lastPage = Math.ceil(totalCount / pageSize);

	if(lastPage >= pageIndex){
		this.dsPageInfo.setColumn(0,"pageIndex",pageIndex);
	}
	
	//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// 서브밋 시작
	//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// 서비스 객체 생성
	this.smfSearchService(serviceId)
	// 데이터 검증
	.validateForm(this.divSearch)
	// 페이징처리
	//.paginator(this, this.divPaginator, this.divPageSummary, this.dsPageInfo, obj, e)
	// 실행
	.run()
	// 콜백
	.callback(function(callbackParams){
		if(callbackParams.errors){
			return;
		}
		this.dsResult.appendData(this.dsResultMore);
		if(this.dsResult.getRowCount() == 0 || lastPage == pageIndex){
			this.btnViewMore.set_visible(false);
		}else{
			this.btnViewMore.set_visible(true);
		}
	
		if(this.dsResultMore.getRowCount() == 0 && this.dsResult.getRowCount() == 0 ){
			this.dsPageInfo.setColumn(0,"totalCount",0);
			this.divPageSummary.form.fnInit(this.grd1, this.dsPageInfo, this.divPageSummary, this.listOtsDscsnAply, this);
			this.divPaginator.form.fnInit(this.grd1, this.dsPageInfo, this.divPageSummary, this.listOtsDscsnAply, this);
		}
		
		
		//화면높이조정
		this.fnResetScreenHeight(this.grd1);
	});
	//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// 서브밋 종료
	//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
};

this.btnViewMore_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 더보기 조회
	this.fnDscsnListMore(obj, e);
};

this.divSearch_onkeydown = function(obj:nexacro.Div,e:nexacro.KeyEventInfo)
{
		// 엔터 클릭 시 조회 버튼 동작
	if(e.keycode == "13"){
		this.DivSearch_btnSearch_onclick();
	}
};
// 현재 체크된 진행상태를 [,] 를 기준으로 입력
this.fnSearchFormSetPrgStsCd = function(dscsnPrgStsCd)
{
	this.divSearch.form.chk00.set_value(false);
	this.divSearch.form.chk01.set_value(false);
	this.divSearch.form.chk02.set_value(false);
	this.divSearch.form.chk03.set_value(false);
	this.divSearch.form.chk04.set_value(false);
	this.divSearch.form.chk05.set_value(false);
	this.divSearch.form.chk06.set_value(false);
	
	var prgStsCdArray = dscsnPrgStsCd.split(",");
	for(idx = 0; idx < prgStsCdArray.length; idx++){
		if(prgStsCdArray.length == 7){
			this.divSearch.form.chk00.set_value(true);		
		}

		if(prgStsCdArray[idx] == "10"){
			this.divSearch.form.chk01.set_value(true);
		}else if(prgStsCdArray[idx] == "20"){
			this.divSearch.form.chk02.set_value(true);			
		}else if(prgStsCdArray[idx] == "21"){
			this.divSearch.form.chk03.set_value(true);		
		}else if(prgStsCdArray[idx] == "30"){
			this.divSearch.form.chk04.set_value(true);		
		}else if(prgStsCdArray[idx] == "50"){
			this.divSearch.form.chk05.set_value(true);		
		}else if(prgStsCdArray[idx] == "60"){
			this.divSearch.form.chk06.set_value(true);		
		}
	}

}
this.fnAfter_onlayoutchanged = function(sLayoutId)
{
	// 화면 높이 조정
	this.fnResetScreenHeight(this.grd1);
};
 this.fnDisplayText = function(obj,nCell,nRow,sLongText)
{	
//	trace("=============================================================================================================");
//	trace("obj.get_id() ::: " + obj.id );
//	trace("sLongText ::: " + sLongText );
//	trace("sLongText.length ::: " + sLongText.length );
//	trace("=============================================================================================================");

	var objId = obj.id;
	var sSize;

	if ( this.objApp.gv_appScreenType == "M" ) { // 모바일
			sSize = 20;		
	}else if ( this.objApp.gv_appScreenType == "T" ) { // 태블릿
			sSize = 25;	
	}else {
			sSize = 25;	
	}		

	return this.scrDisplayText(sLongText, sSize);
};
 
this.fnResetScreenHeight = function(objGrd)
{
	
	// 그리드 사이즈 변경
	var grdHeight = (objGrd.getRealRowFullSize("body") == null ? 0 : objGrd.getRealRowFullSize("body") == 0 ? 386 :objGrd.getRealRowFullSize("body") )
					+ (objGrd.getRealRowFullSize("head") == null ? 0 : objGrd.getRealRowFullSize("head"))
					+ (objGrd.getRealRowFullSize("summary") == null ? 0 : objGrd.getRealRowFullSize("summary"))
					+ 2;
	objGrd.setOffsetHeight(grdHeight);
	// divWork(frame영역) 사이즈 계산
	var nFormHeight = this.getOwnerFrame().form.divAll.form.divWork.form.staTitle.getOffsetHeight()
					+ this.grd1.getOffsetBottom()+50;
	
	// frameAll의 fnAfter_onlayoutchanged에서 divWork 높이 변경하는데 처리 순서가 고르지 않아 일단 여기서 셋팅
	this.getOwnerFrame().form.divAll.form.fv_WorkFormHeight = nFormHeight; 
	
	// divWork(frame영역) 사이즈 변경
	this.getOwnerFrame().form.divAll.form.divWork.setOffsetHeight(nFormHeight);
	
	this.resetScroll();
	this.getOwnerFrame().form.divAll.form.resetScroll();
}]]></Script>
  </Form>
</FDL>
