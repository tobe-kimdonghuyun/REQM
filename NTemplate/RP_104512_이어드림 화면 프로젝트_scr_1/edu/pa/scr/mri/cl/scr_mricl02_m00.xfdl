        <Grid id="grd1" taborder="2" left="20" binddataset="dsResult" top="375" height="386" right="0" formatid="default" autofittype="col" oncellclick="grd1Oncellclick">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="100"/>
                <Column size="450"/>
                <Column size="120"/>
                <Column size="179"/>
                <Column size="221"/>
                <Column size="170"/>
                <Column size="110"/>
              </Columns>
              <Rows>
                <Row size="60" band="head"/>
                <Row size="54"/>
              </Rows>
              <Band id="head">
                <Cell text="번호"/>
                <Cell col="1" text="상담제목"/>
                <Cell col="2" text="신청자"/>
                <Cell col="3" text="신청일시  "/>
                <Cell col="4" text="처리기한"/>
                <Cell col="5" text="답변일시"/>
                <Cell col="6" text="진행상태"/>
              </Band>
              <Band id="body">
                <Cell text="bind:rownum" displaytype="text"/>
                <Cell col="1" cssclass="cell_WF_TxtLink" accessibilitydescription="새창열기" displaytype="buttoncontrol" edittype="button" accessibilityrole="button" tooltiptext="bind:dscsnAplyTitlNm" text="expr:comp.parent.fnDisplayText(comp,0,currow,dscsnAplyTitlNm) "/>
                <Cell col="2" text="bind:schpaNm" displaytype="text"/>
                <Cell col="3" text="expr:dscsnAplyDt == null ? &quot;-&quot; : dscsnAplyDt" displaytype="text" calendareditformat="yyyy.MM.dd" calendardateformat="yyyy.MM.dd" maskeditformat="####.##.## ##:##" maskedittype="string" cssclass="cell_WF_TxtC"/>
                <Cell col="4" text="expr:dataset.parent.fndDcsnPrcsTermDd(dscsnPrcsTermDdCnt,rcptDt)" calendardateformat="yyyy.MM.dd" calendareditformat="yyyy.MM.dd" maskeditformat="####.##.## ##:##" maskedittype="string" cssclass="cell_WF_TxtC" displaytype="text"/>
                <Cell col="5" text="expr:ntfctnDt == null  ?  &quot;-&quot;  :  ntfctnDt" displaytype="text" maskeditformat="####.##.## ##:##" maskedittype="string" cssclass="cell_WF_TxtC"/>
                <Cell col="6" text="bind:dscsnPrgStsCd" displaytype="combotext" cssclass="EXPR(dscsnPrgStsCd=='60'?&quot;cell_WF_IngCancle&quot;:dscsnPrgStsCd=='50'?&quot;cell_WF_IngOk&quot;:dscsnPrgStsCd=='20'?&quot;cell_WF_IngReceipt&quot;:dscsnPrgStsCd=='21'?&quot;cell_WF_IngApply&quot;:dscsnPrgStsCd=='10'?&quot;cell_WF_IngReceipt01&quot;:dscsnPrgStsCd=='30'?&quot;cell_WF_IngApply01&quot;:&quot;&quot;)" combodataset="dsDscsnPrgStsCdList" combocodecol="value" combodatacol="label"/>
              </Band>
            </Format>
            <Format id="format00">
              <Columns>
                <Column size="12" band="left"/>
                <Column size="136"/>
                <Column size="70"/>
                <Column size="100"/>
                <Column size="100"/>
                <Column size="12" band="right"/>
              </Columns>
              <Rows>
