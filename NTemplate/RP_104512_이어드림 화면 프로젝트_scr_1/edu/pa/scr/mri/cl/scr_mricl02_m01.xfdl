    <Script type="xscript5.1"><![CDATA[/**
*  학부모소통시스템 
*  @MenuPath    공통
*  @FileName 	scr_mricl02_m01.xfdl
*  @Creator 	tobesoft
*  @CreateDate 	2025.03.17
*  @Desction    온라인(서면)상담신청상세조회
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2025.03.17     	tobesoft 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::scr_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.scrInitForm(obj);	//필수(화면초기화)
	
	var pv_params = this.smfGetFormParams();	// 이전창의 Parameter 가져오기
	this.dsListParam.loadXML(pv_params.dsListParam);
	this.dsPageInfo.loadXML(pv_params.dsPageInfo);
	this.dsListResult.loadXML(pv_params.dsResult);
	
	this.selectDscsnDtl(pv_params);	// 상담상세내역 조회
	
	
	this.div00.form.divFileUpload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)
	this.div01.form.divFileUpload2.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)
};


/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 this.selectDscsnDtl = function(obj, e)
{
	var from =this.smfGetFormParams().from;
	this.dsParam.setColumn(0, "onlDscsnAplyNo", obj.onlDscsnAplyNo);
	this.dsParam.setColumn(0,"from",from);
	// 서비스 객체 생성
	this.smfSearchService("selectOnlDcmDscscnDtl")	
		.showConfirm(false)
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.fnDataFormatting();
			
		});	
};
 this.saveDscsnCancel = function(obj, e)
{
	// 서비스 객체 생성
	this.smfSaveService("saveOnlDcmDscsnAply")	
		.showConfirm(false)
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;	
			/*
			if(this.dsMsg.getColumn(0,"rtnMsg")=="실패"){
			this.scrAlert("CM000", ["이미 결재진행되어 재신청이 불가능합니다."], function (result){ 
				var params = {menu : "3030",_url : "pa_scr_mri_cl::scr_mricl02_m00.xfdl"};
				this.smfSetWorkPage(params._url, params, null, null);
				});
				return;	
			}
			*/
			this.scrAlert("CM000", ["상담취소가 완료되었습니다."], function (result){ // PA072 ::: {0}이 완료되었습니다.
			/*
				var from =this.smfGetFormParams().from;
				if(from == "ALL"){					
					var params = {menu : "2040",_url : "pa_scr_mri_cl::scr_mricl02_m02.xfdl"};
					this.smfSetWorkPage(params._url, params, null, null);
				}else if(from == "INDI"){
					var params = {menu : "3030",_url : "pa_scr_mri_cl::scr_mricl02_m00.xfdl"};
					this.smfSetWorkPage(params._url, params, null, null);
				}
				
			*/	
				var params = {menu : "3030",_url : "pa_scr_mri_cl::scr_mricl02_m00.xfdl"};
					this.smfSetWorkPage(params._url, params, null, null);
			});
		});	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 // 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){

	if(errcd == -1) return;
	if(svcid=="selectOnlDcmDscscnDtl"){
	
		if(this.smfGetFormParams().from == "INDI"){
			for(i = 0; i < this.dsFileinfo.getRowCount(); i++){
											
				var handlerCode 		= "SA.SCP.BTB";
				var atchFileSn        = this.dsFileinfo.getColumn(i, "fileRefrnId");
				var fileSize          = this.dsFileinfo.getColumn(i, "atchFileMg"); 
				var backendFilename   = this.dsFileinfo.getColumn(i, "atchFileGuid");
				var frontendFilename  = this.dsFileinfo.getColumn(i, "atchFileNm");
				var fileId            = this.dsFileinfo.getColumn(i, "fileId");
				var sDownloadPath 		= "";
				var sFileEncryptYn 		= this.dsFileinfo.getColumn(i, "fileEncryptYn");
				var sPrivInfoFiltYn 	= "Y";
				var sFileSaveStg 		= this.dsFileinfo.getColumn(i, "fileSaveStg");
				var sFileInfSaveYn 		= "Y";	
				
				this.div01.form.divFileUpload2.form.fnAddUploadedFile(handlerCode, atchFileSn, fileSize, backendFilename, frontendFilename, fileId
																	,sDownloadPath,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn);
																		
																
				
			}

			for(i = 0; i < this.dsPrntFileinfo.getRowCount(); i++){

				var handlerCode 		= "SA.SCP.BTB";
				var atchFileSn        = this.dsPrntFileinfo.getColumn(i, "fileRefrnId");
				var fileSize          = this.dsPrntFileinfo.getColumn(i, "atchFileMg"); 
				var backendFilename   = this.dsPrntFileinfo.getColumn(i, "atchFileGuid");
				var frontendFilename  = this.dsPrntFileinfo.getColumn(i, "atchFileNm");
				var fileId            = this.dsPrntFileinfo.getColumn(i, "fileId");
				var sDownloadPath 		= "";
				var sFileEncryptYn 		= this.dsFileinfo.getColumn(i, "fileEncryptYn");
				var sPrivInfoFiltYn 	= "Y";
				var sFileSaveStg 		= this.dsFileinfo.getColumn(i, "fileSaveStg");
				var sFileInfSaveYn 		= "Y";
				
				this.div00.form.divFileUpload.form.fnAddUploadedFile(handlerCode, atchFileSn, fileSize, backendFilename, frontendFilename, fileId
																,sDownloadPath,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn);
																		
														
			}
		}
		
		if(this.dsFileinfo.getRowCount()==0){
			this.div01.form.staFileLabel2.set_height(0);
			this.div01.form.divFileUpload2.set_height(0);
			this.div01.form.sta14.set_height(0);
			
			this.div01.form.staFileLabel2.set_visible(false);
			this.div01.form.divFileUpload2.set_visible(false);
			this.div01.form.sta14.set_visible(false);
			this.smfResetScroll(this.div01.form.staFileLabel2);
		}
		if(this.dsPrntFileinfo.getRowCount()==0){
			this.div00.form.staFileLabel1.set_height(0);
			this.div00.form.divFileUpload.set_height(0);
			this.div00.form.sta08.set_height(0);
			
			this.div00.form.staFileLabel1.set_visible(false);
			this.div00.form.divFileUpload.set_visible(false);
			this.div00.form.sta08.set_visible(false);
			this.smfResetScroll(this.div00.form.staFileLabel1);
		}
		
			// 화면을 다시 그린다.(필수)
		this.smfResetScroll(this.div00.form.staDscsnCn);
		this.smfResetScroll(this.div01.form.staAnsCn);
		this.smfResetScroll(this.div00.form.staHopYn);
		
		//this.smfResetScroll(this.div01.form.divAnsFileDownload);
		//this.smfResetScroll(this.div01.form.divPrntFileDownload);
		
		/*
			this.divFileDownload.form.fnReArrangeHeight();
		var height = parseInt(this.divFileDownload.height);
		this.set_height(parseInt(this.height) + height)
		*/
		/*
		this.resetScroll();
		this.smfResetScroll(this.divFileDownload);
		*/
	}
	if(svcid=="saveOnlDcmDscsnAply"){
		return;
	}
};


/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 this.fndDcsnPrcsTermDd = function(dscsnPrcsTermDdCnt,rcptDt)
{
	if(rcptDt == null || dscsnPrcsTermDdCnt == null){
	 return "-"
	}else{
		
		var tempDate1 = this.smfSubStr(rcptDt, 0, 4);
		var tempDate2 = this.smfSubStr(rcptDt, 5, 7);
		var tempDate3 = this.smfSubStr(rcptDt, 8, 10);
		var hhMm = this.smfSubStr(rcptDt, 11, 16);
		var ymdDate = tempDate1+tempDate2+tempDate3;
		ymdDate = this.smfAddDate(ymdDate,parseInt(dscsnPrcsTermDdCnt));
		tempDate1 = this.smfSubStr(ymdDate, 0, 4);
		tempDate2 = this.smfSubStr(ymdDate, 4, 6);
		tempDate3 = this.smfSubStr(ymdDate, 6, 8);
		var result = dscsnPrcsTermDdCnt+"일 ("+tempDate1+"."+tempDate2+"."+tempDate3+" "+hhMm+")"
		
		return result;
		
	}
		
}

this.fnDataFormatting = function()
{
	
	//공개여부
	var prcrClsdrRsnCn = this.dsResult.getColumn(0,"prcrClsdrRsnCn");
	var apsRlsHopYn = this.dsResult.getColumn(0,"apsRlsHopYn");
	var prcrRlsYn = this.dsResult.getColumn(0,"prcrRlsYn");
	var apsRlsHopNm = "";
	

	if(apsRlsHopYn == "Y"){
		apsRlsHopNm = "공개";
		if(this.isNotNil(prcrClsdrRsnCn)&&prcrRlsYn=="N"){
			apsRlsHopNm = "비공개"+"("+prcrClsdrRsnCn+")";
		}
	}else if(apsRlsHopYn == "N"){
		apsRlsHopNm = "비공개"
	}
	

	//처리기한
	var rcptDt = this.dsResult.getColumn(0,"rcptDt");
	var dscsnPrcsTermDdCnt = this.dsResult.getColumn(0,"dscsnPrcsTermDdCnt");
	var dueDt = "";
	if(rcptDt == null || dscsnPrcsTermDdCnt == null){
	
	 dueDt = "-"
	}else{
	
		var tempDate1 = this.smfSubStr(rcptDt, 0, 4);
		var tempDate2 = this.smfSubStr(rcptDt, 5, 7);
		var tempDate3 = this.smfSubStr(rcptDt, 8, 10);
		var hhMm = this.smfSubStr(rcptDt, 11, 16);
		var ymdDate = tempDate1+tempDate2+tempDate3;
		ymdDate = this.smfAddDate(ymdDate,parseInt(dscsnPrcsTermDdCnt));
		tempDate1 = this.smfSubStr(ymdDate, 0, 4);
		tempDate2 = this.smfSubStr(ymdDate, 4, 6);
		tempDate3 = this.smfSubStr(ymdDate, 6, 8);
		dueDt = tempDate1+"."+tempDate2+"."+tempDate3;
		
	}
	
	//처리상태
	var dscsnPrgStsCd = this.dsResult.getColumn(0,"dscsnPrgStsCd");
	var resultValue = "";
	if(dscsnPrgStsCd == "10"){
		resultValue = "작성중";
	}else if(dscsnPrgStsCd == "11"){
		resultValue = "처리자변경요청";
	}else if(dscsnPrgStsCd == "20"){
		resultValue = "신청";
	}else if(dscsnPrgStsCd == "21"){
		resultValue = "접수";
	}else if(dscsnPrgStsCd == "30"){
		resultValue = "처리중";
	}else if(dscsnPrgStsCd == "50"){
		resultValue = "완료";
	}else if(dscsnPrgStsCd == "60"){
		resultValue = "취소";
	}else{
		resultValue = "코드명없음";
	};
	
	if(dscsnPrgStsCd == "20"){
		this.btnSave00.set_visible(true);
	}
	
	var nm =  this.dsResult.getColumn(0,"prcrNm");
	if(this.isNil(nm)){
		this.div00.form.staPrcrNm.set_text("미지정");
	}
	this.div00.form.staHopYn.set_text(apsRlsHopNm);
	
	this.div00.form.staDueDt.set_text(dueDt);
	
	this.div00.form.staSts.set_text(resultValue);
	
	this.fnSetFrameShow();
}

this.btnList_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var from =this.smfGetFormParams().from;
	var dsListParam = this.dsListParam.saveXML();
	var dsPageInfo = this.dsPageInfo.saveXML();
	var dsResult = this.dsListResult.saveXML();
	if(from == "ALL"){					
		var params = {menu : "2040"
					  ,_url : "pa_scr_mri_cl::scr_mricl02_m02.xfdl"
					  , dsParam : dsListParam
					  , dsPageInfo : dsPageInfo
					  , dsResult : dsResult
					  , listFlag : "Y"
					  };
		this.smfSetWorkPage(params._url, params, null, null);
	}else if(from == "INDI"){
		var params = {menu : "3030"
					  ,_url : "pa_scr_mri_cl::scr_mricl02_m00.xfdl"
					  , dsParam : dsListParam
					  , dsPageInfo : dsPageInfo
					  , dsResult : dsResult
					  , listFlag : "Y"
					  };
		this.smfSetWorkPage(params._url, params, null, null);
	}
};

this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var atrz= this.dsResult.getColumn(0, "atrzStsCd");

	if(atrz!= null && atrz != "" && this.isNotNil(atrz)){
		this.smfAlert('CM000', ['현재 답변이 처리진행중인건 입니다. 취소가 불가능합니다.'], this.callback ); // [등록요청/수정요청] 상태만 취소가 가능합니다.
		return;
	}
	//확인메시지
	this.scrConfirm("PA060", ["상담취소"], function (result){
		if(result.confirmResult){
			this.dsParam.setColumn(0, "onlDscsnAplyNo", this.smfGetFormParams().onlDscsnAplyNo);
			this.dsParam.setColumn(0,"dscsnPrgStsCd","60");
			this.saveDscsnCancel();
		}
	});
};

this.fnSetFrameShow = function()
{
	var from =this.smfGetFormParams().from;
	var dscsnPrgStsCd = this.dsResult.getColumn(0,"dscsnPrgStsCd");
	
	if(from == "INDI"){
		if(dscsnPrgStsCd!="50"&&dscsnPrgStsCd!="60"){
			this.btnCancel.set_visible(true);
		}
		if(dscsnPrgStsCd !="50"){
			this.div01.set_visible(false);
			this.div01.set_height(0);
			
			this.sta16.set_visible(false);
			this.sta16.set_height(0);
			
			this.div01.form.resetScroll();
			this.div01.form.resetScroll();
			this.resetScroll();
		}
		
		return;
	}
	if(from=="ALL"){
	//공개여부가 공개된 상담 내용인 경우 [신청자, 연락처, 주소, 상담교(직)원/답변자] 항목은 보이지 않도록 한다
	
 	this.div00.form.sta03.set_visible(false);
 	this.div00.form.sta04.set_visible(false);
 	this.div00.form.staMblTelNoLabel.set_visible(false);
 	this.div00.form.staMblTelNo.set_visible(false);
 	this.div00.form.staTeacherLabel.set_visible(false);
 	this.div00.form.staPrcrNm.set_visible(false);
 	this.div01.form.staPrcrNmLabel.set_visible(false);
 	this.div01.form.staAns.set_visible(false);
 	this.div00.form.sta05.set_visible(false);
 	this.div00.form.sta06.set_visible(false);
 	this.div00.form.sta99.set_visible(false);
 	this.div01.form.sta15.set_visible(false);
	
	this.div00.form.sta04.set_height(0);
	this.div00.form.sta03.set_height(0);	
	this.div00.form.sta05.set_height(0);
	
	this.div00.form.staMblTelNoLabel.set_height(0);
	this.div00.form.staMblTelNo.set_height(0);
	this.div00.form.sta06.set_height(0);
	
	this.div00.form.staTeacherLabel.set_height(0);
	this.div00.form.staPrcrNm.set_height(0);
	this.div00.form.sta99.set_height(0);
	
	this.div01.form.staPrcrNmLabel.set_height(0);
	this.div01.form.staAns.set_height(0);
	this.div01.form.sta15.set_height(0);
	
	this.div01.form.staFileLabel2.set_height(0);
	this.div01.form.divFileUpload2.set_height(0);
	this.div01.form.sta14.set_height(0);
			
	this.div01.form.staFileLabel2.set_visible(false);
	this.div01.form.divFileUpload2.set_visible(false);
	this.div01.form.sta14.set_visible(false);
	
	this.div00.form.staFileLabel1.set_height(0);
	this.div00.form.divFileUpload.set_height(0);
	this.div00.form.sta08.set_height(0);
	
	this.div00.form.staFileLabel1.set_visible(false);
	this.div00.form.divFileUpload.set_visible(false);
	this.div00.form.sta08.set_visible(false);
	
	this.div00.form.staHopYn.set_height(0);
	this.div00.form.staHopYn.fittocontents="none";
	this.div00.form.staHopYnLabel.set_height(0);
	this.div00.form.sta09.set_height(0);
	
	this.div00.form.staHopYn.set_visible(false);
	this.div00.form.staHopYnLabel.set_visible(false);
	this.div00.form.sta09.set_visible(false);
	
	this.div00.form.sta11.set_height(0);
	this.div00.form.staDueDt.set_height(0);
	this.div00.form.staDuedtLabel.set_height(0);
	
	this.div00.form.sta11.set_visible(false);
	this.div00.form.staDueDt.set_visible(false);
	this.div00.form.staDuedtLabel.set_visible(false);
	
	this.div00.form.sta12.set_height(0);
	this.div00.form.staSts.set_height(0);
	this.div00.form.staStsLabel.set_height(0);
	
	this.div00.form.sta12.set_visible(false);
	this.div00.form.staSts.set_visible(false);
	this.div00.form.staStsLabel.set_visible(false);
	
	this.smfResetScroll(this.div00.form.staHopYn);
	this.smfResetScroll(this.div00.form.staFileLabel1);
	this.smfResetScroll(this.div01.form.staFileLabel2);
	this.div00.form.resetScroll();
	this.div01.form.resetScroll();
	
	
	
	this.resetScroll();
	}
}

//onlayoutchanged이벤트 발생후 자동호출
