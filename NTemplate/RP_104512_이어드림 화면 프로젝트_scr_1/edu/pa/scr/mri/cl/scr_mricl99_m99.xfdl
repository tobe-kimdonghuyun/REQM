/* 로그인 */
this.doLogin = function(lgnMthScCd){
	
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// 데이터 SET
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	this.dsResult.setColumn(0, 'lgnMthScCd', lgnMthScCd ); // 로그인 구분 01: 교육디지털원패스, 02: 공동인증서, 03: 간편인증


	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// 서비스 객체 생성 시작
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	this.smfSaveService("saveCheckLogin")
	.showConfirm(false)
	.run() // 실행

	.callback(function(callbackParams){ // 콜백
		if(callbackParams.errors) return;

		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		// 처리 시작
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		trace("로그인 처리 완료 후 화면처리  :::  >>>>>>>" );

		if (this.dsApiResponseList.getColumn(0, 'code') == 'SUCC'){
			
			trace("1111usePslYn :::  >>>>>>>" + this.dsApiResponseList.getColumn(0, 'usePslYn') );
			
			if (this.dsApiResponseList.getColumn(0, 'usePslYn') == 'Y'){
			
				//알림메시지
				this.scrAlert('PA003', ['강사정보가'], function (result){
					trace("알림메시지 콜백 >>>");
				});
				
				//this.smfAlert('PA003', ['강사정보가'], this.callback ); // 강사정보가 없습니다.

				//this.dsMain.setColumn(0, 'kornFlnm', this.dsMain.getColumn(0, 'userNm'));
				//this.smfSetSessionDataset(this.dsMain);
				//this.smfSendLoginLog(this, "LG005");
				//this.fnCallbackConfirmAuth();
				
			}else{
				this.smfAlert('LI155', ['로그인 정보가 올바르지 않습니다.']);
			}
		}else{
			this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')]);
		}
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		// 처리 종료
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
			
	});
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// 서비스 객체 생성 시작
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.scr_mricl00_m00_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitForm(this);
	var sToday = this.smfToday();	//오늘 날짜
	eDay = this.smfAddDate(sToday, -30);
	
	var sToday1 = this.smfSubStr(sToday, 0, 4)
	var sToday2 = this.smfSubStr(sToday, 4, 6)
	var sToday3 = this.smfSubStr(sToday, 6, 8)

	var eDay1 = this.smfSubStr(eDay, 0, 4)
	var eDay2 = this.smfSubStr(eDay, 4, 6)
	var eDay3 = this.smfSubStr(eDay, 6, 8)

	this.divSearch.form.cal00_00.set_value(sToday1 + "." + sToday2 + "." + sToday3);
	this.divSearch.form.cal00.set_value(eDay1 + "." + eDay2 + "." + eDay3);
};

