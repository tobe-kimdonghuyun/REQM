	// 서비스 객체 생성
	this.smfSaveService("saveSangDamSave")	
		.showConfirm(false)
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.dsResult.applyChange();		
			alert("저장완료");
		});	
}
