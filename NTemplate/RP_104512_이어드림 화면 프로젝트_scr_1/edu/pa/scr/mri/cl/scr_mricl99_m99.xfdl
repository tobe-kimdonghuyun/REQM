/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 this.dscsnPrgStsCd = ""; //검색조건용 전역변수 선언

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 시간포맷팅
this.fnHrFormatting = function(paramHrStr)
{
	var hStr = this.smfSubStr(paramHrStr, 0, 2);
	var mStr = this.smfSubStr(paramHrStr, 2, 4);
	return hStr + ":" + mStr;
};

// 날짜포맷팅
this.fnYmdFormatting = function(paramYmdStr)
{
	var yStr = this.smfSubStr(paramYmdStr, 0, 4);
	var mStr = this.smfSubStr(paramYmdStr, 4, 6);
	var dStr = this.smfSubStr(paramYmdStr, 6, 8);
	return yStr + "-" + mStr + "-" + dStr;
};

// 상담방법명 구하기
this.fnDscsnDmndMthNm = function(dscsnDmndMthCd)
{
	var resultValue = "";
	if(dscsnDmndMthCd == "01"){
		resultValue = "대면";
	}else if(dscsnDmndMthCd == "02"){
		resultValue = "유선";
	}else{
		resultValue = "코드명없음";
	};
	return resultValue;
};

// 진행상태명 구하기
this.fnDscsnPrgStsNm = function(dscsnPrgStsCd)
{
	var resultValue = "";
	if(dscsnPrgStsCd == "01"){
		resultValue = "임시저장";
	}else if(dscsnPrgStsCd == "02"){
		resultValue = "신청";
	}else if(dscsnPrgStsCd == "03"){
		resultValue = "접수";
	}else if(dscsnPrgStsCd == "04"){
		resultValue = "처리중";
	}else if(dscsnPrgStsCd == "05"){
		resultValue = "완료";
	}else if(dscsnPrgStsCd == "06"){
		resultValue = "취소";
	}else{
		resultValue = "코드명없음";
	};
	return resultValue;
};
 
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var aplyYmdFrom = this.divSearch.form.cal00.value;
	var aplyYmdTo = this.divSearch.form.cal00_00.value;
	var dscsnTitl = this.divSearch.form.edt00.value;
	var dscsnPrgStsCd00 = this.divSearch.form.chk00.value;
	var dscsnPrgStsCd01 = this.divSearch.form.chk01.value;
	var dscsnPrgStsCd02 = this.divSearch.form.chk02.value;
	var dscsnPrgStsCd03 = this.divSearch.form.chk03.value;
	var dscsnPrgStsCd04 = this.divSearch.form.chk04.value;
	var dscsnPrgStsCd05 = this.divSearch.form.chk05.value;
	var dscsnPrgStsCd06 = this.divSearch.form.chk06.value;
	
	if(dscsnPrgStsCd01) {
		if(this.smfContainsStr(this.dscsnPrgStsCd, "01")){
			return;
		}else{
			this.dscsnPrgStsCd += "01, ";
		}
	}
	if(dscsnPrgStsCd02) {
		if(this.smfContainsStr(this.dscsnPrgStsCd, "02")){
			return;
		}else{
			this.dscsnPrgStsCd += "02, ";
		}
	}
	if(dscsnPrgStsCd03) {
		if(this.smfContainsStr(this.dscsnPrgStsCd, "03")){
			return;
		}else{
			this.dscsnPrgStsCd += "03, ";
		}
	}
	if(dscsnPrgStsCd04) {
		if(this.smfContainsStr(this.dscsnPrgStsCd, "04")){
			return;
		}else{
			this.dscsnPrgStsCd += "04, ";
		}
	}
	if(dscsnPrgStsCd05) {
		if(this.smfContainsStr(this.dscsnPrgStsCd, "05")){
			return;
		}else{
			this.dscsnPrgStsCd += "05, ";
		}
	}
	if(dscsnPrgStsCd06) {
		if(this.smfContainsStr(this.dscsnPrgStsCd, "06")){
			return;
		}else{
			this.dscsnPrgStsCd += "06, ";
		}
	}

	// 마지막 , 지우기
	var strDscsnPrgStsCd = this.dscsnPrgStsCd;
	var tt = strDscsnPrgStsCd.length;
	
	var commaIndex = strDscsnPrgStsCd.length - 2;
	this.dscsnPrgStsCd = this.smfSubStr(this.dscsnPrgStsCd, 0, commaIndex);

	this.dsSearch.addRow();
	this.dsSearch.setColumn(0, "aplyYmdFrom", aplyYmdFrom);
	this.dsSearch.setColumn(0, "aplyYmdTo", aplyYmdTo);
	this.dsSearch.setColumn(0, "dscsnTitl", dscsnTitl);
	if(!dscsnPrgStsCd00){
		this.dsSearch.setColumn(0, "dscsnPrgStsCd", this.dscsnPrgStsCd);
	}
	console.log(this.dscsnPrgStsCd + "@@@@");
	this.listOtsDscsnAply();
};

