}
this.btnSangSave_onclick= function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsSangDamSaveParam.addRow();
	this.dsSangDamSaveParam.setColumn(0, 'cddcScCd', 'K10');
	this.dsSangDamSaveParam.setColumn(0, 'cteOrgCd', 'K100000092');
	this.dsSangDamSaveParam.setColumn(0, 'shlCd', 'K100000596');
	this.dsSangDamSaveParam.setColumn(0, 'sgByCd', '02');
	this.dsSangDamSaveParam.setColumn(0, 'schpaNm', '대국민학부모');
	this.dsSangDamSaveParam.setColumn(0, 'mblTelno', '010-1234-5678');
	this.dsSangDamSaveParam.setColumn(0, 'stuDtcNo', '');
	this.dsSangDamSaveParam.setColumn(0, 'stuInvlNo', '');
	this.dsSangDamSaveParam.setColumn(0, 'stuFlnm', '김자녀');
	this.dsSangDamSaveParam.setColumn(0, 'ayr', '2025');
	this.dsSangDamSaveParam.setColumn(0, 'grdCd', '3');
	this.dsSangDamSaveParam.setColumn(0, 'clsCd', '2');
	this.dsSangDamSaveParam.setColumn(0, 'schpaDscsnMmntScCd', '01');
	this.dsSangDamSaveParam.setColumn(0, 'dscsnDmndMthCd', '01');
	this.dsSangDamSaveParam.setColumn(0, 'dscsnClfCd', '01');
	this.dsSangDamSaveParam.setColumn(0, 'dscsnAplyTitlNm', '대국민상담제목');
	this.dsSangDamSaveParam.setColumn(0, 'dscsnAplyCn', '대국민상담내용');
	this.dsSangDamSaveParam.setColumn(0, 'dscsnDmndThtsDtcNo', 'K10T20240008942585');
	this.dsSangDamSaveParam.setColumn(0, 'dscsnDmndThtsFlnm', '차은미');
	this.dsSangDamSaveParam.setColumn(0, 'dscsnRsvtPrgStsCd', '20');
	this.dsSangDamSaveParam.setColumn(0, 'userId', 'testId');
	
	var dmndYmd = this.edt00.value;
	var dmndYmdArray = dmndYmd.split(",");
	for(i = 0; i < dmndYmdArray.length; i++){
		var dmndYmdTemp = dmndYmdArray[i];
		var dmndYmdArray2 = dmndYmdTemp.split(" ");
		var dmndYmdArray3 = dmndYmdArray2[1].split("~");
		var dscsnDmndYmd = dmndYmdArray2[0].replace(".", "");
		var dscsnDmndHm = dmndYmdArray3[0].replace(":", "");
		var dscsnDmndEndHm = dmndYmdArray3[1].replace(":", "");

		if(i == 0){
			this.dsSangDamSaveParam.setColumn(0, 'dscsnDmndYmdFr', dscsnDmndYmd);
			this.dsSangDamSaveParam.setColumn(0, 'dscsnDmndHmFr', dscsnDmndHm);
			this.dsSangDamSaveParam.setColumn(0, 'dscsnDmndEndParngHmFr', dscsnDmndEndHm);
		}else if(i == 1){
			this.dsSangDamSaveParam.setColumn(0, 'dscsnDmndYmdSe', dscsnDmndYmd);
			this.dsSangDamSaveParam.setColumn(0, 'dscsnDmndHmSe', dscsnDmndHm);
			this.dsSangDamSaveParam.setColumn(0, 'dscsnDmndEndParngHmSe', dscsnDmndEndHm);
		}else if(i == 2){
			this.dsSangDamSaveParam.setColumn(0, 'dscsnDmndYmdTh', dscsnDmndYmd);
			this.dsSangDamSaveParam.setColumn(0, 'dscsnDmndHmTh', dscsnDmndHm);
			this.dsSangDamSaveParam.setColumn(0, 'dscsnDmndEndParngHmTh', dscsnDmndEndHm);		
		}
		alert(dmndYmdTemp);
	}
	this.dsSangDamSaveParam.setColumn(0, 'dscsnDmndDtSize', dmndYmdArray.length);
	alert(this.dsSangDamSaveParam.getColumn(0, 'dscsnDmndDtSize'));
	this.saveSangDamSave();
}
