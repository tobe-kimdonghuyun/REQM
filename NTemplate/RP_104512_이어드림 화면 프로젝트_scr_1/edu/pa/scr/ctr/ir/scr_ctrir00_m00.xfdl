/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 this.saveDscsn = function(obj, e){
    
	// 서비스 객체 생성
    this.smfSaveService("saveCnctrDscsnAply")
        // 데이터 검증
        //.validateForm(this.divMain)
        .showConfirm(false)
        .run()// 실행
        // 콜백
        .callback(function(callbackParams){
			if (this.dsApiResultMap.getColumn(0, 'code') == 'SUCC'){
				
				var dscsnExstYn = this.dsDscsn.getColumn(0, "dscsnExstYn");
				var tranExstYn = this.dsDscsn.getColumn(0, "tranExstYn");
				
				if(tranExstYn == 'Y'){
				
					var dscsnDmndYmd = this.dsDscsnParam.getColumn(0, "dscsnDmndYmd");
					var dscsnDmndHm = this.dsDscsnParam.getColumn(0, "dscsnDmndHm");
					var dscsnDmndEndParngHm = this.dsDscsnParam.getColumn(0, "dscsnDmndEndParngHm");
					
					var dscsnFr = this.fnYmdFormatting(dscsnDmndYmd) + " " + this.fnHrFormatting(dscsnDmndHm) + "~" + this.fnHrFormatting(dscsnDmndEndParngHm);
				
					this.scrAlert("희망하신 [" + dscsnFr + "] 은\n다른 이용자에 의해 예약되었습니다.\n다른 예약 희망시간을 선택해주시기 바랍니다.");
					
				}else if(dscsnExstYn == 'Y'){
					var ayr = this.dsMnbyRsvtDtList.getColumn(0, "ayr");
					var sem = this.dsMnbyRsvtDtList.getColumn(0, "sem");
					
					this.scrAlert(ayr + "학년도 " + sem + "학기" + " 집중상담 신청 내역이 존재합니다.\n집중 상담은 해당 기간 동안 1번만 가능합니다.");
					
				}else if(this.dsDscsn.getColumn(0, "schpaDscsnDtcNo") != undefined){
					this.scrAlert("PA072", ["예약신청"], function (result){ // PA072 ::: {0}이 완료되었습니다.
						var schpaDscsnDtcNo = this.dsDscsn.getColumn(0, "schpaDscsnDtcNo");
						var params = {menu : "3011",_url : "pa_scr_mri_cl::scr_mricl01_m01.xfdl", schpaDscsnDtcNo : schpaDscsnDtcNo};
						this.smfSetWorkPage(params._url, params, null, null);
					});
				}else{
					this.scrAlert("집중상담 신청에 실패했습니다.");
				}
				
			}else{
				trace("연계실패");
			}

        }); 
}

 
/**
* @description 월단위 예약가능 시간 조회(달력)
*/
this.listDscsnMnbyPosRsvtDt = function(obj, e)
{
    //접속일 기준으로 달력 조회 - 집중상담기간이 아닐때 접근 시 빈 달력 출력
    var date = new Date();
    var yearStr = date.getFullYear();
    var monthStr = String(date.getMonth()+1).padStart(2, '0');
    var dayStr = String(date.getDate()).padStart(2, '0');
    var ymdStr = yearStr + monthStr + dayStr;
	
	this.fv_set_date = ymdStr;
    
    //조회 파라미터 세팅
    this.dsSearchParam.setColumn(0, "cddcCd", nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'cddcCd'));
    this.dsSearchParam.setColumn(0, "shlCd", nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'shlCd'));
    this.dsSearchParam.setColumn(0, "ayr", nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'ayr'));
    this.dsSearchParam.setColumn(0, "dscsnThtsDtcNo", nexacro.getApplication().gdsScrLgnChildList.lookup("chcYn", "Y", "cthrUserDtcNo"));
    this.dsSearchParam.setColumn(0, "dscsnDmndYmd", ymdStr);
    
    // 서비스 객체 생성
    this.smfSearchService("listDscsnMnbyPosRsvtDt") 
        .showConfirm(false)
        .run()// 실행
        // 콜백
        .callback(function(callbackParams){		
            //상단 안내문구 세팅
			this.fnSetSta01();
            
			//달력세팅
			this.fnSetCalendar(ymdStr);
			
			//상담시간 등록이 안된 경우 버튼 안보이게
			if(this.dsDayByRsvtDtList.rowcount < 1){
				this.divHopDscsnHr.setOffsetHeight(45);
				this.btnRsvtAply.set_visible(false);
			}else{
				this.btnRsvtAply.set_visible(true);
			}
			
			//이미 신청한 집중상담 신청서가 존재할 시 알람
			var dscsnDmndYmd = this.dsDscsn.getColumn(0, "dscsnDmndYmd");
			var dscsnDmndHm = this.dsDscsn.getColumn(0, "dscsnDmndHm");
			var dscsnDmndEndParngHm = this.dsDscsn.getColumn(0, "dscsnDmndEndParngHm");
			
			var dscsnFr = this.fnYmdFormatting(dscsnDmndYmd) + " " + this.fnHrFormatting(dscsnDmndHm) + "~" + this.fnHrFormatting(dscsnDmndEndParngHm);
			var msg = "[" + dscsnFr + "] 에 \n예약 확정 건이 있습니다.\n신청결과 화면으로 이동";
			
			this.scrConfirm("PA060", [msg], function (result){
				if(result.confirmResult){
					//집중상담 예약결과 목록 화면 이동
					var schpaDscsnDtcNo = this.dsDscsn.getColumn(0, "schpaDscsnDtcNo");
					var params = {menu : "3011",_url : "pa_scr_mri_cl::scr_mricl01_m00.xfdl", schpaDscsnDtcNo : schpaDscsnDtcNo};
					this.smfSetWorkPage(params._url, params, null, null);
				}
			});
			
        });
}

/**
* @description 일단위 예약가능 시간 조회(버튼)
*/
 this.listDscsnDayByPosRsvtDt = function(sFullDate, totalCalDivHgt)
 {
 	//달력은 최초에 1번만 그려지기 때문에 1번만 값설정을 하면 됨
	if(this.divCalHgt == 0){
		this.divCalHgt = totalCalDivHgt;
	}
 
	//상담상세
	this.dsDscsnParam.clearData();
	this.dsDscsnParam.addRow();
	this.dsDscsnParam.setColumn(0, "dscsnDmndYmd", sFullDate);
	
	//일단위 시간 조회를 위한 인자
    this.dsSearchParam.setColumn(0, "dscsnYmd", sFullDate);	//divCalendar에서 callback 시 일자(sFullDate)를 반환
    
    // 서비스 객체 생성
    this.smfSearchService("listDscsnDayByPosRsvtDt")    
        .showConfirm(false)
        .run()// 실행
        // 콜백
        .callback(function(callbackParams){
			if (this.dsApiResultMap.getColumn(0, 'code') == 'SUCC'){
                this.fnAllHrBtnInit();
            }else{
				this.fnAllHrBtnInit();
                //this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')]);
            }
        }); 
}
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
    if(errcd == -1) return;
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnIsNull = function(sValue)
{
	if( new String(sValue).valueOf() == "undefined")
		return true;
	if( sValue == null )
		return true;
	if( ("x"+sValue == "xNaN") && ( new String(sValue.length).valueOf() == "undefined" ) )
		return true;
	if( sValue.length == 0 )
		return true;
	return false;
};
 
this.fnOnload = function ()
{
	this.listDscsnMnbyPosRsvtDt();
	
	//신청유형 세팅
	var dscsnDmndMthCd = this.dsDscsnParam.getColumn(0, "dscsnDmndMthCd");
	var rdoAplyTyp = this.divCnctrDscsnDtl.form.rdoAplyTyp;
	
	if(fnIsNull(dscsnDmndMthCd) ){
		rdoAplyTyp.set_value('01');
		this.dsDscsnParam.setColumn(0, "dscsnDmndMthCd", rdoAplyTyp.value);
	}else{
		rdoAplyTyp.set_value(dscsnDmndMthCd);
	}
    
    //학부모 전화번호 세팅
	var mblTelno = this.dsDscsnParam.getColumn(0, "mblTelno");
    var prntMblNo = nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'prntMblNo');
	
	if(fnIsNull(mblTelno) && !fnIsNull(prntMblNo)){
		if(prnMblNo.length == 10){
			this.prnMblNo1 = prntMblNo.substr(0,3);
			this.prnMblNo2 = prntMblNo.substr(3,3);
			this.prnMblNo3 = prntMblNo.substr(6,4);
		}else if(prnMblNo.length == 11){
			this.prnMblNo1 = prntMblNo.substr(0,3);
			this.prnMblNo2 = prntMblNo.substr(3,4);
			this.prnMblNo3 = prntMblNo.substr(7,4);
		}
		
		this.divCnctrDscsnDtl.form.cboCttpc1.set_value(this.prnMblNo1);
		this.dsDscsnParam.setColumn(0, "mblTelno", this.prnMblNo1 + "-" + this.prnMblNo2 + "-" + this.prnMblNo3);
		
	}else if(!fnIsNull(mblTelno) ){
		this.divCnctrDscsnDtl.form.cboCttpc1.set_value(mblTelno);
		if(mblTelno.length == 12){
			this.prnMblNo1 = mblTelno.substr(0,3);
			this.prnMblNo2 = mblTelno.substr(4,3);
			this.prnMblNo3 = mblTelno.substr(7,4);
		}else if(prnMblNo.length == 13){
			this.prnMblNo1 = mblTelno.substr(0,3);
			this.prnMblNo2 = mblTelno.substr(4,4);
			this.prnMblNo3 = mblTelno.substr(8,4);
		}
		
		this.dsDscsnParam.setColumn(0, "mblTelno", this.prnMblNo1 + "-" + this.prnMblNo2 + "-" + this.prnMblNo3);
		
	}else{
		this.divCnctrDscsnDtl.form.cboCttpc1.set_index(0);
		this.dsDscsnParam.setColumn(0, "mblTelno", this.divCnctrDscsnDtl.form.cboCttpc1.value + "-" + this.prnMblNo2 + "-" + this.prnMblNo3);
	}

};
 
//달력 생성
this.fnSetCalendar = function(ymdStr)
{
    //일정 초기화
    var fvInitArgs = {  
                    ownerForm    : this
                    ,monthDs      : this.dsMnbyRsvtDtList
                    ,callbackFunc : this.listDscsnDayByPosRsvtDt
                    ,initYm : ymdStr
                    ,initDsCol    : "dateD"
                    ,initDsYnCol  : "dscsnPrgYn"
					,initDsStartDay  : "cnctrDscsnBgngYmd"
					,initDsEndDay  : "cnctrDscsnEndYmd"
                  };
                  
    this.divCalendar.form.fnInitMonthCalendar(fvInitArgs);
};

/**
* @description 달력에서 일자 클릭시, 예약 가능 시간 버튼 생성
*/
this.fnAllHrBtnInit = function()
{
//trace("fnAllHrBtnInit>>>>>>>>");
	//div onsize event 초기화
	this.divHopDscsnHr.set_enableevent(false);
	
    // Creating page button
    var strFont = '500 24px "pre","Pretendard-Medium"'; // this.btn03._getCurrentStyleInheritValue("font").value;

    var leftWidth = 0;
    var topHeight = 0;
    this.divHopDscsnHr.reload();
	
	//상담시간 등록이 안된 경우 예약신청 버튼 안보이게
	if(this.dsDayByRsvtDtList.rowcount < 1){
		this.divHopDscsnHr.setOffsetHeight(45);
		this.btnRsvtAply.set_visible(false);
	}else{
		this.btnRsvtAply.set_visible(true);
	}
    
	var objLastHour = null;
    for(var idx = 0; idx < this.dsDayByRsvtDtList.rowcount; idx++){
        var objBtn = new Button();
        objBtn.init("btnHr"+idx, leftWidth, topHeight, 110, 35);
        this.divHopDscsnHr.addChild(objBtn.name, objBtn);
            
        objBtn.set_text(this.fnHrFormatting(this.dsDayByRsvtDtList.getColumn(idx, "dscsnBgngHm")) + "~" + this.fnHrFormatting(this.dsDayByRsvtDtList.getColumn(idx, "dscsnEndHm")));
        objBtn.set_cssclass("btn_WF_Time");
        objBtn.set_initvalueid("iv_Button");
            
        objBtn.setEventHandler("onclick", this.divDay_btnDay_onclick, this);
        objBtn.setEventHandler("onmouseenter", this.btnMenuButton_onmouseenter, this);
        
        if(this.dsDayByRsvtDtList.getColumn(idx, "dscsnPslYn") == "N"){
            objBtn.set_enable( false );
        }
            
        //@KBR PC웹접근성 키보드로 접근하기 위함
        objBtn.setEventHandler("onsetfocus", this.btnMenuButton_onsetfocus, this);  
        objBtn.show();

        var divHrWth = this.divHopDscsnHr.getOffsetWidth();
		var btnHrCnt = Math.floor(divHrWth / 115);
		/*
		trace("divHrWth : " + divHrWth);
		trace("btnHrCnt : " + btnHrCnt);
		*/
        if((idx+1) % btnHrCnt != 0){
            leftWidth = leftWidth + 115;
        }else{
            leftWidth = 0;
			if((idx+1) != this.dsDayByRsvtDtList.rowcount){
				topHeight += 40;
			}
        }
		
		objLastHour = objBtn;
    }

	if ( objLastHour ) {
		//trace("objLastHour==="+objLastHour.name + ":::::::getOffsetBottom==="+objLastHour.getOffsetBottom());	
		var nHeight = objLastHour.getOffsetBottom();
		
		this.divHopDscsnHr.setOffsetHeight(nHeight);
		
		//this.divHopDscsnHr.form.resetScroll();
		this.resetScroll();
	}	
	else {
	//trace("최소크기로 지정>>>");
		this.divHopDscsnHr.setOffsetHeight(45);		//최소크기 45로 지정
	}
	
	this.divHopDscsnHr.set_enableevent(true);	
	
	//마지막 콤포넌트 기준으로 화면 높이 조정
	this.fnSetFormHeight();	
};

//마지막 콤포넌트 기준으로 화면 높이 조정
this.fnSetFormHeight = function()
{
	//trace("fnSetFormHeight 실행 >>>>>>>>>>");
	var sLayoutID = this.getCurrentLayoutID();
	var nHeigth = this.staFormHeightComp.getOffsetBottom();
	if ( this.divCalendar.getOffsetBottom() > nHeigth ) 
	{
		nHeigth = this.divCalendar.getOffsetBottom();
	}
	//trace("this.staFormHeightComp.getOffsetBottom()==="+this.staFormHeightComp.getOffsetBottom()  + "::::::nHeigth===="+ nHeigth);
	this.parent.setOffsetHeight(nHeigth);
	this.parent.parent.resetScroll();
}

/**
* @description 상단 안내문구 세팅
*/
this.fnSetSta01 = function()
{   
    var ayr = this.dsMnbyRsvtDtList.getColumn(0, "ayr");
    var sem = this.dsMnbyRsvtDtList.getColumn(0, "sem");
    var cnctrDscsnBgngYmd = this.dsMnbyRsvtDtList.getColumn(0, "cnctrDscsnBgngYmd");
    var cnctrDscsnEndYmd = this.dsMnbyRsvtDtList.getColumn(0, "cnctrDscsnEndYmd");

    var vsMsg ="· 집중상담 일정이 등록되어있지 않습니다";

	if ((this.smfIsNull(cnctrDscsnBgngYmd) || cnctrDscsnBgngYmd == undefined)
			|| (this.smfIsNull(cnctrDscsnEndYmd) || cnctrDscsnEndYmd == undefined)){
		this.staCnctrDscsnInfo.set_text(vsMsg);
		this.staCnctrDscsnInfo.set_color("red");
		return;
    }
    
    //일자포맷
    var fromDate = cnctrDscsnBgngYmd.substring(0, 4) + '-' + cnctrDscsnBgngYmd.substring(4, 6) + "-" + cnctrDscsnBgngYmd.substring(6, 10);
    var fromDateFr = new Date(fromDate).getDay();
    var toDate = cnctrDscsnEndYmd.substring(0, 4) + '-' + cnctrDscsnEndYmd.substring(4, 6) + "-" + cnctrDscsnEndYmd.substring(6, 10);
    var toDateFr = new Date(toDate).getDay();
    
    //요일포맷
    var rsvtBgngDtFr = this.fnSetDow(fromDateFr);
    var rsvtEndDtFr = this.fnSetDow(toDateFr);
    
    vsAyr = ayr + "학년도 " + sem + "학기";
    vsRsvtBgngDtt = this.fnYmdFormatting(cnctrDscsnBgngYmd) + "(" + rsvtBgngDtFr + ")";
    vsRsvtEndDt = this.fnYmdFormatting(cnctrDscsnEndYmd) + "(" + rsvtEndDtFr + ")";
    
    vsMsg = "· 집중 상담 주간 : " + vsAyr + "\n" 
            + "· 집중 상담 기간 : " + vsRsvtBgngDtt + " ~ " + vsRsvtEndDt + "\n" 
            + "· 집중 상담 기간에는 담임 선생님만 상담이 가능합니다" + "\n" 
			+ "· 집중 상담은 해당 기간 동안 1번만 가능합니다";
    
    this.staCnctrDscsnInfo.set_text(vsMsg);
    
};

// 요일포매팅
this.fnSetDow = function(rsvtBgngDtFr)
{   
    switch(rsvtBgngDtFr) {
    case 0 :
        dateFr = '일';
        break;
    case 1:
        dateFr = '월';
        break;
    case 2:
        dateFr = '화';
        break;
    case 3:
        dateFr = '수';
        break;
    case 4:
        dateFr = '목';
        break;
    case 5:
        dateFr = '금';
        break;
    case 6:
        dateFr = '토';
        break;
    default:
    }
    
    return dateFr;
};

// 시간포맷팅
this.fnHrFormatting = function(paramHrStr)
{
    var hStr = this.smfSubStr(paramHrStr, 0, 2);
    var mStr = this.smfSubStr(paramHrStr, 2, 4);
    return hStr + ":" + mStr;
};

// 날짜포맷팅
this.fnYmdFormatting = function(paramYmdStr)
{
    var yStr = this.smfSubStr(paramYmdStr, 0, 4);
    var mStr = this.smfSubStr(paramYmdStr, 4, 6);
    var dStr = this.smfSubStr(paramYmdStr, 6, 8);
    return yStr + "." + mStr + "." + dStr;
};

// 예약신청 파라미터 세팅
this.fnSetDsCnctrDscsn = function()
{
    // 요청 파라미터 set
    this.dsDscsnParam.setColumn(0, 'cddcScCd', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'cddcCd'));
    this.dsDscsnParam.setColumn(0, 'shlCd', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'shlCd'));
    this.dsDscsnParam.setColumn(0, 'sgByCd', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'shlKndScCd'));
    this.dsDscsnParam.setColumn(0, 'stuFlnm', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'stdntNm'));
    this.dsDscsnParam.setColumn(0, 'ayr', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'ayr'));
    this.dsDscsnParam.setColumn(0, 'grdCd', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'grd'));
    this.dsDscsnParam.setColumn(0, 'clsCd', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'clsCd'));
    this.dsDscsnParam.setColumn(0, 'clsNo', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'clsNo'));
    this.dsDscsnParam.setColumn(0, 'schpaDscsnMmntScCd', '02');
    this.dsDscsnParam.setColumn(0, 'jobCd', 'I');
    //this.dsDscsnParam.setColumn(0, 'dscsnClfCd', '01'); //[미정] 상담시간분류코드 - 진오이사님께 디폴트값 확인필요
    this.dsDscsnParam.setColumn(0, 'dscsnRsvtPrgStsCd', '40');
    
    this.dsDscsnParam.setColumn(0, 'cthrTcrDtcNo', nexacro.getApplication().gdsScrLgnChildList.lookup('chcYn', 'Y', 'cthrUserDtcNo'));
    this.dsDscsnParam.setColumn(0, 'cthrTcrFlnm', nexacro.getApplication().gdsScrLgnChildList.lookup('chcYn','Y','cthrTcrNm'));
    this.dsDscsnParam.setColumn(0, 'dscsnDmndThtsDtcNo', nexacro.getApplication().gdsScrLgnChildList.lookup('chcYn', 'Y', 'cthrUserDtcNo'));
	this.dsDscsnParam.setColumn(0, 'dscsnDmndThtsDtcNo', nexacro.getApplication().gdsScrLgnChildList.lookup("chcYn", "Y", "cthrUserDtcNo"));
    this.dsDscsnParam.setColumn(0, 'dscsnDmndThtsFlnm', nexacro.getApplication().gdsScrLgnChildList.lookup('chcYn','Y','cthrTcrNm'));
    
    this.dsDscsnParam.setColumn(0, 'schpaNm', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'prntNm'));
    
    this.dsDscsnParam.setColumn(0, 'mblTelno', this.prnMblNo1 + "-" + this.prnMblNo2 + "-" + this.prnMblNo3);
    this.dsDscsnParam.setColumn(0, 'dscsnAplyTitlNm', '집중상담신청');
    //this.dsDscsnParam.setColumn(0, 'dscsnAplyCn', '집중상담내용');    
    this.dsDscsnParam.setColumn(0, 'dscsnDmndMthCd', this.divCnctrDscsnDtl.form.rdoAplyTyp.value);
    
};


/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
* @description 동적으로 생성된 예약 가능 시간 버튼 클릭 이벤트
*/
this.divDay_btnDay_onclick = function(obj:nexacro.Button,e:nexacro.KeyEventInfo)
{
    //버튼값
    var timeStr = obj.text;
    timeStr = nexacro.replaceAll(nexacro.replaceAll(timeStr, "~", ""),":", "");
    
    //상담예약신청시간
    var dscsnDmndHm = this.dsDscsnParam.getColumn(0, "dscsnDmndHm");
    var dscsnDmndEndParngHm = this.dsDscsnParam.getColumn(0, "dscsnDmndEndParngHm");
	
    //선택한 버튼 표시 및 데이터셋 세팅
    if(dscsnDmndHm + dscsnDmndEndParngHm != timeStr){
		var hrBtns = this.divHopDscsnHr.form.components;
		
		if(hrBtns != undefined){
			for(var i=0; i<hrBtns.length; i++){
				hrBtns[i].set_cssclass("btn_WF_Time");
			}
		}
		
        obj.set_cssclass("btn_WF_TimeS");
        
        var fromTimeStr = this.smfSubStr(timeStr, 0, 4);
        var toTimeStr = this.smfSubStr(timeStr, 4, 8);
		
        this.dsDscsnParam.setColumn(0, "dscsnDmndYmd", this.dsDayByRsvtDtList.getColumn(0, "dscsnYmd"));
        this.dsDscsnParam.setColumn(0, "dscsnDmndHm", fromTimeStr);
        this.dsDscsnParam.setColumn(0, "dscsnDmndEndParngHm", toTimeStr);
		
    }
}

this.btnRsvtAply_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//상담방법
	var dscsnDmndMthCd = this.divCnctrDscsnDtl.form.rdoAplyTyp.value;
	if(this.smfIsNull(dscsnDmndMthCd) ){
		this.scrAlert("상담방법은 반드시 선택하셔야 합니다.");
		return;
	}
	
	//상담일시
	var dscsnDmndYmd = this.dsDscsnParam.getColumn(0, "dscsnDmndYmd");
	var dscsnDmndHm = this.dsDscsnParam.getColumn(0, "dscsnDmndHm");
	var dscsnDmndEndParngHm = this.dsDscsnParam.getColumn(0, "dscsnDmndEndParngHm");
	
	//학부모 연락처
	this.prnMblNo1 = this.divCnctrDscsnDtl.form.cboCttpc1.value;
    this.prnMblNo2 = this.divCnctrDscsnDtl.form.mskCttpc2.value;
    this.prnMblNo3 = this.divCnctrDscsnDtl.form.mskCttpc3.value;
	var mblTelno = this.prnMblNo1 + "-" + this.prnMblNo2 + "-" + this.prnMblNo3;
	
	if(mblTelno.length < 12 || this.prnMblNo2.length < 3 || this.prnMblNo3.length <4){
		this.scrAlert("연락처를 올바르게 작성해주세요.");
		return;
	}
	
	if(this.smfIsNull(dscsnDmndYmd) || this.smfIsNull(dscsnDmndHm) || this.smfIsNull(dscsnDmndEndParngHm) ){
		this.scrAlert("CM000", ["예약 희망 상담시간은 반드시 선택하셔야 합니다."], function (result){ // CM000 ::: {0}
		});
		return false;
	}else if(this.fv_set_date > dscsnDmndYmd){
		this.scrAlert("상담은 오늘부터 신청하실 수 있습니다.");
		return;
	}
	
	var msg = "·상담방법 : " + this.divCnctrDscsnDtl.form.rdoAplyTyp.text + "\n"
            + "·연락처 : " + this.prnMblNo1 + "-" + this.prnMblNo2 + "-" + this.prnMblNo3 + "\n"
            + "·희망 상담일시 : " + this.fnYmdFormatting(dscsnDmndYmd)
			+ " " + this.fnHrFormatting(dscsnDmndHm) + "~" + this.fnHrFormatting(dscsnDmndEndParngHm) + "\n"
            + "상담 신청";


    //확인메시지
    this.scrConfirm("PA060", [msg], function (result){
        if(result.confirmResult){
			// 파라미터 세팅
            this.fnSetDsCnctrDscsn();
            
            // 상담저장
            this.saveDscsn();
        }
    });
};

this.fnAfter_onlayoutchanged = function(sLayoutID)
{
	//trace("fnAfter_onlayoutchanged>>>>>>>>>>");
	this.fnAllHrBtnInit();
	/*
    trace("scr_ctrir00_m00_onlayoutchanged >>>>>>" 
        + this.divCalendar.getOffsetLeft() 
        + ":::::" + this.divCalendar.getOffsetTop()
        + ":::::" + this.divCalendar.getOffsetWidth()
        + ":::::" + this.divCalendar.getOffsetHeight()
    );
	*/
};

this.divHopDscsnHr_onsize = function(obj:nexacro.Div,e:nexacro.SizeEventInfo)
{
	//적응형을 위해 상담시간 div 사이즈가 변경될 때마다 다시 그리기
	if ( e.cx == this.fvDivHourX ) {
		return;
	} else {
		this.fvDivHourX = e.cx;
		this.fnAllHrBtnInit();
	}
};]]></Script>
    <Bind>
      <BindItem id="item0" compid="divCnctrDscsnDtl.form.rdoAplyTyp" propid="value" datasetid="dsLayoutChg" columnid="dscsnDmndMthCd"/>
      <BindItem id="item1" compid="divCnctrDscsnDtl.form.cboCttpc1" propid="value" datasetid="dsLayoutChg" columnid="mblTelno1"/>
      <BindItem id="item2" compid="divCnctrDscsnDtl.form.mskCttpc2" propid="value" datasetid="dsLayoutChg" columnid="mblTelno2"/>
      <BindItem id="item3" compid="divCnctrDscsnDtl.form.mskCttpc3" propid="value" datasetid="dsLayoutChg" columnid="mblTelno3"/>
    </Bind>
  </Form>
