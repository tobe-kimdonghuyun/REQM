          <Column id="dscsnPrgStsCd" type="STRING" size="256"/>
          <Column id="ntfctnDt" type="STRING" size="256"/>
          <Column id="rcptDt" type="STRING" size="256"/>
          <Column id="rownum" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
