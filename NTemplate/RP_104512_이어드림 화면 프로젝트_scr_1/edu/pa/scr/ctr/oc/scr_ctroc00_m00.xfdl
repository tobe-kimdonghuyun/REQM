          <Column id="dscsnAplyTitlNm" type="STRING" size="256" description="학부모고유번호"/>
          <Column id="dscsnPrgStsCd" type="STRING" size="256" description="학년코드"/>
          <Column id="fromValue" type="STRING" size="256"/>
          <Column id="toValue" type="STRING" size="256"/>
          <Column id="schpaDtcNo" type="STRING" size="256"/>
          <Column id="cteOrgCd" type="STRING" size="256"/>
          <Column id="instCd" type="STRING" size="256"/>
          <Column id="from" type="STRING" size="256"/>
          <Column id="rcptDt" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsListResult" useclientlayout="true">
        <ColumnInfo>
          <Column id="onlDscsnAplyNo" type="STRING" size="256"/>
          <Column id="dscsnAplyTitlNm" type="STRING" size="256"/>
          <Column id="schpaNm" type="STRING" size="256"/>
