this.btn01_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

		// 주제분류 SET
		this.dsSearchThm.setColumn(0, "onlMlrdScCd", "10"); // 온라인소통구분코드 
		this.dsSearchThm.setColumn(0, "thmClfCd", "A1"); // 주제분류코드 

		trace("======================================================================================");
		trace("onlMlrdScCd ::: " + this.dsSearchThm.getColumn(0, "onlMlrdScCd") );
		trace("thmClfCd ::: " + this.dsSearchThm.getColumn(0, "thmClfCd") );
		trace("======================================================================================");
	

		//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		// 서브밋 시작
		//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	 	// 서비스 객체 생성
		this.smfSearchService("listThmClfCdInfo")
		// (권장) 데이터 존재 필수
		.requireExistsData(this.dsSearchThm)
		// 데이터 변경 필수
		.requireModifredData(this.dsSearchThm)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				return;
			}
			
			trace("!!!! codecodecode :::  >>>>>>>" + this.dsApiResultMap.getColumn(0, 'code') );
			
			if (this.dsApiResultMap.getColumn(0, 'code') == 'SUCC'){
				
				//알림메시지
				this.scrAlert('PA003', ['강사정보가'], function (result){
					trace("알림메시지 콜백 >>>");
				});
				
				//this.smfAlert('PA003', ['강사정보가'], this.callback ); // 강사정보가 없습니다.

				//this.dsMain.setColumn(0, 'kornFlnm', this.dsMain.getColumn(0, 'userNm'));
				//this.smfSetSessionDataset(this.dsMain);
				//this.smfSendLoginLog(this, "LG005");
				//this.fnCallbackConfirmAuth();

			}else{
				this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')]);
			}
		});
		//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		// 서브밋 종료
		//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		
};

this.btn02_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
	trace("======================================================================================");
	trace("간편인증!!! ");
	trace("======================================================================================");
		
		// 오픈방식을 설정한다.
		var sOpenType   = "birth";  // [선택] Open방식 -  "birth"(default) : 생년월일 , "ssn" : 주민등록번호
		var sActionType = "trans";  // [선택] 간편인증 동작방식 -  "trans" : 중계형(온라인채용/검정고시) , "instl" : 설치형(교육비원클릭/그외)
									// 미지정시 subSys를 체크하여 설정. 미지정을 권장
			
		this.dsSearch.setColumn(0, "actionType", sActionType);

		var objParam = {objForm:this, popupcallback :this.fnSimpleAuthPopupCallback , openType: sOpenType, actionType: sActionType };
		this.smfExecSimpleAuth(objParam);


};

this.btn03_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	trace("======================================================================================");
	trace("공동 인증서!!! ");
	trace("======================================================================================");

		var sRrno = "8605241108810";

		var sConnectBaseUrl = window.location.protocol + "//" + window.location.host;

		var sInitUrl  = sConnectBaseUrl + "/cmc_fcm_es01_003.do";
		var sLoginUrl = sConnectBaseUrl + "/cmc_fcm_es01_004.do";
		var userId = sRrno;
		
		var objLoginInfo = {
								initUrl  : sInitUrl    // init시 사용하는 서비스명(앞에 "/"을 붙일 것)
							,   loginUrl : sLoginUrl   // login시 사용하는 서비스명(앞에 "/"을 붙일 것)
							,	userId : userId
						   };   // 생략가능

		var objParam = {objForm:this, popupcallback :this.fnCooperationAuthPopupCallback, loginInfo:objLoginInfo};
		this.smfExecNpkiAuth(objParam);
						
};


]]></Script>
