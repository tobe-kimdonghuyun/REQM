/* 간편인증 CALLBACK */
this.fnSimpleAuthPopupCallback = function(e, sender){

	trace("==================================================================");
	trace("간편인증 CALLBACK>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>");
	trace("e.result ::: " + e.result );
	trace("==================================================================");
		
		
	var sLog 		= "";
	var loginTyp 	= "simpleLogin";


	
	if(e.result){
	
		var sData = JSON.parse(e.data);		
		trace("==================================================================");
		trace("성공");
		trace("sData.userNm ::: " + sData.userNm );
		trace("sData.ssn ::: " +sData.ssn );
		trace("sData.ci ::: " + sData.ci );
		trace("==================================================================");

		if(this.smfIsNull(e.data)){
		
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+e.data+"]";
			console.log(sLog);
			this.smfLiteralAlert("본인 인증 인증에 실패 하였습니다..");
			return;
			
		}
		
		sLog += "처리결과 : [성공]\n";

//sLog += "data : ["+sData+"]";	
//		console.log(sLog);
		
// 		mberNm = sData.userNm;
// 		mberRrn = sData.ssn;
// 
// 		this.dsSearch.setColumn(0, "trprRrno", mberRrn);
// 		this.dsSearch.setColumn(0, "kornFlnm", mberNm);
// 		this.dsSearch.setColumn(0, "sqeScCd", this.fv_sqeScCd);
// 		this.dsSearch.setColumn(0, "cddcCd",  this.smfGetCddcCode());
// 		this.dsSearch.setColumn(0, 'certKey', sData.ci);// 간편인증 CI
		
		
		// 데이터 SET
		this.dsSearch.setColumn(0, "jwt", e.data);
	
	
		/***********************************************************************************************************************
		* 서비스 객체 생성 시작
		************************************************************************************************************************/
		this.smfSearchService("listsimpleAuthParse")
		.run() // 실행			
		.callback(function(callbackParams){ // 콜백
			if(callbackParams.errors) return;
			
			////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
			// 처리 시작
			////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
			
			// 로그인처리[간편인증]
			this.doLogin("03");
			
			////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
			// 처리 종료
			////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
				
		});
		/***********************************************************************************************************************
		* 서비스 객체 생성 시작
		************************************************************************************************************************/
			
	}
	
};

/* 공동인증서 CALLBACK */
this.fnCooperationAuthPopupCallback = function(e, sender){

	trace("==================================================================");
	trace("공동인증서 CALLBACK>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>");
	trace("e.result ::: " + e.result );
	trace("==================================================================");
	
	var sLog = "";
//	var obj = sender.divLoginFrm.form;


	if(e.result){
	
		var sData = JSON.parse(e.data);
		
		trace("==================================================================");
		trace("공동인증서 결과[sData] ::: " + sData );
		trace("==================================================================");
		
		// 데이터 SET
		//this.dsSearch.setColumn(0, "jwt", e.data);
		
		// 로그인처리[공동인증서]
		this.doLogin("2");
		
		//this.doLogin(sData.subjectDn, "LG001"); // 로그인 유형코드 LG001:EPKI/GPKI
		
	}else{
	
		var sData = e.data;
		var arrData = sData.split(":");
		
		if(arrData[0].trim()=='{"visible"'){  // 유저가 팝업을 강제 종료한 경우
		
			sLog += "처리결과 : [에러(유저강제종료)]\n";
			sLog += "data : ["+sData+"]";
			
			trace("==================================================================");
			trace("에러(유저강제종료) ::: " + sData);	
			trace("==================================================================");

		}else{ // 에러인 경우
		
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+sData+"]";
			
			trace("==================================================================");
			trace("에러인 경우 ::: " + sLog);	
			trace("==================================================================");
			
			this.smfAlert(sData);
			return;
			
		}
		
	}
	
	
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/* 로그인 */
this.doLogin = function(lgnMthScCd){
	
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// 데이터 SET
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	this.dsResult.setColumn(0, 'lgnMthScCd', '03'); // 로그인 구분 01: 교육디지털원패스, 02: 공동인증서, 03: 간편인증


	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// 서비스 객체 생성 시작
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	this.smfSearchService("checkLogin")
	.run() // 실행			
	.callback(function(callbackParams){ // 콜백
		if(callbackParams.errors) return;

		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		// 처리 시작
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		trace("로그인 처리 완료 후 화면처리  :::  >>>>>>>" );

		if (this.dsApiResponseList.getColumn(0, 'code') == 'SUCC'){
			
			trace("1111usePslYn :::  >>>>>>>" + this.dsApiResponseList.getColumn(0, 'usePslYn') );
			
			if (this.dsApiResponseList.getColumn(0, 'usePslYn') == 'Y'){
			
				//알림메시지
				this.scrAlert('PA003', ['강사정보가'], function (result){
					trace("알림메시지 콜백 >>>");
				});
				
				//this.smfAlert('PA003', ['강사정보가'], this.callback ); // 강사정보가 없습니다.

				//this.dsMain.setColumn(0, 'kornFlnm', this.dsMain.getColumn(0, 'userNm'));
				//this.smfSetSessionDataset(this.dsMain);
				//this.smfSendLoginLog(this, "LG005");
				//this.fnCallbackConfirmAuth();
				
			}else{
				this.smfAlert('LI155', ['로그인 정보가 올바르지 않습니다.']);
			}
		}else{
			this.smfAlert('LI203', [this.dsApiResponseList.getColumn(0, 'message')]);
		}
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
		// 처리 종료
		////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
			
	});
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
	// 서비스 객체 생성 시작
	////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

}

