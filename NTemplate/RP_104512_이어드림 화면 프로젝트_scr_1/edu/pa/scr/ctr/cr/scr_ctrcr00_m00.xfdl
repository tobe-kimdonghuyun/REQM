}
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.saveDscsn = function(obj, e){
	// 서비스 객체 생성
	this.smfSaveService("saveDscsn")
		// 데이터 검증
		//.validateForm(this.divMain)
		.showConfirm(false)
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.scrAlert("PA072", ["예약신청"], function (result){ // PA072 ::: {0}이 완료되었습니다.
				var schpaDscsnDtcNo = this.dsDscsn.getColumn(0, "schpaDscsnDtcNo")
				var params = {menu : "3011",_url : "pa_scr_mri_cl::scr_mricl00_m01.xfdl", schpaDscsnDtcNo : schpaDscsnDtcNo, listFlagI : "N"};
				this.smfSetWorkPage(params._url, params, null, null);
			});
		});	
}

 this.saveDscsnModify = function(obj, e){
 
	this.dsDscsnParam.setColumn(0, "schpaDscsnMmntScCd", "01");
	
	// 서비스 객체 생성
	this.smfSaveService("saveDscsnModify")	
		.showConfirm(false)
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.scrAlert("PA072", ["예약수정"], function (result){ // PA072 ::: {0}이 완료되었습니다.
				var schpaDscsnDtcNo = this.dsDscsn.getColumn(0, "schpaDscsnDtcNo");
				var params = {menu : "3011",_url : "pa_scr_mri_cl::scr_mricl00_m01.xfdl", schpaDscsnDtcNo : schpaDscsnDtcNo};
				this.smfSetWorkPage(params._url, params, null, null);
			});
		});	
}
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
  // 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

this.fnDscsnDmndDtPopupCallback = function(e, sender)
{
	if(e.result == "취소") return;
	
	this.divMain.form.staDscsnDmndDtFr.set_text();
	this.divMain.form.staDscsnDmndDtFr.set_visible(false);
	this.divMain.form.btnDelDmndDtFr.set_visible(false);
	
	this.divMain.form.staDscsnDmndDtSe.set_text();
	this.divMain.form.staDscsnDmndDtSe.set_visible(false);
	this.divMain.form.btnDelDmndDtSe.set_visible(false);
	
	this.divMain.form.staDscsnDmndDtTh.set_text();
	this.divMain.form.staDscsnDmndDtTh.set_visible(false);
	this.divMain.form.btnDelDmndDtTh.set_visible(false);
	
	var dscsnDmndDt = e.dscsnDmndDt;
	var dscsnDmndDtArray = dscsnDmndDt.split(",");
	
	for(var idx = 0; idx < dscsnDmndDtArray.length; idx++){
		if(idx == 0) {
			this.divMain.form.staDscsnDmndDtFr.set_text(dscsnDmndDtArray[idx]);
			this.divMain.form.staDscsnDmndDtFr.set_visible(true);
			this.divMain.form.btnDelDmndDtFr.set_visible(true);
		};
		
		if(idx == 1) {
			this.divMain.form.staDscsnDmndDtSe.set_text(dscsnDmndDtArray[idx]);
			this.divMain.form.staDscsnDmndDtSe.set_visible(true);
			this.divMain.form.btnDelDmndDtSe.set_visible(true);
		};
		
		if(idx == 2) {
			this.divMain.form.staDscsnDmndDtTh.set_text(dscsnDmndDtArray[idx]);
			this.divMain.form.staDscsnDmndDtTh.set_visible(true);
			this.divMain.form.btnDelDmndDtTh.set_visible(true);
		};
	}
	
	this.dsDscsnParam.setColumn(0, "dscsnDmndDtSize", dscsnDmndDtArray.length);

}

this.fnDscsnDmndTcrPopupCallback = function(e, sender)
{
	this.divMain.form.staThtsFlnm.set_text(e.tcrNm);
	this.dsDscsnParam.setColumn(0, 'dscsnDmndThtsDtcNo', e.userDtcNo);
	this.dsDscsnParam.setColumn(0, 'dscsnDmndThtsFlnm', e.tcrNm);
	
	this.divMain.form.staThtsFlnm.set_visible(true);
	this.divMain.form.btnDelThts.set_visible(true);
	
	// 예약희망일시 삭제
	this.divMain.form.staDscsnDmndDtFr.set_text();
	this.divMain.form.staDscsnDmndDtFr.set_visible(false);
	this.divMain.form.btnDelDmndDtFr.set_visible(false);

	this.divMain.form.staDscsnDmndDtSe.set_text();
	this.divMain.form.staDscsnDmndDtSe.set_visible(false);
	this.divMain.form.btnDelDmndDtSe.set_visible(false);

	this.divMain.form.staDscsnDmndDtTh.set_text();
	this.divMain.form.staDscsnDmndDtTh.set_visible(false);
	this.divMain.form.btnDelDmndDtTh.set_visible(false);

	this.dsDscsnParam.setColumn(0, "dscsnDmndDtSize", null);
}
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/


this.fnInitParamSet = function()
{
	// 기본값 cteOrgCd, stuInvlNo 없음
	this.dsDscsnParam.setColumn(0, 'cddcScCd', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'cddcCd'));
	//this.dsDscsnParam.setColumn(0, 'cteOrgCd', 'K100000092');
	this.dsDscsnParam.setColumn(0, 'shlCd', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'shlCd'));
	this.dsDscsnParam.setColumn(0, 'sgByCd', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'shlKndScCd'));
	this.dsDscsnParam.setColumn(0, 'stuFlnm', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'stdntNm'));
	this.dsDscsnParam.setColumn(0, 'ayr', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'ayr'));
	this.dsDscsnParam.setColumn(0, 'grdCd', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'grd'));
	this.dsDscsnParam.setColumn(0, 'grdNm', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'grd') + "학년");
	this.dsDscsnParam.setColumn(0, 'clsCd', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'clsCd'));
	this.dsDscsnParam.setColumn(0, 'clsNm', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'clsNm'));
	this.dsDscsnParam.setColumn(0, 'clsNo', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'clsNo'));
	
	this.dsDscsnParam.setColumn(0, 'schpaDscsnMmntScCd', '01');
	
	// 2025.05.02 특수학교 경우 추가
	this.dsDscsnParam.setColumn(0, 'shlKndScCd', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'shlKndScCd'));
	this.dsDscsnParam.setColumn(0, 'shlCrseScCd', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'shlCrseScCd'));
	
	//this.dsDscsnParam.setColumn(0, 'dscsnClfCd', '01');
	this.dsDscsnParam.setColumn(0, 'dscsnRsvtPrgStsCd', '20');
	//this.dsDscsnParam.setColumn(0, 'userId', 'testId');
	
	
	// 테스트용 하드코딩 값
	/*
	this.dsDscsnParam.setColumn(0, 'cddcScCd', 'K10');
	this.dsDscsnParam.setColumn(0, 'cteOrgCd', 'K100000092');
	this.dsDscsnParam.setColumn(0, 'shlCd', 'K100000596');
	this.dsDscsnParam.setColumn(0, 'sgByCd', '02');
	this.dsDscsnParam.setColumn(0, 'ayr', '2025');
	*/

}

// 포맷팅이 필요한 항목에 대해 각각 포맷팅 한뒤 해당 컴포넌트에 넣어준다.
 this.fnDataFormatting = function(pv_params)
 {
	this.fv_job_type = "U";

	// 상담방법
	this.divMain.form.rdoDscsnMth.set_value(pv_params.dscsnDmndMthCd);

	// 연락처
	var mblTelno = pv_params.mblTelno;
	var mblTelnoArray = mblTelno.split("-");
	this.divMain.form.comMblno1.set_value(mblTelnoArray[0]);
	this.divMain.form.maskMblno2.set_value(mblTelnoArray[1]);
	this.divMain.form.maskMblno3.set_value(mblTelnoArray[2]);
	
	// 상담제목
	this.divMain.form.editDscsnTiltNm.set_value(pv_params.dscsnAplyTitlNm);
	
	// 상담내용
	this.divMain.form.textaDscsnCn.set_value(pv_params.dscsnAplyCn);
	
	// 상담 희망 교(직)원
	this.divMain.form.staThtsFlnm.set_text(pv_params.dscsnDmndThtsFlnm);
	this.divMain.form.staThtsFlnm.set_visible(true);
	this.divMain.form.btnDelThts.set_visible(true);
	
	// 예약희망일시
	var dscsnDmndDtSize = 0;
	if(!this.smfIsNull(pv_params.fmtDscsnDmndDtFrStr)){
		this.divMain.form.staDscsnDmndDtFr.set_text(pv_params.fmtDscsnDmndDtFrStr);
		this.divMain.form.staDscsnDmndDtFr.set_visible(true);
		this.divMain.form.btnDelDmndDtFr.set_visible(true);
		dscsnDmndDtSize += 1;
	}
	
	if(!this.smfIsNull(pv_params.fmtDscsnDmndDtSeStr)){
		this.divMain.form.staDscsnDmndDtSe.set_text(pv_params.fmtDscsnDmndDtSeStr);
		this.divMain.form.staDscsnDmndDtSe.set_visible(true);
		this.divMain.form.btnDelDmndDtSe.set_visible(true);
		dscsnDmndDtSize += 1;
	}
	
	if(!this.smfIsNull(pv_params.fmtDscsnDmndDtThStr)){
		this.divMain.form.staDscsnDmndDtTh.set_text(pv_params.fmtDscsnDmndDtThStr);
		this.divMain.form.staDscsnDmndDtTh.set_visible(true);
		this.divMain.form.btnDelDmndDtTh.set_visible(true);
		dscsnDmndDtSize += 1;
	}
	
	// 버튼 Text 변경
	this.btnSave.set_text("저장");

	// 검증용 ds 설정
	this.dsDscsnParam.setColumn(0, "dscsnDmndThtsDtcNo", pv_params.dscsnDmndThtsDtcNo);
	this.dsDscsnParam.setColumn(0, "dscsnDmndThtsFlnm", pv_params.dscsnDmndThtsFlnm);
	this.dsDscsnParam.setColumn(0, "dscsnDmndDtSize", dscsnDmndDtSize);
	
	// 수정용 ds 설정
	this.dsDscsnParam.setColumn(0, "schpaDscsnDtcNo", pv_params.schpaDscsnDtcNo);
 }]]></Script>
    <Bind>
      <BindItem id="item0" compid="divMain.form.staSchpaNm" propid="text" datasetid="dsUserInfo" columnid="userNm"/>
    </Bind>
  </Form>
</FDL>
