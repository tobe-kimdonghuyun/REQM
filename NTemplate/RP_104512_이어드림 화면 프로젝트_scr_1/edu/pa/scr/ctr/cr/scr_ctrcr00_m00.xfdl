/**
 * @description 예약신청 클릭 이벤트
*/
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// self Validation
	if(this.smfIsNull(this.divMain.form.maskMblno2.value)) {
		this.scrAlert("CM000", ["연락처 두번째 항목은 필수입니다."], function (result){ // CM000 ::: {0}
		});
		return false;
	}
	
	if(this.divMain.form.maskMblno2.value.length < 3) {
		this.scrAlert("CM000", ["연락처 두번째 항목은 세자리 이상 입니다."], function (result){ // CM000 ::: {0}
		});
		return false;
	}
	
	if(this.smfIsNull(this.divMain.form.maskMblno3.value)) {
		this.scrAlert("CM000", ["연락처 세번째 항목은 필수입니다."], function (result){ // CM000 ::: {0}
		});
		return false;
	}
	
	if(this.divMain.form.maskMblno3.value.length < 3) {
		this.scrAlert("CM000", ["연락처 두번째 항목은 세자리 이상 입니다."], function (result){ // CM000 ::: {0}
		});
		return false;
	}
	
	if(this.smfIsNull(this.divMain.form.editDscsnTiltNm.value)) {
		this.scrAlert("CM000", ["상담제목은 필수입니다."], function (result){ // PA072 ::: CM000 ::: {0}
		});
		return false;
	}
	
	if(this.smfIsNull(this.dsDscsnParam.getColumn(0, 'dscsnDmndThtsDtcNo')) || this.smfIsNull(this.dsDscsnParam.getColumn(0, 'dscsnDmndThtsFlnm')) ) {
		this.scrAlert("CM000", ["희망 교(직)원은 필수입니다."], function (result){ // CM000 ::: {0}
		});
		return false;
	}
	
	if(this.smfIsNull(this.dsDscsnParam.getColumn(0, "dscsnDmndDtSize")) || this.dsDscsnParam.getColumn(0, "dscsnDmndDtSize") == 0 ){
		this.scrAlert("CM000", ["예약희망일시는 필수입니다."], function (result){ // CM000 ::: {0}
		});
		return false;
	}

	// 사용자 입력값
	this.dsDscsnParam.setColumn(0, 'schpaNm', this.divMain.form.staSchpaNm.text);
	this.dsDscsnParam.setColumn(0, 'mblTelno', this.divMain.form.comMblno1.value + "-" + this.divMain.form.maskMblno2.value + "-" + this.divMain.form.maskMblno3.value);
	this.dsDscsnParam.setColumn(0, 'dscsnAplyTitlNm', this.divMain.form.editDscsnTiltNm.value);
	this.dsDscsnParam.setColumn(0, 'dscsnAplyCn', this.divMain.form.textaDscsnCn.value);
	this.dsDscsnParam.setColumn(0, 'dscsnDmndMthCd', this.divMain.form.rdoDscsnMth.value);

	if(this.fv_job_type == "I"){
		this.scrConfirm("PA060", ["예약신청"], function (result){
			if(result.confirmResult){

				// 예약희망일시 
				if(this.dsDscsnParam.getColumn(0, "dscsnDmndDtSize") >= 1){
					var staDscsnDmndDtFr = this.divMain.form.staDscsnDmndDtFr.text
					var staDscsnDmndYmdArray = staDscsnDmndDtFr.split(" ");
					var staDscsnDmndHmArray = staDscsnDmndYmdArray[1].split("~");
					var dscsnDmndYmd = this.smfReplace(staDscsnDmndYmdArray[0], ".", "");
					var dscsnDmndHm = this.smfReplace(staDscsnDmndHmArray[0], ":", "");
					var dscsnDmndEndHm = this.smfReplace(staDscsnDmndHmArray[1], ":", "");
					
					this.dsDscsnParam.setColumn(0, 'dscsnDmndYmdFr', dscsnDmndYmd);
					this.dsDscsnParam.setColumn(0, 'dscsnDmndHmFr', dscsnDmndHm);
					this.dsDscsnParam.setColumn(0, 'dscsnDmndEndParngHmFr', dscsnDmndEndHm);
				}
				if(this.dsDscsnParam.getColumn(0, "dscsnDmndDtSize") >= 2){
					var staDscsnDmndDtSe = this.divMain.form.staDscsnDmndDtSe.text
					var staDscsnDmndYmdArray = staDscsnDmndDtSe.split(" ");
					var staDscsnDmndHmArray = staDscsnDmndYmdArray[1].split("~");
					var dscsnDmndYmd = this.smfReplace(staDscsnDmndYmdArray[0], ".", "");
					var dscsnDmndHm = this.smfReplace(staDscsnDmndHmArray[0], ":", "");
					var dscsnDmndEndHm = this.smfReplace(staDscsnDmndHmArray[1], ":", "");
					
					this.dsDscsnParam.setColumn(0, 'dscsnDmndYmdSe', dscsnDmndYmd);
					this.dsDscsnParam.setColumn(0, 'dscsnDmndHmSe', dscsnDmndHm);
					this.dsDscsnParam.setColumn(0, 'dscsnDmndEndParngHmSe', dscsnDmndEndHm);
				}
				if(this.dsDscsnParam.getColumn(0, "dscsnDmndDtSize") >= 3){
					var staDscsnDmndDtTh = this.divMain.form.staDscsnDmndDtTh.text
					var staDscsnDmndYmdArray = staDscsnDmndDtTh.split(" ");
					var staDscsnDmndHmArray = staDscsnDmndYmdArray[1].split("~");
					var dscsnDmndYmd = this.smfReplace(staDscsnDmndYmdArray[0], ".", "");
					var dscsnDmndHm = this.smfReplace(staDscsnDmndHmArray[0], ":", "");
					var dscsnDmndEndHm = this.smfReplace(staDscsnDmndHmArray[1], ":", "");
					
					this.dsDscsnParam.setColumn(0, 'dscsnDmndYmdTh', dscsnDmndYmd);
					this.dsDscsnParam.setColumn(0, 'dscsnDmndHmTh', dscsnDmndHm);
					this.dsDscsnParam.setColumn(0, 'dscsnDmndEndParngHmTh', dscsnDmndEndHm);
				}
				// 상담신청
				this.saveDscsn();
			}
		});
	}else if(this.fv_job_type == "U"){
		this.scrConfirm("PA060", ["예약수정"], function (result){
		
			if(result.confirmResult){
				
				if(this.dsDscsnParam.getColumn(0, "dscsnDmndDtSize") >= 1){
					var staDscsnDmndDtFr = this.divMain.form.staDscsnDmndDtFr.text
					var staDscsnDmndYmdArray = staDscsnDmndDtFr.split(" ");
					var staDscsnDmndHmArray = staDscsnDmndYmdArray[1].split("~");
					var dscsnDmndYmd = this.smfReplace(staDscsnDmndYmdArray[0], ".", "");
					var dscsnDmndHm = this.smfReplace(staDscsnDmndHmArray[0], ":", "");
					var dscsnDmndEndHm = this.smfReplace(staDscsnDmndHmArray[1], ":", "");
					
					this.dsDscsnParam.setColumn(0, 'dscsnDmndYmdFr', dscsnDmndYmd);
					this.dsDscsnParam.setColumn(0, 'dscsnDmndHmFr', dscsnDmndHm);
					this.dsDscsnParam.setColumn(0, 'dscsnDmndEndParngHmFr', dscsnDmndEndHm);
				}
				if(this.dsDscsnParam.getColumn(0, "dscsnDmndDtSize") >= 2){
					var staDscsnDmndDtSe = this.divMain.form.staDscsnDmndDtSe.text
					var staDscsnDmndYmdArray = staDscsnDmndDtSe.split(" ");
					var staDscsnDmndHmArray = staDscsnDmndYmdArray[1].split("~");
					var dscsnDmndYmd = this.smfReplace(staDscsnDmndYmdArray[0], ".", "");
					var dscsnDmndHm = this.smfReplace(staDscsnDmndHmArray[0], ":", "");
					var dscsnDmndEndHm = this.smfReplace(staDscsnDmndHmArray[1], ":", "");
					
					this.dsDscsnParam.setColumn(0, 'dscsnDmndYmdSe', dscsnDmndYmd);
					this.dsDscsnParam.setColumn(0, 'dscsnDmndHmSe', dscsnDmndHm);
					this.dsDscsnParam.setColumn(0, 'dscsnDmndEndParngHmSe', dscsnDmndEndHm);
				}
				if(this.dsDscsnParam.getColumn(0, "dscsnDmndDtSize") >= 3){
					var staDscsnDmndDtTh = this.divMain.form.staDscsnDmndDtTh.text
					var staDscsnDmndYmdArray = staDscsnDmndDtTh.split(" ");
					var staDscsnDmndHmArray = staDscsnDmndYmdArray[1].split("~");
					var dscsnDmndYmd = this.smfReplace(staDscsnDmndYmdArray[0], ".", "");
					var dscsnDmndHm = this.smfReplace(staDscsnDmndHmArray[0], ":", "");
					var dscsnDmndEndHm = this.smfReplace(staDscsnDmndHmArray[1], ":", "");
					
					this.dsDscsnParam.setColumn(0, 'dscsnDmndYmdTh', dscsnDmndYmd);
					this.dsDscsnParam.setColumn(0, 'dscsnDmndHmTh', dscsnDmndHm);
					this.dsDscsnParam.setColumn(0, 'dscsnDmndEndParngHmTh', dscsnDmndEndHm);
				}
				// 상담수정
				 this.saveDscsnModify();
			}
		});
	}
};

/**
 * @description 예약가능 시간선택 버튼 클릭 이벤트
*/
this.btnDscsnDmndDt_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

// 	var dscsnDmndThtsDtcNo = this.dsDscsnParam.getColumn(0, 'dscsnDmndThtsDtcNo');
// 	var dscsnDmndThtsFlnm = this.dsDscsnParam.getColumn(0, 'dscsnDmndThtsFlnm');
// 	
// 	if( (dscsnDmndThtsDtcNo == null || dscsnDmndThtsDtcNo == '') && (dscsnDmndThtsFlnm == null || dscsnDmndThtsFlnm == '')){
// 		this.scrAlert("CM000", ["희망 교(직)원을 먼저 선택해주세요."], function (result){ // CM000 ::: {0}
// 		});
// 		return false;
// 	}
// 	
 	var procType = "none";
// 	
// 	trace(this.divMain.form.staDscsnDmndDtFr.text);
// 	trace(this.divMain.form.staDscsnDmndDtSe.text);
// 	trace(this.divMain.form.staDscsnDmndDtTh.text);
// 	
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: this.fnDscsnDmndDtPopupCallback, // 콜백함수 지정
		sender: obj, // sender 지정
		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: procType,
			// 파라메터 전달
			dataset: this.dsDscsnParam
			,dscsnDmndYmdFr : this.divMain.form.staDscsnDmndDtFr.text
			,dscsnDmndYmdSe : this.divMain.form.staDscsnDmndDtSe.text
			,dscsnDmndYmdTh : this.divMain.form.staDscsnDmndDtTh.text
		},
		titlebar : false
	};
// 
 	var nFormWidth = nexacro.getApplication().mainframe.getOffsetWidth();
	var nFormHeight = nexacro.getApplication().mainframe.getOffsetHeight();
// 	trace( "모바일 레이아웃 사이즈 :::: " + nFormWidth + "x" + nFormHeight);
	// 모달팝업 실행
	if ( this.objApp.gv_appScreenType == "T" ) {
		this.smfDialog("_auto", "pa_scr_ctr_cr::scr_ctrcr00_p01.xfdl", popupParams, null, null, 740, 778);
	}
	else if ( this.objApp.gv_appScreenType == "M" ) {
		this.smfDialog("_auto", "pa_scr_ctr_cr::scr_ctrcr00_p01.xfdl", popupParams, null, null, nFormWidth, nFormHeight);
	}
	else {
		this.smfDialog("_auto", "pa_scr_ctr_cr::scr_ctrcr00_p01.xfdl", popupParams, null, null, 1017, 778);
	}

	// 모달팝업 실행
	//this.smfDialog("_auto", "pa_scr_ctr_cr::scr_ctrcr00_p01.xfdl", popupParams);
};


/**
 * @description 희망 교(직)원 선택 클릭 이벤트
*/
this.btnThtsNm01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var procType = "none";

	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: this.fnDscsnDmndTcrPopupCallback, // 콜백함수 지정
		sender: obj, // sender 지정
		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: procType,
			// 파라메터 전달
			//dataset: this.dsDscsnParam
		},
		titlebar : false
	};

	// 모달팝업 실행
	if ( this.objApp.gv_appScreenType == "T" ) {
		this.smfDialog("_auto", "pa_scr_ctr_cr::scr_ctrcr00_p00.xfdl", popupParams, null, null, 800, 865);
	}
	else if ( this.objApp.gv_appScreenType == "M" ) {
		this.smfDialog("_auto", "pa_scr_ctr_cr::scr_ctrcr00_p00.xfdl", popupParams, null, null, 480, 852);
	}
	else {
		this.smfDialog("_auto", "pa_scr_ctr_cr::scr_ctrcr00_p00.xfdl", popupParams, null, null, 842, 630);
	}

	// 모달팝업 실행
	//this.smfDialog("_auto", "pa_scr_ctr_cr::scr_ctrcr00_p00.xfdl", popupParams);
};


/**
 * @description 취소 버튼 클릭 이벤트
*/
this.btnCancle_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(obj.text == "취소"){
		
		if(this.fv_job_type == "U"){
			// 수정시 취소 버튼은 상세화면으로 이동해야함
			var schpaDscsnDtcNo = this.dsDscsnParam.getColumn(0, "schpaDscsnDtcNo")
			var params = {menu : "3011",_url : "pa_scr_mri_cl::scr_mricl00_m01.xfdl", schpaDscsnDtcNo : schpaDscsnDtcNo, listFlagI : "N"};
			this.smfSetWorkPage(params._url, params, null, null);
		}else{
			// 취소 시 메인으로 이동
			var sUrl   = "frame::scr/frameWorkMain.xfdl";
			var params = {menu : "MAIN",_url:sUrl};
			this.smfSetWorkPage(sUrl, params, null, "처음화면");
		}
		
	}else if(obj.text == "목록으로"){
	
		var pv_params = this.smfGetFormParams();	// 이전창의 Parameter 가져오기	
		var params = {
			menu : "3010"
			,_url : "pa_scr_mri_cl::scr_mricl00_m00.xfdl"
			, dsDscsnParam : pv_params.dsDscsnListParam
			, dsPageInfo : pv_params.dsPageInfo
			, listFlag : "Y"
		};
		this.smfSetWorkPage(params._url, params, null, null);
		
	}
};

/**
 * @description 희망 교(직)원 삭제 버튼 클릭 이벤트
*/
this.divMain_btnDelThts_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 이미 선택된 상담 희망 교(직)원 삭제
	this.divMain.form.staThtsFlnm.set_text();
	this.divMain.form.staThtsFlnm.set_visible(false);
	obj.set_visible(false);
	this.dsDscsnParam.setColumn(0, "dscsnDmndThtsDtcNo", null);
	this.dsDscsnParam.setColumn(0, "dscsnDmndThtsFlnm", null);
	
	// 예약희망일시 삭제
	this.divMain.form.staDscsnDmndDtFr.set_text();
	this.divMain.form.staDscsnDmndDtFr.set_visible(false);
	this.divMain.form.btnDelDmndDtFr.set_visible(false);

	this.divMain.form.staDscsnDmndDtSe.set_text();
	this.divMain.form.staDscsnDmndDtSe.set_visible(false);
	this.divMain.form.btnDelDmndDtSe.set_visible(false);

	this.divMain.form.staDscsnDmndDtTh.set_text();
	this.divMain.form.staDscsnDmndDtTh.set_visible(false);
	this.divMain.form.btnDelDmndDtTh.set_visible(false);

	this.dsDscsnParam.setColumn(0, "dscsnDmndDtSize", null);
};

/**
 * @description 예약희망일시 삭제 버튼 클릭 이벤트
*/
this.divMain_btnDelDmndDt_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var dtArray = [];
	
	if(obj.id != "btnDelDmndDtFr" && !this.smfIsNull(this.divMain.form.staDscsnDmndDtFr.text)){
		dtArray.push(this.divMain.form.staDscsnDmndDtFr.text);
	}
	
	if(obj.id != "btnDelDmndDtSe" && !this.smfIsNull(this.divMain.form.staDscsnDmndDtSe.text)){
		dtArray.push(this.divMain.form.staDscsnDmndDtSe.text);
	}
	
	if(obj.id != "btnDelDmndDtTh" && !this.smfIsNull(this.divMain.form.staDscsnDmndDtTh.text)){
		dtArray.push(this.divMain.form.staDscsnDmndDtTh.text);
	}
	
	this.divMain.form.staDscsnDmndDtFr.set_text();
	this.divMain.form.staDscsnDmndDtFr.set_visible(false);
	this.divMain.form.btnDelDmndDtFr.set_visible(false);

	this.divMain.form.staDscsnDmndDtSe.set_text();
	this.divMain.form.staDscsnDmndDtSe.set_visible(false);
	this.divMain.form.btnDelDmndDtSe.set_visible(false);

	this.divMain.form.staDscsnDmndDtTh.set_text();
	this.divMain.form.staDscsnDmndDtTh.set_visible(false);
	this.divMain.form.btnDelDmndDtTh.set_visible(false);
	
	for(var idx = 0; idx < dtArray.length; idx++){
		if(idx == 0){
			this.divMain.form.staDscsnDmndDtFr.set_text(dtArray[idx]);
			this.divMain.form.staDscsnDmndDtFr.set_visible(true);
			this.divMain.form.btnDelDmndDtFr.set_visible(true);
		}else if(idx == 1){
			this.divMain.form.staDscsnDmndDtSe.set_text(dtArray[idx]);
			this.divMain.form.staDscsnDmndDtSe.set_visible(true);	
			this.divMain.form.btnDelDmndDtSe.set_visible(true);
		}else if(idx == 2){
			this.divMain.form.staDscsnDmndDtTh.set_text(dtArray[idx]);
			this.divMain.form.staDscsnDmndDtTh.set_visible(true);				
			this.divMain.form.btnDelDmndDtTh.set_visible(true);
		}
	}
	
	this.dsDscsnParam.setColumn(0, "dscsnDmndDtSize", dtArray.length);
};


// 취소 버튼이 목록으로 버튼으로 변경된 후에 이벤트 
this.btnList_onclick = function(obj:nexacro.Button,e:nexacro.KeyEventInfo, pv_params)
{
	var params = {
