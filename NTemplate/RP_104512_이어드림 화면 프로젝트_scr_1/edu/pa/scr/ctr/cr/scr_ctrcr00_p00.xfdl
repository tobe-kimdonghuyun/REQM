this.divMain_btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);	
};



this.divTitle_grd1_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	
	var nCell = e.cell;
	var rdbCell = 4;
	if(this.smfIsMobile()){
		rdbCell = 19;
	}
/*	
	this.dsResult.setColumn(e.row,"check",-1);

	for(var i = 0; i < this.dsResult.getRowCount(); i++){
		if(i !=e.row){
			this.dsResult.setColumn(i,"check",undefined);
		}
	}
*/
	if(nCell==rdbCell||nCell==19){
			// 부모창 전달
			this.smfSendResponseToOpener({
				"tcrIdfId" : this.dsResult.getColumn( this.dsResult.rowposition ,"tcrIdfId"),
				"tcrNm" : this.dsResult.getColumn( this.dsResult.rowposition ,"tcrNm"),
				"damdanggwamok" : this.dsResult.getColumn( this.dsResult.rowposition ,"damdanggwamok"),
				"jbpsNm" : this.dsResult.getColumn( this.dsResult.rowposition ,"jbpsNm"),
				"userDtcNo" : this.dsResult.getColumn( this.dsResult.rowposition ,"userDtcNo"),

			});
			this.close(true);	
	}
	
	
};
 this.fnDisplayText = function(obj,nCell,nRow,sLongText)
{	
//	trace("=============================================================================================================");
//	trace("obj.get_id() ::: " + obj.id );
//	trace("sLongText ::: " + sLongText );
//	trace("sLongText.length ::: " + sLongText.length );
//	trace("=============================================================================================================");

	var objId = obj.id;
	var sSize;

	if ( this.objApp.gv_appScreenType == "M" ) { // 모바일
			sSize = 15;		
	}else if ( this.objApp.gv_appScreenType == "T" ) { // 태블릿
			sSize = 10;	
	}else {
			sSize = 12;	
	}		

	return this.scrDisplayText(sLongText, sSize);
};]]></Script>
  </Form>
</FDL>
