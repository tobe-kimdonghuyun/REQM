/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::scr_script.xjs";
this.objApp = nexacro.getApplication();
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/


/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.scrInitForm(obj);	//필수(화면초기화)
	this.listPrcrInfo(obj);
};

this.fnTransCallback= function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
  this.listPrcrInfo = function(obj, e)
{
	this.dsResult.clearData();

	this.dsParam.setColumn(0, 'shlCd', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'shlCd'));
	this.dsParam.setColumn(0, 'ayr',  nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'ayr'));
	this.dsParam.setColumn(0, 'shlKndScCd', nexacro.getApplication().gdsScrLgnInfo.getColumn(0, 'shlKndScCd'));
	this.dsParam.setColumn(0,'cthrTcrIdfId',nexacro.getApplication().gdsScrLgnChildList.lookup("chcYn", "Y", "cthrTcrIdfId") )
	this.dsParam.setColumn(0, 'stbSbjtNm', this.divTitle.form.divSearch.form.edtGwa.value);
	this.dsParam.setColumn(0, 'tcrNm', this.divTitle.form.divSearch.form.edtPrcr.value);
	
	// 서비스 객체 생성
	this.smfSearchService("listPrcrInfo")	
		.showConfirm(false)
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;

		});	
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.divMain_divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.listPrcrInfo();
};
