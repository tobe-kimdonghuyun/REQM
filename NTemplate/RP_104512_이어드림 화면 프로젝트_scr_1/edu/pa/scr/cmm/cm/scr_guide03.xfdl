        <Static id="Static03" taborder="11" text="01" left="0" top="Div00_00_00_00:34" width="40" height="40" cssclass="sta_WF_Step"/>
        <Static id="Static02" taborder="12" text="로그인/자녀 선택" left="Static03:10" top="Div00_00_00_00:34" height="40" right="0" cssclass="sta_WF_StepTitle"/>
        <Static id="Static02_00" taborder="13" text="자녀가 재학 중인 학교가 자동으로 처리기관으로 지정됩니다." left="Static03:10" top="Static02:8" height="40" right="0" cssclass="sta_WF_StepTxt" fittocontents="height"/>
        <ImageViewer id="ImageViewer00" taborder="14" left="0" top="Static02_00:32" height="0" right="0" image="url('theme::neisScr/images/img_WF_Guide01_1.png')" stretch="fixaspectratio" cssclass="img_WF_Guide"/>
        <Static id="Static03_00" taborder="15" text="02" left="0" top="ImageViewer00:34" width="40" height="40" cssclass="sta_WF_Step"/>
        <Static id="Static02_01" taborder="16" text="신청서 작성/제출" left="Static03_00:10" top="ImageViewer00:34" height="40" right="0" cssclass="sta_WF_StepTitle"/>
        <Static id="Static02_00_00" taborder="17" text="메뉴위치: 학교상담&gt;온라인(서면)상담&#13;&#10;성명,연락처, 상담제목, 상담내용, 희망교(직)원 선택 등으로 신청서를 작성/제출합니다." left="50" top="Static02_01:8" height="40" right="0" cssclass="sta_WF_StepTxt" fittocontents="height"/>
        <ImageViewer id="ImageViewer00_00" taborder="18" left="0" top="Static02_00_00:32" height="0" right="0" image="url('theme::neisScr/images/img_WF_Guide01_1.png')" stretch="fixaspectratio" cssclass="img_WF_Guide"/>
        <Static id="Static03_00_00" taborder="19" text="03" left="0" top="ImageViewer00_00:34" width="40" height="40" cssclass="sta_WF_Step"/>
        <Static id="Static02_01_00" taborder="20" text="접수/처리" left="Static03_00_00:10" top="ImageViewer00_00:34" height="40" right="0" cssclass="sta_WF_StepTitle"/>
        <Static id="Static02_00_00_00" taborder="21" text="학교 민원대응팀은 나이스 업무시스템에서 접수(담당자배정)처리 합니다.&#13;&#10;배정된 처리담당자는 상담에 대한 답변을 등록합니다. " left="50" top="Static02_01_00:8" height="40" right="0" cssclass="sta_WF_StepTxt" fittocontents="height"/>
        <ImageViewer id="ImageViewer00_00_00" taborder="22" left="0" top="Static02_00_00_00:32" height="0" right="0" image="url('theme::neisScr/images/img_WF_Guide01_1.png')" stretch="fixaspectratio" cssclass="img_WF_Guide"/>
        <Static id="Static03_00_00_00" taborder="23" text="04" left="0" top="ImageViewer00_00_00:34" width="40" height="40" cssclass="sta_WF_Step"/>
        <Static id="Static02_01_00_00" taborder="24" text="결과확인" left="Static03_00_00_00:10" top="ImageViewer00_00_00:34" height="40" right="0" cssclass="sta_WF_StepTitle"/>
        <Static id="Static02_00_00_00_00" taborder="25" text="신청한 온라인(서면)상담의 처리 진행상태를 확인합니다.&#13;&#10;진행상태가 완료시 답변을 확인합니다." left="50" top="Static02_01_00_00:8" height="40" right="0" cssclass="sta_WF_StepTxt" fittocontents="height"/>
        <ImageViewer id="imgEnd" taborder="26" left="0" top="Static02_00_00_00_00:32" height="0" right="0" image="url('theme::neisScr/images/img_WF_Guide01_1.png')" stretch="fixaspectratio" cssclass="img_WF_Guide"/>
      </Layout>
