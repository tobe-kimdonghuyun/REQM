  <Form id="scr_guide03" width="1320" height="5285" titletext="이용가이드 집중상담" onload="form_onload">
    <Layouts>
      <Layout height="5285" width="1320" screenid="desktopScr">
        <Static id="Static00" taborder="0" text="이어드림에서는 학부모가 온라인으로 상담내용을 작성하고 답변 받을 수 있는 서비스입니다. " left="12" top="36" height="32" right="0" cssclass="sta_WF_Txt22M" fittocontents="height"/>
        <Static id="Static00_00" taborder="1" left="0" top="Static00:13" cssclass="sta_WF_GuideInfo" height="150" right="0" text="※ 유의사항 &#13;&#10;· 온라인에 상담문의 시 개인정보나 민감정보가 포함하지 않도록 유의바랍니다.&#13;&#10;· 상담보호법에 따라 온라인 상담 내용에 폭언 및 욕설 내용이 있을 경우 고발될 수 있습니다. &#13;&#10;· 국민신문고와 같은 “민원성”업무가 아닙니다. 민원제기시 국민신문고를 이용하시기 바랍니다." fittocontents="height" onclick="Static00_00_onclick"/>
        <Static id="Static00_01" taborder="2" text="온라인(서면)상담 절차 안내" left="12" top="Static00_00:28" height="32" right="0" cssclass="sta_WF_Txt22M"/>
        <Button id="Button00" taborder="3" text="제출 및 결과확인 안내 영상" top="Static00_00:24" width="231" height="40" cssclass="btn_WF_Crud01" right="0"/>
        <Div id="Div00" taborder="4" text="Div00" left="0" top="Static00_01:16" width="22%" height="270" cssclass="div_WF_Guide">
