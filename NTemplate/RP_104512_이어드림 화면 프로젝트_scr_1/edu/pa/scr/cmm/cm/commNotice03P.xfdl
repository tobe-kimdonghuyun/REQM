<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="commNotice03P" width="518" height="518" titletext="안내공지" onload="commNotice03P_onload">
    <Layouts>
      <Layout height="518" width="518" screenid="desktopScr">
        <ImageViewer id="ImageViewer00" taborder="0" left="0" top="0" height="150" right="0" stretch="fixaspectratio" image="url('theme::neisScr/images/img_popup_1.png')"/>
        <Static id="title" taborder="1" text="대국민서버점검 안내" left="0" top="ImageViewer00:40" height="60" cssclass="sta_WF_Title,sta_WF_TxtCenter" accessibilityrole="heading" right="0"/>
        <Div id="divNotice" taborder="2" text="내용" left="0" top="title:10" bottom="80" right="0">
          <Layouts>
            <Layout>
              <Static id="subTitle" taborder="0" text="서버 점검 안내 공지드립니다." left="0" top="0" cssclass="sta_WF_TxtCenter" right="0" bottom="0"/>
            </Layout>
            <Layout name="mobile">
              <Static id="subTitle" cssclass="sta_WF_TxtCenter"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnLink" taborder="3" text="공고 자세히 보기" height="40" width="30.31%" cssclass="btn_WF_Crud04" initvalueid="iv_Button" bottom="10" left="34.94%" onclick="btnLink_onclick"/>
      </Layout>
      <Layout height="660" mobileorientation="Landscape" name="mobile" type="default" width="410" screenid="mobileScr,tabletScr,desktopScr">
        <Button id="btnLink" left="28.84%" width="158" height="40" bottom="10"/>
        <ImageViewer id="ImageViewer00" left="0" top="0" height="100" right="0"/>
        <Static id="title" left="0" top="ImageViewer00:20" height="82" right="0" text="대국민서버점검&#13;&#10;안내"/>
        <Div id="divNotice" top="title:20" left="0" right="0" bottom="80"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  학부모소통시스템 
*  @MenuPath    pa_scr_cmm_cm
*  @FileName 	commNotice03P.xfdl
*  @Creator 	tobesoft
*  @CreateDate 	2025.04.23
*  @Desction    안내 공지 팝업
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2025.04.23     	tobesoft 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/


/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/


/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/

this.commNotice03P_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	
	var popupCn = this.parent.params.popupCn;
	
	if(popupCn.length >= 85)
	{
		popupCn = popupCn.substr(0,85) + "...";
	}
	
	this.title.set_text(this.parent.params.eventTitlNm);		//팝업타이틀
	this.btnLink.set_text(this.parent.params.lnkNm);			//팝업 버튼 명
	this.ImageViewer00.set_accessibilitylabel(this.parent.params.rplcText);	//팝업 이미지 대체 텍스트
	this.divNotice.form.subTitle.set_text(popupCn); //팝업 내용
	if(this.parent.params.lnkTypCd == '0'){	//링크유형이 없을 경우 버튼 숨김
		this.btnLink.set_visible(false);
	}
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/


/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
this.btnLink_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.getOwnerFrame().form.commNoticeAll.form.fnClickEvt(obj,e);	//링크 클릭시 이벤트
};
]]></Script>
  </Form>
</FDL>
