              <Static id="Static01" taborder="1" text="상시상담 예약" left="0" top="126" height="32" right="0" cssclass="sta_WF_GuideTitle" onclick="Div00_00_Static01_onclick"/>
              <Static id="Static01_00" taborder="2" text="상담 제목과 상담내용, 방법&#13;&#10;(방문,유선), 교(직)원 및 희망일시 선택 등으로 상담예약 신청" left="15" top="Static01:8" right="15" cssclass="sta_WF_GuideTxt" bottom="0"/>
            </Layout>
            <Layout name="tablet"/>
            <Layout name="mobile">
              <Static id="Static01_00" left="10" top="Static01:8" right="10" bottom="0"/>
