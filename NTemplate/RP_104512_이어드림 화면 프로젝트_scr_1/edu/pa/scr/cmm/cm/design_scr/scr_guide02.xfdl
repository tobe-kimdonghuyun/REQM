<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="scr_guide02" width="1320" height="5285" titletext="이용가이드 집중상담">
    <Layouts>
      <Layout height="5285" width="1320" screenid="desktopScr">
        <Static id="Static00" taborder="0" text="학부모소통서비스에서는 학교별 집중상담주간에 방문/유선상담을 예약할 수 있습니다." left="12" top="36" height="32" right="0" cssclass="sta_WF_Txt22M" fittocontents="height"/>
        <Static id="Static00_00" taborder="1" left="0" top="Static00:13" cssclass="sta_WF_GuideInfo" height="215" right="0" text="1. 담임교사의 일정을 확인 한 후 방문상담 또는 유선상담을 예약할 수 있습니다.&#13;&#10;2. 다른 학부모가 예약되어 있는 시간에는 예약할 수 없습니다.&#13;&#10;3. 유선상담의 경우 예약확정 후 신청시 등록한 연락처로 수신받을 수 있습니다.&#13;&#10;&#13;&#10;단, 아래의 경우는 집중상담 예약 신청 대상이 아닙니다.&#13;&#10;· 담임교사외의 교(직)원을 대상으로 예약을 할 수 없습니다.&#13;&#10;· 휴일, 수업시간 등 교(직)원이 상담이 불가능한 시간은 예약을 할 수 없습니다" fittocontents="height"/>
        <Static id="Static00_01" taborder="2" text="집중상담예약 절차 안내" left="12" top="Static00_00:28" height="32" right="0" cssclass="sta_WF_Txt22M"/>
        <Button id="Button00" taborder="3" text="집중상담예약신청 안내 영상" top="Static00_00:24" width="238" height="40" cssclass="btn_WF_Crud01" right="0"/>
        <Div id="Div00" taborder="4" text="Div00" left="0" top="Static00_01:16" width="22%" height="270" cssclass="div_WF_Guide">
          <Layouts>
