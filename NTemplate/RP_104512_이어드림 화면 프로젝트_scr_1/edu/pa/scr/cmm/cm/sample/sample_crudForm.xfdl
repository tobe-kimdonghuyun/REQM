    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  학부모소통시스템
*  @MenuPath    공통
*  @FileName 	sample_crudForm.xfdl
*  @Creator 	tobesoft
*  @CreateDate 	2025.03.17
*  @Desction    공통코드조회 샘플
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2025.03.17     	tobesoft 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::scr_script.xjs";	//SCR공통라이브러리(필수)

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.objApp = nexacro.getApplication();

/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.scrInitForm(obj);	//화면초기화 공통함수(필수)
	
	this.fnInitForm(obj);
};

this.fnInitForm = function(obj)
{
	/*
	콤포넌트 정합성 검사로직
	- objComp.validate => required,maxlength:5 형식으로 구현
	- 라벨찾는 순서(prForm.smfGetLabelOf)
		1. validate 표현식에서 검색 (required,title:아이디)
		2. accessibilitylabel에서 검색
		3. 동일 container에 소속한 Static 컴포넌트에서 refinputcomponent 속성이 component의 name과 일치
		4. 동일 container에 소속한 Static대상으로 component.taborder보다 작은 탭오더를 가진 Static
	*/
	//validation설정(divSearch)
	this.divSearch.form.edtId.validate = "required";
	//validation설정(divMain)
	this.divMain.form.edtId.validate = "required";
	this.divMain.form.edtName.validate = "required";
	this.divMain.form.edtArtist.validate = "required";
	this.divMain.form.calRelease.validate = "required";
	this.divMain.form.cboTypeCode.validate = "required";
	this.divMain.form.cboGenreCode.validate = "required";
	this.divMain.form.cboGrade.validate = "required";	
	
	this.smfSetFirstCode(this.dsGenreScCd);
	this.smfSetFirstCode(this.dsTypeCode); 
	this.smfSetFirstCode(this.dsGrade); 
	
	this.smfSetEnable(this.btnDelete, false);
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 트랜잭션 서비스 콜백(필수)
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	//trace("svcid==="+svcid + "::::errcd==="+errcd + "::::errmsg==="+errmsg);
	//if(errcd == -1) return;
};

// 팝업 콜백
this.fnPopupCallback = function(e, sender)
{
	//trace("fnPopupCallback >>>>");
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/


/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// 조회 버튼 클릭
this.div_search_btn_search_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 서비스 객체 생성
	this.smfSearchService("select")
		// 데이터 검증
		.validateForm(this.divSearch)
		// 데이터가 변경되었으면 확인메시지
		.confirmIfModifiedDataset(this.dsMain)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;			

			this.smfSetEnable(this.btnDelete, true);
			if(this.dsMain.rowcount == 0){
				this.btnDelete.set_enable(false);
				this.scrAlert("해당 가수를 찾을 수 없습니다");
			}
		});
};

// 버튼 추가 이벤트
this.btn_add_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 데이터 클리어
	this.dsMain.clearData();
	// row추가
	var nRow = this.dsMain.addRow();
	// 컬럼 초기화("")
	this.smfInitRow(this.dsMain, nRow); 
	
	// id항목 disable
	this.divMain.form.edtId.set_enable(false);
	this.btnDelete.set_enable(false);
};

// 저장버튼 클릭 
this.btn_save_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 서비스 객체 생성 
	this.smfSaveService("save")
		// 데이터 존재 필수(저장할 데이터가 없습니다.)
		//.requireExistsData(this.dsMain) 
		// 데이터 검증
		.validateForm(this.divMain)
		// 데이터 변경 필수(변경된 데이터가 없어서 저장할 수 없습니다.)
		//.requireModifredData(this.dsMain)  
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;

			// 저장이 완료되었습니다.
			// 재조회
			this.scrAlert('CM002', [],  function(){
				// 조회 수행
				this.divSearch.form.btnSearch.click();
			});
		});
};

// 삭제 버튼 클릭
this.btn_delete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 삭제처리
	this.smfDeleteService("delete")
		// 데이터 존재 필수
		.requireExistsData(this.dsMain) 
		// 삭제를 위한 검증수행
		.validateFormDelete(this.divMain)
		.run()
		// 콜백
		.callback(function(callbackParams){ 
			if(callbackParams.errors) {
				alert('[참고] 본 샘플에서 데이터 삭제는 서버에서 동작하지 않도록 처리하였습니다');
			}
		});
};
 
// 조회조건이 변경된 경우
this.dsSearch_oncolumnchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{

};

this.divSearch_sta00_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	this.divSearch.form.edtId.set_value( obj.text );
};

this.divMain_btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfRequired(this.divMain.form.edtName, true);
};

this.divMain_btn00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfRequired(this.divMain.form.edtName, false);
};
this.btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
		trace(this._dsValidationRuleset.saveXML());
		trace("검증==="+this.divSearch.form.edtId.validate);
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.edtId" propid="value" datasetid="dsSearch" columnid="id"/>
      <BindItem id="item3" compid="divMain.form.edtId" propid="value" datasetid="dsMain" columnid="id"/>
      <BindItem id="item1" compid="divMain.form.edtName" propid="value" datasetid="dsMain" columnid="name"/>
      <BindItem id="item2" compid="divMain.form.edtArtist" propid="value" datasetid="dsMain" columnid="artist"/>
      <BindItem id="item10" compid="divMain.form.mskPrice" propid="value" datasetid="dsMain" columnid="price"/>
      <BindItem id="item11" compid="divMain.form.mskDownCnt" propid="value" datasetid="dsMain" columnid="downCnt"/>
      <BindItem id="item12" compid="divMain.form.mskListenCnt" propid="value" datasetid="dsMain" columnid="listenCnt"/>
      <BindItem id="item4" compid="divMain.form.cboTypeCode" propid="value" datasetid="dsMain" columnid="typeCode"/>
      <BindItem id="item5" compid="divMain.form.cboGenreCode" propid="value" datasetid="dsMain" columnid="genreCode"/>
      <BindItem id="item7" compid="divMain.form.cboGrade" propid="value" datasetid="dsMain" columnid="grade"/>
      <BindItem id="item6" compid="divMain.form.calRelease" propid="value" datasetid="dsMain" columnid="release"/>
    </Bind>
  </Form>
</FDL>
