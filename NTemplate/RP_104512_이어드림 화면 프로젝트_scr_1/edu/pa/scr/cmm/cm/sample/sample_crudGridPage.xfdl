<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sample_crudGridPage" width="1340" height="720" titletext="그리드 저장(페이징)샘플" onload="form_onload">
    <Layouts>
      <Layout height="720" width="1340">
        <Static id="staMain" taborder="0" text="사용자관리" left="20" cssclass="sta_Ctitle" top="6" right="90" height="40" font="bold 20px/normal &quot;Consolas&quot;"/>
        <Grid id="grdMain" taborder="1" top="230" height="396" binddataset="dsMain" autofittype="col" scrollbardecbuttonsize="0" scrollbarincbuttonsize="0" left="20" right="0" autoupdatetype="comboselect" autoenter="select" onheadclick="grdMain_onheadclick">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="27"/>
                <Column size="48"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="34" band="head"/>
                <Row size="34"/>
              </Rows>
              <Band id="head">
                <Cell displaytype="checkboxcontrol" edittype="checkbox"/>
                <Cell col="1" text="순번"/>
                <Cell col="2" text="아이디"/>
                <Cell col="3" text="성명"/>
                <Cell col="4" text="아티스트"/>
                <Cell col="5" text="음반릴리즈"/>
                <Cell col="6" text="앨범타입"/>
                <Cell col="7" text="장르"/>
                <Cell col="8" text="등급"/>
                <Cell col="9" text="가격"/>
                <Cell col="10" text="다운로드횟수"/>
                <Cell col="11" text="청취횟수"/>
              </Band>
              <Band id="body">
                <Cell text="bind:_chk" displaytype="checkboxcontrol" edittype="checkbox" checkboxfalsevalue="0" checkboxtruevalue="1"/>
                <Cell col="1" text="expr:currow+1" textAlign="center"/>
                <Cell col="2" text="bind:id" edittype="none"/>
                <Cell col="3" text="bind:name" edittype="text" editautoselect="false"/>
                <Cell col="4" text="bind:artist" edittype="text" editautoselect="false"/>
                <Cell col="5" text="bind:release" edittype="date" editautoselect="true" displaytype="date" calendareditformat="yyyy.MM.dd" calendarautoselect="true" calendardisplayinvalidtype="none" calendardisplaynulltype="none" calendardateformat="yyyy.MM.dd"/>
                <Cell col="6" text="bind:typeCode" edittype="combo" editautoselect="true" combodataset="dsTypeCode" combocodecol="cdcValue" combodatacol="cdcValueNm" displaytype="combocontrol"/>
                <Cell col="7" text="bind:genreCode" edittype="combo" editautoselect="true" displaytype="combocontrol" combodataset="dsGenreScCd2" combocodecol="cdcValue" combodatacol="cdcValueNm" combotype="filterlike"/>
                <Cell col="8" text="bind:grade" edittype="combo" editautoselect="true" combodataset="dsGrade" combocodecol="cdcValue" combodatacol="cdcValueNm" displaytype="combocontrol" combotype="filterlike"/>
                <Cell col="9" text="bind:price" edittype="text" editautoselect="true" displaytype="number" maskeditformat="###,##0"/>
                <Cell col="10" text="bind:downCnt" edittype="text" editautoselect="true" maskeditformat="###,##0" displaytype="number"/>
                <Cell col="11" text="bind:listenCnt" edittype="text" editautoselect="true" maskeditformat="###,##0" displaytype="number"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Div id="divSearch" taborder="2" left="5" top="61" height="119" text="" right="0">
          <Layouts>
            <Layout>
              <Static id="sta_01" taborder="6" left="79" top="6" cssclass="sta_WF_tablebg" width="265" height="34"/>
              <Static id="sta_02" taborder="0" text="사용자명" left="20" top="6" cssclass="sta_WF_tablelabel" width="80" height="34"/>
              <Static id="sta_03" taborder="2" text="아티스트" left="353" top="6" cssclass="sta_WF_tablelabel" width="80" height="34"/>
              <Static id="sta_04" taborder="7" left="472" top="6" cssclass="sta_WF_tablebg" width="225" height="34"/>
              <Edit id="edtName" taborder="1" text="-선택-" left="110" top="6" height="34" leftbase="" topbase="" bottombase="" rightbase="" widthbase="" heightbase="" innerdataset="@ds_dep" codecolumn="code" datacolumn="data" scrollbarbarminsize="20" value="" index="-1" scrollbarbaroutsize="20" scrollbarsize="10" scrollbartrackbarsize="25" itemheight="20" width="223"/>
              <Static id="sta_06" taborder="4" text="장르" left="696" top="6" cssclass="sta_WF_tablelabel" width="80" height="34"/>
              <Static id="sta_16" taborder="8" left="845" top="6" cssclass="sta_WF_tablebg" width="225" height="34"/>
              <Combo id="cboGenreCode" taborder="5" top="6" height="34" leftbase="" topbase="" bottombase="" rightbase="" widthbase="" heightbase="" width="203" innerdataset="dsGenreScCd" codecolumn="cdcValue" datacolumn="cdcValueNm" left="760"/>
              <Edit id="edtArtist" taborder="3" text="-선택-" left="450" top="6" height="34" leftbase="" topbase="" rightbase="" widthbase="" heightbase="" innerdataset="@ds_dep" codecolumn="code" datacolumn="data" value="" index="-1" scrollbarbaroutsize="20" scrollbarsize="10" scrollbartrackbarsize="25" itemheight="20" width="203" validate="maxlength:20"/>
              <Button id="btnSearch" taborder="9" text="페이징검색-기본" top="6" height="34" width="196" right="0" onclick="div_search_btn_search_onclick"/>
              <Button id="btnSearch00" taborder="10" text="페이징검색-함수이용" top="46" height="34" width="196" right="0" onclick="divSearch_btnSearch00_onclick" visible="false"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnDelete" taborder="4" text="삭제" top="185" height="34" width="76" right="0" onclick="btn_delete_onclick"/>
        <Button id="btnSave" taborder="3" text="저장" top="185" height="34" width="76" right="btnDelete:1" onclick="btn_save_onclick"/>
        <Button id="btnAdd" taborder="5" text="추가" top="185" height="34" width="76" right="btnSave:1" onclick="btn_add_onclick"/>
        <Div id="divPaginator" taborder="6" left="20" height="32" url="comm::comp_paginatorScr.xfdl" pageViewSize="100" dsPage="dsPageInfo" right="0" top="grdMain:10" text=""/>
        <Div id="divPageSummary" taborder="7" left="20" top="180" width="430" height="40" url="comm::comp_pageSummaryScr.xfdl"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsOrdScCode" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="firstCode" type="STRING" size="30" value=""/>
          <ConstColumn id="filterExpr" type="STRING" size="30" value=""/>
          <ConstColumn id="clsfCode" type="STRING" size="30" value="ORD_SC_CODE"/>
          <ConstColumn id="userDfnSet" type="STRING" size="30" value=""/>
          <Column id="cdcValue" type="STRING" size="30"/>
          <Column id="cdcValueNm" type="STRING" size="120"/>
          <Column id="cdcValueAbrvNm" type="STRING" size="150"/>
          <Column id="codeValueSeq" type="BIGDECIMAL" size="10"/>
          <Column id="upperClsfCodeValue" type="STRING" size="30"/>
          <Column id="upperCdcValue" type="STRING" size="30"/>
          <Column id="userDfnCodeValue01" type="STRING" size="100"/>
          <Column id="userDfnCodeValue02" type="STRING" size="100"/>
          <Column id="userDfnCodeValue03" type="STRING" size="100"/>
          <Column id="userDfnCodeValue04" type="STRING" size="100"/>
          <Column id="userDfnCodeValue05" type="STRING" size="100"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="inDatasets">search=dsSearch pageInfo=dsPageInfo</Col>
            <Col id="outDatasets">dsMain=main dsPageInfo=pageInfo</Col>
            <Col id="asynctp"/>
            <Col id="url">cmc_sam_pl13_001.do</Col>
            <Col id="id">list</Col>
          </Row>
          <Row>
            <Col id="inDatasets">main=dsMain:U</Col>
            <Col id="outDatasets"/>
            <Col id="asynctp"/>
            <Col id="url">cmc_sam_pl13_002.do</Col>
            <Col id="id">save</Col>
          </Row>
          <Row>
            <Col id="inDatasets">main=dsMain</Col>
            <Col id="outDatasets"/>
            <Col id="asynctp"/>
            <Col id="url">cmc_sam_pl13_003.do</Col>
            <Col id="id">delete</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" oncolumnchanged="dsSearch_oncolumnchanged">
        <ColumnInfo>
          <Column id="name" type="STRING" size="150"/>
          <Column id="genreCode" type="STRING" size="1"/>
          <Column id="artist" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="name"/>
            <Col id="genreCode"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true">
        <ColumnInfo>
          <Column id="_chk" type="STRING" size="1"/>
          <Column id="_pageRow" type="STRING" size="256"/>
          <Column id="id" type="STRING" size="256"/>
          <Column id="name" type="STRING" size="256"/>
          <Column id="artist" type="STRING" size="256"/>
          <Column id="release" type="STRING" size="256"/>
          <Column id="typeCode" type="STRING" size="256"/>
          <Column id="genreCode" type="STRING" size="256"/>
          <Column id="grade" type="STRING" size="256"/>
          <Column id="price" type="STRING" size="256"/>
          <Column id="downCnt" type="STRING" size="256"/>
          <Column id="listenCnt" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSecurity" useclientlayout="true">
        <ColumnInfo>
          <Column id="key" size="255" type="STRING"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="key">sample_select</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsGenreScCd" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="firstCode" size="30" type="STRING" value="ALL"/>
          <ConstColumn id="filterExpr" size="30" type="STRING" value=""/>
          <ConstColumn id="clsfCode" size="30" type="STRING" value="GENRE_SC_CD"/>
          <ConstColumn id="userDfnSet" size="30" type="STRING" value=""/>
          <Column id="cdcValue" size="30" type="STRING"/>
          <Column id="cdcValueNm" size="120" type="STRING"/>
          <Column id="cdcValueAbrvNm" size="150" type="STRING"/>
          <Column id="cdcValueSn" size="10" type="BIGDECIMAL"/>
          <Column id="cmmnCdYn" type="STRING" size="256"/>
          <Column id="stnrdCdYn" type="STRING" size="256"/>
          <Column id="upperClsfCdValue" size="30" type="STRING"/>
          <Column id="upperCdcValue" size="30" type="STRING"/>
          <Column id="userDfnCdValue01" size="100" type="STRING"/>
          <Column id="userDfnCdValue02" size="100" type="STRING"/>
          <Column id="userDfnCdValue03" size="100" type="STRING"/>
          <Column id="userDfnCdValue04" size="100" type="STRING"/>
          <Column id="userDfnCdValue05" size="100" type="STRING"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="cdcValue">1</Col>
            <Col id="cdcValueNm">댄스</Col>
          </Row>
          <Row>
            <Col id="cdcValue">2</Col>
            <Col id="cdcValueNm">발라드</Col>
          </Row>
          <Row>
            <Col id="cdcValue">3</Col>
            <Col id="cdcValueNm">팝</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsGenreScCd2" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="firstCode" size="30" type="STRING" value="EMP"/>
          <ConstColumn id="filterExpr" size="30" type="STRING" value=""/>
          <ConstColumn id="clsfCode" size="30" type="STRING" value="GENRE_SC_CD"/>
          <ConstColumn id="userDfnSet" size="30" type="STRING" value=""/>
          <Column id="cdcValue" size="30" type="STRING"/>
          <Column id="cdcValueNm" size="120" type="STRING"/>
          <Column id="cdcValueAbrvNm" size="150" type="STRING"/>
          <Column id="cdcValueSn" size="10" type="BIGDECIMAL"/>
          <Column id="cmmnCdYn" type="STRING" size="256"/>
          <Column id="stnrdCdYn" type="STRING" size="256"/>
          <Column id="upperClsfCdValue" size="30" type="STRING"/>
          <Column id="upperCdcValue" size="30" type="STRING"/>
          <Column id="userDfnCdValue01" size="100" type="STRING"/>
          <Column id="userDfnCdValue02" size="100" type="STRING"/>
          <Column id="userDfnCdValue03" size="100" type="STRING"/>
          <Column id="userDfnCdValue04" size="100" type="STRING"/>
          <Column id="userDfnCdValue05" size="100" type="STRING"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="cdcValue">1</Col>
            <Col id="cdcValueNm">댄스</Col>
          </Row>
          <Row>
            <Col id="cdcValue">2</Col>
            <Col id="cdcValueNm">발라드</Col>
          </Row>
          <Row>
            <Col id="cdcValue">3</Col>
            <Col id="cdcValueNm">팝</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsGrade" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="firstCode" size="30" type="STRING" value="EMP"/>
          <ConstColumn id="filterExpr" size="30" type="STRING" value=""/>
          <ConstColumn id="clsfCode" size="30" type="STRING" value="GRADE"/>
          <ConstColumn id="userDfnSet" size="30" type="STRING" value=""/>
          <Column id="cdcValue" size="30" type="STRING"/>
          <Column id="cdcValueNm" size="120" type="STRING"/>
          <Column id="cdcValueAbrvNm" size="150" type="STRING"/>
          <Column id="cdcValueSn" size="10" type="BIGDECIMAL"/>
          <Column id="cmmnCdYn" type="STRING" size="256"/>
          <Column id="stnrdCdYn" type="STRING" size="256"/>
          <Column id="upperClsfCdValue" size="30" type="STRING"/>
          <Column id="upperCdcValue" size="30" type="STRING"/>
          <Column id="userDfnCdValue01" size="100" type="STRING"/>
          <Column id="userDfnCdValue02" size="100" type="STRING"/>
          <Column id="userDfnCdValue03" size="100" type="STRING"/>
          <Column id="userDfnCdValue04" size="100" type="STRING"/>
          <Column id="userDfnCdValue05" size="100" type="STRING"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="cdcValue">1</Col>
            <Col id="cdcValueNm">최정상</Col>
          </Row>
          <Row>
            <Col id="cdcValue">2</Col>
            <Col id="cdcValueNm">가능성있는</Col>
          </Row>
          <Row>
            <Col id="cdcValue">3</Col>
            <Col id="cdcValueNm">신입</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsTypeCode" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="firstCode" size="30" type="STRING" value="SEL"/>
          <ConstColumn id="filterExpr" size="30" type="STRING" value=""/>
          <ConstColumn id="clsfCode" size="30" type="STRING" value="TYPE_CODE"/>
          <ConstColumn id="userDfnSet" size="30" type="STRING" value=""/>
          <Column id="cdcValue" size="30" type="STRING"/>
          <Column id="cdcValueNm" size="120" type="STRING"/>
          <Column id="cdcValueAbrvNm" size="150" type="STRING"/>
          <Column id="cdcValueSn" size="10" type="BIGDECIMAL"/>
          <Column id="cmmnCdYn" type="STRING" size="256"/>
          <Column id="stnrdCdYn" type="STRING" size="256"/>
          <Column id="upperClsfCdValue" size="30" type="STRING"/>
          <Column id="upperCdcValue" size="30" type="STRING"/>
          <Column id="userDfnCdValue01" size="100" type="STRING"/>
          <Column id="userDfnCdValue02" size="100" type="STRING"/>
          <Column id="userDfnCdValue03" size="100" type="STRING"/>
          <Column id="userDfnCdValue04" size="100" type="STRING"/>
          <Column id="userDfnCdValue05" size="100" type="STRING"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="cdcValue">1</Col>
            <Col id="cdcValueNm">정규앨범</Col>
          </Row>
          <Row>
            <Col id="cdcValue">2</Col>
            <Col id="cdcValueNm">미니앨범</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsPageInfo" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="initPageIndex" type="INT" size="30" value="1"/>
          <ConstColumn id="initPageSize" type="INT" size="30" value="4"/>
          <Column id="pageIndex" type="INT" size="256"/>
          <Column id="pageSize" type="INT" size="256"/>
          <Column id="totalCount" type="INT" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsMainValid" useclientlayout="true">
        <ColumnInfo>
          <Column id="_chk" type="STRING" size="1"/>
          <Column id="id" type="STRING" size="256" prop="NONE"/>
          <Column id="name" type="STRING" size="256"/>
          <Column id="artist" type="STRING" size="256"/>
          <Column id="release" type="STRING" size="256"/>
          <Column id="typeCode" type="STRING" size="256"/>
          <Column id="genreCode" type="STRING" size="256"/>
          <Column id="grade" type="STRING" size="256"/>
          <Column id="price" type="STRING" size="256"/>
          <Column id="downCnt" type="STRING" size="256"/>
          <Column id="listenCnt" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id"/>
            <Col id="name">title:사용자이름,required,minlength:2,maxlength:100</Col>
            <Col id="artist">required,minlength:2,maxlength:100</Col>
            <Col id="release">required,date</Col>
            <Col id="price">required,digits:6</Col>
            <Col id="downCnt">required,digits:8</Col>
            <Col id="listenCnt">required,digits:8</Col>
            <Col id="typeCode">required</Col>
            <Col id="genreCode">required</Col>
            <Col id="grade">required</Col>
          </Row>
          <Row>
            <Col id="id">title:아이디,required</Col>
            <Col id="name">=</Col>
            <Col id="artist">=</Col>
            <Col id="release">=</Col>
            <Col id="price">=</Col>
            <Col id="downCnt">=</Col>
            <Col id="listenCnt">=</Col>
            <Col id="typeCode">=</Col>
            <Col id="genreCode">=</Col>
            <Col id="grade">=</Col>
            <Col id="_chk"/>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  학부모소통시스템
*  @MenuPath    공통
*  @FileName 	sample_crudGridPage.xfdl
*  @Creator 	tobesoft
*  @CreateDate 	2025.03.17
*  @Desction    그리드 저장(페이징)
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2025.03.17     	tobesoft 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::scr_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/


/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.scrInitForm(obj);	//필수(화면초기화)
	
	//페이지 레코드 size
	this.divPageSummary.form.fnSetInitPageSize(10);
	
	////////////////////////////////////////////
	// 샘플을 위한  함수 호출
	// 장르 콤보에 "전체"를 추가한다
	this.smfSetFirstCode(this.dsGenreScCd);
	// 장르 콤보에 ""를 추가한다
	this.smfSetFirstCode(this.dsGenreScCd2);
	// 등급 콤보에 ""를 추가한다
	this.smfSetFirstCode(this.dsGrade);
	////////////////////////////////////////////

	// Grid Checkbox 활성화/활성화 제어
	this.smfUpdateRednerGridCheckbox(this.grdMain, 0, this.fnRenderGridCheckbox); 

	// 조회 입력창에서 'Ctrl' + 'Enter' 키 입력시 조회수행 이벤트 설정
	this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
};


/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	if(errcd == -1) return;
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 그리드 체크박스 enable 예외처리
this.fnRenderGridCheckbox = function(ds, nRow){
	// '아이유' 데이터는 삭제 불가
    return this.dsMain.getColumn(nRow, "artist") != "아이유";
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// 페이징검색-기본
this.div_search_btn_search_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 서비스 객체 생성
	this.smfSearchService("list")
		// 페이징처리
		.paginator(this.grdMain, this.divPaginator, this.divPageSummary, this.dsPageInfo, obj, e)
		// 데이터가 변경되었으면 확인메시지
		.confirmIfModifiedGrid(this.grdMain)
		// 데이터 검증
		.validateForm(this.divSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			//if(callbackParams.errors) return;

			this.divPageSummary.form.fnDisplayTotalText(this.dsPageInfo.getColumn(0, "totalCount"));
		})
	;
};

