*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::scr_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/


/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.scrInitForm(obj);	//필수(화면초기화)
};


/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.fnSearch = function(obj, e)
{
	
	// 서비스 객체 생성
	this.smfSearchService("select")		
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			var rowCount = this.ds00.getRowCount();
			console.log(rowCount);
		});	
};

this.fnSearch2 = function(obj, e)
{
	
	// 서비스 객체 생성
	this.smfSearchService("select2")		
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			var rowCount = this.ds00.getRowCount();
			console.log(rowCount);
		});	
};

this.scr_mpgmv00_m01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitForm(this);
	this.fnSearch();
	alert("msg");
	//this.fnSearch2();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};

this.btn99 = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	alert("현재 프로젝트(cloud.pa)에서 조회가능한 expertDB가 없습니다.")
	//this.smfInitForm(this);
	//this.fnSearch2();
};
]]></Script>
  </Form>
</FDL>
