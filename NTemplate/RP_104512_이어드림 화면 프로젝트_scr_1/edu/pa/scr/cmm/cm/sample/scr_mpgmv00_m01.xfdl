<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="scr_mpgmv00_m01" width="1280" height="745" titletext="임시 조회 화면" onload="form_onload">
    <Layouts>
      <Layout height="745" mobileorientation="landscape" width="1280">
        <Div id="div00" taborder="0" text="div00" left="21" top="10" width="1064" height="317" onclick="div00_onclick">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" text="expertDB(PostgreSQL) 조회 결과" left="20" top="260" width="202" height="32" onclick="div00_sta00_onclick"/>
              <Button id="btn00" taborder="1" text="대국민 DB 조회 테스트" left="219" top="255" width="225" height="43" onclick="btn99"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta00" taborder="1" text="17개 시도 교육청 코드 조회 결과" left="50" top="20" width="1113" height="37" onclick="sta00_onclick"/>
        <Grid id="grd00" taborder="2" left="37" top="61" width="1117" height="119" binddataset="ds00">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="206"/>
                <Column size="329"/>
                <Column size="498"/>
              </Columns>
              <Rows>
                <Row size="24" band="head"/>
                <Row size="24"/>
              </Rows>
              <Band id="head">
                <Cell text="orgCd"/>
                <Cell col="1" text="kornOrgNm"/>
                <Cell col="2" text="chk"/>
              </Band>
              <Band id="body">
                <Cell text="bind:orgCd"/>
                <Cell col="1" text="bind:kornOrgNm"/>
                <Cell col="2" text="bind:chk"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Grid id="grd01" taborder="3" left="43" top="313" width="801" height="149" binddataset="ds01">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row band="head" size="24"/>
                <Row size="24"/>
              </Rows>
              <Band id="head">
                <Cell text="seqidx"/>
                <Cell col="1" text="subject"/>
                <Cell col="2" text="qry"/>
                <Cell col="3" text="mailform"/>
                <Cell col="4" text="mailto"/>
                <Cell col="5" text="replyto"/>
                <Cell col="6" text="rname"/>
              </Band>
              <Band id="body">
                <Cell text="bind:seqidx"/>
                <Cell col="1" text="bind:subject"/>
                <Cell col="2" text="bind:qry"/>
                <Cell col="3" text="bind:mailform"/>
                <Cell col="4" text="bind:mailto"/>
                <Cell col="5" text="bind:replyto"/>
                <Cell col="6" text="bind:rname"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="ds00" useclientlayout="true">
        <ColumnInfo>
          <Column id="orgCd" type="STRING" size="256"/>
          <Column id="kornOrgNm" type="STRING" size="256"/>
          <Column id="chk" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256"/>
          <Column id="outDatasets" type="STRING" size="256"/>
          <Column id="asynctp" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">select</Col>
            <Col id="url">/scr_mpg_mv00_001.do</Col>
            <Col id="inDatasets">dsSearch</Col>
            <Col id="outDatasets">ds00</Col>
          </Row>
          <Row>
            <Col id="id">select2</Col>
            <Col id="url">/scr_mpg_mv00_004.do</Col>
            <Col id="inDatasets">dsSearch</Col>
            <Col id="outDatasets">ds01</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="testCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="testCd">100</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="ds01" useclientlayout="true">
        <ColumnInfo>
          <Column id="seqidx" type="STRING" size="256"/>
          <Column id="subject" type="STRING" size="256"/>
          <Column id="qry" type="STRING" size="256"/>
          <Column id="mailform" type="STRING" size="256"/>
          <Column id="mailto" type="STRING" size="256"/>
          <Column id="replyto" type="STRING" size="256"/>
          <Column id="rname" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  학부모소통시스템
