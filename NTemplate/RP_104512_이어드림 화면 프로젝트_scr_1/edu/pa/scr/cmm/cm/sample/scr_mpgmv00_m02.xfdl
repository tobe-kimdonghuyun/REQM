/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::scr_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/


/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.scrInitForm(obj);	//필수(화면초기화)
};


/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.fnSearchApi = function(obj, e)
{
	
	// 서비스 객체 생성
	this.smfSearchService("selectApiTest")		
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			var a = this.dsResult2.getColumn(0, "svcId");
			var b = this.dsResult2.getColumn(0, "INVL_NO");
			var c = this.dsResult2.getColumn(0, "jsessionidTest");
			trace("================================================");
			trace("API 호출 결과 Log");
			trace(a);
			trace(b);
			trace(c);
			trace("================================================");
			//this.grd00_00.
		});	
};

this.fnSearchApi2 = function(obj, e)
{
	
	// 서비스 객체 생성
	this.smfSearchService("selectApiTest2")		
		.run()// 실행
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			var a = this.dsResult2.getColumn(0, "svcId");
			var b = this.dsResult2.getColumn(0, "INVL_NO");
			var c = this.dsResult2.getColumn(0, "jsessionidTest");
			trace("================================================");
			trace("API 호출 결과 Log");
			trace(a);
			trace(b);
			trace(c);
			trace("================================================");
			//this.grd00_00.
		});	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};

this.btn01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var reqValue = this.edt00.value;
	this.dsSearch.addRow();
	this.dsSearch.setColumn(0, "INVL_NO", reqValue);
	
	alert("api 통신테스트 진행합니다.");
	this.smfInitForm(this);
	this.fnSearchApi();
};

this.btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var reqValue = this.edt00.value;
	this.dsSearch.addRow();
	this.dsSearch.setColumn(0, "INVL_NO", reqValue);
	
	alert("api 통신테스트 진행합니다.");
	this.smfInitForm(this);
	this.fnSearchApi2();
};
]]></Script>
  </Form>
