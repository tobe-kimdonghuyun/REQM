    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    유아 조회
*  @FileName 	par_spscm00_m01.xfdl
*  @Creator 	안배식
*  @CreateDate 	2023.02.10
*  @Desction    유치원 학부모서비스 - 유치원 조회
************** 소스 수정 이력 ***********************************************
*  date				Modifier				Description
*******************************************************************************
*  2023.02.10		안배식					최초 생성
*******************************************************************************
*/

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::cm_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
var cddcScCd;

/************************************************************************************************
 * FORM EVENT 영역(onload)
 ************************************************************************************************/
/**
 * @description 화면 onload시 처리
 */
this.par_spscm00_m01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	//this.smfInitPopup(obj);
	
	//this.smfUpdatePopupTitle("팝업테스트");
	
	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	
	
	trace("---------------------------------------------------------------");
	trace("팝업");
	trace("21this.pv_params.dataset ::: {}", this.pv_params.dataset );
	trace("221this.pv_params.param1 ::: " + this.pv_params.param1 );
	trace("21this.pv_params.param2 ::: " + this.pv_params.param2 );
	trace("---------------------------------------------------------------");
	
	
	// 전달받은 파라메터 설정
	this.dsPopMain.copyData(this.pv_params.dataset);
	this.divClaiInfo.form.edtStuFlnm.set_value(this.pv_params.param1);
	this.dsSearch.setColumn(0, "stuFlnm",   this.pv_params.param2);

		
};

/************************************************************************************************
 * TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
};



/**
 * @description 엔터키실행
 */
this.fnKeyUp = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode=='13'){
		this.divSearch_btnSearch_onclick();
	}
};

this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (this.divClaiInfo.form.edtStuFlnm.text == '') {
		this.smfAlert('검색하실 유아의 이름을 입력하세요.');
		this.divClaiInfo.form.edtStuFlnm.setFocus();
		return false;
	}

	if (this.divClaiInfo.form.edtClsNm.text == '') {
		this.smfAlert('검색하실 유아의 학급명을 입력하세요.');
		this.divClaiInfo.form.edtClsNm.setFocus();
		return false;
	}
	

/*
	this.dsSearch.setColumn(0, "shlCd", this.divClaiInfo.form.edtShlCd.value);
	this.dsSearch.setColumn(0, "stuFlnm", this.divClaiInfo.form.edtStuFlnm.text);
	this.dsSearch.setColumn(0, "brdt", this.divClaiInfo.form.calClaiBrdt.value);
	this.dsSearch.setColumn(0, "clsNm", this.divClaiInfo.form.edtClsNm.text);
	this.dsSearch.setColumn(0, "cddcScCd", this.cddcScCd);

	this.smfSearchService("selectStuList")
		.run() // 실행
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.dsResult.getRowCount() > 0){
				this.div00.form.grdStuList.setFocus();
			}		

		});
*/
	this.smfSendResponseToOpener({
		"userId": this.dsPopMain.getColumn(e.row, "userId"),
		"userNm": this.dsPopMain.getColumn(e.row, "userNm"),
		"connectNo": this.dsPopMain.getColumn(e.row, "connectNo"),
		"userTypCd": this.dsPopMain.getColumn(e.row, "userTypCd"),
		"grd": this.dsPopMain.getColumn(e.row, "grd"),
		"dddepCd": this.dsPopMain.getColumn(e.row, "dddepCd"),
		"clsCd": this.dsPopMain.getColumn(e.row, "clsCd"),
		"ordScNm": this.dsPopMain.getColumn(e.row, "ordScNm"),
		"grdNm": this.dsPopMain.getColumn(e.row, "grdNm")
	});	
	
	this.close(true);
		
};

this.btn_close_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/
]]></Script>
    <Bind>
      <BindItem id="item4" compid="divClaiInfo.form.edtClaiAddrDetail" propid="accessibilitylabel" datasetid="dsMain" columnid="ClaiAddr"/>
