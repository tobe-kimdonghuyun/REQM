              <Edit id="edtStuFlnm" taborder="2" left="88" top="20" height="30" text="3e3e" width="280" cssclass="essential" initvalueid="ivEdtEssential" accessibilitylabel="유아명" maxlength="80" imemode="hangul"/>
              <Button id="btnSearch" taborder="1" text="팝업콜백테스트" top="60" width="160" height="30" cssclass="btn_WF_Search03" right="20" onclick="divSearch_btnSearch_onclick" initvalueid="ivBtnAccessibilityButton"/>
