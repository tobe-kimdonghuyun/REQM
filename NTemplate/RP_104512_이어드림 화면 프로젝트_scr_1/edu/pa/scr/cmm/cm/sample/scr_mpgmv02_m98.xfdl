<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="scr_mpgmv02_m02" width="1340" height="913" titletext="학부모소통서비스 intro">
    <Layouts>
      <Layout height="913" width="1340" screenid="desktopScr">
        <Static id="Static00" taborder="0" text="서비스소개" left="20" top="0" height="95" cssclass="sta_WF_Title" accessibilityrole="heading" right="0"/>
        <Static id="Static00_00" taborder="1" text="학부모 소통 서비스(이어드림, eardream.neis.go.kr)는" left="20" top="105" height="43" cssclass="sta_WF_Txt36M" accessibilityrole="heading" right="0" letterSpacing="-1px"/>
        <Static id="Static00_00_00" taborder="2" text="학부모서비스에 가입된 정보를 기반으로 학교 교(직)원과의 상담을 위한 예약(방문,유선)과 온라인(서면) 상담 서비스를 제공합니다.&#10;학부모는 로그인 후 자녀의 학교정보를 기반으로 서비스를 이용합니다." left="20" top="Static00_00:28" height="50" cssclass="sta_WF_Txt20M32L,sta_WF_Col333" accessibilityrole="heading" right="0" fittocontents="height" letterSpacing="-1px"/>
        <Static id="Static00_00_00_00" taborder="3" text="&lt;fs v='19'&gt;&lt;b v='true'&gt;&lt;fc v='#21409A'&gt;“이어드림”&lt;/fc&gt;&lt;/b&gt;&lt;/fs&gt;은 서비스 명칭으로 귀 기울여듣다(ear)와 소통으로 희망을 드림(dream)을 의미합니다." left="20" top="Static00_00_00:30" height="30" cssclass="sta_WF_Txt20M32L,,sta_WF_Col333" accessibilityrole="heading" right="0" fittocontents="height" usedecorate="true" letterSpacing="-1px"/>
        <ImageViewer id="ImageViewer00" taborder="4" left="20" top="453" width="360" height="461" image="url('theme::neisScr/images/sta_MF_IntroImg07.svg')" stretch="fixaspectratio" imagealign="left bottom" accessibilityenable="false"/>
        <ImageViewer id="ImageViewer00_00" taborder="5" top="361" width="321" height="227" image="url('theme::neisScr/images/sta_MF_IntroImg08.svg')" stretch="fixaspectratio" imagealign="right top" right="0" accessibilityenable="false"/>
