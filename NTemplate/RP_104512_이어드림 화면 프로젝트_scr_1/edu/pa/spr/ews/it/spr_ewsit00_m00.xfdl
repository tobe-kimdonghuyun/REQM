    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    샘플
*  @FileName 	sampleExcelExportImport.xfdl
*  @Creator 	정인혁
*  @CreateDate 	2022.9.21
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.9.21     	정인혁 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	//파라미터 세팅
	//=======================================
	// 업로드관련 초기설정을 한다.
	//=======================================
	// 업로드시 저장위치등을 판별할 정보 세팅(대문자 : 시스템코드(2)+"."+서브시스템코드(3)+"."+대분류코드(3))
	this.divFileUpload.UPLOAD_CreateComplete = this.fnEventUploadCreateComplete;  // 필요한 경우만 세팅
	this.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;        // 필요한 경우만 세팅(세팅권장)
	this.divFileUpload.UPLOAD_OnError        = this.fnEventUploadError;           // 필요한 경우만 세팅(세팅권장)
	this.divFileUpload.UPLOAD_AfterAddFile   = this.fnEventUploadAfterAddFile;
	
	this.divFileUpload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)
	
	
	// 공통코드의 코드구분
	this.smfCodeList("code", [this.dsApsFamRelCd])
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.cbo01.set_index(0);
		});
	
};


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
};

/**
 * raonkupload가 화면을 생성된 이후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @return : N/A
 */
this.fnEventUploadCreateComplete = function(obj,paramObj)
{
};

/**
 * raonkupload가 파일을upload한 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @param : objResultDataset
 * @return : N/A
 */
this.fnEventUploadComplete = function(obj,paramObj,objResultDataset)
{
	// 업로드 초기화
	this.divFileUpload.form.fnResetUpload();
	
	if(objResultDataset != null){
		for(var i = 0; i < objResultDataset.getRowCount(); i++){
			var row = this.dsOutFileinfo.addRow();
			this.dsOutFileinfo.copyRow(row, objResultDataset, i);
		}
	}
	
};

/**
 * raonkupload가 파일을upload실패 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @return : N/A
 */
this.fnEventUploadError = function(obj,paramObj)
{
};

/**
 * raonkupload가 파일을 추가 후 발생 콜백함수
 * @param : obj
 * @param : paramObj
 * @param : sCustomValue
 * @param : sFileName
 * @param : nFileSize
 * @return : N/A
 */
this.fnEventUploadAfterAddFile = function(obj,paramObj,sCustomValue,sFileName,nFileSize)
{
	this.divFileUpload.form.fnFileUpload();
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/


this.btnExport_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objOption = {
						objGrid : this.grdExport    // [필수] export할 그리드 오브젝트
					,   sheetname : "양식시트1"       // [필수] export할 시트명
					,   filename : "정산양식 내려받기"   // [필수] export할 파일이름
					//,   startcell : "A1"            // [선택] 그리드를 export를 할 시작 위치(default="A1")
					//,   exporttype : "select"    // [선택] "select": 팝업에서 유저가 선택, nexacro.ExportTypes.EXCEL2007(default)  , nexacro.ExportTypes.HANCELL2014 , nexacro.ExportTypes.CSV  , 
					};
	
	this.smfExcelExport(objOption);
};





this.btnFileSelect_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
	if(this.cbo01.index == 0 && (this.edt01.value == null || this.edt01.value == "" || this.edt01.value == "undefined")){
		this.alert("통신사를 직접입력하세요.");
		return false;
	}
	
	this.divFileUpload.form.fnAddFile();
};

this.cbo01_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	if( obj.value == "00" ){
		this.edt01.set_visible(true);
	}else{
		this.edt01.set_visible(false);
	}
	
	this.edt01.set_value(null);
};
]]></Script>
