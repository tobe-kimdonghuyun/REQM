              <Static id="sta01_01" taborder="6" left="0" top="grdDetail:94" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" onclick="sta01_onclick"/>
