<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="hes_mlebb00_p00" left="0" top="0" width="1000" height="834" titletext="강사게시표" onload="fnOnload">
    <Layouts>
      <Layout screenid="ScreenDeskTop">
        <Static id="Static99_00_00_00_00_01_00_00_00_01_00_00_00" taborder="0" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" initvalueid="ivStcAccessibilityOff" height="834"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_01_00_00_00_00" taborder="1" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" right="0" initvalueid="ivStcAccessibilityOff" height="834"/>
        <Div id="divInsrInfo" taborder="2" text="div00" left="20" top="0" width="960" height="880">
          <Layouts>
            <Layout>
              <Grid id="grdDetail" taborder="0" left="0" top="187" right="0" binddataset="dsList" autofittype="col" selecttype="cell" initvalueid="ivGrdAccessibilityOn" scrolldisplaymode="normal" autosizingtype="none" autosizebandtype="allband" height="460" extendsizetype="row">
                <Formats>
                  <Format id="default">
                    <Columns>
                      <Column size="50"/>
                      <Column size="90"/>
                      <Column size="50"/>
                      <Column size="50"/>
                      <Column size="100"/>
                      <Column size="150"/>
                      <Column size="50"/>
                      <Column size="150"/>
                      <Column size="100"/>
                    </Columns>
                    <Rows>
                      <Row size="62" band="head"/>
                      <Row size="40"/>
                    </Rows>
                    <Band id="head">
                      <Cell text="일련&#13;&#10;번호"/>
                      <Cell col="1" text="성명"/>
                      <Cell col="2" text="성별"/>
                      <Cell col="3" text="연령"/>
                      <Cell col="4" text="생년월일"/>
                      <Cell col="5" text="학력&#13;&#10;(전공과목)"/>
                      <Cell col="6" text="경력"/>
                      <Cell col="7" text="소지&#13;&#10;자격증"/>
                      <Cell col="8" text="채용일" cssclass="LineNo"/>
                    </Band>
                    <Band id="body">
                      <Cell text="expr:currow+1" textAlign="center"/>
                      <Cell col="1" text="bind:insrNm" textAlign="center" autosizerow="limitmin"/>
                      <Cell col="2" textAlign="center" text="bind:sxds"/>
                      <Cell col="3" text="expr:dataset.parent.setAgeText((dataset.getColumn(currow, 'age')).substr(0,7))" textAlign="center"/>
                      <Cell col="4" text="expr:dataset.parent.setBrdtText((dataset.getColumn(currow, 'brdt')).substr(0,7))" textAlign="center" displaytype="date" calendardateformat="yyyy.MM.dd" calendareditformat="yyyy.MM.dd"/>
                      <Cell col="5" text="expr:dataset.parent.setAcbgText(currow)" textAlign="center" autosizerow="limitmin"/>
                      <Cell col="6" text="bind:cmptnCnt" textAlign="center"/>
                      <Cell col="7" text="bind:qlflNm" textAlign="center" autosizerow="limitmin"/>
                      <Cell col="8" textAlign="center" text="bind:empmnYmd" calendardateformat="yyyy.MM.dd" displaytype="date" calendareditformat="yyyy.MM.dd" cssclass="LineNo"/>
                    </Band>
                  </Format>
                </Formats>
              </Grid>
              <Static id="staTopText00" taborder="1" top="grdDetail:18" height="43" text="「학원의 설립ㆍ운영 및 과외교습에 관한 법률」 제13조제2항에 따라 강사의 인적사항을 위와 같이 게시합니다." wordWrap="char" width="960" initvalueid="ivStcAccessibilityOn" usedecorate="false" cssclass="sta_WF_Black14" textAlign="left" onclick="sta00_00_01_01_onclick" right="0"/>
              <Static id="Static99_00_00_00_00_01_00_00_00_01_00_01" taborder="2" left="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" top="grdDetail:0"/>
              <Static id="Static99_00_00_00_00_01_00_00_00_01_00_01_00" taborder="3" left="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" top="grdDetail:51"/>
