              <Static id="staTopText" taborder="13" top="20" height="23" text="■ 학원의 설립ㆍ운영 및 과외교습에 관한 법률 시행규칙 [별지 제15호서식] &lt;개정 2019. 1. 10.&gt;" wordWrap="char" width="800" initvalueid="ivStcAccessibilityOn" usedecorate="false" cssclass="sta_WF_Black14" textAlign="left" onclick="sta00_00_01_01_onclick" right="160"/>
              <Static id="sta01_00" taborder="14" left="0" top="45" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" onclick="sta01_onclick"/>
              <Button id="btnClose" taborder="15" text="닫기" height="30" width="50" left="94.79%" initvalueid="ivBtnAccessibilityButton" top="20" onclick="btnClose_onclick"/>
