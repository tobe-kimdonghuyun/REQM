    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 강사게시표
*  @MenuPath    TEMPLATE
*  @FileName 	hes_mlebb00_p00.xfdl
*  @Creator 	최경진
*  @CreateDate 	2023.02.03
*  @Desction    강사게시표
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2023.02.03     	최경진 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 폼 초기화 이벤트
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{	
	// default 초기처리를 한다.
	this.smfInitPopup(obj);

	// 파라메터 셋
	this.pv_params = this.smfGetPopupParams();
	
	this.dsSearch.setColumn(0,"acaDsgnNo",this.pv_params.acaDsgnNo);
	this.dsSearch.setColumn(0,"acaInstiScCd",this.pv_params.acaInstiScCd);
	this.dsSearch.setColumn(0,"cddcOrgCd",this.pv_params.cddcOrgCd.substring(0,3)+"0000001");
	
	// 팝업 타이틀 변경
	this.smfUpdatePopupTitle("강사게시표");	

	// 공통코드 호출
	this.smfCodeList("code", [this.dsAcbgCd])
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;	
		
		// 강사정보조회
		this.listInsrPstChit();		
	});	
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 강사게시표 조회 함수
this.listInsrPstChit = function ()
{	
	this.smfSearchService("listInsrPstChit")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		if(this.dsList.getRowCount() < 1){
			this.smfAlert("게시된 강사가 없습니다.");
			this.close(false);
			return;
		}
	
		//학원명
		this.divInsrInfo.form.staAcaNm.set_text(this.pv_params.acaNm+" 설립ㆍ운영자");
		
		//현재날짜
		var today = this.smfToday();
		this.divInsrInfo.form.staNowDate.set_text(today.substr(0,4)+"년 "+today.substr(4,2)+"월 "+today.substr(6,2)+"일 현재");
		this.divInsrInfo.form.staNowDate2.set_text(today.substr(0,4)+"년 "+today.substr(4,2)+"월 "+today.substr(6,2)+"일");
		
		var rowSize = this.divInsrInfo.form.grdDetail.getRealRowFullSize();
		
		this.divInsrInfo.form.grdDetail.set_height(rowSize+3);
		
		this.smfResetScroll(this.divInsrInfo.form);
		
		this.set_height(760);
	});
};

//성별
this.setSxdsText = function(val){
	if(("1,3,5,7,9").indexOf(val) > -1){
		return "남";
	}else{
		return "여";
	}
}
//연령
this.setAgeText = function(val){
	var today = this.smfToday();
	var nowYr = today.substr(0,4);
	var brYr = val.substr(0,2);
	var gbn = val.substr(6,1);
	
	if(("1,2,5,6").indexOf(gbn) > -1){
		yy = "19";
	}else if(("3,4,7,8").indexOf(gbn) > -1){
		yy = "20";
	}
	return parseInt(nowYr)-parseInt(yy+brYr);
}
//생년월일
this.setBrdtText = function(val){
	var yy = "18";
	var brdt = val.substr(0,6);
	var gbn = val.substr(6,1);
	
	if(("1,2,5,6").indexOf(gbn) > -1){
		yy = "19";
	}else if(("3,4,7,8").indexOf(gbn) > -1){
		yy = "20";
	}
	
	return yy+brdt; 
}
//학력(전공과목)
this.setAcbgText = function(row){
	var acbgCd = this.dsList.getColumn(row,"invlAcbgCd");
	var uvstMjrNm = this.dsList.getColumn(row,"uvstMjrNm");
	var acbgIdx = this.dsAcbgCd.findRow("unyCdValue",acbgCd);
	var invlAcbgNm = this.dsAcbgCd.getColumn(acbgIdx,"unyCdValueNm");

	if(invlAcbgNm == undefined){
		invlAcbgNm = "";
	}
	
	if(uvstMjrNm != "" && uvstMjrNm != null){
		uvstMjrNm = "("+uvstMjrNm+")";
		return invlAcbgNm + uvstMjrNm;
	}else{
		return invlAcbgNm;
	}
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};

this.btnPrt_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//버튼 숨김처리 후 프린트
	this.divInsrInfo.form.btnPrt.set_visible(false);
	this.divInsrInfo.form.btnClose.set_visible(false);
	
	system.print(this);
	
	this.divInsrInfo.form.btnPrt.set_visible(true);
	this.divInsrInfo.form.btnClose.set_visible(true);
};
]]></Script>
  </Form>
</FDL>
