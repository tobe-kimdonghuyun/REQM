                    <Band id="head">
                      <Cell rowspan="2" text="교습과목" font="bold 14px/normal &quot;Arial&quot;"/>
                      <Cell col="1" rowspan="2" text="총교습시간&#13;&#10;(시간/주)" font="bold 14px/normal &quot;Arial&quot;"/>
