// 		var leMmCnt = this.dsList.getColumn(0,"leMmCnt");
// 		var lePrdDdCnt = this.dsList.getColumn(0,"lePrdDdCnt");
// 		var totlLeHrCnt = 0;
// 		
// 		if(totlLeHrMCnt > 0){
// 			if(leMmCnt > 0){
// 				if(lePrdDdCnt > 0){
// 					totlLeHrCnt = totlLeHrMCnt/(leMmCnt+(lePrdDdCnt/30))/4/60;
// 				}else{
// 					totlLeHrCnt = totlLeHrMCnt/leMmCnt/4/60;
// 				}
// 			}else{
// 				totlLeHrCnt = totlLeHrMCnt / 60;
// 			}
// 		}
// 		
// 		this.divThccPstChit.form.staTotlLeHrCnt.set_text(Math.round(totlLeHrCnt));
// 		
// 		//징수단위
// 		var lvesUnit = "-";
// 		
// 		if((leMmCnt*1)>0){
// 			lvesUnit = leMmCnt + "개월";
// 		}
// 		if((lePrdDdCnt*1)>0){
// 			lvesUnit = lvesUnit + lePrdDdCnt + "일";
// 		}
// 		
// 		this.divThccPstChit.form.staLvesUnit.set_text(lvesUnit);
		
		//설립자
		this.div00.form.staKornFlnm.set_text("설립ㆍ운영자 : "+this.dsList.getColumn(0,"kornFlnm"));
		
// 		//금액 format 지정
// 		var thccAmt = this.dsList.getColumn(0,"thccAmt");
// 		this.dsList.setColumn(0,"thccAmt",thccAmt.toString().replace(/\B(?=(\d{3})+(?!\d))/g,','));
// 		
// 		var moteEtcExps = this.dsList.getColumn(0,"moteEtcExps");
// 		this.dsList.setColumn(0,"moteEtcExps",moteEtcExps.toString().replace(/\B(?=(\d{3})+(?!\d))/g,','));
// 		
// 		var etcExpsTmc = this.dsList.getColumn(0,"etcExpsTmc");
// 		this.dsList.setColumn(0,"etcExpsTmc",etcExpsTmc.toString().replace(/\B(?=(\d{3})+(?!\d))/g,','));
// 		
// 		var etcExpsClex = this.dsList.getColumn(0,"etcExpsClex");
// 		this.dsList.setColumn(0,"etcExpsClex",etcExpsClex.toString().replace(/\B(?=(\d{3})+(?!\d))/g,','));
// 		
// 		var etcExpsLm = this.dsList.getColumn(0,"etcExpsLm");
// 		this.dsList.setColumn(0,"etcExpsLm",etcExpsLm.toString().replace(/\B(?=(\d{3})+(?!\d))/g,','));
// 		
// 		var etcExpsBrhsCst = this.dsList.getColumn(0,"etcExpsBrhsCst");
// 		this.dsList.setColumn(0,"etcExpsBrhsCst",etcExpsBrhsCst.toString().replace(/\B(?=(\d{3})+(?!\d))/g,','));
// 		
// 		var etcExpsTrex = this.dsList.getColumn(0,"etcExpsTrex");
// 		this.dsList.setColumn(0,"etcExpsTrex",etcExpsTrex.toString().replace(/\B(?=(\d{3})+(?!\d))/g,','));
