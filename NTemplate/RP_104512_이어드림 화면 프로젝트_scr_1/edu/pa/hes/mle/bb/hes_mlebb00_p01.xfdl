              <Static id="Static99_00_00_00_00_01_00_00_01" taborder="6" left="0" top="125" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Grid id="grd00" taborder="7" left="0" top="135" width="960" initvalueid="ivGrdAccessibilityOn" autofittype="col" binddataset="dsList" autosizebandtype="body" autosizingtype="row" height="309">
                <Formats>
