*******************************************************************************
*/
include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 폼 초기화 이벤트
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// default 초기처리를 한다.
	this.smfInitPopup(obj);

	// 파라메터 셋
	this.pv_params = this.smfGetPopupParams();
	
	this.dsSearch.setColumn(0,"acaDsgnNo",this.pv_params.acaDsgnNo);
	this.dsSearch.setColumn(0,"acaInstiScCd",this.pv_params.acaInstiScCd);
	this.dsSearch.setColumn(0,"cteOfcdcCd",this.pv_params.cteOfcdcCd);
	
	// 팝업 타이틀 변경
	this.smfUpdatePopupTitle("교습비등 게시표");	

	// 교습비등 게시표 정보 조회
	this.listThccPstChit();
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 학원정보 조회 함수
this.listThccPstChit = function ()
{	
	this.smfSearchService("listThccPstChit")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		if(this.dsList.getRowCount() < 1){
			alert("조회된 데이터가 없습니다.");
			this.close(false);
		}
		
		//현재날짜
		var today = this.smfToday();
		this.div00.form.staNowDate.set_text(today.substr(0,4)+"년 "+today.substr(4,2)+"월 "+today.substr(6,2)+"일 현재");
		this.div00.form.staPstChitDate.set_text(today.substr(0,4)+"년 "+today.substr(4,2)+"월 "+today.substr(6,2)+"일");

// 		//총교습시간 계산
