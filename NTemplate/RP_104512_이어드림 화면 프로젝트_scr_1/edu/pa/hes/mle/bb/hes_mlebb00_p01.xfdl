/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};

this.btnPrt_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//버튼 숨김처리 후 프린트
	this.div00.form.btnPrt.set_visible(false);
	this.div00.form.btnClose.set_visible(false);
	
	system.print(this);
	
	this.div00.form.btnPrt.set_visible(true);
	this.div00.form.btnClose.set_visible(true);
};

this.staPopupTitleAss_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	
};
]]></Script>
  </Form>
