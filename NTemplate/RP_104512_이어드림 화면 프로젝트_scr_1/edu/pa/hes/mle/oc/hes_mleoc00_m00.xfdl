    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 온라인사용자정보변경
*  @MenuPath    TEMPLATE
*  @FileName 	hes_mleoc00_m00.xfdl
*  @Creator 	HMH
*  @CreateDate 	2022.6.20
*  @Desction    온라인사용자정보변경

************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.6.20     	HMH 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs"
include "lib::hes_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 //this.fv_param;	//화면에서 넘어온 param값
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 *************************************************************************************************/
 //화면 접근 시 로그인정보 확인
this.fnOninit = function(obj:nexacro.Form,e:nexacro.EventInfo)
{
	this.hesSetGoUrl("pa_hes_mle_oc::hes_mleoc00_m00.xfdl");
};

this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);
	
	
	//화면전환시 전달된 파라메터
	/*this.fv_param = this.smfGetFormParams();
	try{
		trace(this.fv_param.messageId +" // "+ this.fv_param.useYn);
		this.divSearch.form.edtSearchMessageId.set_value(this.fv_param.messageId);
		this.divSearch.form.cboSearchUseYn.set_value(this.fv_param.useYn);
	} catch(e){
		trace(e.message);
	};*/
	
	//학원목록 조회
	// 학원 : 1, 교습소 : 2, 개인과외교습자 : 3
	var acaInstiScCd = this.hesGetAcaInstiScCd;
	var funrRrno = this.smfGetTrprRrno();
	
	this.dsSearch.setColumn(0,"acaInstiScCd",acaInstiScCd);	 
	this.dsSearch.setColumn(0,"acaDsgnNo",this.hesGetAcaDsgnNo);	 
	this.dsSearch.setColumn(0,"cteOfcdcCd",this.hesGetAtptOfcdcOrgCode);	 
	this.dsSearch.setColumn(0,"funrRrno",funrRrno);	
		
	if( acaInstiScCd == '1' || acaInstiScCd == '2' ){ 
		this.fnListAcademy();	
	}else{
		this.fnListInvlPrls();
	}
};

//그리드 셀클릭 이벤트
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{ 
	//선택한 셀만 체크박스 체크
	for (var i =0; i<this.dsMain.rowcount; i++) {
	
		if( i == e.row){ //선택한 셀 체크박스 체크
			this.dsMain.setColumn(e.row, "_chk", 1);
		}else{
			this.dsMain.setColumn(i, "_chk", 0);
		}
    }
	
	//데이터셋 초기화
	this.dsResult.clearData();
	this.dsResultTemp.clearData();
	
	var nRow = e.row;
	var objDs = obj.getBindDataset();
	var sAcaDsgnNo = objDs.getColumn(nRow,"acaDsgnNo");
	//var sRegDsgnNo = objDs.getColumn(nRow,"regDsgnNo");
	//사용자정보 조회시 필요한 값 셋팅
	this.dsSearch.setColumn(0,"acaDsgnNo",sAcaDsgnNo);
	this.dsSearch.setColumn(0,"funrRrno",this.dsMain.getColumn(nRow,"funrRrno"));	
	this.dsSearch.setColumn(0,"cteOfcdcCd",this.dsMain.getColumn(nRow,"cteOfcdcCd"));	
	this.dsSearch.setColumn(0,"acaInstiScCd",this.dsMain.getColumn(nRow,"acaInstiScCd"));		
	//사용자 정보 조회  
	this.fnSelectUserInfo();
	
};


//저장이벤트
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	//사용자 정보 변경  -> 나중에 세션값 설정 필요 DB쪽도 세션값가지고 수정자 정보 넣기
	this.fnUpdateUserInfo();
	
};


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};



/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 학원,교습소 목록 조회 Transaction
 */
 this.fnListAcademy = function () {
	
	this.smfSearchService("list")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
	});
	this.grdMain.setFormatColProperty(5,"size",99);
	this.staAcaNmHd.set_visible(true);
	this.staAcaNm.set_visible(true);
	//this.staFunrKornFlnm.set_width('346');
	
	this.staFunrMblTelnoHd.set_visible(true);
	this.cboFunrMblTelno1.set_visible(true);
	this.edtFunrMblTelno2.set_visible(true);
	this.edtFunrMblTelno3.set_visible(true);
	this.sta79.set_visible(true);
	this.sta99.set_visible(true);
 };
 /**
 * @description 개인과외교습자 목록 조회 Transaction
 */
 this.fnListInvlPrls = function () {
	// 임시 -  세팅
	//this.dsSearch.setColumn(0,"funrRrno","7422121234567");
	this.smfSearchService("list")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;		
	});
	this.grdMain.setFormatColProperty(5,"size",0);
	this.staAcaNmHd.set_visible(false);
	this.staAcaNm.set_visible(false);
	this.staFunrKornFlnm.set_right(0);
	this.staFunrMblTelnoHd.set_visible(false);
	this.cboFunrMblTelno1.set_visible(false);
	this.edtFunrMblTelno2.set_visible(false);
	this.edtFunrMblTelno3.set_visible(false);
	this.sta79.set_visible(false);
	this.sta99.set_visible(false);
 };
 
 /**
 * @description 사용자 정보 조회 Transaction
 */
  this.fnSelectUserInfo = function () {
  
  	//사용자정보 조회시 필요한 값 셋팅	
	//this.dsSearch.setColumn(0, "acaDsgnNo", this.hesGetAcaDsgnNo);	
	//this.dsSearch.setColumn(0, "acaInstiScCd", this.hesGetAcaInstiScCd);
	//this.dsSearch.setColumn(0, "cteOfcdcCd",this.hesGetAtptOfcdcOrgCode);	
	//this.dsSearch.setColumn(0, "atptOfcdcOrgCode", this.hesGetAtptOfcdcOrgCode);
  
	this.edtFaTelno1.set_readonly(true);
	this.edtFaTelno2.set_readonly(true);
	this.edtFaTelno3.set_readonly(true);
	
	this.smfSearchService("select")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;		


		if(this.smfIsNull(this.dsResult.getColumn(0, "regDsgnNo")) == true){
			this.smfAlert('온라인 사용자 정보가 없습니다.');
			return; 
		};

		//전화번호 "-"기준으로 자르기
		if ( !this.smfIsNull(this.dsResult.getColumn(0, "faTelno")) ) {
			var sFaTelno = this.dsResult.getColumn(0, "faTelno").split("-");
			
			this.dsResult.setColumn(0,"faTelno1", sFaTelno[0]);	
			this.dsResult.setColumn(0,"faTelno2", sFaTelno[1]);	
			this.dsResult.setColumn(0,"faTelno3", sFaTelno[2]);	
			this.dsResultTemp.setColumn(0,"faTelno1", sFaTelno[0]);	
			this.dsResultTemp.setColumn(0,"faTelno2", sFaTelno[1]);	
			this.dsResultTemp.setColumn(0,"faTelno3", sFaTelno[2]);	
		}
		if ( !this.smfIsNull(this.dsResult.getColumn(0, "invlMblTelno")) ) {
			var sInvlMblTelno = this.dsResult.getColumn(0, "invlMblTelno").split("-");
			this.dsResult.setColumn(0,"invlMblTelno1", sInvlMblTelno[0]);	
			this.dsResult.setColumn(0,"invlMblTelno2", sInvlMblTelno[1]);	
			this.dsResult.setColumn(0,"invlMblTelno3", sInvlMblTelno[2]);
			this.dsResultTemp.setColumn(0,"invlMblTelno1", sInvlMblTelno[0]);	
			this.dsResultTemp.setColumn(0,"invlMblTelno2", sInvlMblTelno[1]);	
			this.dsResultTemp.setColumn(0,"invlMblTelno3", sInvlMblTelno[2]);	
		}
		if ( !this.smfIsNull(this.dsResult.getColumn(0, "funrMblTelno")) ) {
			var sFunrMblTelno = this.dsResult.getColumn(0, "funrMblTelno").split("-");
			this.dsResult.setColumn(0,"funrMblTelno1", sFunrMblTelno[0]);	
			this.dsResult.setColumn(0,"funrMblTelno2", sFunrMblTelno[1]);	
			this.dsResult.setColumn(0,"funrMblTelno3", sFunrMblTelno[2]);
			this.dsResultTemp.setColumn(0,"funrMblTelno1", sFunrMblTelno[0]);	
			this.dsResultTemp.setColumn(0,"funrMblTelno2", sFunrMblTelno[1]);	
			this.dsResultTemp.setColumn(0,"funrMblTelno3", sFunrMblTelno[2]);	
		}
	
	});
 };
 
 /**
 * @description 사용자 정보 변경 Transaction
 */
 this.fnUpdateUserInfo = function () {
 
	//학원지정번호 셋팅
	this.dsSave.setColumn(0,"regDsgnNo",this.dsResult.getColumn(0,"regDsgnNo"));
	this.dsSave.setColumn(0,"acaDsgnNo",this.dsResult.getColumn(0,"acaDsgnNo"));
	this.dsSave.setColumn(0,"cteOfcdcCd",this.dsResult.getColumn(0,"cteOfcdcCd"));
	this.dsSave.setColumn(0,"acaInstiScCd",this.dsMain.getColumn(0,"acaInstiScCd"));
	this.dsSave.setColumn(0,"funrRrno",this.dsResult.getColumn(0,"funrRrno"));
	this.dsSave.setColumn(0,"invlDsgnNo",this.dsResult.getColumn(0,"invlDsgnNo"));
	
	if(this.smfIsNull(this.dsSave.getColumn(0, "regDsgnNo")) == true){
		this.smfAlert('변경 할 온라인 사용자 정보가 없습니다.');
		return; 
	};
	
	//이메일 셋팅
	this.dsSave.setColumn(0,"emlAddr",this.dsResult.getColumn(0,"emlAddr"));
	
	//설립자주민등록번호 셋팅
	this.dsSave.setColumn(0,"funrRrno",this.dsResult.getColumn(0,"funrRrno"));

	
	var vEmlAddr = this.dsResult.getColumn(0,"emlAddr");	
	var vEmlAddrTemp = this.dsResultTemp.getColumn(0,"emlAddr");
	
	var telno1 = this.dsResult.getColumn(0,"faTelno1");	
	var telno2 = this.dsResult.getColumn(0,"faTelno2");	
	var telno3 = this.dsResult.getColumn(0,"faTelno3");
	var telnoTemp1 = this.dsResultTemp.getColumn(0,"faTelno1");	
	var telnoTemp2 = this.dsResultTemp.getColumn(0,"faTelno2");	
	var telnoTemp3 = this.dsResultTemp.getColumn(0,"faTelno3");
	
	var mblTelno1 = this.dsResult.getColumn(0,"invlMblTelno1");	
	var mblTelno2 = this.dsResult.getColumn(0,"invlMblTelno2");	
	var mblTelno3 = this.dsResult.getColumn(0,"invlMblTelno3");	
	var mblTelnoTemp1 = this.dsResultTemp.getColumn(0,"invlMblTelno1");	
	var mblTelnoTemp2 = this.dsResultTemp.getColumn(0,"invlMblTelno2");	
	var mblTelnoTemp3 = this.dsResultTemp.getColumn(0,"invlMblTelno3");		
	
	var funrMblTelno1 = this.dsResult.getColumn(0,"funrMblTelno1");	
	var funrMblTelno2 = this.dsResult.getColumn(0,"funrMblTelno2");	
	var funrMblTelno3 = this.dsResult.getColumn(0,"funrMblTelno3");	
	var funrMblTelnoTemp1 = this.dsResultTemp.getColumn(0,"funrMblTelno1");	
	var funrMblTelnoTemp2 = this.dsResultTemp.getColumn(0,"funrMblTelno2");	
	var funrMblTelnoTemp3 = this.dsResultTemp.getColumn(0,"funrMblTelno3");	
		
	//변경된 데이터 없으면 저장 X 처리	
	if(vEmlAddr == vEmlAddrTemp && telno1 == telnoTemp1 && telno2 == telnoTemp2 && telno3 == telnoTemp3 && mblTelno1 == mblTelnoTemp1 && mblTelno2 == mblTelnoTemp2 && mblTelno3 == mblTelnoTemp3 && funrMblTelno1 == funrMblTelnoTemp1 && funrMblTelno2 == funrMblTelnoTemp2 && funrMblTelno3 == funrMblTelnoTemp3){	
		this.smfAlert('변경된 데이터가 없어서 저장 할 수 없습니다.');
		return;
		
	}
		
	//전화번호 " - " 처리 및 셋팅 
	var telno = [telno1,telno2,telno3].join("-"); 
	if ( telno == "--" ) telno = "";
	this.dsSave.setColumn(0,"faTelno",telno);
	
	//휴대폰번호 " - " 처리 및 셋팅
	
	var mblTelno = [mblTelno1,mblTelno2,mblTelno3].join("-");
	if ( mblTelno == "--" ) mblTelno = "";
	this.dsSave.setColumn(0,"invlMblTelno",mblTelno);
	
	//설립자 휴대폰번호 " - " 처리 및 셋팅
	
	var funrMblTelno = [funrMblTelno1,funrMblTelno2,funrMblTelno3].join("-");
	if ( funrMblTelno == "--" ) funrMblTelno = "";
	this.dsSave.setColumn(0,"funrMblTelno",funrMblTelno);
	
	//저장값확인
	//alert(this.dsSave.getColumn(0, "faTelno") +"@@@"+this.dsSave.getColumn(0, "invlMblTelno")+"@@@"+this.dsSave.getColumn(0, "funrMblTelno")+ this.dsSave.getColumn(0, "emlAddr")+ this.dsSave.getColumn(0, "funrRrno"));

	// 서비스 객체 생성 
	this.smfSaveService("save")
		// 데이터 존재 필수
		//.requireExistsData(this.dsSave)
		// 데이터 검증
		//.validateForm(this.dsSave)
		// 데이터 변경 필수 
		//.requireModifredData(this.dsSave)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;
			this.smfAlert('CM002');	//저장이 완료되었습니다.
			
		});

	
 };

this.imgTitle00_onclick = function(obj:nexacro.ImageViewer,e:nexacro.ClickEventInfo)
{
	
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="staFunrKornFlnm" propid="text" datasetid="dsResult" columnid="funrKornFlnm"/>
      <BindItem id="item1" compid="staAcaNm" propid="text" datasetid="dsResult" columnid="acaNm"/>
      <BindItem id="item2" compid="staRegDsgnNo" propid="text" datasetid="dsResult" columnid="regDsgnNo"/>
      <BindItem id="item3" compid="staFunrRrno" propid="text" datasetid="dsResult" columnid="funrRrnoDec"/>
      <BindItem id="item4" compid="edtEmlAddr" propid="value" datasetid="dsResult" columnid="emlAddr"/>
      <BindItem id="item5" compid="edtFaTelno1" propid="value" datasetid="dsResult" columnid="faTelno1"/>
      <BindItem id="item6" compid="edtFaTelno2" propid="value" datasetid="dsResult" columnid="faTelno2"/>
      <BindItem id="item7" compid="edtFaTelno3" propid="value" datasetid="dsResult" columnid="faTelno3"/>
      <BindItem id="item9" compid="edtInvlMblTelno2" propid="value" datasetid="dsResult" columnid="invlMblTelno2"/>
      <BindItem id="item10" compid="edtInvlMblTelno3" propid="value" datasetid="dsResult" columnid="invlMblTelno3"/>
      <BindItem id="item12" compid="edtFunrMblTelno2" propid="value" datasetid="dsResult" columnid="funrMblTelno2"/>
      <BindItem id="item13" compid="edtFunrMblTelno3" propid="value" datasetid="dsResult" columnid="funrMblTelno3"/>
      <BindItem id="item8" compid="cboInvlMblTelno1" propid="value" datasetid="dsResult" columnid="invlMblTelno1"/>
      <BindItem id="item11" compid="cboFunrMblTelno1" propid="value" datasetid="dsResult" columnid="funrMblTelno1"/>
    </Bind>
  </Form>
</FDL>
