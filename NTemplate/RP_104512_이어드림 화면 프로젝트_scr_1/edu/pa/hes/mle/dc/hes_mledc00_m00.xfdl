    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 민원신고내역조회
*  @MenuPath    TEMPLATE
*  @FileName 	hes_mledc00_m00.xfdl
*  @Creator 	김명주
*  @CreateDate 	2023.1.3
*  @Desction    민원신고내역조회
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2023.1.3     	김명주 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs"
include "lib::hes_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
// 배열로 업무구분
// 1 : 학원, 2 : 교습소, 3 : 개인과외교습자

// 10 : 학원변경통보
// 11 : 학원강사관리 - 0 : 채용 / 1 : 해임
// 12 : 학원배상책임보험가입
// 13 : 학원면허세납부
// 14 : 학원휴폐원신고 - 0 : 휴원 / 1 : 폐원
// 15 : 학원지도점검관리
// 16 : 학원자율점검신청관리
// 17 : 학원교육이수현황신고

// 20 : 교습소변경통보
// 21 : 교습소임시교습자및보조요원관리	- 0 : 채용 / 1 : 해임
//											- 0 : 임시교습자 / 1: 보조요원
// 22 : 교습소배상책임보험가입
// 23 : 교습소면허세납부
// 24 : 교습소휴폐소신고 - 0 : 휴소 / 1 : 폐소
// 25 : 교습소지도점검관리
// 26 : 교습소자율점검신청관리
// 27 : 교습소교육이수현황신고

// 30 : 개인과외교습자변경신고(기본정보)
// 31 : 개인과외교습자변경신고(교습장소)
// 32 : 개인과외교습자변경신고(교습과정정보)
// 33 : 개인과외교습자폐지신고

// 학원
this.fv_instutCd01 = ["10", "11", "12", "13", "14", "15", "16", "17"];
// 교습소
this.fv_instutCd02 = ["20", "21", "22", "23", "24", "25", "26", "27"];	
// 개인과외교습자
this.fv_invlPrlsCd = ["30", "31", "32", "33"];

this.fv_instutNm01 = [
	"학원변경통보"
	, "학원강사관리"
	, "학원배상책임보험가입"
	, "학원면허세납부"
	, "학원휴폐원신고"
	, "학원지도점검관리"
	, "학원자율점검신청관리"
	, "학원교육이수현황신고"
];

this.fv_instutNm02 = [
	"교습소변경통보"
	, "교습소임시교습자및보조요원관리"
	, "교습소배상책임보험가입"
	, "교습소면허세납부"
	, "교습소휴폐소신고"
	, "교습소지도점검관리"
	, "교습소자율점검신청관리"
	, "교습소교육이수현황신고"
];

this.fv_invlPrlsNm = [
	"개인과외교습자변경신고(기본정보)"
	, "개인과외교습자변경신고(교습장소)"
	, "개인과외교습자변경신고(교습과정정보)"
	, "개인과외교습자폐지신고"
];

this.fv_instutURL01 = [
	"pa_hes_cpt_ra::hes_cptra01"
	, "pa_hes_cpt_ra::hes_cptra02"
	, "pa_hes_cpt_ra::hes_cptra05"
	, "pa_hes_cpt_ra::hes_cptra06"
	, "pa_hes_cpt_ra::hes_cptra07"
	, "pa_hes_cpt_ra::hes_cptra08"
	, "pa_hes_cpt_ra::hes_cptra09"
	, "pa_hes_cpt_ra::hes_cptra10"
];

this.fv_instutURL02 = [
	"pa_hes_cpt_rt::hes_cptrt01"
	, "pa_hes_cpt_rt::hes_cptrt09"
	, "pa_hes_cpt_rt::hes_cptrt03"
	, "pa_hes_cpt_rt::hes_cptrt04"
	, "pa_hes_cpt_rt::hes_cptrt05"
	, "pa_hes_cpt_rt::hes_cptrt06"
	, "pa_hes_cpt_rt::hes_cptrt07"
	, "pa_hes_cpt_rt::hes_cptrt08"
];

this.fv_invlPrlsURL = [
	"pa_hes_cpt_ri::hes_cptri02"
	, "pa_hes_cpt_ri::hes_cptri03"
	, "pa_hes_cpt_ri::hes_cptri04"
	, "pa_hes_cpt_ri::hes_cptri05"
];

/************************************************************************************************
* FORM EVENT 영역(onload, onbeforeclose)
************************************************************************************************/
//화면 접근 시 로그인정보 확인
this.fnOninit = function(obj:nexacro.Form,e:nexacro.EventInfo)
{
	this.hesSetGoUrl("pa_hes_mle_dc::hes_mledc00_m00.xfdl");
};
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	this.grdMain.deleteContentsCol("body",6);
	
	//신청기간 종료일 현재날짜
	var today = this.smfToday();
	this.divSearch.form.calEndAplyYmd.set_value(today);
	
	// 민원신청명 세팅
	// 전체
	this.dsCvlcptAplyCd.addRow();
	this.dsCvlcptAplyCd.setColumn(0, 1, "전체");	// 민원신청명 명칭
	
	// 로그인한 사용자의 학원교습소구분코드로 검색조건 설정
	var rowCount = this.dsCvlcptAplyCd.getRowCount();
		
	switch(this.hesGetAcaInstiScCd){
		case "1" : 
			// 학원
			for(var i = 0; i < this.fv_instutCd01.length; i++){
				this.dsCvlcptAplyCd.addRow();
				this.dsCvlcptAplyCd.setColumn(rowCount, 0, this.fv_instutCd01[i]);	// 민원신청명 코드
				this.dsCvlcptAplyCd.setColumn(rowCount, 1, this.fv_instutNm01[i]);	// 민원신청명 명칭
				rowCount++;
			}
		break;
		case "2" : 
			// 교습소
			for(var i = 0; i < this.fv_instutCd02.length; i++){
				this.dsCvlcptAplyCd.addRow();
				this.dsCvlcptAplyCd.setColumn(rowCount, 0, this.fv_instutCd02[i]);	// 민원신청명 코드
				this.dsCvlcptAplyCd.setColumn(rowCount, 1, this.fv_instutNm02[i]);	// 민원신청명 명칭
				rowCount++;
			}
		break;
		case "3" : 
			// 개인과외교습자
			for(var i = 0; i < this.fv_invlPrlsCd.length; i++){
				this.dsCvlcptAplyCd.addRow();
				this.dsCvlcptAplyCd.setColumn(rowCount, 0, this.fv_invlPrlsCd[i]);	// 민원신청명 코드
				this.dsCvlcptAplyCd.setColumn(rowCount, 1, this.fv_invlPrlsNm[i]);	// 민원신청명 명칭
				rowCount++;
			}
		break;
	}	
	
	this.listInstutInfo();
};

/************************************************************************************************
* CALLBACK 콜백 처리부분(Transaction, Popup)
************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};

/**
 * @description Popup CallBack 함수(선택)
*/
this.fnPopupCallback = function(e, sender){
	//철회 후 팝업을 닫은 경우 목록 재조회
	if(e.search){
		this.listChkDtlCvCmpltRpt();
	}
};

// 학원정보 조회 함수
this.listInstutInfo = function (){
	// 학원조회조건	
	this.dsSearch.setColumn(0, "acaDsgnNo", this.hesGetAcaDsgnNo);	
	this.dsSearch.setColumn(0, "acaInstiScCd", this.hesGetAcaInstiScCd);
	this.dsSearch.setColumn(0, "atptOfcdcOrgCode",  this.hesGetAtptOfcdcOrgCode);
	this.dsSearch.setColumn(0, "invlDsgnNo", this.hesGetInvlDsgnNo);	
	
	if(this.hesGetAcaInstiScCd == "3"){ //개인과외교습자일 경우 학원목록 조회 생략
		this.listChkDtlCvCmpltRpt();
	}else{
		//학원정보조회
		this.smfSearchService("listInstutInfo")
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors)return;
			
			//조회된 학원정보가 있을 경우 해당 민원 조회
			var dsRowCnt = this.dsInstutList.getRowCount();
			if(dsRowCnt > 0){
				var acaDsgnNoArr = [];
				for(var i=0; i<dsRowCnt; i++){
					acaDsgnNoArr[i] = this.dsInstutList.getColumn(i,"acaDsgnNo");
				}
				
				var acaDgsnNoList = acaDsgnNoArr.join(",");
				this.dsSearch.setColumn(0,"acaDgsnNoList",acaDgsnNoList);
				this.listChkDtlCvCmpltRpt();
			}
			
		});
	}
}

// 민원신고내역 조회 함수
this.listChkDtlCvCmpltRpt = function (){

	this.smfSearchService("listChkDtlCvCmpltRpt")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
	});
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.setCvlcptNm = function(val){
	var idx = this.dsCvlcptAplyCd.findRow("id",val);
	return this.dsCvlcptAplyCd.getColumn(idx,"value");
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// 그리드 선택
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var url = "";
	var checkNum = 0;
	
	// 버튼 이벤트
	switch(e.col) {
	case 2:
		var procType = "search";

		// 팝업을 동작에 필요한 파라메터 지정
		var popupParams = {
			callback: this.fnPopupCallback,
			sender: obj, // sender 지정
			// 팝업 전달 파라메터 지정
			params: {
				// 처리타입 지정
				procType: procType,
				acaDsgnNo: this.dsList.getColumn(e.row,"acaDsgnNo"),
				acaInstiScCd: this.dsList.getColumn(e.row,"acaInstiScCd"),
				tmprAcaDsgnNo: this.dsList.getColumn(e.row,"tmprAcaDsgnNo"),
				dstrtOfcdcCd: this.hesGetAtptOfcdcOrgCode,
				invlDsgnNo: this.dsList.getColumn(e.row,"invlDsgnNo")
			},
		};
		
		// 모달리스		
		// 해당 메뉴로 이동
		// 학원
		for(var i = 0; i < this.fv_instutCd01.length; i++){
			if(this.fv_instutCd01[i] == this.dsList.getColumn(e.row, "cvlcptNm")){
				checkNum = i;
				url = this.fv_instutURL01[checkNum] + "_p00.xfdl";
				break;
			}
		}
		
		// 교습자
		for(var i = 0; i < this.fv_instutCd02.length; i++){
			if(this.fv_instutCd02[i] == this.dsList.getColumn(e.row, "cvlcptNm")){
				checkNum = i;
				url = this.fv_instutURL02[checkNum] + "_p00.xfdl";
				break;
			}
		}
		
		// 개인과외교습자
		for(var i = 0; i < this.fv_invlPrlsCd.length; i++){
			if(this.fv_invlPrlsCd[i] == this.dsList.getColumn(e.row, "cvlcptNm")){
				checkNum = i;
				url = this.fv_invlPrlsURL[checkNum] + "_p00.xfdl";
				break;
			}
		}
		
		this.smfOpen("_auto", url, popupParams);
		break;
	default:
	}
};

// 조회
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.dsSearch.getColumn(0,"acaDgsnNoList") == ""){
		alert("조회 가능한 민원정보가 없습니다.");
		return;
	}
	
	this.listChkDtlCvCmpltRpt();
};
]]></Script>
    <Bind>
      <BindItem id="item1" compid="divSearch.form.calSttAplyYmd" propid="value" datasetid="dsSearch" columnid="sttAplyYmd"/>
      <BindItem id="item2" compid="divSearch.form.calEndAplyYmd" propid="value" datasetid="dsSearch" columnid="endAplyYmd"/>
      <BindItem id="item3" compid="divSearch.form.cboCvlcptAplyNm" propid="value" datasetid="dsSearch" columnid="cvlcptNm"/>
    </Bind>
  </Form>
</FDL>
