        <Div id="divSearch" taborder="1" left="0" top="144" height="70" right="0" cssclass="div_WF_Search" initvalueid="ivDivAccessibilityOn" accessibilitylabel="조회영역">
          <Layouts>
            <Layout>
              <Static id="Static00" taborder="0" text="민원신청명" left="0" top="20" width="94" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Combo id="cboCvlcptAplyNm" taborder="1" left="94" width="180" height="30" innerdataset="dsCvlcptAplyCd" codecolumn="id" datacolumn="value" index="-1" top="20" initvalueid="ivCmbNormal" accessibilitylabel="조회조건"/>
              <Static id="Static00_00" taborder="2" text="신청기간" left="274" top="20" width="81" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn"/>
              <Calendar id="calSttAplyYmd" taborder="3" left="355" top="20" width="150" height="30" dateformat="yyyy.MM.dd" readonly="false" editformat="yyyy.MM.dd" initvalueid="ivCalNormal"/>
              <Static id="Static65" taborder="4" text="~" left="505" top="20" width="15" height="30" cssclass="sta_WF_AC" initvalueid="ivStcAccessibilityOn" accessibilitylabel="부터"/>
              <Calendar id="calEndAplyYmd" taborder="5" left="520" top="20" width="150" height="30" dateformat="yyyy.MM.dd" readonly="false" editformat="yyyy.MM.dd" initvalueid="ivCalNormal"/>
              <Button id="btnSearch" taborder="6" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="20" onclick="divSearch_btnSearch_onclick" initvalueid="ivBtnAccessibilityButton"/>
            </Layout>
            <Layout name="Layout0">
              <Button id="btnInit" top="200" width="185" height="60" right="204"/>
              <Button id="btnSearch" top="200" width="164" right="20" height="60"/>
              <Edit id="edtSearchKeyword" right="20" left="20" top="120" height="60" displaynulltext="검색어를 입력해 주세요."/>
              <Combo id="cboSearchType" height="60" left="20" top="40" right="20"/>
              <Static id="Static00" height="42" left="820" top="19" width="182" visible="false"/>
            </Layout>
          </Layouts>
        </Div>
        <Grid id="grdMain" taborder="2" binddataset="dsList" selecttype="cell" extendsizetype="row" autosizingtype="row" left="0" top="234" height="439" autofittype="col" cellsizingtype="col" right="0" oncellclick="grdMain_oncellclick" initvalueid="ivGrdAccessibilityOn">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="40"/>
                <Column size="80"/>
                <Column size="150"/>
                <Column size="80"/>
                <Column size="90"/>
                <Column size="120"/>
                <Column size="85"/>
                <Column size="82"/>
              </Columns>
              <Rows>
                <Row size="31" band="head"/>
                <Row size="31" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell rowspan="2" text="순번" displaytype="normal"/>
                <Cell col="1" rowspan="2" text="접수일자" displaytype="normal"/>
                <Cell col="2" rowspan="2" text="민원명" displaytype="normal"/>
                <Cell col="3" rowspan="2" text="신청인" displaytype="normal"/>
                <Cell col="4" colspan="2" text="민원신청결과" displaytype="normal"/>
                <Cell col="6" rowspan="2" text="변경신고"/>
                <Cell col="7" rowspan="2" text="비고" cssclass="LineNo"/>
                <Cell row="1" col="4" text="진행상태"/>
                <Cell row="1" col="5" text="내용"/>
              </Band>
              <Band id="body">
                <Cell text="expr:currow+1" textAlign="center"/>
                <Cell col="1" text="bind:regDt" textAlign="center" displaytype="date" calendardateformat="yyyy.MM.dd" calendareditformat="yyyy.MM.dd"/>
                <Cell col="2" text="expr:dataset.parent.setCvlcptNm(dataset.getColumn(currow, 'cvlcptNm'))" textAlign="center" cursor="pointer"/>
                <Cell col="3" text="bind:regNm" textAlign="center"/>
                <Cell col="4" text="bind:onlCvlcptPrcsStsCdNm" textAlign="center" expr="onlCvlcptPrcsStsCdNm ==  &quot;상신(진행)&quot; ? &quot;처리중&quot; : onlCvlcptPrcsStsCdNm"/>
                <Cell col="5" text="expr:onlCvlcptPrcsStsCd == '08' ? dataset.getColumn(currow, 'rjctRsnCn') : ''" textAlign="center"/>
                <Cell col="6" text="변경신고" textAlign="center" displaytype="buttoncontrol" edittype="button"/>
                <Cell col="7" textAlign="center" cssclass="LineNo"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="Static99_00_00_00_00" taborder="3" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00" taborder="4" left="0" top="114" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_00_00" taborder="5" left="0" top="214" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
