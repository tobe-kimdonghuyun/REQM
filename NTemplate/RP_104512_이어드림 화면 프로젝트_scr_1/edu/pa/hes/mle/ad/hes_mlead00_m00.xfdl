    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 행정처분사항조회
*  @MenuPath    TEMPLATE
*  @FileName 	hes_mlead00_m00.xfdl
*  @Creator 	HMH
*  @CreateDate 	2022.12.20
*  @Desction    행정처분사항조회

************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.6.20     	HMH 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs"
include "lib::hes_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 //this.fv_param;	//화면에서 넘어온 param값
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 *************************************************************************************************/
 //화면 접근 시 로그인정보 확인
this.fnOninit = function(obj:nexacro.Form,e:nexacro.EventInfo)
{
	this.hesSetGoUrl("pa_hes_mle_ad::hes_mlead00_m00.xfdl");
};

this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnListAdmdsp();
};

this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);
	
	// 공통코드 호출
	this.smfCodeList("code", [this.dsOnlCvlcptAprvCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;	
			
			// 처리상태 콤보박스 세팅
			this.dsPrcsStsCd.addRow();
			this.dsPrcsStsCd.setColumn(0, 1, "전체");	// 코드명
			
			this.dsPrcsStsCd.addRow();
			this.dsPrcsStsCd.setColumn(1, 0, "0");	// 코드
			this.dsPrcsStsCd.setColumn(1, 1, "미상신");	// 코드명

			var rowCount = this.dsPrcsStsCd.getRowCount();
			//alert(rowCount);
			for(var i = 0; i < this.dsOnlCvlcptAprvCd.getRowCount(); i++){
				this.dsPrcsStsCd.addRow();
				this.dsPrcsStsCd.setColumn(rowCount, 0, this.dsOnlCvlcptAprvCd.getColumn(i, 0));	// 코드
				this.dsPrcsStsCd.setColumn(rowCount, 1, this.dsOnlCvlcptAprvCd.getColumn(i, 1));	// 코드명
				rowCount++;
			}
			
			this.dsSearch.setColumn(0,"dstrtOfcdcCd", this.hesGetAtptOfcdcOrgCode);	 
			this.dsSearch.setColumn(0,"funrRrno", this.smfGetTrprRrno());	
			this.dsSearch.setColumn(0,"acaInstiScCd",this.hesGetAcaInstiScCd);	
	
			this.fnListAdmdsp();
		})		
		.run()
	;
};
//그리드 셀클릭 이벤트
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{ 
	
	//데이터셋 초기화
	this.fnInit();
	
	var nRow = e.row;
	var objDs = obj.getBindDataset();
	
	//사용자정보 조회시 필요한 값 셋팅
	this.dsSearchAdmdspDtlInfo.setColumn(0,"tmprAcaDsgnNo",objDs.getColumn(nRow,"tmprAcaDsgnNo"));
	this.dsSearchAdmdspDtlInfo.setColumn(0,"acaDsgnNo",objDs.getColumn(nRow,"acaDsgnNo"));
	this.dsSearchAdmdspDtlInfo.setColumn(0,"dstrtOfcdcCd",objDs.getColumn(nRow,"dstrtOfcdcCd"));
	this.dsSearchAdmdspDtlInfo.setColumn(0,"acaInstiScCd",objDs.getColumn(nRow,"acaInstiScCd"));
	this.dsSearchAdmdspDtlInfo.setColumn(0,"admDspsDsgnNo",objDs.getColumn(nRow,"admDspsDsgnNo"));
	this.dsSearchAdmdspDtlInfo.setColumn(0,"acaSeqDsgnNo",objDs.getColumn(nRow,"acaSeqDsgnNo"));
	this.dsSearchAdmdspDtlInfo.setColumn(0,"chckYmd",objDs.getColumn(nRow,"chckYmd"));
	
	//행정처분 상세정보 조회  
	this.fnSelectAdmdspDtlInfo();
	
};


 /**
 * @description  기본정보초기화 Transaction
 */ 
this.fnInit = function () {
	this.dsAdmdspDtlInfo.setColumn(0,"tmprAcaDsgnNo", '');
	this.dsAdmdspDtlInfo.setColumn(0,"acaDsgnNo", '');
	this.dsAdmdspDtlInfo.setColumn(0,"acaInstiScCd", '');
	this.dsAdmdspDtlInfo.setColumn(0,"acaNm", '');
	this.dsAdmdspDtlInfo.setColumn(0,"cteOfcdcCd", '');
	this.dsAdmdspDtlInfo.setColumn(0,"acaSeqDsgnNo", '');
	this.dsAdmdspDtlInfo.setColumn(0,"chckYmd", '');
	this.dsAdmdspDtlInfo.setColumn(0,"admdspYmd", '');
	this.dsAdmdspDtlInfo.setColumn(0,"admdspMteCd", '');
	this.dsAdmdspDtlInfo.setColumn(0,"admdspMteCdNm", '');
	this.dsAdmdspDtlInfo.setColumn(0,"admdspCn", '');
	this.dsAdmdspDtlInfo.setColumn(0,"admdspBgngYmd", '');
	this.dsAdmdspDtlInfo.setColumn(0,"admdspEndYmd", '');
	this.dsAdmdspDtlInfo.setColumn(0,"viltNocs", '');
	this.dsAdmdspDtlInfo.setColumn(0,"corecBgngYmd", '');
	this.dsAdmdspDtlInfo.setColumn(0,"corecEndYmd", '');
	this.dsAdmdspDtlInfo.setColumn(0,"corecCn", '');
	this.dsAdmdspDtlInfo.setColumn(0,"cchChckKndCd", '');
	this.dsAdmdspDtlInfo.setColumn(0,"cchChckKndCdNm", '');
	this.dsAdmdspDtlInfo.setColumn(0,"viltCn", '');
	this.dsAdmdspDtlInfo.setColumn(0,"dstrtOfcdcCd", '');
	this.dsAdmdspDtlInfo.setColumn(0,"rjctYmd", '');
	this.dsAdmdspDtlInfo.setColumn(0,"rjctRsnCn", '');
	this.dsAdmdspDtlInfo.setColumn(0,"onlCvlcptPrcsStsCd", '');
	this.dsAdmdspDtlInfo.setColumn(0,"onlCvlcptAprvCd", '');
	this.dsAdmdspDtlInfo.setColumn(0,"onlCvlcptAprvCdNm", '');
	this.dsAdmdspDtlInfo.setColumn(0,"admDspsRegCdNm", '');
	this.dsAdmdspDtlInfo.setColumn(0,"admDspsDsgnNo", '');
	this.dsAdmdspDtlInfo.setColumn(0,"funrKornFlnm", '');
	this.dsAdmdspDtlInfo.setColumn(0,"viltMteCn", '');
	this.dsAdmdspDtlInfo.setColumn(0,"regDt", '');
	this.dsAdmdspDtlInfo.setColumn(0,"ffnlgAmt", '');
	this.dsAdmdspDtlInfo.setColumn(0,"ppenaCnt", '');
	this.dsAdmdspDtlInfo.setColumn(0,"txofNtfctnYn", '');
	this.dsAdmdspDtlInfo.setColumn(0,"prufDocuSbmsnMetCd", '');
	this.dsAdmdspDtlInfo.setColumn(0,"prufDocuSbmsnMetCdNm", '');
	this.dsAdmdspDtlInfo.setColumn(0,"fileRefrnId", '');

};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};



/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 행정처분사항 목록 조회 Transaction
 */
 this.fnListAdmdsp= function () {
	
	this.smfSearchService("list")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
	});
	
 };
 
 /**
 * @description 행정처분 상세정보 조회  Transaction
 */
 this.fnSelectAdmdspDtlInfo= function () {
	
	this.smfSearchService("select")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
	});
	
 };]]></Script>
