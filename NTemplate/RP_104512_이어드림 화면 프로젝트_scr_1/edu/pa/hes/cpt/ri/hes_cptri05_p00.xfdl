      <BindItem id="item16" compid="divDtl.form.sta44_00_00_00" propid="text" datasetid="dsResultTempBsc" columnid="uvstMjrNm"/>
      <BindItem id="item17" compid="divDtl.form.sta44_00_00_00_03" propid="text" datasetid="dsResultTempBsc" columnid="insrQlfScCdNm"/>
      <BindItem id="item18" compid="divDtl.form.sta44_00_00_02" propid="text" datasetid="dsResultTempBsc" columnid="leRegStsCdNm"/>
      <BindItem id="item19" compid="divDtl.form.sta44_00_00_02_00" propid="text" datasetid="dsResultTempBsc" columnid="regDt"/>
      <BindItem id="item20" compid="divDtl.form.sta44_00_00_00_02" propid="text" datasetid="dsResultTempBsc" columnid="chgKndCdNm"/>
      <BindItem id="item21" compid="divDtl.form.sta44_00_00_00_02_01" propid="text" datasetid="dsResultTempBsc" columnid="admstZoneCodeNm"/>
      <BindItem id="item22" compid="divDtl.form.rdoPrufDocuSbmsnMetCd" propid="value" datasetid="dsResultTempBsc" columnid="prufDocuSbmsnMetCd"/>
