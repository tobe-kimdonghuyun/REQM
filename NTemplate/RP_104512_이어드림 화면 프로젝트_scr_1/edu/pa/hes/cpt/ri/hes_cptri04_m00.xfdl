this.dsResultTempBsc_oncolumnchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	//그리드에서 분야, 계열 과정 코드 바꾸는 경우 필터 변경
	switch(e.columnid){
		case "realmScCd": 
			this.setCmbFilter(e.row, 2);
		break;
		case "leOrdCd": 
			this.setCmbFilter(e.row, 1);
		break;
	}
};


//교습분야, 계열, 과정 코드 필터
this.setCmbFilter = function(row, level){
	
	if(level == 2){
		//분야구분 > 교습계열 Filter
		var realmScCd = this.dsResultTempBsc.getColumn(row,"realmScCd");
		
		if(realmScCd == ""){
			this.dsLeOrdCd.filter("");
			this.dsLeOrdCd.filter("unyCdValue == ''");
			this.dsResultTempBsc.setColumn(row,"leOrdCd","");
		}else{
			this.dsLeOrdCd.filter("");
			this.dsLeOrdCd.filter("unyCdValue == '' || upUnyCdValue == '"+realmScCd+"'");
			this.dsResultTempBsc.setColumn(row,"leOrdCd","");
		}
	}
	
	if(level >= 1){
		//교습계열 > 교습과정 Filter
		var leOrdCd = this.dsResultTempBsc.getColumn(row,"leOrdCd");
		if(leOrdCd == ""){
			this.dsLeCrseCd.filter("");
			this.dsLeCrseCd.filter("unyCdValue == ''");
			this.dsResultTempBsc.setColumn(row,"leCrseCd","");
		}else{
			this.dsLeCrseCd.filter("");
			this.dsLeCrseCd.filter("(unyCdValue.substr(0,4) == "+leOrdCd.substr(0,4)+" && unyCdValue != "+leOrdCd+") || unyCdValue == null");
			this.dsResultTempBsc.setColumn(row,"leCrseCd","");
		}
	}
}

this.div00_00_grdMain00_00_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	//그리드에서 분야, 계열 과정 코드 바꾸는 경우 필터 변경
	switch(e.cell){
		case 3 : 
			var realmScCd = this.dsResultTempBsc.getColumn(e.row,"realmScCd");
		
			if(realmScCd == ""){
				this.dsLeOrdCd.filter("");
				this.dsLeOrdCd.filter("unyCdValue == ''");
			}else{
				this.dsLeOrdCd.filter("");
				this.dsLeOrdCd.filter("unyCdValue == '' || upUnyCdValue == '"+realmScCd+"'");
			}
		break;
		case 4 : 
			var leOrdCd = this.dsResultTempBsc.getColumn(e.row,"leOrdCd");
			if(leOrdCd == ""){
				this.dsLeCrseCd.filter("");
				this.dsLeCrseCd.filter("unyCdValue == ''");
			}else{
				this.dsLeCrseCd.filter("");
				this.dsLeCrseCd.filter("(unyCdValue.substr(0,4) == "+leOrdCd.substr(0,4)+" && unyCdValue != "+leOrdCd+") || unyCdValue == null");
			}
		break;
	}
};
]]></Script>
  </Form>
