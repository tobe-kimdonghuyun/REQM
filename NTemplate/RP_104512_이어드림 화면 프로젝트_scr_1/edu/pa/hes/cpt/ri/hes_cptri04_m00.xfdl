          <Column id="invlDsgnNo" type="STRING" sumtext="개인지정번호"/>
          <Column id="leSbjtDsgnNo" type="STRING" size="256" sumtext="교습장소지정번호"/>
          <Column id="regDsgnNo" type="STRING" sumtext="신고번호"/>
          <Column id="emhsScCd" type="STRING" sumtext="초중고구분코드"/>
          <Column id="realmScCd" type="STRING" sumtext="분야구분코드"/>
