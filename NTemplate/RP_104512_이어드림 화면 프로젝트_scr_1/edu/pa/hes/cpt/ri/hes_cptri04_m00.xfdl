    <Bind>
      <BindItem id="item0" compid="div00_00.form.div00_00_00.form.staKornOrgNm" propid="text" datasetid="dsResult" columnid="kornOrgNm"/>
      <BindItem id="item1" compid="div00_00.form.div00_00_00.form.staKornFlnm" propid="text" datasetid="dsResult" columnid="kornFlnm"/>
      <BindItem id="item2" compid="div00_00.form.div00_00_00.form.staRegDsgnNo" propid="text" datasetid="dsResult" columnid="regDsgnNo"/>
      <BindItem id="item3" compid="div00_00.form.div00_00_00.form.staRealmScCodeNm" propid="text" datasetid="dsResult" columnid="realmScCdNm"/>
      <BindItem id="item4" compid="div00_00.form.div00_00_00.form.staInvlTelno" propid="text" datasetid="dsResult" columnid="invlTelno"/>
    </Bind>
    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 개인과외교습자변경신청 (교습과정)
*  @MenuPath    TEMPLATE
*  @FileName 	hes_cptri04_m00.xfdl
*  @Creator 	HMH
*  @CreateDate 	2022.08.01
*  @Desction    개인과외교습자변경신청 (교습과정)

************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.08.01     	HMH 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs"
include "lib::hes_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역            
 ************************************************************************************************/
 //this.fv_param;	//화면에서 넘어온 param값
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 *************************************************************************************************/
//화면 접근 시 로그인정보 확인
this.fnOninit = function(obj:nexacro.Form,e:nexacro.EventInfo)
{
	if(this.hesChkLogin("3","pa_hes_cpt_ri::hes_cptri04_m00.xfdl")){
		this.hesSetGoUrl("pa_hes_cpt_ri::hes_cptri04_m00.xfdl");
		this.form_onload(this);
	}
};
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);
	this.fnInit();
	
	this.fnInvlPrlsInfo(); //개인과외교습자정보 조회
	
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};

/**
 * @description  기본정보초기화 Transaction
 */ 
this.fnInit = function () {
	
	this.dsResultTempBsc.clearData(); // 기본정보 초기화

 // 공통코드의 코드구분
	this.smfCodeList("code", [this.dsEmhsScCd, this.dsRealmScCd, this.dsLeOrdCd, this.dsLeCrseCd])
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		}); 
};


/**
 * @description  개인과외교습자정보 조회 Transaction
 */ 
this.fnInvlPrlsInfo = function () {
	// 로그인정보 SET
	this.dsSearchInfo.setColumn(0, "acaDsgnNo", this.hesGetAcaDsgnNo);	
	this.dsSearchInfo.setColumn(0, "invlDsgnNo", this.hesGetInvlDsgnNo);		
	this.dsSearchInfo.setColumn(0, "cteOfcdcCd", this.hesGetAtptOfcdcOrgCode);
	this.dsSearchInfo.setColumn(0, "dstrtOfcdcCd", this.hesGetAtptOfcdcOrgCode);
	
	this.smfSearchService("select")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors){
			var objFrame = this.getOwnerFrame();
			objFrame.form.fnSetMainpage(objFrame.form.fv_mainformUrl);	
		}
		
		if(this.dsResultTemp.getColumn(0, "imsiScCd") == "30"){//제출정보가 있는 경우
			this.smfAlert("현재 진행중인 민원이 있습니다.\n해당 민원처리가 종료된 이후 민원을 진행하실 수 있습니다.\n[확인]버튼을 누르시면 민원신고내역조회 페이지로 이동합니다.",this.hesGoCvlcptDclrList);
			return;
		}else{
			this.dsResult.setColumn(0,"invlTelno",this.dsResult.getColumn(0,"invlTelnoDec")); 
		
			this.btnAddRow_onclick();
			this.dsRealmScCd.filter("unyCdValue=='101' || unyCdValue=='102' || unyCdValue=='103'|| unyCdValue=='105'|| unyCdValue=='106'");
		}
	});
	
 };
  

/**
 * @description  임시저장정보 그리드 셀클릭 이벤트
 */
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{ 
	//this.fnInit();
	
	if( this.dsResultTemp.getColumn(e.row, "_chk") == 1){
		this.dsResultTemp.setColumn(e.row, "_chk", 0);
		//데이터셋 초기화
		this.dsResultTempBsc.clearData(); //교습장소 기본정보 그리드 초기화
	}else{		
		this.dsResultTemp.setColumn(e.row, "_chk", 1);
		
		//데이터셋 초기화
		this.dsResultTempBsc.clearData(); //교습장소 기본정보 그리드 초기화
		
		this.fnSearchTmprStrg(); // 임시저장상세 조회
	}
	
};


/**
 * @description 행추가
*/
this.btnAddRow_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.smfIsNull(this.dsResultTemp.getColumn(0, "tmprInvlDsgnNo")) == true){// 임시저장정보가 없을 시 
		var idx = this.dsResultTempBsc.addRow();
		var num = this.dsResultTempBsc.getRowCount();
		//기본정보 셋팅
		this.dsResultTempBsc.setColumn(num-1,"listNum", num);
		this.dsResultTempBsc.setColumn(num-1,"invlDsgnNo", this.dsResult.getColumn(0, "invlDsgnNo"));
		this.dsResultTempBsc.setColumn(num-1,"regDsgnNo", this.dsResult.getColumn(0, "regDsgnNo"));
		this.dsResultTempBsc.setColumn(num-1,"dstrtOfcdcCd", this.dsResult.getColumn(0, "dstrtOfcdcCd"));
		this.dsResultTempBsc.setColumn(num-1,"cteOfcdcCd", this.dsResult.getColumn(0,"cteOfcdcCd"));
		this.dsResultTempBsc.setColumn(num-1,"kornFlnm", this.dsResult.getColumn(0,"kornFlnm"));

	}else{// 임시저장정보가 있을시 
	
			var idx = this.dsResultTempBsc.addRow();
			var num = this.dsResultTempBsc.getRowCount();
			
			//기본정보 셋팅
			this.dsResultTempBsc.setColumn(num-1,"listNum", num);
			this.dsResultTempBsc.setColumn(num-1,"invlDsgnNo", this.dsResult.getColumn(0, "invlDsgnNo"));
			this.dsResultTempBsc.setColumn(num-1,"regDsgnNo", this.dsResult.getColumn(0, "regDsgnNo"));
			this.dsResultTempBsc.setColumn(num-1,"dstrtOfcdcCd", this.dsResult.getColumn(0, "dstrtOfcdcCd"));
			this.dsResultTempBsc.setColumn(num-1,"cteOfcdcCd", this.dsResult.getColumn(0,"cteOfcdcCd"));
			this.dsResultTempBsc.setColumn(num-1,"kornFlnm", this.dsResult.getColumn(0,"kornFlnm"));
			this.dsResultTempBsc.setColumn(num-1,"tmprInvlDsgnNo", this.dsResultTempBsc.getColumn(0,"tmprInvlDsgnNo"));
			
	}
	
	
	
	
	
};


/**
 * @description 행삭제
*/
this.btnDeleteRow_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	for(var i =0; i<this.dsResultTempBsc.rowcount; i++){
		if(this.dsResultTempBsc.getColumn(i,"_chk") == 1){//체크된 row 삭제
			this.dsResultTempBsc.deleteRow(i); 
		}
	}
	
 	for(var i =0; i<this.dsResultTempBsc.rowcount; i++){ // 순번 재설정
 		
 		this.dsResultTempBsc.setColumn(i,"listNum", i+1);
 	}
};


/**
 * @description 임시저장 버튼 클릭
*/
this.btnTmpSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//그리드 값 데이터셋 반영
	this.div00_00.form.grdMain00_00.updateToDataset();
	
	for(var i =0; i<this.dsResultTempBsc.rowcount; i++){ //저장값
		this.dsResultTempBsc.setColumn(i,"onlCvlcptPrcsStsCd", "01");
		this.dsResultTempBsc.setColumn(i,"invlDsgnNo", this.dsResult.getColumn(0, "invlDsgnNo"));
	}

	this.fnTmprStrg(); // 임시저장 
	
};

/**
 * @description 임시저장 
 */
  this.fnTmprStrg = function () {
    this.dsSave.clearData(); // 기본정보 초기화
	
 	for(var i =0; i<this.dsResultTempBsc.rowcount; i++){ //저장값
		this.dsSave.addRow();
		this.dsSave.setColumn(i,"listNum", this.dsResultTempBsc.getColumn(i, "listNum"));
		this.dsSave.setColumn(i,"tmprInvlDsgnNo", this.dsResultTempBsc.getColumn(i, "tmprInvlDsgnNo"));
		this.dsSave.setColumn(i,"leSbjtDsgnNo", this.dsResultTempBsc.getColumn(i, "leSbjtDsgnNo"));				
		this.dsSave.setColumn(i,"regDsgnNo", this.dsResultTempBsc.getColumn(i, "regDsgnNo"));
		this.dsSave.setColumn(i,"emhsScCd", this.dsResultTempBsc.getColumn(i, "emhsScCd"));
		this.dsSave.setColumn(i,"realmScCd", this.dsResultTempBsc.getColumn(i, "realmScCd"));
		this.dsSave.setColumn(i,"leOrdCd", this.dsResultTempBsc.getColumn(i, "leOrdCd"));
		this.dsSave.setColumn(i,"leCrseCd", this.dsResultTempBsc.getColumn(i, "leCrseCd"));
		this.dsSave.setColumn(i,"leSbjtNm", this.dsResultTempBsc.getColumn(i, "leSbjtNm"));
		this.dsSave.setColumn(i,"thccAmt", this.dsResultTempBsc.getColumn(i, "thccAmt"));
		this.dsSave.setColumn(i,"fxpNmprCnt", this.dsResultTempBsc.getColumn(i, "fxpNmprCnt"));
		this.dsSave.setColumn(i,"chgRsnCn", this.dsResultTempBsc.getColumn(i, "chgRsnCn"));		
		this.dsSave.setColumn(i,"onlCvlcptPrcsStsCd", this.dsResultTempBsc.getColumn(i, "onlCvlcptPrcsStsCd"));
		this.dsSave.setColumn(i,"cteOfcdcCd", this.dsResultTempBsc.getColumn(i, "cteOfcdcCd"));
		this.dsSave.setColumn(i,"kornFlnm", this.dsResultTempBsc.getColumn(i, "kornFlnm"));
		
		this.dsSave.setColumn(i,"invlDsgnNo", this.dsResult.getColumn(0, "invlDsgnNo"));
		this.dsSave.setColumn(i,"dstrtOfcdcCd", this.dsResult.getColumn(0, "dstrtOfcdcCd"));
		this.dsSave.setColumn(i,"cteOfcdcCd", this.dsResult.getColumn(0, "cteOfcdcCd"));
		this.dsSave.setColumn(i,"leRegStsCd", '1');
		
	}
   
	
	this.smfSaveService("saveTmprStrg")
		.run() 
		.callback(function(callbackParams){
	if(callbackParams.errors) return;
	this.fnInit();
	this.fnInvlPrlsInfo(); //개인과외교습자정보 조회
	
	});	
  	
 };
 
 /**
 * @description 임시저장 상세 조회
 */
  this.fnSearchTmprStrg = function () {
    this.dsSearchTemp.copyRow(0, this.dsSearchInfo, 0);
	this.dsSearchTemp.setColumn(0, "tmprAcaDsgnNo", this.dsResultTemp.getColumn(0,"tmprInvlDsgnNo"));
	
	this.smfSearchService("selectTempBsc")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;	
	});
  	
 };
 
 
 

/**
 * @description 임시내역삭제 Transaction
 */			
this.btnTmpDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	if(this.smfIsNull(this.dsResultTemp.getColumn(0, "tmprInvlDsgnNo")) == true){ //임시승인번호가 없으면 
		alert("삭제할 임시내역이 없습니다.");
	}else{
			this.dsResultTempDelete.clearData(); 
			this.dsResultTempDelete.addRow();			
			this.dsResultTempDelete.copyRow(0,this.dsResultTempBsc,0);
			this.dsResultTempDelete.setColumn(0,"leRegStsCd","1");
			
		// 삭제처리
		this.smfDeleteService("deleteTmprStrg")
		.run()
		// 콜백
		.callback(function(callbackParams){ 
			if(callbackParams.errors) return;
			//this.fnInit();
	        //this.fnInvlPrlsInfo(); //개인과외교습자정보 조회

		});
	}
};

