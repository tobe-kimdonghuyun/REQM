    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 개인과외교습자폐지신고
*  @MenuPath    TEMPLATE
*  @FileName 	hes_cptri05_m00.xfdl
*  @Creator 	HMH
*  @CreateDate 	2022.7.22
*  @Desction    개인과외교습자폐지신고

************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.7.22     	HMH 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs"
include "lib::hes_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 //this.fv_param;	//화면에서 넘어온 param값
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 *************************************************************************************************/
//화면 접근 시 로그인정보 확인
this.fnOninit = function(obj:nexacro.Form,e:nexacro.EventInfo)
{
	if(this.hesChkLogin("3","pa_hes_cpt_ri::hes_cptri05_m00.xfdl")){
		this.hesSetGoUrl("pa_hes_cpt_ri::hes_cptri05_m00.xfdl");
		this.form_onload(this);
	}
};
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);
	
	// 업로드 초기설정
	this.divDtl.form.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;        // 필요한 경우만 세팅(세팅권장)
	this.divDtl.form.divFileUpload.UPLOAD_OnError        = this.fnEventUploadError;           // 필요한 경우만 세팅(세팅권장)
	this.divDtl.form.divFileUpload.UPLOAD_AfterAddFile   = this.fnEventAfterAddFile;          // 필요한 경우만 세팅(세팅권장)
	this.divDtl.form.divFileUpload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)
	
	this.fnInit();
	this.fnInvlPrlsInfo(); //개인과외교습자정보 조회
	
	
};


 /**
 * @description  기본정보초기화 Transaction
 */ 
this.fnInit = function () {
	this.dsResultTempBsc.setColumn(0,"caaBgngYmd", '');
	this.dsResultTempBsc.setColumn(0,"caaRsnCn", '');
};


/**
 * @description  개인과외교습자정보 조회 Transaction
 */ 
this.fnInvlPrlsInfo = function () {
	// 임시 -  세팅	
	this.dsSearchInfo.setColumn(0, "invlDsgnNo", this.hesGetInvlDsgnNo);		
	this.dsSearchInfo.setColumn(0, "cteOfcdcCd", this.hesGetAtptOfcdcOrgCode);
	
	
	this.smfSearchService("select")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors){
			var objFrame = this.getOwnerFrame();
			objFrame.form.fnSetMainpage(objFrame.form.fv_mainformUrl);	
		}
		
		if(this.dsResultTemp.getColumn(0, "imsiScCd") == "30"){//제출정보가 있는 경우
			this.smfAlert("현재 진행중인 민원이 있습니다.\n해당 민원처리가 종료된 이후 민원을 진행하실 수 있습니다.\n[확인]버튼을 누르시면 민원신고내역조회 페이지로 이동합니다.",this.hesGoCvlcptDclrList);
			return;
		}else{
			//주민번호, 전화번호 복호화
			this.dsResult.setColumn(0,"invlTelno",this.dsResult.getColumn(0,"invlTelnoDec"));
			
			this.dsResultTempBsc.setColumn(0,"invlTelno",this.dsResultTempBsc.getColumn(0,"invlTelnoDec"));
			this.dsResultTempBsc.setColumn(0,"invlMblTelno",this.dsResultTempBsc.getColumn(0,"invlMblTelnoDec"));
			this.dsResultTempBsc.setColumn(0,"trprRrno",this.dsResultTempBsc.getColumn(0,"trprRrnoDec"));

			if(this.dsResultTemp.getColumn(0,"tmprInvlDsgnNo") == undefined){
				//임시저장정보 없는 경우 증빙서류제출방식 기본값 온라인 사용
				this.dsResultTempBsc.setColumn(0, "prufDocuSbmsnMetCd","2");
			}
		}
	});
	
	
 };
 
/**
 * @description  임시저장정보 조회 Transaction
 */ 
this.fnTmprStrgInfo = function () {
	this.smfSearchService("selectTemp")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;	
		
		
	});
 };
 

/**
 * @description  임시저장정보 그리드 셀클릭 이벤트
 */
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{ 
	// 업로드 초기화
	this.divDtl.form.divFileUpload.form.fnResetUpload();
	
	if( this.dsResultTemp.getColumn(e.row, "_chk") == 1){
		this.dsResultTemp.setColumn(e.row, "_chk", 0);
	
	}else{
		this.dsResultTemp.setColumn(e.row, "_chk", 1);
		this.dsResultTempBsc.setColumn(0,"caaBgngYmd",this.dsResultTemp.getColumn(0,"caaBgngYmd"));
		this.dsResultTempBsc.setColumn(0,"caaRsnCn",this.dsResultTemp.getColumn(0,"caaRsnCn"));
		this.dsResultTempBsc.setColumn(0,"prufDocuSbmsnMetCd",this.dsResultTemp.getColumn(0,"prufDocuSbmsnMetCd"));
		this.dsResultTempBsc.setColumn(0,"tmprInvlDsgnNo",this.dsResultTemp.getColumn(0,"tmprInvlDsgnNo"));
		this.dsResultTempBsc.setColumn(0,"fileRefrnId",this.dsResultTemp.getColumn(0,"fileRefrnId"));
		
		
	
		//파일참조ID가 있는 경우 파일정보조회
		if(this.dsResultTempBsc.getColumn(0,"fileRefrnId") != ""){
			this.transaction(
				 "fn_filesearch" // serviceId
				,"baseUrl::/cm_cmc_file_upload_001.do" // url
				,"" // inDataset
				,"dsOutFileinfo=atchFileinfo" // outDataset
				,"fileRefrnId='"+this.dsResultTempBsc.getColumn(0,"fileRefrnId")+"'"
				,""
				,false // true: 비동기, false:동기
		   );
			
			var responseCustomValue = "";
			var sDownloadUrl       = ""; 
			var sHandlerCode       = "PA.SAM.PLE";
			var sFileSn            = this.dsOutFileinfo.getColumn(0,"fileRefrnId"   );
			var sFileSeq           = this.dsOutFileinfo.getColumn(0,"fileId"        );
			var sFileSize          = this.dsOutFileinfo.getColumn(0,"atchFileMg"    );
			var sBackendFilename   = this.dsOutFileinfo.getColumn(0,"atchFileGuid"  );
			var sForntendFilename  = this.dsOutFileinfo.getColumn(0,"atchFileNm"    );
			var sFileEncryptYn     = this.dsOutFileinfo.getColumn(0,"fileEncryptYn" );
			var sPrivInfoFiltYn    = this.dsOutFileinfo.getColumn(0,"privInfoFiltYn");
			var sFileSaveStg       = this.dsOutFileinfo.getColumn(0,"fileSaveStg"   );
			var sFileInfSaveYn     = this.dsOutFileinfo.getColumn(0,"fileInfSaveYn" );
			
			this.divDtl.form.divFileUpload.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sForntendFilename, sFileSeq, sDownloadUrl
													  ,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn );
			
			this.dsResultTempBsc.setColumn(0, "sfileRefrnId", sFileSn);
		}
	}
	
	
};



/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};





this.btnInit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnInit();
};


/**
 * @description 임시저장 버튼 클릭
*/
this.btnTmpSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsResultTempBsc.setColumn(0,"onlCvlcptPrcsStsCd", "01");
	this.dsResultTempBsc.setColumn(0,"onlCvlcptAprvCd", "0");
	
	this.fnTmprStrg(); // 임시저장

};

/**
 * @description 임시저장 
 */
  this.fnTmprStrg = function () {
		this.dsResultTempBsc.setColumn(0,"leRegStsCd", "4");
		
		this.smfSaveService("saveTmprStrg")
			.run() 
			.callback(function(callbackParams){
		if(callbackParams.errors) return;
		this.fnInit();
	    this.fnInvlPrlsInfo(); //개인과외교습자정보 조회
		// 업로드 초기화
		this.divDtl.form.divFileUpload.form.fnResetUpload();
	});	
  	
 };
 
 
 
 

/**
 * @description 임시내역삭제 Transaction
 */			
this.btnTmpDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	if(this.smfIsNull(this.dsResultTemp.getColumn(0, "tmprInvlDsgnNo")) == true){ //임시승인번호가 없으면 
		alert("삭제할 임시내역이 없습니다.");
	}else{
		// 삭제처리
		this.smfDeleteService("deleteTmprStrg")
		.run()
		// 콜백
		.callback(function(callbackParams){ 
			if(callbackParams.errors) return;
            this.fnInit();
	        this.fnInvlPrlsInfo(); //개인과외교습자정보 조회
		});
	}
};

/**
 * @description 폐지신고 버튼 클릭
*/
this.btnChgDbilSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsResultTempBsc.setColumn(0,"onlCvlcptPrcsStsCd", "02");
	this.dsResultTempBsc.setColumn(0,"onlCvlcptAprvCd", "0");
	this.fnTmprStrg(); // 임시저장
};
this.fnEventAfterAddFile = function(obj,paramObj,sCustomValue,sFileName,nFileSize)
{
	trace("=== Sample : fnEventAfterAddFile");
	this.divDtl.form.divFileUpload.form.fnFileUpload();
}
this.fnEventUploadComplete = function(obj,paramObj,objResultDataset)
{
	// 신규서비스
	trace("=== Sample : fnEventUploadComplete");	
	this.divDtl.form.divFileUpload.form.fnSetUploadCompleteState(obj,paramObj);
	if(objResultDataset){
		trace("====업로드한 결과 데이터셋 ========== : "+objResultDataset.saveXML());
		this.dsResultTempBsc.setColumn(0, "sfileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
		var sFileRefrnId = objResultDataset.getColumn(0,"fileRefrnId");
		trace("sFileRefrnId : "+sFileRefrnId);
	}

}
this.fnEventUploadError = function(obj,paramObj)
{
	trace("파일 업로드에 실패 하였습니다.");		
}


//파일삭제
this.divAplyCn_btnFleDel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divDtl.form.divFileUpload.form.fnResetUpload();
};

//파일다운로드
this.divAplyCn_btnFleDwld_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divDtl.form.divFileUpload.form.fnFileDownload();
};]]></Script>
