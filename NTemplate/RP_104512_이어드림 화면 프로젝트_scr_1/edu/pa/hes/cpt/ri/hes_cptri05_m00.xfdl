        <Rows>
          <Row>
            <Col id="inDatasets">search=dsSearchInfo</Col>
            <Col id="outDatasets">dsResult=result00 dsResultTempBsc=result00 dsResultTemp=result01 dsSave=result01 dsResultTempDelete=result01</Col>
