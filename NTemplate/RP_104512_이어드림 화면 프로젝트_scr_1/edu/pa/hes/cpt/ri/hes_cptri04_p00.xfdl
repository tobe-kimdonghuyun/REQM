          <Column id="leSbjtNm" type="STRING" sumtext="교습과목"/>
          <Column id="thccAmt" type="STRING" sumtext="수강료"/>
          <Column id="fxpNmprCnt" type="STRING" sumtext="수강인원"/>
          <Column id="chgRsnCn" type="STRING" sumtext="변경내역"/>
          <Column id="dstrtOfcdcCd" type="STRING" sumtext="지역교육청코드" size="0"/>
          <Column id="onlCvlcptPrcsStsCd" type="STRING" sumtext="처리상태코드"/>
          <Column id="cteOfcdcCd" type="STRING" sumtext="관할교육청코드" size="0"/>
          <Column id="kornFlnm" type="STRING" sumtext="성명"/>
          <Column id="leRegStsCd" type="STRING" size="256" sumtext="교습등록상태코드"/>
          <Column id="onlCvlcptAprvCd" type="STRING" size="256"/>
          <Column id="atptOfcdcOrgCode" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 개인과외교습자변경신청 (교습과정)
*  @MenuPath    TEMPLATE
*  @FileName 	hes_cptri04_m00.xfdl
*  @Creator 	HMH
*  @CreateDate 	2022.08.01
*  @Desction    개인과외교습자변경신청 (교습과정)

************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.08.01     	HMH 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역            
 ************************************************************************************************/
 //this.fv_param;	//화면에서 넘어온 param값
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 *************************************************************************************************/

this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 팝업 폼 초기화
	this.smfInitPopup(obj);
	
	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	
	this.fnInit();
	
	this.fnInvlPrlsInfo(); //개인과외교습자정보 조회
	
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};

/**
 * @description  기본정보초기화 Transaction
 */ 
this.fnInit = function () {
	
	this.dsResultTempBsc.clearData(); // 기본정보 초기화
	
	this.dsResultTempBsc.addRow();
	this.dsResultTempBsc.setColumn(0,"listNum", 1); //row 기본셋팅
 // 공통코드의 코드구분
	this.smfCodeList("code", [this.dsEmhsScCd, this.dsRealmScCd, this.dsLeOrdCd, this.dsLeCrseCd])
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		
		}); 
};


/**
 * @description  개인과외교습자정보 조회 Transaction
 */ 
this.fnInvlPrlsInfo = function () {
	this.dsSearchInfo.setColumn(0, "invlDsgnNo", this.pv_params.invlDsgnNo);
	this.dsSearchInfo.setColumn(0, "cteOfcdcCd", this.pv_params.dstrtOfcdcCd);
	this.dsSearchInfo.setColumn(0, "atptOfcdcOrgCode", this.pv_params.dstrtOfcdcCd);
	this.dsSearchInfo.setColumn(0, "tmprAcaDsgnNo", this.pv_params.tmprAcaDsgnNo);
	
	
	this.smfSearchService("select")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;	
		
		//미접수상태인 경우 철회버튼 활성화
		if(this.dsResultTempBsc.getColumn(0,"onlCvlcptPrcsStsCd") == "00"){
			this.btnRtrcn.set_visible(true);
		}
	});
	
 };

 

this.btnRtrcn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsResultTempUpdate.clearData();
	this.dsResultTempUpdate.addRow();
	
	this.dsResultTempUpdate.copyRow(0,this.dsResultTempBsc,0);
	this.dsResultTempUpdate.setColumn(0,"onlCvlcptPrcsStsCd", "01");
	this.dsResultTempUpdate.setColumn(0,"onlCvlcptAprvCd", "0");
	this.dsResultTempUpdate.setColumn(0,"leRegStsCd", "1"); 
	
	this.smfConfirm("철회하시겠습니까?", function(result){
		if(result.confirmResult){
			this.smfSaveService("updateTmprStrg")
			.showConfirm(false) 
			.run()
			.callback(function(callbackParams){
				if(callbackParams.errors) return;
				alert("철회되었습니다.");
				// 저장정보 초기화
				this.smfSendResponseToOpener({
					"search": true
				});
				this.close(true);
			});
		}
	});	
};

this.btnCncl_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="div00_00.form.div00_00_00.form.staKornOrgNm" propid="text" datasetid="dsResult" columnid="kornOrgNm"/>
      <BindItem id="item1" compid="div00_00.form.div00_00_00.form.staKornFlnm" propid="text" datasetid="dsResult" columnid="kornFlnm"/>
      <BindItem id="item2" compid="div00_00.form.div00_00_00.form.staRegDsgnNo" propid="text" datasetid="dsResult" columnid="regDsgnNo"/>
      <BindItem id="item3" compid="div00_00.form.div00_00_00.form.staRealmScCodeNm" propid="text" datasetid="dsResult" columnid="realmScCdNm"/>
      <BindItem id="item4" compid="div00_00.form.div00_00_00.form.staInvlTelno" propid="text" datasetid="dsResult" columnid="invlTelno"/>
    </Bind>
  </Form>
</FDL>
