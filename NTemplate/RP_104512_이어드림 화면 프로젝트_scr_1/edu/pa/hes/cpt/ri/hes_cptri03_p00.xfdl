    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 개인과외교습자변경신청 (교습장소)
*  @MenuPath    TEMPLATE
*  @FileName 	hes_cptri03_m00.xfdl
*  @Creator 	HMH
*  @CreateDate 	2022.7.22
*  @Desction    개인과외교습자변경신청 (교습장소)

************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.7.22     	HMH 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 //this.fv_param;	//화면에서 넘어온 param값
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 *************************************************************************************************/

this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 팝업 폼 초기화
	this.smfInitPopup(obj);
	
	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	
	this.dsResultTempBsc.setColumn(0,"listNum", 1); //교습장소 기본정보 row 기본셋팅
	
	this.fnInvlPrlsInfo(); //개인과외교습자정보 조회
};

/**
 * @description  개인과외교습자정보 조회 Transaction
 */ 
this.fnInvlPrlsInfo = function () {
	this.dsSearchInfo.setColumn(0, "invlDsgnNo", this.pv_params.invlDsgnNo);
	this.dsSearchInfo.setColumn(0, "cteOfcdcCd", this.pv_params.dstrtOfcdcCd);
	this.dsSearchInfo.setColumn(0, "atptOfcdcOrgCode", this.pv_params.dstrtOfcdcCd);
	this.dsSearchInfo.setColumn(0, "tmprInvlDsgnNo", this.pv_params.tmprAcaDsgnNo);
	
	this.smfSearchService("select")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;	
		this.dsResult.setColumn(0,"invlTelno",this.dsResult.getColumn(0,"invlTelnoDec"));
		
		//사용자정보 조회시 필요한 값 셋팅
		this.dsSearchTempBsc.setColumn(0,"tmprInvlDsgnNo", this.pv_params.tmprAcaDsgnNo);
		this.dsSearchTempBsc.setColumn(0,"invlDsgnNo", this.dsResult.getColumn(0,"invlDsgnNo"));
		this.dsSearchTempBsc.setColumn(0,"dstrtOfcdcCd", this.pv_params.dstrtOfcdcCd);		
		this.dsSearchTempBsc.setColumn(0,"cteOfcdcCd", this.pv_params.dstrtOfcdcCd);
		//민원신고내역조회 화면 팝업을 구분하기 위해 사용
		this.dsSearchTempBsc.setColumn(0,"tmprYn", "N"); 
		
		
		//교습장소 기본정보 조회  
		this.fnTmprStrgInfoBsc();
	});
 };

 /**
 * @description 교습장소 기본정보 조회 Transaction
 */
  this.fnTmprStrgInfoBsc = function () {
	this.smfSearchService("selectTempBsc")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;	
		
		//미접수상태인 경우 철회버튼 활성화
		if(this.dsResultTempBsc.getColumn(0,"onlCvlcptPrcsStsCd") == "00"){
			this.btnRtrcn.set_visible(true);
		}
	});
 };


this.btnRtrcn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsResultTempBsc.setColumn(0, "cteOfcdcCd", this.pv_params.dstrtOfcdcCd);
	this.dsResultTempBsc.setColumn(0,"onlCvlcptPrcsStsCd", "01");
	this.dsResultTempBsc.setColumn(0,"onlCvlcptAprvCd", "0");
	
	this.smfConfirm("철회하시겠습니까?", function(result){
		if(result.confirmResult){
			this.smfSaveService("updateLePlaceTmprStrg")
			.showConfirm(false) 
			.run()
			.callback(function(callbackParams){
				if(callbackParams.errors) return;
				alert("철회되었습니다.");
				this.smfSendResponseToOpener({
					"search": true
				});
				this.close(true);
			});
		}
	});	
};

this.btnCncl_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSendResponseToOpener({
		"search": false
	});
	this.close(false);
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="div00.form.div00_00_00.form.staKornOrgNm" propid="text" datasetid="dsResult" columnid="kornOrgNm"/>
