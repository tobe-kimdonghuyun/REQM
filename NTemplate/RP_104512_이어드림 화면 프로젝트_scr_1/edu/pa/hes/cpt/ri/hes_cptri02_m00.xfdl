this.div00_00_btn00_00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: this.fnCommpopRdnZip, // 콜백함수 지정
		sender: obj, // sender 지정

		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: 'search',
			// 파라메터 전달 
			//dataset: this.dsSample1,
		},
	};

	// 모달팝업 실행
	this.smfDialog("_auto", "commpop::commpop_rdn_zip.xfdl", popupParams);
};
/**
 * @description 도로명주소찾기 콜백
 */
this.fnCommpopRdnZip = function(e, sender){
	// 출력 정보
	/*
	zipCd
	roadNmAddr
	roadNmDtl
	lotnoAddr
	*/
	var nRow = this.dsResultTempBsc.rowposition;
	this.dsResultTempBsc.setColumn(nRow, "dmclRoadNmZip", e.zipCd);
	this.dsResultTempBsc.setColumn(nRow, "lctnRoadNmAddr", e.roadNmAddr);	
	this.dsResultTempBsc.setColumn(nRow, "lctnRoadNmDtlAddr", e.roadNmDtl);	
};


