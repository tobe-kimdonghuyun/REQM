    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 개인과외교습자변경신청 (교습장소)
*  @MenuPath    TEMPLATE
*  @FileName 	hes_cptri02_m00.xfdl
*  @Creator 	HMH
*  @CreateDate 	2022.7.22
*  @Desction    개인과외교습자변경신청 (개인과외교습자기본정보)

************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.7.22     	HMH 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs"
include "lib::hes_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 //this.fv_param;	//화면에서 넘어온 param값
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 *************************************************************************************************/
//화면 접근 시 로그인정보 확인
this.fnOninit = function(obj:nexacro.Form,e:nexacro.EventInfo)
{
	if(this.hesChkLogin("3","pa_hes_cpt_ri::hes_cptri02_m00.xfdl")){
		this.hesSetGoUrl("pa_hes_cpt_ri::hes_cptri02_m00.xfdl");
		this.form_onload(this);
	}
};

this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);
	
	// 업로드 초기설정
	this.div00_00.form.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;        // 필요한 경우만 세팅(세팅권장)
	this.div00_00.form.divFileUpload.UPLOAD_OnError        = this.fnEventUploadError;           // 필요한 경우만 세팅(세팅권장)
	this.div00_00.form.divFileUpload.UPLOAD_AfterAddFile   = this.fnEventAfterAddFile;          // 필요한 경우만 세팅(세팅권장)
	this.div00_00.form.divFileUpload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)
	
	this.fnInit();
	this.fnInvlPrlsInfo(); //개인과외교습자정보 조회
	
};


 /**
 * @description  기본정보초기화 Transaction
 */ 
this.fnInit = function () {
	
	this.dsResultTempBsc.clearData(); // 기본정보 초기화
	
	this.dsResultTempBsc.addRow();

// 공통코드의 코드구분
	this.smfCodeList("code", [this.dsRealmScCd, this.dsChgKndCd, this.dsInvlAcbgCd, this.dsInsrQlfScCd, this.dsLeRegStsCd])
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			var sUnyCdValue  = new Array();
			var sUnyCdValueNm = new Array();
			var num = 0;
			
			for(var i =0; i<this.dsChgKndCd.rowcount; i++){
				if(this.dsChgKndCd.getColumn(i,"unyCdValue") == '1' || this.dsChgKndCd.getColumn(i,"unyCdValue") == '5' || this.dsChgKndCd.getColumn(i,"unyCdValue") == '9' || this.dsChgKndCd.getColumn(i,"unyCdValue") == '16' || this.dsChgKndCd.getColumn(i,"unyCdValue") == '19'){
					sUnyCdValue[num]= this.dsChgKndCd.getColumn(i,"unyCdValue");
					sUnyCdValueNm[num]= this.dsChgKndCd.getColumn(i,"unyCdValueNm");
					num = num+1;
				}
			}
			
			this.dsChgKndCd.clearData(); 
	
			
 			for(var i =0; i<sUnyCdValue.length; i++){
				this.dsChgKndCd.addRow();
 				this.dsChgKndCd.setColumn(i,"unyCdValue", sUnyCdValue[i]);	
 				this.dsChgKndCd.setColumn(i,"unyCdValueNm", sUnyCdValueNm[i]);	
 			}
		});
};


/**
 * @description  개인과외교습자정보 조회 Transaction
 */ 
this.fnInvlPrlsInfo = function () {
	// 임시 -  세팅	
	this.dsSearchInfo.setColumn(0, "invlDsgnNo", this.hesGetInvlDsgnNo);		
	this.dsSearchInfo.setColumn(0, "cteOfcdcCd", this.hesGetAtptOfcdcOrgCode);	
	
	
	this.smfSearchService("select")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors){
			var objFrame = this.getOwnerFrame();
			objFrame.form.fnSetMainpage(objFrame.form.fv_mainformUrl);	
		}
		
		if(this.dsResult.getColumn(0, "imsiScCd") == "30"){//제출정보가 있는 경우
			this.smfAlert("현재 진행중인 민원이 있습니다.\n해당 민원처리가 종료된 이후 민원을 진행하실 수 있습니다.\n[확인]버튼을 누르시면 민원신고내역조회 페이지로 이동합니다.",this.hesGoCvlcptDclrList);
			return;
		}else{
			this.dsResult.setColumn(0,"trprRrno", this.dsResult.getColumn(0,"trprRrnoDec"));
		
			//전화번호 "-"기준으로 자르기
			if ( !this.smfIsNull(this.dsResult.getColumn(0,"invlTelnoDec")) ) {
				var sFaTelno = this.dsResult.getColumn(0,"invlTelnoDec").split("-");

				if(sFaTelno.length >= 3){
					this.dsResult.setColumn(0,"invlTelno1", sFaTelno[0]);	
					this.dsResult.setColumn(0,"invlTelno2", sFaTelno[1]);	
					this.dsResult.setColumn(0,"invlTelno3", sFaTelno[2]);
					this.dsResultTempBsc.setColumn(0,"invlTelno1", sFaTelno[0]);	
					this.dsResultTempBsc.setColumn(0,"invlTelno2", sFaTelno[1]);	
					this.dsResultTempBsc.setColumn(0,"invlTelno3", sFaTelno[2]);	
				}
			}
			if ( !this.smfIsNull(this.dsResult.getColumn(0,"invlMblTelnoDec")) ) {
				var sInvlMblTelno = this.dsResult.getColumn(0,"invlMblTelnoDec").split("-");
				
				if(sInvlMblTelno.length >= 3){
					this.dsResult.setColumn(0,"invlMblTelno1", sInvlMblTelno[0]);	
					this.dsResult.setColumn(0,"invlMblTelno2", sInvlMblTelno[1]);	
					this.dsResult.setColumn(0,"invlMblTelno3", sInvlMblTelno[2]);	
					this.dsResultTempBsc.setColumn(0,"invlMblTelno1", sInvlMblTelno[0]);	
					this.dsResultTempBsc.setColumn(0,"invlMblTelno2", sInvlMblTelno[1]);	
					this.dsResultTempBsc.setColumn(0,"invlMblTelno3", sInvlMblTelno[2]);
				}
			}	
			
			//임시저장 정보 없을 경우 기본정보 set
			if(this.dsResultTemp.getRowCount() < 1){
				this.dsResultTempBsc.copyRow(0, this.dsResult, 0);
				
				//임시저장정보 없는 경우 증빙서류제출방식 기본값 온라인 사용
				this.dsResultTempBsc.setColumn(0, "prufDocuSbmsnMetCd","2");
			}else{
				this.dsResultTempBsc.clearData();
			}
		}
		
		this.fnSetFileDiv();
	});
	
	
 };

/**
 * @description  임시저장정보 그리드 셀클릭 이벤트
 */
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{ 
	this.fnInit();
	
	// 업로드 초기화
	this.div00_00.form.divFileUpload.form.fnResetUpload();
	
	if( this.dsResultTemp.getColumn(e.row, "_chk") == 1){
		this.dsResultTemp.setColumn(e.row, "_chk", 0);
	
	}else{

		//선택한 셀만 체크박스 체크
		for (var i =0; i<this.div00_00.form.grdMain.rowcount; i++) {

			if( i == e.row){ //선택한 셀 체크박스 체크
				this.dsResultTemp.setColumn(e.row, "_chk", 1);
				/*
				this.alert(this.dsResultTemp.getColumn(i,"invlTelno"));
				this.alert(this.dsResultTempBsc.getColumn(0,"invlTelno"));
				*/
				this.dsResultTempBsc.setColumn(0,"tmprInvlDsgnNo",this.dsResultTemp.getColumn(i,"tmprInvlDsgnNo"));
				this.dsResultTempBsc.setColumn(0,"invlDsgnNo",this.dsResultTemp.getColumn(i,"invlDsgnNo"));
				this.dsResultTempBsc.setColumn(0,"realmScCd",this.dsResultTemp.getColumn(i,"realmScCd"));
				this.dsResultTempBsc.setColumn(0,"realmScCdNm",this.dsResultTemp.getColumn(i,"realmScCdNm"));
				this.dsResultTempBsc.setColumn(0,"kornFlnm",this.dsResultTemp.getColumn(i,"kornFlnm"));
				this.dsResultTempBsc.setColumn(0,"trprRrno",this.dsResultTemp.getColumn(i,"trprRrno"));
				this.dsResultTempBsc.setColumn(0,"dmclRoadNmZip",this.dsResultTemp.getColumn(i,"dmclRoadNmZip"));
				this.dsResultTempBsc.setColumn(0,"lctnRoadNmAddr",this.dsResultTemp.getColumn(i,"lctnRoadNmAddr"));
				this.dsResultTempBsc.setColumn(0,"lctnRoadNmDtlAddr",this.dsResultTemp.getColumn(i,"lctnRoadNmDtlAddr"));
				this.dsResultTempBsc.setColumn(0,"invlAcbgCd",this.dsResultTemp.getColumn(i,"invlAcbgCd"));
				this.dsResultTempBsc.setColumn(0,"invlAcbgCdNm",this.dsResultTemp.getColumn(i,"invlAcbgCdNm"));
				this.dsResultTempBsc.setColumn(0,"insrQlfScCd",this.dsResultTemp.getColumn(i,"insrQlfScCd"));
				this.dsResultTempBsc.setColumn(0,"insrQlfScCdNm",this.dsResultTemp.getColumn(i,"insrQlfScCdNm"));
				this.dsResultTempBsc.setColumn(0,"uvstMjrNm",this.dsResultTemp.getColumn(i,"uvstMjrNm"));
				this.dsResultTempBsc.setColumn(0,"emlAddr",this.dsResultTemp.getColumn(i,"emlAddr"));
				this.dsResultTempBsc.setColumn(0,"invlTelno",this.dsResultTemp.getColumn(i,"invlTelno"));
				this.dsResultTempBsc.setColumn(0,"invlMblTelno",this.dsResultTemp.getColumn(i,"invlMblTelno"));
				this.dsResultTempBsc.setColumn(0,"leRegStsCd",this.dsResultTemp.getColumn(i,"leRegStsCd"));
				this.dsResultTempBsc.setColumn(0,"leRegStsCdNm",this.dsResultTemp.getColumn(i,"leRegStsCdNm"));
				this.dsResultTempBsc.setColumn(0,"regDsgnNo",this.dsResultTemp.getColumn(i,"regDsgnNo"));
				this.dsResultTempBsc.setColumn(0,"regDt",this.dsResultTemp.getColumn(i,"regDt"));
				this.dsResultTempBsc.setColumn(0,"prufDocuSbmsnMetCd",this.dsResultTemp.getColumn(i,"prufDocuSbmsnMetCd"));
				this.dsResultTempBsc.setColumn(0,"fileRefrnId",this.dsResultTemp.getColumn(i,"fileRefrnId"));
				
				this.dsResultTempBsc.setColumn(0,"chgKndCd",this.dsResultTemp.getColumn(i,"chgKndCd"));
				this.dsResultTempBsc.setColumn(0,"chgKndCdNm",this.dsResultTemp.getColumn(i,"chgKndCdNm"));
				this.dsResultTempBsc.setColumn(0,"chgRsnCn",this.dsResultTemp.getColumn(i,"chgRsnCn"));
				this.dsResultTempBsc.setColumn(0,"dstrtOfcdcCd",this.dsResult.getColumn(i,"dstrtOfcdcCd"));
				this.dsResultTempBsc.setColumn(0,"cteOfcdcCd",this.dsResult.getColumn(i,"cteOfcdcCd"));


				//전화번호 "-"기준으로 자르기				
				if ( !this.smfIsNull(this.dsResultTemp.getColumn(i,"invlTelno")) ) {
					var sFaTelno = this.dsResultTemp.getColumn(i,"invlTelno").split("-");
					 
					if(sFaTelno.length >= 3){ 
						this.dsResultTempBsc.setColumn(0,"invlTelno1", sFaTelno[0]);	
						this.dsResultTempBsc.setColumn(0,"invlTelno2", sFaTelno[1]);	
						this.dsResultTempBsc.setColumn(0,"invlTelno3", sFaTelno[2]);
					}
				}
				if ( !this.smfIsNull(this.dsResultTemp.getColumn(i,"invlMblTelno")) ) {
					var sInvlMblTelno = this.dsResultTemp.getColumn(i,"invlMblTelno").split("-");
					
					if(sInvlMblTelno.length >= 3){ 
						this.dsResultTempBsc.setColumn(0,"invlMblTelno1", sInvlMblTelno[0]);	
						this.dsResultTempBsc.setColumn(0,"invlMblTelno2", sInvlMblTelno[1]);	
						this.dsResultTempBsc.setColumn(0,"invlMblTelno3", sInvlMblTelno[2]);	
					}
				}
			}else{
				this.dsResultTemp.setColumn(i, "_chk", 0);
			}
		}
		
	
		//파일참조ID가 있는 경우 파일정보조회
		if(this.dsResultTempBsc.getColumn(0,"fileRefrnId") != ""){
			this.transaction(
				 "fn_filesearch" // serviceId
				,"baseUrl::/cm_cmc_file_upload_001.do" // url
				,"" // inDataset
				,"dsOutFileinfo=atchFileinfo" // outDataset
				,"fileRefrnId='"+this.dsResultTempBsc.getColumn(0,"fileRefrnId")+"'"
				,""
				,false // true: 비동기, false:동기
		   );
			
			var responseCustomValue = "";
			var sDownloadUrl       = ""; 
			var sHandlerCode       = "PA.SAM.PLE";
			var sFileSn            = this.dsOutFileinfo.getColumn(0,"fileRefrnId"   );
			var sFileSeq           = this.dsOutFileinfo.getColumn(0,"fileId"        );
			var sFileSize          = this.dsOutFileinfo.getColumn(0,"atchFileMg"    );
			var sBackendFilename   = this.dsOutFileinfo.getColumn(0,"atchFileGuid"  );
			var sForntendFilename  = this.dsOutFileinfo.getColumn(0,"atchFileNm"    );
			var sFileEncryptYn     = this.dsOutFileinfo.getColumn(0,"fileEncryptYn" );
			var sPrivInfoFiltYn    = this.dsOutFileinfo.getColumn(0,"privInfoFiltYn");
			var sFileSaveStg       = this.dsOutFileinfo.getColumn(0,"fileSaveStg"   );
			var sFileInfSaveYn     = this.dsOutFileinfo.getColumn(0,"fileInfSaveYn" );
			
			this.div00_00.form.divFileUpload.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sForntendFilename, sFileSeq, sDownloadUrl
													  ,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn );
			
			this.dsResultTempBsc.setColumn(0, "sfileRefrnId", sFileSn);
		}
	
	}
	
	this.fnSetFileDiv();
};


//증빙서류제출방식 온라인일때만 파일첨부 활성화
this.fnSetFileDiv = function(){
	if(this.div00_00.form.rdoPrufDocuSbmsnMetCd.value == "2"){
		this.div00_00.form.divFileUpload.set_enable(true);
	}else{
		this.div00_00.form.divFileUpload.set_enable(false);
	}
}

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};

/**
