	this.fnInvlPrlsInfo(); //개인과외교습자정보 조회
};


/**
 * @description 임시저장 버튼 클릭
*/
this.btnTmpSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
		//증빙자료제출방식 온라인 선택 시 첨부파일 필수체크
		if(this.dsResultTempBsc.getColumn(0,"prufDocuSbmsnMetCd") == "2"){
			if(this.dsResultTempBsc.getColumn(0,"sfileRefrnId") == "" || this.dsResultTempBsc.getColumn(0,"sfileRefrnId") == undefined){
				this.smfAlert("증빙서류제출 방식이 온라인일 경우 증빙서류 첨부는 필수입니다.");
				return;
			}
		}
		
		this.dsResultTempBsc.setColumn(0,"onlCvlcptPrcsStsCd", "01");
		
		this.fnSetTelno();
		
		this.smfSaveService("saveTmprStrg")
			.run() 
			.callback(function(callbackParams){
		if(callbackParams.errors) return;
			this.fnInit();
			this.fnInvlPrlsInfo(); //개인과외교습자정보 조회
			// 업로드 초기화
			this.div00_00.form.divFileUpload.form.fnResetUpload();
		});	
};

/**
 * @description 임시저장 
 */
  this.fnTmprStrg = function () {
  
 	
		this.smfSaveService("saveTmprStrg")
			.run() 
			.callback(function(callbackParams){
		if(callbackParams.errors) return;
			this.fnInit();
			this.fnInvlPrlsInfo(); //개인과외교습자정보 조회
		});	
  	
 };
 
 this.fnSetTelno = function(){

	if (!this.smfIsNull(this.dsResultTempBsc.getColumn(0, "invlTelno1"))
	  &&!this.smfIsNull(this.dsResultTempBsc.getColumn(0, "invlTelno2"))
	  &&!this.smfIsNull(this.dsResultTempBsc.getColumn(0, "invlTelno3"))){
	  this.dsResultTempBsc.setColumn(0,"invlTelno", this.dsResultTempBsc.getColumn(0, "invlTelno1")+ "-" +
													this.dsResultTempBsc.getColumn(0, "invlTelno2") + "-" +
													this.dsResultTempBsc.getColumn(0, "invlTelno3"));
	}else{
		this.dsResultTempBsc.setColumn(0,"invlTelno","");
	}
					
	if (!this.smfIsNull(this.dsResultTempBsc.getColumn(0, "invlMblTelno1"))
	  &&!this.smfIsNull(this.dsResultTempBsc.getColumn(0, "invlMblTelno2"))
	  &&!this.smfIsNull(this.dsResultTempBsc.getColumn(0, "invlMblTelno3"))){
	  this.dsResultTempBsc.setColumn(0,"invlMblTelno", this.dsResultTempBsc.getColumn(0, "invlMblTelno1")+ "-" +
													   this.dsResultTempBsc.getColumn(0, "invlMblTelno2") + "-" +
													   this.dsResultTempBsc.getColumn(0, "invlMblTelno3"));
	}else{
		this.dsResultTempBsc.setColumn(0,"invlMblTelno","");
	}
 }
 

/**
 * @description 임시내역삭제 Transaction
 */			
this.btnTmpDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.smfIsNull(this.dsResultTemp.getColumn(0,"tmprInvlDsgnNo")) == true){// 선택한 임시내역 없을 시 
		alert("삭제할 임시저장정보를 선택해주세요");
	}else{
		this.dsResultTempDelete.setColumn(0, "cteOfcdcCd", this.hesGetAtptOfcdcOrgCode);
		//선택한 셀만 임시내역삭제
		for (var i =0; i<this.div00_00.form.grdMain.rowcount; i++) {


			if( this.dsResultTemp.getColumn(i, "_chk") == 1){ //선택한 셀 
				// 삭제처리
				this.smfDeleteService("deleteTmprStrg")
				// 데이터 존재 필수
				//.requireExistsData(this.dsMain)
				// 그리드삭제처리
				//.validateGridDelete(this.grdMain)
				.run()
				// 콜백
				.callback(function(callbackParams){ 
					if(callbackParams.errors) return;
					this.fnInit();
					this.fnInvlPrlsInfo(); //개인과외교습자정보 조회
				});
			}
		}

	}
	
};

/**
 * @description 변경신고서제출 Transaction
 */	
this.btnChgDbilSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//증빙자료제출방식 온라인 선택 시 첨부파일 필수체크
	if(this.dsResultTempBsc.getColumn(0,"prufDocuSbmsnMetCd") == "2"){
		if(this.dsResultTempBsc.getColumn(0,"sfileRefrnId") == "" || this.dsResultTempBsc.getColumn(0,"sfileRefrnId") == undefined){
			this.smfAlert("증빙서류제출 방식이 온라인일 경우 증빙서류 첨부는 필수입니다.");
			return;
		}
		
	}
	this.dsResultTempBsc.setColumn(0,"onlCvlcptPrcsStsCd", "02");
		
	// API 적용 후 데이터셋 세팅
	this.dsSearchTemp.copyRow(0, this.dsResult, this.dsResult.rowposition);
	
	this.fnTmprStrg(); // 임시저장 
};

