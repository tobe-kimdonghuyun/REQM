      <Dataset id="dsSearchTempBsc" useclientlayout="true">
        <ColumnInfo>
          <Column id="tmprInvlDsgnNo" type="STRING" sumtext="임시저장번호"/>
          <Column id="invlDsgnNo" type="STRING" sumtext="개인지정번호"/>
          <Column id="dstrtOfcdcCd" type="STRING" sumtext="지역교육청코드"/>
          <Column id="cteOfcdcCd" type="STRING" size="256" sumtext="관할교육청코드"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsResultTempBsc" useclientlayout="true">
        <ColumnInfo>
          <Column id="tmprInvlDsgnNo" type="STRING" sumtext="임시저장번호" size="256"/>
          <Column id="listNum" type="STRING" size="256" umtext="순서"/>
          <Column id="lePlaceNm" type="STRING" size="256" sumtext="교습장소"/>
          <Column id="rmkMteCn" type="STRING" size="256" sumtext="비고사항 내용"/>
          <Column id="chgRsnCn" type="STRING" size="256" sumtext="변경사유 내용"/>
          <Column id="invlDsgnNo" type="STRING" sumtext="개인지정번호" size="256"/>
          <Column id="regDsgnNo" type="STRING" sumtext="신고번호" size="256"/>
          <Column id="dstrtOfcdcCd" type="STRING" sumtext="지역교육청코드" size="256"/>
          <Column id="cteOfcdcCd" type="STRING" size="256" sumtext="관할교육청코드"/>
          <Column id="onlCvlcptPrcsStsCd" type="STRING" sumtext="처리상태코드" size="256"/>
          <Column id="lePlaceDsgnNo" type="STRING" size="256" sumtext="교습장소지정번호"/>
          <Column id="realmScCd" type="STRING" size="256"/>
          <Column id="kornFlnm" type="STRING" size="256" sumtext="성명" prop="TEXT"/>
          <Column id="_chk" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsResultTempDelete" useclientlayout="true">
        <ColumnInfo>
          <Column id="tmprInvlDsgnNo" type="STRING" sumtext="임시저장번호" size="0"/>
          <Column id="invlDsgnNo" type="STRING" sumtext="개인지정번호" size="0"/>
          <Column id="dstrtOfcdcCd" type="STRING" sumtext="지역교육청코드" size="0"/>
          <Column id="cteOfcdcCd" type="STRING" size="256" sumtext="관할교육청코드"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 개인과외교습자변경신청 (교습장소)
*  @MenuPath    TEMPLATE
*  @FileName 	hes_cptri03_m00.xfdl
*  @Creator 	HMH
*  @CreateDate 	2022.7.22
*  @Desction    개인과외교습자변경신청 (교습장소)

************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.7.22     	HMH 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs"
include "lib::hes_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 //this.fv_param;	//화면에서 넘어온 param값
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 *************************************************************************************************/
//화면 접근 시 로그인정보 확인
this.fnOninit = function(obj:nexacro.Form,e:nexacro.EventInfo)
{
	if(this.hesChkLogin("3","pa_hes_cpt_ri::hes_cptri03_m00.xfdl")){
		this.hesSetGoUrl("pa_hes_cpt_ri::hes_cptri03_m00.xfdl");
		this.form_onload(this);
	}
};

this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);
	this.dsResultTempBsc.setColumn(0,"listNum", 1); //교습장소 기본정보 row 기본셋팅
	

	this.fnInvlPrlsInfo(); //개인과외교습자정보 조회
	
};

/**
 * @description  개인과외교습자정보 조회 Transaction
 */ 
this.fnInvlPrlsInfo = function () {
	// 임시 -  세팅	
	this.dsSearchInfo.setColumn(0, "invlDsgnNo", this.hesGetInvlDsgnNo);		
	this.dsSearchInfo.setColumn(0, "cteOfcdcCd", this.hesGetAtptOfcdcOrgCode);
	this.smfSearchService("select")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors){
			var objFrame = this.getOwnerFrame();
			objFrame.form.fnSetMainpage(objFrame.form.fv_mainformUrl);	
		}	
		
		if(this.dsResultTemp.getColumn(0, "imsiScCode") == "30"){//제출정보가 있는 경우
			this.smfAlert("현재 진행중인 민원이 있습니다.\n해당 민원처리가 종료된 이후 민원을 진행하실 수 있습니다.\n[확인]버튼을 누르시면 민원신고내역조회 페이지로 이동합니다.",this.hesGoCvlcptDclrList);
			return;
		}else{
			this.dsResult.setColumn(0,"invlTelno",this.dsResult.getColumn(0,"invlTelnoDec")); 
		
			if(this.dsResultTemp.getRowCount() < 1){ //임시저장정보가 없는 경우
				var idx = this.dsResultTempBsc.addRow();
				var num = this.dsResultTempBsc.getRowCount();
				//기본정보 셋팅
				this.dsResultTempBsc.setColumn(num-1,"listNum", num);	
				
				this.dsResultTempBsc.setColumn(num-1,"invlDsgnNo", this.dsResult.getColumn(0, "invlDsgnNo"));
				this.dsResultTempBsc.setColumn(num-1,"regDsgnNo", this.dsResult.getColumn(0, "regDsgnNo"));
				this.dsResultTempBsc.setColumn(num-1,"dstrtOfcdcCd", this.dsResult.getColumn(0, "dstrtOfcdcCd"));
				this.dsResultTempBsc.setColumn(num-1,"cteOfcdcCd",this.dsResult.getColumn(0,"cteOfcdcCd"));
				this.dsResultTempBsc.setColumn(num-1,"lePlaceNm",this.dsResult.getColumn(0,"lePlaceNm")); 
				this.dsResultTempBsc.setColumn(num-1,"lePlaceDsgnNo",this.dsResult.getColumn(0,"lePlaceDsgnNo")); 
			}
		}
	});
	
	
 };
 
/**
 * @description  교습장소 임시저장정보 조회 Transaction
 */ 
this.fnTmprStrgInfo = function () {
	
	this.smfSearchService("selectTemp")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;	
		
		
		
		
	});
 };
 
/**
 * @description  교습장소 임시저장정보 그리드 셀클릭 이벤트
 */
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{ 

	//선택한 셀만 체크박스 체크
	for (var i =0; i<this.div00.form.grdMain.rowcount; i++) {

		if( i == e.row){ //선택한 셀 체크박스 체크
			this.dsResultTemp.setColumn(e.row, "_chk", 1);
			
		}else{
			this.dsResultTemp.setColumn(i, "_chk", 0);
		}
    }
	
	//데이터셋 초기화
	this.dsResultTempBsc.clearData(); //교습장소 기본정보 그리드 초기화
	
	var nRow = e.row;
	var objDs = obj.getBindDataset();
	var sTmprInvlDsgnNo = objDs.getColumn(nRow,"tmprInvlDsgnNo");
	
	//사용자정보 조회시 필요한 값 셋팅
	this.dsSearchTempBsc.setColumn(0,"tmprInvlDsgnNo",sTmprInvlDsgnNo);
	this.dsSearchTempBsc.setColumn(0,"invlDsgnNo", this.dsResult.getColumn(0,"invlDsgnNo"));
	this.dsSearchTempBsc.setColumn(0,"dstrtOfcdcCd", this.dsResult.getColumn(0,"dstrtOfcdcCd"));		
	this.dsResultTempBsc.setColumn(0,"cteOfcdcCd",this.dsResult.getColumn(0,"cteOfcdcCd"));
	
	//임시내역 삭제시 필요한 값 셋팅
	//this.dsResultTempDelete.setColumn(0,"tmprInvlDsgnNo",sTmprInvlDsgnNo);
	
	//교습장소 기본정보 조회  
	this.fnTmprStrgInfoBsc();
	
};

/**
 * @description 교습장소 기본정보 조회 Transaction
 */
  this.fnTmprStrgInfoBsc = function () {
	this.smfSearchService("selectTempBsc")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;		
	});
 };

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};

/**
 * @description 행추가
*/
this.btnAddRow_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
	if(this.smfIsNull(this.dsResultTemp.getColumn(0, "tmprInvlDsgnNo")) == true ){// 임시저장정보가 없을 시 

		var idx = this.dsResultTempBsc.addRow();
		var num = this.dsResultTempBsc.getRowCount();
		//기본정보 셋팅
		this.dsResultTempBsc.setColumn(num-1,"listNum", num);	
		
		this.dsResultTempBsc.setColumn(num-1,"invlDsgnNo", this.dsResult.getColumn(0, "invlDsgnNo"));
		this.dsResultTempBsc.setColumn(num-1,"regDsgnNo", this.dsResult.getColumn(0, "regDsgnNo"));
		this.dsResultTempBsc.setColumn(num-1,"dstrtOfcdcCd", this.dsResult.getColumn(0, "dstrtOfcdcCd"));
		this.dsResultTempBsc.setColumn(num-1,"cteOfcdcCd",this.dsResult.getColumn(0,"cteOfcdcCd"));
		this.dsResultTempBsc.setColumn(num-1,"lePlaceDsgnNo",this.dsResult.getColumn(0,"lePlaceDsgnNo")); 

	}else{// 임시저장정보가 있을시 
	
		if(this.dsSearchTempBsc.getColumn(0,"tmprInvlDsgnNo") != null ){// 선택한 임시저장정보 있음

			var idx = this.dsResultTempBsc.addRow();
			var num = this.dsResultTempBsc.getRowCount();
			
			//기본정보 셋팅
			this.dsResultTempBsc.setColumn(num-1,"listNum", num);
			this.dsResultTempBsc.setColumn(num-1,"invlDsgnNo", this.dsResult.getColumn(0, "invlDsgnNo"));
			this.dsResultTempBsc.setColumn(num-1,"regDsgnNo", this.dsResult.getColumn(0, "regDsgnNo"));
			this.dsResultTempBsc.setColumn(num-1,"dstrtOfcdcCd", this.dsResult.getColumn(0, "dstrtOfcdcCd"));
			this.dsResultTempBsc.setColumn(num-1,"cteOfcdcCd",this.dsResult.getColumn(0,"cteOfcdcCd"));
			this.dsResultTempBsc.setColumn(num-1,"tmprInvlDsgnNo", this.dsSearchTempBsc.getColumn(0,"tmprInvlDsgnNo"));
			this.dsResultTempBsc.setColumn(num-1,"lePlaceNm",this.dsResult.getColumn(0,"lePlaceNm")); 
			this.dsResultTempBsc.setColumn(num-1,"lePlaceDsgnNo",this.dsResult.getColumn(0,"lePlaceDsgnNo")); 
		
		}else{// 임시저장정보 미선택
			alert("임시저장정보를 선택해주세요.");
		}
	}

	
};

/**
 * @description 행삭제
*/
this.btnDeleteRow_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	for(var i =0; i<this.dsResultTempBsc.rowcount; i++){
		if(this.dsResultTempBsc.getColumn(i,"_chk") == 1){//체크된 row 삭제
			this.dsResultTempBsc.deleteRow(i); 
		}
	}
	
 	for(var i =0; i<this.dsResultTempBsc.rowcount; i++){ // 순번 재설정
 		
 		this.dsResultTempBsc.setColumn(i,"listNum", i+1);
 	}
};

/**
 * @description 재입력 버튼 클릭(초기화)
*/
this.btnInit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsResultTempBsc.clearData(); //교습장소 기본정보 그리드 초기화
	var idx = this.dsResultTempBsc.addRow();
	this.dsResultTempBsc.setColumn(0,"listNum", 1); //교습장소 기본정보 row 기본셋팅
	this.fnInvlPrlsInfo(); //개인과외교습자정보 조회

};

/**
 * @description 임시저장 버튼 클릭
*/
this.btnTmpSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	this.div00.form.grdMain00.updateToDataset();

	for(var i =0; i<this.dsResultTempBsc.rowcount; i++){ //저장값
		
		var sLePlaceNm = this.dsResultTempBsc.getColumn(i, "lePlaceNm"); 
		var sLePlaceDsgnNo = this.dsResultTempBsc.getColumn(i, "lePlaceDsgnNo"); 
		var sChgRsnCn = this.dsResultTempBsc.getColumn(i, "chgRsnCn");
		var sRmkMteCn = this.dsResultTempBsc.getColumn(i, "rmkMteCn");
		trace("sLePlaceDsgnNo : "+sLePlaceDsgnNo);
		if(sLePlaceNm == null || sLePlaceNm == "" ){
			
			sLePlaceNm = "$$"; 
		}else{
			sLePlaceNm = this.smfReplace(sLePlaceNm,",","^^"); 
		}
		
		if(sChgRsnCn == null || sChgRsnCn == "" ){
			
			sChgRsnCn = "$$"; 
		}else{
			sChgRsnCn = this.smfReplace(sChgRsnCn,",","^^"); 
		}
		
		if(sRmkMteCn == null || sRmkMteCn == "" ){	// 텍스트로 변환시 널 오류 - 대체 문자로 임시 설정
			
			sRmkMteCn = "$$"; 
			
		}else{	// 텍스트로 변환시 ',' 오류 - 대체 문자로 임시 설정
			sRmkMteCn = this.smfReplace(sRmkMteCn,",","^^"); 
		}
		
		this.dsResultTempBsc.setColumn(i,"onlCvlcptPrcsStsCd", "01");
		this.dsResultTempBsc.setColumn(i,"lePlaceNm", sLePlaceNm); 
		this.dsResultTempBsc.setColumn(i,"lePlaceDsgnNo",sLePlaceDsgnNo); 
		this.dsResultTempBsc.setColumn(i,"chgRsnCn",sChgRsnCn);
		this.dsResultTempBsc.setColumn(i,"rmkMteCn",sRmkMteCn);
		this.dsResultTempBsc.setColumn(i,"cteOfcdcCd",this.dsResult.getColumn(0,"cteOfcdcCd"));
	}
	this.dsResultTempDelete.clearData(); 
	this.dsResultTempDelete.addRow();
	this.dsResultTempDelete.setColumn(0,"tmprInvlDsgnNo", this.dsSearchTempBsc.getColumn(0, "tmprInvlDsgnNo"));
	this.dsResultTempDelete.setColumn(0,"invlDsgnNo", this.dsSearchTempBsc.getColumn(0, "invlDsgnNo"));
	this.dsResultTempDelete.setColumn(0,"dstrtOfcdcCd", this.dsSearchTempBsc.getColumn(0, "dstrtOfcdcCd"));		
	this.dsResultTempDelete.setColumn(0,"cteOfcdcCd",this.dsResult.getColumn(0,"cteOfcdcCd"));

	this.fnLePlaceTmprStrg(); //교습장소 임시저장
	
};
/**
 * @description 교습장소 임시저장 
 */
  this.fnLePlaceTmprStrg = function () {

		this.smfSaveService("saveLePlaceTmprStrg")
			.run() 
			.callback(function(callbackParams){
		if(callbackParams.errors) return;
		this.dsResultTempBsc.clearData(); //교습장소 기본정보 그리드 초기화
	    this.dsResultTempDelete.clearData(); //교습장소 기본정보 그리드 초기화
		this.dsResultTempBsc.setColumn(0,"listNum", 1); //교습장소 기본정보 row 기본셋팅
	    this.fnInvlPrlsInfo(); //개인과외교습자정보 조회
	});	
  	
 };

/**
 * @description 교습장소 임시내역삭제 Transaction
 */			
this.btnTmpDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
	if( this.smfIsNull(this.dsSearchTempBsc.getColumn(0, "tmprInvlDsgnNo")) == true){ //임시승인번호가 없으면 
			alert("삭제할 임시내역이 없습니다.");
		}else{
			this.dsResultTempDelete.clearData(); 
			this.dsResultTempDelete.addRow();
			//this.dsResultTempDelete.setColumn(0,"tmprInvlDsgnNo", this.dsSearchTempBsc.getColumn(0, "tmprInvlDsgnNo"));
			//this.dsResultTempDelete.setColumn(0,"invlDsgnNo", this.dsSearchTempBsc.getColumn(0, "invlDsgnNo"));
			//this.dsResultTempDelete.setColumn(0,"dstrtOfcdcCd", this.dsSearchTempBsc.getColumn(0, "dstrtOfcdcCd"));
			this.dsResultTempBsc.setColumn(0,"cteOfcdcCd", this.dsResult.getColumn(0, "cteOfcdcCd"));
		
			// 삭제처리
			this.smfDeleteService("deleteLePlaceTmprStrg")
			.run()
			// 콜백
			.callback(function(callbackParams){ 
				if(callbackParams.errors) return;
				alert("삭제되었습니다.");
				this.dsResultTempBsc.setColumn(0,"listNum", 1); //교습장소 기본정보 row 기본셋팅
	            this.fnInvlPrlsInfo(); //개인과외교습자정보 조회
			});
		}

	
	
};

/**
 * @description 변경신고서제출 Transaction
 */

this.btnChgDbilSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	for(var i =0; i<this.dsResultTempBsc.rowcount; i++){ //저장값
		
		var sLePlaceNm = this.dsResultTempBsc.getColumn(i, "lePlaceNm"); 
		var sLePlaceDsgnNo = this.dsResultTempBsc.getColumn(i, "lePlaceDsgnNo"); 
		var sChgRsnCn = this.dsResultTempBsc.getColumn(i, "chgRsnCn");
		var sRmkMteCn = this.dsResultTempBsc.getColumn(i, "rmkMteCn");
		var sRmkMteCn = this.dsResultTempBsc.getColumn(i, "rmkMteCn");
		if(sLePlaceNm == null || sLePlaceNm == "" ){
			
			sLePlaceNm = "$$"; 
		}else{
			sLePlaceNm = this.smfReplace(sLePlaceNm,",","^^"); 
		}
		
		if(sChgRsnCn == null || sChgRsnCn == "" ){
			
			sChgRsnCn = "$$"; 
		}else{
			sChgRsnCn = this.smfReplace(sChgRsnCn,",","^^"); 
		}
		
		if(sRmkMteCn == null || sRmkMteCn == "" ){	// 텍스트로 변환시 널 오류 - 대체 문자로 임시 설정
			
			sRmkMteCn = "$$"; 
			
		}else{	// 텍스트로 변환시 ',' 오류 - 대체 문자로 임시 설정
			sRmkMteCn = this.smfReplace(sRmkMteCn,",","^^"); 
		}
		
		this.dsResultTempBsc.setColumn(i,"onlCvlcptPrcsStsCd", "02");
		this.dsResultTempBsc.setColumn(i,"lePlaceNm", sLePlaceNm); 
		this.dsResultTempBsc.setColumn(i,"lePlaceDsgnNo",sLePlaceDsgnNo); 
		this.dsResultTempBsc.setColumn(i,"chgRsnCn",sChgRsnCn);
		this.dsResultTempBsc.setColumn(i,"rmkMteCn",sRmkMteCn);
		this.dsResultTempBsc.setColumn(i,"cteOfcdcCd",this.dsResult.getColumn(0,"cteOfcdcCd"));
	}
	this.dsResultTempDelete.clearData(); 
	this.dsResultTempDelete.addRow();
	this.dsResultTempDelete.setColumn(0,"tmprInvlDsgnNo", this.dsSearchTempBsc.getColumn(0, "tmprInvlDsgnNo"));
	this.dsResultTempDelete.setColumn(0,"invlDsgnNo", this.dsSearchTempBsc.getColumn(0, "invlDsgnNo"));
	this.dsResultTempDelete.setColumn(0,"dstrtOfcdcCd", this.dsSearchTempBsc.getColumn(0, "dstrtOfcdcCd"));		
	this.dsResultTempDelete.setColumn(0,"cteOfcdcCd",this.dsResult.getColumn(0,"cteOfcdcCd"));
	this.fnLePlaceTmprStrg(); //교습장소 임시저장	
};

this.sta00_01_00_00_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	this.smfSetWorkPage("pa_hes_cpt_ri::hes_cptri02_m00.xfdl");
};

this.sta00_01_00_00_00_00_00_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
