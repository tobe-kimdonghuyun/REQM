        <Div id="div00_00_00" taborder="5" left="0" cssclass="div_WF_InfoBOX" right="0" top="964" initvalueid="ivDivAccessibilityOff" height="190">
          <Layouts>
            <Layout>
              <Static id="sta00_00_01_01_00" taborder="0" left="29" top="28" height="23" cssclass="sta_WF_InfoTit" text="이용 전 확인해주세요." wordWrap="char" width="200" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00_01_01" taborder="1" left="30" top="67" height="23" cssclass="sta_WF_InfoTxt_Blue" text="학습자의 주거지, 교습자의 주거지는 「건축법 시행령」별표 1의 단독주택 또는 공동주택으로 오피스텔 등에서 이루어지는 개인과외교습을 제한&lt;fc v='#172f57'&gt;하고 있음을 알려드립니다.&lt;/fc&gt;" wordWrap="char" width="1138" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00_01_01_01" taborder="2" left="30" top="89" height="23" cssclass="sta_WF_InfoTxt_Blue" text="교습자 주소지가 변경됐을 경우 관할 교육지원청 담당자가 주소 중복 여부를 확인합니다. 이에 따라 변경 신고가 반려 처리될 수 있음&lt;fc v='#172f57'&gt;을 알려 드립니다.&lt;/fc&gt;" wordWrap="char" width="1138" usedecorate="true" initvalueid="ivStcAccessibilityOn" onclick="div00_00_sta00_00_01_01_01_onclick"/>
              <Static id="sta00_00_01_01_01_00_00" taborder="3" left="30" top="113" height="23" cssclass="sta_WF_InfoTxt_Blue" text="현 교육지원청 관할 구역 외로 주소가 변경된 경우, 폐지신고를 한 뒤 주소 관할 교육지원청에서 신규로 등록&lt;fc v='#172f57'&gt;하셔야 합니다.&lt;/fc&gt;" wordWrap="char" width="1138" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta00_00_01_01_01_00" taborder="4" left="30" top="137" height="23" cssclass="sta_WF_InfoTxt_Blue" text="&lt;fc v='#172f57'&gt;담당자 확인 후 보완 사항이 없을 경우 변경신청이 완료되며, &lt;/fc&gt;재발급된 신고증명서는 교습자의 주소로 등기발송&lt;fc v='#172f57'&gt;됩니다.&lt;/fc&gt;" wordWrap="char" width="1138" usedecorate="true" initvalueid="ivStcAccessibilityOn"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00" left="0" top="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" taborder="5"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_01" taborder="6" left="30" top="51" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="30" initvalueid="ivStcAccessibilityOff"/>
              <Static id="Static99_00_00_00_00_01_00_00_01_00_00" taborder="7" left="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" bottom="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="sta99_00_00_00_00_01_01" taborder="8" left="0" top="30" cssclass="sta_GD_Size" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="30" bottom="30" text="30" initvalueid="ivStcAccessibilityOff"/>
