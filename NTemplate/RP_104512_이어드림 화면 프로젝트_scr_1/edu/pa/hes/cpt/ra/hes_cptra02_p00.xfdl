    <Script type="xscript5.1"><![CDATA[/**
*  대국민 - 학원강사관리
*  @MenuPath    TEMPLATE
*  @FileName 	hes_cptra02_m00.xfdl
*  @Creator 	김명주
*  @CreateDate 	2022.7.01
*  @Desction    학원강사관리
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.6.20     	김명주 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs"
include "lib::hes_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
// 채용 : 0 / 해임 : 1 구분
this.fv_empmnRlsofc = 0;	// 초기 값은 채용

// 채용시 버튼영역 위치 세팅
this.btnTop = 0;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 폼 초기화 이벤트
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{	
	// 팝업 폼 초기화
	this.smfInitPopup(obj);
	
	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
		
	// 공통코드 호출
	this.smfCodeList("code", [this.dsAcbgCd, this.dsInsrScCd, this.dsFrgnrInsrStayQlfCd
							, this.dsInsrQlfScCd, this.dsPrufDocuSbmsnMetCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;	
			
			this.listInstutInfo();
		})		
		.run()
	;	
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 학원정보 조회 함수
this.listInstutInfo = function ()
{
	//조회조건 set
	this.dsSearch00.setColumn(0, "acaDsgnNo", this.hesGetAcaDsgnNo); //변조체크용
	this.dsSearch00.setColumn(0, "searchAcaDsgnNo", this.pv_params.acaDsgnNo);
	this.dsSearch00.setColumn(0, "acaInstiScCd", this.pv_params.acaInstiScCd);
	this.dsSearch00.setColumn(0, "atptOfcdcOrgCode", this.pv_params.dstrtOfcdcCd);
	
	this.smfSearchService("listInstutInfo")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		// 데이터셋 복사하기
		this.dsInstutInfo.copyRow(0, this.dsMain00, 0);
		
		this.fnTmprInfoSearch();
	});
}

// 임시저장정보 조회(강사 채용)
this.fnTmprInfoSearch = function(){
	// 파라미터 세팅
	this.dsSearch02.copyRow(0, this.dsInstutInfo, this.dsInstutInfo.rowposition);
	this.dsSearch02.setColumn(0, "tmprInvlDsgnNo", this.pv_params.tmprAcaDsgnNo);
	this.dsSearch02.setColumn(0, "atptOfcdcOrgCode", this.pv_params.dstrtOfcdcCd);
	
	// 초기화(강사 해임)
	this.dsMain01.clearData();
	
	this.dsDetailInfo00.deleteRow(0);
	this.dsDetailInfo00.addRow();
	
	// 초기화(강사 채용)
	this.dsMain02.clearData();
	
	this.dsDetailInfo01.deleteRow(0);
	this.dsDetailInfo01.addRow();
	
	this.smfSearchService("listInstrctrEmpmnCnTmpr")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		// 데이터셋 복사하기
		this.dsDetailInfo00.copyRow(0, this.dsMain02, 0);	
		
		if(this.dsDetailInfo00.getColumn(0,"empmnScCd") == "2"){
			this.fv_empmnRlsofc = 1;
		}
		
		//제출상태인 경우 철회버튼 활성화
		if(this.dsDetailInfo00.getColumn(0,"onlCvlcptPrcsStsCd") == "02"){
			this.btnRtrcn.set_visible(true);
		}
		
	});
};

// 전송값 세팅
this.fnSaveSetting = function(gbn) {

	if(this.fv_empmnRlsofc == 1){
		// 강사해임 인 경우
		
		// 학원정보 내용 복사
		this.dsSave00.copyRow(0, this.dsInstutInfo, this.dsInstutInfo.rowposition);
		// 임시정보 내용 복사
		this.dsSave00.copyRow(0, this.dsMain02, this.dsTmprInfoList.rowposition);
		
		// 관할교육청코드, 지역교육청코드 세팅
		var cteOfcdcCd = this.dsSave00.getColumn(0, "cteOfcdcCd");
		
		this.dsSave00.setColumn(0, "dstrtOfcdcCd", cteOfcdcCd);
			
		cteOfcdcCd = cteOfcdcCd.substring(0, 3) + "0000001";
		this.dsSave00.setColumn(0, "cteOfcdcCd", cteOfcdcCd);
		
		// 임시학원지정번호 세팅
		this.dsSave00.setColumn(0,"tmprInvlDsgnNo",this.pv_params.tmprAcaDsgnNo);
		
		// 처리상태코드 세팅
		this.dsSave00.setColumn(0, "onlCvlcptPrcsStsCd", "01");
		this.dsSave00.setColumn(0, "onlCvlcptAprvCd", "0");
		
		// 임시저장여부 Y로 세팅
		this.dsSave00.setColumn(0, "tmprStrgYn", "Y");
		// 채용통보일자 초기화
		this.dsSave00.setColumn(0, "empmnNtfctnYmd", "");
	} else if(this.fv_empmnRlsofc == 0){
	
		// 강사채용 인 경우
		// 학원정보 내용 복사
		this.dsSave01.copyRow(0, this.dsInstutInfo, this.dsInstutInfo.rowposition);
		// 임시정보 내용 복사
		this.dsSave01.copyRow(0, this.dsMain02, this.dsTmprInfoList.rowposition);
			
		// 채용관련 내용 복사
		this.dsSave01.copyRow(0, this.dsDetailInfo01, this.dsDetailInfo01.rowposition);
		
		// 관할교육청코드, 지역교육청코드 세팅
		var cteOfcdcCd = this.dsSave01.getColumn(0, "cteOfcdcCd");
		//alert("cteOfcdcCd : " + cteOfcdcCd);
		
		this.dsSave01.setColumn(0, "dstrtOfcdcCd", cteOfcdcCd);
			
		cteOfcdcCd = cteOfcdcCd.substring(0, 3) + "0000001";
		this.dsSave01.setColumn(0, "cteOfcdcCd", cteOfcdcCd);
		
		// 전화번호 세팅
		// 임시 앞자리 세팅
		this.dsDetailInfo01.setColumn(0, "invlTelno1", "02");
		var invlTelno = this.dsDetailInfo01.getColumn(0, "invlTelno1") + "-" +
						this.dsDetailInfo01.getColumn(0, "invlTelno2") + "-" +
						this.dsDetailInfo01.getColumn(0, "invlTelno3");		
		this.dsSave01.setColumn(0, "invlTelno", invlTelno);
		
		// 임시학원지정번호 세팅
		this.dsSave01.setColumn(0,"tmprInvlDsgnNo",this.pv_params.tmprAcaDsgnNo);
	
		// 처리상태코드 세팅
		this.dsSave01.setColumn(0, "onlCvlcptPrcsStsCd", "01");
		this.dsSave01.setColumn(0, "onlCvlcptAprvCd", "0");
		
		// 채용통보일자 초기화
		this.dsSave01.setColumn(0, "empmnNtfctnYmd", "");
	}
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/


this.btnRtrcn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.fv_empmnRlsofc == 1){
		// 강사해임 수정 기능

		// 전송 값 세팅
		this.fnSaveSetting('01');
			
		this.smfConfirm("철회하시겠습니까?", function(result){
		if(result.confirmResult){
				this.smfSaveService("updateInstrctrRlsofcCnTmpr")
				.showConfirm(false) 
				.run()
				.callback(function(callbackParams){
					if(callbackParams.errors) return;
					alert("철회되었습니다.");
					// 저장정보 초기화
					this.dsSave00.deleteRow(0);
					this.dsSave00.addRow();
					this.close(true);
				});
			}
		});	
		
	} else if(this.fv_empmnRlsofc == 0){
		// 강사채용 인 경우
		this.fnSaveSetting('01');
			
		this.smfConfirm("철회하시겠습니까?", function(result){
		if(result.confirmResult){
				this.smfSaveService("updateInstrctrEmpmnCnTmpr")
				.showConfirm(false) 
				.run()
				.callback(function(callbackParams){
					if(callbackParams.errors) return;
					alert("철회되었습니다.");
					// 저장정보 초기화
					this.dsSave01.deleteRow(0);
					this.dsSave01.addRow();
					this.smfSendResponseToOpener({
						"search": true
					});
					this.close(true);
				});
			}
		});	
	}
};

this.btnCncl_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSendResponseToOpener({
		"search": false
	});
	this.close(false);
};
]]></Script>
