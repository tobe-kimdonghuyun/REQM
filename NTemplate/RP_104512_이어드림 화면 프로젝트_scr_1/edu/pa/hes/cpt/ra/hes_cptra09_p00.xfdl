    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 학원자율점검신청관리
*  @MenuPath    TEMPLATE
*  @FileName 	hes_cptra09_m00.xfdl
*  @Creator 	김명주
*  @CreateDate 	2022.10.24
*  @Desction    학원자율점검신청관리
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.10.24     	김명주 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs"
include "lib::hes_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 폼 초기화 이벤트
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{	
	// 폼 초기화
	this.smfInitPopup(obj);
	
	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	
	// 학원정보 조회
	this.listInstutInfo();
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 학원정보 조회 함수
this.listInstutInfo = function ()
{
	// 조회값 세팅
	this.dsSearch00.setColumn(0, "acaDsgnNo", this.hesGetAcaDsgnNo); //변조체크용
	this.dsSearch00.setColumn(0, "searchAcaDsgnNo", this.pv_params.acaDsgnNo);
	this.dsSearch00.setColumn(0, "acaInstiScCd", this.pv_params.acaInstiScCd);
	this.dsSearch00.setColumn(0, "atptOfcdcOrgCode", this.pv_params.dstrtOfcdcCd);
	
	// 학원정보 조회(로그인 후에 조회 1번만 하는 것으로 변경 필요)
	this.smfSearchService("listInstutInfo")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		// 데이터셋 복사하기
		this.dsInstutInfo.copyData(this.dsMain00);
		//임시정보조회
		this.listSlfctrlChckReqstCnTmpr();
	});
};

// 임시정보 조회 함수
this.listSlfctrlChckReqstCnTmpr = function ()
{
	// 파라미터 세팅
	this.dsSearch01.copyRow(0, this.dsSearch00, 0);
	
	this.dsSearch01.setColumn(0, "dstrtOfcdcCd", this.dsInstutInfo.getColumn(0, "cteOfcdcCd"));
	this.dsSearch01.setColumn(0, "slctlChckDsgnNo", this.pv_params.tmprAcaDsgnNo);
	
	this.smfSearchService("listSlfctrlChckReqstCnTmpr")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		//제출상태인 경우 철회버튼 활성화 
		if(this.dsMain01.getColumn(0,"onlCvlcptPrcsStsCd") == "02"){
			this.btnRtrcn.set_visible(true);
		}
		
		// 관할교육청명, 학원명 세팅
		this.dsMain01.copyRow(0, this.dsInstutInfo, this.dsInstutInfo.rowposition);	
		
		//신청인경우 결과보고 영역 숨김처리
		if(this.dsMain01.getColumn(0,"prufDocuSbmsnMetCd") != undefined){
			this.divRlt.set_visible(true);
			
			var fileRefrnId = this.dsMain01.getColumn(0, "fileRefrnId");
	
			// 업로드 초기화
			this.divRlt.form.divFileUpload.form.fnResetUpload();
			
			//파일참조ID가 있는 경우 파일정보조회
			if(fileRefrnId != ""){
				this.transaction(
					 "fn_filesearch" // serviceId
					,"baseUrl::/cm_cmc_file_upload_001.do" // url
					,"" // inDataset
					,"dsOutFileinfo=atchFileinfo" // outDataset
					,"fileRefrnId='"+fileRefrnId+"'"
					,""
					,false // true: 비동기, false:동기
			   );
				
				var responseCustomValue = "";
				var sDownloadUrl       = ""; 
				var sHandlerCode       = "PA.SAM.PLE";
				var sFileSn            = this.dsOutFileinfo.getColumn(0,"fileRefrnId"   );
				var sFileSeq           = this.dsOutFileinfo.getColumn(0,"fileId"        );
				var sFileSize          = this.dsOutFileinfo.getColumn(0,"atchFileMg"    );
				var sBackendFilename   = this.dsOutFileinfo.getColumn(0,"atchFileGuid"  );
				var sForntendFilename  = this.dsOutFileinfo.getColumn(0,"atchFileNm"    );
				var sFileEncryptYn     = this.dsOutFileinfo.getColumn(0,"fileEncryptYn" );
				var sPrivInfoFiltYn    = this.dsOutFileinfo.getColumn(0,"privInfoFiltYn");
				var sFileSaveStg       = this.dsOutFileinfo.getColumn(0,"fileSaveStg"   );
				var sFileInfSaveYn     = this.dsOutFileinfo.getColumn(0,"fileInfSaveYn" );
				
				this.divRlt.form.divFileUpload.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sForntendFilename, sFileSeq, sDownloadUrl
														  ,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn );
				
				this.dsSave.setColumn(0, "sfileRefrnId", sFileSn);
			}
		}else{
			this.divRlt.set_visible(false);
			this.divBtn.set_top(this.divBtn.top - this.divRlt.height);
		}
	});
};

// 전송 값 세팅
this.fnSaveSetting = function(gbn) {
	// 학원정보 내용 복사
	this.dsSave.copyRow(0, this.dsInstutInfo, this.dsInstutInfo.rowposition);
	// 입력된 보험내용 복사
	this.dsSave.copyRow(0, this.dsMain01, this.dsMain01.rowposition);
		
	// 학원개인지정번호 세팅(학원지정번호로... 컬럼명 확인 필요함)
	this.dsSave.setColumn(0, "acaInvlDsgnNo", this.dsInstutInfo.getColumn(0, "acaDsgnNo"));	
	
	this.dsSave.setColumn(0, "onlCvlcptPrcsStsCd", "01");
	this.dsSave.setColumn(0, "onlCvlcptAprvCd", "0");
	
	// 점검대상명 세팅(학원명)
	this.dsSave.setColumn(0, "chckTrgtNm", this.dsSave.getColumn(0, "acaNm"));
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

// 임시내역수정
this.divReg_btnModify_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 전송 값 세팅
	this.fnSaveSetting('01');
	
	this.smfConfirm("철회하시겠습니까?", function(result){
		if(result.confirmResult){
			// 서비스 객체 생성
			this.smfSaveService("updateSlfctrlChckReqstCnTmpr")
				.showConfirm(false) 
				// 실행
				.run()
				// 콜백
				.callback(function(callbackParams){
					if(callbackParams.errors) return;
					alert("철회되었습니다.");
					// 저장정보 초기화
					this.dsSave.deleteRow(0);
					this.dsSave.addRow();
					this.smfSendResponseToOpener({
						"search": true
					});
					this.close(true);
				});
		}
	});	
	
};


this.btnCncl_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSendResponseToOpener({
		"search": false
	});
	this.close(false);
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="divInstutInfo01.form.stakornOrgNm" propid="text" datasetid="dsInstutInfo" columnid="kornOrgNm"/>
      <BindItem id="item1" compid="divInstutInfo01.form.staAcaKndNm" propid="text" datasetid="dsInstutInfo" columnid="acaKndNm"/>
      <BindItem id="item2" compid="divInstutInfo01.form.staRegDsgnNo" propid="text" datasetid="dsInstutInfo" columnid="regDsgnNo"/>
      <BindItem id="item3" compid="divInstutInfo01.form.staAcaNm" propid="text" datasetid="dsInstutInfo" columnid="acaNm"/>
      <BindItem id="item4" compid="divInstutInfo01.form.staRealmScCodeNm" propid="text" datasetid="dsInstutInfo" columnid="realmScCodeNm"/>
      <BindItem id="item5" compid="divInstutInfo01.form.staFaTelno" propid="text" datasetid="dsInstutInfo" columnid="faTelno"/>
      <BindItem id="item6" compid="divReg.form.rdoPrufDocuSbmsnMetCd" propid="value" datasetid="dsMain01" columnid="prufDocuSbmsnMetCd"/>
      <BindItem id="item7" compid="divReg.form.txtChckRltCn" propid="value" datasetid="dsMain01" columnid="chckRltCn"/>
      <BindItem id="item8" compid="divReg.form.txtActnRltCn" propid="value" datasetid="dsMain01" columnid="actnRltCn"/>
      <BindItem id="item9" compid="divRlt.form.txtChckRltCn" propid="value" datasetid="dsMain01" columnid="chckRltCn"/>
      <BindItem id="item10" compid="divRlt.form.txtActnRltCn" propid="value" datasetid="dsMain01" columnid="actnRltCn"/>
      <BindItem id="item11" compid="divRlt.form.rdoPrufDocuSbmsnMetCd" propid="value" datasetid="dsMain01" columnid="prufDocuSbmsnMetCd"/>
    </Bind>
  </Form>
</FDL>
