    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 학원변경통보
*  @MenuPath    TEMPLATE
*  @FileName 	hes_cptra01_m00.xfdl
*  @Creator 	김명주
*  @CreateDate 	2022.6.13
*  @Desction    학원변경통보
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.6.13     	김명주 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs"
include "lib::hes_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 this.acaNmDpcnCeck = "N";
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 //화면 접근 시 로그인정보 확인
this.fnOninit = function(obj:nexacro.Form,e:nexacro.EventInfo)
{
	if(this.hesChkLogin("1","pa_hes_cpt_ra::hes_cptra01_m00.xfdl")){
		this.hesSetGoUrl("pa_hes_cpt_ra::hes_cptra01_m00.xfdl");
		this.fnOnload(this);
	}
};

 this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	
	// [첨부파일]첨부파일 세팅
	//this.atchFileLoad();
	
	
	// 업로드 초기설정 - 학원변경통보	
	this.divAplyCn.form.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;        // 필요한 경우만 세팅(세팅권장)
	this.divAplyCn.form.divFileUpload.UPLOAD_OnError        = this.fnEventUploadError;           // 필요한 경우만 세팅(세팅권장)
	this.divAplyCn.form.divFileUpload.UPLOAD_AfterAddFile   = this.fnEventAfterAddFile;          // 필요한 경우만 세팅(세팅권장)
	this.divAplyCn.form.divFileUpload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)
	
	
	// 폼 초기화
	this.smfInitForm(obj);
	
	// 학원정보 조회
	this.listInstutInfo();
};
 /************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 // 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};
