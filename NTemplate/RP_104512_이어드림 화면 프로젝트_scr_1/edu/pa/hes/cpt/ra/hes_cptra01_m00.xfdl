 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 this.fnAgreCallback = function(){
	//민원신고내역조회 화면 이동
				
 }
// 전화번호 초기화
this.initClaiInfoTelno = function (){
	this.divClaiInfo.form.edtInvlTelno1.set_value("");
	this.divClaiInfo.form.edtInvlTelno2.set_value("");
	this.divClaiInfo.form.edtInvlTelno3.set_value("");

	this.divClaiInfo.form.edtMblTelno1.set_value("");
	this.divClaiInfo.form.edtMblTelno2.set_value("");
	this.divClaiInfo.form.edtMblTelno3.set_value("");
}

this.initAplyCnTelno = function (){
	this.divAplyCn.form.edtMblTelno1.set_value("");
	this.divAplyCn.form.edtMblTelno2.set_value("");
	this.divAplyCn.form.edtMblTelno3.set_value("");
}

// 학원정보 조회
this.listInstutInfo = function (){	
	this.dsSearch02.setColumn(0, "acaDsgnNo", this.hesGetAcaDsgnNo);	
	this.dsSearch02.setColumn(0, "acaInstiScCd", this.hesGetAcaInstiScCd);
	this.dsSearch02.setColumn(0, "atptOfcdcOrgCode", this.hesGetAtptOfcdcOrgCode);
	this.dsSearch00.setColumn(0, "acaDsgnNo", this.hesGetAcaDsgnNo);	
	this.dsSearch00.setColumn(0, "acaInstiScCd", this.hesGetAcaInstiScCd);
	this.dsSearch00.setColumn(0, "atptOfcdcOrgCode", this.hesGetAtptOfcdcOrgCode);
	
	// 학원정보 조회
	this.smfSearchService("listInstutInfo")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors){
			var objFrame = this.getOwnerFrame();
			objFrame.form.fnSetMainpage(objFrame.form.fv_mainformUrl);	
		}
		// 학원 개수에 따른 학원정보 세팅
		if(this.dsMain00.getRowCount() > 1){
			// 1개 이상이면
			// 데이터셋 복사하기
			this.dsInstutInfoList.copyData(this.dsMain00);
		}else{		
			// 1개 이면
			this.divInstutInfo00.set_visible(false);
			var divInstutInfo00Top = this.divInstutInfo00.top;
			var divInstutInfo01Top = this.divInstutInfo01.top;
			var top = divInstutInfo01Top - divInstutInfo00Top;
			
			this.divInstutInfo01.set_top(divInstutInfo01Top - top);			
			this.divClaiInfo.set_top(this.divClaiInfo.top - top);
			this.divMain.set_top(this.divMain.top - top);
			this.divAplyCn.set_top(this.divAplyCn.top - top);
			
			// 데이터셋 복사하기
			this.dsInstutInfo.copyData(this.dsMain00);
			
			this.dsMain01.clearData();
			
			this.initClaiInfoTelno();
			this.initAplyCnTelno();
			
			// 조회 조건 세팅
			this.dsSearch01.copyRow(0, this.dsInstutInfo, this.dsInstutInfo.rowposition);
			
			// 신청인 정보 조회 -> 학원교습소 정보 조회 시 같이 가져올 수 있음
			// 신청인 정보 조회 후 임시정보 조회
			this.listInstutChangeCnTmpr();
		}
	});
};

// 신청정보 세팅
this.aplyInfoSetting = function (){
	// 변경 전 내용이 없는 경우
	// 명칭 : 현재 학원명
	if(this.dsTmprInfo.getColumn(0, "bfchNm") == ""){
		this.dsTmprInfo.setColumn(0, "bfchNm", this.dsTmprInfo.getColumn(0, "acaNm"));
	}
	// 정원수 : 현재 정원수
	if(this.dsTmprInfo.getColumn(0, "bfchFxpCnt") == ""){
		this.dsTmprInfo.setColumn(0, "bfchFxpCnt", this.dsTmprInfo.getColumn(0, "fxpTtl"));
	}
	
	
	// 휴대전화번호 세팅
	var mblTelno = this.dsMain01.getColumn(0, "funrMblTelno");
	var result = this.smfSplit(mblTelno, "-");
	if(result.length == 3){
		this.divAplyCn.form.edtMblTelno1.set_value(result[0]);
		this.divAplyCn.form.edtMblTelno2.set_value(result[1]);
		this.divAplyCn.form.edtMblTelno3.set_value(result[2]);
	}
	
	// 전화번호 세팅
	var invlTelno = this.dsMain01.getColumn(0, "invlTelno");
	var result = this.smfSplit(invlTelno, "-");
	if(result.length == 3){
		this.divClaiInfo.form.edtInvlTelno1.set_value(result[0]);
		this.divClaiInfo.form.edtInvlTelno2.set_value(result[1]);
		this.divClaiInfo.form.edtInvlTelno3.set_value(result[2]);
	}
	
	// 전화번호 세팅
	var invlTelno = this.dsMain01.getColumn(0, "funrMblTelno");
	var result = this.smfSplit(invlTelno, "-");
	if(result.length == 3){
		this.divClaiInfo.form.edtMblTelno1.set_value(result[0]);
		this.divClaiInfo.form.edtMblTelno2.set_value(result[1]);
		this.divClaiInfo.form.edtMblTelno3.set_value(result[2]);
	}

	// 휴대전화번호 세팅
	var mblTelno = this.dsMain01.getColumn(0, "invlMblTelno");
	result = this.smfSplit(mblTelno, "-");
	if(result.length == 3){
		this.divAplyCn.form.edtMblTelno1.set_value(result[0]);
		this.divAplyCn.form.edtMblTelno2.set_value(result[1]);
		this.divAplyCn.form.edtMblTelno3.set_value(result[2]);
	}

	// 법인 세팅(등록유형코드 : 1 )
	var regTypCd = this.dsMain01.getColumn(0, "regTypCd");
	if(regTypCd == "1"){
		this.divClaiInfo.form.chkTypCd.set_value("1");
	}else{
		this.divClaiInfo.form.chkTypCd.set_value("0");
	}
	
	// 접수일 - 제출인 경우에만 출력
	var onlCvlcptPrcsStsCd = this.dsTmprInfo.getColumn(0, "onlCvlcptPrcsStsCd");
	
	result = this.smfTrim(onlCvlcptPrcsStsCd);
}

// 신청인정보 & 임시저장정보 조회
this.listInstutChangeCnTmpr = function (){
		
	this.dsSearch02.copyRow(0, this.dsInstutInfo, this.dsInstutInfo.rowposition);

	this.initAplyCnTelno();

	this.dsMain02.clearData();

	this.dsTmprInfoList.clearData();

	this.dsTmprInfo.deleteRow(0);
	this.dsTmprInfo.addRow();
	
	this.smfSearchService("listInstutChangeCnTmpr")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		if(this.dsMain02.getColumn(0, "imsiScCode") == "30"){//제출정보가 있는 경우
			if(this.dsMain00.getRowCount() > 1){ //학원이 여러건인 경우				
				//임시저장정보 clear
				this.dsMain02.clearData();
				this.dsTmprInfoList.clearData();
				this.dsTmprInfo.deleteRow(0);
				
				this.dsInstutInfoList.setColumn(this.dsInstutInfoList.rowposition,"_chk",0);
				this.divInstutInfo00.form.grdInstutInfo.clearSelect();
				
				this.smfAlert("현재 진행중인 민원이 있습니다. \n해당 민원처리가 종료된 이후 민원을 진행하실 수 있습니다.\n다른 학원을 선택해주세요.");
				return;
			}else{ //학원이 1건인 경우
				this.smfAlert("현재 진행중인 민원이 있습니다.\n해당 민원처리가 종료된 이후 민원을 진행하실 수 있습니다.\n[확인]버튼을 누르시면 민원신고내역조회 페이지로 이동합니다.",this.hesGoCvlcptDclrList);
				return;
			}
		}else if( this.dsMain02.getColumn(0, "imsiScCode") == "10"){ //임시저장정보가 있는 경우
			// 데이터셋 복사하기
			this.dsTmprInfoList.copyData(this.dsMain02);
		}else{
			this.dsTmprInfo.copyRow(0, this.dsMain02, this.dsMain02.rowposition);
			
			//임시저장정보 없는 경우 증빙서류제출방식 기본값 온라인 사용
			this.dsTmprInfo.setColumn(0, "prufDocuSbmsnMetCd","2");
		}
		
		// 신청정보 세팅
		this.aplyInfoSetting();
	});
}

// 전송 값 세팅
this.fnSaveSetting = function(gbn) {
	// 학원정보 내용 복사
	this.dsSave.copyRow(0, this.dsInstutInfo, this.dsInstutInfo.rowposition);
	// 입력된 보험내용 복사
	this.dsSave.copyRow(0, this.dsTmprInfo, this.dsTmprInfo.rowposition);
		
	// 지역교육청코드 세팅
	var cteOfcdcCd = this.dsSave.getColumn(0, "cteOfcdcCd");
	cteOfcdcCd = cteOfcdcCd.substring(0, 3) + "0000001";
	
	this.dsSave.setColumn(0,"dstrtOfcdcCd", cteOfcdcCd);
	
	// NULL 값 임시 처리
	// 변경구분코드 세팅
	this.dsSave.setColumn(0,"chgScCd","0");
	// 업무구분코드
	this.dsSave.setColumn(0,"wrkScCd","0");

	// 변경 후 정원수 없으면 이전 값으로 세팅
	if(this.dsSave.getColumn(0, "afchFxpCnt") == ""){
		this.dsSave.setColumn(0, "afchFxpCnt", this.dsTmprInfo.getColumn(0, "bfchFxpCnt"));
	}
	
	// 온라인민원승인코드 세팅
	this.dsSave.setColumn(0, "onlCvlcptAprvCd", "0");
	
	// 임시저장, 수정 시 처리상태코드 세팅
	if (gbn == "01") {
		this.dsSave.setColumn(0, "onlCvlcptPrcsStsCd", "01");
		//alert("임시저장, 수정");
	} else if (gbn == "02") {	//등록인경우
		this.dsSave.setColumn(0, "onlCvlcptPrcsStsCd", "02");
		//alert("등록");
	}
}

// 선택한 셀만 체크박스 체크(라디오 버튼 효과)
this.fnGridRadioCheck = function(grid, dataset){
	var row = dataset.rowposition;

	for (var i = 0; i < grid.rowcount; i++) {
		// 체크박스 컬럼 생성
		dataset.addColumn("_chk", "string");
		
		if( i == row){ //선택한 셀 체크박스 체크
			dataset.setColumn(row, "_chk", 1);
		}else{
			dataset.setColumn(i, "_chk", 0);
		}
    }
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// 학원정보 리스트 선택
this.divInstutInfo00_grdInstutInfo_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	// 그리드 체크박스(라디오버튼)
	this.fnGridRadioCheck(this.divInstutInfo00.form.grdInstutInfo, this.dsInstutInfoList);
	
	this.dsInstutInfo.copyRow(0, this.dsInstutInfoList, this.dsInstutInfoList.rowposition);
	
	// 신청인 정보, 임시정보 조회
	this.dsMain01.clearData();
	
	this.initClaiInfoTelno();
	this.initAplyCnTelno();
	
	// 조회 조건 세팅
	this.dsSearch01.copyRow(0, this.dsInstutInfo, this.dsInstutInfo.rowposition);
	
	// 신청인 정보 조회 -> 학원교습소 정보 조회 시 같이 가져올 수 있음
	this.listInstutChangeCnTmpr();
};

// 임시저장
this.btnTemp_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//학원명 변경 시 중복체크 확인
	if(this.acaNmDpcnCeck == "N"){
		alert("변경 후 학원명을 중복체크해주세요.");
		return;
	}
	
	this.fnSaveSetting('01');
	// 전송 값 세팅
	/*	
	this.smfConfirm("저장하시겠습니까?", function(result){
		if(result.confirmResult){
			// [첨부파일]업로드
			this.divFileUpload.form.fnFileUpload();
		}
	});	
	*/
	
	// 서비스 객체 생성
	this.smfSaveService("saveInstutChangeCnTmpr")
	// 데이터 검증
	//.validateForm(this.divReg)
	// 실행
	.run()
	// 콜백
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		// 저장정보 초기화
		this.dsSave.deleteRow(0);
		this.dsSave.addRow();
		
		// 업로드 초기화
		this.divAplyCn.form.divFileUpload.form.fnResetUpload();
		
		this.smfAlert('CM002', []);
		
		// 임시저장목록 재조회
		this.listInstutChangeCnTmpr();
	});
	
};

// 임시내역수정
this.btnModify_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//학원명 변경 시 중복체크 확인
