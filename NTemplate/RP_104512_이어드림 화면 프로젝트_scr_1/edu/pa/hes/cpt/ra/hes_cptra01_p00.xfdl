          <Column id="invlMblTelno" type="STRING" size="256" sumtext="개인휴대전화번호"/>
          <Column id="mblTelno" type="STRING" size="256" sumtext="휴대전화번호"/>
          <Column id="prufDocuSbmsnMetCd" type="STRING" size="256" sumtext="증빙서류제출방식코드"/>
          <Column id="fileRefrnId" type="STRING" size="256" sumtext="파일참조ID"/>
          <Column id="cvlcptAplyNo" type="STRING" size="256" sumtext="민원신청번호"/>
