    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 학원변경통보
*  @MenuPath    TEMPLATE
*  @FileName 	hes_cptra01_m00.xfdl
*  @Creator 	김명주
*  @CreateDate 	2022.6.13
*  @Desction    학원변경통보
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.6.13     	김명주 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs"
include "lib::hes_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	
	// 팝업 폼 초기화
	this.smfInitPopup(obj);
	
	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	
	// 컴포넌트 readonly, disable
	this.svcfTravelComponents(this.divAplyCn, this.onReadOnly);
	
	// 학원정보 조회
	this.listInstutInfo();
};
 /************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 // 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 전화번호 초기화
this.initClaiInfoTelno = function (){
	this.divClaiInfo.form.edtInvlTelno1.set_value("");
	this.divClaiInfo.form.edtInvlTelno2.set_value("");
	this.divClaiInfo.form.edtInvlTelno3.set_value("");

	this.divClaiInfo.form.edtMblTelno1.set_value("");
	this.divClaiInfo.form.edtMblTelno2.set_value("");
	this.divClaiInfo.form.edtMblTelno3.set_value("");
}

this.initAplyCnTelno = function (){
	this.divAplyCn.form.edtMblTelno1.set_value("");
	this.divAplyCn.form.edtMblTelno2.set_value("");
	this.divAplyCn.form.edtMblTelno3.set_value("");
}

// 학원정보 조회
this.listInstutInfo = function (){
	// 사용자정보 SET
	this.dsSearch00.setColumn(0, "acaDsgnNo", this.hesGetAcaDsgnNo); //변조체크용
	this.dsSearch00.setColumn(0, "searchAcaDsgnNo", this.pv_params.acaDsgnNo);
	this.dsSearch00.setColumn(0, "acaInstiScCd", this.pv_params.acaInstiScCd);
	this.dsSearch00.setColumn(0, "atptOfcdcOrgCode", this.pv_params.dstrtOfcdcCd);
	
	// 학원정보 조회
	this.smfSearchService("listInstutInfo")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
					
		// 신청인 정보, 민원신청내용 조회
		this.dsMain01.clearData();
		this.dsMain02.clearData();
		
		this.initClaiInfoTelno();
		this.initAplyCnTelno();
		
		// 신청인 정보, 민원신청내용 조회
		this.listInstutChangeCnTmpr();
	});
};

// 신청정보 세팅
this.aplyInfoSetting = function (){

	// 변경 전 정보
	this.divAplyCn.form.edtBfchNm.set_value(this.dsMain02.getColumn(0, "bfchNm"));
	this.divAplyCn.form.edtBfchFxpCnt.set_value(this.dsMain02.getColumn(0, "bfchFxpCnt"));
	
	// 휴대전화번호 세팅
	var mblTelno = this.dsMain01.getColumn(0, "mblTelno");
	var result = this.smfSplit(mblTelno, "-");
	if(result.length == 3){
		this.divAplyCn.form.edtMblTelno1.set_value(result[0]);
		this.divAplyCn.form.edtMblTelno2.set_value(result[1]);
		this.divAplyCn.form.edtMblTelno3.set_value(result[2]);
	}
	
	// 전화번호 세팅
	var invlTelno = this.dsMain01.getColumn(0, "invlTelno");
	var result = this.smfSplit(invlTelno, "-");
	if(result.length == 3){
		this.divClaiInfo.form.edtInvlTelno1.set_value(result[0]);
		this.divClaiInfo.form.edtInvlTelno2.set_value(result[1]);
		this.divClaiInfo.form.edtInvlTelno3.set_value(result[2]);
	}

	// 휴대전화번호 세팅
	var mblTelno = this.dsMain01.getColumn(0, "mblTelno");
	result = this.smfSplit(mblTelno, "-");
	if(result.length == 3){
		this.divClaiInfo.form.edtMblTelno1.set_value(result[0]);
		this.divClaiInfo.form.edtMblTelno2.set_value(result[1]);
		this.divClaiInfo.form.edtMblTelno3.set_value(result[2]);
	}

	// 법인 세팅(등록유형코드 : 1 )
	var regTypCd = this.dsMain01.getColumn(0, "regTypCd");
	if(regTypCd == "1"){
		this.divClaiInfo.form.chkTypCd.set_value("1");
	}else{
		this.divClaiInfo.form.chkTypCd.set_value("0");
	}
	
}

// 신청인정보 & 임시저장정보 조회
this.listInstutChangeCnTmpr = function (){
	//검색조건 SET
	this.dsSearch02.copyRow(0, this.dsMain00, 0);
	this.dsSearch02.setColumn(0, "atptOfcdcOrgCode", this.pv_params.dstrtOfcdcCd);
	this.dsSearch02.setColumn(0, "tmprAcaDsgnNo", this.pv_params.tmprAcaDsgnNo);
	
	this.smfSearchService("listInstutChangeCnTmpr")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
	
		// 신청정보 세팅
		this.aplyInfoSetting();
		
		//미접수상태인 경우 철회버튼 활성화
		if(this.dsMain02.getColumn(0,"onlCvlcptPrcsStsCd") == "00"){
			this.btnRtrcn.set_visible(true);
		}
		
		// 업로드 초기화
		this.divAplyCn.form.divFileUpload.form.fnResetUpload();
		
		//파일참조ID가 있는 경우 파일정보조회
		if(this.dsMain02.getColumn(0,"fileRefrnId") != ""){
			this.transaction(
				 "fn_filesearch" // serviceId
				,"baseUrl::/cm_cmc_file_upload_001.do" // url
				,"" // inDataset
				,"dsOutFileinfo=atchFileinfo" // outDataset
				,"fileRefrnId='"+this.dsMain02.getColumn(0,"fileRefrnId")+"'"
				,""
				,false // true: 비동기, false:동기
		   );
			
			var responseCustomValue = "";
			var sDownloadUrl       = ""; 
			var sHandlerCode       = "PA.SAM.PLE";
			var sFileSn            = this.dsOutFileinfo.getColumn(0,"fileRefrnId"   );
			var sFileSeq           = this.dsOutFileinfo.getColumn(0,"fileId"        );
			var sFileSize          = this.dsOutFileinfo.getColumn(0,"atchFileMg"    );
			var sBackendFilename   = this.dsOutFileinfo.getColumn(0,"atchFileGuid"  );
			var sForntendFilename  = this.dsOutFileinfo.getColumn(0,"atchFileNm"    );
			var sFileEncryptYn     = this.dsOutFileinfo.getColumn(0,"fileEncryptYn" );
			var sPrivInfoFiltYn    = this.dsOutFileinfo.getColumn(0,"privInfoFiltYn");
			var sFileSaveStg       = this.dsOutFileinfo.getColumn(0,"fileSaveStg"   );
			var sFileInfSaveYn     = this.dsOutFileinfo.getColumn(0,"fileInfSaveYn" );
			
			this.divAplyCn.form.divFileUpload.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sForntendFilename, sFileSeq, sDownloadUrl
													  ,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn );
													  
			this.dsSave.setColumn(0, "sfileRefrnId", sFileSn);
		}
	});
}

// readolny, disable
this.onReadOnly = function(objComp, nLvl, oOwner){
	if((objComp instanceof nexacro.Edit) 
	|| (objComp instanceof nexacro.MaskEdit) 
	|| (objComp instanceof nexacro.Combo)
	|| (objComp instanceof nexacro.TextArea)
	|| (objComp instanceof nexacro.Spin)
	|| (objComp instanceof nexacro.Calendar)
	|| (objComp instanceof nexacro.Radio))
	{
		objComp.set_readonly(true);
	}
	else if((objComp instanceof nexacro.Button))
	{
		objComp.set_enable(false)
	}
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.btnRtrcn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 학원정보 내용 복사
	this.dsSave.copyRow(0, this.dsMain00, 0);
	// 민원내용 복사
	this.dsSave.copyRow(0, this.dsMain02, 0);
	// 임시학원지정번호 세팅
	this.dsSave.setColumn(0,"tmprAcaDsgnNo",this.pv_params.tmprAcaDsgnNo);
		
	// 지역교육청코드 세팅
	var cteOfcdcCd = this.dsSave.getColumn(0, "cteOfcdcCd");
	cteOfcdcCd = cteOfcdcCd.substring(0, 3) + "0000001";
	
	this.dsSave.setColumn(0,"dstrtOfcdcCd", cteOfcdcCd);
	
	// 변경구분코드 세팅
	this.dsSave.setColumn(0,"chgScCd","0");
	// 업무구분코드
	this.dsSave.setColumn(0,"wrkScCd","0");
	
	// 변경 후 정원수 없으면 이전 값으로 세팅
	if(this.dsSave.getColumn(0, "afchFxpCnt") == ""){
		this.dsSave.setColumn(0, "afchFxpCnt", this.dsTmprInfo.getColumn(0, "bfchFxpCnt"));
	}
	
	// 온라인민원승인코드 세팅
	this.dsSave.setColumn(0, "onlCvlcptAprvCd", "0");
	
	//철회 시 온라인민원상태코드 임시저장으로 SET
	this.dsSave.setColumn(0,"onlCvlcptPrcsStsCd","01");
	
	this.smfConfirm("철회하시겠습니까?", function(result){
		if(result.confirmResult){
			this.smfSaveService("updateCvlcptWtdr")
			.showConfirm(false) 
			.run()
			.callback(function(callbackParams){
				if(callbackParams.errors) return;
				alert("철회되었습니다.");
				this.smfSendResponseToOpener({
					"search": true
				});
				this.close(true);
			});
		}
	});	
	
};

this.btnCncl_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSendResponseToOpener({
		"search": false
	});
	this.close(false);
};
]]></Script>
