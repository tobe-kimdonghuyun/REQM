    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 학원교육이수현황신고
*  @MenuPath    TEMPLATE
*  @FileName 	hes_cptra10_m00.xfdl
*  @Creator 	김명주
*  @CreateDate 	2022.10.25
*  @Desction    학원교육이수현황신고
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.10.25     	김명주 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs"
include "lib::hes_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 //화면 접근 시 로그인정보 확인
this.fnOninit = function(obj:nexacro.Form,e:nexacro.EventInfo)
{
	if(this.hesChkLogin("1","pa_hes_cpt_ra::hes_cptra10_m00.xfdl")){
		this.hesSetGoUrl("pa_hes_cpt_ra::hes_cptra10_m00.xfdl");
		this.fnOnload(this);
	}
};
// 폼 초기화 이벤트
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{	
	// 업로드 초기설정
	this.divReg.form.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;        // 필요한 경우만 세팅(세팅권장)
	this.divReg.form.divFileUpload.UPLOAD_OnError        = this.fnEventUploadError;           // 필요한 경우만 세팅(세팅권장)
	this.divReg.form.divFileUpload.UPLOAD_AfterAddFile   = this.fnEventAfterAddFile;          // 필요한 경우만 세팅(세팅권장)
	this.divReg.form.divFileUpload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)

	// 폼 초기화
	this.smfInitForm(obj);
	
	// 공통코드 호출
	this.smfCodeList("code", [this.dsEduMthCd, this.dsEduTrgtCd])
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;	
	
		// 학원정보 조회
		this.listInstutInfo();
	});	
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 학원정보 조회 함수
this.listInstutInfo = function ()
{	
	this.dsSearch01.setColumn(0, "acaDsgnNo", this.hesGetAcaDsgnNo);	
	this.dsSearch01.setColumn(0, "acaInstiScCd", this.hesGetAcaInstiScCd);
	this.dsSearch01.setColumn(0, "atptOfcdcOrgCode", this.hesGetAtptOfcdcOrgCode);
	
	this.dsSearch00.setColumn(0, "acaDsgnNo", this.hesGetAcaDsgnNo);	
	this.dsSearch00.setColumn(0, "acaInstiScCd", this.hesGetAcaInstiScCd);
	this.dsSearch00.setColumn(0, "atptOfcdcOrgCode", this.hesGetAtptOfcdcOrgCode);
	
	// 학원정보 조회
	this.smfSearchService("listInstutInfo")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors){
			var objFrame = this.getOwnerFrame();
			objFrame.form.fnSetMainpage(objFrame.form.fv_mainformUrl);	
		}
		
		if(this.dsMain00.getRowCount() > 1){
			// 학원 수가 1개 이상 이면
			this.divInstutInfo00.set_visible(true);
			this.divInstutInfo01.set_visible(false);
			
			var nTop = this.divReg.getPixelTop();
			var nOldTop = this.divInstutInfo01.getPixelTop();

			var top = nTop - nOldTop;

			this.divReg.set_top(this.divReg.getPixelTop() - top);
			
			// 데이터셋 복사하기
			this.dsInstutInfoList.copyData(this.dsMain00);
		}else{
			// 학원 수가 1개면
			this.divInstutInfo00.set_visible(false);
			this.divInstutInfo01.set_visible(true);
			
			var nTop = this.divInstutInfo01.getPixelTop();
			var nOldTop = this.divInstutInfo00.getPixelTop();

			var top = nTop - nOldTop;

			this.divInstutInfo01.set_top(nTop - top);
			this.divReg.set_top(this.divReg.getPixelTop() - top);
			
			this.dsInstutInfo.copyData(this.dsMain00);

			// 임시정보 조회
			this.listEdcComplSttusCnTmpr();
		}
	});
};

// 임시정보 조회 함수
this.listEdcComplSttusCnTmpr = function ()
{
	this.dsSearch01.copyRow(0, this.dsInstutInfo, this.dsInstutInfo.rowposition);
	this.dsSearch01.setColumn(0, "dstrtOfcdcCd", this.dsInstutInfo.getColumn(0, "cteOfcdcCd"));
	
	// 임시학원정보 조회
	this.dsMain01.clearData();
	
	this.smfSearchService("listEdcComplSttusCnTmpr")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		if(this.dsMain01.getColumn(0, "imsiScCode") == "30"){//제출정보가 있는 경우
			if(this.dsMain00.getRowCount() > 1){ //학원이 여러건인 경우				
				//임시저장정보 clear
				this.dsMain01.clearData();
				
				this.dsInstutInfoList.setColumn(this.dsInstutInfoList.rowposition,"_chk",0);
				this.divInstutInfo00.form.grdInstutInfo.clearSelect();
				
				this.smfAlert("현재 진행중인 민원이 있습니다. \n해당 민원처리가 종료된 이후 민원을 진행하실 수 있습니다.\n다른 학원을 선택해주세요.");
				return;
			}else{ //학원이 1건인 경우
				this.smfAlert("현재 진행중인 민원이 있습니다.\n해당 민원처리가 종료된 이후 민원을 진행하실 수 있습니다.\n[확인]버튼을 누르시면 민원신고내역조회 페이지로 이동합니다.",this.hesGoCvlcptDclrList);
				return;
			}
		}else{
			//임시저장정보 없는 경우 증빙서류제출방식 기본값 온라인 사용
			this.dsMain01.setColumn(0, "prufDocuSbmsnMetCd","2");
			
			var fileRefrnId = this.dsMain01.getColumn(0, "fileRefrnId");
			
			// 업로드 초기화
			this.divReg.form.divFileUpload.form.fnResetUpload();
			
			//파일참조ID가 있는 경우 파일정보조회
			if(fileRefrnId != ""){
				this.transaction(
					 "fn_filesearch" // serviceId
					,"baseUrl::/cm_cmc_file_upload_001.do" // url
					,"" // inDataset
					,"dsOutFileinfo=atchFileinfo" // outDataset
					,"fileRefrnId='"+fileRefrnId+"'"
					,""
					,false // true: 비동기, false:동기
			   );
				
				var responseCustomValue = "";
				var sDownloadUrl       = ""; 
				var sHandlerCode       = "PA.SAM.PLE";
				var sFileSn            = this.dsOutFileinfo.getColumn(0,"fileRefrnId"   );
				var sFileSeq           = this.dsOutFileinfo.getColumn(0,"fileId"        );
				var sFileSize          = this.dsOutFileinfo.getColumn(0,"atchFileMg"    );
				var sBackendFilename   = this.dsOutFileinfo.getColumn(0,"atchFileGuid"  );
				var sForntendFilename  = this.dsOutFileinfo.getColumn(0,"atchFileNm"    );
				var sFileEncryptYn     = this.dsOutFileinfo.getColumn(0,"fileEncryptYn" );
				var sPrivInfoFiltYn    = this.dsOutFileinfo.getColumn(0,"privInfoFiltYn");
				var sFileSaveStg       = this.dsOutFileinfo.getColumn(0,"fileSaveStg"   );
				var sFileInfSaveYn     = this.dsOutFileinfo.getColumn(0,"fileInfSaveYn" );
				
				this.divReg.form.divFileUpload.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sForntendFilename, sFileSeq, sDownloadUrl
														  ,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn );
				
				this.dsSave.setColumn(0, "sfileRefrnId", sFileSn);
			}
		}
		
		this.fnSetFileDiv();
	});
};

// 전송 값 세팅
this.fnSaveSetting = function(gbn) {
	// 학원정보 내용 복사
	this.dsSave.copyRow(0, this.dsInstutInfo, this.dsInstutInfo.rowposition);
	// 입력된 보험내용 복사
	this.dsSave.copyRow(0, this.dsMain01, this.dsMain01.rowposition);
	
	// 학원개인지정번호 세팅(학원지정번호로... 컬럼명 확인 필요함)
	this.dsSave.setColumn(0, "acaInvlDsgnNo",this.dsInstutInfo.getColumn(0, "acaDsgnNo"));	
	
	// 지역교육청코드 세팅
	var cteOfcdcCd = this.dsSave.getColumn(0, "cteOfcdcCd");
	cteOfcdcCd = cteOfcdcCd.substring(0, 3) + "0000001";
	
	this.dsSave.setColumn(0,"dstrtOfcdcCd", cteOfcdcCd);
	
	// 관할교육청코드, 지역교육청코드 세팅
	/*
	var cteOfcdcCd = this.dsSave.getColumn(0, "cteOfcdcCd");
	this.dsSave.setColumn(0, "dstrtOfcdcCd", cteOfcdcCd);
		
	cteOfcdcCd = cteOfcdcCd.substring(0, 3) + "0000001";
	this.dsSave.setColumn(0, "cteOfcdcCd", cteOfcdcCd);	
	*/
	
	// 교육종료일자 세팅
	// 입력된 날짜에서 매개변수만큼 일 증감
	var eduBgngYmd = this.dsSave.getColumn(0, "eduBgngYmd");

	if(eduBgngYmd != ""){
		var comptHr = this.dsSave.getColumn(0, "comptHr");
		var addDate = comptHr / 24;

		var result = this.smfAddDate(eduBgngYmd, addDate);
		this.dsSave.setColumn(0, "eduEndYmd", result);
	}
	
	// 온라인민원승인코드 세팅
	this.dsSave.setColumn(0, "onlCvlcptAprvCd", "0");
	
	// 임시저장, 수정 시 처리상태코드 세팅
	if (gbn == "01") {
		this.dsSave.setColumn(0, "onlCvlcptPrcsStsCd", "01");
		//alert("임시저장, 수정");
	} else if (gbn == "02") {	//등록인경우
		this.dsSave.setColumn(0, "onlCvlcptPrcsStsCd", "02");
		//alert("등록");
	}
}

// 선택한 셀만 체크박스 체크(라디오 버튼 효과)
this.fnGridRadioCheck = function(grid, dataset){
	var row = dataset.rowposition;

	for (var i = 0; i < grid.rowcount; i++) {
		// 체크박스 컬럼 생성
		dataset.addColumn("_chk", "string");
		
		if( i == row){ //선택한 셀 체크박스 체크
			dataset.setColumn(row, "_chk", 1);
		}else{
			dataset.setColumn(i, "_chk", 0);
		}
    }
};

//저장 시 필수갑 체크
this.fnValid = function(){
	//그리드 필수값체크 (추후 서버단 validation가져와서 하는걸로 변경)
	for(var i=0; i<this.dsMain01.getRowCount(); i++){
		if(this.smfIsNull(this.dsMain01.getColumn(i,"comptEduCd"))){
			this.smfAlert('CM022', ['교육내용']); // 교육내용을(를) 선택하여 주십시오.
			return false;
		}
		if(this.smfIsNull(this.dsMain01.getColumn(i,"eduBgngYmd").trim())){
			this.smfAlert('CM022', ['교육일시']); // 교육일시을(를) 선택하여 주십시오.
			return false;
		}
		if(this.smfIsNull(this.dsMain01.getColumn(i,"eduPlaceNm"))){
			this.smfAlert("교육장소를 입력해주세요.");
			return false;
		}
		if(this.smfIsNull(this.dsMain01.getColumn(i,"eduTrgtCd"))){
			this.smfAlert('CM022', ['교육대상']); // 교육대상을(를) 선택하여 주십시오.
			return false;
		}
		if(this.smfIsNull(this.dsMain01.getColumn(i,"trprCnt"))){
			this.smfAlert("대상인원을 입력해주세요.");
			return false;
		}
		if(this.smfIsNull(this.dsMain01.getColumn(i,"comptHr"))){
			this.smfAlert("이수시간을 입력해주세요.");
			return false;
		}
		if(this.smfIsNull(this.dsMain01.getColumn(i,"eduMthCd"))){
			this.smfAlert('CM022', ['교육방법']); // 교육방법을(를) 선택하여 주십시오.
			return false;
		}
	}
	
	//증빙자료제출방식 온라인 선택 시 첨부파일 필수체크
	if(this.dsMain01.getColumn(0,"prufDocuSbmsnMetCd") == "2"){
		if(this.dsSave.getColumn(0,"sfileRefrnId") == "" || this.dsSave.getColumn(0,"sfileRefrnId") == undefined){
			this.smfAlert("증빙서류제출 방식이 온라인일 경우 증빙서류 첨부는 필수입니다.");
			return false;
		}
	}
	
	return true;
}

//증빙서류제출방식 온라인일때만 파일첨부 활성화
this.fnSetFileDiv = function(){
	if(this.divReg.form.rdoPrufDocuSbmsnMetCd.value == "2"){
		this.divReg.form.divFileUpload.set_enable(true);
	}else{
		this.divReg.form.divFileUpload.set_enable(false);
	}
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// 학원정보 리스트 선택
this.divInstutInfo00_grdInstutInfo_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	// 그리드 체크박스(라디오버튼)
	this.fnGridRadioCheck(this.divInstutInfo00.form.grdInstutInfo, this.dsInstutInfoList);
	
	this.dsInstutInfo.copyRow(0, this.dsInstutInfoList, this.dsInstutInfoList.rowposition);
	
	// 임시정보 조회
	this.listEdcComplSttusCnTmpr();
};

// 임시저장정보 리스트 선택
this.divReg_grdTmprInfo_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{	
	// 그리드 체크박스(라디오버튼)
	this.fnGridRadioCheck(this.divReg.form.grdTmprInfo, this.dsMain01);
};

// 재입력
this.divReg_btnRein_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfConfirm("처음부터 다시 입력하시겠습니까?", function(bYes){
		if(bYes.confirmResult){
			this.dsMain01.setColumn(0, "comptEduCd", "");
			this.dsMain01.setColumn(0, "eduBgngYmd", "");
			this.dsMain01.setColumn(0, "eduPlaceNm", "");
			this.dsMain01.setColumn(0, "eduTrgtCd", "");
			this.dsMain01.setColumn(0, "trprCnt", "");
			this.dsMain01.setColumn(0, "comptNmpr", "");
			this.dsMain01.setColumn(0, "comptHr", "");
			this.dsMain01.setColumn(0, "eduMthCd", "");
			this.dsMain01.setColumn(0, "rmkCn", "");
			this.dsMain01.setColumn(0, "onlCvlcptPrcsStsCd", "");
		}
	});
};

// 임시저장
this.divReg_btnTemp_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	//그리드 값 데이터셋 반영
	this.divReg.form.grdTmprInfo.updateToDataset();
	
	if(this.fnValid){
		// 전송 값 세팅
		this.fnSaveSetting('01');
			
		// 서비스 객체 생성
		this.smfSaveService("saveEdcComplSttusCnTmpr")
		// 데이터 검증
		.validateForm(this.divReg)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			// 저장정보 초기화
			this.dsSave.deleteRow(0);
			this.dsSave.addRow();
			
			// 업로드 초기화
			this.divReg.form.divFileUpload.form.fnResetUpload();
			
			this.smfAlert('CM002', []);
			
			// 임시저장목록 재조회
			this.listEdcComplSttusCnTmpr();
		});
	}
};

// 임시내역수정
this.divReg_btnModify_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//if(!this.fnendDateCheck()) {
	//	return;
	//}
	
	// 전송 값 세팅
	this.fnSaveSetting('01');
	
	// 서비스 객체 생성
	this.smfSaveService("updateEdcComplSttusCnTmpr")
	// 데이터 검증
	.validateForm(this.divReg)
	// 실행
	.run()
	// 콜백
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		// 저장정보 초기화
		this.dsSave.deleteRow(0);
		this.dsSave.addRow();
		
		this.smfAlert('CM004', []);
		
		// 임시저장목록 재조회
		this.listEdcComplSttusCnTmpr();
	});
};

// 임시내역삭제
this.divReg_btnDel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{		
	// 전송 값 세팅
	this.fnSaveSetting('01');
	
	if(this.dsSave.getColumn(0, "eduComptDsgnNo") == ""){
		this.smfAlert("삭제 할 임시내역이 없습니다.");
		return;
	}
	
	this.smfDeleteService("deleteEdcComplSttusCnTmpr")
	.run()
	// 콜백
	.callback(function(callbackParams){ 
		if(callbackParams.errors) return;

		this.smfAlert("삭제되었습니다.");
		
		// 삭제정보 초기화
		this.dsSave.deleteRow(0);
		this.dsSave.addRow();
		
		// 임시저장목록 재조회
		this.listEdcComplSttusCnTmpr();
	})
};


// 교육결과보고서 제출 
this.divReg_btnReq_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//그리드 값 데이터셋 반영
	this.divReg.form.grdTmprInfo.updateToDataset();
	
	if(this.fnValid){
		// 전송 값 세팅
		this.fnSaveSetting('02');
		
		// 서비스 객체 생성
		this.smfSaveService("saveEdcResultReprt")
		// 데이터 검증
		.validateForm(this.divReg)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			// 저장정보 초기화
			this.dsSave.deleteRow(0);
			this.dsSave.addRow();
			
			// 업로드 초기화
			this.divReg.form.divFileUpload.form.fnResetUpload();
			
			this.smfAlert('CM002', []);
			
			// 임시저장목록 재조회
			this.listEdcComplSttusCnTmpr();
		});
	}
};


this.fnEventAfterAddFile = function(obj,paramObj,sCustomValue,sFileName,nFileSize)
{
	trace("=== Sample : fnEventAfterAddFile");
	this.divReg.form.divFileUpload.form.fnFileUpload();
}
this.fnEventUploadComplete = function(obj,paramObj,objResultDataset)
{
	// 신규서비스
	trace("=== Sample : fnEventUploadComplete");	
	this.divReg.form.divFileUpload.form.fnSetUploadCompleteState(obj,paramObj);
	if(objResultDataset){
		trace("====업로드한 결과 데이터셋 ========== : "+objResultDataset.saveXML());
		this.dsSave.setColumn(0, "sfileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
		var sFileRefrnId = objResultDataset.getColumn(0,"fileRefrnId");
		trace("sFileRefrnId : "+sFileRefrnId);
	}

}
this.fnEventUploadError = function(obj,paramObj)
{
	trace("파일 업로드에 실패 하였습니다.");		
}

//파일삭제
this.divAplyCn_btnFleDel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divReg.form.divFileUpload.form.fnResetUpload();
	this.dsSave.setColumn(0, "sfileRefrnId", "");
};

//파일다운로드
this.divAplyCn_btnFleDwld_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divReg.form.divFileUpload.form.fnFileDownload();
};
this.divReg_rdoPrufDocuSbmsnMetCd_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	this.fnSetFileDiv();
};
