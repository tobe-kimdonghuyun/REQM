// 재입력
this.divReg_btnRein_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfConfirm("처음부터 다시 입력하시겠습니까?", function(bYes){
		if(bYes.confirmResult){
			this.dsTmprInfo.deleteRow(0);
			this.dsTmprInfo.addRow();
		}
	});
};

// 임시저장
this.divReg_btnTemp_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.fnValid()){
		// 전송 값 세팅
		this.fnSaveSetting('01');
			
		// 서비스 객체 생성
		this.smfSaveService("saveInstutBassCnTmpr")
		// 데이터 검증
		.validateForm(this.divReg)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			// 저장정보 초기화
			this.dsSave.deleteRow(0);
			this.dsSave.addRow();
			
			// 업로드 초기화
			this.divReg.form.divEtc.form.divFileUpload.form.fnResetUpload();
			
			// 결과 값 출력
			//this.fnResult("임시저장");
			
			// 임시저장목록 조회
			this.listInstutBassCnTmpr();
		});
	}
};

// 임시내역 삭제
this.divReg_btnDel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 전송 값 세팅
	this.fnSaveSetting('01');
			
	this.smfDeleteService("deleteInstutBassCnTmpr")
	.run()
	// 콜백
	.callback(function(callbackParams){ 
		if(callbackParams.errors) return;
		//this.smfAlert("삭제되었습니다.");
		
		// 삭제정보 초기화
		this.dsSave.deleteRow(0);
		this.dsSave.addRow();

		// 결과 값 출력
		this.fnResult("삭제");

		// 임시저장목록 조회
		this.listInstutBassCnTmpr();
	})
};

// 신고서 제출
this.divReg_btnReq_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.fnValid()){
		// 전송 값 세팅
		this.fnSaveSetting('02');
		
		// 서비스 객체 생성
		this.smfSaveService("saveInstutDclrt")
		// 데이터 검증
		.validateForm(this.divReg)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			// 저장정보 초기화
			this.dsSave.deleteRow(0);
			this.dsSave.addRow();
			
			// 업로드 초기화
			this.divReg.form.divEtc.form.divFileUpload.form.fnResetUpload();
			
			// 결과 값 출력
			this.fnResult("신고서 제출");
			
			// 임시저장목록 조회
			this.listInstutBassCnTmpr();
		});
	}
};

// 휴원/폐원 선택
this.rdoCaaCai_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	this.fv_CaaCai = obj.value;

	if(this.fv_CaaCai == 0){		// 휴원
		// 휴원 관련
		this.divReg.form.divCaa.set_visible(true);
		
		// 폐원 관련
		this.divReg.form.divCai.set_visible(false);
		
		// 그리드
		this.divMain.form.grdTmprInfo.setCellProperty("head", 3, "text", "휴원예정일");
		this.divMain.form.grdTmprInfo.setCellProperty("head", 4, "text", "휴원사유");
		
		// 위치 이동
		this.divReg.form.divEtc.set_top(this.fv_divCaiTop);
		
		// 버튼
		this.divReg.form.divEtc.form.btnReq.set_text("휴원신고서 제출");
	}else if(this.fv_CaaCai == 1){	// 폐원
		// 휴원 관련
		this.divReg.form.divCaa.set_visible(false);
		
		// 폐원 관련
		this.divReg.form.divCai.set_visible(true);
		
		// 위치 이동
		var top = this.fv_divCaiTop - this.fv_divCaaTop;
		var divCaiTop = this.fv_divCaiTop - top;
		var divEtcTop = this.fv_divEtcTop - top;
		
		this.divReg.form.divCai.set_top(divCaiTop);
		this.divReg.form.divEtc.set_top(divEtcTop);
		
		// 그리드
		this.divMain.form.grdTmprInfo.setCellProperty("head", 3, "text", "폐원예정일(말소예정일)");
		this.divMain.form.grdTmprInfo.setCellProperty("head", 4, "text", "폐원(말소)사유");
		
		// 버튼
		this.divReg.form.divEtc.form.btnReq.set_text("폐원신고서 제출");
	}
		
	// 임시저장목록 조회
	this.listInstutBassCnTmpr();
};
