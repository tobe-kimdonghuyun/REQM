    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 학원휴원폐원신고
*  @MenuPath    TEMPLATE
*  @FileName 	hes_cptra07_m00.xfdl
*  @Creator 	김명주
*  @CreateDate 	2022.8.01
*  @Desction    학원휴원폐원신고
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.8.01     	김명주 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs"
include "lib::hes_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
// 휴원 : 0 / 폐원 : 1 구분
this.fv_CaaCai = 0;	// 초기 값은 휴원

// 휴/폐원 관련 top 위치 세팅
this.fv_divCaaTop = 0;	// 휴원 div
this.fv_divCaiTop = 0;	// 폐원 div
this.fv_divEtcTop = 0;	// 기타 div

 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 //화면 접근 시 로그인정보 확인
this.fnOninit = function(obj:nexacro.Form,e:nexacro.EventInfo)
{
	if(this.hesChkLogin("1","pa_hes_cpt_ra::hes_cptra07_m00.xfdl")){
		this.hesSetGoUrl("pa_hes_cpt_ra::hes_cptra07_m00.xfdl");
		this.fnOnload(this);
	}
};
// 폼 초기화 이벤트
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

	// 업로드 초기설정	
	this.divReg.form.divEtc.form.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;        // 필요한 경우만 세팅(세팅권장)
	this.divReg.form.divEtc.form.divFileUpload.UPLOAD_OnError        = this.fnEventUploadError;           // 필요한 경우만 세팅(세팅권장)
	this.divReg.form.divEtc.form.divFileUpload.UPLOAD_AfterAddFile   = this.fnEventAfterAddFile;          // 필요한 경우만 세팅(세팅권장)
	this.divReg.form.divEtc.form.divFileUpload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)

	// 폼 초기화
	this.smfInitForm(obj);
	
	// 휴원 세팅
	this.divInstutInfo01.form.rdoCaaCai.set_value(this.fv_CaaCai);

	// 사이즈 관련 고정 값 세팅
	this.fv_divCaaTop = this.divReg.form.divCaa.top;	// 휴원 div
	this.fv_divCaiTop = this.divReg.form.divCai.top;	// 폐원 div
	this.fv_divEtcTop = this.divReg.form.divEtc.top;	// 기타 div

	// 폐원 관련
	this.divReg.form.divCai.set_visible(false);
	this.divReg.form.divEtc.set_top(this.fv_divCaiTop);

	// 그리드
	this.divMain.form.grdTmprInfo.setCellProperty("head", 3, "text", "휴원예정일");
	this.divMain.form.grdTmprInfo.setCellProperty("head", 4, "text", "휴원사유");

	// 학원정보 정보 조회
	this.listInstutInfo();
}
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 학원정보 조회 함수
this.listInstutInfo = function ()
{	
	this.dsSearch01.setColumn(0, "acaDsgnNo", this.hesGetAcaDsgnNo);	
	this.dsSearch01.setColumn(0, "acaInstiScCd", this.hesGetAcaInstiScCd);
	this.dsSearch01.setColumn(0, "atptOfcdcOrgCode", this.hesGetAtptOfcdcOrgCode);
	this.dsSearch00.setColumn(0, "acaDsgnNo", this.hesGetAcaDsgnNo);	
	this.dsSearch00.setColumn(0, "acaInstiScCd", this.hesGetAcaInstiScCd);
	this.dsSearch00.setColumn(0, "atptOfcdcOrgCode", this.hesGetAtptOfcdcOrgCode);
	
	// 학원정보 조회
	this.smfSearchService("listInstutInfo")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors){
			var objFrame = this.getOwnerFrame();
			objFrame.form.fnSetMainpage(objFrame.form.fv_mainformUrl);	
		}
		
		// 학원 개수에 따른 학원정보 세팅
		if(this.dsMain00.getRowCount() > 1){
			// 1개 이상이면
			// 데이터셋 복사하기
			this.dsInstutInfoList.copyData(this.dsMain00);
		}else{		
			// 1개 이면
			this.divInstutInfo00.set_visible(false);
			var divInstutInfo00Top = this.divInstutInfo00.top;
			var divInstutInfo01Top = this.divInstutInfo01.top;
			var top = divInstutInfo01Top - divInstutInfo00Top;
			
			this.divInstutInfo01.set_top(divInstutInfo01Top - top);		
			this.divMain.set_top(this.divMain.top - top);
			this.divReg.set_top(this.divReg.top - top);
			
			this.dsInstutInfo.copyData(this.dsMain00);
			this.fnSetInfoFrm();
	
			// 임시저장목록 조회
			this.listInstutBassCnTmpr();
		}
	});
};

// 전송 값 세팅
this.fnSaveSetting = function(gbn) {
	// 데이터셋 복사 할 때 순서 주의...(추후 정리 필요 할 듯...)
	// 임시정보 내용 복사
	if( this.dsMain01.getColumn(0, "imsiScCode") == "10"){
		this.dsSave.copyRow(0, this.dsMain01, this.dsTmprInfoList.rowposition);
	}else{
		this.dsSave.copyRow(0, this.dsMain01, this.dsTmprInfo.rowposition);
	}
	// 학원정보 내용 복사(학원이 1개인 경우 dsInstutInfo, 1개 이상이면 dsInstutInfoList로 변경 확인)
	this.dsSave.copyRow(0, this.dsInstutInfo, this.dsInstutInfo.rowposition);
	// 입력된 내용 복사
	this.dsSave.copyRow(0, this.dsTmprInfo, this.dsTmprInfo.rowposition);
		
	// 관할교육청코드, 지역교육청코드 세팅
	var cteOfcdcCd = this.dsSave.getColumn(0, "cteOfcdcCd");
	this.dsSave.setColumn(0, "dstrtOfcdcCd", cteOfcdcCd);
		
	cteOfcdcCd = cteOfcdcCd.substring(0, 3) + "0000001";
	this.dsSave.setColumn(0, "cteOfcdcCd", cteOfcdcCd);	
	
	// 임시저장, 수정 시 처리상태코드 세팅
	if (gbn == "01") {
		this.dsSave.setColumn(0, "onlCvlcptPrcsStsCd", "01");
	} else if (gbn == "02") {	//등록인경우
		this.dsSave.setColumn(0, "onlCvlcptPrcsStsCd", "02");
	}
	
	var result = this.smfToday();
	//alert("today : " + result);
	//this.dsSave.setColumn(0, "", result);
	
	if(this.fv_CaaCai == 0){		// 휴원
		// 휴폐원등록일자
		this.dsSave.setColumn(0, "caiRegYmd", result);
		// 등록상태코드 (자진휴원(소)) ->	1 : 개원, 2 : 자진휴원(소), 3 : 직권휴원(소), 4 : 자진폐원(소)
		//									5 : 직권폐원(소), 6 : 재개원, 7 : 말소, 9 : 이전신청
		this.dsSave.setColumn(0, "regStsCd", "2");
		// 변경종류코드 (휴원) -> 휴원 : 11, 폐원 : 12
		this.dsSave.setColumn(0, "chgKndCd", "11");
	}else if(this.fv_CaaCai == 1){	// 폐원
		// 휴폐원등록일자
		this.dsSave.setColumn(0, "caiRegYmd", result);
		// 등록상태코드 (자진폐원(소)) ->	1 : 개원, 2 : 자진휴원(소), 3 : 직권휴원(소), 4 : 자진폐원(소)
		//									5 : 직권폐원(소), 6 : 재개원, 7 : 말소, 9 : 이전신청
		this.dsSave.setColumn(0, "regStsCd", "4");
		// 변경종류코드 (폐원) -> 휴원 : 11, 폐원 : 12
		this.dsSave.setColumn(0, "chgKndCd", "12");
	}

	// 사업자번호 ??
	var brno = this.dsSave.getColumn(0, "brno");
	//alert("000" + brno + "000\n000" + this.smfTrim(brno) + "000");
	this.dsSave.setColumn(0, "brno", this.smfTrim(brno));
	
	// 학원등록증반납여부 null 값 처리
	var acaRgcfRtnYn = this.dsSave.getColumn(0, "acaRgcfRtnYn");
	this.dsSave.setColumn(0, "acaRgcfRtnYn", this.nvl(acaRgcfRtnYn, " "));
};

// 임시저장목록 조회
this.listInstutBassCnTmpr = function(){
	// 파라미터 세팅
	this.dsSearch01.copyRow(0, this.dsInstutInfo, this.dsInstutInfo.rowposition);
	this.dsSearch01.setColumn(0, "dstrtOfcdcCd", this.dsInstutInfo.getColumn(0, "cteOfcdcCd"));
	this.dsSearch01.setColumn(0, "acaInstiScCd", "1");
	
	// 휴원/폐원 라디오 버튼 값 세팅
	if(this.fv_CaaCai == 0){		// 휴원
		this.dsSearch01.setColumn(0, "chgKndCd", "11");
	}else if(this.fv_CaaCai == 1){	// 폐원
		this.dsSearch01.setColumn(0, "chgKndCd", "12");
	}

	// 임시 학원휴폐원정보 조회
	this.dsMain01.clearData();
	
	this.dsTmprInfoList.clearData();
	
	this.dsTmprInfo.deleteRow(0);
	this.dsTmprInfo.addRow();
	
	this.smfSearchService("listInstutBassCnTmpr")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		if(this.dsMain01.getColumn(0, "imsiScCode") == "30"){//제출정보가 있는 경우
			if(this.dsMain00.getRowCount() > 1){ //학원이 여러건인 경우				
				//임시저장정보 clear
				this.dsMain01.clearData();
				this.dsTmprInfoList.clearData();
				this.dsTmprInfo.deleteRow(0);
				
				this.dsInstutInfoList.setColumn(this.dsInstutInfoList.rowposition,"_chk",0);
				this.divInstutInfo00.form.grdInstutInfo.clearSelect();
				
				this.smfAlert("현재 진행중인 민원이 있습니다. \n해당 민원처리가 종료된 이후 민원을 진행하실 수 있습니다.\n다른 학원을 선택해주세요.");
				return;
			}else{ //학원이 1건인 경우
				this.smfAlert("현재 진행중인 민원이 있습니다.\n해당 민원처리가 종료된 이후 민원을 진행하실 수 있습니다.\n[확인]버튼을 누르시면 민원신고내역조회 페이지로 이동합니다.",this.hesGoCvlcptDclrList);
				return;
			}
		}else if( this.dsMain01.getColumn(0, "imsiScCode") == "10"){ // 데이터셋 복사하기
			// 임시저장 정보 있으면 리스트에 넣고
			this.dsTmprInfoList.copyData(this.dsMain01);
		}else{
			// 아니면 데이터 바로 출력
			this.dsTmprInfo.copyRow(0, this.dsMain01, this.dsMain01.rowposition);
			this.fnSetInfoFrm("tmpr");
		}	
		
		
		// 휴원, 폐원 가능여부 확인
		var regStsCd = this.dsMain01.getColumn(this.dsMain01.rowposition, "regStsCd");
		var onlCvlcptPrcsStsCd = this.dsMain01.getColumn(this.dsMain01.rowposition, "onlCvlcptPrcsStsCd");
				
		// 컴포넌트 enable
		this.svcfTravelComponents(this.divReg.form.divEtc, this.onEnable);
		
		if(this.fv_CaaCai == 0){		// 휴원
			// 휴원이면 1 : 개원, 6 : 재개원 만 신청 가능
			if(onlCvlcptPrcsStsCd != "01"){//임시저장이 아닐 경우
				if(!(regStsCd == "1" || regStsCd == "6")){
					this.smfAlert("휴원 신고가 불가능합니다.");
					// 컴포넌트 disable
					this.svcfTravelComponents(this.divReg.form.divEtc, this.onDisable);
				}
			}			
		}else if(this.fv_CaaCai == 1){	// 폐원
			if(onlCvlcptPrcsStsCd != "01"){//임시저장이 아닐 경우
				// 폐원이면 1 : 개원, 2 : 자진휴원(소), 3 : 직권휴원(소), 6 : 재개원 만 신청 가능			
				if(!(regStsCd == "1" || regStsCd == "2" || regStsCd == "3" || regStsCd == "6")){
					this.smfAlert("폐원 신고가 불가능합니다.");
					// 컴포넌트 disable
					this.svcfTravelComponents(this.divReg.form.divEtc, this.onDisable);
				}
			}
		}
	});
};

// 선택한 셀만 체크박스 체크(라디오 버튼 효과)
this.fnGridRadioCheck = function(grid, dataset){
	var row = dataset.rowposition;

	for (var i = 0; i < grid.rowcount; i++) {
		// 체크박스 컬럼 생성
		dataset.addColumn("_chk", "string");
		
		if( i == row){ //선택한 셀 체크박스 체크
			dataset.setColumn(row, "_chk", 1);
		}else{
			dataset.setColumn(i, "_chk", 0);
		}
    }
};

// 결과 값 출력
this.fnResult = function(fnc){
	//alert(this.dsResult.getColumn(0, "result"));
	var result = this.dsResult.getColumn(0, "result");
	if(result == "88"){
		this.smfAlert("사업자등록번호가 이미 등록되어있습니다.");
	}else if(result == "99"){
		var res = "";
		if(this.fv_CaaCai == 0){		// 휴원
			res = "학원휴원신고내역 " + fnc + "에 실패하였습니다.";
		}else if(this.fv_CaaCai == 1){	// 폐원
			res = "학원폐원신고내역 " + fnc + "에 실패하였습니다.";
		}
		
		this.smfAlert(res + " 임시저장에 실패하였습니다.");
	}else {
		this.smfAlert('CM002', []);
	}
};

// disable
this.onDisable = function(objComp, nLvl, oOwner){
	if((objComp instanceof nexacro.Edit) 
	|| (objComp instanceof nexacro.MaskEdit) 
	|| (objComp instanceof nexacro.Combo)
	|| (objComp instanceof nexacro.TextArea)
	|| (objComp instanceof nexacro.Spin)
	|| (objComp instanceof nexacro.Calendar)
	|| (objComp instanceof nexacro.Radio))
	{
		//if(objComp.id.indexOf("Addr") !== -1 || objComp.id.indexOf("File") !== -1  || objComp.id.indexOf("NoRd") !== -1 ) return false;
		objComp.set_readonly(true);
	}
	else if((objComp instanceof nexacro.Button))
	{
		//if(objComp.id.indexOf("Down") !== -1) return false;
		objComp.set_enable(false)
	}
};


// enable
this.onEnable = function(objComp, nLvl, oOwner){
	if((objComp instanceof nexacro.Edit) 
	|| (objComp instanceof nexacro.MaskEdit) 
	|| (objComp instanceof nexacro.Combo)
	|| (objComp instanceof nexacro.TextArea)
	|| (objComp instanceof nexacro.Spin)
	|| (objComp instanceof nexacro.Calendar)
	|| (objComp instanceof nexacro.Radio))
	{
		//if(objComp.id.indexOf("Addr") !== -1 || objComp.id.indexOf("File") !== -1  || objComp.id.indexOf("NoRd") !== -1 ) return false;
		objComp.set_readonly(false);
	}
	else if((objComp instanceof nexacro.Button))
	{
		//if(objComp.id.indexOf("Down") !== -1) return false;
		objComp.set_enable(true);
	}
};

//저장 시 필수값체크
this.fnValid = function(){
	if(this.fv_CaaCai == 0){ //휴원
		this.divReg.form.divCaa.form.calCaaBgngYmd.updateToDataset();
		if(this.smfIsNull(this.dsTmprInfo.getColumn(0,"caaBgngYmd").trim())){
			this.smfAlert('CM022', ['휴원시작일']); // 휴원시작일을(를) 선택하여 주십시오.
			this.divReg.form.divCaa.form.calCaaBgngYmd.setFocus();
			return false;
		}
		this.divReg.form.divCaa.form.calCaaEndYmd.updateToDataset();
		if(this.smfIsNull(this.dsTmprInfo.getColumn(0,"caaEndYmd").trim())){
			this.smfAlert('CM022', ['휴원종료일']); // 휴원종료일을(를) 선택하여 주십시오.
			this.divReg.form.divCaa.form.calCaaEndYmd.setFocus();
			return false;
		}
		this.divReg.form.divCaa.form.edtCaaRsnCn.updateToDataset();
		if(this.smfIsNull(this.dsTmprInfo.getColumn(0,"caaRsnCn"))){
			this.smfAlert("휴원사유를 입력해주세요.");
			this.divReg.form.divCaa.form.edtCaaRsnCn.setFocus();
			return false;
		}
	}else{ //폐원
		this.divReg.form.divCai.form.calCaiBgngYmd.updateToDataset();
		if(this.smfIsNull(this.dsTmprInfo.getColumn(0,"caaBgngYmd").trim())){
			this.smfAlert('CM022', ['폐원일']); // 폐원일을(를) 선택하여 주십시오.
			this.divReg.form.divCai.form.calCaiBgngYmd.setFocus();
			return false;
		}
		this.divReg.form.divCai.form.edtCaiRsnCn.updateToDataset();
		if(this.smfIsNull(this.dsTmprInfo.getColumn(0,"caaRsnCn"))){
			this.smfAlert("폐원사유를 입력해주세요.");
			this.divReg.form.divCai.form.edtCaiRsnCn.setFocus();
			return false;
		}
	}
	
	return true;
}
