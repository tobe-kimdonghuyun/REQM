		if(callbackParams.errors) return;
		
		// 저장정보 초기화
		this.dsSave.deleteRow(0);
		this.dsSave.addRow();
		
		// 업로드 초기화
		this.divReq.form.divFileUpload.form.fnResetUpload();
		
		this.smfAlert('CM002', []);
		
		// 임시저장목록 조회
		this.listLnxPayBassCnTmpr();
	});
};
this.fnEventAfterAddFile = function(obj,paramObj,sCustomValue,sFileName,nFileSize)
{
	trace("=== Sample : fnEventAfterAddFile");
	this.divReq.form.divFileUpload.form.fnFileUpload();
}
this.fnEventUploadComplete = function(obj,paramObj,objResultDataset)
{
	// 신규서비스
	trace("=== Sample : fnEventUploadComplete");	
	this.divReq.form.divFileUpload.form.fnSetUploadCompleteState(obj,paramObj);
	if(objResultDataset){
		trace("====업로드한 결과 데이터셋 ========== : "+objResultDataset.saveXML());
		this.dsSave.setColumn(0, "sfileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
		var sFileRefrnId = objResultDataset.getColumn(0,"fileRefrnId");
		trace("sFileRefrnId : "+sFileRefrnId);
	}

}
this.fnEventUploadError = function(obj,paramObj)
{
	trace("파일 업로드에 실패 하였습니다.");		
}

//파일삭제
this.divAplyCn_btnFleDel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divReq.form.divFileUpload.form.fnResetUpload();
	this.dsSave.setColumn(0, "sfileRefrnId", "");
};

//파일다운로드
this.divAplyCn_btnFleDwld_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divReq.form.divFileUpload.form.fnFileDownload();
};

this.divReq_rdoPrufDocuSbmsnMetCd_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	this.fnSetFileDiv();
};
