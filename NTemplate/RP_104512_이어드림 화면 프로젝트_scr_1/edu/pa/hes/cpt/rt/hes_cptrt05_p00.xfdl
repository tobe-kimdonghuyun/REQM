          <Column id="caiRegYmd" type="STRING" size="256" sumtext="폐원등록일자"/>
          <Column id="rmkMteCn" type="STRING" size="256" sumtext="비고사항내용"/>
          <Column id="actnMteCn" type="STRING" size="256" sumtext="조치사항내용"/>
          <Column id="rjctYmd" type="STRING" size="256" sumtext="반려일자"/>
          <Column id="lftmQlfScCd" type="STRING" size="256" sumtext="평생자격구분코드"/>
          <Column id="faZip" type="STRING" size="256" sumtext="시설우편번호"/>
          <Column id="faAddr" type="STRING" size="256" sumtext="시설주소"/>
          <Column id="faLnbrNm" type="STRING" size="256" sumtext="시설번지명"/>
          <Column id="faRoadNmPostNo" type="STRING" size="256" sumtext="시설도로명우편번호"/>
          <Column id="faRoadNmAddr" type="STRING" size="256" sumtext="시설도로명주소"/>
          <Column id="faRoadNmDtlAddr" type="STRING" size="256" sumtext="시설도로명상세주소"/>
          <Column id="rjctRsnCn" type="STRING" size="256" sumtext="반려사유내용"/>
          <Column id="acaRegCd" type="STRING" size="256" sumtext="학원등록코드"/>
          <Column id="fxpNmprCnt" type="STRING" size="256" sumtext="정원인원수"/>
          <Column id="bfrRegDsgnNo" type="STRING" size="256" sumtext="이전등록지정번호"/>
