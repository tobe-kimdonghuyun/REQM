    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 교습소휴폐소신고
*  @MenuPath    TEMPLATE
*  @FileName 	hes_cptrt05_m00.xfdl
*  @Creator 	김명주
*  @CreateDate 	2022.12.01
*  @Desction    교습소휴폐소신고
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.12.01     	김명주 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
// 휴소 : 0 / 폐소 : 1 구분
this.fv_CaaCai = 0;	// 초기 값은 휴소

// 휴/폐소 관련 top 위치 세팅
this.fv_divCaaTop = 0;	// 휴소 div
this.fv_divCaiTop = 0;	// 폐소 div
this.fv_divEtcTop = 0;	// 기타 div

 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 폼 초기화 이벤트
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{	
	// 팝업 폼 초기화
	this.smfInitPopup(obj);
	
	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();

	// 사이즈 관련 고정 값 세팅
	this.fv_divCaaTop = this.divReg.form.divCaa.top;	// 휴원 div
	this.fv_divCaiTop = this.divReg.form.divCai.top;	// 폐원 div
	this.fv_divEtcTop = this.divReg.form.divEtc.top;	// 기타 div

	// 교습소 정보 조회
	this.listInstutInfo();
}
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 교습소정보 조회 함수
this.listInstutInfo = function ()
{
	this.dsSearch00.setColumn(0, "acaDsgnNo", this.pv_params.acaDsgnNo);
	this.dsSearch00.setColumn(0, "acaInstiScCd", this.pv_params.acaInstiScCd);
	this.dsSearch00.setColumn(0, "atptOfcdcOrgCode", this.pv_params.dstrtOfcdcCd);

	// 교습소정보 조회
	this.smfSearchService("listInstutInfo")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		// 데이터셋 복사하기
		this.dsInstutInfo.copyData(this.dsMain00);
		
		// 임시저장목록 조회
		this.listInstutBassCnTmpr();
	});
};

// 전송 값 세팅
this.fnSaveSetting = function(gbn) {
	// 학원정보 내용 복사(학원이 1개인 경우 dsInstutInfo, 1개 이상이면 dsInstutInfoList로 변경 확인)
	this.dsSave.copyRow(0, this.dsInstutInfo, 0);
	// 입력된 내용 복사
	this.dsSave.copyRow(0, this.dsTmprInfo, 0);
	
	this.dsSave.setColumn(0, "onlCvlcptPrcsStsCd", "01");
	this.dsSave.setColumn(0, "onlCvlcptAprvCd", "0");
};

// 임시저장목록 조회
this.listInstutBassCnTmpr = function(){
	// 파라미터 세팅(학원지정번호, 지역교육청코드, 학원교습소구분코드)
	this.dsSearch01.copyRow(0,this.dsSearch00,0);
	this.dsSearch01.setColumn(0, "dstrtOfcdcCd", this.dsInstutInfo.getColumn(0, "cteOfcdcCd"));
	this.dsSearch01.setColumn(0, "tmprAcaDsgnNo", this.pv_params.tmprAcaDsgnNo);
	this.dsSearch01.setColumn(0, "acaInstiScCd", "2");
	
	// 임시 휴폐소정보 조회
	this.dsMain01.clearData();
	
	this.dsTmprInfoList.clearData();
	
	this.dsTmprInfo.deleteRow(0);
	this.dsTmprInfo.addRow();
	
	this.smfSearchService("listInstutBassCnTmpr")
	.run()
	.callback(function(callbackParams){
		//미접수상태인 경우 철회버튼 활성화 
		if(this.dsMain01.getColumn(0,"onlCvlcptPrcsStsCd") == "00"){
			this.btnRtrcn.set_visible(true);
		}
		
		this.dsTmprInfo.copyRow(0,this.dsMain01,0);
		
		this.fnSetInfoFrm();
	});
};
this.fnSetInfoFrm = function(gbn){
	if(this.dsTmprInfo.getColumn(0,"regStsCd") == "2"){ //휴원일 경우
		// 휴원 관련
		this.divReg.form.divCaa.set_visible(true);
		
		// 폐원 관련
		this.divReg.form.divCai.set_visible(false);
		this.divReg.form.divEtc.set_top(this.fv_divCaiTop);
		this.divBtn.set_top(this.divBtn.top - this.divReg.form.divCai.height);
	}else{ //폐원일경우
		// 휴원 관련
		this.divReg.form.divCaa.set_visible(false);
		
		// 폐원 관련
		this.divReg.form.divCai.set_visible(true);
		
		// 위치 이동
		var top = this.fv_divCaiTop - this.fv_divCaaTop;
		var divCaiTop = this.fv_divCaiTop - top;
		var divEtcTop = this.fv_divEtcTop - top;
		
		this.divReg.form.divCai.set_top(divCaiTop);
		this.divReg.form.divEtc.set_top(divEtcTop);
		this.divBtn.set_top(this.divBtn.top - this.divReg.form.divCaa.height);
	}

	// 전화번호/휴대폰 세팅
	var invlTelno = this.dsTmprInfo.getColumn(0, "invlTelno");
	var invlMblTelno = this.dsTmprInfo.getColumn(0, "invlMblTelno");
	
	var result = this.smfSplit(invlTelno, "-");
	if(result.length == 3){
		this.dsTmprInfo.setColumn(0, "invlTelno1", result[0]);
		this.dsTmprInfo.setColumn(0, "invlTelno2", result[1]);
		this.dsTmprInfo.setColumn(0, "invlTelno3", result[2]);
	}
	
	result = this.smfSplit(invlMblTelno, "-");
	if(result.length == 3){
		this.dsTmprInfo.setColumn(0, "invlMblTelno1", result[0]);
		this.dsTmprInfo.setColumn(0, "invlMblTelno2", result[1]);
		this.dsTmprInfo.setColumn(0, "invlMblTelno3", result[2]);
	}
	
	// 업로드 초기화
	this.divReg.form.divEtc.form.divFileUpload.form.fnResetUpload();
	
	//파일참조ID가 있는 경우 파일정보조회
	if(this.dsTmprInfo.getColumn(0,"fileRefrnId") != ""){
		this.transaction(
			 "fn_filesearch" // serviceId
			,"baseUrl::/cm_cmc_file_upload_001.do" // url
			,"" // inDataset
			,"dsOutFileinfo=atchFileinfo" // outDataset
			,"fileRefrnId='"+this.dsTmprInfo.getColumn(0,"fileRefrnId")+"'"
			,""
			,false // true: 비동기, false:동기
	   );
		
		var responseCustomValue = "";
		var sDownloadUrl       = ""; 
		var sHandlerCode       = "PA.SAM.PLE";
		var sFileSn            = this.dsOutFileinfo.getColumn(0,"fileRefrnId"   );
		var sFileSeq           = this.dsOutFileinfo.getColumn(0,"fileId"        );
		var sFileSize          = this.dsOutFileinfo.getColumn(0,"atchFileMg"    );
		var sBackendFilename   = this.dsOutFileinfo.getColumn(0,"atchFileGuid"  );
		var sForntendFilename  = this.dsOutFileinfo.getColumn(0,"atchFileNm"    );
		var sFileEncryptYn     = this.dsOutFileinfo.getColumn(0,"fileEncryptYn" );
		var sPrivInfoFiltYn    = this.dsOutFileinfo.getColumn(0,"privInfoFiltYn");
		var sFileSaveStg       = this.dsOutFileinfo.getColumn(0,"fileSaveStg"   );
		var sFileInfSaveYn     = this.dsOutFileinfo.getColumn(0,"fileInfSaveYn" );
		
		this.divReg.form.divEtc.form.divFileUpload.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sForntendFilename, sFileSeq, sDownloadUrl
												  ,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn );
		
		this.dsSave.setColumn(0, "sfileRefrnId", sFileSn);
	}
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.btnRtrcn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 전송 값 세팅
	this.fnSaveSetting();
	
	this.smfConfirm("철회하시겠습니까?", function(result){
		if(result.confirmResult){
			// 서비스 객체 생성
			this.smfSaveService("updateInstutBassCnTmpr")
			.showConfirm(false) 
			// 실행
			.run()
			// 콜백
			.callback(function(callbackParams){
				if(callbackParams.errors) return;
					alert("철회되었습니다.");
					// 저장정보 초기화
					this.dsSave.deleteRow(0);
					this.dsSave.addRow();
					this.smfSendResponseToOpener({
						"search": true
					});
					this.close(true);
			});
		}
	});	
};

this.btnCncl_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSendResponseToOpener({
		"search": false
	});
	this.close(false);
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="divInstutInfo01.form.staKornOrgNm" propid="text" datasetid="dsInstutInfo" columnid="kornOrgNm"/>
      <BindItem id="item1" compid="divInstutInfo01.form.staAcaNm" propid="text" datasetid="dsInstutInfo" columnid="acaNm"/>
      <BindItem id="item2" compid="divInstutInfo01.form.staFaTelno" propid="text" datasetid="dsInstutInfo" columnid="faTelno"/>
      <BindItem id="item3" compid="divInstutInfo01.form.staEtbYmd" propid="text" datasetid="dsInstutInfo" columnid="etbYmd"/>
      <BindItem id="item4" compid="divInstutInfo01.form.staRegDsgnNo" propid="text" datasetid="dsInstutInfo" columnid="regDsgnNo"/>
      <BindItem id="item5" compid="divInstutInfo01.form.staRealmScCodeNm" propid="text" datasetid="dsInstutInfo" columnid="realmScCodeNm"/>
      <BindItem id="item6" compid="divReg.form.staRegDsgnNo" propid="text" datasetid="dsTmprInfo" columnid="regDsgnNo"/>
      <BindItem id="item7" compid="divReg.form.mskBrno" propid="value" datasetid="dsTmprInfo" columnid="brno"/>
      <BindItem id="item8" compid="divReg.form.staAcaNm" propid="text" datasetid="dsTmprInfo" columnid="acaNm"/>
      <BindItem id="item9" compid="divReg.form.edtFaRoadNmPostNo" propid="value" datasetid="dsTmprInfo" columnid="faRoadNmPostNo"/>
      <BindItem id="item10" compid="divReg.form.edtFaRoadNmAddr" propid="value" datasetid="dsTmprInfo" columnid="faRoadNmAddr"/>
      <BindItem id="item11" compid="divReg.form.edtFaRoadNmDtlAddr" propid="value" datasetid="dsTmprInfo" columnid="faRoadNmDtlAddr"/>
      <BindItem id="item12" compid="divReg.form.staAcaKndNm" propid="text" datasetid="dsTmprInfo" columnid="acaKndNm"/>
      <BindItem id="item13" compid="divReg.form.staRealmScCodeNm" propid="text" datasetid="dsTmprInfo" columnid="realmScCodeNm"/>
      <BindItem id="item14" compid="divReg.form.staLeOrdCodeNm" propid="text" datasetid="dsTmprInfo" columnid="leOrdCodeNm"/>
      <BindItem id="item15" compid="divReg.form.staLeCrseCodeNm" propid="text" datasetid="dsTmprInfo" columnid="leCrseCodeNm"/>
      <BindItem id="item16" compid="divReg.form.calEtbYmd" propid="value" datasetid="dsTmprInfo" columnid="etbYmd"/>
      <BindItem id="item17" compid="divReg.form.calRegDt" propid="value" datasetid="dsTmprInfo" columnid="regDt"/>
      <BindItem id="item18" compid="divReg.form.edtRegSttusCodeNm" propid="value" datasetid="dsTmprInfo" columnid="regSttusCodeNm"/>
      <BindItem id="item19" compid="divReg.form.staChgKndCodeNm" propid="text" datasetid="dsTmprInfo" columnid="chgKndCodeNm"/>
