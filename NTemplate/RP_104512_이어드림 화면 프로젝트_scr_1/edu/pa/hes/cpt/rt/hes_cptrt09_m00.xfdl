    <Script type="xscript5.1"><![CDATA[/**
*  대국민 - 교습소임시교습자및보조요원관리
*  @MenuPath    TEMPLATE
*  @FileName 	hes_cptrt09_m00.xfdl
*  @Creator 	김명주
*  @CreateDate 	2022.12.06
*  @Desction    교습소임시교습자및보조요원관리
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.12.06     	김명주 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs"
include "lib::hes_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 //화면 접근 시 로그인정보 확인
this.fnOninit = function(obj:nexacro.Form,e:nexacro.EventInfo)
{
	if(this.hesChkLogin("2","pa_hes_cpt_rt::hes_cptrt09_m00.xfdl")){
		this.hesSetGoUrl("pa_hes_cpt_rt::hes_cptrt09_m00.xfdl");
		this.fnOnload(this);
	}
};
// 채용 : 0 / 해임 : 1 구분
this.fv_empmnRlsofc = 0;	// 초기 값은 채용

// 임시교습자 : 0 / 보조요원 : 1 구분
this.fv_tmprLesrAtaSewEmpmn = 0;	// 초기 값은 임시교습자 (채용)
this.fv_tmprLesrAtaSewRlsofc = 0;	// 초기 값은 임시교습자 (해임)

// 채용시 버튼영역 위치 세팅
this.btnTop = 0;

//채용 시 주민번호체크여부
this.rrnoCeckYn = "Y";
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
// 폼 초기화 이벤트
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{	
	
	// 업로드 초기설정
	this.divReq.form.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;        // 필요한 경우만 세팅(세팅권장)
	this.divReq.form.divFileUpload.UPLOAD_OnError        = this.fnEventUploadError;           // 필요한 경우만 세팅(세팅권장)
	this.divReq.form.divFileUpload.UPLOAD_AfterAddFile   = this.fnEventAfterAddFile;          // 필요한 경우만 세팅(세팅권장)
	this.divReq.form.divFileUpload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)

	
	// 라디오버튼 초기화(채용, 임시교습자)
	this.divInstutInfo01.form.rdoEmpmnRlsofc.set_value(this.fv_empmnRlsofc);
	this.divMain01.form.rdoTmprLesrAtaSew.set_value(this.fv_tmprLesrAtaSewEmpmn);	// (채용) 임시교습자
	this.divSearch.form.rdoTmprLesrAtaSew.set_value(this.fv_tmprLesrAtaSewRlsofc);	// (해임) 임시교습자
	
	// 사이즈 관련 고정 값 세팅
	var divSearchTop = this.divSearch.top;		// 임시교습자/보조요원 조회 div top
	var divSearchHeight = this.divSearch.height;// 임시교습자/보조요원 조회 div height
	var divMain01Top = this.divMain01.top;		// 임시저장정보 div top
	
	// 해임 관련
	this.divSearch.set_visible(false);
	this.divMain00.set_visible(false);
	this.divInfo.set_visible(false);
	
	this.divInfo.set_left(0);
	this.divInfo.set_right(0);
	
	// 기본 간격 30, 안쓰이는 버튼 영역 포함 40... 추후 수정 필요
	var divMain00Top = divSearchTop * 1 + divSearchHeight * 1;
	this.divMain00.set_top(divMain00Top * 1+10);	// 임시교습자/보조요원 조회 리스트 위치 이동
	
	var divMain00Top = this.divMain00.top;
	var divMain00Height = this.divMain00.height;
	var divInfoTop = divMain00Top * 1 + divMain00Height * 1;

	this.divInfo.set_top(divInfoTop-20);	// 임시교습자/보조요원 상세정보 위치 이동
	
	// 채용 관련
	this.divMain01.set_top(divSearchTop);	// 임시저장정보 위치 이동
	
	var top = divMain01Top - divSearchTop;
	
	var divReqTop = this.divReq.top;	// 기본정보 div top
	var divReqNewTop = divReqTop - top;
	
	this.divReq.set_top(divReqNewTop);	// 기본정보 위치이동

	var divBtnTop = this.divBtn.top;	// 버튼영역 div top
	var divBtnNewTop = divBtnTop - top;

	this.divBtn.set_top(divBtnNewTop);	// 버튼영역 위치 이동
	this.btnTop = this.divBtn.top;		// 채용 시 버튼영역 위치 고정
	
	// 공통코드 호출
	this.smfCodeList("code", [this.dsAcbgCd, this.dsInsrQlfScCd])
		.callback(function(callbackParams){
			if(callbackParams.errors) return;	
			
			// 서비스 객체 생성 (채용)
			this.smfValidateService("validateMain01", {
					url: "/hes_cpt_rt09_901.do",
			})
			.mappingRulesetToForm(this.divReq, "save01")
			.run()
			.callback(function(callbackParams){
				if(callbackParams.errors) return;
				
			});
			
			// 교습소정보 조회
			this.listInstutInfo();
		})		
		.run()
	;	
};

