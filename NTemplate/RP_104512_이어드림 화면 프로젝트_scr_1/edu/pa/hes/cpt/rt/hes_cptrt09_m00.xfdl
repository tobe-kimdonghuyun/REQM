// 교습소정보 조회 함수
this.listInstutInfo = function ()
{
	// 임시세팅	
	this.dsSearch02.setColumn(0, "acaDsgnNo", this.hesGetAcaDsgnNo);	
	this.dsSearch02.setColumn(0, "acaInstiScCd", this.hesGetAcaInstiScCd);
	this.dsSearch02.setColumn(0, "atptOfcdcOrgCode", this.hesGetAtptOfcdcOrgCode);
	this.dsSearch01.setColumn(0, "acaDsgnNo", this.hesGetAcaDsgnNo);	
	this.dsSearch01.setColumn(0, "acaInstiScCd", this.hesGetAcaInstiScCd);
	this.dsSearch01.setColumn(0, "atptOfcdcOrgCode", this.hesGetAtptOfcdcOrgCode);
	this.dsSearch00.setColumn(0, "acaDsgnNo", this.hesGetAcaDsgnNo);	
	this.dsSearch00.setColumn(0, "acaInstiScCd", this.hesGetAcaInstiScCd);
	this.dsSearch00.setColumn(0, "atptOfcdcOrgCode", this.hesGetAtptOfcdcOrgCode);
	
	this.smfSearchService("listInstutInfo")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors){
			var objFrame = this.getOwnerFrame();
			objFrame.form.fnSetMainpage(objFrame.form.fv_mainformUrl);	
		}
		
		// 데이터셋 복사하기
		this.dsInstutInfo.copyData(this.dsMain00);
		
		if(this.fv_empmnRlsofc == 0){		// 채용
			// 임시저장정보 조회
			this.fnTmprInfoSearch();
		}else if(this.fv_empmnRlsofc == 1){	// 해임
			// 임시교습자/보조요원 조회(해임)
			this.InsrInq();
		}
	});
}

// 임시저장정보 조회(채용)
this.fnTmprInfoSearch = function(){
	// 파라미터 세팅
	this.dsSearch02.copyRow(0, this.dsInstutInfo, this.dsInstutInfo.rowposition);
	this.dsSearch02.setColumn(0, "empmnScCd", "1");
	
	// 초기화(해임)
	this.dsMain01.clearData();
	
	this.dsDetailInfo00.deleteRow(0);
	this.dsDetailInfo00.addRow();
	
	// 초기화(채용)
	this.dsMain02.clearData();
	
	this.dsDetailInfo01.deleteRow(0);
	this.dsDetailInfo01.addRow();
	
	// 강사구분코드 사용(임시로 세팅)
	if(this.fv_tmprLesrAtaSewEmpmn == 0){		// 임시교습자 : 5
		this.dsSearch02.setColumn(0, "insrScCd", "5");
	}else if(this.fv_tmprLesrAtaSewEmpmn == 1){	// 보조요원 : 1
		this.dsSearch02.setColumn(0, "insrScCd", "1");
	}
	
	this.smfSearchService("listEmpmnCnTmpr")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		if(this.dsMain02.getColumn(0, "imsiScCode") == "20"){//제출정보가 있는 경우
			this.smfAlert("현재 진행중인 민원이 있습니다.\n해당 민원처리가 종료된 이후 민원을 진행하실 수 있습니다.\n[확인]버튼을 누르시면 민원신고내역조회 페이지로 이동합니다.",this.hesGoCvlcptDclrList);
			return;
		}else{
			// 데이터셋 복사하기
			this.dsTmprInfoList.copyData(this.dsMain02);		
			
			if(this.fv_empmnRlsofc == 0){ //채용일때만 증빙서류 사용
				//임시저장정보 없는 경우 증빙서류제출방식 기본값 온라인 사용
				this.dsDetailInfo01.setColumn(0, "prufDocuSbmsnMetCd","2");
			}
		}
		
		this.fnSetFileDiv();
	});
};

// 임시교습자/보조요원 조회(해임)
this.InsrInq = function (){
	// 파라미터 세팅
	this.dsSearch01.copyRow(0, this.dsInstutInfo, this.dsInstutInfo.rowposition);

	// 시도교육청코드 세팅	
	var cddcOrgCd = this.dsInstutInfo.getColumn(0, "cteOfcdcCd");

	cddcOrgCd = cddcOrgCd.substring(0, 3) + "0000001";
	this.dsSearch01.setColumn(0, "cddcOrgCd", cddcOrgCd);	
	this.dsSearch01.setColumn(0, "empmnScCd", "2");
	this.dsSearch01.setColumn(0, "acaInstScCd", "2");

	// 초기화(해임)
	this.dsMain01.clearData();
	
	this.dsDetailInfo00.deleteRow(0);
	this.dsDetailInfo00.addRow();
	
	// 초기화(채용)
	this.dsMain02.clearData();
	
	this.dsDetailInfo01.deleteRow(0);
	this.dsDetailInfo01.addRow();
	
	// 임시교습자, 보조요원 구분(강사구분코드 사용)
	if(this.fv_tmprLesrAtaSewRlsofc == 0){			// 임시교습자 : 5
		this.dsSearch01.setColumn(0, "insrScCd", "5");
	}else if(this.fv_tmprLesrAtaSewRlsofc == 1){	// 보조요원 : 1
		this.dsSearch01.setColumn(0, "insrScCd", "1");
	}
	
	this.smfSearchService("listInfo")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		// 데이터셋 복사하기
		this.dsInstrctrInfoList.copyData(this.dsMain01);
		

	});
};

// 선택한 셀만 체크박스 체크(라디오 버튼 효과)
this.fnGridRadioCheck = function(grid, dataset){
	var row = dataset.rowposition;

	for (var i = 0; i < grid.rowcount; i++) {
		// 체크박스 컬럼 생성
		dataset.addColumn("_chk", "string");
		
		if( i == row){ //선택한 셀 체크박스 체크
			dataset.setColumn(row, "_chk", 1);
		}else{
			dataset.setColumn(i, "_chk", 0);
		}
    }
};
//해임 시 강사 선택 여부 확인
this.fnInsrCeckYn = function(){
	var isCheck = this.dsInstrctrInfoList.getColumn(this.dsInstrctrInfoList.rowposition, "_chk");
		
	if(!isCheck){
		this.smfAlert("강사를 선택해 주세요.");
		return false;
	}
	
	return true;
}
//해임 시 필수값
this.fnDismCeck = function(){
	if(this.dsSave00.getColumn(0,"dismYmd") == undefined){
		alert("해임일은 필수입니다.");
		return false;
	}
	if(this.dsSave00.getColumn(0,"dismRsnCn") == undefined){
		alert("해임사유는 필수입니다.");
		return false;
	}
	
	return true;
}

// 전송값 세팅
this.fnSaveSetting = function(gbn) {

	if(this.fv_empmnRlsofc == 1){
		// 해임 인 경우
		
		// 임시정보 내용 복사
		this.dsSave00.copyRow(0, this.dsMain01, this.dsInstrctrInfoList.rowposition);
			
		// 해임관련 내용 복사
		this.dsSave00.copyRow(0, this.dsInstrctrInfoList, this.dsInstrctrInfoList.rowposition);
		
		//개인지정번호 세팅
		var invlDsgnNo = this.dsSave00.getColumn(0, "invlDsgnNo");
		this.dsSave00.setColumn(0, "invlDsgnNo", invlDsgnNo);
		
		// 관할교육청코드, 지역교육청코드 세팅
		var cteOfcdcCd = this.dsSave00.getColumn(0, "cteOfcdcCd");
		this.dsSave00.setColumn(0, "dstrtOfcdcCd", cteOfcdcCd);
			
		cteOfcdcCd = cteOfcdcCd.substring(0, 3) + "0000001";
		this.dsSave00.setColumn(0, "cteOfcdcCd", cteOfcdcCd);
		
		this.dsSave00.setColumn(0, "empmnScCd", "2");

		// 임시교습자, 보조요원 구분(강사구분코드 사용)
		if(this.fv_tmprLesrAtaSewRlsofc == 0){		// 임시교습자 : 5
			this.dsSearch01.setColumn(0, "insrScCd", "5");
		}else if(this.fv_tmprLesrAtaSewRlsofc == 1){	// 보조요원 : 1
			this.dsSearch01.setColumn(0, "insrScCd", "1");
		}

		// 임시저장, 수정 시 처리상태코드 세팅
		if (gbn == "01") {
			// 임시저장여부 Y로 세팅
			this.dsSave00.setColumn(0, "tmprStrgYn", "Y");
			// 처리상태코드 세팅
			this.dsSave00.setColumn(0, "onlCvlcptPrcsStsCd", "01");
			// 채용통보일자 초기화
			this.dsSave00.setColumn(0, "empmnNtfctnYmd", "");
		} else if (gbn == "02") {	//등록인경우
			// 임시저장여부 N으로 세팅
			this.dsSave00.setColumn(0, "tmprStrgYn", "N");
			// 처리상태코드 세팅
			this.dsSave00.setColumn(0, "onlCvlcptPrcsStsCd", "02");
			// 채용통보일자 세팅
			var result = this.smfToday();
			this.dsSave00.setColumn(0, "empmnNtfctnYmd", result);
		}
	} else if(this.fv_empmnRlsofc == 0){
		// 채용 인 경우
		// 교습소정보 내용 복사
		this.dsSave01.copyRow(0, this.dsInstutInfo, this.dsInstutInfo.rowposition);
		// 임시정보 내용 복사
		this.dsSave01.copyRow(0, this.dsMain02, this.dsTmprInfoList.rowposition);
			
		// 채용관련 내용 복사
		this.dsSave01.copyRow(0, this.dsDetailInfo01, this.dsDetailInfo01.rowposition);
		
		//개인지정번호 세팅
		var invlDsgnNo = this.dsSave01.getColumn(0, "invlDsgnNo");
		this.dsSave01.setColumn(0, "invlDsgnNo", invlDsgnNo);
		
		// 관할교육청코드, 지역교육청코드 세팅		
		var cteOfcdcCd = this.dsSave01.getColumn(0, "cteOfcdcCd");
		
		this.dsSave01.setColumn(0, "dstrtOfcdcCd", cteOfcdcCd);
		cteOfcdcCd = cteOfcdcCd.substring(0, 3) + "0000001";
		this.dsSave01.setColumn(0, "cteOfcdcCd", cteOfcdcCd);
		
		this.dsSave00.setColumn(0, "empmnScCd", "1");
		
		// 전화번호 세팅
		// 임시 앞자리 세팅
		//this.dsDetailInfo01.setColumn(0, "invlTelno1", "02");
		var invlTelno = this.dsDetailInfo01.getColumn(0, "invlTelno1") + "-" +
						this.dsDetailInfo01.getColumn(0, "invlTelno2") + "-" +
						this.dsDetailInfo01.getColumn(0, "invlTelno3");
		//alert(invlTelno);
		
		this.dsSave01.setColumn(0, "invlTelno", invlTelno);
		
		// 임시교습자, 보조요원 구분(강사구분코드 사용)
		if(this.fv_tmprLesrAtaSewEmpmn == 0){		// 임시교습자 : 5
			this.dsSave01.setColumn(0, "insrScCd", "5");
		}else if(this.fv_tmprLesrAtaSewEmpmn == 1){	// 보조요원 : 1
			this.dsSave01.setColumn(0, "insrScCd", "1");
		}

		// 임시저장, 수정 시 처리상태코드 세팅
		if (gbn == "01") {
			// 처리상태코드 세팅
			this.dsSave01.setColumn(0, "onlCvlcptPrcsStsCd", "01");
			// 채용통보일자 초기화
			this.dsSave01.setColumn(0, "empmnNtfctnYmd", "");
		}else if (gbn == "02") {	//등록인경우
			// 처리상태코드 세팅
			this.dsSave01.setColumn(0, "onlCvlcptPrcsStsCd", "02");
			// 채용통보일자 세팅
			var result = this.smfToday();
			this.dsSave01.setColumn(0, "empmnNtfctnYmd", result);
		}
	}
};
