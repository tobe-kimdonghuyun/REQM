// 임시교습자/보조요원 리스트 선택
this.divMain00_grdInstrctrInfo_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	// 그리드 체크박스(라디오버튼)
	this.fnGridRadioCheck(this.divMain00.form.grdInstrctrInfo, this.dsInstrctrInfoList);
	
	this.dsDetailInfo00.copyRow(0, this.dsMain01, this.dsInstrctrInfoList.rowposition);
};

// 임시정보리스트 선택
this.divMain01_grdTmprInfo_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	// 그리드 체크박스(라디오버튼)
	this.fnGridRadioCheck(this.divMain01.form.grdTmprInfo, this.dsTmprInfoList);
		
	this.dsDetailInfo01.copyRow(0, this.dsMain02, this.dsTmprInfoList.rowposition);
	
	// 전화번호 세팅
	var invlTelno = this.dsDetailInfo01.getColumn(0, "invlTelno");
	
	var result = this.smfSplit(invlTelno, "-");
	if(result.length == 3){
		// 앞자리 임시 세팅
		this.dsDetailInfo01.setColumn(0, "invlTelno1", result[0]);
		this.dsDetailInfo01.setColumn(0, "invlTelno2", result[1]);
		this.dsDetailInfo01.setColumn(0, "invlTelno3", result[2]);
	}
	
	this.divReq.form.cboInvlTelno1.set_index(0);
	
	// 업로드 초기화
	this.divReq.form.divFileUpload.form.fnResetUpload();
	
	//파일참조ID가 있는 경우 파일정보조회
	if(this.dsDetailInfo01.getColumn(0,"fileRefrnId") != ""){
		this.transaction(
			 "fn_filesearch" // serviceId
			,"baseUrl::/cm_cmc_file_upload_001.do" // url
			,"" // inDataset
			,"dsOutFileinfo=atchFileinfo" // outDataset
			,"fileRefrnId='"+this.dsDetailInfo01.getColumn(0,"fileRefrnId")+"'"
			,""
			,false // true: 비동기, false:동기
	   );
	    
		var responseCustomValue = "";
		var sDownloadUrl       = ""; 
		var sHandlerCode       = "PA.SAM.PLE";
		var sFileSn            = this.dsOutFileinfo.getColumn(0,"fileRefrnId"   );
		var sFileSeq           = this.dsOutFileinfo.getColumn(0,"fileId"        );
		var sFileSize          = this.dsOutFileinfo.getColumn(0,"atchFileMg"    );
		var sBackendFilename   = this.dsOutFileinfo.getColumn(0,"atchFileGuid"  );
		var sForntendFilename  = this.dsOutFileinfo.getColumn(0,"atchFileNm"    );
		var sFileEncryptYn     = this.dsOutFileinfo.getColumn(0,"fileEncryptYn" );
		var sPrivInfoFiltYn    = this.dsOutFileinfo.getColumn(0,"privInfoFiltYn");
		var sFileSaveStg       = this.dsOutFileinfo.getColumn(0,"fileSaveStg"   );
		var sFileInfSaveYn     = this.dsOutFileinfo.getColumn(0,"fileInfSaveYn" );
		
		this.divReq.form.divFileUpload.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sForntendFilename, sFileSeq, sDownloadUrl
												  ,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn );
		
		this.dsSave01.setColumn(0, "sfileRefrnId", sFileSn);
	}
	
	this.fnSetFileDiv();
};

// 임시저장
this.divBtn_btnTemp_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.fv_empmnRlsofc == 1){
		//해임 인 경우
	
		//그리드 값 데이터셋 반영
		this.divMain00.form.grdInstrctrInfo.updateToDataset();
		
		//강사체크여부확인
		if(!this.fnInsrCeckYn()){
			return;
		}
		
		// 전송 값 세팅
		this.fnSaveSetting('01');
		
		//(임시)해임 validation
		if(!this.fnDismCeck()){
			return;
		}
		
		// 서비스 객체 생성
		this.smfSaveService("saveInstrctrRlsofcCnTmpr")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			// 저장정보 초기화
			this.dsSave00.deleteRow(0);
			this.dsSave00.addRow();
			
			// 업로드 초기화
			this.divReq.form.divFileUpload.form.fnResetUpload();
			
			this.smfAlert('CM004', []);
			
			// 임시교습자/보조요원 조회
			this.InsrInq();
		});

	} else if(this.fv_empmnRlsofc == 0){
		// 채용 인 경우
		
		//증빙자료제출방식 온라인 선택 시 첨부파일 필수체크
		if(this.dsDetailInfo01.getColumn(0,"prufDocuSbmsnMetCd") == "2"){
			if(this.dsSave01.getColumn(0,"sfileRefrnId") == "" || this.dsSave01.getColumn(0,"sfileRefrnId") == undefined){
				this.smfAlert("증빙서류제출 방식이 온라인일 경우 증빙서류 첨부는 필수입니다.");
				return;
			}
		}
		
		//주민등록번호 체크여부 확인		
		if(this.rrnoCeckYn == "N"){
			alert("주민등록번호를 체크해주세요.");
			return ;
		}
		
		// 전송 값 세팅
		this.fnSaveSetting('01');
			
		// 서비스 객체 생성
		this.smfSaveService("saveEmpmnCnTmpr")
		// 데이터 검증
		.validateForm(this.divReq)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			// 저장정보 초기화
			this.dsSave01.deleteRow(0);
			this.dsSave01.addRow();
			
			// 업로드 초기화
			this.divReq.form.divFileUpload.form.fnResetUpload();
			
			this.smfAlert("저장 되었습니다.");
			
			// 임시저장목록 재조회
			this.fnTmprInfoSearch();
		});
	}
};

