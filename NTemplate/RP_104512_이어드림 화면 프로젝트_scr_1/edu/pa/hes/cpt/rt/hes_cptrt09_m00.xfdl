// 채용/해임 선택
this.rdoEmpmnRlsofc_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	this.fv_empmnRlsofc = obj.value;
	
	if(this.fv_empmnRlsofc == 0){		// 채용
		// 채용 관련
		this.divMain01.set_visible(true);
		this.divReq.set_visible(true);
		
		// 해임 관련
		this.divSearch.set_visible(false);
		this.divMain00.set_visible(false);
		this.divInfo.set_visible(false);
		
		// 버튼 영역
		this.divBtn.set_top(this.btnTop);	// 버튼영역 위치 이동
		
		this.divBtn.form.btnReq.set_text("채용신고서제출");
		
		// 서비스 객체 생성 (채용)
		this.smfValidateService("validateMain01", {
				url: "/hes_cpt_rt09_901.do",
		})
		.mappingRulesetToForm(this.divReq, "save01")
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
		});
		
		// 임시저장정보 재조회
		this.fnTmprInfoSearch();		
	}else if(this.fv_empmnRlsofc == 1){	// 해임
		// 채용 관련
		this.divMain01.set_visible(false);
		this.divReq.set_visible(false);
		
		// 해임 관련
		this.divSearch.set_visible(true);
		this.divMain00.set_visible(true);
		this.divInfo.set_visible(true);
		
		// 버튼 영역
		var divInfoTop = this.divInfo.top;
		var divInfoHeight = this.divInfo.height;
		var divBtnTop = divInfoTop * 1 + divInfoHeight * 1;

		this.divBtn.set_top(divBtnTop);	// 버튼영역 위치 이동
	
		this.divBtn.form.btnReq.set_text("해임통보서제출");
		
		// 서비스 객체 생성 (해임)
		/*this.smfValidateService("validateMain00", {
				url: "/hes_cpt_rt09_900.do",
		})
		.mappingRulesetToDataset(this.dsSave00, "save00")
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
		});*/
		
		// 임시교습자/보조요원 조회 재조회
		this.InsrInq();
	}
};

// 임시교습자/보조요원 선택(채용)
this.divMain01_rdoTmprLesrAtaSew_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	this.fv_tmprLesrAtaSewEmpmn = obj.value;
	
	if(this.fv_tmprLesrAtaSewEmpmn == 0){		// 임시교습자
		this.divMain01.form.grdTmprInfo.setCellProperty("head", 1, "text", "임시교습자명");
		this.divReq.form.imgBscInfoTit.set_text("임시교습자 기본정보");
	}else if(this.fv_tmprLesrAtaSewEmpmn == 1){	// 보조요원
		this.divMain01.form.grdTmprInfo.setCellProperty("head", 1, "text", "보조요원명");
		this.divReq.form.imgBscInfoTit.set_text("보조요원 기본정보");
	}
	
	// 임시저장정보 재조회
	this.fnTmprInfoSearch();	
};

// 임시교습자/보조요원 선택(해임)
this.divSearch_rdoTmprLesrAtaSew_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	this.fv_tmprLesrAtaSewRlsofc = obj.value;

	if(this.fv_tmprLesrAtaSewRlsofc == 0){		// 임시교습자
		this.divSearch.form.staInsrNm.set_text("임시교습자명");
		this.divMain00.form.grdInstrctrInfo.setCellProperty("head", 1, "text", "임시교습자명");
		this.divInfo.form.img00_00_00_00.set_text("임시교습자 기본정보");
	}else if(this.fv_tmprLesrAtaSewRlsofc == 1){// 보조요원
		this.divSearch.form.staInsrNm.set_text("보조요원명");
		this.divMain00.form.grdInstrctrInfo.setCellProperty("head", 1, "text", "보조요원명");
		this.divInfo.form.img00_00_00_00.set_text("보조요원 기본정보"); 
	}

	// 임시교습자/보조요원 조회 재조회
	this.InsrInq();
};

this.divReq_btnInvlRrnoChk_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsRrnoCeck.clearData();
	var rrno = this.dsDetailInfo01.getColumn(0,"invlRrno");
	if(rrno  == ""||rrno == null){
		alert("주민등록번호를 입력해주세요.");
		return;
	}
	
	this.dsSearch04.setColumn(0,"acaDsgnNo",this.dsInstutInfo.getColumn(this.dsInstutInfo.rowposition,"acaDsgnNo"));
	this.dsSearch04.setColumn(0,"invlRrno",this.dsDetailInfo01.getColumn(0,"invlRrno"));
	this.dsSearch04.setColumn(0,"insrScCd",this.dsSearch02.getColumn(0,"insrScCd"));
	this.dsSearch04.setColumn(0,"acaInstScCd","2");
	this.dsSearch04.setColumn(0,"atptOfcdcOrgCode",this.hesGetAtptOfcdcOrgCode);
	
	this.smfSearchService("listRrnoCeck")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		//주민등록번호 체크 결과
		var tmprCnt = this.dsRrnoCeck.getColumn(0,"tmprCnt");
		var empmnCnt = this.dsRrnoCeck.getColumn(0,"empmnCnt");
		
		if(empmnCnt > 0){ //채용 강사 수
			alert("이미 채용되었습니다.");
			return;
		}else if(tmprCnt > 0){ //임시저장된 강사 수
			var txt = "임시교습자";
			var insrScCd = this.dsSearch02.getColumn(0, "insrScCd");
			
			if(insrScCd == "1"){
				txt = "보조요원";
			}
			alert("임시저장된 "+txt+"입니다.");
			return;
		}else{
			alert("채용가능합니다.");
			this.rrnoCeckYn = "Y";
			return;
		}			
	});
};

this.divReq_mskInvlRrno_onchanged = function(obj:nexacro.MaskEdit,e:nexacro.ChangeEventInfo)
{
	//주민등록번호 수정하는 경우 체크여부 N
	this.rrnoCeckYn = "N";
};

this.divReq_btnZipSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: this.fnCommpopRdnZip, // 콜백함수 지정
		sender: obj, // sender 지정

		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: 'search',
		},
	};

	// 모달팝업 실행
	this.smfDialog("_auto", "commpop::commpop_rdn_zip.xfdl", popupParams);
};

