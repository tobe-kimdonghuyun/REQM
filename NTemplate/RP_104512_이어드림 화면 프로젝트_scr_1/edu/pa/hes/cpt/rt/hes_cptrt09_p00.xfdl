          <Column id="dmclZip" type="STRING" size="256" sumtext="거주지우편번호"/>
          <Column id="insrScCd" type="STRING" size="256" sumtext="강사구분코드"/>
          <Column id="insrQlfScCd" type="STRING" size="256" sumtext="강사자격구분코드"/>
          <Column id="lctnAddr" type="STRING" size="256" sumtext="소재지주소"/>
          <Column id="frgnrInsrStayQlfCd" type="STRING" size="256" sumtext="외국인강사체류자격코드"/>
