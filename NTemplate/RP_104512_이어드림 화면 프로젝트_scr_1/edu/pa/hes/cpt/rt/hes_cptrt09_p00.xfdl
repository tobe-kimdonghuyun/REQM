          <Column id="rplyYmd" type="STRING" size="256" sumtext="회신일자"/>
          <Column id="plcsNm" type="STRING" size="256" sumtext="경찰서명"/>
          <Column id="empmnYmd" type="STRING" size="256" sumtext="채용일자"/>
          <Column id="aprvTmprNo" type="STRING" size="256" sumtext="승인임시번호"/>
          <Column id="onlCvlcptPrcsStsCd" type="STRING" size="256" sumtext="온라인민원처리상태코드"/>
          <Column id="acaDsgnNo" type="STRING" size="256" sumtext="학원지정번호"/>
          <Column id="cteOfcdcCd" type="STRING" size="256" sumtext="관할교육청코드"/>
