          <Column id="rmkMteCn" type="STRING" size="256" sumtext="비고사항내용"/>
          <Column id="lctnRoadNmAddr" type="STRING" size="256" sumtext="소재지도로명주소"/>
          <Column id="lctnRoadNmDtlAddr" type="STRING" size="256" sumtext="소재지도로명상세주소"/>
          <Column id="dmclRoadNmZip" type="STRING" size="256" sumtext="거주지도로명우편번호"/>
          <Column id="uvstMjrNm" type="STRING" size="256" sumtext="대학전공명"/>
          <Column id="emlAddr" type="STRING" size="256" sumtext="이메일주소"/>
          <Column id="etcRmkCn" type="STRING" size="256" sumtext="기타비고내용"/>
          <Column id="onlCvlcptAprvCd" type="STRING" size="256" sumtext="온라인민원승인코드"/>
          <Column id="empmnNtfctnYmd" type="STRING" size="256" sumtext="채용통보일자"/>
          <Column id="dstrtOfcdcCd" type="STRING" size="256" sumtext="지역교육청코드"/>
          <Column id="rjctYmd" type="STRING" size="256" sumtext="반려일자"/>
          <Column id="rjctRsnCn" type="STRING" size="256" sumtext="반려사유"/>
          <Column id="chlIltrtYn" type="STRING" size="256" sumtext="아동학대여부"/>
          <Column id="prufDocuSbmsnMetCd" type="STRING" size="256" sumtext="증빙서류제출방식코드"/>
          <Column id="dismRsnCn" type="STRING" size="256" sumtext="해임사유내용"/>
          <Column id="onlCvlcptRtrcnRsnCn" type="STRING" size="256" sumtext="온라인민원취소사유내용"/>
