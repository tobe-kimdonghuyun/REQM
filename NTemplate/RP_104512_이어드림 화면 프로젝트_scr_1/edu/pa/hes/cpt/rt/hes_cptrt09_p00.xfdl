          <Column id="chlIltrtYnNm" type="STRING" size="256"/>
          <Column id="prufDocuSbmsnMetCdNm" type="STRING" size="256"/>
          <Column id="insrSecmeInqYnNm" type="STRING" size="256"/>
          <Column id="invlBrdt" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsSave00">
        <ColumnInfo>
          <Column id="tmprInvlDsgnNo" type="STRING" size="256" sumtext="임시개인지정번호"/>
          <Column id="dismYmd" type="STRING" size="256" sumtext="해임일자"/>
          <Column id="dismRsnCn" type="STRING" size="256" sumtext="해임사유"/>
          <Column id="acaNm" type="STRING" size="256" sumtext="학원명"/>
          <Column id="invlDsgnNo" type="STRING" size="256" sumtext="개인지정번호"/>
          <Column id="cteOfcdcCd" type="STRING" size="256" sumtext="관할교육청코드"/>
          <Column id="dstrtOfcdcCd" type="STRING" size="256" sumtext="지역교육청코드"/>
          <Column id="tmprStrgYn" type="STRING" size="256" sumtext="임시저장여부"/>
          <Column id="empmnNtfctnYmd" type="STRING" size="256" sumtext="채용통보일자"/>
          <Column id="acaDsgnNo" type="STRING" size="256" sumtext="학원지정번호"/>
          <Column id="onlCvlcptPrcsStsCd" type="STRING" size="256"/>
          <Column id="onlCvlcptAprvCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsSave01">
        <ColumnInfo>
