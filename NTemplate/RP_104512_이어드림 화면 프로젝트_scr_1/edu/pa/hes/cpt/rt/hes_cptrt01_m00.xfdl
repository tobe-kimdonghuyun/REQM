	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		// 저장정보 초기화
		this.dsSave.deleteRow(0);
		this.dsSave.addRow();
		
		this.smfAlert('CM002', []);
		
		// 임시저장목록 재조회
		this.listInstutChangeCnTmpr();
	});
};

// 교습소변경등록 신고(제출)
this.btnReq_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//교습소명 변경 시 중복체크 확인
	if(this.acaNmDpcnCeck == "N"){
		alert("변경 후 교습소명을 중복체크해주세요.");
		return;
	}
	
	//증빙자료제출방식 온라인 선택 시 첨부파일 필수체크
	if(this.dsTmprInfo.getColumn(0,"prufDocuSbmsnMetCd") == "2"){
		if(this.dsSave.getColumn(0,"sfileRefrnId") == "" || this.dsSave.getColumn(0,"sfileRefrnId") == undefined){
			this.smfAlert("증빙서류제출 방식이 온라인일 경우 증빙서류 첨부는 필수입니다.");
			return;
		}
	}
	
	// 전송 값 세팅
	this.fnSaveSetting('02');
	
	// 서비스 객체 생성
	this.smfSaveService("saveInstutChangeNtcdoc")
	// 데이터 검증
	//.validateForm(this.divReg)
	// 실행
	.run()
	// 콜백
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		// 저장정보 초기화
		this.dsSave.deleteRow(0);
		this.dsSave.addRow();
		
		// 업로드 초기화
		this.divAplyCn.form.divFileUpload.form.fnResetUpload();
		
		if(this.dsMessage.rowcount != 0){
			alert(this.dsMessage.getColumn(0, "message"));
		}else{
			this.smfAlert('CM002', []);
		}
		
		// 임시저장목록 재조회
		this.listInstutChangeCnTmpr();
	});
};

// 임시저장정보 리스트 선택
this.grdTmprInfo_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	// 그리드 체크박스(라디오버튼)
	this.fnGridRadioCheck(this.divMain.form.grdTmprInfo, this.dsTmprInfoList);
	
	this.dsTmprInfo.copyRow(0, this.dsTmprInfoList, this.dsTmprInfoList.rowposition);
	
	// 신청정보 세팅
	this.aplyInfoSetting();
	
	// 업로드 초기화
	this.divAplyCn.form.divFileUpload.form.fnResetUpload();
	
	//파일참조ID가 있는 경우 파일정보조회
	if(this.dsTmprInfo.getColumn(0,"fileRefrnId") != ""){
		this.transaction(
			 "fn_filesearch" // serviceId
			,"baseUrl::/cm_cmc_file_upload_001.do" // url
			,"" // inDataset
			,"dsOutFileinfo=atchFileinfo" // outDataset
			,"fileRefrnId='"+this.dsTmprInfo.getColumn(0,"fileRefrnId")+"'"
			,""
			,false // true: 비동기, false:동기
	   );
	    
		var responseCustomValue = "";
		var sDownloadUrl       = ""; 
		var sHandlerCode       = "PA.SAM.PLE";
		var sFileSn            = this.dsOutFileinfo.getColumn(0,"fileRefrnId"   );
		var sFileSeq           = this.dsOutFileinfo.getColumn(0,"fileId"        );
		var sFileSize          = this.dsOutFileinfo.getColumn(0,"atchFileMg"    );
		var sBackendFilename   = this.dsOutFileinfo.getColumn(0,"atchFileGuid"  );
		var sForntendFilename  = this.dsOutFileinfo.getColumn(0,"atchFileNm"    );
		var sFileEncryptYn     = this.dsOutFileinfo.getColumn(0,"fileEncryptYn" );
		var sPrivInfoFiltYn    = this.dsOutFileinfo.getColumn(0,"privInfoFiltYn");
		var sFileSaveStg       = this.dsOutFileinfo.getColumn(0,"fileSaveStg"   );
		var sFileInfSaveYn     = this.dsOutFileinfo.getColumn(0,"fileInfSaveYn" );
		
		this.divAplyCn.form.divFileUpload.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sForntendFilename, sFileSeq, sDownloadUrl
												  ,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn );
		
		this.dsSave.setColumn(0, "sfileRefrnId", sFileSn);
	}
};

this.divAplyCn_btn00_00_01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//교습소명 중복체크
	this.dsSearch03.setColumn(0,"acaNm",this.dsTmprInfo.getColumn(0,"afchNm"));
	this.dsSearch03.setColumn(0, "atptOfcdcOrgCode", this.hesGetAtptOfcdcOrgCode);
	this.dsSearch03.setColumn(0, "cteOfcdcCd", this.hesGetAtptOfcdcOrgCode);
	this.dsSearch03.setColumn(0, "acaInstiScCd", this.hesGetAcaInstiScCd);
	
	this.smfSearchService("listAcaNmDpcnCeck")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		this.acaNmDpcnCeck = "Y";
		alert("등록 가능한 교습소명 입니다.");
	});
};

this.divAplyCn_edtAfchNm_onchanged = function(obj:nexacro.Edit,e:nexacro.ChangeEventInfo)
{
	if(e.postvalue == ""){
		this.acaNmDpcnCeck = "Y";
	}else{
		this.acaNmDpcnCeck = "N";
	}	
};


this.fnEventAfterAddFile = function(obj,paramObj,sCustomValue,sFileName,nFileSize)
{
	trace("=== Sample : fnEventAfterAddFile");
	this.divAplyCn.form.divFileUpload.form.fnFileUpload();
}
this.fnEventUploadComplete = function(obj,paramObj,objResultDataset)
{
	// 신규서비스
	trace("=== Sample : fnEventUploadComplete");	
	this.divAplyCn.form.divFileUpload.form.fnSetUploadCompleteState(obj,paramObj);
	if(objResultDataset){
		trace("====업로드한 결과 데이터셋 ========== : "+objResultDataset.saveXML());
		this.dsSave.setColumn(0, "sfileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
		var sFileRefrnId = objResultDataset.getColumn(0,"fileRefrnId");
		trace("sFileRefrnId : "+this.dsSave.getColumn(0,"sfileRefrnId"));
	}

}
this.fnEventUploadError = function(obj,paramObj)
{
	trace("파일 업로드에 실패 하였습니다.");		
}


//파일삭제
this.divAplyCn_btnFleDel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divFileUpload.form.fnResetUpload();
	this.dsSave.setColumn(0, "sfileRefrnId", "");
};

//파일다운로드
this.divAplyCn_btnFleDwld_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divFileUpload.form.fnFileDownload();
};]]></Script>
