	this.dsInstutInfo.copyRow(0, this.dsInstutInfoList, this.dsInstutInfoList.rowposition);
	
	// 신청인 정보, 임시정보 조회
	this.dsMain01.clearData();
	
	this.initClaiInfoTelno();
	this.initAplyCnTelno();
	
	// 조회 조건 세팅
	this.dsSearch01.copyRow(0, this.dsInstutInfo, this.dsInstutInfo.rowposition);
	
	// 신청인 정보 조회 -> 학원교습소 정보 조회 시 같이 가져올 수 있음
	// 신청인 정보 조회 후 임시정보 조회
	this.listClaiInfo();	
};
*/
// 임시저장
this.btnTemp_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//교습소명 변경 시 중복체크 확인
	if(this.acaNmDpcnCeck == "N"){
		alert("변경 후 교습소명을 중복체크해주세요.");
		return;
	}
	
	//증빙자료제출방식 온라인 선택 시 첨부파일 필수체크
	if(this.dsTmprInfo.getColumn(0,"prufDocuSbmsnMetCd") == "2"){
		if(this.dsSave.getColumn(0,"sfileRefrnId") == "" || this.dsSave.getColumn(0,"sfileRefrnId") == undefined){
			this.smfAlert("증빙서류제출 방식이 온라인일 경우 증빙서류 첨부는 필수입니다.");
			return;
		}
	}
	
	// 전송 값 세팅
	this.fnSaveSetting('01');
	
	// 서비스 객체 생성
	this.smfSaveService("saveInstutChangeCnTmpr")
	// 데이터 검증
	//.validateForm(this.divReg)
	// 실행
	.run()
	// 콜백
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		// 저장정보 초기화
		this.dsSave.deleteRow(0);
		this.dsSave.addRow();
		
		// 업로드 초기화
		this.divAplyCn.form.divFileUpload.form.fnResetUpload();
		
		this.smfAlert('CM002', []);
		
		// 임시저장목록 재조회
		this.listInstutChangeCnTmpr();
	});
};

// 임시내역수정
this.btnModify_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//교습소명 변경 시 중복체크 확인
	if(this.acaNmDpcnCeck == "N"){
		alert("변경 후 교습소명을 중복체크해주세요.");
		return;
	}
	
	// 전송 값 세팅
	this.fnSaveSetting('01');
	
	// 서비스 객체 생성
	this.smfSaveService("updateInstutChangeCnTmpr")
	// 데이터 검증
	//.validateForm(this.divReg)
	// 실행
	.run()
	// 콜백
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		// 저장정보 초기화
		this.dsSave.deleteRow(0);
		this.dsSave.addRow();
		
		this.smfAlert('CM002', []);
		
		// 임시저장목록 재조회
		this.listInstutChangeCnTmpr();
	});
};

// 임시내역 삭제
this.btnDel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 전송 값 세팅
	this.fnSaveSetting('01');

