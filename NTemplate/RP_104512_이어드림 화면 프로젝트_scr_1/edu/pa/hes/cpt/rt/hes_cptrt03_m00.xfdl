    <Script type="xscript5.1"><![CDATA[/**
*  대국민 - 교습소배상책임보험가입
*  @MenuPath    TEMPLATE
*  @FileName 	hes_cptrt03_m00.xfdl
*  @Creator 	김명주
*  @CreateDate 	2022.11.24
*  @Desction    교습소배상책임보험가입
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.11.24     	김명주 	        최초 생성 
*******************************************************************************
*/
include "lib::cm_script.xjs"
include "lib::hes_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
  //화면 접근 시 로그인정보 확인
this.fnOninit = function(obj:nexacro.Form,e:nexacro.EventInfo)
{
	if(this.hesChkLogin("2","pa_hes_cpt_rt::hes_cptrt03_m00.xfdl")){
		this.hesSetGoUrl("pa_hes_cpt_rt::hes_cptrt03_m00.xfdl");
		this.fnOnload(this);
	}
};
// 폼 초기화 이벤트
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{	
	// 업로드 초기설정
	this.divReg.form.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;        // 필요한 경우만 세팅(세팅권장)
	this.divReg.form.divFileUpload.UPLOAD_OnError        = this.fnEventUploadError;           // 필요한 경우만 세팅(세팅권장)
	this.divReg.form.divFileUpload.UPLOAD_AfterAddFile   = this.fnEventAfterAddFile;          // 필요한 경우만 세팅(세팅권장)
	this.divReg.form.divFileUpload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)

	// 폼 초기화
	this.smfInitForm(obj);
	
	// 교습소 정보 조회
	this.listInstutInfo();
	
	// 서비스 객체 생성 
	this.smfValidateService("validateMain", {
			url: "/hes_cpt_rt03_900.do",
	})
	.mappingRulesetToForm(this.divReg, "save")
	//.mappingRulesetToDataset(this.dsMainValid, "save")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		// 공통코드 호출
		this.smfCodeList("code", [this.dsInrJoinInstKndCd])
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			// 교습소 정보 조회
			this.listInstutInfo();
			
			// 보험가입기관 종류 콤보박스 세팅
			this.cboInrJoinInstKndCdItemChange("00");
		});	
	});
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
// 교습소정보 조회 함수
this.listInstutInfo = function ()
{	
	this.dsSearch01.setColumn(0, "acaDsgnNo", this.hesGetAcaDsgnNo);	
	this.dsSearch01.setColumn(0, "acaInstiScCd", this.hesGetAcaInstiScCd);
	this.dsSearch01.setColumn(0, "atptOfcdcOrgCode", this.hesGetAtptOfcdcOrgCode);
	this.dsSearch00.setColumn(0, "acaDsgnNo", this.hesGetAcaDsgnNo);	
	this.dsSearch00.setColumn(0, "acaInstiScCd", this.hesGetAcaInstiScCd);
	this.dsSearch00.setColumn(0, "atptOfcdcOrgCode", this.hesGetAtptOfcdcOrgCode);

	// 교습소정보 조회
	this.smfSearchService("listInstutInfo")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors){
			var objFrame = this.getOwnerFrame();
			objFrame.form.fnSetMainpage(objFrame.form.fv_mainformUrl);	
		}
		
		// 데이터셋 복사하기
		//this.dsInstutInfoList.copyData(this.dsMain00);
		this.dsInstutInfo.copyData(this.dsMain00);
		
		// 임시저장목록 조회
		this.listRepratnRspnsblInsrncTmpr();
	});
};

// 임시정보 조회 함수
this.listRepratnRspnsblInsrncTmpr = function ()
{
	// 파라미터 세팅(학원지정번호, 지역교육청코드, 학원교습소구분코드)
	this.dsSearch01.copyRow(0, this.dsInstutInfo, this.dsInstutInfo.rowposition);
	this.dsSearch01.setColumn(0, "dstrtOfcdcCd", this.dsInstutInfo.getColumn(0, "cteOfcdcCd"));
	
	// 임시교습소정보 조회
	this.dsMain01.clearData();
	
	this.dsTmprInfoList.clearData();
	
	this.dsTmprInfo.deleteRow(0);
	this.dsTmprInfo.addRow();
	
	this.smfSearchService("listRepratnRspnsblInsrncTmpr")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		if(this.dsMain01.getColumn(0, "imsiScCode") == "30"){//제출정보가 있는 경우
			this.smfAlert("현재 진행중인 민원이 있습니다.\n해당 민원처리가 종료된 이후 민원을 진행하실 수 있습니다.\n[확인]버튼을 누르시면 민원신고내역조회 페이지로 이동합니다.",this.hesGoCvlcptDclrList);
			return;
		}else if( this.dsMain01.getColumn(0, "imsiScCode") == "10"){// 데이터셋 복사하기
			// 임시저장 정보 있으면 리스트에 넣고
			this.dsTmprInfoList.copyData(this.dsMain01);
		}else{
			// 아니면 데이터 바로 출력
			this.dsTmprInfo.copyRow(0, this.dsMain01, this.dsMain01.rowposition);
			
			//임시저장정보 없는 경우 증빙서류제출방식 기본값 온라인 사용
			this.dsTmprInfo.setColumn(0, "prufDocuSbmsnMetCd","2");
			
			// 보험가입기관 종류 콤보박스 세팅
			this.cboInrJoinInstKndCdItemChange(this.dsTmprInfo.getColumn(0, "inrJoinInstKndCd"));
		}
		
		this.fnSetFileDiv();
	});
};

// 전송 값 세팅
this.fnSaveSetting = function(gbn) {
	// 교습소정보 내용 복사
	this.dsSave.copyRow(0, this.dsInstutInfo, this.dsInstutInfo.rowposition);
	// 입력된 보험내용 복사
	this.dsSave.copyRow(0, this.dsTmprInfo, this.dsTmprInfo.rowposition);
	
	// 관할교육청코드, 지역교육청코드 세팅
	var cteOfcdcCd = this.dsSave.getColumn(0, "cteOfcdcCd");
	this.dsSave.setColumn(0, "dstrtOfcdcCd", cteOfcdcCd);
		
	cteOfcdcCd = cteOfcdcCd.substring(0, 3) + "0000001";
	this.dsSave.setColumn(0, "cteOfcdcCd", cteOfcdcCd);	
	
	// 보험등록일자 세팅
	var result = this.smfToday();
	//alert("today : " + result);
	this.dsSave.setColumn(0, "inrRegYmd", result);
	
	// null 값 0 세팅
	var psnbyRewLmtAmt = this.dsSave.getColumn(0, "psnbyRewLmtAmt");
	var acdntRewLmtAmt = this.dsSave.getColumn(0, "acdntRewLmtAmt");
	var psnbyMdlcAcexpAmt = this.dsSave.getColumn(0, "psnbyMdlcAcexpAmt");
	
	this.dsSave.setColumn(0, "psnbyRewLmtAmt", this.nvl(psnbyRewLmtAmt, "0"));
	this.dsSave.setColumn(0, "acdntRewLmtAmt", this.nvl(acdntRewLmtAmt, "0"));
	this.dsSave.setColumn(0, "psnbyMdlcAcexpAmt", this.nvl(psnbyMdlcAcexpAmt, "0"));
	
	// 온라인민원승인코드 세팅(확인 필요함... 쿼리 수정, 평생교육과 같이 사용)
	this.dsSave.setColumn(0, "onlCvlcptAprvCd", "0");
	
	// 임시저장, 수정 시 처리상태코드 세팅
	if (gbn == "01") {
		this.dsSave.setColumn(0, "onlCvlcptPrcsStsCd", "01");
		//alert("임시저장, 수정");
	} else if (gbn == "02") {	//등록인경우
		this.dsSave.setColumn(0, "onlCvlcptPrcsStsCd", "02");
		//alert("등록");
	}
};

// 시작일 종료일 체크
this.fnendDateCheck = function(){
	var strInrBgngYmd = this.divReg.form.calInrBgngYmd.value;	// 보험시작일
	var strInrEndYmd  = this.divReg.form.calInrEndYmd.value;	// 보험종료일

	if (strInrBgngYmd) {
		if (strInrBgngYmd > strInrEndYmd) {
			this.smfAlert("보험시작일보다 보험종료일이 과거일 수 없습니다.");
			this.divReg.form.calInrEndYmd.set_value("");
			return false;
		} 
	}
	return true;
};

// 선택한 셀만 체크박스 체크(라디오 버튼 효과)
this.fnGridRadioCheck = function(grid, dataset){
	var row = dataset.rowposition;

	for (var i = 0; i < grid.rowcount; i++) {
		// 체크박스 컬럼 생성
		dataset.addColumn("_chk", "string");
		
		if( i == row){ //선택한 셀 체크박스 체크
			dataset.setColumn(row, "_chk", 1);
		}else{
			dataset.setColumn(i, "_chk", 0);
		}
    }
};

// 보험가입기관 종류 콤보박스 선택
this.cboInrJoinInstKndCdItemChange = function(inrJoinInstKndCd){
	if(inrJoinInstKndCd == "03"){
		// 보험가입기관 종류가 기타 인 경우
		//this.divReg.form.staInrJoinKndEtcNm00.set_visible(true);
		//this.divReg.form.staInrJoinKndEtcNm01.set_visible(true);
		this.divReg.form.sta45_00_00.set_visible(true);
		this.divReg.form.edtInrJoinKndEtcNm.set_visible(true);
		
		//this.divReg.form.staInrJoinInstKndCd.set_width(416);
	}else{
		// 아닌 경우
		//this.divReg.form.staInrJoinKndEtcNm00.set_visible(false);
		//this.divReg.form.staInrJoinKndEtcNm01.set_visible(false);
		this.divReg.form.sta45_00_00.set_visible(false);
		this.divReg.form.edtInrJoinKndEtcNm.set_visible(false);
		
		//this.divReg.form.staInrJoinInstKndCd.set_right(0);
	}
};

//증빙서류제출방식 온라인일때만 파일첨부 활성화
this.fnSetFileDiv = function(){
	if(this.divReg.form.rdoPrufDocuSbmsnMetCd.value == "2"){
		this.divReg.form.divFileUpload.set_enable(true);
	}else{
		this.divReg.form.divFileUpload.set_enable(false);
	}
}
