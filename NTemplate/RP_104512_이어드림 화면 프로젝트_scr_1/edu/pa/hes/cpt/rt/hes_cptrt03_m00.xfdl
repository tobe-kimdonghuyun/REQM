		// 임시저장목록 재조회
		this.listRepratnRspnsblInsrncTmpr();
	});
};

// 가입일자
this.divReg_calInrJoinYmd_onchanged = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{
	var strInrBgngYmd = this.divReg.form.calInrBgngYmd.value;	// 보험시작일
	var strInrEndYmd  = this.divReg.form.calInrEndYmd.value;	// 보험종료일
	var strInrJoinYmd = this.divReg.form.calInrJoinYmd.value;	// 가입일

	//alert(strInrBgngYmd + ", " + strInrEndYmd + ", " + strInrJoinYmd);

	if (strInrBgngYmd) {
		if (strInrBgngYmd < strInrJoinYmd) {
			this.smfAlert("보험가입일은 보험시작일보다 이전이어야 합니다.");
			this.divReg.form.calInrJoinYmd.set_value("");
			return;
		}
	}
	if (strInrEndYmd) {
		if (strInrEndYmd < strInrJoinYmd) {
			this.smfAlert("보험가입일은 보험종료일보다 이전이야 합니다.");
			this.divReg.form.calInrJoinYmd.set_value("");
			return;
		}
	}
};

// 보험종료일
this.divReg_calInrEndYmd_onchanged = function(obj:nexacro.Calendar,e:nexacro.ChangeEventInfo)
{
	var strInrBgngYmd = this.divReg.form.calInrBgngYmd.value;	// 보험시작일
	var strInrEndYmd  = this.divReg.form.calInrEndYmd.value;	// 보험종료일
	var strInrJoinYmd = this.divReg.form.calInrJoinYmd.value;	// 가입일

	if (strInrJoinYmd) {
		if (strInrJoinYmd > strInrEndYmd) {
			this.smfAlert("보험종료일은 보험가입일보다 나중이어야 합니다.");
			this.divReg.form.calInrEndYmd.set_value("");
			return;
		}
	}
	if (strInrBgngYmd) {
		if (strInrBgngYmd > strInrEndYmd) {
			this.smfAlert("보험종료일은 보험시작일보다 나중이어야 합니다.");
			this.divReg.form.calInrEndYmd.set_value("");
			return;
		}
	}
};

