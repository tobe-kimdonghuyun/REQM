<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmMain" width="500" height="326" titletext="설립자강사정보" onload="frmMain_onload">
    <Layouts>
      <Layout height="326" width="500" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Grid id="grdMain" taborder="1" left="20" top="20" height="226" right="20" autofittype="col" selecttype="cell" initvalueid="ivGrdAccessibilityOn" binddataset="dsList">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="344"/>
                <Column size="344"/>
              </Columns>
              <Rows>
                <Row size="31" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="구분"/>
                <Cell col="1" text="성명" cssclass="LineNo"/>
              </Band>
              <Band id="body">
                <Cell displaytype="normal" edittype="none" textAlign="center" text="bind:insrScCdNm"/>
                <Cell col="1" displaytype="normal" edittype="none" cssclass="LineNo" textAlign="center" text="bind:kornFlnm"/>
              </Band>
            </Format>
            <Format id="default_00">
              <Columns>
                <Column size="344"/>
                <Column size="344"/>
              </Columns>
              <Rows>
                <Row size="50" band="head"/>
                <Row size="70"/>
              </Rows>
              <Band id="head">
                <Cell text="구분"/>
                <Cell col="1" text="성명" cssclass="LineNo"/>
              </Band>
              <Band id="body">
                <Cell displaytype="normal" edittype="date" textAlign="center" text="bind:insrScCdNm"/>
                <Cell col="1" displaytype="normal" edittype="date" cssclass="LineNo" textAlign="center" text="bind:kornFlnm"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="btnCancel" taborder="2" text="취소" height="40" width="68" left="45.00%" fittocontents="width" initvalueid="ivBtnAccessibilityButton" top="266" onclick="btnCancel_onclick"/>
        <Static id="staGD00" taborder="3" left="20" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGD00_00" taborder="4" left="20" top="246" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGD01" taborder="5" left="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" height="20" initvalueid="ivStcAccessibilityOff" top="306"/>
        <Static id="staGD02" taborder="6" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGD03" taborder="7" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
      <Layout height="326" width="600" screenid="mobile,tablet" name="default0">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Grid id="grdMain" taborder="1" left="20" top="20" height="226" right="20" autofittype="col" selecttype="cell" initvalueid="ivGrdAccessibilityOn" binddataset="dsList" formatid="default_00"/>
        <Button id="btnCancel" taborder="2" text="취소" height="40" width="75" left="45.00%" fittocontents="width" initvalueid="ivBtnAccessibilityButton" top="266"/>
        <Static id="staGD00" taborder="3" left="20" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGD00_00" taborder="4" left="20" top="246" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGD01" taborder="5" left="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" height="20" initvalueid="ivStcAccessibilityOff" top="306"/>
        <Static id="staGD02" taborder="6" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staGD03" taborder="7" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="0" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsList" useclientlayout="true">
        <ColumnInfo>
          <Column id="insrScCdNm" type="STRING" size="256"/>
          <Column id="kornFlnm" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsList=dsList</Col>
            <Col id="asynctp"/>
            <Col id="url">hes_ics_sl00_004.do</Col>
            <Col id="id">listInsrInfo</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="cteOfcdcCd" type="STRING" size="256"/>
          <Column id="acaDsgnNo" type="STRING" size="256"/>
          <Column id="acaInstiScCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="cteOfcdcCd"/>
            <Col id="acaDsgnNo"/>
            <Col id="acaInstiScCd"/>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  온라인통합채용-계약제교원인력풀-학력정보 팝업
*  @MenuPath    pa_hrd_oew_ap
*  @FileName 	pa_hrd_oewap02_p00.xfdl
*  @Creator 	
*  @CreateDate 	2022.8.30
*  @Desction    온라인통합채용-계약제교원인력풀-학력정보 팝업
************** 소스 수정 이력 ***********************************************
*  date                Modifier            Description
*******************************************************************************
*  2022.8.30    	 	최지원             최초 생성 
********************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

this.frmMain_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

	// default 초기처리를 한다.
	this.smfInitPopup(obj);

	// 파라메터 셋
	this.pv_params = this.smfGetPopupParams();
	
	this.dsSearch.setColumn(0,"cteOfcdcCd",this.pv_params.cteOfcdcCd);
	this.dsSearch.setColumn(0,"acaDsgnNo",this.pv_params.acaDsgnNo);
	this.dsSearch.setColumn(0,"acaInstiScCd",this.pv_params.acaInstiScCd);
	
	// 팝업 타이틀 변경
	this.smfUpdatePopupTitle("설립자강사정보");	
	
	//설립자강사정보조회
	this.smfSearchService("listInsrInfo")
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

 /************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 
 /************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/


/**
 * 취소버튼 클릭
 */
this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};
]]></Script>
  </Form>
</FDL>
