              <ImageViewer id="imgTitle" taborder="0" text="자주묻는 질문" left="20" top="0" height="65" cssclass="img_WF_SubTit01" width="290" initvalueid="ivTitleAccessibilityOn"/>
            </Layout>
          </Layouts>
        </Div>
        <Edit id="edtSearchKeyword" taborder="1" left="0" top="154" width="570" height="40" displaynulltext="궁금하신 내용을 입력해 주세요." cssclass="edi_WF_FAQ" initvalueid="ivEdtNormal"/>
        <Button id="btnSearch" taborder="2" top="154" width="50" height="40" cssclass="btn_WF_FAQSearch" initvalueid="ivBtnAccessibilityButton" left="521" onclick="btnSearch_onclick" accessibilitylabel="검색하기"/>
        <Div id="div02" taborder="3" text="0" left="581" top="159" height="30" width="620" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Div id="divTotal" taborder="1" top="5" width="65" height="30" url="comm::comp_pageSummary2.xfdl" initvalueid="ivDivAccessibilityOff" right="0" visible="false">
                <Layouts>
                  <Layout/>
                  <Layout name="default0"/>
                </Layouts>
              </Div>
            </Layout>
            <Layout name="default0">
              <Div id="divTotal" taborder="1" top="5" width="200" height="40" url="comm::comp_pageSummary2.xfdl" initvalueid="ivDivAccessibilityOff" visible="false" left="0"/>
