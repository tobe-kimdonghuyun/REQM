          <Column id="regDt" type="DATETIME" size="256"/>
          <Column id="mdfrId" type="STRING" size="256"/>
          <Column id="mdfcnDt" type="DATETIME" size="256"/>
        </ColumnInfo>
        <Rows/>
      </Dataset>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">select</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsPageInfo=dsPageInfo</Col>
            <Col id="outDatasets">dsList=dsList dsPageInfo=dsPageInfo</Col>
            <Col id="url">/hes_len_nt00_001.do</Col>
            <Col id="asynctp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsPageInfo" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="initPageIndex" type="INT" size="30" value="1"/>
          <ConstColumn id="initPageSize" type="INT" size="30" value="10"/>
          <Column id="pageIndex" type="INT" size="256"/>
          <Column id="pageSize" type="INT" size="256"/>
          <Column id="totalCount" type="INT" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="pageIndex"/>
            <Col id="pageSize"/>
            <Col id="totalCount"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="searchType" type="STRING" size="256"/>
          <Column id="searchKeyword" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="ntcMteClfCd" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*   대국민 학원관련민원 - 공지사항 목록조회
*  @MenuPath    pa_hes_len_nt
*  @FileName 	hes_lennt00_m00.xfdl
*  @Creator 	박가혜
*  @CreateDate 	2022.12.29
*  @Desction    공지사항 목록조회
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.12.29    	이재열 	        최초 생성 
*******************************************************************************
*/

include "lib::cm_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.sqa_noibi_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	this.hesSetGoUrl("pa_hes_len_fo::hes_lenfo00_m00.xfdl");
	
	this.dsSearch.addRow();
	
	// 파라메터 세팅
	this.pv_params = this.smfGetFormParams();

	if(!this.smfIsNull(this.pv_params.dsSearchParam)){
		this.dsSearch.loadXML(this.pv_params.dsSearchParam);
		this.divSearch.form.cboSearch.set_value(this.dsSearch.getColumn(0,"searchType"));
	}
	
	if(!this.smfIsNull(this.pv_params.dsPagingParam)){
		this.dsPageInfo.loadXML(this.pv_params.dsPagingParam);
		if(this.dsPageInfo.getConstColIndex("initIsUsePageInfo") < 0){
			this.dsPageInfo.addConstColumn("initIsUsePageInfo","Y");
		} else {
			this.dsPageInfo.setConstColumn("initIsUsePageInfo","Y");
		}
	}

	//  페이지를 조회한다.
	this.divSearch.form.btnSearch.click();
	
	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.fnSearch = function(obj, e)
{
	this.dsSearch.setColumn(0,"searchType" , this.divSearch.form.cboSearch.value);
	this.dsSearch.setColumn(0,"searchKeyword" , this.divSearch.form.edtSearchKeyword.value);
	this.dsSearch.setColumn(0,"cddcCd" ,  this.smfGetCddcCode()); //접속시도 가져오기
	this.dsSearch.setColumn(0,"ntcMteClfCd" , '41'); 	//공지사항분류코드 
	
	//40:공지사항 41:작성방법 안내 자료 42:설문조사 게시 관리

 	// 서비스 객체 생성
	this.smfSearchService("select")
		// 페이징처리
		.paginator(this.grdMain, this.divPaging, this.divTotal, this.dsPageInfo, obj, e)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
		
			this.parent.parent.scrollTo(0,0);
			this.smfResetScroll(this);
			
			for(var i = 0; i < this.dsList.rowcount; i++){
				var row = this.fnGetNum(i)
				this.dsList.setColumn(i,"rowNum",row)
			}
			
			if(callbackParams.errors) return;
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnGetNum = function(row){

	var total = this.dsPageInfo.getColumn(0,"totalCount")
	var pageSize = this.dsPageInfo.getColumn(0,"pageSize")
	var pageIndex = this.dsPageInfo.getColumn(0,"pageIndex")
	var numOfPage = total - (pageSize * ( pageIndex -1 ));

	return numOfPage - row;

}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearch(obj, e);
};

this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	// 클릭한 셀을 구한다
	var nRow = e.row;
	var nCell = e.cell;
	
	if(this.smfIsMobile() && nCell == 3){
		nCell = 2;
	}
	
	if(nCell == 2){ // 제목클릭 시
		var objDs = obj.getBindDataset();
		var sNtcMteId = objDs.getColumn(nRow,"ntcMteId");

		var params = {"ntcMteId":sNtcMteId
						, "dsSearchParam":this.dsSearch.saveXML()
						, "dsPagingParam":this.dsPageInfo.saveXML()
						};
		this.smfSetWorkPage("pa_hes_len_fo::hes_lenfo01_m00.xfdl", params);
	}
};

this.edtSearchKeyword_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode == "13"){
		this.divSearch.form.btnSearch.click();
	}
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.edtSearchKeyword" propid="value" datasetid="dsSearch" columnid="searchKeyword"/>
    </Bind>
  </Form>
</FDL>
