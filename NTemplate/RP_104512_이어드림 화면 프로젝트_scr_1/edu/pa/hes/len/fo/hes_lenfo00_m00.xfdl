                <Cell col="2" displaytype="normal" edittype="none" text="bind:ntcMteTitlNm" cssclass="expr:imptYn==&quot;Y&quot;?&quot;cell_ImpNoti&quot;:&quot;&quot;" expr="expr:imptYn==&quot;Y&quot;?comp.parent.smfDispLongTextGrid(comp,2,currow,ntcMteTitlNm,imptYn) :comp.parent.smfDispLongTextGrid(comp,2,currow,ntcMteTitlNm) " cursor="pointer"/>
                <Cell col="3" displaytype="normal" edittype="none" cssclass="expr:(fileRefrnId != undefined &amp;&amp; fileRefrnId != &quot;&quot;) &amp;&amp; imptYn==&quot;Y&quot; ? &quot;cell_NotiFile,cell_bgGray&quot;:((fileRefrnId != undefined &amp;&amp; fileRefrnId != &quot;&quot;) &amp;&amp; imptYn == &quot;N&quot;?&quot;cell_NotiFile&quot;:((fileRefrnId == undefined || fileRefrnId == &quot;&quot;) &amp;&amp; imptYn== &quot;Y&quot;?&quot;cell_bgGray&quot;:&quot;&quot;))"/>
                <Cell col="4" displaytype="date" edittype="none" text="bind:regDt" calendardateformat="yyyy.MM.dd " calendareditformat="yyyy.MM.dd" cssclass="expr:imptYn==&quot;Y&quot;?&quot;cell_bgGray&quot;:&quot;&quot;"/>
                <Cell col="5" text="bind:ntcMteInqCnt" displaytype="text" cssclass="LineNo"/>
