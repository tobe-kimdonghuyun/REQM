        <Static id="staCts" taborder="2" left="20" top="125" height="23" text="설문조사 화면입니다." initvalueid="ivStcAccessibilityOn" usedecorate="false" cssclass="sta_WF_Black14" textAlign="center" onclick="sta00_00_01_01_onclick" right="20"/>
        <Button id="btnClose" taborder="3" text="닫기" height="30" width="50" left="47.50%" initvalueid="ivBtnAccessibilityButton" top="229" onclick="btnClose_onclick"/>
