    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 학원서비스로그인
*  @MenuPath    TEMPLATE
*  @FileName 	hes_llelv00_m00.xfdl
*  @Creator 	최경진
*  @CreateDate 	2023.02.08
*  @Desction    학원서비스 로그인

************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.02.08     	최경진 	        최초 생성 
*******************************************************************************

********* 로그인 후 세션에서 가져올 수 있는 정보 *********
* 학원지정번호
this.smfGetSessionValue("acaDsgnNo");
* 학원교습소구분코드
this.smfGetSessionValue("acaInstiScCd");
* 개인지정번호
this.smfGetSessionValue("invlDsgnNo");
* 시도교육청코드
this.smfGetCddcCode();
* 한글성명
this.smfGetKornFlnm();
* 주민등록번호
this.smfGetTrprRrno();

*/
include "lib::cm_script.xjs"
include "lib::pam_script.xjs";
include "lib::hes_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.mberNm = "";
this.mberRrn = "";
this.fv_nextFormUrl = "";
this.fv_nextFormMenuId = "";
this.tmpLoginYn = false;
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 *************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);
	
	this.hesSetGoUrl("pa_hes_lle_lv::hes_llelv00_m00.xfdl");
	
	// 파라메터 세팅
	this.pv_params = this.smfGetFormParams();
	
	this.fv_nextFormUrl = this.pv_params.resendUrl;
	this.fv_nextFormMenuId = this.pv_params.resendMenuId;
	
	
	// 서비스 객체 생성 
	this.smfValidateService("validateMain", {
			url: "/hes_lle_lv00_900.do",
	})
	.mappingRulesetToForm(this.divLoginFrm, "login")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
	});
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};

/**
 * 팝업의 콜백함수 지정한다 (공동인증서)
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	var sLog = "";
	var obj = sender.divLoginFrm.form;
	if(e.result)
	{
		var sData = JSON.parse(e.data);
		
		this.doLogin(sData.subjectDn, "LG001"); // 로그인 유형코드 LG001:EPKI/GPKI
	}
	else
	{
		var sData = e.data;
		var arrData = sData.split(":");
		if(arrData[0].trim()=='{"visible"')
		{  // 유저가 팝업을 강제 종료한 경우
			sLog += "처리결과 : [에러(유저강제종료)]\n";
			sLog += "data : ["+sData+"]";
			
			trace(sLog);			
		}
		else
		{
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+sData+"]";
			
			trace(sLog);
			this.smfAlert(sData);
		}
		
	}
};

/**
 * 팝업의 콜백함수 지정한다 (금융인증서)
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnFinAuthPopupCallback = function(e, sender){
	trace("===>this.fnPopupCallback : popup callback");
	var sLog = "";
	var obj = sender.divLogin2.form;
	if(e.result)
	{
		var sData = e.data;
		
		sLog += "처리결과 : [성공]\n";
		sLog += "data : ["+sData+"]";
		
		trace(sLog);
		var subjectDn = JSON.parse(sData).certificate.subject_dn.toString();
		
		this.doLogin(subjectDn , "LG009");	//금융인증서
		
// 		var dnNm = subjectDn.substring(3, subjectDn.indexOf("("))
// 		var vidResult = JSON.parse(sData).vidresult.toString();
// 		
// 		if(vidResult == "true"){
// 		
// 			mberNm = obj.edtKornFlnm.value;
// 			
// 			if(dnNm != mberNm){
// 			
// 				this.smfLiteralAlert("현재 선택하신 인증서의 성명과 입력하신 성명이 일치하지 않습니다.");
// 				
// 			}else{
// 						
// 				this.dsSearch.setColumn(0, "trprRrno", mberRrn);
// 				this.dsSearch.setColumn(0, "kornFlnm", mberNm);
// 				this.dsSearch.setColumn(0, "sqeScCd",  this.fv_sqeScCd);
// 				this.dsSearch.setColumn(0, "cddcCd",   this.smfGetCddcCode());
// 				
// 				this.doLogin(subjectDn , "LG009");	//금융인증서
// 			}
// 		
// 	
// 			
// 		}else if(vidResult == "false"){
// 		
// 			this.smfLiteralAlert("입력된 정보와 인증서 정보가 일치하지 않습니다. 다시 한 번 확인 해 주세요.");
// 			
// 		}else{
// 			this.smfLiteralAlert("인증서 인증에 에러가 발생했습니다. 관리자에게 문의하세요.");
// 		}
	}
	else
	{
		var sData = e.data;
		var arrData = sData.split(":");
		
		if(arrData[0].trim()=="800000")
		{  // 유저가 팝업을 강제 종료한 경우
			sLog += "처리결과 : [에러(유저강제종료)]\n";
			sLog += "data : ["+sData+"]";
			
			trace(sLog);		
		}
		else
		{
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+sData+"]";
			
			trace(sLog);		
		}
		
	}
};

/**
 * 팝업의 콜백함수 지정한다 (간편인증)
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnSimpleAuthPopupCallback = function(e, sender){
	trace("===>this.fnSimpleAuthPopupCallback : popup callback");
	
	var sLog 		= "";
	var loginTyp 	= "simpleLogin";
	
	if(e.result){
//		var sData = JSON.parse(e.data);

		if(this.smfIsNull(e.data)){
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+e.data+"]";
			console.log(sLog);
			this.smfLiteralAlert("본인 인증 인증에 실패 하였습니다..");
			return;
		}
		
		sLog += "처리결과 : [성공]\n";
		//sLog += "data : ["+sData+"]";	
		console.log(sLog);
		
// 		mberNm = sData.userNm;
// 		mberRrn = sData.ssn;
// 
// 		this.dsSearch.setColumn(0, "trprRrno", mberRrn);
// 		this.dsSearch.setColumn(0, "kornFlnm", mberNm);
// 		this.dsSearch.setColumn(0, "sqeScCd", this.fv_sqeScCd);
// 		this.dsSearch.setColumn(0, "cddcCd",  this.smfGetCddcCode());
// 		this.dsSearch.setColumn(0, 'certKey', sData.ci);// 간편인증 CI
		
		this.dsSearch.setColumn(0, "jwt", e.data);
	
		// 서비스 객체 생성
		this.smfSearchService("listToken")
			.run()	// 실행
			// 콜백
			.callback(function(callbackParams){		
				if(callbackParams.errors) return;
				this.doLogin(this.dsResult.getColumn(0, "ci") , "LG005");	//간편인증
			});	
	}
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.divLoginFrm_btnLogin_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(!this.divLoginFrm.form.chkPinAgre.value){
		this.smfLiteralAlert("개인식별번호 처리에 동의해주세요.");
		return;
	}
	
	if(this.validation(obj)){
		this.mberNm = obj.parent.edtUserNm.value;
		this.mberRrn = obj.parent.edtUserIhtNo1.value + obj.parent.edtUserIhtNo2.value;
		
		this.doLogin();
	}
};

/**
 * 공동인증서 로그인
 */
this.divLoginFrm_btnCertLogin_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	if(this.validation(obj)){
		
		var sConnectBaseUrl = window.location.protocol + "//" + window.location.host;

		var sInitUrl  = sConnectBaseUrl + "/cmc_fcm_es01_003.do";
		var sLoginUrl = sConnectBaseUrl + "/cmc_fcm_es01_005.do";

		var objLoginInfo = {
								initUrl  : sInitUrl    // init시 사용하는 서비스명(앞에 "/"을 붙일 것)
							,   loginUrl : sLoginUrl   // login시 사용하는 서비스명(앞에 "/"을 붙일 것)
							,	userId : "1111111111111" //주민번호 입력하지 않아 임의의 값 전달
							,	useRrno : "N"
						   };   // 생략가능

		var objParam = {objForm:this, popupcallback :this.fnPopupCallback, loginInfo:objLoginInfo};
		this.smfExecNpkiAuth(objParam);
	}
};

