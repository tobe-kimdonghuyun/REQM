    <Script type="xscript5.1"><![CDATA[/**
*   대국민 - 학원서비스로그인
*  @MenuPath    TEMPLATE
*  @FileName 	hes_llelv00_m00.xfdl
*  @Creator 	최경진
*  @CreateDate 	2023.02.08
*  @Desction    행정처분사항조회

************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.02.08     	최경진 	        최초 생성 
*******************************************************************************

********* 로그인 후 세션에서 가져올 수 있는 정보 *********
* 학원지정번호
this.smfGetSessionValue("acaDsgnNo");
* 학원교습소구분코드
this.smfGetSessionValue("acaInstiScCd");
* 개인지정번호
this.smfGetSessionValue("invlDsgnNo");
* 시도교육청코드
this.smfGetCddcCode();
* 한글성명
this.smfGetKornFlnm();
* 주민등록번호
this.smfGetTrprRrno();

*/
include "lib::cm_script.xjs"
include "lib::pam_script.xjs";
include "lib::hes_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.mberNm = "";
this.mberRrn = "";
this.fv_nextFormUrl = "";
this.fv_nextFormMenuId = "";
this.tmpLoginYn = false;
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 *************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);
	
	//this.hesSetGoUrl("pa_hes_lle_lv::hes_llelv00_m01.xfdl");
	
	// 파라메터 세팅
	this.pv_params = this.smfGetFormParams();
	
	this.fv_nextFormUrl = this.pv_params.resendUrl;
	this.fv_nextFormMenuId = this.pv_params.resendMenuId;
	
	//@KBR 가상키보드 사용
	var objOption1 = {
		target : this.divUserInfoFrm.form.edtUserIhtNo2, // 대상 Edit 컴포넌트 [필수]
		targetKey : this.divUserInfoFrm.form.staTransKey, // Edit와 쌍으로 있는 마우스입력 체크박스(static) [필수]
		bshow : true,
		maxLength : 7,
		kbdType :  "number"
	}
	this.smfInitTranskey(objOption1);
	
	
	// 서비스 객체 생성 
	this.smfValidateService("validateMain", {
			url: "/hes_lle_lv00_900.do",
	})
	.mappingRulesetToForm(this.divUserInfoFrm, "login")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
	});
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};

/**
 * 팝업의 콜백함수 지정한다 (공동인증서)
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	var sLog = "";
	var obj = sender.divUserInfoFrm.form;
	if(e.result)
	{
		var sData = JSON.parse(e.data);
		
		if(sData.vidResult == "true"){
			this.fnRegCertKey(sData.subjectDn);
		}else if(sData.vidResult.indexOf("VID") != -1){
		
			this.smfLiteralAlert("입력된 정보와 인증서 정보가 일치하지 않습니다. 다시 한 번 확인 해 주세요.");
			
		}else{
			this.smfLiteralAlert("인증서 인증에 에러가 발생했습니다. 관리자에게 문의하세요.");
		}		
	}
	else
	{
		var sData = e.data;
		var arrData = sData.split(":");
		
		if(arrData[0].trim()=='{"visible"')
		{  // 유저가 팝업을 강제 종료한 경우
			sLog += "처리결과 : [에러(유저강제종료)]\n";
			sLog += "data : ["+sData+"]";
			
			trace(sLog);			
		}
		else
		{
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+sData+"]";
			
			trace(sLog);	
			this.smfAlert(sData);
		}
		
	}
};

/**
 * 팝업의 콜백함수 지정한다 (금융인증서)
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnFinAuthPopupCallback = function(e, sender){
	trace("===>this.fnPopupCallback : popup callback");
	var sLog = "";
	var obj = sender.divUserInfoFrm.form;
	if(e.result)
	{
		var sData = e.data;
		
		sLog += "처리결과 : [성공]\n";
		sLog += "data : ["+sData+"]";
		
		trace(sLog);
		var subjectDn = JSON.parse(sData).certificate.subject_dn.toString();
		var dnNm = subjectDn.substring(3, subjectDn.indexOf("("))
		var vidResult = JSON.parse(sData).vidresult.toString();
		
		if(vidResult == "true"){
			this.fnRegCertKey(subjectDn);
		}else if(vidResult == "false"){
			this.smfLiteralAlert("입력된 정보와 인증서 정보가 일치하지 않습니다. 다시 한 번 확인 해 주세요.");
		}else{
			this.smfLiteralAlert("인증서 인증에 에러가 발생했습니다. 관리자에게 문의하세요.");
		}		
	}
	else
	{
		var sData = e.data;
		var arrData = sData.split(":");
		
		if(arrData[0].trim()=="800000")
		{  // 유저가 팝업을 강제 종료한 경우
			sLog += "처리결과 : [에러(유저강제종료)]\n";
			sLog += "data : ["+sData+"]";
			
			trace(sLog);		
		}
		else
		{
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+sData+"]";
			
			trace(sLog);		
		}
		
	}
};

/**
 * 팝업의 콜백함수 지정한다 (간편인증)
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnSimpleAuthPopupCallback = function(e, sender){
	trace("===>this.fnSimpleAuthPopupCallback : popup callback");
	
	var sLog = "";
	var obj = sender.divUserInfoFrm.form;

	if(e.result){
		if(this.smfIsNull(e.data)){
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+e.data+"]";
			console.log(sLog);
			this.smfLiteralAlert("본인 인증 인증에 실패 하였습니다..");
			return;
		}
		
		sLog += "처리결과 : [성공]\n";
		//sLog += "data : ["+sData+"]";	
		console.log(sLog);
		
		this.dsSearch.setColumn(0, "jwt", e.data);
	
		// 서비스 객체 생성
		this.smfSearchService("listToken")
			.run()	// 실행
			// 콜백
			.callback(function(callbackParams){		
				if(callbackParams.errors) return;
				this.fnRegCertKey(this.dsResult.getColumn(0, "ci"));
			});	
	}
}

this.fnAgreCallback = function(e, sender){
	//개인정보팝업에서 모두 동의한 경우 체크하고 readOnly
	if(e.agre){
		this.divUserInfoFrm.form.chkPinAgre.set_value(true);
	}else{
		this.divUserInfoFrm.form.chkPinAgre.set_value(false);
	}
}
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
this.divLoginFrm_btnLogin_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.mberNm = this.divUserInfoFrm.form.edtUserNm.value;
	this.mberRrn = this.divUserInfoFrm.form.edtUserIhtNo1.value + this.divUserInfoFrm.form.edtUserIhtNo2.value;
	this.doLogin();
};

/**
 * 공동인증서 등록 버튼 클릭
 */
this.divUserInfoFrm_btnCertReg_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.doChkUsrInfo(obj, 'LG001');	// 로그인 유형코드 LG001:EPKI/GPKI
};

/**
 * 금융인증서 등록 버튼 클릭
 */
this.divUserInfoFrm_btnFinReg_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.doChkUsrInfo(obj, 'LG009');	// 금융인증서
};

/**
 * 간편인증서 등록 버튼 클릭
 */
this.divUserInfoFrm_btnSimpleReg_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.doChkUsrInfo(obj, 'LG005');	// 간편인증서
};

this.divUserInfoFrm_edtUserIhtNo2_onkeyup = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	this.divUserInfoFrm.form.edtUserIhtNo2.updateToDataset();
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
/*************************************************************************************************/
this.validation = function(obj){
	var transKey = this.fnTransKey(this.divUserInfoFrm.form.edtUserIhtNo2);
	var sRtnVal = this.smfGetValueTranskey(this.divUserInfoFrm.form.edtUserIhtNo2);
	
	if(this.smfIsNull(this.rdoAcaInstiScCd.value)){
		this.smfLiteralAlert("학원/교습소 구분을 선택해주세요.");
		this.rdoAcaInstiScCd.setFocus();
		return false;
	}

	if( obj.parent.parent.name == "divUserInfoFrm" && this.smfIsNull(obj.parent.edtUserNm.value)){
		this.smfLiteralAlert("성명을 입력해주세요.");
		obj.parent.edtUserNm.setFocus();
		return false;
	}
	else if(this.smfIsNull(obj.parent.edtUserIhtNo1.value)){
		this.smfLiteralAlert("주민등록번호 앞자리를 입력해주세요.")
		obj.parent.edtUserIhtNo1.setFocus();
		return false;
	}
	else if(this.smfIsNull(this.divUserInfoFrm.form.edtUserIhtNo2.text) && sRtnVal == "e2e"){
		this.smfLiteralAlert("주민등록번호 뒷자리를 입력해주세요.")
		obj.parent.edtUserIhtNo2.setFocus();
		return false;
	}	
	else if(obj.parent.edtUserIhtNo1.value.length != 6){
		this.smfLiteralAlert("주민등록번호를 바르게 입력해주세요.")
		obj.parent.edtUserIhtNo1.setFocus();
		return false;
	}
	else if(obj.parent.edtUserIhtNo2.text.length != 7  && sRtnVal == "e2e"){
		this.smfLiteralAlert("주민등록번호를 바르게 입력해주세요.")
		obj.parent.edtUserIhtNo2.setFocus();
		return false;
	}else{
		return true;
	}
}

this.doChkUsrInfo = function(obj, type){
	
	if(!this.divUserInfoFrm.form.chkPinAgre.value){
		this.smfLiteralAlert("개인식별번호 처리에 동의해주세요.");
		return;
	}
	
	if(this.validation(obj)){
		this.mberNm = obj.parent.edtUserNm.value;
		this.mberRrn = this.divUserInfoFrm.form.edtUserIhtNo1.value + this.divUserInfoFrm.form.edtUserIhtNo2.value
		
		this.divUserInfoFrm.form.edtUserIhtNo3.set_value(this.mberRrn);
		this.dsSearch.setColumn(0,"cteOfcdcCd", this.smfGetCddcCode());
		this.dsSearch.setColumn(0,"atptOfcdcOrgCode", this.smfGetCddcCode());
		
		this.smfSearchService("listOnlUserInfo")
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			//온라인사용자등록여부
			if(this.dsOnlUserInq.getRowCount() < 1){
				this.smfLiteralAlert("온라인 사용자로 등록되어있지 않습니다.");
				return;
			}else{
				//인증서 등록여부
				var certKey = this.dsOnlUserInq.getColumn(0,"certKey");
				
				if(certKey != "" && certKey != undefined){ //기등록된 인증서가 있는 경우
					this.smfConfirm("이미 등록된 인증서가 있습니다.\n변경하시겠습니까?", function(result){
						if(result.confirmResult){
							switch(type){
								case "LG001" : this.callCertPop();			break;	// 공동인증서
								case "LG009" : this.callFinCertPop();		break;	// 금융인증서
								case "LG005" : this.callSimpleCertPop();	break;	// 간편인증서
							}
						}
					});
				}else{
					switch(type){
						case "LG001" : this.callCertPop();			break;	// 공동인증서
						case "LG009" : this.callFinCertPop();		break;	// 금융인증서
						case "LG005" : this.callSimpleCertPop();	break;	// 간편인증서
					}
				}
			}
		});
	}
	
}

this.doLogin = function(){
	this.divUserInfoFrm.form.edtUserIhtNo3.set_value(this.mberRrn);
	this.dsSearch.setColumn(0,"atptOfcdcOrgCode", this.smfGetCddcCode());

	this.smfSearchService("listLoginInfo")
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		this.dsOnlUserInq.setColumn(0,"cddcCd",this.smfGetCddcCode());
		this.dsOnlUserInq.setColumn(0,"cddcNm",this.smfGetCddcName());
		
		this.smfSetSessionDataset(this.dsOnlUserInq);		
		this.smfSetKornFlnm(this.dsOnlUserInq.getColumn(0,"funrKornFlnm"));
		this.smfSetTrprRrno(this.dsOnlUserInq.getColumn(0,"trprRrno"));
		
		this.smfLiteralAlert("로그인에 성공하였습니다.");
		
		var objFrame = this.getOwnerFrame();
		
		if(objFrame.form.divAll){
		
			//로그인처리
			this.smfLoginProc();
			
			//로그인로그생성
			var sLgnTypCd = "LG001";  // 로그인 유형코드 LG001:EPKI/GPKI
			this.smfSendLoginLog(this, sLgnTypCd);     
			
			var sMainUrl = "frame::hes/frameSubMain.xfdl";
			
			if(this.pv_params.returnUrl != undefined){
				sMainUrl = this.pv_params.returnUrl;
			}
			
			// 메인URL로 이동한다.
			if(!this.smfIsNull(sMainUrl)){
				objFrame.form.fnSetMainpage(sMainUrl);	
			}
		}
	});
}

this.fnRegCertKey = function(certKey){
	this.dsSave.copyRow(0, this.dsOnlUserInq, 0);
	//인증서key값 세팅
	this.dsSave.setColumn(0,"certKey",certKey);
	
	this.smfConfirm("선택한 인증서를 등록하시겠습니까?", function(result){
		if(result.confirmResult){
			this.smfSaveService("saveCertKey")
			.showConfirm(false) 
			.run()
			.callback(function(callbackParams){
				if(callbackParams.errors) return;
				
				this.smfLiteralAlert("인증서가 등록되었습니다.\n등록된 인증서로 로그인해주세요.");
				this.smfSetWorkPage("pa_hes_lle_lv::hes_llelv00_m00.xfdl");
			});
		}
	});	
	
}

/**
 * 가상키패드
 * @param  : obj			- edit 컴포넌트
 * @return : N/A
 */
this.fnTransKey = function(obj)
{
	var arrComp = [obj];  //대상 Edit component List: array [필수]
	
	if(!this.smfIsMobile()){
		// 키보드보안 적용여부
		var sRtnVal = this.smfGetValueTranskey(obj);
	
		if(sRtnVal == "transkey"){	//선택
			var sVal = this.smfGetEncDataTranskey(arrComp);
			//전달받은 파라미터 데이터셋에 담기
			this.smfConvRaonDataToDs(this.dsRaonKeyData,arrComp,sVal);
			this.dsRaonKeyData.setColumn(0, 'tk_col_check', "transkey");
		}else if(sRtnVal == "e2e"){ //미선택
			sVal= obj.value;
		}
	}else{
		var sVal = this.smfGetEncDataTranskey(arrComp);
		//전달받은 파라미터 데이터셋에 담기
		this.smfConvRaonDataToDs(this.dsRaonKeyData,arrComp,sVal);
		this.dsRaonKeyData.setColumn(0, 'tk_col_check', "transkey");
	}
}

/**
 * 공동인증서 등록화면 호출
 */
this.callCertPop = function(){
	//인증서등록화면 호출 (주민번호로 신원확인)
	var sConnectBaseUrl = window.location.protocol + "//" + window.location.host;
	var sInitUrl  = sConnectBaseUrl + "/cmc_fcm_es01_003.do";
	var sLoginUrl = sConnectBaseUrl + "/cmc_fcm_es01_004.do";
	var objLoginInfo = {
							initUrl  : sInitUrl    // init시 사용하는 서비스명(앞에 "/"을 붙일 것)
						,   loginUrl : sLoginUrl   // login시 사용하는 서비스명(앞에 "/"을 붙일 것)
						,	userId : this.dsOnlUserInq.getColumn(0,"funrRrno")  //입력한 주민번호
					   };

	var objParam = {objForm:this, popupcallback :this.fnPopupCallback, loginInfo:objLoginInfo};
	this.smfExecNpkiAuth(objParam);
}

/**
 * 금융인증서 등록화면 호출 https://t-4user.yeskey.or.kr/v1/fincertInt.js?dt=
 */
this.callFinCertPop = function(){
	
	var sRrno	= this.dsOnlUserInq.getColumn(0,"funrRrno");
	
	var objParam = {objForm:this, popupcallback :this.fnFinAuthPopupCallback, rrno : sRrno};
				
	this.smfExecFinAuth(objParam);
}

/**
 * 간편인증 등록화면 호출 https://easysign.anyid.go.kr/esign
 */
this.callSimpleCertPop = function(){

	// 오픈방식을 설정한다.	
	var sOpenType   = "birth";  // [선택] Open방식 -  "birth"(default) : 생년월일 , "ssn" : 주민등록번호
	var sActionType = 'instl';  // [선택] 간편인증 동작방식 -  "trans" : 중계형(온라인채용/검정고시) , "instl" : 설치형(교육비원클릭/그외)
	                                             // 미지정시 subSys를 체크하여 설정. 미지정을 권장

	var objParam = {objForm:this, popupcallback :this.fnSimpleAuthPopupCallback , openType: sOpenType, actionType: sActionType };
	this.smfExecSimpleAuth(objParam);
}

this.divUserInfoFrm_chkPinAgre_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	if(!this.divUserInfoFrm.form.chkPinAgre.value){
		this.divUserInfoFrm.form.chkPinAgre.set_value(false);
	}else{
		this.divUserInfoFrm.form.chkPinAgre.set_value(false);
		
		var procType = "search";

		// 팝업을 동작에 필요한 파라메터 지정
		var popupParams = { 
			callback: this.fnAgreCallback,
			sender: obj, // sender 지정
			// 팝업 전달 파라메터 지정
			params: {
				// 처리타입 지정
				procType: procType
			},
		};
		
		this.smfDialog("_auto", "pa_hes_lle_lv::hes_llelv00_p01.xfdl", popupParams,null,null,1200,800);
	}
};

/**
 * 공동인증서 탭(버튼) 클릭
 */
this.btn01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divUserInfoFrm.form.btnCertReg.set_visible(true);
	this.divUserInfoFrm.form.btnCertReg.move(176,279);
	this.divUserInfoFrm.form.btnFinReg.set_visible(false);
	this.divUserInfoFrm.form.btnSimpleReg.set_visible(false);
	
	this.divUserInfoFrm.form.staImgCopr.set_visible(true);
	this.divUserInfoFrm.form.imgWA.set_visible(false);
	this.divUserInfoFrm.form.divSimple.set_visible(false);
	
	this.btn01.set_cssclass("btn_Login_TabCaseS")
	this.btn02.set_cssclass("btn_Login_TabCase")
	this.btn03.set_cssclass("btn_Login_TabCase")
};

/**
 * 금융인증서 탭(버튼) 클릭
 */
this.btn02_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divUserInfoFrm.form.btnCertReg.set_visible(false);
	this.divUserInfoFrm.form.btnFinReg.set_visible(true);
	this.divUserInfoFrm.form.btnFinReg.move(176,279);
	this.divUserInfoFrm.form.btnSimpleReg.set_visible(false);
	
	this.divUserInfoFrm.form.staImgCopr.set_visible(false);
	this.divUserInfoFrm.form.imgWA.set_visible(true);
	this.divUserInfoFrm.form.divSimple.set_visible(false);

	this.btn01.set_cssclass("btn_Login_TabCase")
	this.btn02.set_cssclass("btn_Login_TabCaseS")
	this.btn03.set_cssclass("btn_Login_TabCase")
};

/**
 * 간편인증 탭(버튼) 클릭
 */
this.btn03_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divUserInfoFrm.form.btnCertReg.set_visible(false);
	this.divUserInfoFrm.form.btnFinReg.set_visible(false);
	this.divUserInfoFrm.form.btnSimpleReg.set_visible(true);
	this.divUserInfoFrm.form.btnSimpleReg.move(176,279);
	
	this.divUserInfoFrm.form.staImgCopr.set_visible(false);
	this.divUserInfoFrm.form.imgWA.set_visible(false);
	this.divUserInfoFrm.form.divSimple.set_visible(true);

	this.btn01.set_cssclass("btn_Login_TabCase")
	this.btn02.set_cssclass("btn_Login_TabCase")
	this.btn03.set_cssclass("btn_Login_TabCaseS")
};

//////////////////// 로그인 테스트를 위한 임시 로직 ////////////////////
this.img00_00_onkeydown = function(obj:nexacro.ImageViewer,e:nexacro.KeyEventInfo)
{
	this.tmpLoginYn = e.ctrlkey && e.shiftkey && e.altkey ? true : false;
};

this.img00_00_onkeyup = function(obj:nexacro.ImageViewer,e:nexacro.KeyEventInfo)
{
	if (this.tmpLoginYn && e.keycode == 49){
	
		var isVisible = this.btn02.visible;
		
		if(isVisible){
			this.btn01.move(514,152);
			this.btn01_onclick();
		}else{
			this.btn01.move(339,152);
		}
		
		this.btn02.set_visible(!isVisible);
		this.btn03.set_visible(!isVisible);
	}
};
]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listLoginInfo</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsRaonKeyData=dsRaonKeyData</Col>
            <Col id="outDatasets">dsOnlUserInq=dsOnlUserLgnInq</Col>
            <Col id="svctp"/>
            <Col id="url">hes_lle_lv00_000.do</Col>
            <Col id="callback"/>
            <Col id="message">조회</Col>
            <Col id="asynctp"/>
            <Col id="service"/>
          </Row>
          <Row>
            <Col id="id">listOnlUserInfo</Col>
            <Col id="inDatasets">search=dsSearch dsRaonKeyData=dsRaonKeyData</Col>
            <Col id="outDatasets">dsOnlUserInq=result</Col>
            <Col id="svctp"/>
            <Col id="url">hes_lle_lv00_001.do</Col>
            <Col id="callback"/>
            <Col id="message">조회</Col>
            <Col id="asynctp"/>
            <Col id="service"/>
          </Row>
          <Row>
            <Col id="inDatasets">save=dsSave</Col>
            <Col id="outDatasets">dsSave=dsSave</Col>
            <Col id="url">hes_mle_oc00_002.do</Col>
            <Col id="id">saveCertKey</Col>
          </Row>
          <Row>
            <Col id="id">listToken</Col>
            <Col id="url">hes_lle_lv00_002.do</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResult=dsResult</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="userNm" type="STRING" size="256"/>
          <Column id="funrRrno" type="STRING" size="256"/>
          <Column id="cteOfcdcCd" type="STRING" size="256"/>
          <Column id="acaInstiScCd" type="STRING" size="256"/>
          <Column id="atptOfcdcOrgCode" type="STRING" size="256"/>
          <Column id="userIhtNo1" type="STRING" size="256"/>
          <Column id="userIhtNo2" type="STRING" size="256"/>
          <Column id="jwt" type="STRING" size="256"/>
        </ColumnInfo>
