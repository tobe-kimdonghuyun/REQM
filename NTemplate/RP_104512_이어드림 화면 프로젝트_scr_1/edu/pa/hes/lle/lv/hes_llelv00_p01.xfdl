<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmTemp01" width="1200" height="730" onload="frmTemp01_onload" titletext="인증서등록개인식별번호처리동의팝업">
    <Layouts>
      <Layout height="730" width="1200" screenid="ScreenDeskTop">
        <ImageViewer id="imgTitle" taborder="0" text="고유식별번호 및 개인정보 처리 동의" left="20" top="40" height="54" cssclass="img_WF_SubTit01" width="680" initvalueid="ivTitleAccessibilityOn"/>
        <Div id="div00" taborder="1" text="div00" left="20" top="134" height="506" width="1160" cssclass="div_WF_kinder" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="sta00_00_00_00_00" taborder="1" text="■ 개인정보 수집 및 이용에 관한 동의&#13;&#10;&#13;&#10;가. 개인정보의 수집 및 이용 목적&#13;&#10;     ○ 학원서비스를 이용하는 온라인사용자의 등록여부를 확인하기 위함&#13;&#10;     ○ 학원서비스를 통해 민원처리 되는 학원의 강사, 교습소의 임시교습자 및 보조요원 등록 민원을 처리하기 위함&#13;&#10;나. 수집하려는 개인정보의 항목&#13;&#10;     ○ 온라인사용자의 성명, 주민등록번호, &#13;&#10;     ○ 학원강사의 성명, 주민등록번호, 전화번호, 이메일, 주소, 학력, 전공, 강사구분, 자격구분, 자격증, 채용일, 교습과목, 외국인강사체류자격코드, &#13;&#10;         증빙서류(자격), 성범죄경력여부, 아동학대여부, 학력정보(학교/학과/학위/졸업일자)&#13;&#10;     ○ 교습소 임시교습자, 보조요원의 성명, 주민등록번호, 전화번호, 이메일, 주소, 학력, 전공, 자격구분, 증빙서류(자격), 성범죄경력여부, 아동학대여부 &#13;&#10;     ※ 「 학원의설립운영및괴외교습에관한시행령 」 제19조(고유식별정보의 처리) , 「 민원처리에관한법률시행령 」 제52조(고유식별정보의 처리) 에 근거하여 처리합니다. &#13;&#10;&lt;b v='true'&gt;다. 개인정보의 보유기간&#13;&#10;     ○ 수집한 개인정보는 학원의 설립 운영 및 과외교습에 관한 법률에 정해진 기간 동안 보유&lt;/b&gt;&#13;&#10;라. 동의를 거부할 권리 및 동의 거부에 따른 제약사항&#13;&#10;     ○ 위 사항에 대하여 동의를 거부할 권리가 있으며, 동의 거부시에는 본 사이트의 로그인 및 민원관련 서비스를 이용할수 없습니다." left="32" top="30" height="425" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_Txt16" right="71" letterSpacing="-1px" onclick="div00_sta00_00_00_00_00_onclick" usedecorate="true"/>
              <Static id="Static99_00_00_00_00_00" taborder="1" left="0" top="0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0"/>
              <Static id="Static99_00_00_00_00_00_00" taborder="2" left="-9" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" bottom="3"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="Static99_00_00_00_00_00_00" left="0" height="90" right="0" bottom="0" text="90"/>
              <Static id="sta00_00_00_00_00" cssclass="sta_WF_Txt28C" left="20" top="0" height="508" text="나이스 대국민 서비스는 장애인, 노인 등의 &#13;&#10;정보취약계층의 사용자가 전문적인 능력없이도 &#13;&#10;웹 사이트에서 제공하는 정보에 접근할 수 있도록 &#13;&#10;최선의 노력을 기울이고 있습니다.&#13;&#10;&#13;&#10;나이스 대국민 서비스는 장애인, 노인 등 &#13;&#10;정보취약계층의 인터넷 정보 접근을 보장하기 위해 &#13;&#10;국가표준(KICS)으로 제정된 &#13;&#10;&quot;한국형 웹 콘텐츠 접근성 지침2.1&quot;와&#13;&#10;&quot;전자정부서비스 호환성 준수지침&#13;&#10;(행정자치부 고시 제1호)&quot;를 준수하여 &#13;&#10;제작되어 있습니다." letterSpacing="-2px" minwidth="560" maxwidth="" right="20"/>
              <Static id="Static99_00_00_00_00_00" left="0" top="0" height="30" right="555"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="Static99_00_00_00_00" taborder="2" left="20" top="0" height="40" cssclass="sta_GD_Size" text="40" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20"/>
        <Static id="Static99_00_00_00_00_00" taborder="3" left="20" top="94" height="40" cssclass="sta_GD_Size" text="40" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20"/>
        <CheckBox id="chkPinAgre1" taborder="4" text="동의합니다" left="1067" top="663" width="113" height="30" value="false" initvalueid="ivChkNormal" cssclass="chk_Login_Normal" onchanged="chkPinAgre1_onchanged"/>
        <Static id="Static99_00_00_00_00_00_00" taborder="5" left="19" top="643" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="21"/>
        <Static id="Static99_00_00_00_00_00_00_00" taborder="6" left="1" top="0" height="730" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20"/>
        <Static id="Static99_00_00_00_00_00_00_00_00" taborder="7" left="1180" top="0" height="730" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20"/>
        <Static id="Static99_00_00_00_00_01" taborder="8" left="20" top="690" height="40" textAlign="center" font="10px &quot;Tahoma&quot;" visible="true" right="20" cssclass="sta_GD_Size"/>
      </Layout>
      <Layout name="Layout0" screenid="mobile" width="640" height="4147" mobileorientation="portrait" type="default">
        <ImageViewer id="imgTitle" cssclass="img_WF_Txt48BC" left="156" top="72" height="80" taborder="0" right="156" minwidth="340" maxwidth=""/>
        <Static id="Static99_00_00_00_00" left="0" top="0" height="90" right="0" taborder="2"/>
        <Div id="div00" left="20" top="imgTitle:22" height="589" cssclass="div_WF_BotLine" taborder="1" right="20"/>
        <Static id="Static99_00_00_00_00_00" left="0" top="134" height="40" right="0" taborder="3"/>
      </Layout>
    </Layouts>
