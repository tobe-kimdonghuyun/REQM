          <Column id="aslSemNm" type="STRING" size="256"/>
          <Column id="ym" type="STRING" size="256"/>
          <Column id="lectIdfNo" type="STRING" size="256"/>
          <Column id="aslLectNm" type="STRING" size="256"/>
