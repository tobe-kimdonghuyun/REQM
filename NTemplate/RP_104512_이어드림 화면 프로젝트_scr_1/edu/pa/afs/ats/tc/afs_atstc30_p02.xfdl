    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 > 방과후학교 > 외부강사 > 시간표조회
*  @FileName 	afs_atstc30_p02.xfdl 
*  @Creator 	임대성
*  @CreateDate 	2022.05.31
*  @Desction    대국민 방과후학교 외부강사 시간표조회 팝업
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.05.31            임대성                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::afs_script.xjs"



/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/



/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitPopup(obj);
	
	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	this.dsSearch.copyRow(0, this.pv_params.dsPgm, 0);
	
	if(this.pv_params.all =="Y"){
		this.divSearch.form.staAslLectNm.set_visible(false);
		this.divSearch.form.edtAslLectNm.set_visible(false);
	}
	
	this.dsCd.setColumn(0, "cddcCd",       this.dsSearch.getColumn(0, "cddcCd"));
	this.dsCd.setColumn(0, "shlCd",        this.dsSearch.getColumn(0, "shlCd"));
	this.dsCd.setColumn(0, "ayr",          this.dsSearch.getColumn(0, "ayr"));
	this.dsCd.setColumn(0, "aslSem",       this.dsSearch.getColumn(0, "aslSem"));
	this.dsCd.setColumn(0, "lectIdfNo",    this.dsSearch.getColumn(0, "lectIdfNo"));
	this.dsCd.setColumn(0, "cntnCtpvScCd", this.dsSearch.getColumn(0, "cntnCtpvScCd"));
	this.dsCd.setColumn(0, "scaSysScCd",   this.dsSearch.getColumn(0, "scaSysScCd"));
	
	this.afsfCodeList(this.dsCd);
	
	this.afsfMakeYm(this.dsYm, "", "", this.dsSearch.getColumn(0, "aslLectBgngYmd"), this.dsSearch.getColumn(0, "aslLectEndYmd"), "", "N");
	
};



/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/




/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
	switch(svcid) {
		case "listPgmClrmCd" : 
			var nWidth = 180;
			this.grdMain.set_autofittype("none");
		    for(var nIdx=0; nIdx<this.dsClrmCd.rowcount; nIdx++){
				//그리드 컬럼 추가
				var nCol = this.grdMain.appendContentsCol("body");

				//추가 컬럼 설정
				this.grdMain.setCellProperty("head",nCol,"text", this.dsClrmCd.getColumn(nIdx, "unyCdValueNm")); // 헤더명
				if(nIdx==0){
				    this.grdMain.setFormatColProperty(nCol, "size", 80);              // 컬럼 사이즈
					this.grdMain.setCellProperty("body",nCol, "text", "bind:dt");     // 컬럼값 bind
					this.grdMain.setCellProperty("body",nCol, "textAlign", "center"); // 컬럼정렬
					this.grdMain.setCellProperty("body",nCol, "cssclass", "expr:dfkCd==7?'cell_Font_Red':(dfkCd==6?'cell_Font_Blue':'')"); // 컬럼정렬
				}else{
					this.grdMain.setFormatColProperty(nCol, "size", 150);                     //컬럼 사이즈
					this.grdMain.setCellProperty("body",nCol, "displaytype", "decoratetext"); // displaytype 설정 글자별 색설정
					this.grdMain.setCellProperty("body",nCol, "text", "bind:clrmCd"+nIdx);    // 컬럼값 bind
				}
			}
			
			if(this.grdMain.getRealColFullSize() <= this.grdMain.getOffsetWidth()){
				this.grdMain.set_autofittype("col");
			}

			break;
	}
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * 시간표 조회
 */
this.fnListSearch = function(){
	if(this.dsSearch.getColumn(0, "ym") == ""){
		this.smfAlert('CM022', ['조회조건[년월]'] ); // 조회조건[년월]을(를) 선택하여 주십시오.
		return;
	}
	// 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			for(var nIdx=0; nIdx<this.dsTiList.getRowCount(); nIdx++){
			    var sDt              = this.dsTiList.getColumn(nIdx, "dt");
			    var vDfkNm           = this.afsfGetDfkNm(sDt.replaceAll(".", ""));
				var vDfkCd           = this.afsfGetDfk(sDt.replaceAll(".", ""));
				this.dsTiList.setColumn(nIdx, "dt", sDt+"("+vDfkNm+")");
				this.dsTiList.setColumn(nIdx, "dfkCd", vDfkCd);
				console.log("dfkCd:"+this.dsTiList.getColumn(nIdx, "dfkCd"));
				
				var nRow             = this.dsClrmCd.findRow("unyCdValue", this.dsTiList.getColumn(nIdx, "clrmCd"));
				var arrAslLectBgngHm = this.dsTiList.getColumn(nIdx, "aslLectBgngHm").split("|");
				var arrAslLectEndHm  = this.dsTiList.getColumn(nIdx, "aslLectEndHm").split("|");
				var arrItrtScNm      = this.dsTiList.getColumn(nIdx, "itrtScNm").split("|");
				var arrItrtScCd      = this.dsTiList.getColumn(nIdx, "itrtScCd").split("|");
				
				var sTi              = "";
				for(nJdx=0; nJdx<arrAslLectBgngHm.length; nJdx++){
					var sBgngHm = arrAslLectBgngHm[nJdx].substring(0, 2)+":"+arrAslLectBgngHm[nJdx].substring(2, 4);
					var sEndHm  = arrAslLectEndHm[nJdx].substring(0, 2)+":"+arrAslLectEndHm[nJdx].substring(2, 4);
					var sTmpTi     = "["+arrItrtScNm[nJdx]+"] "+sBgngHm+"~"+sEndHm;
					if(arrItrtScCd[nJdx] == "1"){
						sTmpTi = "<fc v='red'>"+sTmpTi+"</fc>";
					}else if(arrItrtScCd[nJdx] == "2"){
						sTmpTi = "<fc v='green'>"+sTmpTi+"</fc>";
					}
					
					if(sTi == ""){
						sTi = sTmpTi; 
					}else{
						sTi += "\n"+sTmpTi; 
					}
				}
				
				this.dsTiList.setColumn(nIdx, "clrmCd"+nRow, sTi);
			}
		});
}



/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// 초기화버튼
this.divSearch_btnInit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsSearch.setColumn(0, "ym", "");
};
// 조회버튼
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnListSearch();
};
// 닫기버튼
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};


]]></Script>
