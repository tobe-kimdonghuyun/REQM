<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmTemp01" width="800" height="1090" titletext="개인정보 수집동의(필수)" onload="form_onload">
    <Layouts>
      <Layout height="1090" width="800" screenid="ScreenDeskTop">
        <ImageViewer id="imgTitle00" taborder="0" text="개인정보의 수집·이용 동의서(필수)" left="20" top="16" width="280" height="30" cssclass="img_WF_SubTit04" initvalueid="ivTitleAccessibilityOn" accessibilitylabel="개인정보의 수집 이용 동의서(필수)"/>
        <Div id="divContent00_00" taborder="1" left="20" height="50" right="20" top="72" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staContent00_00" taborder="1" left="0" top="3" text="방과후학교 지원서비스는 다음과 같은 이유로 귀하의 개인정보를 수집․이용합니다. &#13;&#10;아래의 개인정보 수집·이용에 대한 내용을 자세히 읽어 보신 후 동의 여부를 결정하여 주시기 바랍니다." wordWrap="char" right="19" initvalueid="ivStcAccessibilityOn" onclick="div00_sta00_00_01_01_onclick" bottom="3" cssclass="sta_WF_Black14" accessibilitylabel="방과후학교 지원서비스는 다음과 같은 이유로 귀하의 개인정보를 수집.이용합니다. 아래의 개인정보 수집·이용에 대한 내용을 자세히 읽어 보신 후 동의 여부를 결정하여 주시기 바랍니다."/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staGd01" taborder="17" left="315" top="divContent00_00:0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="150"/>
        <Static id="staContent00" taborder="2" text="[ 개인정보의 수집․이용 목적 ]" left="19" top="staGd01:-3" width="295" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn" accessibilitylabel="개인정보의 수집.이용 목적"/>
        <Static id="staGd02" taborder="18" left="315" top="staContent00:-1" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="150"/>
        <Div id="divContent00" taborder="3" left="20" height="115" cssclass="div_WF_InfoBOX" right="20" top="staGd02:0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staContent00" taborder="0" left="24" top="3" cssclass="sta_WF_Black14" text="나이스 업무지원 방과후학교지원서비스는 다음과 같은 이유로 귀하의 개인정보를 수집․이용합니다.&#13;&#10;1. 나이스 업무지원 방과후학교지원서비스 홈페이지 사용자 등록 및 정보관리&#13;&#10;  - 방과후학교 강사 본인등록 및 소득 관리용&#13;&#10;  - 방과후학교 강사 활동확인서 발급용" wordWrap="char" right="19" initvalueid="ivStcAccessibilityOn" onclick="div00_sta00_00_01_01_onclick" bottom="3" accessibilitylabel="나이스 업무지원 방과후학교지원서비스는 다음과 같은 이유로 귀하의 개인정보를 수집.이용합니다. 첫번째. 나이스 업무지원 방과후학교지원서비스 홈페이지 사용자 등록 및 정보관리. 방과후학교 강사 본인등록 및 소득 관리용. 방과후학교 강사 활동확인서 발급용."/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staGd07" taborder="19" left="315" top="divContent00:0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="150"/>
        <Static id="staContent01" taborder="4" text="[ 수집하는 개인정보의 항목 ]" left="19" top="staGd07:-4" width="295" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn" accessibilitylabel="수집하는 개인정보의 항목"/>
        <Static id="staGd08" taborder="20" left="315" top="staContent01:-1" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="150"/>
        <Div id="divContent01" taborder="5" left="20" height="75" cssclass="div_WF_InfoBOX" top="staGd08:0" initvalueid="ivDivAccessibilityOff" right="20">
          <Layouts>
            <Layout>
              <Static id="staContent00" taborder="0" left="24" top="3" cssclass="sta_WF_Black14" text="방과후학교 지원서비스는 아래와 같이 개인정보를 수집하고 있습니다.&#13;&#10;1. 성명, &lt;b&gt;&lt;font size='3'&gt;주민등록번호&lt;/font&gt;&lt;/b&gt;, 은행명, 계좌번호, 휴대전화번호" wordWrap="char" initvalueid="ivStcAccessibilityOn" bottom="3" right="20" usedecorate="true" accessibilitylabel="방과후학교 지원서비스는 아래와 같이 개인정보를 수집하고 있습니다. 첫번째. 성명, 주민등록번호, 은행명, 계좌번호, 휴대전화번호"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staGd13_00" taborder="21" left="314" top="divContent01:-1" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="150"/>
        <Static id="staContent02_00" taborder="6" text="[ 고유식별정보(주민등록번호) 수집 근거 ]" left="18" top="staGd13_00:-3" width="272" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn" accessibilitylabel="고유식별정보(주민등록번호) 수집 근거"/>
        <Static id="staGd14_00" taborder="22" left="314" top="staContent02_00:-2" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="150"/>
        <Div id="divContent02_00" taborder="7" left="20" height="120" cssclass="div_WF_InfoBOX" right="20" top="staGd14_00:0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staContent00" taborder="0" left="24" top="3" cssclass="sta_WF_Black14" text="한국교육학술정보원은 귀하의 동의를 얻어 개인정보를 수집하는 과정에서, 고유식별정보(주민등록번호)의 경우 소득관리를 위한 목적으로 귀하의 동의하에 수집․이용할 수 있습니다.&#13;&#10;1. 소득세법 제21조(기타소득)&#13;&#10;2. 소득세법 제166조(주민등록 전산정보자료 등의 이용)" wordWrap="char" right="20" initvalueid="ivStcAccessibilityOn" bottom="3" accessibilitylabel="한국교육학술정보원은 귀하의 동의를 얻어 개인정보를 수집하는 과정에서, 고유식별정보(주민등록번호)의 경우 소득관리를 위한 목적으로 귀하의 동의하에 수집.이용할 수 있습니다. 첫번째. 소득세법 제21조(기타소득) 두번째. 소득세법 제166조(주민등록 전산정보자료 동의 이용)"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="Static99_00_00_00_00_01_01_01_00_00" taborder="23" left="314" top="divContent02_00:0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="336" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staContent02_00_00" taborder="8" text="[ 개인정보의 처리 및 보유기간 ]" left="18" top="Static99_00_00_00_00_01_01_01_00_00:-3" width="381" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn" accessibilitylabel="개인정보의 처리 및 보유기간"/>
        <Static id="staGd14_00_00" taborder="24" left="314" top="staContent02_00_00:-1" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="150"/>
        <Div id="divContent02_00_00" taborder="9" left="20" height="160" cssclass="div_WF_InfoBOX" right="20" top="staGd14_00_00:0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staContent00" taborder="0" left="24" top="3" cssclass="sta_WF_Black14" text="&lt;b&gt;&lt;font size='3'&gt;방과후학교 지원서비스는 &quot;공공기록물 관리에 관한 법률 시행령 제25조  및 동법 제3조 5항&quot;에 의거, 귀하의 방과후학교 경력인정을 위하여 해당 내역을 준영구기간동안 보유합니다. &#13;&#10;귀하가 방과후학교 운영지원에서 기본정보를 삭제할 경우 즉시 파기됩니다.&lt;/font&gt;&lt;/b&gt;&#13;&#10;단, 다음의 사유에 해당하는 경우에는 해당 사유 종료시까지 개인정보를 처리·보유합니다.&#13;&#10;1) 관계 법령 위반에 따른 수사·조사 등이 진행중인 경우에는 해당 수사·조사 종료시까지&#13;&#10;2) 홈페이지 이용에 따른 채권·채무관계 잔존시에는 해당 채권·채무관계 정산시까지" wordWrap="char" right="20" initvalueid="ivStcAccessibilityOn" bottom="3" usedecorate="true" accessibilitylabel="방과후학교 지원서비스는 &quot;공공기록물 관리에 관한 법률 시행령 제25조 및 동법 제3조 5항&quot;에 의거, 귀하의 방과후학교 경력인정을 위하여 해당 내역을 준영구기간동안 보유합니다. 귀하가 방과후학교 운영지원에서 기본정보르 삭제할 경우 즉시 파기됩니다. 단, 다음의 사유에 해당하는 경우에는 해당 사유 종료시까지 개인정보를 처리·보유합니다. 첫번째. 관계법령 위반에 따른 수사·조사 등이 진행중인 경우에는 해당 수사·조사 종료시까지. 두번째. 홈페이지 이용에 따른 채권·채무관계 잔존시에는 해당 채권·채무관계 정산시까지"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="Static99_00_00_00_00_01_01_01_00_00_00" taborder="25" left="314" top="divContent02_00_00:0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="336" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staContent02_00_00_00" taborder="26" text="[ 개인정보 수집․이용에 대한 동의를 거부할 권리 ]" left="18" top="Static99_00_00_00_00_01_01_01_00_00_00:-3" width="381" height="20" cssclass="sta_WF_InfoTit01" initvalueid="ivStcAccessibilityOn" accessibilitylabel="개인정보 수집·이용에 대한 동의를 거부할 권리"/>
        <Static id="staGd14_00_00_00" taborder="27" left="314" top="staContent02_00_00_00:0" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="150" height="10"/>
        <Div id="divContent02_00_00_00" taborder="10" left="20" height="70" cssclass="div_WF_InfoBOX" right="20" top="staGd14_00_00_00:0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staContent00" taborder="0" left="24" top="3" cssclass="sta_WF_Black14" text="귀하가 방과후학교 지원서비스에 해당의 정보를 제공하기 원하지 않을 경우 귀하는 고유식별정보를 포함한 개인정보의 수집․이용에 대한 동의를 거부할 수 있으며, 동의 거부시에는 방과후학교 지원서비스 이용이 제한됩니다." wordWrap="char" right="20" initvalueid="ivStcAccessibilityOn" bottom="3" accessibilitylabel="귀하가 방과후학교 지원서비스에 해당의 정보를 제공하기 원하지 않을 경우 귀하는 고유식별정보를 포함한 개인정보의 수집.이용에 대한 동의를 거부할 수 있으며, 동의 거부시에는 방과후학교 지원서비스 이용이 제한됩니다."/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="Static99_00_00_00_00_01_00_00_01_00_01_00_00" taborder="28" left="20" top="divContent02_00_00_00:0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_00_00_01_00_01_00_00_00" taborder="29" left="20" top="1010" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Button id="btnClose" taborder="12" text="확인" left="47.50%" width="50" height="30" top="Static99_00_00_00_00_01_00_00_01_00_01_00_00_00:0" initvalueid="ivBtnAccessibilityButton" onclick="btnClose_onclick" accessibilitylabel="확인"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_01" taborder="15" left="20" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_01_00_00_00" taborder="13" left="0" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="89" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_00_00_00_01_00_00_00_00" taborder="14" top="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" width="20" bottom="89" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="Static99_00_00_00_00_01_00_00_01_00_01_00_01" taborder="30" left="20" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="20" initvalueid="ivStcAccessibilityOff" top="btnClose:0"/>
        <Static id="staGd01_00" taborder="16" left="315" top="42" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="150"/>
        <Div id="divContent02_00_00_00_00" taborder="11" left="20" cssclass="div_WF_InfoBOX" right="20" top="Static99_00_00_00_00_01_00_00_01_00_01_00_00:0" initvalueid="ivDivAccessibilityOff" height="40">
          <Layouts>
            <Layout>
              <Static id="staContent00" taborder="0" left="24" top="3" cssclass="sta_WF_Black14" text="개인정보의 수집 및 이용목적에 동의하십니까?" wordWrap="char" right="409" initvalueid="ivStcAccessibilityOn" bottom="3" accessibilitylabel="개인정보의 수집 및 이용목적에 동의하십니까?"/>
