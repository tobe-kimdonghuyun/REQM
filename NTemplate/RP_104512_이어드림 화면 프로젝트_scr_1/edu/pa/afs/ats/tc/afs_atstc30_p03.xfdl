        <Div id="divSearch" taborder="4" left="20" top="sta01:0" height="70" cssclass="div_WF_Search" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staAyr" taborder="0" text="학년도" left="0" top="20" width="71" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" accessibilitylabel="학년도"/>
              <Edit id="edtAyr" taborder="1" left="staAyr:0" width="120" height="30" top="20" initvalueid="ivEdtNormal" readonly="true" accessibilitylabel="학년도 입력"/>
              <Static id="staAslSem" taborder="2" text="기간명" left="edtAyr:0" top="20" width="71" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" accessibilitylabel="기간명"/>
              <Edit id="edtAslSem" taborder="3" left="262" width="120" height="30" top="20" initvalueid="ivEdtNormal" readonly="true" accessibilitylabel="기간명 입력"/>
