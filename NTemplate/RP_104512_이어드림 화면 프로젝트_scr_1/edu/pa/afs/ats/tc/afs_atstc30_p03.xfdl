              <Edit id="edtAslLectNm" taborder="5" left="staAslLectNm:0" width="153" height="30" top="20" initvalueid="ivEdtNormal" readonly="true" accessibilitylabel="프로그램명 입력"/>
              <Static id="staTiYmd" taborder="6" text="수업기간" left="edtAslLectNm:0" top="21" width="99" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" accessibilitylabel="수업시간"/>
              <Calendar id="calTiYmdBgng" taborder="7" left="staTiYmd:0" top="20" width="130" height="30" value="20190308" dateformat="yyyy.MM.dd " readonly="true" initvalueid="ivCalEssential" cssclass="essential" editformat="yyyy.MM.dd " accessibilitylabel="시작일 선택"/>
              <Static id="Static65" taborder="8" text="~" left="calTiYmdBgng:0" top="20" width="15" height="30" cssclass="sta_WF_AC" initvalueid="ivStcAccessibilityOn"/>
              <Calendar id="calTiYmdEnd" taborder="9" left="Static65:0" top="20" width="130" height="30" value="20190308" dateformat="yyyy.MM.dd " readonly="true" initvalueid="ivCalEssential" cssclass="essential" editformat="yyyy.MM.dd " accessibilitylabel="종료일 선택"/>
              <Button id="btnSearch" taborder="10" text="조회" top="20" width="74" height="30" cssclass="btn_WF_Search03" right="20" initvalueid="ivBtnAccessibilityButton" onclick="divSearch_btnSearch_onclick" visible="false"/>
              <Button id="btnInit" taborder="11" text="초기화" top="20" width="88" height="30" cssclass="btn_WF_Refresh03" onclick="divSearch_btnInit_onclick" right="btnSearch:12" initvalueid="ivBtnAccessibilityOff" visible="false"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta02" taborder="5" left="0" top="divSearch:0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta03" taborder="6" left="0" top="204" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Grid id="grdMain" taborder="7" left="20" top="sta03:0" height="416" autofittype="col" right="20" binddataset="dsCaclReiList" selecttype="cell" initvalueid="ivGrdAccessibilityOn" autoenter="select" onheadclick="grdMain_onheadclick" accessibilitylabel="결보강설정 관리 : 순번, 강의정보, 수업일, 시작시간, 종료시간, 강의실, 결강상태, 보강정보, 수업일, 시작시간, 종료시간, 강의실, 상태 정보 등">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="48"/>
                <Column size="40"/>
                <Column size="130"/>
                <Column size="90"/>
                <Column size="90"/>
                <Column size="120"/>
                <Column size="65"/>
                <Column size="130"/>
                <Column size="90"/>
                <Column size="90"/>
                <Column size="120"/>
                <Column size="65"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell rowspan="2" displaytype="checkboxcontrol" edittype="checkbox"/>
                <Cell col="1" rowspan="2" text="순번"/>
                <Cell col="2" colspan="4" text="강의정보"/>
                <Cell col="6" rowspan="2" text="결강&#13;&#10;상태"/>
                <Cell col="7" colspan="5" text="보강정보"/>
                <Cell row="1" col="2" text="수업일"/>
                <Cell row="1" col="3" text="시작시간"/>
                <Cell row="1" col="4" text="종료시간"/>
                <Cell row="1" col="5" text="강의실"/>
                <Cell row="1" col="7" text="수업일"/>
                <Cell row="1" col="8" text="시작시간"/>
                <Cell row="1" col="9" text="종료시간"/>
                <Cell row="1" col="10" text="강의실"/>
                <Cell row="1" col="11" text="상태"/>
              </Band>
              <Band id="body">
                <Cell displaytype="expr:(caclAprvPrgStsCd == '1' &amp;&amp; reiAprvPrgStsCd == '1') || caclAprvPrgStsCd == '2' || reiAprvPrgStsCd == '2' || caclAprvPrgStsCd == '4' || reiAprvPrgStsCd == '4'|| (caclAprvPrgStsCd == '3' &amp;&amp; reiAprvPrgStsCd == '1') ? 'checkboxcontrol' : 'none'" edittype="expr:(caclAprvPrgStsCd == '1' &amp;&amp; reiAprvPrgStsCd == '1') || caclAprvPrgStsCd == '2' || reiAprvPrgStsCd == '2' || caclAprvPrgStsCd == '4' || reiAprvPrgStsCd == '4'|| (caclAprvPrgStsCd == '3' &amp;&amp; reiAprvPrgStsCd == '1') ? 'checkbox' : 'none'" text="bind:chk" maskeditautoselect="true"/>
                <Cell col="1" text="expr:currow + 1" textAlign="center"/>
                <Cell col="2" textAlign="center" text="bind:caclTiYmd" displaytype="date" calendareditformat="yyyy.MM.dd" calendardateformat="yyyy.MM.dd"/>
                <Cell col="3" text="bind:caclAslLectBgngHm" textAlign="center" displaytype="mask" maskeditformat="##:##" maskedittype="string"/>
                <Cell col="4" text="bind:caclAslLectEndHm" textAlign="center" displaytype="mask" maskeditformat="##:##" maskedittype="string"/>
                <Cell col="5" textAlign="left" text="bind:caclClrmNm"/>
                <Cell col="6" text="bind:caclAprvPrgStsNm" textAlign="center"/>
                <Cell col="7" textAlign="center" calendardisplayinvalidtype="none" text="bind:reiTiYmd" maskeditautoselect="true" displaytype="expr:(caclAprvPrgStsCd == '1' &amp;&amp; reiAprvPrgStsCd == '1') ? 'calendarcontrol' : ((caclAprvPrgStsCd == '3' || caclAprvPrgStsCd == '4') &amp;&amp; (reiAprvPrgStsCd == '1' || reiAprvPrgStsCd == '4')) ? 'calendarcontrol' : 'mask'" edittype="expr:(caclAprvPrgStsCd == '1' &amp;&amp; reiAprvPrgStsCd == '1') ? 'date' : ((caclAprvPrgStsCd == '3' || caclAprvPrgStsCd == '4') &amp;&amp; (reiAprvPrgStsCd == '1' || reiAprvPrgStsCd == '4')) ? 'date' : 'none'" maskeditformat="####.##.##" maskedittype="string" calendareditformat="yyyy.MM.dd" calendardisplaynulltype="none" calendarautoselect="true"/>
                <Cell col="8" text="bind:reiAslLectBgngHm" edittype="expr:(caclAprvPrgStsCd == '1' &amp;&amp; reiAprvPrgStsCd == '1') ? 'mask' : ((caclAprvPrgStsCd == '3' || caclAprvPrgStsCd == '4') &amp;&amp; (reiAprvPrgStsCd == '1' || reiAprvPrgStsCd == '4')) ? 'mask' : 'none'" textAlign="center" editmaxlength="2" editinputtype="digit" editautoselect="true" displaytype="expr:(caclAprvPrgStsCd == '1' &amp;&amp; reiAprvPrgStsCd == '1') ? 'maskeditcontrol' : ((caclAprvPrgStsCd == '3' || caclAprvPrgStsCd == '4') &amp;&amp; (reiAprvPrgStsCd == '1' || reiAprvPrgStsCd == '4')) ? 'maskeditcontrol' : 'mask'" maskeditformat="##:##" maskeditautoselect="true" maskedittype="string"/>
                <Cell col="9" displaytype="expr:(caclAprvPrgStsCd == '1' &amp;&amp; reiAprvPrgStsCd == '1') ? 'maskeditcontrol' : ((caclAprvPrgStsCd == '3' || caclAprvPrgStsCd == '4') &amp;&amp; (reiAprvPrgStsCd == '1' || reiAprvPrgStsCd == '4')) ? 'maskeditcontrol' : 'mask'" edittype="expr:(caclAprvPrgStsCd == '1' &amp;&amp; reiAprvPrgStsCd == '1') ? 'mask' : ((caclAprvPrgStsCd == '3' || caclAprvPrgStsCd == '4') &amp;&amp; (reiAprvPrgStsCd == '1' || reiAprvPrgStsCd == '4')) ? 'mask' : 'none'" text="bind:reiAslLectEndHm" textAlign="center" editmaxlength="2" editinputtype="digit" editautoselect="true" maskeditformat="##:##" maskedittype="string" maskeditautoselect="true"/>
                <Cell col="10" textAlign="left" displaytype="expr:(caclAprvPrgStsCd == '1' &amp;&amp; reiAprvPrgStsCd == '1') ? 'combocontrol' : ((caclAprvPrgStsCd == '3' || caclAprvPrgStsCd == '4') &amp;&amp; (reiAprvPrgStsCd == '1' || reiAprvPrgStsCd == '4')) ? 'combocontrol' : 'combotext'" edittype="expr:(caclAprvPrgStsCd == '1' &amp;&amp; reiAprvPrgStsCd == '1') ? 'combo' : ((caclAprvPrgStsCd == '3' || caclAprvPrgStsCd == '4') &amp;&amp; (reiAprvPrgStsCd == '1' || reiAprvPrgStsCd == '4')) ? 'combo' : 'none'" combodataset="dsClrmCd" combocodecol="unyCdValue" combodatacol="unyCdValueNm" text="bind:reiClrmCd" combotype="dropdown" maskeditautoselect="true" comboautoselect="true"/>
                <Cell col="11" textAlign="center" text="bind:reiAprvPrgStsNm"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="btnAprvDmnd" taborder="8" text="승인요청" top="sta02:0" height="30" fittocontents="width" cssclass="btn_WF_Custom" visible="true" right="104" width="76" onclick="btnAprvDmnd_onclick"/>
        <Button id="btnDmndRtrcn" taborder="9" text="요청취소" top="sta02:0" height="30" fittocontents="width" cssclass="btn_WF_Custom" visible="true" right="20" width="76" onclick="btnDmndRtrcn_onclick"/>
        <Static id="sta04" taborder="10" left="0" top="grdMain:0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" height="20"/>
        <Button id="btnClose" taborder="11" text="닫기" height="30" width="50" left="47.5%" initvalueid="ivBtnAccessibilityButton" top="sta04:0" onclick="btnClose_onclick" accessibilitylabel="닫기"/>
        <Static id="sta05" taborder="12" left="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" top="680" height="20"/>
        <Static id="sta00_00_00_00_00_00" taborder="13" text="※ 결강 처리만 진행하는 경우 보강정보 입력 없이 승인요청해주시기 바랍니다." left="20" top="sta02:4" width="550" height="20" onclick="sta00_00_00_00_00_00_onclick" cssclass="sta_WF_Black14" accessibilitylabel="결강 처리만 진행하는 경우 보강정보 입력 없이 승인요청해주시기 바랍니다."/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    방과후학교(외부강사) > 결보강설정
*  @FileName 	afs_atstc30_p03.xfdl
*  @Creator 	김민성
*  @CreateDate 	2022.05.20
*  @Desction    방과후학교(외부강사) 결보강설정
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.05.10            김민성                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::afs_script.xjs"


/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/



/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	
	//파라메터세팅
	this.pv_params = this.smfGetPopupParams();
	this.dsSearch.copyRow(0, this.pv_params.dsPgm, 0);
	
	this.fnInitTiYmd();
	
	this.dsCd.setColumn(0, "cddcCd",       this.dsSearch.getColumn(0, "cddcCd"));
	this.dsCd.setColumn(0, "shlCd",        this.dsSearch.getColumn(0, "shlCd"));
	this.dsCd.setColumn(0, "ayr",          this.dsSearch.getColumn(0, "ayr"));
	this.dsCd.setColumn(0, "cntnCtpvScCd", this.dsSearch.getColumn(0, "cntnCtpvScCd"));
	this.dsCd.setColumn(0, "scaSysScCd",   this.dsSearch.getColumn(0, "scaSysScCd"));
	
	this.afsfCodeList(this.dsCd);
	
	this.afsfMakeHour(this.dsHour, "", "", "N");
	this.afsfMakeMin(this.dsMin, "", "", "N");
	
	
	console.log("'"+this.dsHour.getColumn(0,0)+"'" );
	console.log("'"+this.dsCaclReiList.getColumn(0,"reiAslLectBgngHh")+"'" );
	this.dsCaclReiList.setColumn(0,"reiAslLectBgngHh","");
	
	this.fnListSearch();
};


/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/




/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
	if(svcid == "listClrmCd"){
		console.log("fnTransCallback : "+ svcid);
		console.log(this.dsClrmCd.saveXML());
	}
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnInitTiYmd = function(){
	var sToday = this.smfToday();
	this.dsSearch.setColumn(0, "tiYmdBgng", sToday);
	this.dsSearch.setColumn(0, "tiYmdEnd",  this.smfAddDate(sToday, 7));
}

/**
 * 프로그램별 강의시간 조회
 */
this.fnListSearch = function(){
	// 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});
}

/**
 * 결보강 승인요청
 */
this.fnAprvDmnd = function(){
    // 조회된 행이 없는 경우
	if(this.dsCaclReiList.rowcount ==0){
		this.smfAlert('PA002'); // 조회된 자료가 없습니다.
		return;
	}
	// 체크된 행이 존재하는 지 체크
	var nRow = this.dsCaclReiList.findRowExpr( "chk == 1" );
	if(nRow == -1){
		this.smfAlert('PA003', ['승인요청 할 데이타가'] ); // 승인요청 할 데이타가 없습니다.
		return;
	}

	// 보강정보 중 일부만 있는지 체크
	for(var nIdx=0; nIdx<this.dsCaclReiList.rowcount; nIdx++){
		if(this.dsCaclReiList.getColumn(nIdx, "chk") == 1){
			var caclAprvPrgStsCd  = this.nvl(this.dsCaclReiList.getColumn(nIdx, "caclAprvPrgStsCd"), "");
			var reiAprvPrgStsCd   = this.nvl(this.dsCaclReiList.getColumn(nIdx, "reiAprvPrgStsCd"), "");
			var reiTiYmd          = this.nvl(this.dsCaclReiList.getColumn(nIdx, "reiTiYmd"),         "");        
			var reiAslLectBgngHm  = this.nvl(this.dsCaclReiList.getColumn(nIdx, "reiAslLectBgngHm"), "");
			var reiAslLectEndHm   = this.nvl(this.dsCaclReiList.getColumn(nIdx, "reiAslLectEndHm"),  "");
			var reiClrmCd         = this.nvl(this.dsCaclReiList.getColumn(nIdx, "reiClrmCd"),        "");
			
			if(caclAprvPrgStsCd == "2" || reiAprvPrgStsCd == "2"){ // 결강, 보강 중 하나가 신청일 경우
				this.smfAlert('PA003', [(nIdx+1)+'행은 결강/보강이 신청 중입니다. 신청할 수'] ); // (nIdx+1)+'행은 결강/보강이 신청 중입니다. 신청할 수 없습니다.
				return;
			}
			// 입력된 보강정보가 있는지 확인
			if(caclAprvPrgStsCd == "3" || (reiTiYmd != "" || reiAslLectBgngHm != "" || reiAslLectEndHm != "" || reiClrmCd != "")){ 
			    // 보강정보가 모두 입력되었는지확인
				if(reiTiYmd == "" || reiAslLectBgngHm == "" || reiAslLectEndHm == "" || reiClrmCd == ""){ 
					this.smfAlert('PA006', [(nIdx+1)+'행의 보강정보를'] ); // (nIdx+1)+'행의 보강정보를  확인하세요.
					return;
				}
				
				if(!this.smfIsDate(reiTiYmd)){
					this.smfAlert('PA006', [(nIdx+1)+'행의 보강정보 수업일을'] ); // (nIdx+1)+'행의 보강정보 수업일을  확인하세요.
					return;
				}
				if(reiAslLectBgngHm.length != 4 || reiAslLectBgngHm.substring(0, 2) > 23 || reiAslLectBgngHm.substring(2, 4) > 59){
					this.smfAlert('PA006', [(nIdx+1)+'행의 보강정보 시작시간을'] ); // (nIdx+1)+'행의 보강정보 시작시간을  확인하세요.
					return;
				}
				
				if(reiAslLectEndHm.length != 4 || reiAslLectEndHm.substring(0, 2) > 23 || reiAslLectEndHm.substring(2, 4) > 59){
					this.smfAlert('PA006', [(nIdx+1)+'행의 보강정보 종료시간을'] ); // (nIdx+1)+'행의 보강정보 종료시간을  확인하세요.
					return;
				}
				
				// 강의기간 중인지 체크
				if(this.dsSearch.getColumn(0, "aslLectBgngYmd") > reiTiYmd || this.dsSearch.getColumn(0, "aslLectEndYmd") < reiTiYmd){
					this.smfAlert((nIdx+1)+"행의 보강정보 수업일을 강의기간 중으로 설정해주세요.");
					return;
				}
				
				if(reiAslLectBgngHm > reiAslLectEndHm){
					this.smfAlert((nIdx+1)+"행의 보강정보 시작시간이 종료시간보다 클 수 없습니다."); 
					return;
				}
				// 동일날짜 강의정보 존재여부 -- 같은날짜의 강의가 들어올 수 있는 상황 발생시 제거
				var caclList = this.dsCaclReiList.extractRows("caclAprvPrgStsCd != '3' && caclTiYmd=='"+reiTiYmd+"'");
				for(var nJdx=0; nJdx<caclList.length; nJdx++){
					if(nIdx != caclList[nJdx]){
						this.smfAlert((caclList[nJdx]+1)+"행에 같은날 강의정보가 존재합니다.");
						return;
					}
				}
				var reiList = this.dsCaclReiList.extractRows("reiTiYmd=='"+reiTiYmd+"'");
				for(var nJdx=0; nJdx<reiList.length; nJdx++){
					if(nIdx != reiList[nJdx]){
						this.smfAlert((reiList[nJdx]+1)+"행에 같은날 강의정보가 존재합니다.");
						return;
					}
				}

				
				// 중복체크 (강의정보 중 중복체크) -- 같은날짜의 강의가 들어올 수 있는 상황 발생시 다시 복구
				/*var caclList = this.dsCaclReiList.extractRows("caclAprvPrgStsCd != '3' && caclTiYmd=='"+reiTiYmd+"' && caclClrmCd=='"+reiClrmCd+"'");
				for(var nJdx=0; nJdx<caclList.length; nJdx++){
					if(nIdx != caclList[nJdx]){
						if(this.dsCaclReiList.getColumn(caclList[nJdx], "caclAslLectBgngHm") <= reiAslLectBgngHm && this.dsCaclReiList.getColumn(caclList[nJdx], "caclAslLectEndHm") >= reiAslLectBgngHm){
							this.smfAlert((caclList[nJdx]+1)+"행의 강의정보와 중복이 발생하였습니다.");
							return;
						}
						
						if(this.dsCaclReiList.getColumn(caclList[nJdx], "caclAslLectBgngHm") <= reiAslLectEndHm && this.dsCaclReiList.getColumn(caclList[nJdx], "caclAslLectEndHm") >= reiAslLectEndHm){
							this.smfAlert((caclList[nJdx]+1)+"행의 강의정보와 중복이 발생하였습니다.");
							return;
						}
					}
				}*/
				
				// 중복체크 (보강정보 중 중복체크) -- 같은날짜의 강의가 들어올 수 있는 상황 발생시 다시 복구
				/*var reiList = this.dsCaclReiList.extractRows("reiTiYmd=='"+reiTiYmd+"' && reiClrmCd=='"+reiClrmCd+"'");
				for(var nJdx=0; nJdx<reiList.length; nJdx++){
					if(nIdx != reiList[nJdx]){
						if(this.dsCaclReiList.getColumn(reiList[nJdx], "reiAslLectBgngHm") <= reiAslLectBgngHm && this.dsCaclReiList.getColumn(reiList[nJdx], "reiAslLectEndHm") >= reiAslLectBgngHm){
							this.smfAlert((reiList[nJdx]+1)+"행의 보강정보와 중복이 발생하였습니다.");
							return;
						}
						
						if(this.dsCaclReiList.getColumn(reiList[nJdx], "reiAslLectBgngHm") <= reiAslLectEndHm && this.dsCaclReiList.getColumn(reiList[nJdx], "reiAslLectEndHm") >= reiAslLectEndHm){
							this.smfAlert((reiList[nJdx]+1)+"행의 보강정보와 중복이 발생하였습니다.");
							return;
						}
					}
				}*/
			}
		}
	}
	// 서비스 객체 생성
	this.smfSaveService("save")
		.messagePrefix(["승인요청"])
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.smfAlert('PA001', ['승인요청'], this.callback ); // 승인요청 되었습니다.
		});
}
 
/**
 * 외부강사 신청취소
 */
this.fnDmndRtrcn = function(){
	
    // 조회된 행이 없는 경우
	if(this.dsCaclReiList.rowcount ==0){
		this.smfAlert('PA002'); // 조회된 자료가 없습니다.
		return;
	}
	
	// 체크된 행이 존재하는 지 체크
	var nRow = this.dsCaclReiList.findRowExpr( "chk == 1" );
	if(nRow == -1){
		this.smfAlert('PA003', ['요청취소 할 데이타가'] ); // 요청취소 할 데이타가 없습니다.
		return;
	}
	// 체크된 행의 상태 정보 체크
	for(var nIdx=0; nIdx<this.dsCaclReiList.rowcount; nIdx++){
		if(this.dsCaclReiList.getColumn(nIdx, "chk") == 1){
			var caclAprvPrgStsCd       = this.nvl(this.dsCaclReiList.getColumn(nIdx, "caclAprvPrgStsCd"), "");        
			var reiAprvPrgStsCd        = this.nvl(this.dsCaclReiList.getColumn(nIdx, "reiAprvPrgStsCd"),  "");
			
			// 결강, 보강 신청한 이력이 없거나 신청상태가 아닌 경우
			if((caclAprvPrgStsCd == "" && reiAprvPrgStsCd == "") || (caclAprvPrgStsCd != "2" &&  reiAprvPrgStsCd != "2") ){ 
				this.smfAlert('PA003', [(nIdx+1)+'행은 요청취소할 수'] ); // (nIdx+1)+'행은 요청취소할 수 없습니다.
				return;
			}
		}
	}
	// 서비스 객체 생성
	this.smfDeleteService("delete")
		.messagePrefix(["요청취소"])
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.smfAlert('PA001', ['요청취소'], this.callback ); // 요청취소 되었습니다.
		});
}
