};
// 요청취소버튼
this.btnDmndRtrcn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnDmndRtrcn();
};
// 승인요청버튼
this.btnAprvDmnd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnAprvDmnd();
};
// 닫기버튼
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};
// 그리드값변경
this.dsCaclReiList_onvaluechanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	
};

this.grdMain_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if (e.col == 0){
		this.smfToggleChkHeader(obj, e);
	}
};

this.sta00_00_00_00_00_00_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	
};
