<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="form" width="900" height="660" titletext="수강생목록" nHeight="754" onload="form_onload">
    <Layouts>
      <Layout height="660" width="900" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divTitle" taborder="1" left="0" top="20" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="수강생목록" left="20" top="0" height="44" cssclass="img_WF_SubTit01" width="170" initvalueid="ivTitleAccessibilityOn" accessibilitylabel="수강생 목록"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staInfo" taborder="3" left="0" top="174" width="230" height="26" cssclass="sta_WF_Total" fittocontents="width" initvalueid="ivStcAccessibilityOn"/>
        <Grid id="grdMain" taborder="4" left="20" top="174" height="416" autofittype="col" right="20" binddataset="dsAtnlcStuList" selecttype="cell" initvalueid="ivGrdAccessibilityOn" autoenter="select" accessibilitylabel="수강생목록 관리: 순번, 원적교, 학년, 반, 번호, 이름 정보 등">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="40"/>
                <Column size="150"/>
                <Column size="80"/>
                <Column size="100"/>
                <Column size="80"/>
                <Column size="120"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="순번"/>
                <Cell col="1" text="원적교"/>
                <Cell col="2" text="학년"/>
                <Cell col="3" text="반"/>
                <Cell col="4" text="번호"/>
                <Cell col="5" text="이름"/>
              </Band>
              <Band id="body">
                <Cell text="expr:currow + 1" textAlign="center"/>
                <Cell col="1" textAlign="center" calendardisplaynulltype="none" calendardisplayinvalidtype="none" calendardateformat="yyyy-MM-dd" text="bind:enrShlCdNm"/>
                <Cell col="2" combodataset="dsHour" combocodecol="unyCdValue" combodatacol="unyCdValueNm" combotype="dropdown" combodisplaynulltext="- 선택 -" combodisplaynulltype="nulltext" textAlign="center" expr="(ordNm != null) ? ordNm+&quot;/&quot;+grd+&quot;/&quot;+dddepNm : grd"/>
                <Cell col="3" combodataset="dsHour" combocodecol="unyCdValue" combodatacol="unyCdValueNm" text="bind:clsNm" combotype="dropdown" combodisplaynulltext="- 선택 -" combodisplaynulltype="nulltext" textAlign="center"/>
                <Cell col="4" textAlign="center" combocodecol="unyCdValue" combodatacol="unyCdValueNm" combodataset="dsClrmCd" text="bind:clsNo" combotype="dropdown" combodisplaynulltext="- 선택 -" combodisplaynulltype="nulltext"/>
                <Cell col="5" text="bind:stuFlnm"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="sta_main" taborder="6" left="0" top="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta01" taborder="7" left="0" top="divTitle:0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta04" taborder="9" left="0" top="grdMain:0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" height="20"/>
        <Div id="divSearch" taborder="2" left="20" top="sta01:0" height="70" cssclass="div_WF_Search" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staAslLectNm" taborder="4" text="프로그램명" left="394" top="20" width="99" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" accessibilitylabel="프로그램명"/>
              <Edit id="edtAslLectNm" taborder="5" left="staAslLectNm:0" width="153" height="30" top="20" initvalueid="ivEdtNormal" readonly="true" accessibilitylabel="프로그램명 입력"/>
              <Static id="staAyr" taborder="0" text="학년도" left="0" top="20" width="77" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" accessibilitylabel="학년도"/>
              <Static id="staAslSem" taborder="2" text="기간명" left="197" top="20" width="77" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" accessibilitylabel="기간명"/>
              <Edit id="edtAyr" taborder="1" left="staAyr:0" width="120" height="30" top="20" initvalueid="ivEdtNormal" readonly="true" accessibilitylabel="학년도 입력"/>
              <Edit id="edtAslSem" taborder="3" left="staAslSem:0" width="120" height="30" top="20" initvalueid="ivEdtNormal" readonly="true" accessibilitylabel="기간명 입력"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta02" taborder="8" left="0" top="154" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta05" taborder="10" left="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" top="640" height="20"/>
        <Button id="btnClose" taborder="5" text="닫기" height="30" width="50" left="47.5%" initvalueid="ivBtnAccessibilityButton" top="sta04:0" onclick="btnClose_onclick" accessibilitylabel="닫기"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    방과후학교(외부강사) > 결보강설정
*  @FileName 	afs_atstc30_p03.xfdl
*  @Creator 	김민성
*  @CreateDate 	2022.05.20
*  @Desction    방과후학교(외부강사) 결보강설정
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.05.10            김민성                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::afs_script.xjs"


/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/



/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	
	//파라메터세팅
	this.pv_params = this.smfGetPopupParams();
	this.dsSearch.copyRow(0, this.pv_params.dsPgm, 0);
	
	if(this.dsSearch.getColumn(0, "scaSysScCd") == "HIS"){
		this.grdMain.setCellProperty("head", 2, "text", "계열/학년/학과"); 
		this.grdMain.setFormatColProperty(2, "size", 120);
	}
	this.fnListSearch();
};



/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/




/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * 프로그램별 강의시간 조회
 */
this.fnListSearch = function(){
	// 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// 닫기버튼
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};
]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">list</Col>
            <Col id="url">/afs_ats_tc30_008.do</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsAtnlcStuList=dsAtnlcStuList</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsAtnlcStuList" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="shlCd" type="STRING" size="256"/>
          <Column id="shlCdNm" type="STRING" size="256"/>
          <Column id="lectIdfNo" type="STRING" size="256"/>
          <Column id="enrShlCd" type="STRING" size="256"/>
          <Column id="enrShlCdNm" type="STRING" size="256"/>
          <Column id="grd" type="STRING" size="256"/>
          <Column id="dddepNm" type="STRING" size="256"/>
          <Column id="ordNm" type="STRING" size="256"/>
          <Column id="clsNm" type="STRING" size="256"/>
          <Column id="clsNo" type="STRING" size="256"/>
          <Column id="stuFlnm" type="STRING" size="256"/>
          <Column id="midAplyYmd" type="STRING" size="256"/>
          <Column id="atnlcAplyPrcsStsCd" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSearch">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="shlCd" type="STRING" size="256"/>
          <Column id="ayr" type="STRING" size="256"/>
          <Column id="ayrNm" type="STRING" size="256"/>
          <Column id="aslSem" type="STRING" size="256"/>
          <Column id="aslSemNm" type="STRING" size="256"/>
          <Column id="lectIdfNo" type="STRING" size="256"/>
          <Column id="aslLectNm" type="STRING" size="256"/>
          <Column id="aslLectBgngYmd" type="STRING" size="256"/>
          <Column id="aslLectEndYmd" type="STRING" size="256"/>
          <Column id="tiYmdBgng" type="STRING" size="256"/>
          <Column id="tiYmdEnd" type="STRING" size="256"/>
          <Column id="cntnCtpvScCd" type="STRING" size="256"/>
          <Column id="scaSysScCd" type="STRING" size="256"/>
          <Column id="atnlcAplyPrcsStsCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="shlCd"/>
            <Col id="ayr"/>
            <Col id="aslSem"/>
            <Col id="aslLectEndYmd"/>
            <Col id="aslLectBgngYmd"/>
            <Col id="aslLectNm"/>
            <Col id="lectIdfNo"/>
            <Col id="aslSemNm"/>
            <Col id="ayrNm"/>
            <Col id="cddcCd"/>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.edtAyr" propid="value" datasetid="dsSearch" columnid="ayr"/>
      <BindItem id="item1" compid="divSearch.form.edtAslSem" propid="value" datasetid="dsSearch" columnid="aslSemNm"/>
      <BindItem id="item3" compid="divSearch.form.edtAslLectNm" propid="value" datasetid="dsSearch" columnid="aslLectNm"/>
    </Bind>
  </Form>
</FDL>
