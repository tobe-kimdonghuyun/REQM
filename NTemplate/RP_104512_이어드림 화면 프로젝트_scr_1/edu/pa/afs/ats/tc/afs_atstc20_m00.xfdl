<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="form" width="1200" height="790" titletext="활동확인서신청관리" nHeight="754" onload="form_onload">
    <Layouts>
      <Layout height="790" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="65" height="54" text="" right="0">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="활동확인서신청관리" left="0" top="0" height="54" cssclass="img_WF_SubTit01" width="280" initvalueid="ivTitleAccessibilityOn" accessibilitylabel="활동확인서 신청관리"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divSearch" taborder="1" left="0" top="144" height="70" cssclass="div_WF_Search" right="0" accessibilityenable="false" accessibilityrole="none" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout initvalueid="ivDivAccessibilityOff">
              <Static id="staShlCd" taborder="0" text="학교명" left="0" top="20" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" accessibilitylabel="학교명" width="68"/>
              <Combo id="cboShlCd" taborder="1" left="68" width="144" height="30" index="0" top="20" initvalueid="ivCmbNormal" text="" value="" innerdataset="dsShlCd" codecolumn="unyCdValue" datacolumn="unyCdValueNm" displaynulltext="- 선택 -  " accessibilitylabel="학교명 선택"/>
              <Static id="staAprvYn" taborder="2" text="신청상태" left="212" top="20" width="81" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" accessibilitylabel="상태"/>
              <Combo id="cboAprvYn" taborder="3" left="293" width="144" height="30" innerdataset="dsAprvYn" codecolumn="unyCdValue" datacolumn="unyCdValueNm" index="0" top="20" value="" initvalueid="ivCmbNormal" text="- 전체 -" onitemchanged="divSearch_cboAslAplyStsScCd_onitemchanged" accessibilitylabel="신청상태 선택"/>
              <Button id="btnInit" taborder="4" text="초기화" top="20" width="88" height="30" cssclass="btn_WF_Refresh03" onclick="divSearch_btnInit_onclick" right="100" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="초기화"/>
              <Button id="btnSearch" taborder="5" text="조회" top="20" width="72" height="30" cssclass="btn_WF_Search03" right="20" onclick="btnSearch_onclick" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="조회"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="sta00_00_00_00_00_00" taborder="11" text="* &quot;발급가능일시&quot;에 표시된 일시까지 발급할 수 있습니다.&#13;&#10;* 본 서류는 개인위탁 외부강사의 프로그램 활동에 대한 확인서임을 안내드립니다." left="0" top="220" width="732" height="40" cssclass="sta_WF_Red14" accessibilitylabel="발급가능일시 에 표시된 일시까지 발급할 수 있습니다. 본 서류는 개인위탁 외부강사의 프로그램 활동에 대한 확인서임을 안내드립니다."/>
        <Static id="sta02" taborder="8" left="0" top="sta00_00_00_00_00_00:0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Button id="btnIssuAply" taborder="2" text="발급신청" top="sta02:0" height="30" width="76" cssclass="btn_WF_Custom" right="84" onclick="btnIssuAply_onclick" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="발급신청"/>
        <Button id="btnAplyRtrcn" taborder="3" text="신청취소" top="sta02:0" height="30" width="76" cssclass="btn_WF_Custom" right="0" onclick="btnAplyRtrcn_onclick" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="신청취소"/>
        <Static id="sta03" taborder="9" left="0" top="btnIssuAply:0" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Grid id="grdMain" taborder="4" left="0" top="sta03:0" height="449" autofittype="col" right="0" selecttype="cell" initvalueid="ivGrdAccessibilityOn" binddataset="dsActCftAplyList" onheadclick="grdInsrList_onheadclick" oncellclick="grdMain_oncellclick" accessibilitylabel="활동확인서신청관리 : 순번,학교명,신청번호,신청일시,신청상태, 발급가능일시, 발급번호, 발급일시, 발급상태 등의 정보제공">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="48"/>
                <Column size="40"/>
                <Column size="140"/>
                <Column size="120"/>
                <Column size="137"/>
                <Column size="80"/>
                <Column size="120"/>
                <Column size="150"/>
                <Column size="120"/>
                <Column size="73"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell displaytype="checkboxcontrol"/>
                <Cell col="1" text="순번"/>
                <Cell col="2" text="학교명"/>
                <Cell col="3" text="신청번호"/>
                <Cell col="4" text="신청일시"/>
                <Cell col="5" text="신청상태"/>
                <Cell col="6" text="발급가능일시"/>
                <Cell col="7" text="발급번호"/>
                <Cell col="8" text="발급일시"/>
                <Cell col="9" text="발급상태" cssclass="LineNo"/>
              </Band>
              <Band id="body">
                <Cell displaytype="expr:(aprvYn == 'N' &amp;&amp; aprvDt == null) ? 'checkboxcontrol' : 'none'" edittype="expr:(aprvYn == 'N' &amp;&amp; aprvDt == null) ? 'checkbox' : 'none'" text="bind:chk"/>
                <Cell col="1" text="expr:currow+1" displaytype="normal" edittype="none" textAlign="center"/>
                <Cell col="2" displaytype="normal" edittype="none" text="bind:shlCdNm"/>
                <Cell col="3" displaytype="normal" edittype="none" text="bind:crtfAplyNo" textAlign="center"/>
                <Cell col="4" text="bind:crtfAplyDt" textAlign="center" edittype="none" displaytype="date" calendardateformat="yyyy.MM.dd HH:mm:ss" maskeditautoselect="false" maskeditimeaction="next" maskedittype="string" calendareditformat="yyyy.MM.dd HH:mm:ss"/>
                <Cell col="5" text="expr:(aprvYn == 'N' &amp;&amp; aprvDt == null) ? '신청' : (aprvYn == 'Y' &amp;&amp; aprvDt != null) ? '승인' : '반려'" textAlign="center" displaytype="normal"/>
                <Cell col="6" text="bind:issuPslDt" maskedittype="string" displaytype="expr:issuPslDt != null ? 'date' : 'normal'" textAlign="center" calendardateformat="yyyy.MM.dd HH:mm:ss" calendareditformat="yyyy.MM.dd HH:mm:ss"/>
                <Cell col="7" text="bind:issuNo" textAlign="center"/>
                <Cell col="8" text="bind:issuDt" textAlign="center" maskedittype="string" displaytype="expr:issuDt != null ? 'date' : 'normal'" calendardateformat="yyyy.MM.dd HH:mm:ss" calendareditformat="yyyy.MM.dd HH:mm:ss"/>
                <Cell col="9" textAlign="center" accessibilityrole="textarea" displaytype="expr:issuPslCk == 'F' ? 'normal'  : (issuPslCk == 'T'  ?  'buttoncontrol' : 'normal')" text="expr:issuPslCk == 'F' ? '기간만료'  : (issuPslCk == 'T' ?  '출력' : '')" edittype="expr:issuPslCk == 'F' ? 'none'  : (issuPslCk == 'T'  ?  'button' : 'none')" cssclass="LineNo"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="sta04" taborder="5" left="0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" top="grdMain:0"/>
        <Static id="sta_main" taborder="6" left="0" top="0" height="70" cssclass="sta_Ctitle" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta01" taborder="7" left="0" top="114" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta03_00" taborder="10" left="0" top="214" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 > 방과후학교(외부강사) > 활동확인서신청관리
*  @FileName 	afs_atstc20_m00.xfdl 
*  @Creator 	강채윤
*  @CreateDate 	2022.06.21
*  @Desction    방과후학교(외부강사) > 활동확인서신청관리
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.05.10            강채윤                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::afs_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_userId   = ""; //외부강사ID
this.fv_insrRrno = "";
this.fv_cddcCd   = ""; //시도교육청 코드
this.fv_shlCd    = ""; //학교 코드

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	//폼을 초기화
	this.smfInitForm(obj);
	
	this.dsSearch.setColumn(0,'insrScCd', "I");
	this.afsfSetSession(this); 
};



/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 활동확인서신청관리 목록 조회 Transaction
 */
this.fnListAply = function () {

	// 서비스 객체 생성
	this.smfSearchService("listActCftAply")
	// 실행
	.run()
	 
	// 콜백
	.callback(function(callbackParams) {
		if(callbackParams.errors) return; 
	});
}

/**
 * @description 활동확인서 신청 Transaction
 */
this.fnSaveAplyAct = function () {

	// 서비스 객체 생성
	this.smfSaveService("saveAplyAct")
	.messagePrefix(["발급신청"])
	// 실행
	.run()
	 
	// 콜백
	.callback(function(callbackParams) {
		if(callbackParams.errors) return; 
		
		this.smfAlert('PA001', ['신청']); // 신청 되었습니다.
		
		//활동확인서신청관리 목록 재조회
		this.fnListAply();
	});
}

/**
 * @description 활동확인서 신청 취소 Transaction
 */
this.fnDeleteAplyAct = function () {

	// 서비스 객체 생성
	this.smfDeleteService("deleteAplyAct")
	.messagePrefix(["신청취소"])
	//실행전 처리
	.beforeService(function(next) {
		var arrChk = this.dsActCftAplyList.extractRows('chk==1');
		this.dsActCftAplyList.deleteMultiRows(arrChk);
		next();
	})
	
	// 실행
	.run()
	 
	// 콜백
	.callback(function(callbackParams) {
		if(callbackParams.errors) return; 
		this.smfAlert('PA001', ['신청취소']); // 신청취소 되었습니다.
		
		//활동확인서신청관리 목록 재조회
		this.fnListAply();
	});
}

/**
 * @description 활동확인서 출력 Transaction
 */
this.fnSaveAplyIssu = function () {
	
	//서비스 객체 생성
	this.smfSaveService("saveAplyIssu")
	.showConfirm(false)
	//실행
	.run()
	
	//콜백
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		
		//활동확인서신청관리 목록 재조회
		this.fnListAply();
	})
	
	
}
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 /**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback  = function(svcid,errcd,errmsg) {
	if(errcd < 0) { 
		return;
	}
	
	switch(svcid) {	
	
		case "selectSession" : 
			this.divSearch_btnInit_onclick();
			
			this.fv_cddcCd   = this.dsSearch.getColumn(0,"cddcCd"); 	//시도교육청코드 
			this.fv_insrRrno = this.dsSearch.getColumn(0,"insrRrno");
			this.fv_userId   = this.dsSearch.getColumn(0,"userId");
			
			this.dsCd.setColumn(0, "cddcCd",    this.fv_cddcCd);
			this.dsCd.setColumn(0, "insrRrno",  this.fv_insrRrno);
			this.dsCd.setColumn(0, "userId",    this.fv_userId);
			this.afsfCodeList(this.dsCd);
			break;
	}
};   

/**
 * 학교 찾기 팝업 콜백
 */
this.fnPopupCallback = function(context, responseParams, sender){
	if(responseParams.name == "btnIssuAply"){
		this.dsInsert.clearData();
		
		if(context.row.rowcount > 0){
			for(var i=0; i<context.row.rowcount; i++){
				this.dsInsert.addRow();
				this.dsInsert.setColumn(i,'cddcCd',       this.fv_cddcCd);
				this.dsInsert.setColumn(i,'shlCd',        context.row.getColumn(i, "shlCd"));
				this.dsInsert.setColumn(i,'insrRrno',     this.fv_insrRrno);
				this.dsInsert.setColumn(i,'userId',       this.fv_userId);
				this.dsInsert.setColumn(i,'scaSysScCd',   context.row.getColumn(i, "scaSysScCd"));
				this.dsInsert.setColumn(i,'cntnCtpvScCd', this.dsSearch.getColumn(0, 'cntnCtpvScCd'));
			}
			this.fnSaveAplyAct();
		}
	}
};


/**
 * 학교 찾기 팝업 콜백
 */
this.fnReportCallback = function(context, responseParams, sender){
	
}
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnReportView = function()
{
	var sSecurityYN     = "Y";   // 위변조방지 삽입
	var sReportName  = "/edu/pa/afs/ats/tc/afs_atstc20_r01.ozr";

	// 리포트를 생성하기 위한 옵션을 설정한다.
	var oOzOption = {
					    reports : [	
									{	
										// 기본데이터
										  displayname : "활동확인서"  // [필수] 멀티리포트시 Tree에 보여줄 이름
										, reportname  : sReportName  // [필수] 리포트명  "/jsonsample.ozr"
										
										// json연동형
										//  - jsonDs/jsonDsName은 갯수가 같아야 됨
										, jsonDs     : [this.dsActCft, this.dsActCftList, this.dsRltList]   // [선택] json으로 변환할 데이터셋
										, jsonDsName : ["ActCft", "ActCftList", "RltList"]                  // [선택] json으로 변환할 데이터의이름(ozr파일에서 지정된 값과 일치)
										//, jsonParam  : ["viewerType=HTML5 Canvas Viewer 1"]  // [선택] json이외에추가할 데이터(KEY=VALUE형태의 스트링(배열))
										
										// 추가/보안옵션
										, security     : sSecurityYN       // [선택] 위변조방지 삽입   ("Y"(default):표시,"N":비표시)
									}
							      ]
	                };
					
	//리포트를 그린다.
	this.smfReportView(this, "popup", oOzOption, this.fnReportCallback);  // 팝업으로 표시(아직기능구현안됨)
	
	//활동확인서 출력 시 업데이트 처리
	this.fnSaveAplyIssu();
};


/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 조회 버튼 클릭
*/
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//활동확인서 신청관리 목록 조회
	this.fnListAply();
};

/**
 * @description 조회 버튼 클릭
*/
this.divSearch_btnInit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsSearch.setColumn(0, "shlCd",  "");
	this.dsSearch.setColumn(0, "aprvYn", "");
	this.dsSearch.setColumn(0, "eccYn", "Y");
};

/**
 * @description 발급신청 버튼 클릭
*/
this.btnIssuAply_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	/*//조회 조건 필수값(학교명) 미 선택 시 알림
	var shlCdChk = this.divSearch.form.cboShlCd.value;

	if(this.isNil(shlCdChk)){
		this.smfAlert('CM013', ['학교명']); //선택된 학교명이(가) 없습니다. 학교명을(를) 선택하여 주십시오.
		return;
	}
	
	if(this.dsInsert.rowcount == 0){
		this.dsInsert.insertRow();
	}
	
	this.dsInsert.setColumn(0,'cddcCd',   this.fv_cddcCd);
	this.dsInsert.setColumn(0,'shlCd',    this.dsSearch.getColumn(0, "shlCd"));
	this.dsInsert.setColumn(0,'insrRrno', this.fv_insrRrno);
	
	//활동확인서 신청 처리
	this.fnSaveAplyAct();*/
	if(this.isNil(this.fv_insrRrno)){
		this.smfAlert('PA063', ['개인 로그인 후 사용가능']); 
		return;
	}
	this.afsfPopupShl(this.btnIssuAply, this.fnPopupCallback, this.dsSearch);
};

/**
 * @description 신청취소 버튼 클릭
*/
this.btnAplyRtrcn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var arrChk = this.dsActCftAplyList.extractRows('chk==1');
	
	if (arrChk == -1){
		 this.smfAlert('PA002', '', this.callback ); // 조회된 자료가 없습니다.
		 return;
	}
	
	//체크박스 선택 여부 확인
	if (arrChk.length == 0){
		
		this.smfAlert('CM013', ['행']); //선택된 행이(가) 없습니다. 행을(를) 선택하여 주십시오.
		return;
	}
	
	//신청상태가 '신청'인 목록만 삭제
	var chkList2 = this.dsActCftAplyList.extractRows("chk == 1 && aprvYn != 'N'");
	if (chkList2.length > 0){
		this.smfAlert('PA004', ['[신청]상태만 취소가'], this.callback ); // [신청]상태만 취소가 가능합니다.
		return;
	}
	
	//활동확인서 신청 취소처리
	this.fnDeleteAplyAct();
};

/**
 * @description 출력 버튼 클릭
*/
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if(e.col == 9){  //신청승인 상태가 Y이면서, 발급 상태가 N일 때
		var aprvYnChk = this.dsActCftAplyList.getColumn(e.row, "aprvYn");    //승인여부
		var issuYnChk = this.dsActCftAplyList.getColumn(e.row, "issuPslCk"); //발급가능여부
		
		if(aprvYnChk == 'Y' && issuYnChk == 'T'){
			this.smfConfirm('PA005', ['활동확인서를'], function(result){
				if(result.confirmResult){
					this.dsActCftList.clearData();
					
					//선택된 행 상태를 업데이트 처리
					this.dsActCftAplyList.set_updatecontrol(false);
					this.dsActCftAplyList.setRowType(e.row,"U");
					this.dsActCftAplyList.set_updatecontrol(true);
					
					// 서비스 객체 생성
					this.smfSearchService("listActCft")
					// 실행
					.run()
					 
					// 콜백
					.callback(function(callbackParams) {
						console.log("grdMain_oncellclick:"+e.row);
						if(callbackParams.errors) return; 
						
						if(this.dsActCftList.rowcount > 0){
							this.dsActCft.clearData();
							this.dsActCft.addRow();
							
							this.dsActCft.copyRow(0, this.dsActCftList, 0);
							//리포트 화면 표출 추가
							this.fnReportView();
						}else{
							this.smfAlert('PA003', ['경력사항이'], this.callback ); // 경력사항이 없습니다.
							return;
						}
					});
				}
			});
			
			
		}
	}
};

/**
 * @description 그리드 체크박스 헤드 클릭
*/
this.grdInsrList_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{   
	//체크박스 전체 선택 
	this.smfSetGridCheckAll(obj, e, function (ds, nRow){
				if(ds.getColumn(nRow,"aplyYn" )=="N" && ds.getColumn(nRow,"aplyDt" )==null){
					return true;
				}else{
					return false;
				}
			});
};

]]></Script>
