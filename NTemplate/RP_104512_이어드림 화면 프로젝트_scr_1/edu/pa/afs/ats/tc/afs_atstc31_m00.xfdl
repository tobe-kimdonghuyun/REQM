    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    방과후학교(외부강사) > 프로그램 정보 상세 조회
*  @FileName 	afs_atstc31_m00.xfdl 
*  @Creator 	김민성
*  @CreateDate 	2022.06.23
*  @Desction    방과후학교(외부강사) 프로그램 정보 상세 조회
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.06.23            김민성                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/



/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/



/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	
	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
		url : "/afs_ats_tc31_000.do",
	})
	//.mappingRulesetToForm(this.divLectInfo, "lectInfo")
	.callback(function(callbackParams) {
	
    })
    .run()
    ;
	
	//=======================================
	// 업로드관련 초기설정을 한다.
	//=======================================
	// 업로드시 저장위치등을 판별할 정보 세팅(대문자 : 시스템코드(2)+"."+서브시스템코드(3)+"."+대분류코드(3))
	this.divLectInfo.form.divFileUpload.UPLOAD_CreateComplete = this.fnEventUploadCreateComplete;  // 필요한 경우만 세팅
	this.divLectInfo.form.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;        // 필요한 경우만 세팅(세팅권장)
	this.divLectInfo.form.divFileUpload.UPLOAD_OnError        = this.fnEventUploadError;           // 필요한 경우만 세팅(세팅권장)
	this.divLectInfo.form.divFileUpload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)
	this.divLectInfo.form.divFileUpload.UPLOAD_AfterAddFile   = this.fnEventAfterAddFile;
	
	//파라메터세팅
	this.pv_params = this.smfGetPopupParams();
	this.dsSearch.copyRow(0, this.pv_params.dsPgm, 0);
	
	this.fnSelectPgm();
	console.log("form_onload");
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

this.fnEventUploadCreateComplete = function(obj,paramObj)
{
	this.divLectInfo.form.divFileUpload.form.RaonkUpload.SetMaxTotalFileCount(1);
	this.divLectInfo.form.divFileUpload.form.RaonkUpload.SetMaxTotalFileSize("2MB");
	
	this.divLectInfo.form.divFileUpload.form.fnResetBeforeAddNewFile("1");
}

this.fnEventUploadComplete = function(obj,paramObj, objResultDataset)
{
	this.divLectInfo.form.divFileUpload.form.fnSetUploadCompleteState(obj,paramObj);
	
	if(objResultDataset != null){
		this.dsPgm.setColumn(0, "fileRefrnId", objResultDataset.getColumn(0,"fileRefrnId"));
		
		this.dsAttach.assign(objResultDataset);
	}
	this.fnChgAply();
}

this.fnEventUploadError = function(obj,paramObj)
{
	trace("=== Sample : fnEventUploadError");	
	
}

this.fnEventAfterAddFile = function(obj, obj2, paramObj, customValue, fileName, fileSize)
{
	trace("=== Sample : fnEventAfterAddFile");	
	
}

this.smfUploadInfoFileSn = function(sCustomerInfo,nIndex)
{
	return sCustomerInfo.split(",")[nIndex];	
}


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnInit = function(){
	this.dsPgm.set_updatecontrol(false);
	this.dsPgm.setColumn(0, "cntnCtpvScCd", this.dsSearch.getColumn(0, "cntnCtpvScCd"));
	this.dsPgm.setColumn(0, "scaSysScCd",   this.dsSearch.getColumn(0, "scaSysScCd"));
	this.dsPgm.set_updatecontrol(true);
	
	if(this.dsPgm.getColumn(0, "aprvPrgStsCd") == "2"){
		this.divLectInfo.form.edtAslLectCn.set_readonly(true);
		this.divLectInfo.form.divFileUpload.set_enable(false);
		this.btnChgAply.set_enable(false);
		this.btnAplyRtrcn.set_enable(true);
		
		this.divLectInfo.form.divFileUpload.form.fnSetButtonBarEdit("download");
	}else{
		this.divLectInfo.form.edtAslLectCn.set_readonly(false);
		this.divLectInfo.form.divFileUpload.set_enable(true);
		this.btnChgAply.set_enable(true);
		this.btnAplyRtrcn.set_enable(false);
		
		this.divLectInfo.form.divFileUpload.form.fnSetButtonBarEdit("add,remove,remove_all,download");
	}
	
	this.divLectInfo.form.divFileUpload.form.fnResetUpload();
	if(this.dsAttach.rowcount > 0){
		var handlerCode       = "PA.ASF.ATS";
		var atchFileSn        = this.dsAttach.getColumn(0, "fileRefrnId");
		var fileSize          = this.dsAttach.getColumn(0, "atchFileMg"); 
		var backendFilename   = this.dsAttach.getColumn(0, "atchFileGuid");
		var frontendFilename  = this.dsAttach.getColumn(0, "atchFileNm");
		var fileId            = this.dsAttach.getColumn(0, "fileId");
		if(this.isNotNil(atchFileSn)){
			this.divLectInfo.form.divFileUpload.form.fnAddUploadedFile(handlerCode, atchFileSn, fileSize, backendFilename, frontendFilename, fileId);
		}
	}
}

this.fnSelectPgm = function ()
{
	// 서비스 객체 생성 
	this.smfSearchService("select")

		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;
			
			this.fnInit();
		});
}

this.fnChgAply = function ()
{
	
	
	// 서비스 객체 생성 
	this.smfSaveService("insert")

		// 데이터 변경 필수 
		.requireModifredData([this.dsPgm])
		.showConfirm(false)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;
			this.smfAlert('CM002');	//저장이 완료되었습니다.
			this.fnInit();
		});

}

this.fnAplyRtrcn = function ()
{
	if(this.dsPgm.getColumn(0, "aprvPrgStsCd") != "2"){
		this.smfAlert('PA004', ['[신청]상태만 취소가']);  // [신청]상태만 취소가 가능합니다.
		return;
	}
	// 서비스 객체 생성 
	this.smfDeleteService("delete")

		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;
			this.smfAlert('CM002');	//저장이 완료되었습니다.
			this.fnInit();
		});

}


// KUpload를 생성시 지정할 property값
//  Property의 자세한 설명은 
//  \12 나이스개발센터\17. 도입SW\01. 나이스클라우드\분리-06.파일 업로드 관리(RAON K Upload 2018)\raonkupload\sdk\index.html 참조 
this.fnSetRaonProp = function()
{
	var objAddRaonProps = {
								ExtensionAllowOrLimit : "1"        // 업로드 할 파일 확장자를 허용 또는 제한 설정
							,   ExtensionArr          : "ppt,pptx,doc,docx,hwp,zip"  // 제한 및 허용할 확장자명을 ",(콤마)"로 구분하여 설정
							,   AllowedZeroFileSize   : "1"        // 0byte 파일의 업로드를 허용 할지 설정합니다.(기본값은 "0" 허용안함이고, "1"로 설정시 허용입니다.)
	                      };
	return objAddRaonProps;
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/


this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};

this.btnChgAply_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.dsPgm.getColumn(0, "aprvPrgStsCd") == "2"){
		this.smfAlert('PA003', ['[신청]상태는 변경신청 할 수']);	 // [신청]상태는 변경신청 할 수 없습니다.
		return;
	}
	
	if(!this.smfIsUpdate(this.dsPgm) && !this.divLectInfo.form.divFileUpload.form.fnIsExistUploadFile()){
		this.smfAlert('PA003', ['변경된 데이터가 없어서 변경신청 할 수']);	 
		return;
	}
	this.smfConfirm("변경신청 하시겠습니까?", function(result){
		if(result.confirmResult){
			this.divLectInfo.form.divFileUpload.form.fnFileUpload();
		}
	});
};

this.btnAplyRtrcn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnAplyRtrcn();
};
]]></Script>
