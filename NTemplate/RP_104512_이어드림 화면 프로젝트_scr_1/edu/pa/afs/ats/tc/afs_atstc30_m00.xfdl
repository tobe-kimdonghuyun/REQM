    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 > 방과후학교(외부강사) > 프로그램관리
*  @FileName 	afs_atstc30_m00.xfdl 
*  @Creator 	임대성
*  @CreateDate 	2022.05.31
*  @Desction    방과후학교(외부강사) 프로그램관리
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.05.31            임대성                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::afs_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.fv_userId   = "";
this.fv_insrRrno = "";
this.fv_cddcCd   = "";

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	/*if(this.smfIsMobile()){
		this.grdMain.set_formatid("mobile");
	}else{
		this.grdMain.set_formatid("default");
	}*/
	//this.form.set_name("mobile");
	// 폼 초기화
	this.smfInitForm(obj);
	this.pv_params    = this.smfGetFormParams();
	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
			url : "/afs_ats_tc30_000.do",
		})
		.mappingRulesetToForm(this.divSearch, "list")
		.run()
		.callback(function(callbackParams) {
			
		});
	if(!this.pv_params.hasOwnProperty("jwtData")){
		this.afsfSetSession(this);
	}else{
		this.afsfSetSession(this, '', this.pv_params.jwtData);
	}
};

this.divSearch_cboShlCd_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	
	this.dsCd2.setColumn(0, "cddcCd",       this.fv_cddcCd);
	this.dsCd2.setColumn(0, "cntnCtpvScCd", this.dsSearch.getColumn(0,"cntnCtpvScCd"));
	this.dsCd2.setColumn(0, "insrRrno",     this.fv_insrRrno);
	this.dsCd2.setColumn(0, "userId",       this.fv_userId);
	this.dsCd2.setColumn(0, "shlCd",        e.postvalue);
	this.dsCd2.setColumn(0, "scaSysScCd",    this.dsShlCd.getColumn(e.postindex, "scaSysScCd"));
	
	this.dsCd2.setColumn(1, "cddcCd",       this.fv_cddcCd);
	this.dsCd2.setColumn(1, "cntnCtpvScCd", this.dsSearch.getColumn(0,"cntnCtpvScCd"));
	this.dsCd2.setColumn(1, "insrRrno",     this.fv_insrRrno);
	this.dsCd2.setColumn(1, "userId",       this.fv_userId);
	this.dsCd2.setColumn(1, "shlCd",        e.postvalue);
	this.dsCd2.setColumn(1, "scaSysScCd",   this.dsShlCd.getColumn(e.postindex, "scaSysScCd"));
	
	this.dsSearch.setColumn(0, "ayr",    "");
	this.dsSearch.setColumn(0, "aslSem", "");
	if(this.dsSearch.getColumn(0, "shlCd") != ""){
		this.afsfCodeList(this.dsCd2);
		this.divSearch.form.cboAyr.set_enable(true);
	}else{
		this.divSearch.form.cboAyr.set_enable(false);
	}
	this.divSearch.form.cboAslSem.set_enable(false);
};

this.divSearch_cboAyr_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.dsAslSem.filter("");
	this.dsAslSem.filter("unyCdValue == '' ||ayr == '"+e.postvalue+"'");
	this.dsSearch.setColumn(0, "aslSem", "");
	
	if(this.dsSearch.getColumn(0, "ayr") != ""){
		this.divSearch.form.cboAslSem.set_enable(true);
	}else{
		this.divSearch.form.cboAslSem.set_enable(false);
	}
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/




/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback = function(svcid,errcd,errmsg){
	console.log("svcid : "+svcid);
	if(errcd == -1) return;
	
	switch(svcid) {
	
		case "selectSession" : 
		    this.dsSearch.setColumn(0,"userId", "");
			this.fv_cddcCd   = this.dsSearch.getColumn(0,"cddcCd"); 	//시도교육청코드 
			this.fv_insrRrno = this.dsSearch.getColumn(0,"insrRrno");
			this.fv_userId   = this.dsSearch.getColumn(0,"userId");
			
			if(this.isNil(this.fv_insrRrno)){ // 모바일로 로그인시 CI가 없는 경우 주민번호 조회 안됨
				this.smfAlert("기존 방과후학교 외부강사시스템 을 이용하셨던 분들도 최초 접속 시\nPC 홈페이지에서 간편인증 및 본인인증을 진행하여 주시기 바랍니다.");
				return;
			}
			this.dsCd.setColumn(0, "cddcCd",       this.fv_cddcCd);
			this.dsCd.setColumn(0, "insrRrno",     this.fv_insrRrno);
			this.dsCd.setColumn(0, "userId",       this.fv_userId);
			
			this.afsfCodeList(this.dsCd);
			break;
		case "listShlCd" : 
			console.log("listShlCd");
			this.dsSearch.setColumn(0, "shlCd",  "");
			this.dsSearch.setColumn(0, "ayr",    "");
			this.dsSearch.setColumn(0, "aslSem", "");
			
			this.divSearch.form.cboAyr.set_enable(false);
			this.divSearch.form.cboAslSem.set_enable(false);
			break;
		case "listAyr" : 
			this.dsSearch.setColumn(0, "aslSem", "");
			
			this.divSearch.form.cboAslSem.set_enable(false);
	}
};

/**
 * @description Popup CallBack 함수(선택)
*/
this.fnPopupCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
	switch(svcid) {
		case "" : 
			break;
	}
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
  /**
 * @description 프로그램팝업
 */
this.fnPgmPopup = function(){
	var nIdx = this.dsPgm.rowposition;
	
	var dsTmp = this.afsfCopyRow(this.dsPgm, [nIdx]);
	dsTmp.setColumn(0, "cntnCtpvScCd", this.dsSearch.getColumn(0,"cntnCtpvScCd"));
	
	var popupParams = {
		      callback : this.fnPopupCallback
			, sender   : obj
			, params   : { 
				  procType  : "none"
				, dsPgm     : dsTmp
			}
	};
	this.smfDialog("pgmPopup", "pa_afs_ats_tc::afs_atstc31_m00.xfdl", popupParams );
}

 /**
 * @description 수강생팝업
 */
this.fnAtnlcStuPopup = function(){
	var nIdx = this.dsPgm.rowposition;
	
	if(this.dsPgm.getColumn(nIdx, "atnlcCnt") > 0){
		var dsTmp = this.afsfCopyRow(this.dsPgm, [nIdx]);
		dsTmp.setColumn(0, "cntnCtpvScCd", this.dsSearch.getColumn(0,"cntnCtpvScCd"));
		dsTmp.setColumn(0, "atnlcAplyPrcsStsCd", "02");
		
		var popupParams = {
				  callback : this.fnPopupCallback
				, sender   : obj
				, params   : { 
					  procType  : "none"
					, dsPgm     : dsTmp
				}
		};
		this.smfDialog("tiPopup", "pa_afs_ats_tc::afs_atstc30_p04.xfdl", popupParams );
	}
}

 /**
 * @description 시간표팝업
 */
this.fnTiPopup = function(){
	var nIdx = this.dsPgm.rowposition;
	
	var dsTmp = this.afsfCopyRow(this.dsPgm, [nIdx]);
	dsTmp.setColumn(0, "cntnCtpvScCd", this.dsSearch.getColumn(0,"cntnCtpvScCd"));
	
	var popupParams = {
		      callback : this.fnPopupCallback
			, sender   : obj
			, params   : { 
				  procType  : "none"
				, dsPgm     : dsTmp
				, all       : "N"
			}
	};
	this.smfOpen("tiPopup", "pa_afs_ats_tc::afs_atstc30_p02.xfdl", popupParams );
}

/**
 * @description 출석부팝업
 */
this.fnAtendPopup = function(){
	var nIdx = this.dsPgm.rowposition;
	
	var dsTmp = this.afsfCopyRow(this.dsPgm, [nIdx]);
	dsTmp.setColumn(0, "cntnCtpvScCd", this.dsSearch.getColumn(0,"cntnCtpvScCd"));
	
	var popupParams = {
		      callback : this.fnPopupCallback
			, sender   : obj
			, params   : { 
				  procType  : "none"
				, dsPgm     : dsTmp
			}
	};
	var scrInfo = this.smfCurScreenInfo(30, 30);
	
	if(this.smfIsMobile()){
		this.smfDialog("atendPopup", "pa_afs_ats_tc::afs_atstc30_p01.xfdl", popupParams, null, null, scrInfo[0], scrInfo[1] );
	}else{
		this.smfDialog("atendPopup", "pa_afs_ats_tc::afs_atstc30_p01.xfdl", popupParams, null, null, scrInfo[0], scrInfo[1] );
	}
	
	
}

/**
 * @description 결보강팝업
 */
this.fnCaclReiPopup = function(){
	var nIdx = this.dsPgm.rowposition;
	
	var dsTmp = this.afsfCopyRow(this.dsPgm, [nIdx]);
	dsTmp.setColumn(0, "cntnCtpvScCd", this.dsSearch.getColumn(0,"cntnCtpvScCd"));
	
	var popupParams = {
		      callback : this.fnPopupCallback
			, sender   : obj
			, params   : { 
				  procType  : "none"
				, dsPgm     : dsTmp
			}
	};
	this.smfDialog("caclReiPopup", "pa_afs_ats_tc::afs_atstc30_p03.xfdl", popupParams, null, null, "1000" );
}



/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 // 조회버튼
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
	this.dsSearch.setColumn(0, "scaSysScCd", this.dsShlCd.getColumn(this.divSearch.form.cboShlCd.index, "scaSysScCd"));
	// 서비스 객체 생성
	this.smfSearchService("list")
	    .validateForm(this.divSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.dsPgm.set_filterstr("lectIdfNo != null");
		});
};
// 초기화버튼
this.divSearch_btnInit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsSearch.setColumn(0, "shlCd",  "");
	this.dsSearch.setColumn(0, "ayr",    "");
	this.dsSearch.setColumn(0, "aslSem", "");
	
	this.divSearch.form.cboAyr.set_enable(false);
	this.divSearch.form.cboAslSem.set_enable(false);
};

/**
 * @description 전체시간표 버튼 클릭
 */
this.btnPi_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{ 
	if(this.dsSearch.getColumn(0, "shlCd") == ""){
		this.smfAlert('CM022', ['조회조건[학교명]']); // 조회조건[학교명]을(를) 선택하여 주십시오.
		return;
	}
	if(this.dsSearch.getColumn(0, "ary") == ""){
		this.smfAlert('CM022', ['조회조건[학년도]']); // 조회조건[학년도]을(를) 선택하여 주십시오.
		return;
	}
	if(this.dsSearch.getColumn(0, "aslSem") == ""){
		this.smfAlert('CM022', ['조회조건[기간명]']); // 조회조건[기간명]을(를) 선택하여 주십시오.
		return;
	}
	
	this.dsSearch.setColumn(0, "aslSemNm",       this.dsAslSem.getColumn(this.divSearch.form.cboAslSem.index, "unyCdValueNm"));
	this.dsSearch.setColumn(0, "aslLectBgngYmd", this.dsAslSem.getColumn(this.divSearch.form.cboAslSem.index, "userDfnCd6Value").replaceAll("-", ""));
	this.dsSearch.setColumn(0, "aslLectEndYmd",  this.dsAslSem.getColumn(this.divSearch.form.cboAslSem.index, "userDfnCd7Value").replaceAll("-", ""));
	this.dsSearch.setColumn(0, "scaSysScCd",     this.dsShlCd.getColumn(this.divSearch.form.cboShlCd.index, "scaSysScCd"));
	
	var popupParams = {
			  callback : this.fnPopupCallback
			, sender   : obj
			, params   : { 
				  procType  : "none"
				, dsPgm     : this.dsSearch
				, all       : "Y"
			}
	
	};
	this.smfDialog("_auto", "pa_afs_ats_tc::afs_atstc30_p02.xfdl", popupParams );
};


/**
 * @description 그리드 셀 클릭
 */
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	trace("col : "+e.col);
	trace("row : "+e.row);
	switch( e.col ) {
		case 1:
			// 프로그램명 클릭
			if(!this.smfIsMobile()){
				this.fnPgmPopup();
			}
			break;
		case 8:
			// 수강생
			this.fnAtnlcStuPopup();
			break;
		case 11:
			// 시간표 클릭
			this.fnTiPopup();
			break;
		case 12:
			// 출석부 클릭
			this.fnAtendPopup();
			break;
		case 13:
			// 결보강 클릭
			this.fnCaclReiPopup();
			break;
	}
};




]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="true">
