            </Tabpage>
          </Tabpages>
        </Tab>
        <Static id="sta_main" taborder="8" left="0" top="0" height="70" cssclass="sta_Ctitle" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta01" taborder="9" left="0" top="114" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta02" taborder="10" left="0" top="164" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta03" taborder="11" left="0" top="421" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta05" taborder="12" left="0" top="481" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 > 방과후학교(외부강사) > 강사정보
*  @FileName    afs_atstc00_m00
*  @Creator     임대성
*  @CreateDate  2022.05.19
*  @Desction    방과후학교(외부강사) 강사정보
*
******************* 소스 수정 이력 ******************************************
*  date                 Modifier                Description
*******************************************************************************
* 2022.05.19            임대성                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::afs_script.xjs";


/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_cddcCd            = ""; //시도교육청코드 
this.fv_insrScCd          = ""; //강사구분코드 ( I: 외부강사, O:위탁업체소속외부강사 )
this.fv_insrRrno          = "";
this.fv_brno              = "";
this.cnsgnComyId = "";
this.fv_param             = null; 
this.fv_ruleNm            = "";
this.fv_brdt              = "";

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{  

/*
추가 작업 필요 내역
1. 콤보 공통코드 적용 --> 
2. 주소검색 팝업 적용 --> 0615 공통팝업적용 -> 공통팝업이 현재 임시팝업(서버X)
3. 주민번호, 계좌번호 암호화 --> 암호화 API방식 적용 됨
4. 나이스에 주민번호로 등록된 계정이 존재하는지 확인 
   - 있는 경우 나이스 ID사용 (교원강사 처리?) 
*/
    //폼을 초기화
    this.smfInitForm(obj);
    this.pv_params    = this.smfGetFormParams();
    if(!this.smfIsEmptyObject(this.pv_params) && this.isNil(this.pv_params.menu) && !this.pv_params.hasOwnProperty("jwtData")){
        this.fv_ruleNm = "cnsgnBscInfo";
    }else{
        console.log("jwtData :"+this.pv_params.jwtData);
        this.fv_ruleNm = "bscInfo";
        
        this.parent.parent.parent.parent.divTop.form.fnDestroyTopMenu();
    }
        
    // 서버단에 설정한 유효성 검증 목록을 획득하여 설정
    this.smfValidateService("validateMain", {
            url: "/afs_ats_tc00_000.do",
        })
        .mappingRulesetToForm(this.divBscInfo, this.fv_ruleNm) 
        .mappingRulesetToDataset(this.dsAcbgListValid, "saveAcbgList")
        .mappingRulesetToDataset(this.dsQlflListValid, "saveQlflList")
        .mappingRulesetToDataset(this.dsCarrListValid, "saveCarrList")
        .run() 
        .callback(function(callbackParams){
            if(callbackParams.errors) return;
            
            if(!this.pv_params.hasOwnProperty("jwtData")){
                this.afsfSetSession(this);
            }else{
                this.afsfSetSession(this, '', this.pv_params.jwtData);
            }
        });
    
};



/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 강사 기본정보 조회 Transaction
 */
this.fnSelectInsrInfo = function () {
    this.dsAcbgList.clearData();
    this.dsQlflList.clearData();
    this.dsCarrList.clearData();
    
    // 서비스 객체 생성
    this.smfSearchService("selectInsrInfo")
        // 실행
        .run()
        // 콜백
        .callback(function(callbackParams) {
            if(callbackParams.errors) return;
            
            if(this.dsBscInfo.rowcount == 0){
                this.fnInitBscInfo();
            }else{
                //전화번호 셋팅
                this.afsfSplitTelno(this.dsBscInfo, "homeTelno");
                this.afsfSplitTelno(this.dsBscInfo, "mblTelno");

                this.dsSearch.setColumn(0,"userId", this.dsBscInfo.getColumn(0,"userId"));          
                this.fnSelectDtlList(); //상세정보 조회
            }
            //this.afsfCallbackTrim(callbackParams);    //cboColumn 공백제거
            
        });
        
};

/**
 * @description 강사 기본정보 저장 Transaction
 */
this.fnSaveInsrInfo = function ()
{
    //성별코드 생성
    var rrno     = this.dsBscInfo.getColumn(0,"insrRrno");
    var sxdsScCd = rrno.substr(6,1) % 2 == 0 ? 2 : 1; //SXDS_SC_CD
    this.dsBscInfo.setColumn(0,"sxdsScCd",sxdsScCd);    
    
    // CI셋팅
    this.dsBscInfo.setColumn(0,"aslInsrCiNo", this.dsSearch.getColumn(0, "aslInsrCiNo"));   
    
    //강사구분코드
    this.dsBscInfo.setColumn(0,"insrScCd", this.fv_insrScCd);   
    
    //전화번호결합
    var telno1 = this.dsBscInfo.getColumn(0,"homeTelno1");  
    var telno2 = this.dsBscInfo.getColumn(0,"homeTelno2");  
    var telno3 = this.dsBscInfo.getColumn(0,"homeTelno3");
    var telno = [telno1,telno2,telno3].join("-"); 
    if ( telno == "--" ) telno = "";
    this.dsBscInfo.setColumn(0,"homeTelno",telno);
    
    var mblTelno1 = this.dsBscInfo.getColumn(0,"mblTelno1");    
    var mblTelno2 = this.dsBscInfo.getColumn(0,"mblTelno2");    
    var mblTelno3 = this.dsBscInfo.getColumn(0,"mblTelno3");    
    var mblTelno = [mblTelno1,mblTelno2,mblTelno3].join("-");
    this.dsBscInfo.setColumn(0,"mblTelno",mblTelno);
    
    if(!this.smfIsUpdate(this.dsBscInfo) && !this.smfIsUpdate(this.dsAcbgList) && !this.smfIsUpdate(this.dsCarrList) && !this.smfIsUpdate(this.dsQlflList)){
        this.smfAlert('PA003', ["변경된 데이터가 없어서 저장할 수"]); //변경된 데이타가 없어서 저장할 수 없습니다.
        return;
    }
    
    if(!this.isNil(this.dsBscInfo.getColumn(0,"esntlPrvcGthAgreYn")) && this.dsBscInfo.getColumn(0,"esntlPrvcGthAgreYn") != "Y"){
        this.smfAlert('PA063', ["개인정보 수집동의(필수)는 반드시 동의하셔야"]);
        return;
    }
    
    // 서비스 객체 생성 
    this.smfSaveService("saveInsrInfo")
        // 데이터 존재 필수
        .requireExistsData(this.dsBscInfo)
        // 데이터 검증
        .validateForm(this.divBscInfo)
        .validateGrid(this.tabDtl.tapAcbg.form.grdAcbg, this.dsAcbgListValid, {"_chkOption" : "ignore"})
        .validateGrid(this.tabDtl.tapCarr.form.grdCarr, this.dsCarrListValid, {"_chkOption" : "ignore"})
        .validateGrid(this.tabDtl.tapQlfl.form.grdQlfl, this.dsQlflListValid, {"_chkOption" : "ignore"})
        // 데이터 변경 필수 
        //.requireModifredData([this.dsBscInfo, this.dsAcbgList, this.dsQlflList, this.dsCarrList])
        // 실행
        .run()
        // 콜백
        .callback(function(callbackParams) {
            if(callbackParams.errors) return;
            
            this.smfAlert('CM002'); //저장이 완료되었습니다.
            this.dsCd2.setColumn(0, "cddcCd",      this.fv_cddcCd);
            this.dsCd2.setColumn(0, "insrRrno",    this.fv_insrRrno);
            this.afsfCodeList(this.dsCd2);
            
            if(this.pv_params.hasOwnProperty("jwtData")){ // 로그인 직후 저장시만
                var sFilter = "lvl==0&&isShow!='N'&cnsgnYn =='N'";
                this.parent.parent.parent.parent.divTop.form.dsMenu.set_filterstr(sFilter);
                this.parent.parent.parent.parent.divTop.form.fnDestroyTopMenu();
                this.parent.parent.parent.parent.divTop.form.fnSetTopMenu();
            }
        });
};

/**
 * @description 강사 기본정보 삭제 Transaction
 */
this.fnDeleteInsrInfo = function () {

    if ( this.dsBscInfo.getRowType() == 2) {
        //신규 상태이면 return;
        this.smfAlert('PA003', ['저장된 데이터가']); // 저장된 데이터가 없습니다
        return;
    }
    
    // 서비스 객체 생성 
    this.smfSaveService("saveInsrInfo")
        //confirm 메시지 삭제로 변경
        .messagePrefix("삭제")
        // 전처리
        .beforeService(function(next) {
            this.dsBscInfo.set_updatecontrol(false);
            this.dsBscInfo.setRowType(0, "D");
            this.dsBscInfo.set_updatecontrol(true);
            // 학력
            this.dsAcbgList.set_updatecontrol(false);
            for(var i=0; i<this.dsAcbgList.rowcount; i++){
                this.dsAcbgList.setRowType(i, "D");
            }
            this.dsAcbgList.set_updatecontrol(true);
            // 자격증
            this.dsQlflList.set_updatecontrol(false);
            for(var i=0; i<this.dsQlflList.rowcount; i++){
                this.dsQlflList.setRowType(i, "D");
            }
            this.dsQlflList.set_updatecontrol(true);
            // 경력
            this.dsCarrList.set_updatecontrol(false);
            for(var i=0; i<this.dsCarrList.rowcount; i++){
                this.dsCarrList.setRowType(i, "D");
            }
            this.dsCarrList.set_updatecontrol(true);
            next();
        })
        // 실행
        .run()
        // 콜백
        .callback(function(callbackParams) {
            if(callbackParams.errors) return;
            this.smfAlert('CM155', ['삭제처리되어 메인화면으로 이동합니다.'], function(){this.parent.parent.parent.parent.divTop.form.fnLogout();}); //삭제 되었습니다.

            /*this.dsCd2.setColumn(0, "insrRrno",    this.fv_insrRrno);
            this.afsfCodeList(this.dsCd2);*/
        });
};


/**
 * @description 강사 상세정보 조회 Transaction
 */
this.fnSelectDtlList = function () {
    // 서비스 객체 생성
    this.smfSearchService("selectDtlList")
        // 실행
        .run()
        // 콜백
        .callback(function(callbackParams) {
            if(callbackParams.errors) return;
            this.afsfCallbackTrim(callbackParams);
        });
};

/**
 * @description 강사 상세정보 저장 Transaction
 */
this.fnSaveDtl = function () {
    var grdObj = this.getGrdObj();
    var dsObj = grdObj.getBindDataset();
    var dsValidObj = this.lookup(dsObj.id+"Valid");
    
    //상세내부 저장 구분..
    var objTap = this.tabDtl.tabpages[this.tabDtl.tabindex];
    var dtlId = objTap.id.replace("tap", "")+ "List";
    this.dsSearch.setColumn(0, "saveDtlId", dtlId);
          
    // 서비스 객체 생성 
    this.smfSaveService("saveDtlList")
        // 데이터 존재 필수
        .requireExistsData(dsObj)
        // 데이터 검증
        .validateGrid(grdObj, dsValidObj) 
        // 데이터 변경 필수
        .requireModifredData(dsObj)     
        // 실행
        .run() 
        // 콜백
        .callback(function(callbackParam){
            if(callbackParam.errors) return; 
            this.smfAlert('CM002', [], this.fnSelectDtlList()); //저장이 완료되었습니다.
        });
};

this.fnInitBscInfo = function(){
    var nRowIdx = this.dsBscInfo.insertRow();
    this.dsBscInfo.setColumn(nRowIdx, "userId",      "신규"); 
    this.dsBscInfo.setColumn(nRowIdx, "cddcCd",      this.fv_cddcCd);
    
    if(this.fv_insrScCd == "O"){
        this.dsBscInfo.setColumn(nRowIdx, "insrRrno",    "");
        this.dsBscInfo.setColumn(nRowIdx, "cnsgnComyId", this.fv_param.cnsgnComyId);
    }else{
        this.dsBscInfo.setColumn(nRowIdx, "insrRrno",    this.fv_insrRrno);
    }
    
    this.dsAcbgList.clearData();
    this.dsQlflList.clearData(); 
    this.dsCarrList.clearData();
};

this.fnMoblCet = function(){

    var param = {   "insrNm"   : this.dsBscInfo.getColumn(0, "insrNm")
                  , "insrRrno" : this.dsBscInfo.getColumn(0, "insrRrno")
                  , "brdt"     : this.pv_params.jwtData.birthday
                  , "mblTelno" : this.dsBscInfo.getColumn(0, "mblTelno1")+this.dsBscInfo.getColumn(0, "mblTelno2")+this.dsBscInfo.getColumn(0, "mblTelno3")
                };
    this.afsfPopupMoblCet(this, this.fnPopupMoblCetCallback, param);
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback  = function(svcid,errcd,errmsg) {
    if(errcd == -1) { 
        return;
    }
    
    switch(svcid) { 
    
        case "selectSession" : 
            this.fv_cddcCd   = this.dsSearch.getColumn(0,"cddcCd");     //시도교육청코드 
            
            this.pv_params = this.smfGetFormParams();
            if(!this.smfIsEmptyObject(this.pv_params) && this.isNil(this.pv_params.menu) && !this.pv_params.hasOwnProperty("jwtData")){
                this.fv_insrRrno = this.pv_params.insrRrno;
                this.dsSearch.setColumn(0,"userId",      this.pv_params.userId);
                this.dsSearch.setColumn(0,"cnsgnComyId", this.pv_params.cnsgnComyId);
                this.dsSearch.setColumn(0,"insrRrno",    this.fv_insrRrno);
                
                this.dsCd.setColumn(2, "cddcCd",      this.fv_cddcCd);
                this.dsCd.setColumn(2, "insrRrno",    this.fv_insrRrno);
                this.afsfCodeList(this.dsCd);
                
                this.pageInit();
            }else{
                if(this.pv_params.hasOwnProperty("jwtData")){ // 로그인 직후 
                    if(this.dsSearch.getColumn(0,"aslInsrCiNoYn") == "Y"){ // 등록된 CI가 존재하는 경우
                        this.fv_insrRrno = this.dsSearch.getColumn(0,"insrRrno");
                        
                        this.dsCd.setColumn(2, "cddcCd",      this.fv_cddcCd);
                        this.dsCd.setColumn(2, "insrRrno",    this.fv_insrRrno);
                        this.afsfCodeList(this.dsCd);
                        
                        this.pageInit();
                        
                        var sFilter = "lvl==0&&isShow!='N'&cnsgnYn =='N'";
                        this.parent.parent.parent.parent.divTop.form.dsMenu.set_filterstr(sFilter);
                        this.parent.parent.parent.parent.divTop.form.fnDestroyTopMenu();
                        this.parent.parent.parent.parent.divTop.form.fnSetTopMenu();
        
                        this.divBscInfo.form.div31.form.btnOnfCet.set_enable(false);
                    }else{ // 등록된 CI가 존재하지 않는 경우
                        /*var msg = "아래의 순서대로 진행하여 주시기 바랍니다.\n\n"
                                + "1. 주민등록번호 입력 및 본인인증\n"
                                + "2. 개인정보수집동의 및 강사정보 입력\n"
                                + "3. 저장 버튼 클릭하여 저장\n\n"
                                + "* 최초 접속 후 강사정보를 입력한 뒤 [저장]버튼을 클릭하여, \n"
                                + " 저장하셔야 서비스를 정상적으로 이용할 수 있습니다.";
                        this.smfAlert('CM000', [msg]); */
                        this.fnMoblCet();
                    }
                }else{
                    this.fv_insrRrno = this.dsSearch.getColumn(0,"insrRrno");
                    
                    this.dsCd.setColumn(2, "cddcCd",      this.fv_cddcCd);
                    this.dsCd.setColumn(2, "insrRrno",    this.fv_insrRrno);
                    
                    this.afsfCodeList(this.dsCd);
                    
                    this.pageInit();
                    
                    var sFilter = "lvl==0&&isShow!='N'&cnsgnYn =='N'";
                    this.parent.parent.parent.parent.divTop.form.dsMenu.set_filterstr(sFilter);
                    this.parent.parent.parent.parent.divTop.form.fnDestroyTopMenu();
                    this.parent.parent.parent.parent.divTop.form.fnSetTopMenu();
                }
            }
            
            break;
        case "listInsrId" : 
            if(!this.smfIsEmptyObject(this.fv_param) && this.isNotNil(this.fv_param.cnsgnComyId)){
                
                if(this.fv_param.type == "REG"){
                    this.dsInsrId.insertRow(0);
                    this.dsInsrId.setColumn(0, "unyCdValue",   "신규");
                    this.dsInsrId.setColumn(0, "unyCdValueNm", "위탁업체강사 신규");
                    this.dsInsrId.setColumn(0, "insrScCd",     "O");
                    
                    this.dsInsrId.set_rowposition(0);
                    
                    this.fv_insrScCd = "O";
                    this.fnInitBscInfo();
                }else{
                    //강사 기본정보 조회
                    this.fnSelectInsrInfo();
                }

                this.divBscInfo.form.div03.form.cboInsrId.set_readonly(true);
            }else if(this.dsInsrId.rowcount == 0){
                this.dsInsrId.insertRow(0);
                this.dsInsrId.setColumn(0, "unyCdValue",   "신규");
                this.dsInsrId.setColumn(0, "unyCdValueNm", "외부강사 신규");
                this.dsInsrId.setColumn(0, "insrScCd",     "I");
                
                this.dsInsrId.set_rowposition(0);
                
                this.fv_insrScCd = "I";
                this.fnInitBscInfo();
            }else if(this.dsInsrId.findRow( "insrScCd", "I" ) < 0){
                this.dsInsrId.insertRow(0);
                this.dsInsrId.setColumn(0, "unyCdValue",   "신규");
                this.dsInsrId.setColumn(0, "unyCdValueNm", "외부강사 신규");
                this.dsInsrId.setColumn(0, "insrScCd",     "I");
                
                this.dsInsrId.set_rowposition(0);
                
                this.fv_insrScCd = "I";
                this.fnInitBscInfo();
            }else{
                //강사 기본정보 조회
                this.fnSelectInsrInfo();
            }
            break;
        //================
        //  상세정보 저장
        //================
        case "saveDtlList" : 
            //오류메시지 확인용 
            if ( errcd == -100 ) {
                this.smfAlert("errcd : "+errcd);
                this.alert(errmsg);
            }
            break;
            
    }
};

/**
 * @description 주소검색 callback 
 */
this.fnPopupCallback = function(e, sender){
    var nRow = this.dsBscInfo.rowposition;  
    if (sender == this.divBscInfo.form.div21.form.btnAddr) {
        this.dsBscInfo.setColumn(nRow, "homeAddr", e.roadNmAddr+" "+e.roadNmDtl);
    }else if (sender == this.divBscInfo.form.staPrvcPrcusEsntlYn) {
        this.dsBscInfo.setColumn(nRow, "esntlPrvcGthAgreYn", e.esntlPrvcGthAgreYn);
    }else if (sender == this.divBscInfo.form.staPrvcPrcusChcYn) {
        this.dsBscInfo.setColumn(nRow, "chcPrvcGthAgreYn", e.chcPrvcGthAgreYn);
    }
};

this.fnPopupMoblCetCallback = function(e, sender){

    if(this.dsSearch.getColumn(0, "aslInsrCiNo") != e.row.strCi){ // CI값 차이 발생
    //if(1==2){
        this.smfAlert("로그인 정보와 본인인증 정보가 상이합니다.");
    }else{ // CI값 동일    
        //this.divBscInfo.form.div31.form.btnOnfCet.set_enable(false);
        //this.divBscInfo.form.div31.form.mskRrno.set_readonly(true);
        this.divBscInfo.form.div31.form.btnOnfCet.set_enable(true);
        this.dsSearch.setColumn(0,"aslInsrCiNoYn", "Y");
        
        let genderGb = "";
        let yy = e.row.strBirth.substring(0, 2);
        if(e.row.strGender == "M"){ // 남성
            if(yy == '19' && e.row.strFgnGbn == "1"){ // 내국인이면서 1900년대 출생자
                genderGb = "1";
            }else if(yy == '19' && e.row.strFgnGbn == "2"){ // 외국인이면서 1900년대 출생자
                genderGb = "5";
            }else if(yy == '20' && e.row.strFgnGbn == "1"){ // 내국인이면서 2000년대 출생자
                genderGb = "3";
            }else if(yy == '20' && e.row.strFgnGbn == "2"){ // 외국인이면서 2000년대 출생자
                genderGb = "7";
            }
        }else if(e.row.strGender == "F"){ // 여성
            if(yy == '19' && e.row.strFgnGbn == "1"){ // 내국인이면서 1900년대 출생자
                genderGb = "2";
            }else if(yy == '19' && e.row.strFgnGbn == "2"){ // 외국인이면서 1900년대 출생자
                genderGb = "6";
            }else if(yy == '20' && e.row.strFgnGbn == "1"){
                genderGb = "4";
            }else if(yy == '20' && e.row.strFgnGbn == "2"){
                genderGb = "8";
            }
        }
        this.fv_brdt = e.row.strBirth.substring(2)+genderGb;
        /*this.dsSearch.setColumn(0,"insrRrno", this.dsBscInfo.getColumn(0,"insrRrno"));
        
        this.fv_insrRrno = this.dsSearch.getColumn(0,"insrRrno");
        
        this.dsCd.setColumn(2, "cddcCd",      this.fv_cddcCd);
        this.dsCd.setColumn(2, "insrRrno",    this.fv_insrRrno);
        this.afsfCodeList(this.dsCd);
        
        this.pageInit(); */
    }
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.pageInit = function(){
    this.fv_param    = this.smfGetFormParams();

    if(!this.smfIsEmptyObject(this.pv_params) && this.isNil(this.pv_params.menu) && !this.pv_params.hasOwnProperty("jwtData")){
        this.dsSearch.setColumn(0,"cnsgnComyId", this.fv_param.cnsgnComyId);
        //위탁업체강사관리화면에서 이동
        if ( this.isNotNil(this.fv_param.userId) ) {
            this.dsSearch.setColumn(0,"userId",      this.fv_param.userId);
            this.fv_insrRrno = this.fv_param.insrRrno;
        }
        //목록버튼 표시
        this.btnList.set_visible(true);
        
        this.fv_ruleNm = "cnsgnBscInfo";
        
        this.divBscInfo.form.staBankNm.set_cssclass("sta_WF_Input01");
        this.divBscInfo.form.staBankNm.set_text("은행명");
        this.divBscInfo.form.div41.form.cboBankCd.set_readonly(true);
        this.divBscInfo.form.staActno.set_cssclass("sta_WF_Input01");
        this.divBscInfo.form.staActno.set_text("계좌번호");
        this.divBscInfo.form.div42.form.edtActno.set_readonly(true);
        
        this.divBscInfo.form.staPrvcPrcusEsntlYn.set_cssclass("sta_WF_Input01");
        this.divBscInfo.form.staPrvcPrcusEsntlYn.set_text("개인정보 수집동의(필수)");
        this.divBscInfo.form.staPrvcPrcusChcYn.set_cssclass("sta_WF_Input01");
        this.divBscInfo.form.staPrvcPrcusChcYn.set_text("개인정보 수집동의(선택)");
    } else {
        //목록버튼 숨김
        this.btnList.set_visible(false);
        //주민등록번호 읽기전용
        
        if(this.pv_params.hasOwnProperty("jwtData")){ // 로그인 직후 
            if(this.dsSearch.getColumn(0,"aslInsrCiNoYn") == "Y"){ // 등록된 CI가 존재하는 경우
                this.divBscInfo.form.div31.form.mskRrno.set_readonly(true);
            }else{
                this.divBscInfo.form.div31.form.mskRrno.set_readonly(false);
            }
        }else{
            this.divBscInfo.form.div31.form.mskRrno.set_readonly(true);
        }
        
        this.fv_ruleNm = "bscInfo";
    }
    
    this.divBscInfo.form.div21.form.btnAddr.set_enable(true);
    this.btnSave.set_enable(true);
    this.btnDelete.set_enable(true);
    // 서버단에 설정한 유효성 검증 목록을 획득하여 설정
    this.smfValidateService("validateMain", {
            url: "/afs_ats_tc00_000.do",
        })
        .mappingRulesetToForm(this.divBscInfo, this.fv_ruleNm) 
        .mappingRulesetToDataset(this.dsAcbgListValid, "saveAcbgList")
        .mappingRulesetToDataset(this.dsQlflListValid, "saveQlflList")
        .mappingRulesetToDataset(this.dsCarrListValid, "saveCarrList")
        .run() 
        .callback(function(callbackParams){
            if(callbackParams.errors) return;
        })
    ; 
}


/**
 * @description 현재 화면에 표시된 탭페이지 내부 Grid Object 반환
 */
this.getGrdObj = function () {
    //현재 활성화된 탭페이지 내부 grid object 검색
    var objTap = this.tabDtl.tabpages[this.tabDtl.tabindex];
    var grdId = "grd" + objTap.id.replace("tap", "");
    var grdObj = objTap.form.lookup(grdId);
    
    return grdObj;
}

/**
 * @description 상세정보 그리드 행 추가
 */
this.fnDtlAddRow = function () {
    //if ( !this.isCrtInsrId() ) return;
    
    var grdObj = this.getGrdObj();
    // 조회를 수행했는지 검증후 그리드에 row를 추가한다
    //var nRow = this.smfAddGridRow(grdObj, "selectInsrInfo");  //그리드, 해당 서비스 실행 여부
    //if(nRow == -1) return;
    grdObj.getBindDataset().addRow();
    
    var dsObj = grdObj.getBindDataset();
    var userId = this.dsBscInfo.getColumn(0,"userId")   
    dsObj.setColumn(grdObj.getBindDataset().rowcount-1, "userId", userId);
    dsObj.setColumn(grdObj.getBindDataset().rowcount-1, "regSn", "추가");
    dsObj.setColumn(grdObj.getBindDataset().rowcount-1, "cddcCd", this.fv_cddcCd);
    
}

/**
 * @description 상세정보 그리드 행 삭제
 */
this.fnDtlDeleteRow = function () 
{
    var grdObj = this.getGrdObj();
    var dsObj = grdObj.getBindDataset();
    
    var arrChk = dsObj.extractRows("_chk");
    dsObj.deleteMultiRows(arrChk);
    
}



