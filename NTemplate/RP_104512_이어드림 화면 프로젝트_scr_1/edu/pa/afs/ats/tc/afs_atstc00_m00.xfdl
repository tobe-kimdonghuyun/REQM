                </Layout>
              </Layouts>
            </Tabpage>
            <Tabpage id="tapCarr" text="경력정보">
              <Layouts>
                <Layout>
                  <Div id="divBtnCarr" taborder="0" right="0" height="30" top="20" width="280" initvalueid="ivDivAccessibilityOff">
                    <Layouts>
                      <Layout>
                        <Button id="btnAddCarr" taborder="0" text="추가" height="30" cssclass="btn_WF_Write" width="71" right="58" onclick="tabDtl_tapCarr_divBtnCarr_btnAddCarr_onclick" top="0" initvalueid="ivBtnAccessibilityButton"/>
                        <Button id="btnDeleteCarr" taborder="1" text="삭제" height="30" cssclass="btn_WF_Crud" width="50" right="0" onclick="tabDtl_tapCarr_divBtnCarr_btnDeleteCarr_onclick" top="0" initvalueid="ivBtnAccessibilityButton"/>
                      </Layout>
                    </Layouts>
                  </Div>
                  <Grid id="grdCarr" taborder="1" left="0" top="divBtnCarr:10" autofittype="col" binddataset="dsCarrList" right="0" bottom="0" onheadclick="tabDtl_tapCarr_grdCarr_onheadclick" initvalueid="ivGrdAccessibilityOn" accessibilitylabel="경력정보 그리드" autoenter="select" selecttype="cell">
                    <Formats>
