this.divBscInfo_staPrvcPrcusEsntlYn_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
    if(this.divBscInfo.form.staPrvcPrcusEsntlYn.cssclass != "sta_WF_Essential"){
        return;
    }
    
    if(this.isNil(this.dsBscInfo.getColumn(0, "insrRrno"))){
        this.smfAlert("본인인증을 먼저 진행해주세요.");
        return;
    }
    
    var popupParams = {
        callback: this.fnPopupCallback, // 콜백함수 지정
        sender: obj,                    // sender 지정
        params: { 
                  procType           : "none"
                , esntlPrvcGthAgreYn : this.dsBscInfo.getColumn(0, "esntlPrvcGthAgreYn")
                , all                : "N"
               }     // 팝업 전달 파라메터 지정
    };
    
    this.smfDialog("prvcPrcusEsntlPopup", "pa_afs_ats_tc::afs_atstc00_p01.xfdl", popupParams, null, null, 800, 600);
};


this.divBscInfo_staPrvcPrcusChcYn_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
    if(this.divBscInfo.form.staPrvcPrcusChcYn.cssclass != "sta_WF_Essential"){
        return;
    }
    
    if(this.isNil(this.dsBscInfo.getColumn(0, "insrRrno"))){
        this.smfAlert("본인인증을 먼저 진행해주세요.");
        return;
    }
    
    var popupParams = {
        callback: this.fnPopupCallback, // 콜백함수 지정
        sender: obj,                    // sender 지정
        params: { 
                  procType         : "none"
                , chcPrvcGthAgreYn : this.dsBscInfo.getColumn(0, "chcPrvcGthAgreYn")
               }      // 팝업 전달 파라메터 지정
    };

    this.smfDialog("prvcPrcusChcPopup", "pa_afs_ats_tc::afs_atstc00_p02.xfdl", popupParams, null, null, 800, 600);
};

this.divBscInfo_div31_btnOnfCet_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
    if(this.isNil(this.dsBscInfo.getColumn(0, "insrRrno"))){
        this.smfAlert("주민번호를 입력해주세요.");
        return;
    }
    
    if(!this.smfIsRsrNo(this.dsBscInfo.getColumn(0, "insrRrno"))){
        this.smfAlert("주민번호를 확인해주세요.");
        return;
    }
    
    if(this.dsBscInfo.getColumn(0, "insrRrno").substring(0, 7) != this.fv_brdt ){
        this.smfAlert("인증한 생년월일과 입력한 생년월일이 다릅니다.");
        return;
    }
    
    this.smfConfirm("해당 주민번호로 입력하시겠습니까?", function(result){
        if(result.confirmResult){
            this.divBscInfo.form.div31.form.btnOnfCet.set_enable(false);
            this.dsSearch.setColumn(0,"insrRrno", this.dsBscInfo.getColumn(0,"insrRrno"));
                
            this.fv_insrRrno = this.dsSearch.getColumn(0,"insrRrno");
            
            this.dsCd.setColumn(2, "cddcCd",      this.fv_cddcCd);
            this.dsCd.setColumn(2, "insrRrno",    this.fv_insrRrno);
            this.afsfCodeList(this.dsCd);
            
            this.pageInit();
        }
    });
        
        /*var param = {   "insrNm"   : this.dsBscInfo.getColumn(0, "insrNm")
                      , "insrRrno" : this.dsBscInfo.getColumn(0, "insrRrno")
                      , "brdt"     : this.pv_params.jwtData.birthday
                      , "mblTelno" : this.dsBscInfo.getColumn(0, "mblTelno1")+this.dsBscInfo.getColumn(0, "mblTelno2")+this.dsBscInfo.getColumn(0, "mblTelno3")
                    };
        this.afsfPopupMoblCet(obj, this.fnPopupMoblCetCallback, param);*/
    
};
]]></Script>
