                          <Cell col="4" cssclass="grid_col_right" displaytype="calendarcontrol" edittype="date" calendardateformat="yyyy-MM-dd" text="bind:workBgngYmd" calendardisplaynulltype="nullmask"/>
                          <Cell col="5" cssclass="grid_col_right" displaytype="calendarcontrol" edittype="date" calendardateformat="yyyy-MM-dd" text="bind:workEndYmd" calendardisplaynulltype="nullmask"/>
