//수정후
this.divAtteCd_rdoAtteCd_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	if(this.dsAtteList.getColumn(this.divGrid.form.grdAtteList.currentrow, "clrm"+(this.divGrid.form.grdAtteList.currentcol-5)) != "000"){
		this.dsAtteList.setColumn(this.divGrid.form.grdAtteList.currentrow, "d"+(this.divGrid.form.grdAtteList.currentcol-5),        e.postvalue);
		this.dsAtteList.setColumn(this.divGrid.form.grdAtteList.currentrow, "dNm"+(this.divGrid.form.grdAtteList.currentcol-5),      e.posttext.substring(0, 1));
		this.dsAtteList.setColumn(this.divGrid.form.grdAtteList.currentrow, "updateYn"+(this.divGrid.form.grdAtteList.currentcol-5), "Y");
	}
};

this.divAtteRmkCn_edtAtteRmkCn_onchanged = function(obj:nexacro.Edit,e:nexacro.ChangeEventInfo)
{
	if(this.dsAtteList.getColumn(this.divGrid.form.grdAtteList.currentrow, "clrm"+(this.divGrid.form.grdAtteList.currentcol-5)) != "000"){
		this.dsAtteList.setColumn(this.divGrid.form.grdAtteList.currentrow, "atteRmkCn"+(this.divGrid.form.grdAtteList.currentcol-5), e.posttext);
		this.dsAtteList.setColumn(this.divGrid.form.grdAtteList.currentrow, "updateYn"+(this.divGrid.form.grdAtteList.currentcol-5),  "Y");
	}
};

//2023.08.02 데이터 양 초과로 조회조건 추가에 따른 세팅
this.divSearch_cboYm_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	if (this.dsSearch.getColumn(0, "tiMonth") == ""){
		this.dsDd.clearData();
		var nRow = this.dsDd.addRow();		
		
		this.dsDd.setColumn(nRow, "unyCdValue", "");	
		this.dsDd.setColumn(nRow, "unyCdValueNm", "- 선택 -");
		this.dsSearch.setColumn(0, "dd", "");		
		return;
	}
	
	this.dsDd.clearData();
	var nRow = this.dsDd.addRow();		
	
	this.dsDd.setColumn(nRow, "unyCdValue", "");	
	this.dsDd.setColumn(nRow, "unyCdValueNm", "- 선택 -");
	this.dsSearch.setColumn(0, "dd", "");		
	
	var dt = this.dsSearch.getColumn(0, "tiMonth");
	var lastDd = this.afsfGetLastDd(dt);
	var day = "";
	var weekCnt = 0;

	for(var i = 1; i <= lastDd; i++){
		day = dt+String(i).padLeft(2, "0");
		var dfkNum = this.afsfGetDfk(day);
		var dfkName = this.afsfGetDfk(day);
		if (dfkNum == '6'){
			var nRow = this.dsDd.addRow();		
			weekCnt++;
			if (String(1).padLeft(2, "0") == String(i).padLeft(2, "0")){		
				this.dsDd.setColumn(nRow, "unyCdValue", String(1).padLeft(2, "0")+String(i).padLeft(2, "0"))	
				this.dsDd.setColumn(nRow, "unyCdValueNm", String(1).padLeft(2, "0")+"일 ("+nRow+"주차)")					
			}
			else if (i < 7){	
				this.dsDd.setColumn(nRow, "unyCdValue", String(1).padLeft(2, "0")+String(i).padLeft(2, "0"))
				this.dsDd.setColumn(nRow, "unyCdValueNm", String(1).padLeft(2, "0") + "일 ~ "+String(i).padLeft(2, "0")+"일 ("+nRow+"주차)")				
			}
			else{		
				this.dsDd.setColumn(nRow, "unyCdValue", String(i-6).padLeft(2, "0")+String(i).padLeft(2, "0"))
				this.dsDd.setColumn(nRow, "unyCdValueNm", String(i-6).padLeft(2, "0") + "일 ~ "+String(i).padLeft(2, "0")+"일 ("+nRow+"주차)")				
			}
		}
		if (i+6 > lastDd && dfkNum == '7'){
			var nRow = this.dsDd.addRow();			
			if (i == lastDd && dfkNum == '7'){
				this.dsDd.setColumn(nRow, "unyCdValue", String(i).padLeft(2, "0")+String(lastDd).padLeft(2, "0"))
				this.dsDd.setColumn(nRow, "unyCdValueNm", String(i).padLeft(2, "0") + "일 ("+nRow+"주차)")						
			}else{
				this.dsDd.setColumn(nRow, "unyCdValue", String(i).padLeft(2, "0")+String(lastDd).padLeft(2, "0"))
				this.dsDd.setColumn(nRow, "unyCdValueNm", String(i).padLeft(2, "0") + "일 ~ "+String(lastDd).padLeft(2, "0")+"일 ("+nRow+"주차)")				
			}
			
		}
	};	
	
	
};
]]></Script>
