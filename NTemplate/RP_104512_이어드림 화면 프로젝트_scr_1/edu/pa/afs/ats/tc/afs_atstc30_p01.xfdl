// 					}
// 				}
// 			}

			//수정본
			for(var nIdx=6; nIdx<=(nColCnt-1); nIdx++){
				var sDfkNm = this.afsfGetDfkNm(this.dsSearch.getColumn(0, "tiMonth")+String(nIdx-5).padLeft(2, "0"));
				var sDfkCd = this.afsfGetDfk(this.dsSearch.getColumn(0, "tiMonth")+String(nIdx-5).padLeft(2, "0"));
				var sCss   = "";
				var cnt    = 0;						
				if(sDfkCd == "6"){
					sCss   = "cell_Font_Blue";
				}else if(sDfkCd == "7"){
					sCss   = "cell_Font_Red";
				}
				
				this.divGrid.form.grdAtteList.setCellProperty("head",(1*nColCnt-6)+nIdx, "text",     sDfkNm); // 헤더명(2행)
				this.divGrid.form.grdAtteList.setCellProperty("head",nIdx,               "cssclass", sCss);   // 헤더색
				this.divGrid.form.grdAtteList.setCellProperty("head",(1*nColCnt-6)+nIdx, "cssclass", sCss);   // 헤더색(2행)

				if(this.smfIsMobile()){				
					var tiseqIdNum = this.dsAtteList.findRowExpr("tiSeqNo"+(nIdx-5) +"!= null &&" + "tiSeqNo"+(nIdx-5) +"!= ''")
					if (tiseqIdNum != -1){
						this.divGrid.form.grdAtteList.setFormatColProperty(nIdx, "size", 60);						
					}else{
						this.divGrid.form.grdAtteList.setFormatColProperty(nIdx, "size", 0);
					}
				}else{
// 					if(sLastDay < nIdx -5){
// 						this.divGrid.form.grdAtteList.setFormatColProperty(nIdx, "size", 0);
// 					}else{
// 						this.divGrid.form.grdAtteList.setFormatColProperty(nIdx, "size", 35);
// 					}		
					//2023.08.02 pc화면도 출결일자만 나오게 수정
					var tiseqIdNum = this.dsAtteList.findRowExpr("tiSeqNo"+(nIdx-5) +"!= null &&" + "tiSeqNo"+(nIdx-5) +"!= ''")
					if (tiseqIdNum != -1){
						this.divGrid.form.grdAtteList.setFormatColProperty(nIdx, "size", 35);						
					}else{
						this.divGrid.form.grdAtteList.setFormatColProperty(nIdx, "size", 0);
					}					
					
				}
			}

			//this.divGrid.form.grdAtteList.set_autofittype(true);
		});
}

 /**
  * 해당월 마지막 일자 리턴 
  *
  * @param  날짜
  * @return 요일
  * @see    afsfDfk('20220101');
  */
// 2023.08.02 출결 데이터 양 초과로 인한 조회조건 관련 스크립트
this.afsfGetLastDd = function(dt){
 	var nMonth = 0;
 	var nLastDate = 0;

 	if (this.isNil(dt)){
 		return 0;
 	}
 	var nY = parseInt(dt.substring(0,4),10); 	
 	nMonth = parseInt(dt.substr(4,2),10);
 	if (nMonth == 1 || nMonth == 3 || nMonth == 5 || nMonth == 7 || nMonth == 8 || nMonth == 10 || nMonth == 12){
 		nLastDate = 31;
 	}
 	else if (nMonth == 2){
		//윤달 체크
		if ((nY % 4) == 0){
			if ((nY % 100) != 0 || (nY % 400) == 0){
				nLastDate = 29;
			}else{
				nLastDate = 28;
			}
		}else{
			nLastDate = 28;
		}
 	}
 	else{
 		nLastDate = 30;
 	}
 	return nLastDate;
}

