//수정후
this.grdAtteList_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if(e.col > 5){
		if(this.dsAtteList.getColumn(this.divGrid.form.grdAtteList.currentrow, "clrm"+(this.divGrid.form.grdAtteList.currentcol-5)) != "000"){
			this.dsAtteList.set_updatecontrol(false);
			this.dsAtteList.setColumn(e.row, "tiYmd",     this.dsAtteList.getColumn(e.row, "scMonth")+String(obj.getCellProperty("head",e.col,"text")).padLeft(2, "0"));
			this.dsAtteList.setColumn(e.row, "tms",       this.dsAtteList.getColumn(e.row, "tms"+(e.col-5)));
			this.dsAtteList.setColumn(e.row, "atteCd",    this.dsAtteList.getColumn(e.row, "d"+(e.col-5)));
			this.dsAtteList.setColumn(e.row, "atteRmkCn", this.dsAtteList.getColumn(e.row, "atteRmkCn"+(e.col-5)));
			this.dsAtteList.set_updatecontrol(true);
			this.divAtteCd.form.rdoAtteCd.set_readonly(false);
			this.divAtteRmkCn.form.edtAtteRmkCn.set_readonly(false);
		}else{
			this.dsAtteList.setColumn(e.row, "tiYmd",     "");
			this.dsAtteList.setColumn(e.row, "tms",       "");
			this.dsAtteList.setColumn(e.row, "atteCd",    "");
			this.dsAtteList.setColumn(e.row, "atteRmkCn", "");
			this.divAtteCd.form.rdoAtteCd.set_readonly(true);
			this.divAtteRmkCn.form.edtAtteRmkCn.set_readonly(true);
		}
	}else {
		this.dsAtteList.setColumn(e.row, "tiYmd",     "");
		this.dsAtteList.setColumn(e.row, "tms",       "");
		this.dsAtteList.setColumn(e.row, "atteCd",    "");
		this.dsAtteList.setColumn(e.row, "atteRmkCn", "");
		this.divAtteCd.form.rdoAtteCd.set_readonly(true);
		this.divAtteRmkCn.form.edtAtteRmkCn.set_readonly(true);
	}
};

