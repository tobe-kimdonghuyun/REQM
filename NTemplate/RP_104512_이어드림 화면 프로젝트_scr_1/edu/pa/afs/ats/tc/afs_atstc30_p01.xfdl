    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 > 방과후학교(외부강사) > 프로그램관리
*  @FileName 	afs_atstc30_m00.xfdl 
*  @Creator 	임대성
*  @CreateDate 	2022.05.31
*  @Desction    방과후학교(외부강사) 프로그램관리
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.05.31            임대성                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::afs_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역 
 ************************************************************************************************/
this.fv_userId   = "";
this.fv_insrRrno = "";
this.fv_cddcCd   = "";


/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	if(this.smfIsMobile()){
		this.divGrid.form.grdAtteList.set_formatid("mobile");
	}else{
		this.divGrid.form.grdAtteList.set_formatid("default");
	}
	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	/*this.smfValidateService("validateMain", {
			url : "/afs_ats_tc30_000.do",
		})
		.mappingRulesetToForm(this.divSearch, "dsSearch")
		.run()
		.callback(function(callbackParams) {
			
		});*/
		
	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	this.dsSearch.copyRow(0, this.pv_params.dsPgm, 0);	
	
	this.afsfMakeYm(this.dsYm, "", "", this.dsSearch.getColumn(0, "aslLectBgngYmd"), this.dsSearch.getColumn(0, "aslLectEndYmd"), "", "N");
	
	this.afsfCodeList(this.dsCd);

	// 2023.07.28 데이터 크기 조절
	this.dsSearch.setColumn(0, "dd", "");
	
	if(this.dsSearch.getColumn(0, "scaSysScCd") == "HIS"){
		this.divGrid.form.grdAtteList.setCellProperty("head", 1, "text", "계열/학년/학과"); 
		if(this.smfIsMobile()){
			this.divGrid.form.grdAtteList.setFormatColProperty(1, "size", 200);
		}else{
			this.divGrid.form.grdAtteList.setFormatColProperty(1, "size", 120);
		}
		this.staGrd.set_text("계열/학년/학과");
		//this.staGrd.set_width("10%");
		//this.divGrd.set_width("10%");
		
	}else if(this.dsSearch.getColumn(0, "scaSysScCd") == "SPS"){
		this.divGrid.form.grdAtteList.setFormatColProperty(1, "size", 100);
	}
	//this.cboYm.redrow();
};


/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/




/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback = function(svcid,errcd,errmsg){
	console.log("svcid : "+svcid);
	if(errcd == -1) return;
	
	switch(svcid) {
		case "listAtteCd" : 
		    this.dsAtteCd.insertRow(0);
			this.dsAtteCd.setColumn(0, "unyCdValue",   "0");
			this.dsAtteCd.setColumn(0, "unyCdValueNm", "출석");
			break;
		
	}
};

/**
 * @description Popup CallBack 함수(선택)
*/
this.fnPopupCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
	switch(svcid) {
		case "" : 
			break;
	}
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * 출석부 조회
 */
this.fnListSearch = function(){
	if(this.dsSearch.getColumn(0, "tiMonth") == ""){
		this.smfAlert('CM022', ['년월'] );
		return;
	}
	
	// 2023.07.28 데이터 크기 조절
	if(this.dsSearch.getColumn(0, "dd") == ""){
		this.smfAlert('CM022', ['일자'] );
		return;
	}	
	var dd = this.dsSearch.getColumn(0, "dd")
	this.dsSearch.setColumn(0, "ddFirst", dd.substr(0,2));
	this.dsSearch.setColumn(0, "ddSecond", dd.substr(2,2));

	// 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			console.log(this.dsAtteList.saveXML());
			
			var nColCnt   = this.divGrid.form.grdAtteList.getFormatColCount();
			var sLastDay  = this.smfLastDateNum(this.dsSearch.getColumn(0, "tiMonth")+"01");
			//this.divGrid.form.grdAtteList.set_autofittype(false);
			
			//주석풀기
// 			for(var nIdx=5; nIdx<=(nColCnt-1); nIdx++){
