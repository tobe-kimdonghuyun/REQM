<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="frmTemp01" width="1200" height="738" titletext="위탁업체강사신청관리" onload="form_onload" nHeight="754">
    <Layouts>
      <Layout height="738" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="65" height="54" text="" right="0" accessibilityenable="false" accessibilityrole="none" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout initvalueid="ivDivAccessibilityOff">
              <ImageViewer id="imgTitle" taborder="0" text="위탁업체강사신청관리" left="0" top="0" height="54" cssclass="img_WF_SubTit01" width="310" initvalueid="ivTitleAccessibilityOn" accessibilitylabel="위탁업체강사신청관리"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divSearch" taborder="1" left="0" top="149" height="70" cssclass="div_WF_Search" right="0" accessibilityenable="false" accessibilityrole="none" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout initvalueid="ivDivAccessibilityOff">
              <Static id="staShlNm" taborder="0" text="학교명" left="0" top="20" width="68" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" accessibilitylabel="학교명"/>
              <Combo id="cboShlNm" taborder="1" left="68" width="144" height="30" innerdataset="dsShlCd" codecolumn="unyCdValue" datacolumn="unyCdValueNm" index="0" readonly="false" top="20" value="" initvalueid="ivCmbNormal" text="- 전체 -" accessibilitylabel="학교명 구분"/>
              <Static id="staInsrNm" taborder="2" text="강사명" left="212" top="20" width="68" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" accessibilitylabel="강사명"/>
              <Edit id="edtInsrNm" taborder="3" left="280" top="20" width="140" height="30" initvalueid="ivCmbNormal" text="아무개" accessibilitylabel="강사명 입력"/>
              <Static id="staAslAplyStsScCd" taborder="4" text="상태" left="420" top="20" width="55" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" accessibilitylabel="상태"/>
              <Combo id="cboAslAplyStsScCd" taborder="5" left="475" width="144" height="30" innerdataset="dsAslAplyStsScCd" codecolumn="unyCdValue" datacolumn="unyCdValueNm" index="0" readonly="false" top="20" value="" initvalueid="ivCmbNormal" text="- 전체 -" accessibilitylabel="상태 구분"/>
              <Button id="btnInit" taborder="6" text="초기화" top="20" width="88" height="30" cssclass="btn_WF_Refresh03" onclick="divSearch_btnInit_onclick" right="100" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="초기화"/>
              <Button id="btnSearch" taborder="7" text="조회" top="20" width="72" height="30" cssclass="btn_WF_Search03" right="20" onclick="divSearch_btnSearch_onclick" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="조회"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnRegAply" taborder="2" text="등록신청" top="239" height="30" width="76" cssclass="btn_WF_Custom" visible="true" right="194" initvalueid="ivBtnAccessibilityLink" accessibilitydescription="새창열기" accessibilitylabel="등록신청" onclick="btnRegAply_onclick"/>
        <Button id="btnInfoChgAply" taborder="3" text="정보변경신청" top="239" height="30" width="102" cssclass="btn_WF_Custom" visible="true" right="84" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="정보변경신청" onclick="btnInfoChgAply_onclick"/>
        <Button id="btnAplyRtrcn" taborder="4" text="신청취소" top="239" height="30" width="76" cssclass="btn_WF_Custom" visible="true" right="0" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="신청취소" onclick="btnAplyRtrcn_onclick"/>
        <Grid id="grdMain" taborder="5" left="0" top="279" height="439" autofittype="col" right="0" binddataset="dsMain" initvalueid="ivGrdAccessibilityOn" accessibilitylabel="위탁업체강사신청관리 : 순번,학교명,강사명,신청일자,처리일자,상태 등의 정보제공" onheadclick="grdMain_onheadclick" selecttype="cell">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="48"/>
                <Column size="40"/>
                <Column size="100"/>
                <Column size="100"/>
                <Column size="100"/>
                <Column size="100"/>
                <Column size="100"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell displaytype="checkboxcontrol" edittype="checkbox"/>
                <Cell col="1" text="순번"/>
                <Cell col="2" text="학교명"/>
                <Cell col="3" text="강사명"/>
                <Cell col="4" text="신청일시" cssclass="LineNo"/>
                <Cell col="5" text="처리일시"/>
                <Cell col="6" text="상태" cssclass="LineNo"/>
              </Band>
              <Band id="body">
                <Cell text="bind:chk" displaytype="expr:aslAplyStsScCd == 10 || aslAplyStsScCd == 20 ? 'checkboxcontrol' : 'none'" edittype="expr:aslAplyStsScCd == 10 || aslAplyStsScCd == 20 ? 'checkbox' : 'none'"/>
                <Cell col="1" text="expr:currow + 1" textAlign="center"/>
                <Cell col="2" text="bind:shlCdNm"/>
                <Cell col="3" text="bind:userNm"/>
                <Cell col="4" displaytype="mask" edittype="none" text="bind:regDt" cssclass="LineNo" maskedittype="string" maskeditformat="@@@@.@@.@@ @@:@@" textAlign="center"/>
                <Cell col="5" displaytype="expr:mdfcnDt != null ? 'mask' : 'normal'" edittype="none" text="bind:mdfcnDt" cssclass="LineNo" maskedittype="string" maskeditformat="@@@@.@@.@@ @@:@@" textAlign="center"/>
                <Cell col="6" text="bind:aslAplyStsScCdNm" textAlign="center" cssclass="LineNo"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="sta_main" taborder="6" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta01" taborder="7" left="0" top="divTitle:0" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta02" taborder="8" left="0" top="219" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta04" taborder="10" left="0" top="718" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta03" taborder="9" left="0" top="269" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    방과후학교(외부강사) > 위탁업체강사신청관리
*  @FileName 	afs_atscm30_m00.xfdl
*  @Creator 	김민성
*  @CreateDate 	2022.06.08
*  @Desction    방과후학교(외부강사) 위탁업체강사신청관리
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.06.08            김민성                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::afs_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_cddcCd      = ""; 	//시도교육청코드 
this.fv_brno        = "";	//사업자등록번호
this.fv_cnsgnComyId = "";

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
			url : "/afs_ats_cm30_000.do",
		})
		.mappingRulesetToForm(this.divSearch, "search")
		.run()
		.callback(function(callbackParams) {
			this.fnSearchType();
		});
		
	this.afsfSetSession(this);
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 위탁업체강사 신청목록 조회
 */
this.fnListSearch = function(){
	// 서비스 객체 생성
	this.smfSearchService("list")
		.messagePrefix(["등록신청"])
		// 데이터 검증
		.validateForm(this.divSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});
}

/**
 * 위탁업체강사 등록신청
 */
this.fnInfoRegAply = function()
{
	// 서비스 객체 생성
	this.smfSaveService("insert")
		.messagePrefix(["등록신청"])
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;
			this.smfAlert('PA001', ['등록신청'], this.callback ); // 등록신청 되었습니다.
			this.fnListSearch();
	});
};

/**
 * 위탁업체강사 정보변경신청
 */
this.fnInfoChgAply = function(){
	// 서비스 객체 생성
	this.smfSaveService("update")
		.messagePrefix(["정보변경신청"])
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.smfAlert('PA001', ['정보변경신청'], this.callback ); // 정보변경신청 되었습니다.
			this.fnListSearch();
		});
}

/**
 * 위탁업체강사 신청취소
 */
this.fnAplyRtrcn = function(){
	// 서비스 객체 생성
	this.smfDeleteService("delete")
		.messagePrefix(["신청취소"])
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.smfAlert('PA001', ['신청취소'], this.callback ); // 신청취소 되었습니다.
			this.fnListSearch();
		});
}

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
		
	switch(svcid) {	
	
		case "selectSession" : 
			this.divSearch_btnInit_onclick();
			
			this.fv_cddcCd        = this.dsSearch.getColumn(0,"cddcCd"); 	//시도교육청코드 
			this.fv_brno          = this.dsSearch.getColumn(0,"brno");
			this.fv_cnsgnComyId   = this.dsSearch.getColumn(0,"cnsgnComyId");
			
			this.dsCd.setColumn(1,'cddcCd',      this.fv_cddcCd);
			this.dsCd.setColumn(1,'brno',        this.fv_brno);
			this.dsCd.setColumn(1,'cnsgnComyId', this.fv_cnsgnComyId);
			
			this.afsfCodeList(this.dsCd);
			break;
	}
};

/**
 * 등록신청 팝업 콜백
 */
this.fnPopupCallback = function(context, responseParams, sender){
	this.dsInsert.clearData();
	this.dsInsert.copyData(context.row);

	if(responseParams.name == "btnInfoChgAply"){
		this.fnInfoChgAply();
	}else if(responseParams.name == "btnRegAply"){
		
		this.fnInfoRegAply();
	}
}

/**
 * 메세지 콜백
 */
this.callback = function(){
}
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/




/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 조회조건 조회
 */
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnListSearch();
};

/**
 * 조회조건 초기화
 */
this.divSearch_btnInit_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsSearch.setColumn(0, "shlCd",          "");
	this.dsSearch.setColumn(0, "insrNm",         "");
	this.dsSearch.setColumn(0, "aslAplyStsScCd", "");
};

/**
 * 등록신청 버튼 클릭
 */
this.btnRegAply_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var popupParams = {
		callback: this.fnPopupCallback,
		sender: obj,
		params: {
			procType: 'insert'
		},
	};
	
	this.smfDialog("_auto", "pa_afs_ats_cm::afs_atscm30_p01.xfdl", popupParams);
};

/**
 * 정보변경신청 버튼 클릭
 */
this.btnInfoChgAply_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var popupParams = {
		callback: this.fnPopupCallback,
		sender: obj,
		params: {
			procType: 'update'
		},
	};
	
	this.smfDialog("_auto", "pa_afs_ats_cm::afs_atscm30_p01.xfdl", popupParams);
};

/**
 * 신청취소 버튼 클릭
 */
this.btnAplyRtrcn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	const chkList = this.dsMain.extractRows("chk");
	
	if (chkList == -1){
		 this.smfAlert('PA002', '', this.callback ); // 조회된 자료가 없습니다. 
		 return;
	}
	
	if (chkList.length == 0){
		 this.smfAlert('CM013', ['행'], this.callback ); // 선택된 행이(가) 없습니다. 행을(를) 선택하여 주십시오.
		 return;
	}
	
	for(let i = 0; i < chkList.length ; i++){
		if (this.dsMain.getColumn(chkList[i], "aslAplyStsScCd") != '10' && this.dsMain.getColumn(chkList[i], "aslAplyStsScCd") != '20'){
			this.smfAlert('PA004', ['[등록요청/수정요청] 상태만 취소가'], this.callback ); // [등록요청/수정요청] 상태만 취소가 가능합니다.
			 return;
		}
	}
	
	this.fnAplyRtrcn();
};

/**
 * 위탁업체강사신청 목록 그리드 헤더 클릭
 */
this.grdMain_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if (e.col == 0){
		this.smfToggleChkHeader(obj, e, function (ds, nRow){
				if(ds.getColumn(nRow,"aslAplyStsScCd" )=="10" || ds.getColumn(nRow,"aslAplyStsScCd" )=="20"){
					return true;
				}else{
					return false;
				}
			});
	}
};


]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="inDatasets">search=dsSearch</Col>
            <Col id="outDatasets">dsMain=main</Col>
            <Col id="asynctp"/>
            <Col id="url">afs_ats_cm30_002.do</Col>
            <Col id="id">list</Col>
          </Row>
          <Row>
            <Col id="id">update</Col>
            <Col id="url">afs_ats_tc10_004.do</Col>
            <Col id="inDatasets">insert=dsInsert</Col>
          </Row>
          <Row>
            <Col id="id">delete</Col>
            <Col id="url">afs_ats_tc10_005.do</Col>
            <Col id="inDatasets">main=dsMain:U</Col>
          </Row>
          <Row>
            <Col id="url">afs_ats_tc10_003.do</Col>
            <Col id="id">insert</Col>
            <Col id="inDatasets">insert=dsInsert</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" oncolumnchanged="dsSearch_oncolumnchanged">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="cnsgnComyId" type="STRING" size="256"/>
          <Column id="shlCd" type="STRING" size="256"/>
          <Column id="insrNm" type="STRING" size="256"/>
          <Column id="aslAplyStsScCd" type="STRING" size="256"/>
          <Column id="brno" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="cddcCd"/>
            <Col id="cnsgnComyId"/>
            <Col id="shlCd"/>
            <Col id="insrNm"/>
            <Col id="aslAplyStsScCd"/>
            <Col id="brno"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcCd" type="string" size="256"/>
          <Column id="shlCd" type="string" size="256"/>
          <Column id="shlCdNm" type="string" size="256"/>
          <Column id="userId" type="string" size="256"/>
          <Column id="userNm" type="string" size="256"/>
          <Column id="insrAplySeqNo" type="string" size="256"/>
          <Column id="aslAplyStsScCd" type="string" size="256"/>
          <Column id="aslAplyStsScCdNm" type="string" size="256"/>
          <Column id="rgtrId" type="string" size="256"/>
          <Column id="regDt" type="string" size="256"/>
          <Column id="mdfrId" type="string" size="256"/>
          <Column id="mdfcnDt" type="string" size="256"/>
          <Column id="chk" type="int" size="1"/>
          <Column id="scaSysScCd" type="STRING" size="256"/>
          <Column id="cntnCtpvScCd" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsMainValid" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcCd" type="string" size="256"/>
          <Column id="shlCd" type="string" size="256"/>
          <Column id="shlNm" type="string" size="256"/>
          <Column id="userId" type="string" size="256"/>
          <Column id="userNm" type="string" size="256"/>
          <Column id="careHnfAplySeqNo" type="string" size="256"/>
          <Column id="eccHnfStsScCd" type="string" size="256"/>
          <Column id="eccHnfStsScNm" type="string" size="256"/>
          <Column id="rgtrId" type="string" size="256"/>
          <Column id="regDt" type="string" size="256"/>
          <Column id="mdfrId" type="string" size="256"/>
          <Column id="mdfcnDt" type="string" size="256"/>
          <Column id="chk" type="int" size="1"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsShlCd" useclientlayout="true">
        <ColumnInfo>
          <Column id="unyCdValue" type="STRING" size="256"/>
          <Column id="unyCdValueNm" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="unyCdValueNm">- 전체 -</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsAslAplyStsScCd" useclientlayout="true">
        <ColumnInfo>
          <Column id="unyCdValue" type="STRING" size="256"/>
          <Column id="unyCdValueNm" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="unyCdValueNm">- 전체 -</Col>
          </Row>
          <Row>
            <Col id="unyCdValue">01</Col>
            <Col id="unyCdValueNm">신청</Col>
          </Row>
          <Row>
            <Col id="unyCdValue">02</Col>
            <Col id="unyCdValueNm">승인</Col>
          </Row>
          <Row>
            <Col id="unyCdValue">03</Col>
            <Col id="unyCdValueNm">반려</Col>
          </Row>
          <Row>
            <Col id="unyCdValue">04</Col>
            <Col id="unyCdValueNm">신청취소</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsCd">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="outDs" type="STRING" size="256"/>
          <Column id="allYn" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
