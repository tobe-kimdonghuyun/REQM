<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="form" width="1200" height="643" titletext="위탁업체강사관리" nHeight="754" onload="form_onload">
    <Layouts>
      <Layout height="643" width="1200" screenid="ScreenDeskTop">
        <Div id="divTitle" taborder="0" left="0" top="65" height="54" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="위탁업체강사관리" left="0" top="0" height="54" cssclass="img_WF_SubTit01" width="250" initvalueid="ivTitleAccessibilityOn" accessibilitylabel="위탁업체강사관리"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnReg" taborder="1" text="등록" top="144" height="30" width="50" fittocontents="width" right="58" onclick="btnReg_onclick" initvalueid="ivBtnAccessibilityLink" accessibilitylabel="등록"/>
        <Button id="btnDelete" taborder="2" text="삭제" top="144" height="30" cssclass="btn_WF_Crud" width="50" right="0" initvalueid="ivBtnAccessibilityButton" onclick="btnDelete_onclick" accessibilitylabel="삭제"/>
        <Grid id="grdInsrList" taborder="3" left="0" top="184" autofittype="col" right="0" binddataset="dsInsrList" initvalueid="ivGrdAccessibilityOn" accessibilitylabel="위탁업체 소속강사 목록(순번, 강사명, 휴대전화번호, 이메일, 주소) 등의 정보제공" onheadclick="grdInsrList_onheadclick" height="439" oncellclick="grdInsrList_oncellclick" selecttype="cell">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="40"/>
                <Column size="40"/>
                <Column size="140"/>
                <Column size="140"/>
                <Column size="200"/>
                <Column size="500"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell displaytype="checkboxcontrol"/>
                <Cell col="1" text="순번"/>
                <Cell col="2" text="강사명"/>
                <Cell col="3" text="휴대전화번호" displaytype="normal"/>
                <Cell col="4" text="이메일"/>
                <Cell col="5" text="주소" cssclass="LineNo"/>
              </Band>
              <Band id="body">
                <Cell displaytype="checkboxcontrol" edittype="checkbox" text="bind:_chk"/>
                <Cell col="1" displaytype="normal" text="expr:currow+1" accessibilityenable="false" textAlign="right"/>
                <Cell col="2" text="bind:insrNm" textDecoration="underline" cssclass="cell_WF_Pointer"/>
                <Cell col="3" text="bind:mblTelno" maskeditclipmode="excludespace" textAlign="center" maskeditautoselect="true" displaytype="mask" edittype="none" maskeditformat="@@@-@@@@-@@@@" maskedittype="string"/>
                <Cell col="4" calendardateformat="yyyy-MM-dd " text="bind:emlAddr"/>
                <Cell col="5" text="bind:homeAddr" cssclass="LineNo"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="sta_main" taborder="4" left="0" top="0" height="70" cssclass="sta_GD_Size" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta01" taborder="5" left="0" top="114" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta03" taborder="6" left="0" top="174" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" onclick="Static99_00_00_00_00_01_00_00_onclick" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta04" taborder="7" left="0" top="grdInsrList:0" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
      <Layout name="Layout0" screenid="mobile" width="640" height="1024" mobileorientation="portrait" type="default"/>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 > 방과후학교(외부강사) > 위탁업체
*  @FileName 	afs_atscm20_m00
*  @Creator 	강채윤
*  @CreateDate 	2022.05.30
*  @Desction    방과후학교(외부강사) 위탁업체강사관리
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.05.30            강채윤                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
 include "lib::afs_script.xjs"

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_cddcCd      = ""; 	//시도교육청코드 
this.fv_brno        = "";	//사업자등록번호
this.fv_cnsgnComyId = "";

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{ 
	//폼을 초기화
	this.smfInitForm(this);
	
	this.afsfSetSession(this);
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 위탁업체 소속강사 목록 조회 Transaction
 */
this.fnListInsr = function () {

	// 서비스 객체 생성
	this.smfSearchService("list")
		
	// 실행
	.run()
	
	// 콜백
	.callback(function(callbackParams) {
		if(callbackParams.errors) return;
	});
	
};

/**
 * @description 소속강사 삭제 Transaction
 */
this.fnDeleteInsr = function(){

	// 서비스 객체 생성
	this.smfDeleteService("delete")
	
	//실행전 처리
	.beforeService(function(next) {
		var arrChk = this.dsInsrList.extractRows("_chk==1");
		this.dsInsrList.deleteMultiRows(arrChk);
		next();
	})
	
	//실행
	.run()
	
	// 콜백
	.callback(function(callbackParams) {
		if(callbackParams.errors) return;
		this.smfAlert('PA001', ['삭제']);	//삭제 되었습니다.
		
		//위탁업체 소속강사 목록 재조회
		this.fnListInsr();
	});
}

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback  = function(svcid,errcd,errmsg) {
	if(errcd < 0) { 
		return;
	}
	
	switch(svcid) {	
	
		case "selectSession" : 
			this.fv_cddcCd        = this.dsSearch.getColumn(0,"cddcCd"); 	//시도교육청코드 
			this.fv_brno          = this.dsSearch.getColumn(0,"brno");
			this.fv_cnsgnComyId   = this.dsSearch.getColumn(0,"cnsgnComyId");
			
			//위탁업체 소속강사 목록 조회
			this.fnListInsr(); 
	
			break;
	}
	
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/


/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 등록버튼 클릭
 */
this.btnReg_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if ( this.isNil( this.fv_cnsgnComyId ) ) {
		this.smfAlert('PA003', ['위탁업체정보가']); //위탁업체정보가 없습니다.
		return;
	}

	var sUrl = "pa_afs_ats_tc::afs_atstc00_m00.xfdl"
	var params = {};
	params.cnsgnComyId = this.fv_cnsgnComyId;
	params.type = "REG";
	params.menu = "";
	
	this.smfSetWorkPage(sUrl, params);
};

/**
 * @description 삭제버튼 클릭
 */
 this.btnDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//체크박스 선택 여부 확인
	var arrChk = this.dsInsrList.extractRows("_chk");

	if(this.isNil(arrChk)){  // 체크한 소속 강사 없으면
		//선택된 {0}이(가) 없습니다. {0}을(를) 선택하여 주십시오.
		this.smfAlert('CM013', ['강사']);	 //선택된 강사이(가) 없습니다. 강사을(를) 선택하여 주십시오.
		return;
	}
	
	//소속강사 삭제처리
	this.fnDeleteInsr();
};

/**
 * @description 그리드 셀 더블클릭
 */
this.grdInsrList_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if (e.col == 2) {
		//강사명 더블클릭
		if ( this.isNil( this.fv_cnsgnComyId ) ) {
			this.smfAlert('PA003', ['위탁업체정보가']); // 위탁업체정보가 없습니다.
			return;
		}

		var sUrl = "pa_afs_ats_tc::afs_atstc00_m00.xfdl"
		var params = {};
		params.cnsgnComyId = this.fv_cnsgnComyId;
		params.userId      = this.dsInsrList.getColumn(e.row, "userId");
		params.insrRrno    = this.dsInsrList.getColumn(e.row, "insrRrno");
		params.type        = "SEARCH";
		params.menu        = "";

		this.smfSetWorkPage(sUrl, params);
	}
};

/**
 * @description 그리드 체크박스 헤드 클릭
*/
this.grdInsrList_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{   
	//체크박스 전체 선택 
	this.smfSetGridCheckAll(obj, e);
};

]]></Script>
    <Objects>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="cnsgnComyId" type="STRING" size="256" description="위탁업체ID"/>
          <Column id="cddcCd" type="STRING" size="256" description="시도교육청코드"/>
          <Column id="brno" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="outDatasets">dsInsrList=dsInsrList</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="id">list</Col>
            <Col id="url">/afs_ats_cm20_001.do</Col>
          </Row>
          <Row>
            <Col id="id">delete</Col>
            <Col id="inDatasets">dsInsrList=dsInsrList:U</Col>
            <Col id="url">/afs_ats_cm20_002.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsInsrList" useclientlayout="true">
        <ColumnInfo>
          <Column id="_chk" type="int" size="1"/>
          <Column id="cddcCd" type="STRING" size="256" description="시도교육청코드"/>
          <Column id="cnsgnComyId" type="STRING" size="256" description="위탁업체ID"/>
          <Column id="userId" type="string" size="256" description="사용자ID"/>
          <Column id="insrNm" type="string" size="256" description="강사명"/>
          <Column id="mblTelno" type="string" size="256" description="휴대전화번호"/>
          <Column id="homeAddr" type="string" size="256" description="자택주소"/>
          <Column id="emlAddr" type="string" size="256" description="이메일주소"/>
          <Column id="insrScCd" type="STRING" size="256" description="강사구분코드"/>
          <Column id="regSn" type="INT" size="1"/>
          <Column id="delYn" type="STRING" size="256" description="삭제여부"/>
          <Column id="insrRrno" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
  </Form>
</FDL>
