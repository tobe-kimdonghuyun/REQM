              <Static id="staPrgeTelno00" taborder="8" left="225" height="30" text="-" top="47" onclick="Static45_onclick" width="15" cssclass="sta_WF_AC" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtPrgeTelno2" taborder="9" height="30" text="넥사크로17" left="240" width="70" top="47" readonly="false" maxlength="4" initvalueid="ivEdtNormal" accessibilitylabel="대표전화번호2 입력" inputtype="digit"/>
