          </Layouts>
        </Div>
        <Static id="sta_main" taborder="5" left="0" top="0" height="70" cssclass="sta_Ctitle" text="70" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta01" taborder="6" left="0" top="114" height="20" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
        <Static id="sta02" taborder="7" left="0" top="165" height="10" cssclass="sta_GD_Size" text="10" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    대국민 > 방과후학교(외부강사) > 강사정보
*  @FileName 	afs_atscm00_m00
*  @Creator 	윤성민
*  @CreateDate 	2022.05.30
*  @Desction    방과후학교(외부강사) 강사정보
*
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.05.30            윤성민                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::afs_script.xjs"


/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 this.fv_cddcCd   = ""; //시도교육청코드 
 this.fv_brno     = ""; //임시데이터 사업자등록번호

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{  

	//폼을 초기화
	this.smfInitForm(obj);
	
	var sFilter = "lvl==0&&isShow!='N'&cnsgnYn =='Y'";
	this.parent.parent.parent.parent.divTop.form.dsMenu.set_filterstr(sFilter);
	this.parent.parent.parent.parent.divTop.form.fnDestroyTopMenu();
	this.parent.parent.parent.parent.divTop.form.fnSetTopMenu();
	
    // 서버단에 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
			url: "/afs_ats_cm00_000.do",
		})

		.mappingRulesetToForm(this.divBscInfo, "bscInfo")
		.run() 
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.afsfSetSession(this);
		})
	;	
	
	
};



/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 위탁업체 기본정보 조회 Transaction
 */
this.fnSelectCnsgnComyInfo = function () {

 	// 서비스 객체 생성
	this.smfSearchService("selectCnsgnComyInfo")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;

			if ( this.dsBscInfo.rowcount == 0 ) {
				var nRowIdx = this.dsBscInfo.insertRow();			
				this.dsBscInfo.setColumn(0,"cddcCd",         this.fv_cddcCd);
				this.dsBscInfo.setColumn(0,"brno",           this.fv_brno);
				this.dsBscInfo.setColumn(0,"bankCd",         "");
				this.dsBscInfo.setColumn(0,"prftmNoprfScCd", "");
				
				return;
			}	
			//전화번호 셋팅
			this.afsfSplitTelno(this.dsBscInfo, "prgeTelno");
			this.afsfSplitTelno(this.dsBscInfo, "prgeMblTelno");

			this.afsfCallbackTrim(callbackParams); //cboColumn 공백제거
		});
		
}

/**
 * @description 위탁업체 기본정보 저장 Transaction
 */
this.fnSaveCnsgnComyInfo = function ()
{
 	//전화번호결합
	this.dsBscInfoTelno(this.dsBscInfo.updatecontrol);

// 서비스 객체 생성 
	this.smfSaveService("saveCnsgnComyInfo")
		// 데이터 존재 필수
		.requireExistsData(this.dsBscInfo)
		// 데이터 검증
		.validateForm(this.divBscInfo)
		// 데이터 변경 필수 
		.requireModifredData(this.dsBscInfo)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;
			this.smfAlert('CM002');	//저장이 완료되었습니다.
			this.fnSelectCnsgnComyInfo();	//재조회
		});
}


/**
 * @description 위탁업체 기본정보 삭제 Transaction
 */
this.fnDeleteCnsgnComyInfo = function () {

	if ( this.dsBscInfo.getRowType() == 2) {
		//신규 상태이면 return;
		this.smfAlert('PA003', ['저장된 데이터가']); //저장된 데이터가 없습니다.
		return;
	}
	if ( this.dsBscInfo.getColumn(0, "cnsgnComyByInsrNu") != 0){
		this.smfAlert('PA003', ['등록된 강사가 존재하여 삭제할 수']); //등록된 강사가 존재하여 삭제할 수 없습니다.
		return;
	}
	
	// 서비스 객체 생성 
	this.smfSaveService("saveCnsgnComyInfo")
		//confirm 메시지 삭제로 변경
		.messagePrefix("삭제")
		// 전처리
		.beforeService(function(next) {
			this.dsBscInfo.set_updatecontrol(false);
			this.dsBscInfo.setRowType(0, Dataset.ROWTYPE_DELETE);
			this.dsBscInfo.set_updatecontrol(true);		
			next();
		})
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return;
			this.smfAlert('PA001', ['삭제']); //삭제 되었습니다.
			this.fnSelectCnsgnComyInfo();	//재조회
		});
}

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description Transaction CallBack 함수(선택)
*/
this.fnTransCallback  = function(svcid,errcd,errmsg) {
	if(errcd < 0) { 
		return;
	}
	
	switch(svcid) {	
	
		case "selectSession" : 
			this.fv_cddcCd   = this.dsSearch.getColumn(0,"cddcCd"); 	//시도교육청코드 
			this.fv_brno     = this.dsSearch.getColumn(0,"brno");

			this.afsfCodeList(this.dsCd);
			//위탁업체 기본정보 조회
			this.fnSelectCnsgnComyInfo();
	
			break;
	}
};

/**
 * @description 주소검색 callback 
 */
this.afsfPopupCallback = function(e, sender){
	var nRow = this.dsBscInfo.rowposition;	
	if (sender == this.divBscInfo.form.btnCnsgnComyAddr) {
		this.dsBscInfo.setColumn(nRow, "cnsgnComyAddr", e.roadNmAddr+" "+e.roadNmDtl);
	}
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/**
 * @description 전화번호 결합
 */
this.dsBscInfoTelno = function(){
 	//전화번호결합
	this.dsBscInfo.set_updatecontrol(false);
	var telno1 = this.dsBscInfo.getColumn(0,"prgeTelno1");	
	var telno2 = this.dsBscInfo.getColumn(0,"prgeTelno2");	
	var telno3 = this.dsBscInfo.getColumn(0,"prgeTelno3");
	var telno = [telno1,telno2,telno3].join("-"); 
	if ( telno == "--" ) telno = "";
	this.dsBscInfo.setColumn(0,"prgeTelno",telno);
	
	var mblTelno1 = this.dsBscInfo.getColumn(0,"prgeMblTelno1");	
	var mblTelno2 = this.dsBscInfo.getColumn(0,"prgeMblTelno2");	
	var mblTelno3 = this.dsBscInfo.getColumn(0,"prgeMblTelno3");	
	var mblTelno = [mblTelno1,mblTelno2,mblTelno3].join("-");
	this.dsBscInfo.setColumn(0,"prgeMblTelno",mblTelno);
	this.dsBscInfo.set_updatecontrol(true);
}
 
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

/**
 * @description 주소검색 버튼 클릭
 */
 
this.divBscInfo_btnAddr_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (this.dsBscInfo.rowcount < 1) return;
	
	//주소검색 팝업
	var params = {};
	//params.test = '1234';
	this.afsfPopupAddr(obj, this.afsfPopupCallback, params);
};

/**
 * @description 위탁업체 기본정보 저장버튼 클릭
 */
this.btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	this.fnSaveCnsgnComyInfo();
};

/**
 * @description 위탁업체 기본정보 삭제버튼 클릭
 */
this.btnDelete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnDeleteCnsgnComyInfo();
};

this.divBscInfo_cboBankCd_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	
};
]]></Script>
    <Objects>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="cnsgnComyId" type="STRING" size="256" description="위탁업체ID"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="brno" type="STRING" size="256" description="사업자등록번호"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsBscInfo" useclientlayout="true" oncolumnchanged="dsBscInfo_oncolumnchanged">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256" description="시도교육청코드"/>
          <Column id="cnsgnComyId" type="STRING" size="256" description="위탁업체ID"/>
          <Column id="comyNm" type="STRING" size="256" description="업체명"/>
          <Column id="brno" type="STRING" size="256" description="사업자등록번호"/>
          <Column id="prftmNoprfScCd" type="STRING" size="256" description="영리비영리구분코드"/>
          <Column id="rveNm" type="STRING" size="256" description="대표자명"/>
          <Column id="prgeTelno" type="STRING" size="256" description="담당자전화번호"/>
          <Column id="prgeTelno1" type="STRING" size="256" description="담당자전화번호"/>
          <Column id="prgeTelno2" type="STRING" size="256" description="담당자전화번호"/>
          <Column id="prgeTelno3" type="STRING" size="256" description="담당자전화번호"/>
