              <Edit id="edtPrgeMblTelno1" taborder="13" height="30" text="넥사크로17" left="555" width="70" top="47" readonly="false" maxlength="4" initvalueid="ivEdtEssential" accessibilitylabel="휴대전화번호1 입력" inputtype="digit"/>
              <Static id="staPrgeMblTelno00" taborder="14" left="625" height="30" text="-" top="47" onclick="Static45_onclick" width="15" initvalueid="ivStcAccessibilityOn" cssclass="sta_WF_AC"/>
              <Edit id="edtPrgeMblTelno2" taborder="15" height="30" text="넥사크로17" left="640" width="70" top="47" readonly="false" maxlength="4" initvalueid="ivEdtEssential" accessibilitylabel="휴대전화번호2 입력" inputtype="digit"/>
