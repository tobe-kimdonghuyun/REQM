              <Edit id="edtPrgeMblTelno3" taborder="17" height="30" text="넥사크로17" left="725" width="70" top="47" readonly="false" maxlength="4" initvalueid="ivEdtEssential" accessibilitylabel="휴대전화번호3 입력" inputtype="digit"/>
              <Static id="staEmlAddr" taborder="18" left="800" width="150" height="42" cssclass="sta_WF_Input01" text="이메일" top="41" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn" accessibilitylabel="이메일"/>
              <Edit id="edtEmlAddr" taborder="19" height="30" text="넥사크로17" left="955" top="47" readonly="false" onchanged="Div01_Edit00_onchanged" maxlength="100" initvalueid="ivEdtNormal" accessibilitylabel="이메일 입력" right="5"/>
              <Static id="Static44_00_00" taborder="20" left="0" height="42" cssclass="sta_WF_Input02" top="Static44_00:-1" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staCnsgnComyAddr" taborder="21" left="0" width="150" height="42" cssclass="sta_WF_Input01" text="주소" top="82" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn" accessibilitylabel="주소"/>
              <Button id="btnCnsgnComyAddr" taborder="22" text="주소검색" top="88" height="30" width="76" left="155" fittocontents="width" cssclass="btn_WF_Crud" visible="true" onclick="divBscInfo_btnAddr_onclick" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="주소검색 버튼" accessibilityrole="link"/>
              <Edit id="edtCnsgnComyAddr" taborder="23" height="30" text="넥사크로17" left="btnCnsgnComyAddr:5" top="88" readonly="true" onchanged="Div01_Edit00_onchanged" right="6" maxlength="500" initvalueid="ivEdtReadOnly" accessibilitylabel="주소검색 입력" accessibilitydescription="자동입력"/>
              <Static id="Static44_00_00_00" taborder="24" left="0" height="42" cssclass="sta_WF_Input02" top="123" right="0" onclick="divBscInfo_Static44_00_00_00_onclick" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staPrftmNoprfScCd" taborder="25" left="0" width="150" height="42" cssclass="sta_WF_Input01" text="법인구분" top="123" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn" accessibilitylabel="법인구분"/>
              <Combo id="cboPrftmNoprfScCd" taborder="26" left="155" width="240" height="30" top="129" innerdataset="dsPrftmNoprfScCd" codecolumn="unyCdValue" datacolumn="unyCdValueNm" initvalueid="ivCmbNormal" text="- 선택 -" value="" accessibilitylabel="법인 보기 구분" index="0"/>
              <Static id="staBrno" taborder="27" left="400" width="150" height="42" cssclass="sta_WF_Essential" text="*사업자등록번호" top="123" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn" accessibilitylabel="사업자등록번호"/>
              <MaskEdit id="mskBrno" taborder="28" left="555" top="129" width="240" height="30" type="string" textAlign="left" format="###-##-#####" initvalueid="ivMskReadOnly" accessibilitylabel="사업자등록번호 입력" enable="true" readonly="true"/>
              <Static id="Static44_00_00_01" taborder="29" left="0" height="42" cssclass="sta_WF_Input02" top="164" right="0" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staBankCd" taborder="30" left="0" width="150" height="42" cssclass="sta_WF_Input01" text="은행명" top="164" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn" accessibilitylabel="은행명"/>
              <Combo id="cboBankCd" taborder="31" left="155" width="240" height="30" innerdataset="dsBankCd" codecolumn="unyCdValue" datacolumn="unyCdValueNm" top="170" initvalueid="ivCmbNormal" accessibilitylabel="은행명 구분" index="0" text="- 선택 -" value="" onitemchanged="divBscInfo_cboBankCd_onitemchanged"/>
              <Static id="staActno" taborder="32" left="400" width="150" height="42" cssclass="sta_WF_Input01" text="계좌번호" top="164" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn" accessibilitylabel="계좌번호"/>
              <Edit id="edtActno" taborder="33" height="30" text="넥사크로17" left="555" width="240" top="170" readonly="false" onchanged="Div01_Edit00_onchanged" maxlength="100" inputtype="number" initvalueid="ivEdtNormal" accessibilitylabel="계좌번호 입력"/>
              <Static id="Static44_00_00_02" taborder="34" left="0" height="192" top="205" right="0" cssclass="sta_WF_Input02" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staRmkCn" taborder="35" left="0" width="150" height="192" cssclass="sta_WF_Input01" text="비고" top="205" onclick="Static45_onclick" initvalueid="ivStcAccessibilityOn" accessibilitylabel="비고"/>
              <TextArea id="txtRmkCn" taborder="36" left="155" top="211" height="180" right="5" maxlength="1000" accessibilitylabel="비고 입력" initvalueid="ivTxtNormal"/>
