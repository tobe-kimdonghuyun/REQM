    <Objects>
      <Dataset id="dsService" useclientlayout="true">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">selectRequestSci</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsRequestSci=dsRequestSci</Col>
            <Col id="url">ore_oew_co00_005.do</Col>
            <Col id="asynctp"/>
          </Row>
          <Row>
            <Col id="id">selectRetrySci</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsRetrySci=dsRetrySci</Col>
            <Col id="url">ore_oew_co00_006.do</Col>
          </Row>
          <Row>
            <Col id="id">selectResultSci</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsResultSci=dsResultSci</Col>
            <Col id="url">ore_oew_co00_007.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true" updatecontrol="false">
        <ColumnInfo>
          <Column id="birth" type="STRING" size="256" description="생년월일(YYYYMMDD)"/>
          <Column id="gender" type="STRING" size="256" description="성별(M-남, F-여)"/>
          <Column id="fgnGbn" type="STRING" size="256" description="내/외국인구분(1-내국인, 2-외국인)"/>
          <Column id="name" type="STRING" size="256" description="성명"/>
          <Column id="hpcorp" type="STRING" size="256" description="이통사"/>
          <Column id="hpno" type="STRING" size="256" description="휴대폰번호"/>
          <Column id="reqInfo" type="STRING" size="256" description="요청정"/>
          <Column id="confirmSeq" type="STRING" size="256" description="재전송순번"/>
          <Column id="smsnum" type="STRING" size="256" description="인증번호"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true" updatecontrol="false">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256" description="접속시도 교육청코드"/>
          <Column id="cddcNm" type="STRING" size="256" description="접속시도 교육청명"/>
          <Column id="mblTelNo" type="STRING" size="256" description="휴대전화번호"/>
          <Column id="insrNm" type="STRING" size="256" description="이름"/>
          <Column id="insrRrno" type="STRING" size="256" description="주민번호"/>
          <Column id="brdt" type="STRING" size="256" description="생년월일 YYYYMMDD"/>
          <Column id="sxdsScCd" type="STRING" size="256"/>
          <Column id="authNo" type="STRING" size="256"/>
          <Column id="hpCorp" type="STRING" size="256"/>
          <Column id="insrRrno1" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="cddcCd"/>
            <Col id="cddcNm"/>
            <Col id="mblTelNo"/>
            <Col id="insrNm"/>
            <Col id="insrRrno"/>
            <Col id="brdt"/>
            <Col id="sxdsScCd"/>
            <Col id="authNo"/>
            <Col id="hpCorp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsHpCorp" useclientlayout="true" updatecontrol="false">
        <ColumnInfo>
          <Column id="hpCorpCd" type="STRING" size="256" description="통신사코드"/>
          <Column id="hpCorpNm" type="STRING" size="256" description="통신사명"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="hpCorpCd">SKT</Col>
            <Col id="hpCorpNm">SKT</Col>
          </Row>
          <Row>
            <Col id="hpCorpCd">KTF</Col>
            <Col id="hpCorpNm">KT</Col>
          </Row>
          <Row>
            <Col id="hpCorpCd">LGT</Col>
            <Col id="hpCorpNm">LGU+</Col>
          </Row>
          <Row>
            <Col id="hpCorpCd">SKM</Col>
            <Col id="hpCorpNm">(알뜰폰) SKT</Col>
          </Row>
          <Row>
            <Col id="hpCorpCd">KTM</Col>
            <Col id="hpCorpNm">(알뜰폰) KT</Col>
          </Row>
          <Row>
            <Col id="hpCorpCd">LGM</Col>
            <Col id="hpCorpNm">(알뜰폰) LGU+</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSciResultCd" useclientlayout="true" updatecontrol="false">
        <ColumnInfo>
          <Column id="code" type="STRING" size="256" description="생년월일"/>
          <Column id="desc" type="STRING" size="256" description="내외국인구분"/>
          <Column id="succYn" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="code">NME0000</Col>
            <Col id="succYn">Y</Col>
            <Col id="desc">정상</Col>
          </Row>
          <Row>
            <Col id="code">NME0011</Col>
            <Col id="desc">통신사 불일치</Col>
            <Col id="succYn">N</Col>
          </Row>
          <Row>
            <Col id="code">NME0012</Col>
            <Col id="desc">명의 불일치 (생년월일/성별)</Col>
            <Col id="succYn">N</Col>
          </Row>
          <Row>
            <Col id="code">NME0013</Col>
            <Col id="desc">분실/일시정지 휴대폰</Col>
            <Col id="succYn">N</Col>
          </Row>
          <Row>
            <Col id="code">NME0015</Col>
            <Col id="desc">사업자(법인) 명의 휴대폰</Col>
            <Col id="succYn">N</Col>
          </Row>
          <Row>
            <Col id="code">NME0017</Col>
            <Col id="desc">선불 휴대폰</Col>
            <Col id="succYn">N</Col>
          </Row>
          <Row>
            <Col id="code">NME0024</Col>
            <Col id="desc">명의 불일치 (성명)</Col>
            <Col id="succYn">N</Col>
          </Row>
          <Row>
            <Col id="code">NME0031</Col>
            <Col id="desc">제한 요금제 가입자 / 한도부족</Col>
            <Col id="succYn">N</Col>
          </Row>
          <Row>
            <Col id="code">NME0035</Col>
            <Col id="desc">SMS 승인번호 발송 실패</Col>
            <Col id="succYn">N</Col>
          </Row>
          <Row>
            <Col id="code">NME0040</Col>
            <Col id="desc">CI 값 검증오류</Col>
            <Col id="succYn">N</Col>
          </Row>
          <Row>
            <Col id="code">NME0070</Col>
            <Col id="desc">인증번호 불일치</Col>
            <Col id="succYn">N</Col>
          </Row>
          <Row>
            <Col id="code">NME0071</Col>
            <Col id="desc">인증번호 재전송 횟수 초과 (3회)</Col>
            <Col id="succYn">N</Col>
          </Row>
          <Row>
            <Col id="code">NME0072</Col>
            <Col id="desc">인증번호 입력 오류횟수 초과 (5회)</Col>
            <Col id="succYn">N</Col>
          </Row>
          <Row>
            <Col id="code">NME0073</Col>
            <Col id="desc">인증번호 입력 시간 초과 (7분)</Col>
            <Col id="succYn">N</Col>
          </Row>
          <Row>
            <Col id="code">NME0096</Col>
            <Col id="desc">5회 인증 오류 제한</Col>
            <Col id="succYn">N</Col>
          </Row>
          <Row>
            <Col id="code">NME0097</Col>
            <Col id="desc">입력정보 오류</Col>
            <Col id="succYn">N</Col>
          </Row>
          <Row>
            <Col id="code">NME0098</Col>
            <Col id="desc">시스템 오류 (통신사 장애)</Col>
            <Col id="succYn">N</Col>
          </Row>
          <Row>
            <Col id="code">NME0099</Col>
            <Col id="desc">시스템 오류 (기타 오류)</Col>
            <Col id="succYn">N</Col>
          </Row>
        </Rows>
      </Dataset>
