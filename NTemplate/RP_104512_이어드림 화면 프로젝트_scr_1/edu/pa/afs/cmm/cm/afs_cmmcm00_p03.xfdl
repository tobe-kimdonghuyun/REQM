          <Column id="strHpCode" type="STRING" size="256" description="휴대폰인증결과코드"/>
          <Column id="strDi" type="STRING" size="256" description="DI(중복가입확인정보)"/>
          <Column id="strCiVer" type="STRING" size="256" description="CI 버전"/>
          <Column id="strCi" type="STRING" size="256" description="CI"/>
          <Column id="strReturnCode" type="STRING" size="256" description="응답코드"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  휴대폰본인인증팝업
*  @MenuPath    pa_afs_cmm_cm
*  @FileName 	afs_cmmcm00_p03.xfdl
*  @Creator 	
*  @CreateDate 	
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2023.6.8   	 	         최초 생성 
*******************************************************************************
*/
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 // 재전송순번
this.pv_confirmSeq = '00';
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
// default 초기처리를 한다.
	this.smfInitPopup(obj);
	
	this.pv_params = this.smfGetPopupParams();
	// opener dataset 복사
	var mainParam = this.pv_params.dsMain;
	this.dsMain.setColumn(0, 'insrNm',    mainParam.insrNm);
	this.dsMain.setColumn(0, 'insrRrno',  mainParam.insrRrno);
	this.dsMain.setColumn(0, 'insrRrno1', mainParam.insrRrno.substring(0, 6));
	this.dsMain.setColumn(0, 'sxdsScCd',  mainParam.insrRrno.substring(6, 7));
	this.dsMain.setColumn(0, 'brdt',      mainParam.brdt);
	this.dsMain.setColumn(0, 'mblTelno',  mainParam.mblTelNo);
	
	// 버튼 초기화
	this.fnInitBtn();

};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

 /**
 * 초기 버튼상태
 */
this.fnInitBtn = function(){ 
	this.pv_confirmSeq ='00'// 인증요청횟수 초기화
	this.btnAuthReq.set_enable(true); // 인증요청 활성
	this.btnAuthRetry.set_enable(false); // 재요청 버튼 비활성
	
	this.edtAuthNo.set_readonly(true); //인증번호 입력 비활성
	this.btnAuthComp.set_enable(false); //인증완료 버튼 비활성
}

// SCI 문자인증요청
 this.fnRequestSci= function(){

	// 성별(주민번호 뒷 첫자리)
	var sxdsNo = this.dsMain.getColumn(0, 'sxdsScCd');
	if(this.smfIsNull(sxdsNo)){
		this.edtSxdsScCd.setFocus();
		this.smfAlert("주민번호 뒷 첫자리를 입력 해주세요.");
		return;
	}
	// 주민번호 뒷 첫자리 유효 숫자 체크
	if(!(nexacro.toNumber(sxdsNo) >= 1 && nexacro.toNumber(sxdsNo) <= 8)){
		this.edtSxdsScCd.setFocus();
		this.smfAlert("주민번호 뒷 첫자리는 1~8의 숫자로 입력 해주세요.");
		return;
	}
	
	// 성별(M-남, F-여)
	var gender;
	if(sxdsNo === "1" || sxdsNo === "3" || sxdsNo === "5" || sxdsNo === "7"){
		gender = 'M';
		 //남성 : [내국인] 1,3 [외국인] 5,7
	}else if(sxdsNo === "2" || sxdsNo === "4" || sxdsNo === "6" || sxdsNo === "8"){
		 //여성 : [내국인] 2,4 [외국인] 6,8
		gender = 'F';
	}else{
		this.smfAlert("주민번호 뒷 첫자리를 올바르게 입력 해주세요.");
		return;
	}
	
	// 내/외국인구분(1-내국인, 2-외국인)
	var fgnGbn;
	if(sxdsNo === "1" || sxdsNo === "2" || sxdsNo === "3" || sxdsNo === "4"){
		// [내국인] 1,2,3,4 
		fgnGbn = '1';
	}else if(sxdsNo === "5" || sxdsNo === "6" || sxdsNo === "7" || sxdsNo === "8"){
		 // [외국인] 5,6,7,8
		fgnGbn = '2';
	}else{
		this.smfAlert("주민번호 뒷 첫자리를 올바르게 입력 해주세요.");
		return;
	}
	
	// 통신사 선택 체크
	var hpCorpCd = this.dsMain.getColumn(0, 'hpCorp');
	if(this.smfIsNull(hpCorpCd)){
		this.cboHpCorp.setFocus();
		this.smfAlert("통신사를 선택 해주세요.");
		return;
	}

	// SCI 인증번호요청 PARAM
	this.dsSearch.clearData();
	this.dsSearch.addRow();
	this.dsSearch.setColumn(0, 'birth' , this.dsMain.getColumn(0, 'brdt')); //생년월일(YYYYMMDD)
	this.dsSearch.setColumn(0, 'gender', gender);// 생년월일(YYYYMMDD)
	this.dsSearch.setColumn(0, 'fgnGbn', fgnGbn); //내/외국인구분(1-내국인, 2-외국인)
	this.dsSearch.setColumn(0, 'name',   this.dsMain.getColumn(0, 'insrNm'));
	this.dsSearch.setColumn(0, 'hpcorp', this.dsMain.getColumn(0, 'hpCorp'));
	this.dsSearch.setColumn(0, 'hpno',   this.dsMain.getColumn(0, 'mblTelNo'));

	// SCI 인증번호 요청 
	this.smfSearchService("selectRequestSci")
		.showConfirm(false)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				this.smfAlert('인증번호 요청에 실패하였습니다. \n\n지속적인 오류 발생시 관리자에 문의 해주세요.');
				return;
			}
			//console.log("=======SCI 인증요청 문자 발송=======");
			//console.log(this.dsRequestSci.saveJSON());
			
			if(this.dsRequestSci.getRowCount() <1){
				this.smfAlert('인증번호 요청에 실패하였습니다. \n\n지속적인 오류 발생시 관리자에 문의 해주세요.');
				return;
			}
			
			var rResult = this.dsRequestSci.getColumn(0, 'rResult'); // 요청결과
			var rHpcode = this.dsRequestSci.getColumn(0, 'rHpcode').trim(); // 인증요청 결과코드
			// 요청실패
			if(rResult != 'Y' || rHpcode != 'NME0000'){
				// 정보 불일치 [통신사]NME0011 | [생년월일/성별]NME0012 | [성명]NME0012 | [불일치]NME0097
				if(rHpcode === 'NME0011' || rHpcode === 'NME0012' || rHpcode === 'NME0024' || rHpcode === 'NME0097'){
					this.smfAlert('인증번호 요청에 실패하였습니다. \n\n입력 정보를 확인 해주세요.');
					return;
				// 인증불가휴대폰 [사업자명의]NME0016 | [선불폰]NME0017 
				}else if(rHpcode === 'NME0015' || rHpcode === 'NME0017'){
					this.smfAlert('사업자 명의 및 선불폰은 인증 할 수 없습니다.');
					return;
				}
				// 그 외 에러
				this.smfAlert("인증번호 요청에 실패하였습니다");
				return;
			}
			
			// 요청성공
			this.smfAlert('인증번호가 발송되었습니다. \n\n인증번호를 입력 후 인증 완료를 해주세요.');
			// 인증요청버튼 비활성
			this.btnAuthReq.set_enable(false);
			// 재인증버튼 활성
			this.btnAuthRetry.set_enable(true);
			// 인증완료버튼 활성
			this.btnAuthComp.set_enable(true);
			// 인증번호입력창 입력가능
			this.edtAuthNo.set_readonly(false);
			this.edtAuthNo.setFocus();

		});	
}

// SCI 인증번호 문자 재요청
 this.fnRetrySci= function(){
 
	// SCI 인증번호 재요청 PARAM
	this.dsSearch.clearData();
	this.dsSearch.addRow();
	this.dsSearch.setColumn(0, 'reqInfo',    this.dsRequestSci.getColumn(0, 'reqInfo')); // 최초인증요청정보
	this.dsSearch.setColumn(0, 'confirmSeq', this.pv_confirmSeq); // 재전송 순번
	
	// SCI 인증번호 재요청 
	this.smfSearchService("selectRetrySci")
		.showConfirm(false)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				this.smfAlert('인증번호 요청에 실패하였습니다. \n\n지속적인 오류 발생시 관리자에 문의 해주세요.');
				return;
			}
			//console.log("=======SCI 재요청 문자 발송=======");
			//console.log(this.dsRetrySci.saveJSON());
			
			if(this.dsRetrySci.getRowCount() <1){
				this.smfAlert('인증번호 재요청에 실패하였습니다. \n\n지속적인 오류 발생시 관리자에 문의 해주세요..');
				return;
			}
			
			var strResult = this.dsRetrySci.getColumn(0, 'strResult'); // 재요청결과
			var strHpCode = this.dsRetrySci.getColumn(0, 'strHpCode').trim(); // 재요청 결과코드
			// 요청실패
			if(strResult != 'Y' || strHpCode != 'NME0000'){
				// 버튼 초기화
				this.fnInitBtn();
				// 인증번호 재요청 횟수 초과
				if(strHpCode === 'NME0071'){
					// 재요청 횟수 에러
					this.smfAlert("인증번호 재요청은 3회 까지 가능 합니다.");
					return;
				}
				// 그 외 에러
				this.smfAlert("인증번호 재요청에 실패하였습니다");
				return;
			}
			// 재요청 횟수
			this.pv_confirmSeq = this.dsRetrySci.getColumn(0, 'strSmsSeq');
			// 요청성공
			this.smfAlert('재요청 인증번호가 발송되었습니다. \n\n인증번호를 입력 후 인증 완료를 해주세요.');	
			this.edtAuthNo.setFocus();
		});	
 }
 
 // SCI 인증완료
 this.fnResultSci = function(){
	// 인증번호
 	var authNo = this.dsMain.getColumn(0, 'authNo');
	if(this.smfIsNull(authNo) || authNo.length != 6){
		this.edtAuthNo.setFocus();
		this.smfAlert("인증번호 숫자 6자리를 정확하게 입력 해주세요.");
		return;
	}
	
 	// SCI 인증완료 PARAM
	this.dsSearch.clearData();
	this.dsSearch.addRow();
	this.dsSearch.setColumn(0, 'reqInfo' ,   this.dsRequestSci.getColumn(0, 'reqInfo')); //인증요청정보
	this.dsSearch.setColumn(0, 'confirmSeq', this.pv_confirmSeq); // 재전송 순번
	this.dsSearch.setColumn(0, 'smsnum',     authNo);
	
	// SCI 인증번호 재요청 
	this.smfSearchService("selectResultSci")
		.showConfirm(false)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				this.smfAlert('본인인증에 실패하였습니다. \n\n지속적인 오류 발생시 관리자에 문의 해주세요.');
				return;
			}
			//console.log("=======SCI 인증완료 =======");
			//console.log(this.dsResultSci.saveJSON());
			
			if(this.dsResultSci.getRowCount() <1){
				this.smfAlert('본인인증에 실패하였습니다. \n\n지속적인 오류 발생시 관리자에 문의 해주세요.');
				return;
			}
			
			var strHpCode = this.dsResultSci.getColumn(0, 'strHpCode').trim(); // 재요청 결과코드
			// 요청실패
			if(strHpCode != 'NME0000'){
			
				if(strHpCode === 'NME0070'){
					this.smfAlert('인증번호가 일치하지 않습니다. ');
					return;
				}else if(strHpCode === 'NME0072'){
					// 버튼 초기화
					this.fnInitBtn();
					this.smfAlert('인증번호 입력 오류 횟수를 초과(5회) 하였습니다. \n\n인증번호를 다시 요청 해주세요.');
					return;
				}else if(strHpCode === 'NME0073'){
					// 버튼 초기화
					this.fnInitBtn();
					this.smfAlert('인증번호 입력 시간을 초과(7분) 하였습니다.\n\n인증번호를 다시 요청 해주세요.');
					return;
				}else if(strHpCode === 'NME0096'){
					// 버튼 초기화
					this.fnInitBtn();
					this.smfAlert('인증 오류 횟수(5회)를 초과 하였습니다.\n\n다시 시도 해주세요.');
					this.close(false); // 닫기
				}
				// 그 외 에러
				this.smfAlert("본인인증에 실패 하였습니다.");
				return;
			}else{
				// 인증성공 -입력값 부모창 전달
				this.smfSendResponseToOpener({
					"row": this.smfRowToObject(this.dsResultSci)
				});
				this.close(true);
			}
		});	
 }

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
* 인증요청버튼 클릭
*/
this.btnAuthReq_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnRequestSci();
};
/**
* 재요청버튼 클릭
*/
this.btnAuthRetry_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnRetrySci();
};

/**
* 인증완료버튼 클릭
*/
this.btnAuthComp_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnResultSci();
};

/**
* 취소버튼 클릭
*/
this.btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
		this.close(false);
};





]]></Script>
    <Bind>
      <BindItem id="item0" compid="edtNm" propid="value" datasetid="dsMain" columnid="insrNm"/>
      <BindItem id="item1" compid="edtBrdt" propid="value" datasetid="dsMain" columnid="insrRrno1"/>
      <BindItem id="item2" compid="edtMblTelNo" propid="value" datasetid="dsMain" columnid="mblTelNo"/>
      <BindItem id="item3" compid="edtSxdsScCd" propid="value" datasetid="dsMain" columnid="sxdsScCd"/>
      <BindItem id="item4" compid="edtAuthNo" propid="value" datasetid="dsMain" columnid="authNo"/>
      <BindItem id="item5" compid="cboHpCorp" propid="value" datasetid="dsMain" columnid="hpCorp"/>
    </Bind>
  </Form>
</FDL>
