<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="form" width="600" height="660" titletext="신청학교조회" nHeight="754" onload="form_onload">
    <Layouts>
      <Layout height="660" width="600" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divTitle" taborder="1" left="0" top="20" height="44" text="" right="0" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <ImageViewer id="imgTitle" taborder="0" text="신청학교조회" left="20" top="0" height="44" cssclass="img_WF_SubTit01" width="190" initvalueid="ivTitleAccessibilityOn" accessibilitylabel="신청학교조회"/>
            </Layout>
          </Layouts>
        </Div>
        <Div id="divSearch" taborder="2" left="20" top="84" height="70" cssclass="div_WF_Search" right="20" initvalueid="ivDivAccessibilityOff">
          <Layouts>
            <Layout>
              <Static id="staAyr" taborder="0" text="학교명" left="0" top="20" width="77" height="30" cssclass="sta_WF_Searchtxt01" initvalueid="ivStcAccessibilityOn" accessibilitylabel="학교명"/>
              <Edit id="edtAyr" taborder="1" left="staAyr:0" width="120" height="30" top="20" initvalueid="ivEdtNormal" accessibilitylabel="학교명 입력칸"/>
              <Button id="btnSearch" taborder="2" text="조회" top="20" width="72" height="30" cssclass="btn_WF_Search03" right="20" onclick="divSearch_btnSearch_onclick" initvalueid="ivBtnAccessibilityButton" accessibilitylabel="조회"/>
            </Layout>
          </Layouts>
        </Div>
        <Grid id="grdMain" taborder="3" left="20" top="174" height="416" autofittype="col" right="20" binddataset="dsShlList" selecttype="cell" initvalueid="ivGrdAccessibilityOn" autoenter="select" onheadclick="grdMain_onheadclick" accessibilitylabel="신청학교목록">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="40"/>
                <Column size="40"/>
                <Column size="150"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="36" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell displaytype="checkboxcontrol" edittype="checkbox"/>
                <Cell col="1" text="순번"/>
                <Cell col="2" text="학교명"/>
                <Cell col="3" text="소재지명"/>
              </Band>
              <Band id="body">
                <Cell displaytype="checkboxcontrol" edittype="checkbox" text="bind:chk"/>
                <Cell col="1" text="expr:currow + 1" textAlign="center"/>
                <Cell col="2" textAlign="left" displaytype="normal" edittype="none" calendardisplaynulltype="none" calendardisplayinvalidtype="none" calendardateformat="yyyy-MM-dd" text="bind:shlCdNm"/>
                <Cell col="3" displaytype="normal" edittype="none" combodataset="dsHour" combocodecol="unyCdValue" combodatacol="unyCdValueNm" text="bind:lctnScCdNm" combotype="dropdown" combodisplaynulltext="- 선택 -" combodisplaynulltype="nulltext"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="btnClose" taborder="4" text="닫기" height="30" width="50" left="244" initvalueid="ivBtnAccessibilityButton" top="610" onclick="btnClose_onclick" cssclass="btn_WF_Custom" accessibilitylabel="닫기"/>
        <Button id="btnIdnty" taborder="5" text="확인" height="30" initvalueid="ivBtnAccessibilityButton" top="610" width="50" onclick="btnIdnty_onclick" left="304" accessibilitylabel="확인"/>
        <Static id="sta05" taborder="6" left="0" cssclass="sta_GD_Size" text="20" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff" top="640" height="20"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  
*  @MenuPath    방과후학교(외부강사) > 신청학교조회
*  @FileName 	afs_cmmcm00_p01.xfdl
*  @Creator 	김민성
*  @CreateDate 	2022.05.20
*  @Desction    방과후학교(외부강사) 신청학교조회
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.05.10            김민성                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::afs_script.xjs"


/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/



/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	
	//파라메터세팅
	this.pv_params = this.smfGetPopupParams();
	this.dsSearch.copyRow(0, this.pv_params, 0);
	
	this.dsSearch.setColumn(0, "shlCd", "");
	if(this.isNotNil(this.dsSearch.getColumn(0, "brno"))){
		this.dsSearch.setColumn(0, "invlCnsgnScCd", "C");
	}else if(this.isNotNil(this.dsSearch.getColumn(0, "insrRrno"))){
		this.dsSearch.setColumn(0, "invlCnsgnScCd", "I");
	}
	this.dsSearch.setColumn(0, "aplyYn",       "Y");
	this.dsSearch.setColumn(0, "outDs",        "dsShlList");
	
	this.fnListSearch();
};



/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/




/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};


/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * 프로그램별 강의시간 조회
 */
this.fnListSearch = function(){
	// 서비스 객체 생성
	this.smfSearchService("listShl")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// 닫기버튼
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};

this.btnIdnty_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.dsShlList.rowcount < 1) return;
	
	//체크박스 선택 여부 확인
	var arrChk = this.dsShlList.extractRows("chk==1");

	if(arrChk == -1){  // 체크한 소속 강사 없으면
		//선택된 {0}이(가) 없습니다. {0}을(를) 선택하여 주십시오.
		this.smfAlert('CM013', ['학교']);	 //선택된 학교이(가) 없습니다. 학교을(를) 선택하여 주십시오.
		return;
	}
	
	
	// 응답을 
	this.smfSendResponseToOpener({
		"row": this.afsfCopyRow(this.dsShlList, arrChk)
	});

	this.close(true);
};

this.grdMain_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if (e.col == 0){
		this.smfToggleChkHeader(obj, e);
	}
};

this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnListSearch();
};
]]></Script>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">listShl</Col>
            <Col id="url">/afs_cmm_cm00_007.do</Col>
            <Col id="inDatasets">clfCdList=dsSearch</Col>
            <Col id="outDatasets">dsShlList=dsShlList</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsShlList" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="shlCd" type="STRING" size="256"/>
          <Column id="shlCdNm" type="STRING" size="256"/>
          <Column id="lctnScCd" type="STRING" size="256"/>
          <Column id="lctnScCdNm" type="STRING" size="256"/>
          <Column id="chk" type="STRING" size="256"/>
          <Column id="scaSysScCd" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSearch">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="shlCdNm" type="STRING" size="256"/>
          <Column id="invlCnsgnScCd" type="STRING" size="256"/>
          <Column id="brno" type="STRING" size="256"/>
          <Column id="cnsgnComyId" type="STRING" size="256"/>
          <Column id="insrRrno" type="STRING" size="256"/>
          <Column id="userId" type="STRING" size="256"/>
          <Column id="aplyYn" type="STRING" size="256"/>
          <Column id="outDs" type="STRING" size="256"/>
          <Column id="eccYn" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="shlCdNm"/>
            <Col id="cddcCd"/>
            <Col id="invlCnsgnScCd"/>
            <Col id="brno"/>
            <Col id="cnsgnComyId"/>
            <Col id="insrRrno"/>
            <Col id="userId"/>
            <Col id="aplyYn">Y</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.edtAyr" propid="value" datasetid="dsSearch" columnid="shlCdNm"/>
    </Bind>
  </Form>
</FDL>
