    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 학교폭력실태조사 > 학생정보확인 > 학교찾기
*  @FileName 	eds_vffos04_p01.xfdl 
*  @Creator 	김민성
*  @CreateDate 	2022.11.08
*  @Desction    학생정보확인
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.11.08            김민성                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvLangCd;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);	
	// 필수
	this.smfResetScroll(this);
	this.pv_params = this.smfGetPopupParams();
	this.fvLangCd = this.pv_params.langCd;
	this.dsSearch.copyData(this.pv_params.dataset);
	this.fnSelectLang(this.fvLangCd);
	if (this.isNotNil(this.dsSearch.getColumn(0, 'shlNm'))){
		this.fnSearchList();
	}
	this.divMain.form.edtTitle03.setFocus();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
}
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 학교찾기 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchList = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){
				if (this.dsShlList.getRowCount() == 0){
					this.divMain.form.div01.form.grdMain.set_nodatatext(this.dsLang.getColumn(this.fvLangCd - 1, 'title07')
					+ '\n' + this.dsLang.getColumn(this.fvLangCd - 1, 'title08')
					+ '\n' + this.dsLang.getColumn(this.fvLangCd - 1, 'title08_1')
					+ '\n' + this.dsLang.getColumn(this.fvLangCd - 1, 'title09')
					+ '\n' + this.dsLang.getColumn(this.fvLangCd - 1, 'title10'));
				}
			}else{
				this.smfAlertEds('LI155', [this.dsApiResponseList.getColumn(0, 'message')], this.fnMessageCallback );
			}
		});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * Top Menu에서 언어를 변경시 발생
 * @param  : sSelectLangCd	- 언어코드
 * @return : N/A
 */
this.fnSelectLang = function(sSelectLangCd)
{
	this.fvLangCd = sSelectLangCd--;
	var divMainCompList = this.svcfSortByTabOrder(this.divMain);
	
	for(var i in divMainCompList){
		if (divMainCompList[i] instanceof nexacro.Static){
			divMainCompList[i].set_text(this.dsLang.getColumn(sSelectLangCd, divMainCompList[i].name.substr(3).toLowerCase()));
		}
		if (divMainCompList[i] instanceof nexacro.Button){
			divMainCompList[i].set_text(this.dsLang.getColumn(sSelectLangCd, divMainCompList[i].name == 'btnSearch' ? 'title01' : (divMainCompList[i].name == 'btnIdnty' ? 'title11' : '')));
		}
		if (divMainCompList[i] instanceof nexacro.Edit){
			divMainCompList[i].set_displaynulltext(this.dsLang.getColumn(sSelectLangCd, divMainCompList[i].name == 'edtTitle03' ? 'title03' : ''));
		}
		if (divMainCompList[i] instanceof nexacro.Grid){
			divMainCompList[i].set_nodatatext(this.dsLang.getColumn(sSelectLangCd, divMainCompList[i].name == 'grdMain' ? 'title07' : ''));
		}
	}
	this.resetScroll();
}

/**
 * 학교 선택
 * @param : N/A
 * @param : N/A
 */
 this.fnChoice = function(){
	if(this.dsShlList.rowposition <= -1) return;
	
	this.smfSendResponseToOpener({
		"row": this.smfRowToObject(this.dsShlList)
	});

	this.close(true);
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 엔터 누를 시
* @param  : obj		   - [object]Edit
* @param  : e		   - [string]KeyEventInfo
* @return : N/A
 */
this.divMain_edtTitle03_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode == "13"){
		this.btnSearch_onclick();
	}
};

/**
 * 조회 버튼 클릭 시
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
 this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.dsSearch.setColumn(0, 'shlNm', this.divMain.form.edtTitle03.value);
	if(this.isNil(this.dsSearch.getColumn(0, 'shlNm'))){
		this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle02')], this.fnMessageCallback );
		this.divMain.form.edtTitle03.setFocus();
		return;
	}
	this.fnSearchList();
};

/**
 * 그리드 셀 더블 클릭 시
* @param  : obj		   - [object]Grid
* @param  : e		   - [string]GridClickEventInfo
* @return : N/A
 */
this.div00_grdMain_oncelldblclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	this.fnChoice();
};

/**
 * 확인 버튼 클릭 시
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
this.btnIdnty_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (this.dsShlList.getRowCount() == 0){
		this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'title08_1')], this.fnMessageCallback );
		return;
	}
	this.fnChoice();
};

/**
 * X 버튼 클릭 시
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
this.div00_btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};]]></Script>
    <Bind>
      <BindItem id="item0" compid="divMain.form.edtTitle03" propid="value" datasetid="dsSearch" columnid="shlNm"/>
    </Bind>
  </Form>
</FDL>
