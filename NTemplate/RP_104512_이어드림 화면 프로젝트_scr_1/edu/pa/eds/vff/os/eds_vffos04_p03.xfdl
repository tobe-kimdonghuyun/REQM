    <Objects/>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 학교폭력 > 참여자로그인 > QR 언어선택
*  @FileName 	eds_vffos04_p03.xfdl 
*  @Creator 	김지영
*  @CreateDate 	2023.04.18
*  @Desction    학교폭력 설문(참여자로그인(QR접속 시)_언어선택 팝업)
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.04.18            김지영                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvLangCd = 1;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);	
	// 필수
	this.fv_param = this.smfGetFormParams();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
}
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 /**
 * 버튼 css 설정
 * @param : langCd			- 언어코드
 */
this.fnSetSelectCss = function(langCd){
	for(var i = 0; i < 8; i++){
		this.div00.form['btnSelLang0' + i].set_cssclass('btn_TF_LanggChoice');
	}
	this.div00.form['btnSelLang0' + (langCd-1)].set_cssclass('btn_TF_LanggChoiceS');
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 확인 버튼 클릭 시
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
this.div00_btnPemOthbc07_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{		
	this.smfSendResponseToOpener({
		"result": this.fvLangCd,
	});
	
	this.close(true);
};

/**
 * 언어 버튼 클릭 시
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
this.Button_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSetSelectCss(obj.langVal);
	this.fvLangCd = obj.langVal;
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="div00.form.cboClf" propid="value" datasetid="dsSearch" columnid="stuPtorRelCd"/>
    </Bind>
  </Form>
