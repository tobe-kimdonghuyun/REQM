    <Objects>
      <Dataset id="dsLang">
        <ColumnInfo>
          <Column id="pemOthbc01" type="STRING" size="256"/>
          <Column id="pemOthbc02" type="STRING" size="256"/>
          <Column id="pemOthbc03_0" type="STRING" size="256"/>
          <Column id="pemOthbc03_1" type="STRING" size="256"/>
          <Column id="pemOthbc03_2" type="STRING" size="256"/>
          <Column id="pemOthbc03_3" type="STRING" size="256"/>
          <Column id="pemOthbc03_4" type="STRING" size="256"/>
          <Column id="pemOthbc03_5" type="STRING" size="256"/>
          <Column id="pemOthbc04" type="STRING" size="256"/>
          <Column id="pemOthbc06" type="STRING" size="256"/>
          <Column id="pemOthbc07" type="STRING" size="256"/>
          <Column id="pemOthbc08" type="STRING" size="256"/>
          <Column id="pemOthbc09" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="pemOthbc01">개인정보 수집 및 이용 동의(선택)</Col>
            <Col id="pemOthbc02">「 개인정보 보호법 」 제15조 제1항, 제2항에 의거하여, 본인의 동의를 통한 개인정보를 수집·이용하고자 합니다. 수집하는 개인정보는 관련 목적 외의 용도로 이용되거나 제3자에게 제공되지 않습니다.</Col>
            <Col id="pemOthbc09">☞ 개인정보 수집 동의 시 학년, 반, 번호 이름을 해당학교 담당자가 조회 가능</Col>
            <Col id="pemOthbc07">동의</Col>
            <Col id="pemOthbc08">비동의</Col>
            <Col id="pemOthbc03_0">- 개인정보 수집 및 이용 목적</Col>
            <Col id="pemOthbc03_1">학교폭력 신고 응답에 관한 정확한 사실관계 확인 및 신고(목격)자 상담</Col>
            <Col id="pemOthbc03_2">- 개인정보 수집 및 이용 항목</Col>
            <Col id="pemOthbc03_3">학년, 반, 번호, 이름</Col>
            <Col id="pemOthbc03_4">- 개인정보 보유 및 이용 기간</Col>
            <Col id="pemOthbc03_5">학교폭력 실태조사 응답 후 해당 학년도 종료 시까지</Col>
            <Col id="pemOthbc06">동의하지 않아도 신고 문항 제출은 가능하며, 동의하지 않아도 일체 불이익은 없습니다.</Col>
            <Col id="pemOthbc04">동의 거부 권리 및 불이익</Col>
          </Row>
          <Row>
            <Col id="pemOthbc01">Collection and consent of personal data</Col>
            <Col id="pemOthbc02">Under Article 15, Paragraph 1 and Paragraph 2 of the 「Personal Information Protection Act」, we intend to collect and use personal data with the consent of the individual. Personal data collected is not used for purposes other than related purposes or provided to third parties.</Col>
            <Col id="pemOthbc06">You can submit report questions even if you do not agree to it.</Col>
            <Col id="pemOthbc07">Agree</Col>
            <Col id="pemOthbc08">Disagree</Col>
            <Col id="pemOthbc09">☞ If you agree to provide your personal data, your grade, class, number and name can be inquired by the person in charge of the school.</Col>
            <Col id="pemOthbc03_0">- Purpose of collecting and using personal data</Col>
            <Col id="pemOthbc03_1">Confirmation of accurate facts regarding the reports of school violence and consultation with the reporter (witness)</Col>
            <Col id="pemOthbc03_2">- Collected personal data</Col>
            <Col id="pemOthbc03_3">Grade, class, number, name</Col>
            <Col id="pemOthbc03_4">- Period of retention and use of personal data</Col>
            <Col id="pemOthbc03_5">Until the end of the school year from after responding to the school violence survey</Col>
            <Col id="pemOthbc04">Right to Refuse Consent and Disadvantages</Col>
          </Row>
          <Row>
            <Col id="pemOthbc01">个人信息收集及同意</Col>
            <Col id="pemOthbc02">根据《个人信息保护法》第十五条第一项、第二项规定，经过本人同意后，收集并使用个人信息。 所收集的个人信息不会用于相关目的以外的其他用途或提供给第三方。</Col>
            <Col id="pemOthbc06">即使不同意也可提交所填写的举报问项。</Col>
            <Col id="pemOthbc07">同意</Col>
            <Col id="pemOthbc08">不同意</Col>
            <Col id="pemOthbc09">☞ 同意收集个人信息时，相关学校负责人可以查询年级、班级、学号、姓名</Col>
            <Col id="pemOthbc03_0">- 个人信息收集及使用目的</Col>
            <Col id="pemOthbc03_1">确认与校园暴力举报作答相关的准确事实关系及举报人（目击者）咨询</Col>
            <Col id="pemOthbc03_2">- 个人信息收集及使用项目</Col>
            <Col id="pemOthbc03_3">年级、班级、学号、姓名</Col>
            <Col id="pemOthbc03_4">- 个人信息保留及使用期限</Col>
            <Col id="pemOthbc03_5">作答校园暴力实况调查后到该学年度结束时为止</Col>
            <Col id="pemOthbc04">拒絶同意的权利和缺点</Col>
          </Row>
          <Row>
            <Col id="pemOthbc01">個人情報収集及び同意</Col>
            <Col id="pemOthbc02">「個人情報保護法」第15条第1項、第2項に基づき、本人の同意を通じた個人情報を収集・利用します。 収集する個人情報は、関連目的以外の用途で利用されたり第三者に提供されません。</Col>
            <Col id="pemOthbc06">同意しなくても通報アンケートは提出することができます。</Col>
            <Col id="pemOthbc07">同意</Col>
            <Col id="pemOthbc08">同意しない</Col>
            <Col id="pemOthbc09">☞ 個人情報収集に同意した場合、学年、クラス、番号、氏名を当該学校の担当者が照会できる。</Col>
            <Col id="pemOthbc03_0">- 個人情報収集及び利用目的</Col>
            <Col id="pemOthbc03_1">校内暴力通報回答に関する事実関係の確認と通報(目撃)者の相談</Col>
            <Col id="pemOthbc03_2">- 個人情報収集及び利用項目</Col>
            <Col id="pemOthbc03_3">学年、クラス、番号、氏名</Col>
            <Col id="pemOthbc03_4">- 個人情報保有及び利用期間</Col>
            <Col id="pemOthbc03_5">校内暴力実態調査回答後から当該学年度終了時まで</Col>
            <Col id="pemOthbc04">同意を拒否する権利と不利益</Col>
          </Row>
          <Row>
            <Col id="pemOthbc01">Thu thập và Đồng ý cung cấp thông tin cá nhân</Col>
            <Col id="pemOthbc02">Theo Điều 15, Khoản 1 và Khoản 2 của 「Luật Bảo mật Thông tin」, chúng tôi sẽ thu thập và sử dụng thông tin cá nhân với sự nhất trí của cá nhân đó.  Thông tin cá nhân thu thập được sẽ chỉ sử dụng cho các mục đích liên quan, không sử dụng cho bất kỳ mục đích nào khác hoặc không được cung cấp cho bên thứ ba.</Col>
            <Col id="pemOthbc06">Bạn vẫn có thể khai báo dù không đồng ý cung cấp thông tin cá nhân.</Col>
            <Col id="pemOthbc07">Đồng ý</Col>
            <Col id="pemOthbc08">Không đồng ý</Col>
            <Col id="pemOthbc09">☞ Nếu bạn đồng ý cung cấp thông tin cá nhân, người phụ trách của trường có thể trích lục được năm học, lớp học, mã số và tên của bạn.</Col>
            <Col id="pemOthbc03_0">- Mục đích thu thập và sử dụng thông tin cá nhân</Col>
            <Col id="pemOthbc03_1">Để xác nhận về độ chính xác của thông tin liên quan đến khai cáo về bạo lực học đường và để tham vấn nhân chứng (người khai cáo)</Col>
            <Col id="pemOthbc03_2">- Thông tin cá nhân được thu thập và sử dụng</Col>
            <Col id="pemOthbc03_3">năm học, lớp học, mã số, tên</Col>
            <Col id="pemOthbc03_4">- Thời gian lưu trữ và sử dụng thông tin cá nhân</Col>
            <Col id="pemOthbc03_5">Tính t sau khi trả lời khảo sát về bạo lực học đường cho đến cuối năm học</Col>
            <Col id="pemOthbc04">Quyển từchồi chấp thuận vá bất lợi</Col>
          </Row>
          <Row>
            <Col id="pemOthbc01">Pagkuha at pagsang-ayon sa personal na datos</Col>
            <Col id="pemOthbc02">Sa Ilalim ng Artikulo 15, Talata 1 at Talata 2 ng 「 Act ng Proteksyon sa Personal na Impormasyon」, nais namin kunin at gamitin ang personal na datos nang may pagsang-ayon ng indibidwal.  Ang nakuhang personal na datos ay hindi ginagamit para sa mga layuning bukod sa mga kaugnay na layunin o binibigay sa mga third party.</Col>
            <Col id="pemOthbc06">Maaari mong ipasa ang mga tanong sa pag-uulat kahit na hindi ka sumang-ayon.</Col>
            <Col id="pemOthbc07">Sang-ayon ako</Col>
            <Col id="pemOthbc08">Di ako sang-ayon</Col>
            <Col id="pemOthbc09">☞ Kung sang-ayon kang ibigay ang iyong personal na datos, ang antas, klase, bilang at pangalan mo ay maaaring itanong ng taong namamahala sa paaralan.</Col>
            <Col id="pemOthbc03_0">- Layunin ng pagkuha at paggamit ng personal na datos</Col>
            <Col id="pemOthbc03_1">Kumpirmasyon ng tamang katotohanan tungkol sa mga pag-uulat ng karahasan sa paaralan at konsultasyon sa nag-uulat (saksi)</Col>
            <Col id="pemOthbc03_2">- Nakuhang personal na datos</Col>
            <Col id="pemOthbc03_3">Antas, klase, bilang, pangalan</Col>
            <Col id="pemOthbc03_4">- Panahon ng pagtatago at paggamit ng personal na datos</Col>
            <Col id="pemOthbc03_5">Hanggang sa dulo ng school year mula sa pagsagot ng survey ng karahasan sa paaralan</Col>
            <Col id="pemOthbc04">Karapatan na Tanggihan ang Pahintulot at Mga Disadvantage</Col>
          </Row>
          <Row>
            <Col id="pemOthbc01">Согласие на сбор персональных данных</Col>
            <Col id="pemOthbc02">В соответствии с Параграфом 1 и Параграфом 2 Статьи 15「Закона о защите персональных данных」мы намерены получить и использовать персональную информацию с согласия физического лица.  Полученные персональные данные не будут использоваться в целях, отличных от связанных целей, и не будет предоставлены третьим лицам.</Col>
            <Col id="pemOthbc06">Вы можете подать ответы на вопросы, даже если вы не согласны с этим.</Col>
            <Col id="pemOthbc07">Согласен</Col>
            <Col id="pemOthbc08">Не согласен</Col>
            <Col id="pemOthbc09">☞ Если вы согласны предоставить свои персональные данные, лицо, курирующее школу, может запросить ваши год обучения в школе, класс, номер и имя.</Col>
            <Col id="pemOthbc03_0">- Цель получения и использования персональных данных</Col>
            <Col id="pemOthbc03_1">Подтверждение действительности фактов в отношении сообщений о школьном насилии и консультирование сообщившего о насилии лица (свидетеля)</Col>
            <Col id="pemOthbc03_2">- Полученные персональные данные</Col>
            <Col id="pemOthbc03_3">Год обучения в школе, класс, номер, имя</Col>
            <Col id="pemOthbc03_4">- Период хранения и использования персональных данных</Col>
            <Col id="pemOthbc03_5">До окончания школьного года с момента ответа на опросник, посвященный школьному насилию</Col>
            <Col id="pemOthbc04">Пpaвo нa откaз в согласии и недоcтaтки</Col>
          </Row>
          <Row>
            <Col id="pemOthbc01">การรวบรวมและการยินยอมให้ใช้ข้อมูลส่วนบุคคล</Col>
            <Col id="pemOthbc02">ภายใต้มาตรา 15 วรรค 1 และวรรค 2 ของ 「พระราชบัญญัติคุ้มครองข้อมูลส่วนบุคคล」 เราตั้งใจที่จะรวบรวมและใช้ข้อมูลส่วนบุคคลโดยได้รับความยินยอมจากแต่ละบุคคล ข้อมูลส่วนบุคคลที่รวบรวมจะไม่ถูกใช้เพื่อวัตถุประสงค์อื่นนอกเหนือจากวัตถุประสงค์ที่เกี่ยวข้อง หรือมอบให้แก่บุคคลที่สาม</Col>
            <Col id="pemOthbc06">คุณสามารถส่งคำถามรายงานได้แม้ว่าคุณจะไม่เห็นด้วยก็ตาม</Col>
            <Col id="pemOthbc07">เห็นด้วย</Col>
            <Col id="pemOthbc08">ไม่เห็นด้วย</Col>
            <Col id="pemOthbc09">☞ หากคุณยินยอมที่จะให้ข้อมูลส่วนตัวของคุณ ผู้รับผิดชอบของโรงเรียนนั้นๆ สามารถสอบถามข้อมูลชั้นปี ห้องเรียน หมายเลข และชื่อของคุณได้</Col>
            <Col id="pemOthbc03_0">- วัตถุประสงค์ในการเก็บรวบรวมและใช้ข้อมูลส่วนบุคคล</Col>
            <Col id="pemOthbc03_1">การยืนยันข้อเท็จจริงที่ถูกต้องเกี่ยวกับรายงานความรุนแรงในโรงเรียนและการปรึกษาหารือกับผู้รายงาน (พยาน)</Col>
            <Col id="pemOthbc03_2">- ข้อมูลส่วนบุคคลที่รวบรวม</Col>
            <Col id="pemOthbc03_3">ชั้นปี, ห้องเรียน, หมายเลข, ชื่อ</Col>
            <Col id="pemOthbc03_4">- ระยะเวลาในการเก็บรักษาและใช้ข้อมูลส่วนตัว</Col>
            <Col id="pemOthbc03_5">ตั้งแต่หลังจากตอบแบบสำรวจความรุนแรงในโรงเรียน จนกระทั่งจบปีการศึกษานั้นๆ</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 학교폭력실태조사 > 학교폭력(설문참여_주관식) > 학교폭력(설문참여_개인정보수집동의팝업)
*  @FileName 	eds_vffos07_p02.xfdl 
*  @Creator 	김민성
*  @CreateDate 	2022.11.22
*  @Desction    학교폭력(설문참여_개인정보수집동의팝업)
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.11.22            김민성                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvLangCd;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	
	// 필수
	this.pv_params = this.smfGetPopupParams();
	this.fvLangCd = this.pv_params.langCd;
	this.fnSelectLang(this.fvLangCd);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
}
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * Top Menu에서 언어를 변경시 발생
 * @param  : sSelectLangCd	- 언어코드
 * @return : N/A
 */
this.fnSelectLang = function(sSelectLangCd)
{
	this.fvLangCd = sSelectLangCd--;
	var divMainCompList = this.svcfSortByTabOrder(this.divMain);
	
	for(var i in divMainCompList){
		if (divMainCompList[i] instanceof nexacro.Static){
			divMainCompList[i].set_text(this.dsLang.getColumn(sSelectLangCd, 'p' + divMainCompList[i].name.substr(4)));
		}
		if (divMainCompList[i] instanceof nexacro.Button){
			divMainCompList[i].set_text(this.dsLang.getColumn(sSelectLangCd, divMainCompList[i].name != 'btnClose' ? 'p' + divMainCompList[i].name.substr(4) : ''));
		}
	}
	this.smfResetScroll(this.divMain.form.divPers00.form.divPers01.form);
	this.smfResetScroll(this.divMain.form.divPers00.form.divPers02.form);
	this.smfResetScroll(this.divMain.form.divPers00.form.divPers03.form);
	this.smfResetScroll(this.divMain.form.divPers00.form);
	this.divMain.set_height(this.divMain.form.sta00.getOffsetBottom());
	this.smfResetScroll(this);
}

/**
 * 동의/비동의 여부
 * @param  : ynValue	- 동의여부
 * @return : row
 */
this.fnIsAgree = function(ynValue){
	
	this.smfSendResponseToOpener({
		"row": ynValue
	});
	this.close(true);
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 동의 버튼 클릭 시
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
this.div00_btnPemOthbc07_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnIsAgree('Y');
};

/**
 * 비동의 버튼 클릭 시
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
this.div00_btnPemOthbc08_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnIsAgree('N');
};

/**
 * X 버튼 클릭 시
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
this.div00_btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};]]></Script>
  </Form>
</FDL>
