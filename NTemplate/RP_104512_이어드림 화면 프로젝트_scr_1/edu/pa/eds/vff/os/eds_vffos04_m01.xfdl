    <Script type="xscript5.1"><![CDATA[/**
* 
*  @MenuPath    교육설문 > 학교폭력실태조사 > 학생정보확인
*  @FileName    eds_vffos04_m01.xfdl 
*  @Creator     김민성
*  @CreateDate  2022.11.03
*  @Desction    학생정보확인
******************* 소스 수정 이력 ******************************************
*  date                 Modifier                Description
*******************************************************************************
* 2022.11.03            김민성                   최초 생성 
*******************************************************************************

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::eds_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvLangCd;
this.fvFilterStr = '';
this.fvScreenUrl = '';
this.fvKeyBoardChange = false;
this.fvLang = ['ko', 'en', 'zh', 'ja', 'vi', 'tl', 'ru', 'th'];
this.fvIsInfoOpen = true;
this.fvPeriod;
this.prefixs;
this.staKeyValue;
this.cddcCd;
this.surveyCk = true;   // 설문기간 여부 (기본값: true) 
this.fv_isQr = "";  // QR여부
var btnClickCount = 1;  // 확인하기 버튼 틀린 횟수

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
    // 폼 초기화
    this.smfInitForm(obj);

    // 필수
    this.smfResetScroll(this);
    this.pv_params = this.smfGetFormParams();
    this.fvLangCd = this.pv_params.langCd;
    this.cddcCd = this.pv_params.cddcCd;
    
    // Top버튼의 언어선택등을 안보이게 한다.(보여줄때는 처리를 안해도 됨)
    this.divTop.form.fnSetTopFrameBtnVisible(true, true, false);
    this.fvPeriod = this.fnChkPeriod("vff", null);

    // pc화면 정렬
    this.fnSetcompSizeP();
    
    this.dsSearch.setColumn(0, 'qstnYr', this.fvPeriod[0].substr(0,4));
    this.dsSearch.setColumn(0, 'qstnDgr', this.fvPeriod[6]);
    if(this.smfIsNull(this.pv_params.edsType) == true){ //edsdata 없으면
        this.dsSearch.setColumn(0, 'cddcScCd', this.cddcCd.substr(0,3));
    }else{
        this.dsSearch.setColumn(0, 'cddcScCd', this.pv_params.edsData.substr(0, 3));
    }
    
    // 초기 onload세팅
    this.divMain.form.div01.form.cboGrd.set_index(0);
    this.divMain.form.div01.form.edtTitle03.setFocus();
    if(this.smfIsNull(this.fvLangCd)){
        this.fvLangCd = 1;
    }
    this.divTop.form.fnSetSelect(this.fvLangCd);
    this.fnSelectLang(this.fvLangCd);
        
    //@KBR 가상키보드 사용
    var objOption1 = {
        target : this.divMain.form.div01.form.edtPtptNo, // 대상 Edit 컴포넌트 [필수]
        targetKey : this.divMain.form.div01.form.staTransKey, // Edit와 쌍으로 있는 마우스입력 체크박스(static) [필수]
        bshow : true,
        dataType : "A",
        maxLength : 6 // maxLength (default = 8) [선택]
        }
    this.smfInitTranskey(objOption1);


    // 서비스 객체 생성 (현재 시간 받아오기)   =============================================
    this.smfSearchService("select")
    // 실행
    .run()
    // 콜백
    .callback(function(callbackParams){
        if(callbackParams.errors) return;
            
        // today 날짜, 시간
        var surveyDate = this.dsSearch.getColumn(0, "date");    // 현재 날짜
        var surveyTime = this.dsSearch.getColumn(0, "time");    // 현재 시간
		
		var vffBgngYmd = this.dsVffDate.getColumn(0, "vffBgngYmd");
		var vffEndYmd = this.dsVffDate.getColumn(0, "vffEndYmd");
		var vffBgngTm = this.dsVffDate.getColumn(0, "vffBgngTm");
		var vffEndTm = this.dsVffDate.getColumn(0, "vffEndTm");
        
        // today일 때만 시작시간, 마감시간 변경
        surveyDate == this.dsValid.getColumn(0, "qstnBgngYmd") ? this.dsValid.setColumn(0, "vffStaTm", "0900") : this.dsValid.setColumn(0, "vffStaTm", "0000");
        surveyDate == this.dsValid.getColumn(0, "qstnEndYmd") ? this.dsValid.setColumn(0, "vffFinTm", "1800") : this.dsValid.setColumn(0, "vffFinTm", "2359");

        if(this.smfIsNull(this.dsValid.getColumn(0, "qstnBgngYmd"))){   // 설문기간 데이터 아예 없으면
            this.surveyCk = false;  // 설문기간 마감 (false)
        }else{
            if(!this.smfIsNull(surveyDate) && !(surveyDate >= this.dsValid.getColumn(0, "qstnBgngYmd") && surveyDate < this.dsValid.getColumn(0, "qstnEndYmd")) && surveyDate < this.dsValid.getColumn(0, "qstnEndYmd")){   // 설문기간 전
                this.surveyCk = false;  // 설문기간 마감 (false)
            }else if(!this.smfIsNull(surveyDate) && !(surveyDate >= this.dsValid.getColumn(0, "qstnBgngYmd")  && surveyDate < this.dsValid.getColumn(0, "qstnEndYmd")) && surveyDate > this.dsValid.getColumn(0, "qstnEndYmd")){    // 설문기간 후
                this.surveyCk = false;  // 설문기간 마감 (false)
            }else if(!this.smfIsNull(surveyTime) && !(surveyTime >= this.dsValid.getColumn(0, "vffStaTm") && surveyTime < this.dsValid.getColumn(0, "vffFinTm"))){  // 시간 비교
                this.surveyCk = false;  // 설문시간 마감 (false)
            }
        }

        //this.dsSearch.setColumn(0, 'cddcScCd', this.smfGetCddcCode().substr(0,3));
        // ---------------------------------------------------------------------------------------------
        // QR코드로 참여시
        // 예) http://dev.eduro.go.kr/nxui/index.html?edstype=AA&edsdata=K100000001K1000003834PJ29K2
        // this.pv_params
        // "autoLogin": "Y",
        // "edsType": "AA",
        // "edsData": "K100000001K1000003834D69LCG"
        // ---------------------------------------------------------------------------------------------
        if(this.smfIsNull(this.pv_params.edsType) == false && this.smfIsNull(this.pv_params.edsData) == false && this.pv_params.edsData.length != 10) {
            if(this.pv_params.edsType.length != 2 || this.pv_params.edsData.length != 27) {
                this.smfAlertEds('잘못된 접근입니다.', [], function() {
                    window.location.href = document.location.href.split("?")[0];
                });
                return;
            }
			
			if (((vffBgngYmd <= surveyDate) && (surveyDate <= vffEndYmd)) && ((vffBgngTm <= surveyTime) && (surveyTime <= vffEndTm))) {
				this.smfAlertEds("현재는 설문조사 참여 시간이 아닙니다.\n 설문조사 참여 제한시간 : 오전 7:00 ~ 10:00 \n\n 이용에 불편을 드려 죄송합니다.", [], function() {
                    window.location.href = document.location.href.split("?")[0];
                });
                return;
			}
     
            if(this.surveyCk == true){
                if(this.isNotNil(this.pv_params.edsData)){  // edsData가 있으면 (데이터 검증)
                    this.fv_isQr = "Y";
                    var popupParams = {
                                        callback: this.fnQrCallback,        // 콜백함수 지정
                                        sender: obj,                        // sender 지정
                                        params: {                           // 팝업 전달 파라메터 지정
                                            procType: "none",               // 처리타입 지정
                                        },
                                        titlebar : false
                                        };
                    // 모바일일 때만 nLeft, nTop null로 주고 nWidth, nHeight는 모바일 사이즈 그대로 줌*** popup
                    this.smfIsMobile() ? this.smfDialog("_auto", "pa_eds_vff_os::eds_vffos04_p03.xfdl", popupParams, null, null, 600, 710) : this.smfDialog("_auto", "pa_eds_vff_os::eds_vffos04_p03.xfdl", popupParams);
                }
            }else{
                this.smfAlertEds('설문에 참여할 수 없습니다. 설문기간이 아닙니다.');
            }
        }else{
            if(this.smfIsNull(this.pv_params.edsType) == false && this.smfIsNull(this.pv_params.edsData) == false && this.pv_params.edsData.length == 10) {
                // 조회조건
                this.dsSearch.setColumn(0, "cddcScCd", this.pv_params.edsData.substr(0, 3));    // 시도코드
            }else if((this.smfIsNull(this.pv_params.edsType) == false && this.smfIsNull(this.pv_params.edsData) == true) || (this.smfIsNull(this.pv_params.edsType) == false && this.smfIsNull(this.pv_params.edsData) == false && this.pv_params.edsData.length < 10)){
                this.smfAlertEds('잘못된 접근입니다.', [], function(){
                    window.location.href = document.location.href.split("?")[0];
                });
                return;
            }
        }
    }); // callback end =====================================================================
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
    if(errcd == -1) return;
};

/**
 * 팝업의 콜백함수
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
    if(e.row){
        for(var sKey in e.row){
            this.dsShlList.setColumn(0, sKey, e.row[sKey]);
        }
    }
    this.dsSearch.copyRow(0, this.dsShlList, 0);
    this.fnSetComp();
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
    var param = {langCd: this.fvLangCd,
        prefixs: this.prefixs,
        mdfcnNts: this.dsTrnRltList.getColumn(0, "mdfcnNts"),
        dataset: this.dsSearch.saveXML(),
        dataset2: this.dsTrnRltList.saveXML(),
     };

    this.smfSetWorkPage(this.fvScreenUrl,param,false);
}

/**
 * Top Menu에서 이전화면으로 가기 버튼을 클릭 시 발생
 * @param : N/A
 */
this.fnMoveBack = function(){
    var param = {langCd: this.fvLangCd
                 ,cddcCd: this.cddcCd || this.pv_params.edsData.substr(0,10)};
    this.smfSetWorkPage("pa_eds_vff_os::eds_vffos03_m01.xfdl",param,false);
};

/**
 * 학교폭력설문 QR 콜백
 * @param : N/A
 * @param : N/A
 */
this.fnQrCallback = function(e)
{   
    this.fvLangCd = e.result;
    this.dsSearch.setColumn(0, "edsData", this.pv_params.edsData);
    qrCddcCd = this.pv_params.edsData.substr(0, 3);
    qrPaptCd = this.pv_params.edsData.substring(21, 27);
    qrShlCrseScCd = this.pv_params.edsData.substr(20, 1);
    qrShlCd = this.pv_params.edsData.substr(10, 10);
    
    // 조회조건
    this.dsSearch.setColumn(0, "qstnDgr", this.fvPeriod[6]);    // 1 or 2
    this.dsSearch.setColumn(0, "qstnYr", this.fvPeriod[0].substr(0,4)); // 검사연도
    this.dsSearch.setColumn(0, "cddcScCd", qrCddcCd);   // 시도코드
    this.dsSearch.setColumn(0, "qstnPtptCnfmCd", qrPaptCd); // 참여번호
    this.dsSearch.setColumn(0, "shlCd", qrShlCd);   // 학교코드
    this.dsSearch.setColumn(0, "shlCrseScCd", qrShlCrseScCd);   // 학교과정구분코드
    this.dsSearch.setColumn(0, "eamScCd", qrShlCrseScCd == 2 ? 1 : 2); // 초중등구분코드
    
    this.fnSearchCheck();   // 학생조회
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 학교찾기 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchShlList = function()
{
    // 서비스 객체 생성
    this.smfSearchService("list")
        // 실행
        .run()
        // 콜백
        .callback(function(callbackParams){
            if(callbackParams.errors){
                this.smfAlertEds('LI155', [this.dsComLang.getColumn(this.fvLangCd - 1, 'alertCommonTitle07')]);
                return;
            }

            if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){
                if (this.dsApiResponseList.getColumn(0, 'shlResult') == '0'){
                    this.dsShlList.setColumn(0, 'shlCd', null);
                }
                if (this.dsShlList.getRowCount() == 1 && this.isNotNil(this.dsShlList.getColumn(0, 'shlCd'))){
                    this.dsSearch.copyRow(0, this.dsShlList, 0);
                    this.fnSetComp();
                }else{
                    this.fnSearchShlPopup();
                }
            }else{
                this.smfAlertEds('LI155', [this.dsApiResponseList.getColumn(0, 'message')]);
            }
        });
};

/**
 * 학생정보 확인서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSearchCheck = function()
{       
    // 서비스 객체 생성
    this.smfSearchService("check")
        // 실행
        .run()
        // 콜백
        .callback(function(callbackParams){
            if(callbackParams.errors){
                this.smfAlertEds('LI155', [this.dsComLang.getColumn(this.fvLangCd - 1, 'alertCommonTitle07')]);
                return;
            }
            
            if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){
                if(this.dsTrnRltList.getRowCount() == 0){
                    this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle05')]);
                    this.divMain.form.btnQstn.set_enable(true);
                    return;
                }
    
                var mdfcnNts = this.dsTrnRltList.getColumn(0, 'mdfcnNts'); // 객관식 수정횟수
                var dscrpMdfcnNts = this.dsTrnRltList.getColumn(0, 'dscrpMdfcnNts'); // 주관식 수정횟수
                var tmprStrgYn = this.dsTrnRltList.getColumn(0, 'tmprStrgYn'); // 임시저장 여부
                var sbmsnYn = this.dsTrnRltList.getColumn(0, 'sbmsnYn'); // 제출여부
                var joinCd = this.dsTrnRltList.getColumn(0, 'joinCd'); // 참여가능코드
                var qstnDgr = this.dsTrnRltList.getColumn(0, 'qstnDgr'); // 전수 1 표본 2
                this.dsSearch.setColumn(0, 'qstnDgr', qstnDgr); // 설문 차수 자동(참여번호 맞출 때 들고 옴)
                var qstnKndScCd = this.dsTrnRltList.getColumn(0, 'qstnKndScCd');
                
                // DB에서 가져온 참여번호, joinCd 세팅
                this.dsSearch.copyRow(0,this.dsTrnRltList, 0);
                this.dsSearch.setColumn(0, "cddcScCd", this.dsTrnRltList.getColumn(0, 'cteOfcdcCd').substr(0, 3));

                 // 사용교
                if (this.dsShlList.getColumn(0, 'neisUseYn') == 'Y' || this.isNotNil(this.pv_params.edsData)){
                    if(joinCd == 3){ // 설문완료
                        // 이미 설문조사에 참여하였습니다.
                        if((btnClickCount < 5)) {
                            this.smfAlertEds('LI155', [this.dsComLang.getColumn(this.fvLangCd - 1, 'alertCommonTitle05')]);
                        }
                        this.fnBtnClickChk(); // 5회 이상 틀리는 경우 버튼 5분 잠김
                        return;
                    }
                    if(this.isNil(tmprStrgYn) && this.isNil(sbmsnYn)){ // 임시저장 x, 제출 x
                        // 학생정보가 확인되었습니다.
                        this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle06')], this.fnMessageCallback);
                        this.fvScreenUrl = "pa_eds_vff_os::eds_vffos05_m01.xfdl";
                        return;
                    } // 임시저장 o, 제출X
                    else if(tmprStrgYn == 'Y' && sbmsnYn == 'N'){
                        // 임시저장된 설문내역이 있습니다. 임시저장한 화면으로 이동합니다.
                        this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle14')], this.fnMessageCallback );
                        this.fvScreenUrl = "pa_eds_vff_os::eds_vffos06_m01.xfdl";
                        return;
                    } // 표본조사 제출 후 참여
                    else if(tmprStrgYn == 'N' && sbmsnYn == 'Y' && qstnDgr == 2){
                        // 학교폭력 설문을 1회 참여하였으며 1회에 한하여 수정하여 제출할 수 있습니다.\n※ 재참여 시 기존 설문 응답 내용은 초기화됩니다.
                        this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle15') + '\n'
                                             + this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle15_0')], this.fnMessageCallback );
                        this.fvScreenUrl = "pa_eds_vff_os::eds_vffos06_m01.xfdl";
                        return;
                    } 
                    else if(tmprStrgYn == 'N' && sbmsnYn == 'Y' && qstnDgr == 1){
                        // 학교폭력 설문을 1회 참여하였으며 1회에 한하여 수정하여 제출할 수 있습니다.\n※ 재참여 시 기존 설문 응답 내용은 초기화됩니다.
                        this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle15') + '\n'
                                             + this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle15_0')], this.fnMessageCallback );
                        this.fvScreenUrl = "pa_eds_vff_os::eds_vffos06_m01.xfdl";
                        return;
                    }
                    
//                  //주관식 제출 후 나중에 제출(2024년 1차 전수조사 주관식 설문 주석)
//                  else if(tmprStrgYn == 'N' && sbmsnYn == 'Y' && mdfcnNts == 1 && joinCd == 2){
//                      // 학교폭력 설문을 1회 수정하였으며 학교폭력 신고문항은 제출하지 않았습니다. 학교폭력 신고화면으로 이동합니다.
//                      this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle12')], this.fnMessageCallback );
//                      this.fvScreenUrl = "pa_eds_vff_os::eds_vffos07_m01.xfdl";
//                      return;
//                  } // 주관식 나중에 제출
//                  else if(tmprStrgYn == 'N' && sbmsnYn == 'Y' && joinCd == 2){
//                      // 학교폭력 설문을 1회 참여하였으며 학교폭력 신고문항은 제출하지 않았습니다. 학교폭력 신고화면으로 이동합니다.
//                      this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle10')], this.fnMessageCallback );
//                      this.fvScreenUrl = "pa_eds_vff_os::eds_vffos07_m01.xfdl";
//                      return;
//                  } // 주관식 예 or 아니오
//                  else if(tmprStrgYn == 'N' && sbmsnYn == 'Y' && joinCd == 1){
//                      // 학교폭력 설문과 학교폭력 신고문항을 각각 1회씩 제출하였습니다. 1회에 한하여 수정하여 제출할 수 있습니다.       
//                      this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle11')], this.fnMessageCallback );
//                      this.fvScreenUrl = "pa_eds_vff_os::eds_vffos06_m01.xfdl";
//                      return;
//                  }
                }else{ // 미사용교
                    // 학생정보가 확인되었습니다.
                    this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle06')], this.fnMessageCallback );
                    this.fvScreenUrl = "pa_eds_vff_os::eds_vffos05_m01.xfdl";
                    return;
                }
            }else{  // fail (학생정보 미확인)
                if((btnClickCount < 5)) {
                    this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle05')]);
                }
                this.fnBtnClickChk(); // 5회 이상 틀리는 경우 버튼 5분 잠김
                return;
            }
        });
};

/**
 * 5회이상 틀릴경우 버튼 잠금
 * @param  : initVal            - 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnBtnClickChk = function(){
    btnClickCount = btnClickCount + 1;  // 확인하기 버튼 틀린 횟수
    
    if (btnClickCount > 5) {
        this.divMain.form.btnQstn.set_enable(false);
        this.smfAlertEds("5회 이상 잘못된 정보를 입력하였습니다.\n5분 뒤에 다시 시도하실 수 있습니다.\n\n※ 참여번호 분실 등 문제가 있을 경우\n학교로 재발급을 요청해주시기 바랍니다.");
        this.setTimer(1,300000);
        btnClickCount = 1;
    return false;
    }
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * Top Menu에서 언어를 변경시 발생
 * @param  : sSelectLangCd  - 언어코드
 * @return : N/A
 */
this.fnSelectLang = function(sSelectLangCd)
{
    this.dsSearch.setColumn(0, 'qstnExmnLangScCd', (this.fvLang[this.fvLangCd-1]).toUpperCase());
    
    this.fvLangCd = sSelectLangCd--;
    var divMainCompList = this.svcfSortByTabOrder(this.divMain);

    for(var i in divMainCompList){
        if (divMainCompList[i] instanceof nexacro.Static){
            //@KBR 가상키보드Static 제외
            if(divMainCompList[i].name.indexOf('staTransKey') > -1) continue;
            if(divMainCompList[i].name.indexOf('staBtnScrtyTooltipText') > -1)  continue;
                divMainCompList[i].set_text(this.dsLang.getColumn(sSelectLangCd, divMainCompList[i].name.substr(3).toLowerCase()));
            if (divMainCompList[i].name.indexOf('staTitle18_') > -1){
                this.divMain.form.div00.form.resetScroll();
            }
        }
        if (divMainCompList[i] instanceof nexacro.Button){
            divMainCompList[i].set_text(this.dsLang.getColumn(sSelectLangCd, divMainCompList[i].name == 'btnQstn' ? 'title17' : ''));
        }
        if (divMainCompList[i] instanceof nexacro.Edit){
            divMainCompList[i].set_displaynulltext(this.dsLang.getColumn(sSelectLangCd, divMainCompList[i].name == 'edtTitle03' ? 'title03' : ''));
        }
    }
    
    this.dsGrd.filter();
    if (this.smfIsNull(this.dsSearch.getColumn(0, 'shlCd'))){
        this.fvFilterStr = "langCd == " + this.fvLangCd;
    }
    this.dsGrd.filter(this.fvFilterStr);
    this.fnSetComp();
}

/**
 * 미사용학교인지 사용학교인지에 따른 컴포넌트 동적 변화
 * @param  : N/A
 * @return : N/A
 */
this.fnSetComp = function()
{
    var isUse = this.dsShlList.getColumn(0, 'neisUseYn') == 'Y' || this.smfIsNull(this.dsShlList.getColumn(0, 'neisUseYn')) ? true : false;

    // 참여번호, 생년월일, 성별
    this.divMain.form.div01.form.staTitle13.set_visible(isUse); // 참여번호
    this.divMain.form.div01.form.edtPtptNo.set_visible(isUse);  // 참여번호edit
    this.divMain.form.div01.form.staTransKey.set_visible(isUse);  // 참여번호chk static
    this.divMain.form.div01.form.btnQestn.set_visible(isUse);  // ? 버튼
    this.divMain.form.div01.form.staTitle30.set_visible(!isUse); // 생년월일
    this.divMain.form.div01.form.calBrdt.set_visible(!isUse);    // 캘랜더
    this.divMain.form.div01.form.staTitle31.set_visible(!isUse); // 성별
    this.divMain.form.div01.form.rdoSxds.set_visible(!isUse);    // 성별radio
    this.divMain.form.div01.form.chkKeyboardScrtyYn.set_visible(this.smfIsMobile() ? (isUse ? true : false) : false);   // 키보드보안 안내
    this.divMain.form.div01.form.sta00.set_visible(this.smfIsMobile() ? (isUse ? true : false) : false);    // 키보드보안 안내2

    // 안내문 문구
    this.divMain.form.div00.form.staTitle18_1.set_text(this.dsLang.getColumn(this.fvLangCd-1, isUse ? 'title18_1' : 'title18_2_1'));
    this.divMain.form.div00.form.staTitle18_2.set_text(this.dsLang.getColumn(this.fvLangCd-1, isUse ? 'title18_2' : 'title18_2_2'));
    this.divMain.form.div00.form.staTitle18_3.set_text(this.dsLang.getColumn(this.fvLangCd-1, isUse ? 'title18_3' : 'title18_2_3'));
    this.divMain.form.div00.form.staTitle18_4.set_text(this.dsLang.getColumn(this.fvLangCd-1, isUse ? 'title18_4' : 'title18_2_4'));
    this.divMain.form.div00.form.resetScroll();
    
    this.fnSetGrd();
    this.fnSetSxds();
    this.fnSetcompSize();
    this.fnSetSecureKeyboard();
}

/**
 * 가상키패드 동적변화
 * @param  : N/A
 * @return : N/A
 */
this.fnSetSecureKeyboard = function()
{
    if(!this.smfIsMobile()){
        if(this.dsShlList.getColumn(0, 'neisUseYn') == 'N'){
            this.divMain.form.div01.form.sta01.set_visible(false);  // 키보드보안 안내2
        }else{
			this.divMain.form.div01.form.sta01.set_visible(true);
            this.divMain.form.div01.form.sta01.set_text(this.dsLang.getColumn(this.fvLangCd-1, 'title34'));
            if(this.fvLangCd == 1 || this.fvLangCd == 3){
                this.divMain.form.div01.form.btnQestn.set_left(290);
            }else{
                this.divMain.form.div01.form.btnQestn.set_left(370);
            }
        }
        
    }else{
        this.divMain.form.div01.form.sta00.set_text(this.dsLang.getColumn(this.fvLangCd-1, 'title34'));
    }
}

/**
 * 학년도 동적변화
 * @param  : N/A
 * @return : N/A
 */
this.fnSetGrd = function()
{
    this.dsGrd.filter("");
    var shlKndScCd = this.dsShlList.getColumn(0, 'shlKndScCd');
    if(shlKndScCd == "02" || shlKndScCd == "06" || shlKndScCd == "14" || shlKndScCd == "19" || shlKndScCd == "20") {    //초등
        this.fvFilterStr = this.fvLangCd == 1 ? "langCd == '" + this.fvLangCd + "_2'" : "langCd == '" + this.fvLangCd + "_3'";
    } else if(shlKndScCd == "03" || shlKndScCd == "07" || shlKndScCd == "09" || shlKndScCd == "12" || shlKndScCd == "16" || shlKndScCd == "25") {   //중등
        this.fvFilterStr = this.fvLangCd == 1 ? "langCd == '" + this.fvLangCd + "_1'" : "langCd == '" + this.fvLangCd + "_4'";
    } else if(shlKndScCd == "04" || shlKndScCd == "08" || shlKndScCd == "10" || shlKndScCd == "11" || shlKndScCd == "13" || shlKndScCd == "17" || shlKndScCd == "18") { //고등
        if(this.fvLangCd == 1){
            if ((new Date().getMonth() + 1) > 6){
                this.fvFilterStr = "code < 3 && langCd == '" + this.fvLangCd + "_1'";
            }else{
                this.fvFilterStr = "langCd == '" + this.fvLangCd + "_1'";
            }
        } else {
            if ((new Date().getMonth() + 1) > 6){
                this.fvFilterStr = "code < 3 && langCd == '" + this.fvLangCd + "_5'";
            }else{
                this.fvFilterStr = "langCd == '" + this.fvLangCd + "_5'";
            }
        }
    }else if(shlKndScCd == "05" || shlKndScCd == "26") {        //특수
        if ((new Date().getMonth() + 1) > 6){
            this.fvFilterStr = "code != 3 && langCd == '" + this.fvLangCd + "_6'";
        }else{
            this.fvFilterStr = "langCd == '" + this.fvLangCd + "_6'";
        }
    }
    this.dsGrd.filter(this.fvFilterStr);
    
    if (this.divMain.form.div01.form.cboGrd.index == -1){
        this.divMain.form.div01.form.cboGrd.set_index(0);
    }
}

/**
 * 성별 동적변화
 * @param  : N/A
 * @return : N/A
 */
this.fnSetSxds = function()
{
    var ds = this.divMain.form.div01.form.rdoSxds.getInnerDataset();

    ds.setColumn(0, 'datacolumn', this.dsLang.getColumn(this.fvLangCd-1, 'title32')); // 남
    ds.setColumn(1, 'datacolumn', this.dsLang.getColumn(this.fvLangCd-1, 'title33')); // 여
}

/**
 * 학교찾기 팝업 호출
 * @param  : N/A
 * @return : N/A
 */
this.fnSearchShlPopup = function()
{
    var popupParams = {
        callback: this.fnPopupCallback,
        sender: obj, // sender 지정
        params: {
            procType : 'search'
            ,dataset: this.dsSearch
            ,langCd: this.fvLangCd
        },
        titlebar : false,
    };

    this.smfDialog("_auto", "pa_eds_vff_os::eds_vffos04_p01.xfdl", popupParams, null, null, this.smfIsMobile() ? 640 : null, this.smfIsMobile() ? 559 : null);
}

/**
 * 디바이스 구분
 * @param  : N/A
 * @return : deviceNm           - 디바이스 명칭
 */
this.fnDeviceKnd = function(){
    var mobileFlag = /Mobile|iP(hone|od)|Windows(CE|Phone)|Minimo|Opera M(obi|ini)|BlackBerry|Nokia/;

    if(navigator.userAgent.match(mobileFlag) && !navigator.userAgent.match(/iPad/)){
        return 'Mobile';
    }else if(navigator.userAgent.match(/iPad|Android/)){
        return 'Tablet';
    }else{
        return 'PC';
    }
};

/**
 * 드롭다운/오픈 Btn 함수
 * @param  : initVal            - 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnSetDropBtn = function(){
    if (this.smfIsMobile()){
        if (this.fvIsInfoOpen){ // 안내문 오픈 > 닫힘
            this.divMain.form.div00.set_height(this.divMain.form.div00.form.sta03.getOffsetTop());
            this.divMain.form.div00.form.btn00.set_cssclass('btn_WF_SurvDropUp');
            this.fvIsInfoOpen = false;
            this.smfResetScroll(this.divMain.form);
        }else{ // 안내문 닫힘 > 오픈
            this.divMain.form.div00.form.btn00.set_cssclass('btn_WF_SurvDropDown');
            this.smfResetScroll(this.divMain.form.div00.form);
            this.smfResetScroll(this.divMain.form.div01.form);
            this.divMain.form.div00.set_height(this.divMain.form.div00.form.staTitle18_5.getOffsetBottom() + 20);
            this.smfResetScroll(this.divMain.form);
            this.fvIsInfoOpen = true;
        }
        this.divMain.set_height(this.divMain.form.sta02.getOffsetBottom());
        this.smfResetScroll(this);
    }
}

/**
 * 컴포넌트 사이즈 조절(Mobile)
 * @param  : initVal            - 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnSetcompSize = function(){
    if (this.smfIsMobile()){
        if(this.fvIsInfoOpen == false){ // 닫힌 상태이면
            this.divMain.form.div00.set_height(this.divMain.form.div00.form.sta03.getOffsetTop());
            this.smfResetScroll(this.divMain.form.div01.form);
            this.smfResetScroll(this.divMain.form);
        }else{
            this.smfResetScroll(this.divMain.form.div00.form);
            this.smfResetScroll(this.divMain.form.div01.form);
            this.divMain.form.div00.set_height(this.divMain.form.div00.form.staTitle18_5.getOffsetBottom() + 20);
            this.smfResetScroll(this.divMain.form);
        }
        this.divMain.set_height(this.divMain.form.sta02.getOffsetBottom());
        this.smfResetScroll(this);
    }
};

/**
 * 컴포넌트 사이즈 조절(PC)
 * @param  : initVal            - 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnSetcompSizeP = function(){
    if (!this.smfIsMobile()){
        var nMaxWidth = 1200;
        var nFormWidth = this.getOffsetWidth();
        var vLeft = Math.floor((this.getOffsetWidth() - (+this.divMain.form.div01.getOffsetWidth()))/2);
        
        if(nFormWidth>nMaxWidth){
            var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
            this.divMain.form.div00.setOffsetLeft(10 + nLeft);
            this.divMain.form.div01.setOffsetLeft(10 + vLeft);
        }else{
            var nLeft = 0;
            this.divMain.form.div00.setOffsetLeft(nLeft);
        }
        this.divMain.form.resetScroll();
    }
};

/**
 * 가상키패드
 * @param  : obj            - edit 컴포넌트
 * @return : N/A
 */
this.fnTransKey = function(obj)
{
    var sVal    = "";
    var arrComp = [obj];  //대상 Edit component List: array [필수]
    
    if(!this.smfIsMobile()){    // PC일 때
        // 키보드보안 적용여부
        var sRtnVal = this.smfGetValueTranskey(obj);
        
        if (this.dsShlList.getColumn(0, 'neisUseYn') == 'N'){   // 나이스 미사용교이면
            sRtnVal = "e2e";
        }
        
        if(sRtnVal == "transkey"){  //선택
            var sVal = this.smfGetEncDataTranskey(arrComp);
            this.staKeyValue = true;
            this.dsSearch.setColumn(0, 'qstnPtptCnfmCd', null); // 코드 추가
            
            //전달받은 파라미터 데이터셋에 담기
            this.smfConvRaonDataToDs(this.dsRaonKeyData,arrComp,sVal);
            this.dsRaonKeyData.setColumn(0, 'tk_col_check', "transkey");
        }else if(sRtnVal == "e2e"){ //미선택
            sVal= obj.value;
            this.staKeyValue = false;
            
            this.dsRaonKeyData.setColumn(0, 'transkey', null);  // 코드 추가
            this.dsRaonKeyData.setColumn(0, 'tk_col_check', 'e2e'); // 코드 추가
        }
    }else{  // 모바일
        if (this.divMain.form.div01.form.chkKeyboardScrtyYn.value == true){ // 모바일일 때, 가상키패드 사용 O
            sVal = this.smfGetEncDataTranskey(arrComp);
            this.dsSearch.setColumn(0, 'qstnPtptCnfmCd', null);
        
            //전달받은 파라미터 데이터셋에 담기
            this.smfConvRaonDataToDs(this.dsRaonKeyData,arrComp,sVal);
            this.dsRaonKeyData.setColumn(0, 'tk_col_check', "transkey");
        }else{  // 모바일일 때, 가상키패드 사용 X
            this.dsRaonKeyData.setColumn(0, 'transkey', null);
            this.dsRaonKeyData.setColumn(0, 'tk_col_check', "e2e");
        }
    }
}

/**
 * ontimer 타이머
 * @param  : obj           - [object]Form
 * @param  : e             - [string]TimerEventInfo
 * @return : N/A
 */
this.eds_vffos04_m01_ontimer = function(obj:nexacro.Form,e:nexacro.TimerEventInfo)
{   
    if (e.timerid == 1){
        this.divMain.form.btnQstn.set_enable(true);
        this.killTimer(e.timerid);
    }
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 학교입력 keydown 시
 * @param  : obj           - [object]Button
 * @param  : e         - [string]ClickEventInfo
 * @return : N/A
 */
this.divMain_div01_edtTitle03_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
    if(e.keycode == "13"){
        this.divMain_div01_btnSearch_onclick(null, null);
    }
};

/**
 * 학교찾기 버튼 클릭 시
 * @param  : obj           - [object]Button
 * @param  : e         - [string]ClickEventInfo
 * @return : N/A
 */
this.divMain_div01_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
    this.dsSearch.setColumn(0, 'shlNm', this.divMain.form.div01.form.edtTitle03.value);
    if (this.smfIsNull(this.dsSearch.getColumn(0, 'shlNm'))){
        this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle01')]);
        this.divMain.form.div01.form.edtTitle03.setFocus();
        return;
    }
    this.fnSearchShlList();
};

/**
 * 가상키패드 물음표박스 버튼 클릭 시
 * @param  : obj           - [object]Button
 * @param  : e         - [string]ClickEventInfo
 * @return : N/A
 */
this.divMain_div01_btnQestn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
    var popupParams = {
        callback: this.fnPopupCallback,
        sender: obj, // sender 지정
        params: {
            procType : 'search'
        },
        titlebar : false,
    };

    this.smfIsMobile() ? this.smfDialog("_auto", "pa_eds_vff_os::eds_vffos04_p02.xfdl", popupParams, null, null, 600, 960) : this.smfDialog("_auto", "pa_eds_vff_os::eds_vffos04_p02.xfdl", popupParams);
};

/**
 * 참여번호 keyup 시
 * @param  : obj           - [object]Button
 * @param  : e         - [string]ClickEventInfo
 * @return : N/A
 */
this.divMain_div01_edtPtptNo_onkeyup = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
    if(!this.smfIsMobile()){
        if(e.keycode == "13"){
            this.divMain_btnQstn_onclick();
        }
    }
};

/**
 * 시작하기 버튼 클릭 시
 * @param  : obj           - [object]Button
 * @param  : e         - [string]ClickEventInfo
 * @return : N/A
 */
this.divMain_btnQstn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
    //@KBR 입력된 참여번호 가져오기
    var transKey = this.fnTransKey(this.divMain.form.div01.form.edtPtptNo);
    
    if (this.isNil(this.dsSearch.getColumn(0, 'shlCd'))){
        if((btnClickCount < 5)) {
            this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle01')]);
            this.divMain.form.div01.form.edtTitle03.setFocus();
        }
        this.fnBtnClickChk(); // 5회 이상 틀리는 경우 버튼 5분 잠김
        return;
    }
    
    if (this.dsSearch.getColumn(0, 'shlNm') != this.dsShlList.getColumn(0, 'shlNm')){
        if((btnClickCount < 5)) {
            this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle01')]);
            this.divMain.form.div01.form.edtTitle03.setFocus();
        }
        this.fnBtnClickChk(); // 5회 이상 틀리는 경우 버튼 5분 잠김
        return;
    }

    if (this.dsShlList.getColumn(0, 'neisUseYn') == 'Y' || this.isNil(this.dsShlList.getColumn(0, 'neisUseYn'))){   // 나이스 사용교이거나 정보없을 때
        this.dsSearch.setColumn(0, "qstnPtptCnfmCd", this.divMain.form.div01.form.edtPtptNo.value);
        
        if (this.smfIsNull(this.divMain.form.div01.form.edtPtptNo.text)){
            if((btnClickCount < 5)) {
                this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle03')]);
                this.divMain.form.div01.form.edtPtptNo.setFocus();
            }
            this.fnBtnClickChk(); // 5회 이상 틀리는 경우 버튼 5분 잠김
            return;
        }
    }
    
    if (this.dsShlList.getColumn(0, 'neisUseYn') == 'N'){   // 나이스 미사용교이면
        if (this.isNil(this.dsSearch.getColumn(0, 'brdt'))){
            if((btnClickCount < 5)) {
                this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle07')]);
                this.divMain.form.div01.form.calBrdt.setFocus();
            }
            this.fnBtnClickChk(); // 5회 이상 틀리는 경우 버튼 5분 잠김
            return;
        }
        
        if (this.isNil(this.dsSearch.getColumn(0, 'sxdsScCd'))){
            if((btnClickCount < 5)) {
                this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle08')]);
                this.divMain.form.div01.form.rdoSxds.setFocus();
            }
            this.fnBtnClickChk(); // 5회 이상 틀리는 경우 버튼 5분 잠김
            return;
        }
    }else{
//      var qstnPtPtCnfmCdValue = this.dsSearch.getColumn(0, 'qstnPtptCnfmCd');
//      if (this.isNil(qstnPtPtCnfmCdValue) || qstnPtPtCnfmCdValue.length != 6 ){
//          if((btnClickCount < 5)) {
//              this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle03')]);
//              this.divMain.form.div01.form.edtPtptNo.setFocus();
//          }
//          this.fnBtnClickChk(); // 5회 이상 틀리는 경우 버튼 5분 잠김
//          return;
//      }
    }
    
    var grd = this.dsSearch.getColumn(0, 'grd');
    var shlKndScCd = this.dsSearch.getColumn(0, 'shlKndScCd');
    
    if(shlKndScCd == '02' || shlKndScCd == '06' || shlKndScCd == '19'){ // 초등
        this.dsSearch.setColumn(0, 'shlCrseScCd', 2);
        this.dsSearch.setColumn(0, 'eamScCd', 1);
		this.prefixs = '_ele';
    }else if(shlKndScCd == '03' || shlKndScCd == '07' || shlKndScCd == '09' || shlKndScCd == '25'){ // 중등
        this.dsSearch.setColumn(0, 'shlCrseScCd', 3);
        this.dsSearch.setColumn(0, 'eamScCd', 2);
		this.prefixs = '_mid'; 
    }else if(shlKndScCd == '04' || shlKndScCd == '08' || shlKndScCd == '10' || shlKndScCd == '11' || shlKndScCd == '18'){ // 고등
        this.dsSearch.setColumn(0, 'shlCrseScCd', 4);
        this.dsSearch.setColumn(0, 'eamScCd', 2);
		this.prefixs = '_mid'; 
    }else if(shlKndScCd == '05' || shlKndScCd == '26'){ // 특수
        if(grd == 4 || grd == 5 || grd == 6){
            this.dsSearch.setColumn(0, 'shlCrseScCd', 2);
            this.dsSearch.setColumn(0, 'eamScCd', 1);
			this.prefixs = '_ele';
        }else if(grd == 7 || grd == 8 || grd == 9){
            this.dsSearch.setColumn(0, 'shlCrseScCd', 3);
            this.dsSearch.setColumn(0, 'eamScCd', 2);
			this.prefixs = '_mid'; 
        }else if(grd == 1 || grd == 2 || grd == 3){
            this.dsSearch.setColumn(0, 'shlCrseScCd', 4);
            this.dsSearch.setColumn(0, 'eamScCd', 2);
			this.prefixs = '_mid'; 
        }else{
            this.dsSearch.setColumn(0, 'shlCrseScCd', 0);
            this.dsSearch.setColumn(0, 'eamScCd', 1);
			this.prefixs = '_mid'; 
        }
    }else{
        this.dsSearch.setColumn(0, 'shlCrseScCd', 0);
        this.dsSearch.setColumn(0, 'eamScCd', 1);
		this.prefixs = '_mid'; 
    }
    
    if(this.surveyCk == true){
        this.fnSearchCheck();   // 학생조회
    }else{
        if((btnClickCount < 5)) {
            this.smfAlertEds('설문에 참여할 수 없습니다. 설문기간이 아닙니다.');
        }
        this.fnBtnClickChk(); // 5회 이상 틀리는 경우 버튼 5분 잠김
        return;
    }
};

/**
 * 유의사항 버튼 클릭 시
 * @param  : obj           - [object]CheckBox
 * @param  : e             - [string]CheckBoxChangedEventInfo
 * @return : N/A
 */
this.divMain_div00_btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
    this.fnSetDropBtn();
};

/**
 * 화면 사이즈 변경시 (Mobile)
