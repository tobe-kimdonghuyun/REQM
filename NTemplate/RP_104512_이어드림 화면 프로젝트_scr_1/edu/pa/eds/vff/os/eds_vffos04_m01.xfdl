 * @return : N/A
 */
this.eds_vffos04_m01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
    this.fnSetcompSizeP();
};

/**
 * 모바일일 때 가상키패드 활성화 (초기화)
 * @param  : obj            - [object]CheckBox
 * @param  : e              - [string]SizeEventInfo
 * @return : N/A
 */
this.div00_div00_chkKeyboardScrtyYn_canchange = function(obj:nexacro.CheckBox,e:nexacro.ChangeEventInfo)
{
    this.divMain.form.div01.form.chkKeyboardScrtyYn.value == "true" ? this.divMain.form.div01.form.chkKeyboardScrtyYn.set_value == "false" : this.divMain.form.div01.form.chkKeyboardScrtyYn.set_value == "true" ;
    if(this.smfIsMobile()){ // 모바일/테블릿
        document.getElementsByClassName("staTransKey")[0].children.item(0).click();
    }else{  // 데스크탑
        document.getElementsByClassName("staTransKey")[0].children.item(0).children.item(0).click();
    }
    this.smfClearTranskey(this.divMain.form.div01.form.edtPtptNo);
    this.divMain.form.div01.form.edtPtptNo.value = "";
};

/**
 * PC일 때 taborder시 가상키패드 노출
 * @param  : obj            - [object]Edit
 * @param  : e              - [string]SetFocusEventInfo
 * @return : N/A
 */
this.divMain_div01_edtPtptNo_onsetfocus = function(obj:nexacro.Edit,e:nexacro.SetFocusEventInfo)
{
    var orderTabCk = document.getElementsByClassName("staTransKey")[0].children.item(0).children.item(0);

    // if() PC이고 키패드가 켜져있을 때만
    if(!this.smfIsMobile() && orderTabCk.src.indexOf("on") > -1){
        orderTabCk.click();
        orderTabCk.click();
    }
};

/**
 * 가상키패드 결함 수동 제거(PC)
 * @param  : obj            - [object]Static
 * @param  : e
 * @return : N/A
 */
this.divMain_div01_staTransKey_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
    this.fnTransKey(this.divMain.form.div01.form.edtPtptNo);
    // PC
    if(!this.smfIsMobile() && this.staKeyValue == true){
        this.divMain.form.div01.form.edtPtptNo.set_value("");
    }
};

/**
 * 가상키패드 결함 수동 제거(모바일)
 * @param  : obj            - [object]CheckBox
 * @param  : e              - [string]SetFocusEventInfo
 * @return : N/A
 */
this.divMain_div01_chkKeyboardScrtyYn_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
    this.fnTransKey(this.divMain.form.div01.form.edtPtptNo);
    // mobile
    if(this.smfIsMobile()){
        this.smfClearTranskey(this.divMain.form.div01.form.edtPtptNo);
        this.divMain.form.div01.form.edtPtptNo.value = "";
    }
};]]></Script>
