      <Dataset id="dsComLang">
        <ColumnInfo>
          <Column id="alertCommonTitle01" type="STRING" size="256"/>
          <Column id="alertCommonTitle02" type="STRING" size="256"/>
          <Column id="alertCommonTitle03" type="STRING" size="256"/>
