            <Col id="title06_5">การคุกคามทางเพศ :</Col>
            <Col id="title06_4">การทำร้ายร่างกาย :</Col>
            <Col id="title06_3">การขู่กรรโชก :</Col>
            <Col id="title06_2">การบังคับ :</Col>
            <Col id="title06_1">ความรุนแรงทางวาจา :</Col>
            <Col id="title06_1_1">การสบถคำหยาบคาย การล้อเลียน หรือการข่มขู่(คำพูดที่ทำให้กลัว)</Col>
            <Col id="title06_2_1">การบังคับให้ทำสิ่งที่ไม่ต้องการ</Col>
            <Col id="title06_3_1">แย่งเอาเงินหรือสิ่งของ</Col>
            <Col id="title06_4_1">ตบตีหรือกักขังไว้ในสถานที่ที่กำหนดไว้</Col>
            <Col id="title06_5_1">การกลั่นแกล้ง เช่น หยอกล้อทางเพศ การลวนลาม การข่มขืน ฯลฯ</Col>
            <Col id="title06_6_1">รังแกนักเรียนคนอื่นบนพื้นที่ออนไลน์(เช่น: อินเทอร์เน็ต สมาร์ทโฟน ฯลฯ)</Col>
            <Col id="title06_7_1">แต่ก็ยังคอยตามและคุกคามพวกเขา การคอยติดตามและคุกคามอีกฝ่าย(นักเรียนคนดังกล่าว) ทั้งที่พวกเขาแสดงออกว่าไม่ชอบ</Col>
            <Col id="title06_8_1">คอยกลั่นแกล้งโดยคนหลายคน</Col>
            <Col id="button02">ยกเลิก</Col>
            <Col id="cddcNmB10">สำนักงานการศึกษากรุงโซล</Col>
            <Col id="cddcNmC10">สำนักงานการศึกษาปูซาน</Col>
            <Col id="cddcNmD10">สำนักงานการศึกษาแทกู</Col>
            <Col id="cddcNmE10">สำนักงานการศึกษานครอินชอน</Col>
            <Col id="cddcNmF10">สำนักงานการศึกษาควังจู</Col>
            <Col id="cddcNmG10">สำนักงานการศึกษาแทจอน</Col>
            <Col id="cddcNmH10">สำนักงานการศึกษาอุลซาน</Col>
            <Col id="cddcNmI10">สำนักงานการศึกษาจังหวัดปกครองตนเองพิเศษเซจง</Col>
            <Col id="cddcNmJ10">สำนักงานการศึกษาคยองกีโด</Col>
            <Col id="cddcNmK10">สำนักงานการศึกษาจังหวัดปกครองตนเองพิเศษคังวอน</Col>
            <Col id="cddcNmM10">สำนักงานการศึกษาชุงชองบุกโด</Col>
            <Col id="cddcNmN10">สำนักงานการศึกษาชุงชองนัมโด</Col>
            <Col id="cddcNmP10">สำนักงานการศึกษาจังหวัดปกครองตนเองพิเศษชอนบุก</Col>
            <Col id="cddcNmR10">สำนักงานการศึกษาคยองซังบุกโด</Col>
            <Col id="cddcNmS10">สำนักงานการศึกษาคยองซังนัมโด</Col>
            <Col id="cddcNmT10">สำนักงานการศึกษาจังหวัดปกครองตนเองพิเศษเชจู</Col>
            <Col id="cddcNmQ10">สำนักงานการศึกษาชอลลานัมโด</Col>
            <Col id="title10">4. 2025.</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    교육설문 > 학교폭력실태조사 > 학교폭력(인사말)
*  @FileName 	eds_vffos03_m01.xfdl
*  @Creator 	정인혁
*  @CreateDate 	2022.11.1
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.11.1     	정인혁 	        최초 생성
*  2022.11.3     	김민성 	        소스 개발
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::eds_script.xjs"
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvLangCd = 1;
this.fvLang = ['ko', 'en', 'zh', 'ja', 'vi', 'tl', 'ru', 'th'];
this.fvLang2 = ['kor', 'eng', 'chn', 'jpn', 'vin', 'phi', 'rus', 'tha'];
this.fvPeriod;
this.cddcCd;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitForm(this);
	
	// 필수
	this.smfResetScroll(this);
	this.pv_params = this.smfGetFormParams();
	if (!this.smfIsNull(this.pv_params.langCd)){
		this.fvLangCd = this.pv_params.langCd;
		this.divTop.form.fnSetSelect(this.fvLangCd);
	}
	
	if (!this.smfIsNull(this.pv_params.cddcCd)){
		this.cddcCd = this.pv_params.cddcCd;
	}
	
	this.fnSelectLang(this.fvLangCd);
	
	this.fvPeriod = this.fnChkPeriod("vff", null);
	
	this.fnCallTTS();	// 음성 auto실행
}; 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
}

/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
};

/**
 * Top Menu에서 이전화면으로 가기 버튼을 클릭 시 발생
 * @param : N/A
 */
this.fnMoveBack = function(){
	var param = {ptptKndCd : "1"};
	this.smfSetWorkPage("frame::eds/frameMap.xfdl",param,false);
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 설문기간 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSelectSurveyPeriod = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("select")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
		
		this.fnSelectLang(this.fvLangCd);
	});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * Top Menu에서 언어를 변경시 발생
 * @param  : sSelectLangCd	- 언어코드
 * @return : N/A
 */
this.fnSelectLang = function(sSelectLangCd)
{
	this.fvLangCd = sSelectLangCd--;
	var divMainCompList = this.svcfSortByTabOrder(this.divMain);
	
	for(var i in divMainCompList){
		if (divMainCompList[i] instanceof nexacro.Static){
			divMainCompList[i].set_text(this.dsLang.getColumn(sSelectLangCd, divMainCompList[i].name.substr(3).toLowerCase()));
			if (divMainCompList[i].name == 'staTitle05_1'){
				divMainCompList[i].set_text("<b v='true'><fc v='#ff3f3f'>" + this.dsLang.getColumn(sSelectLangCd, "title05_1") + "</fc></b>");
				this.divMain.form.div00.form.resetScroll();
			}
			if (divMainCompList[i].name == 'staTitle11'){
				var cddcSc = this.pv_params.cddcCd.substr(0, 3);
				divMainCompList[i].set_text(
											// this.fvPeriod[0].replaceAll('/', '.')
											this.dsLang.getColumn(sSelectLangCd, "title10")
											+ '  '
											+ this.dsLang.getColumn(sSelectLangCd, "cddcNm" + cddcSc));
			}
		}
		if (divMainCompList[i] instanceof nexacro.Button){
			divMainCompList[i].set_text(this.dsLang.getColumn(sSelectLangCd, divMainCompList[i].name == 'btnCancel' ? 'button02' : 'button01'));
		}
	}
	this.fnSetcompSize();
}

/**
 * Top Menu에서 TTS버튼을 클릭시 발생
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.fnCallTTS = function(){
	var qstnYr = this.fvPeriod[0].substr(0,4);
	var qstnDgr = this.fvPeriod[6];
		
	if (!this.smfContainsStr(window.location.host, "local") &&
			  !this.smfContainsStr(window.location.host, "dev") &&
			  !this.smfContainsStr(window.location.host, "tst")){	// cdn (실제 운영 음성)
		return "https://cdn.neis.go.kr/sv/" + this.fvLang2[this.fvLangCd-1] + "/01_ele/00_info/조사안내.mp3";
	}else{	// tts (개발환경 음성)
		return "https://cdn.neis.go.kr/sv/" + this.fvLang2[this.fvLangCd-1] + "/01_ele/00_info/조사안내.mp3";
	}
};

/**
 * 컴포넌트 사이즈 조절
 * @param  : N/A
 * @return : N/A
 */
this.fnSetcompSize = function(){
	if (this.smfIsMobile()){
		this.smfResetScroll(this.divMain.form.div00.form);
		this.divMain.form.div00.set_height(this.divMain.form.div00.form.staTitle07.getOffsetBottom() + 20);
		this.smfResetScroll(this.divMain.form);
		this.divMain.set_height(this.divMain.form.sta04.getOffsetBottom());
		this.smfResetScroll(this);
	}else{	// PC
		var nMaxWidth = 1200;
		var nFormWidth = this.getOffsetWidth();
		var mLeft = Math.floor((this.getOffsetWidth() - (+this.divMain.form.btnCancel.getOffsetWidth() + this.divMain.form.btnSurveyStart.getOffsetWidth()))/2);
		
		this.divMain.form.btnCancel.set_left(mLeft < 0 ? 0 : mLeft);
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.divMain.form.staTitle01.setOffsetLeft(10+nLeft);
			this.divMain.form.staTitle02.setOffsetLeft(10+nLeft);
			this.divMain.form.staTitle03.setOffsetLeft(10+nLeft);
			this.divMain.form.staTitle04.setOffsetLeft(10+nLeft);
			this.divMain.form.div00.setOffsetLeft(10+nLeft);
			this.divMain.form.staTitle08_1.setOffsetLeft(10+nLeft);
			this.divMain.form.staTitle08_2.setOffsetLeft(10+nLeft);
			this.divMain.form.staTitle11.setOffsetLeft(10+nLeft);
		}else{
			var nLeft = 0;
			this.divMain.form.staTitle01.setOffsetLeft(nLeft);
			this.divMain.form.staTitle02.setOffsetLeft(nLeft);
			this.divMain.form.staTitle03.setOffsetLeft(nLeft);
			this.divMain.form.staTitle04.setOffsetLeft(nLeft);
			this.divMain.form.div00.setOffsetLeft(nLeft);
			this.divMain.form.staTitle08_1.setOffsetLeft(nLeft);
			this.divMain.form.staTitle08_2.setOffsetLeft(nLeft);
			this.divMain.form.staTitle11.setOffsetLeft(nLeft);
		}
		this.divMain.form.resetScroll();
	}
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 설문 참여하기 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.divMain_btnSurveyStart_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var param = {langCd: this.fvLangCd
				,cddcCd: this.cddcCd};
	this.smfSetWorkPage("pa_eds_vff_os::eds_vffos04_m01.xfdl",param,false);
};

/**
 * 취소 버튼 클릭 시
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.divMain_btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var param = {ptptKndCd : "1"};
	this.smfSetWorkPage("frame::eds/frameMap.xfdl",param,false);
};

/**
 * 화면 사이즈 변경시 (Mobile)
 * @param  : obj			- [object]Div
 * @param  : e				- [string]SizeEventInfo
 * @return : N/A
 */
this.divMain_btnSurveyStart_onsize = function(obj:nexacro.Button,e:nexacro.SizeEventInfo)
{
	this.fnSetcompSize();
};

/**
 * 화면 사이즈 변경시 (PC)
 * @param  : obj			- [object]Div
 * @param  : e				- [string]SizeEventInfo
 * @return : N/A
 */
this.eds_vffos03_m01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	if(!this.smfIsMobile()){
		this.fnSetcompSize();
	}
};]]></Script>
  </Form>
</FDL>
