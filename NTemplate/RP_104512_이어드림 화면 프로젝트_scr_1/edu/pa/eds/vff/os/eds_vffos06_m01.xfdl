		}else if(qstnQuitmNo.substr(0, 1) == '7'){
			return "https://cdn.neis.go.kr/sv/" + this.fvLang2[this.fvLangCd-1] + "/01_ele/03_add/추가_문항"+qstnNo+".mp3";
		}else if(qstnQuitmNo.substr(0, 1) == '8'){
			return "https://cdn.neis.go.kr/sv/" + this.fvLang2[this.fvLangCd-1] + "/01_ele/04_back/문"+qstnNo+".mp3";
		}else{
			return "https://cdn.neis.go.kr/sv/" + this.fvLang2[this.fvLangCd-1] + "/01_ele/01_basic/문"+qstnQuitmNo.replace(/-/gi, '-')+".mp3";
		}
	}else if(this.prefixs == '_mid'){
		if(qstnQuitmNo.substr(0, 1) == '5'){
			return "https://cdn.neis.go.kr/sv/" + this.fvLang2[this.fvLangCd-1] + "/02_mid/02_basic-add/응답 결과에 따른 추가 질문_목격경험.mp3";
		}else if(quitmNo == '6'){
			return "https://cdn.neis.go.kr/sv/" + this.fvLang2[this.fvLangCd-1] + "/02_mid/02_basic-add/응답 결과에 따른 추가 질문_피해경험_0"+quitNo1+".mp3";
		}else if(qstnQuitmNo.substr(0, 1) == '7'){
			return "https://cdn.neis.go.kr/sv/" + this.fvLang2[this.fvLangCd-1] + "/02_mid/03_add/추가_문항"+qstnNo+".mp3";
		}else if(qstnQuitmNo.substr(0, 1) == '8'){
			return "https://cdn.neis.go.kr/sv/" + this.fvLang2[this.fvLangCd-1] + "/02_mid/04_back/문"+qstnNo+".mp3";
		}else{
			return "https://cdn.neis.go.kr/sv/" + this.fvLang2[this.fvLangCd-1] + "/02_mid/01_basic/문"+qstnQuitmNo.replace(/-/gi, '-')+".mp3";
		}
	}

}

/**
 * 문항 세팅
 * @param  : N/A
 * @return : N/A
 */
this.fnSetStaQuitm = function(){
	var qstnQuitmNo = this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.fvQuitmNo), 'qstnQuitmNo');
	var qstnQuitmNcn = this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.fvQuitmNo), 'qstnQuitmNcn');
	this.divMain.form.div00.form.staQuitmNo.set_text(qstnQuitmNo);
	this.divMain.form.div00.form.resetScroll();

	this.divMain.form.div00.form.staQuitm.set_text(qstnQuitmNcn);
	if(this.smfIsMobile()){	// 모바일일 때, 문항 Bold
		this.divMain.form.div00.form.staQuitm.set_usedecorate(true);
		this.divMain.form.div00.form.staQuitm.set_text("<b v='true'>"+qstnQuitmNcn+"</b>");
	}

	if(this.smfIsNull(this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.fvQuitmNo), 'atchFileId'))
		&& this.smfIsNull(this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.fvQuitmNo), 'qstnAdiEpl')) ){
		this.divMain.form.div00.form.btnExamQuitm.set_visible(false);
		this.divMain.form.div00.form.btnExamQuitm.set_height(0);
	}else{
		this.divMain.form.div00.form.btnExamQuitm.set_visible(true);
		this.divMain.form.div00.form.btnExamQuitm.set_height(this.smfIsMobile() ? 46 : 26);
		if(this.fvLangCd != 1 && this.smfIsMobile()){	// 한국어 아니면
			this.divMain.form.div00.form.btnExamQuitm.set_width(170);
		}
		if(this.fvLangCd != 1 && !this.smfIsMobile()){	// 한국어 아니면
			this.divMain.form.div00.form.btnExamQuitm.set_width(105);
		}
	}
	
	if(this.dsSearch.getColumn(0, "qstnYr") == '2023' && this.dsSearch.getColumn(0, "qstnDgr") == '1' && qstnQuitmNo == '6 '
	|| this.dsSearch.getColumn(0, "qstnYr") == '2024' && this.dsSearch.getColumn(0, "qstnDgr") == '1' && qstnQuitmNo == '6 '){	// 2023. 1차수 6번 하드코딩 문항
		var val = this.dsRsltList.lookup('quitmNo', '30100', 'rsltVal');
		var chkUnit = this.smfIsNull(val) ? 0 : val.substr(0,this.fvQuitmNo.substr(2,1)).replaceAll(0,'');
		var ChkCnt = this.smfIsNull(val) ? 0 : val.substr(0,8).replaceAll(0,'');
		this.divMain.form.div00.form.staQuitm.set_text(this.smfIsMobile() ? ("<b v='true'>" +qstnQuitmNcn + "(" + chkUnit.length + "/" + ChkCnt.length +")" + "</b>") : (qstnQuitmNcn + "(" + chkUnit.length + "/" + ChkCnt.length +")"));
	}
};

/**
 * 체크 및 기타 부분 설정
 * @param  : N/A
 * @return : N/A
 */
this.fnSetRslt = function(){
	var rsltVal = (this.dsRsltList.getColumn(this.dsRsltList.findRow('quitmNo', this.fvQuitmNo), 'rsltVal')).split('');
	var sbjctRsltVal = (this.dsRsltList.getColumn(this.dsRsltList.findRow('quitmNo', this.fvQuitmNo), 'sbjctRsltVal')).replace(']', '').split('[');
	var insChcTypCdVal = +this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.fvQuitmNo), 'insChcTypCd');
	
	if(insChcTypCdVal == '1'){	// 단건
		for(var i = 0; i < this.fvRdoIns.length; i++){
			if(rsltVal[(i)] == "1"){
				this.fvRdoIns[i].set_value(1);
				if(sbjctRsltVal.length != 0){
					this.fvEdtRslt[i].set_value(sbjctRsltVal[1]);
				}
			}
		}
	}else{
		for(var i = 0; i < this.fvChkIns.length; i++){
			if(rsltVal[(i)] == "1"){
				this.fvChkIns[i].set_value(true);
				if(sbjctRsltVal.length != 0){
					this.fvEdtRslt[i].set_value(sbjctRsltVal[1]);
				}
			}
		}
	}
};

/**
 * 컴포넌트 사이즈 조절
 * @param  : N/A
 * @return : N/A
 */
this.fnSetcompSize = function(){
	this.fnSetPrg();
	if (this.smfIsMobile()){	// 모바일 화면 제어
		var cssNm = this.fvLangCd == 1 ? "sta_WF_Txt30M" : "sta_WF_Txt30_M";
		var insCntM = 1;
	
		// 문항 keep-all
		if (document.getElementsByClassName("Static " + cssNm).item(0).children.item(0).id.indexOf("staQuitm:text") > -1){
			this.smfResetScroll(this.divMain.form.div00.form.divIns.form);
			([3, 4].indexOf(this.fvLangCd) > -1) ? document.getElementsByClassName("Static " + cssNm).item(0).children.item(0).style.wordBreak = "break-all" : document.getElementsByClassName("Static " + cssNm).item(0).children.item(0).style.wordBreak = "keep-all";
			document.getElementsByClassName("Static " + cssNm).item(0).style.height = "auto";
			var quitmText = document.getElementsByClassName("Static " + cssNm).item(0).children.item(0);
			var offsetH = document.getElementsByClassName("Static " + cssNm).item(0).children.item(0).children;
			var offsetHv = offsetH[0].offsetHeight;
			quitmText.style.height = offsetH[0].offsetHeight + "px";	
		}
		
		// 러시아어만 모바일에서 break-all (문항)
		if(this.dsSearch.getColumn(0, "qstnYr") == '2024' && this.dsSearch.getColumn(0, "qstnDgr") == '2' && this.fvLangCd == 7){
			document.getElementsByClassName("Static sta_WF_Txt30_M").item(0).children.item(0).style.wordBreak = "break-all";	
		}
		
		// 보기 keep-all
		for(var i in document.getElementsByClassName("Static")){
		
			if (this.smfIsNull(document.getElementsByClassName("Static")[i].children)
				|| this.smfIsNull(document.getElementsByClassName("Static")[i].children.item(0))) continue;
			if (document.getElementsByClassName("Static")[i].children.item(0).id.indexOf("staIns"+insCntM+":text") > -1){
				([3, 4].indexOf(this.fvLangCd) > -1) ? document.getElementsByClassName("Static")[i].children.item(0).style.wordBreak = "break-all" : document.getElementsByClassName("Static")[i].children.item(0).style.wordBreak = "keep-all";
				// 러시아어만 모바일에서 break-all (보기)
				if(this.dsSearch.getColumn(0, "qstnYr") == '2024' && this.dsSearch.getColumn(0, "qstnDgr") == '2' && this.fvLangCd == 7){
					document.getElementsByClassName("Static")[i].children.item(0).style.wordBreak = "break-all";
				}
				document.getElementsByClassName("Static")[i].style.height = "auto";
				
				for(var j=1; j<=this.dsCurrentInsList.rowcount; j++){
					this.smfResetScroll(this.divMain.form.div00.form.divIns.form["staIns"+j].form);
				}
				insCntM++;
			}
		}
	}else{	// PC 화면 제어
		var docSurvey;
		for(var i =0; i < document.getElementsByClassName("Static sta_WF_Txt22B").length; i++){
			if(document.getElementsByClassName("Static sta_WF_Txt22B").item(i).id.indexOf("div00.form.staQuitm") > -1){
				docSurvey = i;
			}
		}
		// 문항 keep-all
		document.getElementsByClassName("Static sta_WF_Txt22B").item(docSurvey).children.item(0).style.wordBreak = "keep-all";
		this.smfResetScroll(this.divMain.form.div00.form.divIns.form);
		document.getElementsByClassName("Static sta_WF_Txt22B").item(docSurvey).style.height = "auto";
		
		var insCnt = 1;
		var hVal = +this.divMain.form.div00.form.staQuitm._adjust_height + 3;
		
		// 보기 keep-all
		for(var i in document.getElementsByClassName("Static")){
			if (this.smfIsNull(document.getElementsByClassName("Static")[i].children)
				|| this.smfIsNull(document.getElementsByClassName("Static")[i].children.item(0))) continue;
			// 다국어 시 [문항] 잘림 방지 height px늘려줌
			if (document.getElementsByClassName("Static")[i].children.item(0).id.indexOf("staQuitm:text") > -1){
				document.getElementsByClassName("Static")[i].style.height = hVal + "px";
				document.getElementsByClassName("Static")[i].children.item(0).style.height = hVal + "px";
			}
			
			if (document.getElementsByClassName("Static")[i].children.item(0).id.indexOf("staIns"+insCnt+":text") > -1){
				document.getElementsByClassName("Static")[i].children.item(0).style.wordBreak = "keep-all";
				insCnt++;				
			}
			if (this.divMain.form.div00.form.sta03.getOffsetBottom() < this.divMain.form.div00.form.divIns.getOffsetBottom()){
				this.divMain.form.div00.set_height(this.divMain.form.div00.form.divIns.getOffsetBottom() + 30);
			}else{
				this.divMain.form.div00.set_height(this.divMain.form.div00.form.sta03.height);
			}
			this.smfResetScroll(this.divMain.form);	
		}	// --for문 end
		// 영어 화면결함 하드코딩 수정
		var insChcTypCdVal = +this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.fvQuitmNo), 'insChcTypCd');
		if(insChcTypCdVal == '1'){
			if(this.dsSearch.getColumn(0, "qstnYr") == '2024' && this.dsSearch.getColumn(0, "qstnDgr") == '2' && this.fvLangCd == 2 && this.fvQuitmNo == '40700'){
				document.getElementsByClassName("Static")[42].children.item(0).style.wordBreak = "break-all";
				document.getElementsByClassName("Static")[42].children.item(0).style.height = 29 + "px";
				document.getElementsByClassName("Static")[42].children.item(0).style.width = 950 + "px";
				document.getElementsByClassName("Static")[42].style.height = 30 + "px";
				this.divMain.form.div00.form.divIns.form.staIns3.set_top(80);
				this.divMain.form.div00.form.divIns.form.rdoIns3.set_top(80);
				this.divMain.form.div00.form.divIns.form.staIns4.set_top(120);
				this.divMain.form.div00.form.divIns.form.rdoIns4.set_top(120);
				this.divMain.form.div00.form.divIns.form.staIns5.set_top(160);
				this.divMain.form.div00.form.divIns.form.rdoIns5.set_top(160);
				this.divMain.form.div00.form.divIns.form.staIns6.set_top(200);
				this.divMain.form.div00.form.divIns.form.rdoIns6.set_top(200);
				this.divMain.form.div00.form.divIns.form.staIns7.set_top(240);
				this.divMain.form.div00.form.divIns.form.rdoIns7.set_top(240);
				this.divMain.form.div00.form.divIns.form.staIns8.set_top(280);
				this.divMain.form.div00.form.divIns.form.rdoIns8.set_top(280);
				this.divMain.form.div00.form.divIns.form.edtRslt8.set_top(280);
			}
		}
	}
	
	this.divMain.set_height(this.divMain.form.sta03.getOffsetBottom());
	this.smfResetScroll(this);
};

/**
 * 컴포넌트 사이즈 조절(PC)
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnSetcompSizeP = function(){
	if (!this.smfIsMobile()){
		var nMaxWidth = 1200;
		var nFormWidth = this.getOffsetWidth();
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.divMain.form.sta00.setOffsetLeft(10 + nLeft);
			this.divMain.form.staCommonTitle05.setOffsetLeft(38 + nLeft);
			this.divMain.form.div00.setOffsetLeft(10 + nLeft);
		}else{
			var nLeft = 0;
			this.divMain.form.sta00.setOffsetLeft(nLeft);
			this.divMain.form.staCommonTitle05.setOffsetLeft(28);
			this.divMain.form.div00.setOffsetLeft(nLeft);
		}
		this.divMain.form.resetScroll();
	}
};

/**
 * 문항 입력 값 저장 세팅
 * @param  : N/A
 * @return : N/A
 */
this.fnSetRsltList = function(){
	var cnt = this.fnChkCnt(); // 문항선택확인
	if(cnt == 0 && this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.fvQuitmNo), 'qstnQuitmScCd') != "S"){
		this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle05')]);
		return false;
	}
	
	var rowIndex = new Array();
	var rsltVal = '';
	var sbjctRsltVal = '';
	var sbjctRsltYn = true;

	for(var i = 0; i < this.dsCurrentInsList.getRowCount(); i++){
		if(this.fvChkIns[i].value || this.fvRdoIns[i].value == 1){
			rowIndex.push(i);
			rsltVal += '1';
		}else{
			rsltVal += '0';
		}
		
		if(this.dsCurrentInsList.getColumn(i, 'sbjctInsYn') == 'Y'){
			if(this.isNil(this.fvEdtRslt[i].value)){
				if(this.fvChkIns[i].value || this.fvRdoIns[i].value == 1){
					sbjctRsltYn = false;
				}
			}else{
				sbjctRsltVal = this.fvChkIns[i].value || this.fvRdoIns[i].value == 1 ? '[' + this.fvEdtRslt[i].value + ']' : '';
			}
		}
	}

	if(!sbjctRsltYn){
		this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle02_0')]);
		return false;
	}
	
	var rowData = {
		'quitmSn' : this.fvQuitmSn
		,'quitmNo' : this.fvQuitmNo
		,'rsltVal' : rsltVal
		,'sbjctRsltVal' : sbjctRsltVal
		,'quitmRelmCd' : this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.fvQuitmNo), 'quitmRelmCd')
	};
	
	// 같은 문항의 번호가 중복되어 들어가면 안됨
	if (!this.smfIsNull(this.dsRsltList.lookup('quitmNo', this.fvQuitmNo, 'quitmNo'))){
		this.dsRsltList.deleteRow(this.dsRsltList.findRow('quitmNo', this.fvQuitmNo));
	}
	
	var row = this.dsRsltList.addRow();
	
	for(var i = 0; i < this.dsRsltList.getColCount(); i++){
		this.dsRsltList.setColumn(row, this.dsRsltList.getColID(i), rowData[this.dsRsltList.getColID(i)]);
	}
	return rowIndex[0];
};

/**
 * 제출하기 유무
 * @param  : N/A
 * @return : true/false
 */
this.fnIsSbmsn = function(){
	/* 표본
	if (this.dsSearch.getColumn(0, 'qstnDgr') == 2){
		return true;
	}
	*/
	return false;
};

/**
 * 문항선택 확인
 * @param  : N/A
 * @return : cnt
 */
this.fnChkCnt = function(){
	var cnt = 0;
	var insChcTypCdVal = +this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.fvQuitmNo), 'insChcTypCd');
	
	if (insChcTypCdVal == '1'){ // 단건
		for(var i = 0; i < this.fvRdoIns.length; i++){
			if(this.fvRdoIns[i].value == 1){
				cnt++;
			}
		}
	}else{ // 다건
		for(var i = 0; i < this.fvChkIns.length; i++){
			if(this.fvChkIns[i].value){
				cnt++;
			}
		}
	}
	return cnt;
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 체크박스 클릭 시
 * @param  : obj		   - [object]CheckBox
 * @param  : e		       - [string]CheckBoxChangedEventInfo
 * @isChk  : e		       - 설문 보기를 클릭 시의 값 true
 * @subObj  : e		       - 설문 보기를 클릭 시의 해당 체크박스 객체
 * @return : N/A
 */
this.CheckBox_onchanged = function(obj:nexacro.CheckBox,e:nexacro.CheckBoxChangedEventInfo, isChk, subObj)
{
	var objChk = this.isNotNil(e) ? obj : subObj;
	//if (this.isNotNil(e) ? e.postvalue : isChk){
// 		var insChcTypCdVal = +this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmSn', this.fvQuitmSn), 'insChcTypCd');
// 		if (insChcTypCdVal != '1'){ // 다건
			if(this.isNil(e)){ // 스태틱 클릭
				this.fvChkIns[objChk.id.substr(6)-1].set_value(this.fvChkIns[objChk.id.substr(6)-1].value == false ? true : false);
				this.fvChkIns[objChk.id.substr(6)-1].setFocus(this.fvChkIns[objChk.id.substr(6)-1].value == false ? true : false);
			}
			var cnt = 0;
			var numN = 0;
			var insChkVal = this.dsCurrentInsList.getColumn(objChk.id.substr(6)-1, 'insChkVal');
			
			for(var i = 0; i < this.fvChkIns.length; i++){
				if(this.fvChkIns[i].value){
					cnt++;
					// 2023. 1차수 하드코딩 문항
					if(this.dsSearch.getColumn(0, "qstnYr") == '2023' && this.dsSearch.getColumn(0, "qstnDgr") == '1' && this.fvQuitmNo == '30100' && i < 8){
						numN++;
					}
				}
				
				if (this.fvChkIns[i].value && this.dsCurrentInsList.getColumn(i, 'insChkVal') != insChkVal){
					this.fvChkIns[i].set_value(false);
					cnt = 0;
				}
			}

			// 2024. 2차수 하드코딩 문항
			if(this.dsSearch.getColumn(0, "qstnYr") == '2024' && this.dsSearch.getColumn(0, "qstnDgr") == '2' && this.fvQuitmNo == '20401'
				|| this.dsSearch.getColumn(0, "qstnYr") == '2024' && this.dsSearch.getColumn(0, "qstnDgr") == '2' && this.fvQuitmNo == '20500') {
				if(objChk.id.substr(6) == 9){
					for(var i = 0; i < this.dsCurrentInsList.getRowCount()-1; i++){
						this.fvChkIns[i].set_value(false);
						cnt = 0;
					}
				}else{
					this.fvChkIns[8].set_value(false);
				}			
			}
			
			// 2024. 2차수 하드코딩 문항 (외국어)
			if(this.fvLangCd != 1){
				if(this.dsSearch.getColumn(0, "qstnYr") == '2024' && this.dsSearch.getColumn(0, "qstnDgr") == '2' && this.fvQuitmNo == '20400'
					|| this.dsSearch.getColumn(0, "qstnYr") == '2024' && this.dsSearch.getColumn(0, "qstnDgr") == '2' && this.fvQuitmNo == '20401'
					|| this.dsSearch.getColumn(0, "qstnYr") == '2024' && this.dsSearch.getColumn(0, "qstnDgr") == '2' && this.fvQuitmNo == '20500'
					|| this.dsSearch.getColumn(0, "qstnYr") == '2024' && this.dsSearch.getColumn(0, "qstnDgr") == '1' && this.fvQuitmNo == '30600') {
					
					if(objChk.id.substr(6) == 9){
						for(var i = 0; i < this.dsCurrentInsList.getRowCount()-1; i++){
							this.fvChkIns[i].set_value(false);
							cnt = 0;
						}
					}else{
						this.fvChkIns[8].set_value(false);
					}			
				}
			}
			
			var maxInsChcCnt = this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.fvQuitmNo), 'maxInsChcCnt');
			if(cnt > maxInsChcCnt){
				this.fvChkIns[objChk.id.substr(6)-1].set_value(false);
				this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'maxInsChcCnt' + maxInsChcCnt)]);
			}
			
			// edit창 활성화
			if (this.fvChkIns[objChk.id.substr(6)-1].value == true && this.dsCurrentInsList.getColumn(objChk.id.substr(6)-1, 'sbjctInsYn') == 'Y'){
				this.fvEdtRslt[objChk.id.substr(6)-1].set_enable(true);	// edit창 활성화
				this.fvEdtRslt[objChk.id.substr(6)-1].setFocus();
			}else if(this.fvChkIns[objChk.id.substr(6)-1].value == false){
				this.fvEdtRslt[objChk.id.substr(6)-1].set_enable(false);	// edit창 비활성화
				this.fvEdtRslt[objChk.id.substr(6)-1].set_value(null);
			}
		//}
	//}
};

/**
 * 설문 보기 클릭 시
 * @param  : obj		   - [object]Static
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.Static_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	var insChcTypCdVal = +this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.fvQuitmNo), 'insChcTypCd');
	if (insChcTypCdVal == '1'){	//(단건)
		this.Radio_onitemchanged(null, null, true, this.fvRdoIns[obj.name.substr(6)-1]);
	}else{
		this.CheckBox_onchanged(null, null, true, this.fvChkIns[obj.name.substr(6)-1]);
	}
};

/**
 * 라디오 클릭 시
 * @param  : obj		   - [object]Radio
 * @param  : e		       - [string]ItemChangeEventInfo
 * @isChk  : e		       - 설문 보기를 클릭 시의 값 true
 * @subObj  : e		       - 설문 보기를 클릭 시의 해당 체크박스 객체
 * @return : N/A
 */
this.Radio_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo, isChk, subObj)
{
	var objChk = this.isNotNil(e) ? obj : subObj;
	for(var i = 0; i < this.fvRdoIns.length; i++){
		this.fvRdoIns[i].set_value(this.fvRdoIns[i].name != objChk.name ? null : 1);
		this.fvRdoIns[objChk.id.substr(6)-1].setFocus(this.fvRdoIns[objChk.id.substr(6)-1].value == false ? true : false);
		
		this.fvEdtRslt[i].set_enable(this.fvRdoIns[i].value && this.dsCurrentInsList.getColumn(i, 'sbjctInsYn') == 'Y' ? true : false);	// edit창 활성화
		this.fvRdoIns[i].focus ? this.fvEdtRslt[i].setFocus() : this.fvEdtRslt[i].set_value(null);
	}
};

/**
 * 이전문항 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.divMain_btnTitle02_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divTop.form.fnEventTTS(); // TTS 중단
	this.fnPrevQuitmQtr(); // 문항번호 세팅
	this.fnSetStaQuitm(); // 문항문구 세팅
	this.dsInsList.filter('quitmNo ==' + this.fvQuitmNo);
	this.dsCurrentInsList.copyData(this.dsInsList, true);
	this.fnSetIns(); // 보기 세팅
	this.fnSetRslt(); // 저장된 값 체크 세팅
	this.dsRsltList.deleteRow(this.dsRsltList.getRowCount() - 1);
	this.fnAutoSound();
	this.divMain.form.div00.setFocus();
};

/**
 * 다음문항 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.divMain_btnTitle01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divTop.form.fnEventTTS(); // TTS 중단
	
	// 첫 문항이면 dsRsltList 첫행 지우기
	if (this.fvQuitmNo == this.dsQuitmList.getColumn(0, 'quitmNo')){
		this.dsRsltList.deleteRow(0);
	}
	
	var rowIndexVal = this.fnSetRsltList();
	if (typeof rowIndexVal == 'boolean' && rowIndexVal == false){
		return false;
	}
	
	// 다음단계
	if (this.fvQuitmNo == this.dsQuitmList.getColumn(this.dsQuitmList.getRowCount() - 1, 'quitmNo')){
		if (this.fnIsSbmsn()){
		/* 어울림앱 추가로 인해 주석
			if(this.dsSearch.getColumn(0, "qstnDgr") == '2'){	// 설문 2차수 일 때
				this.smfConfirmEds([this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle08_1')], this.fnQstnSaveCallback, null);
			}else{	// 설문 1차수
				this.smfConfirmEds([this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle08_1') + '\n' + this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle08_2')], this.fnQstnSaveCallback, null);
			}
		*/
			this.smfConfirmEds([this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle08_1') + '\n' + this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle08_2')], this.fnQstnSaveCallback, null);
		}else{	// 제출하기
			this.fnDsTrnRltListSet();
			
			var param = {langCd: this.fvLangCd,
				 dataset: this.dsSearch.saveXML(),
				 dataset2: this.dsTrnRltList.saveXML(),
				 };
			/* 어울림앱 추가로 인해 주석
			if(this.dsSearch.getColumn(0, "qstnDgr") == '2'){	// 설문 2차수
				this.smfSetWorkPage("pa_eds_vff_os::eds_vffos08_m02.xfdl",param,false);
				return;
			}else{	// 설문 1차수
				this.smfSetWorkPage("pa_eds_vff_os::eds_vffos07_m01.xfdl",param,false);
				return;
			}
			*/
			
			this.smfSetWorkPage("pa_eds_vff_os::eds_vffos07_m01.xfdl",param,false);
			return;
		}
	}
	
	// 2024. 2차수 하드코딩 문항
	if(this.dsSearch.getColumn(0, "qstnYr") == '2024' && this.dsSearch.getColumn(0, "qstnDgr") == '2' && this.fvQuitmNo == '20100' && this.fvChkIns[5].value == true){
		this.fnNextQuitmQtr(this.dsCurrentInsList.getColumn(5, 'insSn')); // 문항번호 세팅
	}else{
		this.fnNextQuitmQtr(this.dsCurrentInsList.getColumn(rowIndexVal, 'insSn')); // 문항번호 세팅
	}

	this.fnSetStaQuitm(); // 문항문구 세팅
	
	this.dsInsList.filter('quitmNo ==' + this.fvQuitmNo);
	this.dsCurrentInsList.copyData(this.dsInsList, true);
	
	this.fnSetIns();
	this.fnAutoSound();
	this.divMain.form.div00.setFocus();
};

/**
 * 임시저장 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.divMain_btnTitle13_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	if(this.fnChkCnt() == 0){
		this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle05')]);
		return false;
	}
	
	this.smfConfirmEds([this.dsLang.getColumn(this.fvLangCd - 1, 'rsltanswer05')], this.fnQstnCallback, null);
};

/**
 * 예시보기 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.Button_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var imgAtchFileValue = obj.id == 'btnExamQuitm' ? this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.fvQuitmNo), 'imgData') : this.dsCurrentInsList.getColumn(obj.id.replace('btnExamIns', '') - 1, 'imgData');
	var staQstnAdiEplValue = obj.id == 'btnExamQuitm' ? this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.fvQuitmNo), 'qstnAdiEpl') : this.dsCurrentInsList.getColumn(obj.id.replace('btnExamIns', '') - 1, 'qstnAdiEpl');
	
		var popupParams = {
		callback: this.fnPopupCallback,
		sender: obj, // sender 지정
		params: {
			procType : 'search'
			,imgAtchFileValue: imgAtchFileValue
			,staQstnAdiEplValue: staQstnAdiEplValue
		},
		titlebar : false,
	};
	
	this.smfDialog("_auto", "pa_eds_vff_os::eds_vffos06_p01.xfdl", popupParams, null, null, this.smfIsMobile() ? 540 : null, this.smfIsMobile() ? 764 : null);
};

/**
 * 화면 사이즈 변경시
 * @param  : obj			- [object]Div
 * @param  : e				- [string]SizeEventInfo
 * @return : N/A
 */
this.divMain_staCommonTitle06_onsize = function(obj:nexacro.Static,e:nexacro.SizeEventInfo)
{
	this.fnSetcompSize();
};

/**
 * 마우스 왼쪽버튼 눌렀을 시
 * @param  : obj			- [object]Static
 * @param  : e				- [string]MouseEventInfo
 * @return : N/A
 */
this.divMain_div00_div01_staPrg_onlbuttondown = function(obj:nexacro.Static,e:nexacro.MouseEventInfo)
{
	this.fvIsBtnDrag = true;
};

/**
 * 마우스 왼쪽버튼 떼었을 시
 * @param  : obj			- [object]Static
 * @param  : e				- [string]MouseEventInfo
 * @return : N/A
 */
this.divMain_div00_div01_staPrg_onlbuttonup = function(obj:nexacro.Static,e:nexacro.MouseEventInfo)
{
	this.fvIsBtnDrag = false;
};

/**
 * 마우스 포인터가 움직일 시
 * @param  : obj			- [object]Div
 * @param  : e				- [string]MouseEventInfo
 * @return : N/A
 */
this.divMain_div00_div01_onmousemove = function(obj:nexacro.Div,e:nexacro.MouseEventInfo)
{
	if (this.fvIsBtnDrag){
		this.fvOpacityVal = Math.floor((e.canvasx < 0 ? 0 : e.canvasx) * 100 / obj.getOffsetWidth());
		this.fnSetSurvOpacity(this.fvOpacityVal);
	}
};

/**
 * 투명도바 클릭 시
 * @param  : obj		   - [object]ProgressBar
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.divMain_div00_div01_pgb00_onclick = function(obj:nexacro.ProgressBar,e:nexacro.ClickEventInfo)
{
	var posValue = Math.floor(e.clientx/30) * 10;
	this.fvOpacityVal = posValue;
	this.fnSetSurvOpacity(posValue);
};

/**
 * PC 폼사이즈 변경 시
 * @param  : obj		   - [object]ProgressBar
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.eds_vffos06_m01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	if(!this.smfIsMobile()){
		this.fnSetcompSizeP();
	}
};
]]></Script>
  </Form>
</FDL>
