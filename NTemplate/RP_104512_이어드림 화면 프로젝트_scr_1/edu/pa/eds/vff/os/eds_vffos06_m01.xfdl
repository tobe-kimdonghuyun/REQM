            <Col id="alertCommonTitle03">ระบบการเชื่อมต่อขัดข้อง กรุณารอสักครู่เพื่อเข้าใช้งานใหม่</Col>
            <Col id="alertCommonTitle05">เคยทำแบบสอบถามแล้ว</Col>
            <Col id="alertCommonTitle06">ไม่ใช่เลขกำหนดตัวผู้ใช้ที่ออกให้ค่ะ</Col>
            <Col id="alertCommonTitle07">ไม่พบข้อมูลที่เชื่อมโยงได้</Col>
            <Col id="alertCommonTitle08">จำนวนผู้ทำแบบสอบถามเกินกำหนด</Col>
            <Col id="alertCommonTitle09">สอบถามเกี่ยวกับการสำรวจสภาวะความรุนแรงในโรงเรียนจากครูผู้รับผิดชอบ</Col>
            <Col id="commonTitle01">สำรวจสถานภาพจริงของการใช้ความรุนแรงในโรงเรียน ปี +qstrYr;</Col>
            <Col id="commonTitle02">ปุ่มเปิดปิดเสียง</Col>
            <Col id="commonTitle03">สถานะปิดเสียง</Col>
            <Col id="commonTitle04">สถานะเปิดเสียง</Col>
            <Col id="commonTitle05">&lt;fs v='9'&gt;STEP 01&lt;/fs&gt; การอบรมการป้องกันความรุนแรงในโรงเรียน</Col>
            <Col id="commonTitle06">&lt;fs v='9'&gt;STEP 02&lt;/fs&gt; ทำแบบสอบถามความรุนแรงในโรงเรียน</Col>
            <Col id="commonTitle07">&lt;fs v='9'&gt;STEP 03&lt;/fs&gt; เกี่ยวกับการป้องกันและการแจ้งความรุนแรงในโรงเรียน</Col>
            <Col id="commonTitle09">&lt;br&gt;&lt;center&gt;&amp;lt;การใช้ความรุนแรงในโรงเรียน&amp;gt;&lt;/center&gt;&lt;br&gt;คือการกระทำที่ทำให้เพื่อนร่วมโรงเรียนทุกข์ใจอยู่บ่อยครั้งทั้งภายในโรงเรียนและนอกโรงเรียนจากการกระทำต่อไปนี้&lt;br&gt;&lt;b&gt;ด่าว่าล้อเลียนหรือแกล้งให้กลัว, ขู่บังคับ, รีดไถเงินหรือสิ่งของ, ทำร้ายร่างกายหรือกักขังเพื่อน, บังคับขู่เข็ญทางเพศ, กระทำชำเราทางเพศ, ด่าว่าหรือทำให้ทุกข์ใจในระบบออนไลน์ (อินเตอร์เน็ต, สมาร์ทโฟน), กลั่นแกล้งหรือล้อเลียนอยู่ตลอดเวลา, รังแกหรือกลั่นแกล้งอยู่บ่อยครั้ง เป็นต้น&lt;/b&gt;</Col>
            <Col id="commonTitle10">&lt;br&gt;&lt;center&gt;&amp;lt;การใช้ความรุนแรงในโรงเรียน&amp;gt;&lt;/center&gt;&lt;br&gt;คือการกระทำที่ทำให้เพื่อนร่วมโรงเรียนทุกข์ใจอยู่บ่อยครั้งทั้งภายในโรงเรียนและนอกโรงเรียนจากการกระทำต่อไปนี้&lt;br&gt;&lt;b&gt;ด่าว่าล้อเลียนหรือแกล้งให้กลัว, ขู่บังคับ, รีดไถเงินหรือสิ่งของ, ทำร้ายร่างกายหรือกักขังเพื่อน, บังคับขู่เข็ญทางเพศ, กระทำชำเราทางเพศ, ด่าว่าหรือทำให้ทุกข์ใจในระบบออนไลน์ (อินเตอร์เน็ต, สมาร์ทโฟน), กลั่นแกล้งหรือล้อเลียนอยู่ตลอดเวลา, รังแกหรือกลั่นแกล้งอยู่บ่อยครั้ง เป็นต้น&lt;/b&gt;</Col>
            <Col id="commonTitle11">&lt;br&gt;&lt;center&gt;&amp;lt;การใช้ความรุนแรงในโรงเรียน&amp;gt;&lt;/center&gt;&lt;br&gt;คือการกระทำที่ทำให้เพื่อนร่วมโรงเรียนทุกข์ใจอยู่บ่อยครั้งทั้งภายในโรงเรียนและนอกโรงเรียนจากการกระทำต่อไปนี้&lt;br&gt;&lt;b&gt;ด่าว่าล้อเลียนหรือแกล้งให้กลัว, ขู่บังคับ, รีดไถเงินหรือสิ่งของ, ทำร้ายร่างกายหรือกักขังเพื่อน, บังคับขู่เข็ญทางเพศ, กระทำชำเราทางเพศ, ด่าว่าหรือทำให้ทุกข์ใจในระบบออนไลน์ (อินเตอร์เน็ต, สมาร์ทโฟน), กลั่นแกล้งหรือล้อเลียนอยู่ตลอดเวลา, รังแกหรือกลั่นแกล้งอยู่บ่อยครั้ง เป็นต้น&lt;/b&gt;</Col>
            <Col id="commonTitle05m">การอบรมการป้องกันความรุนแรงในโรงเรียน</Col>
            <Col id="commonTitle06m">ทำแบบสอบถามความรุนแรงในโรงเรียน</Col>
            <Col id="commonTitle07m">เกี่ยวกับการป้องกันและการแจ้งความรุนแรงในโรงเรียน</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 학교폭력실태조사 > 학교폭력(설문참여_객관식 체크박스)
*  @FileName 	eds_vffos06_m01.xfdl 
*  @Creator 	김민성
*  @CreateDate 	2022.11.15
*  @Desction    학교폭력(설문참여_객관식 체크박스)
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.11.15            김민성                   최초 생성
*******************************************************************************
*/
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvLangCd;
this.fvQuitmVoice = 'QuitmVoiceW';
this.fvQuitmSn = 0;
this.fvQuitmNo = 0;
this.fvLang = ['ko', 'en', 'zh', 'ja', 'vi', 'tl', 'ru', 'th'];
this.fvLang2 = ['kor', 'eng', 'chn', 'jpn', 'vin', 'phi', 'rus', 'tha'];
this.fvRdoIns = new Array();
this.fvChkIns = new Array();
this.fvStaIns = new Array();
this.fvEdtRslt = new Array();
this.fvBtnExamIns = new Array();
this.fvIsBtnDrag = false;
this.fvOpacityVal = 0;
this.prefixs;
this.mdfcnNts;
this.ttsBtn = false;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	// 필수
	this.smfResetScroll(this);
	this.pv_params = this.smfGetFormParams();
	this.dsSearch.loadXML(this.pv_params.dataset);
	if (this.isNotNil(this.pv_params.dataset2)){
		this.dsTrnRltList.loadXML(this.pv_params.dataset2);
	}
	this.fvLangCd = this.pv_params.langCd;
	this.prefixs = this.pv_params.prefixs;
	this.mdfcnNts = this.pv_params.mdfcnNts;
	this.divTop.form.fnSetTopFrameBtnVisible(false, false, true);
	this.divTop.form.fnSetTopFrameBtnHomeVisible(false);

	// PC 화면 정렬
	this.fnSetcompSizeP();
	
	// 외국어 일때 이전문항, 다음문항 화살표 제거
	if (this.fvLangCd != 1){
		this.divMain.form.btnTitle02.set_cssclass('btn_WF_SurveyPreNo');
		this.divMain.form.btnTitle01.set_cssclass('btn_WF_SurveyNextNo');
	}
	
	this.dsSearch.setColumn(0, 'qsdTypCd', '001'); // 설문지유형코드
	this.dsSearch.setColumn(0, 'qstnQuitmScCd', 'O'); // 설문문항구분코드
	this.fvOpacityVal = this.dsSearch.getColumn(0, 'posValue') || 0; // 투명도값
	
	// 보기문항(divIns)에 있는 chk, sta, edt, btn, rdo 리스트 형식으로 각각 저장
	var divInsCompList = this.svcfSortByTabOrder(this.divMain.form.div00.form.divIns);
	for(var i = 0; i < divInsCompList.length; i++){
		if (divInsCompList[i] instanceof nexacro.CheckBox) this.fvChkIns.push(divInsCompList[i]);
		if (divInsCompList[i] instanceof nexacro.Static) this.fvStaIns.push(divInsCompList[i]);
		if (divInsCompList[i] instanceof nexacro.Edit) this.fvEdtRslt.push(divInsCompList[i]);
		if (divInsCompList[i] instanceof nexacro.Button) this.fvBtnExamIns.push(divInsCompList[i]);
		if (divInsCompList[i] instanceof nexacro.Radio) this.fvRdoIns.push(divInsCompList[i]);
	}
	this.fnSelectLang(this.fvLangCd);
	
	var pvShlKndScCd = this.dsSearch.getColumn(0, 'shlKndScCd');
	var pvShlCrseScCd = this.dsSearch.getColumn(0, 'shlCrseScCd');
	var prefix = 2;
	
	// 투명도는 특수학교05, 각종학교26 이면 안보임
	if (pvShlKndScCd == '05' || pvShlKndScCd == '26'){
		this.divMain.form.div00.form.staTitle12.set_visible(false);
		this.divMain.form.div00.form.div01.set_visible(false);
	}
	
	// 나이스 미사용학교는 임시저장 버튼 안보임
	if (this.dsSearch.getColumn(0, 'neisUseYn') == 'N'){
		this.divMain.form.btnTitle13.set_visible(false);
	}
	
	if(pvShlKndScCd == '05' || pvShlKndScCd == '26'){
		if(pvShlCrseScCd == '2'){
			prefix = 1; // 특수초등
		}
	}else if (this.isNotNil(pvShlKndScCd) && (pvShlKndScCd == '02' || pvShlKndScCd == '06' || pvShlKndScCd == '14' || pvShlKndScCd == '19' || pvShlKndScCd == '20')) {
		prefix = 1; // 일반초등
	}
	
	if (this.fvLangCd == 1){
		this.fvQuitmVoice = prefix == 2 ? 'quitmVoiceW' : 'quitmVoiceM';
	}else{
		this.fvQuitmVoice = prefix == 2 ? 'quitmVoiceEtcW' : 'quitmVoiceEtcM';
	}
	
	if(this.smfIsMobile() && this.fvLangCd != 1){	// 한국어가 아닐 때
		this.divMain.form.div00.form.staQuitm.set_cssclass("sta_WF_Txt30_M");
	}
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 팝업의 콜백함수
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
	var param = {langCd: this.fvLangCd,
	 dataset: this.dsSearch.saveXML(),
	 };

	if(this.dsSearch.getColumn(0, "qstnDgr") == '2'){	// 2차수
		this.smfSetWorkPage("pa_eds_vff_os::eds_vffos08_m02.xfdl",param,false);
	}else{	// 1차수
		this.smfSetWorkPage("pa_eds_vff_os::eds_vffos08_m01.xfdl",param,false);
	}
};

/**
 * 설문응답 임시저장 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnQstnCallback = function(){
	if (!arguments[0].confirmResult){
		return;
	}
	
	var rowIndexVal = this.fnSetRsltList();
	if (typeof rowIndexVal == 'boolean' && rowIndexVal == false){
		return false;
	}
	
	this.fnDsTrnRltListSet();
	this.dsTrnRltList.setColumn(0, 'tmprStrgYn', 'Y');
	this.dsTrnRltList.setColumn(0, 'sbmsnYn', 'N');
	this.dsTrnRltList.setColumn(0, 'rspnsErrYn', 'N');
	this.dsTrnRltList.setColumn(0, 'invlPemRlsYn', 'N');
	this.fnSaveSurvey();
};

/**
 * 설문응답 제출하기 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnQstnSaveCallback = function(){
	if (!arguments[0].confirmResult){
		return;
	}
	this.fnDsTrnRltListSet();
	for(var i = 0; i < 6; i++){
		this.dsTrnRltList.setColumn(0, 'dscrpQuitm' + (i + 1) + 'RspnsValue', null);
	}
	this.dsTrnRltList.setColumn(0, 'tmprStrgYn', 'N');
	this.dsTrnRltList.setColumn(0, 'sbmsnYn', 'Y');
	this.dsTrnRltList.setColumn(0, 'rspnsErrYn', 'N');
	this.dsTrnRltList.setColumn(0, 'invlPemRlsYn','N');
	
	this.fnSaveSurvey();
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSelectSurvey = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.isNotNil(this.dsTrnRltList.getColumn(0, 'qstnYr'))){
				this.fnTempSurveyInfo();
			}else{
 				this.fvQuitmSn = this.dsQuitmList.getColumn(this.fvQuitmSn, 'quitmSn');
				this.fvQuitmNo = this.dsQuitmList.getColumn(this.fvQuitmNo, 'quitmNo');
				this.fnSetStaQuitm();
				
				this.dsInsList.filter('quitmNo == ' + this.fvQuitmNo);
				this.dsCurrentInsList.copyData(this.dsInsList, true);
				this.fnSetIns();
			}
	});
};

/**
 * 저장서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSaveSurvey = function()
{
 	// 서비스 객체 생성
	this.smfSaveService("save")
		// 사용자에게 confirm메시지를 표시할지 여부
		.showConfirm(false)
		// (권장) 데이터 존재 필수
		.requireExistsData(this.dsTrnRltList)
		// 데이터 변경 필수
		.requireModifredData(this.dsTrnRltList)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				if (this.dsTrnRltList.getColumn(0, 'tmprStrgYn') == 'Y'){
					this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle07_2')]);
				}else{
					this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle09') + this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle10')]);
				}
				return;
			}
			
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){
				if (this.dsTrnRltList.getColumn(0, 'tmprStrgYn') == 'Y'){
					this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle07_1')]);	// 임시저장
				}else{	// 저장
					if(this.dsSearch.getColumn(0, "qstnDgr") == '2'){	// 설문 2차수
						this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle11')], this.fnMessageCallback);
					}else{	// 설문 1차수
						this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle11') + this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle12')], this.fnMessageCallback);
					}
				}
			}else {	// fail
				if(this.mdfcnNts >= 1){
					this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle14')]);	// 최대 수정횟수 초과
				}else{
					//this.smfAlertEds('LI155', [this.dsApiResponseList.getColumn(0, 'message')]);
					this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle13')]);	// 원자료 통계 미생성
				}
			}
		});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * Top Menu에서 언어를 변경시 발생
 * @param  : sSelectLangCd	- 언어코드
 * @return : N/A
 */
this.fnSelectLang = function(sSelectLangCd)
{
	this.fvLangCd = sSelectLangCd--;
	var divMainCompList = this.svcfSortByTabOrder(this.divMain);
	
	for(var i in divMainCompList){
		if (divMainCompList[i] instanceof nexacro.Static){
			divMainCompList[i].set_text(this.dsLang.getColumn(sSelectLangCd, divMainCompList[i].name.substr(3).toLowerCase()));
			if (divMainCompList[i].name.indexOf('staCommonTitle') > -1){
				if(this.dsSearch.getColumn(0, 'qstnDgr') == 1){
					if (this.smfIsMobile()){
						divMainCompList[i].set_text(this.dsComLang.getColumn(sSelectLangCd, 'c' + divMainCompList[i].name.substr(4)+'m'));
					}else{
						divMainCompList[i].set_text(this.dsComLang.getColumn(sSelectLangCd, 'c' + divMainCompList[i].name.substr(4)));
					}
				}
				if(this.dsSearch.getColumn(0, 'qstnDgr') == 2){
					if (this.smfIsMobile()){
						divMainCompList[i].set_text(this.dsComLang2.getColumn(sSelectLangCd, 'c' + divMainCompList[i].name.substr(4)+'m'));
					}else{
						divMainCompList[i].set_text(this.dsComLang2.getColumn(sSelectLangCd, 'c' + divMainCompList[i].name.substr(4)));
					}
				}
			}
		}
		if (divMainCompList[i] instanceof nexacro.Button){
			divMainCompList[i].set_text(this.dsLang.getColumn(sSelectLangCd, divMainCompList[i].name.substr(3).toLowerCase()));
			if (divMainCompList[i].name == 'btnExamQuitm'){
				divMainCompList[i].set_text(this.dsLang.getColumn(sSelectLangCd, 'tooltipTit'));
			}else if(divMainCompList[i].name.indexOf('btnExamIns') > -1){
				divMainCompList[i].set_text(this.dsLang.getColumn(sSelectLangCd, 'tooltipTitIns'));
			}
		}
	}
	this.dsSearch.setColumn(0, 'qstnExmnLangScCd', (this.fvLang[this.fvLangCd-1]).toUpperCase());
	this.fnSelectSurvey();
}

/**
 * 문항 auto 음성 function
 * @param  : N/A
 * @return : N/A
 */
this.fnAutoSound = function(){	
	// 다음문항, 이전문항 클릭 시 sound on 상태(true)이면 자동 음성 재생
	if(this.ttsBtn == true){
		this.divTop.form.fnAutoTTS();
	}
};

/**
 * 설문 보기 설정
 * @param  : N/A
 * @return : N/A
 */
this.fnSetIns = function()
{
	var insChcTypCdVal = +this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.fvQuitmNo), 'insChcTypCd');
	//this.divMain.form.div00.form.divIns.set_height(this.divMain.form.div00.form.btnExamQuitm.visible ? 26 : 0);

	for(var i = 0; i < this.fvChkIns.length; i++){
		this.fvRdoIns[i].set_value(false);
		this.fvRdoIns[i].set_visible(false);
		this.fvRdoIns[i].set_height(0);
		this.fvChkIns[i].set_value(false);
		this.fvChkIns[i].set_visible(false);
		this.fvChkIns[i].set_height(0);
		
		if(insChcTypCdVal == '1'){	// 단건일 때
			// rdo 설정
			this.fvRdoIns[i].insChkVal = this.dsCurrentInsList.getColumn(i, 'insChkVal');
			if (this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.fvQuitmNo), 'qstnQuitmScCd') == 'O'){
				if (i < this.dsCurrentInsList.getRowCount()){
					this.fvRdoIns[i].set_height(this.smfIsMobile() ? 50 : 30);
					this.fvRdoIns[i].set_visible(true);
				}else {
					this.fvRdoIns[i].set_visible(false);
					this.fvRdoIns[i].set_height(0);
				}
			}else {
				this.fvRdoIns[i].set_visible(false);
				this.fvRdoIns[i].set_height(0);
			}
		}else{	// 다건일 때
			// chk 설정
			this.fvChkIns[i].insChkVal = this.dsCurrentInsList.getColumn(i, 'insChkVal');
			if (this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.fvQuitmNo), 'qstnQuitmScCd') == 'O'){
				if (i < this.dsCurrentInsList.getRowCount()){
					this.fvChkIns[i].set_height(this.smfIsMobile() ? 50 : 30);
					this.fvChkIns[i].set_visible(true);
				}else {
					this.fvChkIns[i].set_visible(false);
					this.fvChkIns[i].set_height(0);
				}
			}else {
				this.fvChkIns[i].set_visible(false);
				this.fvChkIns[i].set_height(0);
			}
		}

		if (i < this.dsCurrentInsList.getRowCount()){
			// sta 설정
			this.fvStaIns[i].set_text(this.dsCurrentInsList.getColumn(i, 'qstnQuitmCn'));
			this.fvStaIns[i].set_visible(true);
			this.divMain.form.div00.form.divIns.form.resetScroll();

			if(!this.smfIsMobile() && ((this.fvLangCd == 7 && this.dsInsList.getColumn(i, 'qstnQuitmCn').length>=217)
				|| (this.fvLangCd == 6 && this.dsInsList.getColumn(i, 'qstnQuitmCn').length>=252))){	//2024년 1차 보기 짤리는 현상으로 인해 조건 추가
				this.fvStaIns[i].set_height(this.fvStaIns[i]._width > 960 ? 68 : 30);
			} else if (!this.smfIsMobile() && this.fvLangCd == 2 && this.dsInsList.getColumn(i, 'qstnQuitmCn').length>=108) {
				this.fvStaIns[i].set_height(this.fvStaIns[i]._width > 900 ? 50 : 30);
			} else if (!this.smfIsMobile() && this.fvLangCd == 4 && this.dsInsList.getColumn(i, 'qstnQuitmCn').length>=48) {
				this.fvStaIns[i].set_height(this.fvStaIns[i]._width > 840 ? 50 : 30);
			} else {
				this.fvStaIns[i].set_height(this.fvStaIns[i]._width > 960 ? 50 : 30);
			}
			
			// edt 설정
 			this.fvEdtRslt[i].set_value(null);
 			this.fvEdtRslt[i].set_enable(false);
			
			if (this.dsCurrentInsList.getColumn(i, 'sbjctInsYn') == 'Y'){
				this.fvEdtRslt[i].set_displaynulltext(this.dsLang.getColumn(this.fvLangCd-1, 'title09'));
				this.fvEdtRslt[i].set_height(this.smfIsMobile() ? 46 : 34);
				this.fvEdtRslt[i].set_visible(true);
			}else {
				this.fvEdtRslt[i].set_visible(false);
				this.fvEdtRslt[i].set_height(0);
			}
			
			// btn 설정
			if(this.nvl(this.dsCurrentInsList.getColumn(i, 'atchFileId'), '') == ''
				&& this.nvl(this.dsCurrentInsList.getColumn(i, 'qstnAdiEpl'), '') == ''){
				this.fvBtnExamIns[i].set_visible(false);
				this.fvBtnExamIns[i].set_height(0);
			}else {
				this.fvBtnExamIns[i].set_height(this.smfIsMobile() ? 46 : 26);
				this.fvBtnExamIns[i].set_visible(true);
			}
		}else {
			this.fvStaIns[i].set_visible(false);
			this.fvStaIns[i].set_height(0);
			this.fvEdtRslt[i].set_visible(false);
			this.fvEdtRslt[i].set_height(0);
			this.fvBtnExamIns[i].set_visible(false);
			this.fvBtnExamIns[i].set_height(0);
		}
	}
	
	// 1번 문항이면 이전문항 비활성화
	this.divMain.form.btnTitle02.set_enable(this.fvQuitmNo == this.dsQuitmList.getColumn(0, 'quitmNo') ? false : true);
	
	// 마지막 문항이면 '다음문항'을 '다음단계'로 변경, 차수2(표본)이면 '제출하기'로 변경
	if (this.fvQuitmNo == this.dsQuitmList.getColumn(this.dsQuitmList.getRowCount()-1, 'quitmNo')){
		this.divMain.form.btnTitle01.set_text(this.dsLang.getColumn(this.fvLangCd-1, this.fnIsSbmsn() ? 'title11' : 'title10'));
	}else{
		this.divMain.form.btnTitle01.set_text(this.dsLang.getColumn(this.fvLangCd-1, 'title01'));
	}
	
	this.fnSetPrg();
	// 투명도 조절
	this.fnSetSurvOpacity(this.fvOpacityVal);
	this.fnSetcompSize();
}

/**
 * 진행률 설정
 * @param  : N/A
 * @return : N/A
 */
this.fnSetPrg = function()
{
	// pos 설정
	var prgVal = Math.floor((this.dsQuitmList.findRow('quitmNo', this.fvQuitmNo) + 1) * 100 / this.dsQuitmList.getRowCount()) || 0;
	if (this.smfIsMobile()){
		// x 위치 설정
		var leftX = Math.floor((this.divMain.form.div00_00.form.pgb00._adjust_width - 30) * prgVal / 100);
		this.divMain.form.div00_00.form.staPrg.set_left(leftX);
		this.divMain.form.div00_00.form.staPrg.set_text(prgVal + '%');
		this.divMain.form.div00_00.form.pgb00.set_pos(prgVal);
	}else{
		// x 위치 설정
		var leftX = Math.floor((this.divMain.form.div00.form.div00.form.pgb00._adjust_width - 30) * prgVal / 100);
		this.divMain.form.div00.form.div00.form.staPrg.set_left(leftX);
		this.divMain.form.div00.form.div00.form.staPrg.set_text(prgVal + '%');
		this.divMain.form.div00.form.div00.form.pgb00.set_pos(prgVal);
	}
}

/**
 * 이전 문항 일련번호 및 번호 설정
 * @param  : N/A
 * @return : N/A
 */
this.fnPrevQuitmQtr = function()
{
	// 같은 문항의 번호가 중복되어 들어가면 안됨
	if (!this.smfIsNull(this.dsRsltList.lookup('quitmNo', this.fvQuitmNo, 'quitmNo'))){
		this.dsRsltList.deleteRow(this.dsRsltList.getRowCount() - 1);
	}
	
	this.fvQuitmSn = this.dsRsltList.getColumn(this.dsRsltList.rowcount - 1, 'quitmSn');
	this.fvQuitmNo = this.dsRsltList.getColumn(this.dsRsltList.rowcount - 1, 'quitmNo');
};

/**
 * 다음 문항 일련번호 및 번호 설정
 * @param  : insSn		- 보기 일련번호
 * @return : N/A
 */
this.fnNextQuitmQtr = function(insSn)
{
	this.dsQtrList.filter('quitmNo ==' + this.fvQuitmNo + (this.fvQuitmNo != '30100' ? ' && insSn == ' + insSn : ""));
	this.dsCurrentQtrList.copyData(this.dsQtrList, true);
	
	var excpYn = false;
	
	for(var i = 0; i < this.dsCurrentQtrList.getRowCount(); i++){
			if(this.dsCurrentQtrList.getColumn(i, 'quitmQtrScCd') == "2"){	// 다건
				if (this.dsRsltList.findRow('quitmNo', this.dsCurrentQtrList.getColumn(i, 'excpPrcsQuitmNo')) == -1){
					continue;
				}
				
				var rsltVal = (this.dsRsltList.getColumn(this.dsRsltList.findRow('quitmNo', this.dsCurrentQtrList.getColumn(i, 'excpPrcsQuitmNo')), 'rsltVal')).split('');
				var compVal = rsltVal[this.dsCurrentQtrList.getColumn(i, 'excpPrcsInsNo') - 1];
				
				if(compVal == "1"){
					this.fvQuitmSn = this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.dsCurrentQtrList.getColumn(i, 'quitmShrtcNo')), 'quitmSn');
					this.fvQuitmNo = this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.dsCurrentQtrList.getColumn(i, 'quitmShrtcNo')), 'quitmNo');

					excpYn = true;
					break;
				}
			}
	}
	
	if(!excpYn){
		for(var i = 0; i < this.dsCurrentQtrList.getRowCount(); i++){
			if(this.dsCurrentQtrList.getColumn(i, 'quitmQtrScCd') == "1"){	// 단건
				this.fvQuitmSn = this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.dsCurrentQtrList.getColumn(i, 'quitmShrtcNo')), 'quitmSn');
				this.fvQuitmNo = this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.dsCurrentQtrList.getColumn(i, 'quitmShrtcNo')), 'quitmNo');
			}
		}
	}
};

/**
 * 임시저장된 응답 값 세팅
 * @param  : N/A
 * @return : N/A
 */
this.fnTempSurveyInfo = function()
{
	this.dsRsltList.clearData();
	if (this.dsTrnRltList.getColumn(0, 'sbmsnYn') == 'N' || this.smfIsNull(this.dsTrnRltList.getColumn(0, 'sbmsnYn'))){
		for(var i = 0; i < this.dsTrnRltList.getColCount(); i++){
			if (this.dsTrnRltList.getColID(i).indexOf('RspnsValue') > -1 ){
				if (this.isNotNil(this.dsTrnRltList.getColumn(0, i))){
					if (this.dsTrnRltList.getColumn(0, i).indexOf('1') == -1){
						continue;
					}
					var row = this.dsRsltList.addRow();
					this.fvQuitmSn = this.dsTrnRltList.getColID(i).replace('quitm', '').replace('RspnsValue', '');
					this.fvQuitmNo = this.dsQuitmList.getColumn(this.fvQuitmSn -1, 'quitmNo');

					this.dsRsltList.setColumn(row, 'quitmSn', this.fvQuitmSn);
					this.dsRsltList.setColumn(row, 'quitmNo', this.fvQuitmNo);
					this.dsRsltList.setColumn(row, 'quitmRelmCd', this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.fvQuitmNo), 'quitmRelmCd'));

					if (this.dsTrnRltList.getColumn(0, i).indexOf('[') > -1){
						var sbjctRsltVal = this.dsTrnRltList.getColumn(0, i).split('[');
						
						this.dsRsltList.setColumn(row, 'rsltVal', sbjctRsltVal[0]);
						this.dsRsltList.setColumn(row, 'sbjctRsltVal', '[' + sbjctRsltVal[1]);
					}else{
						this.dsRsltList.setColumn(row, 'rsltVal', this.dsTrnRltList.getColumn(0, i));
						this.dsRsltList.setColumn(row, 'sbjctRsltVal', '');
					}
				}
			}
		}
	}else{
		this.fvQuitmSn = this.dsQuitmList.getColumn(this.fvQuitmSn, 'quitmSn');
		this.fvQuitmNo = this.dsQuitmList.getColumn(this.fvQuitmNo, 'quitmNo');
	}
	
	this.fnSetStaQuitm();
	this.dsInsList.filter('quitmNo == ' + this.fvQuitmNo);
	this.dsCurrentInsList.copyData(this.dsInsList, true);
	this.fnSetIns();
	this.fnSetRslt();
};

/**
 * dsTrnRltList 데이터셋 세팅
 * @param  : N/A
 * @return : N/A
 */
this.fnDsTrnRltListSet = function(){
	this.dsTrnRltList.clearData();
	this.dsTrnRltList.addRow();
	this.dsTrnRltList.copyRow(0, this.dsSearch, 0);

	for(var i = 0; i < this.dsQuitmList.rowcount; i++){
		var row = this.dsRsltList.findRow('quitmNo', this.dsQuitmList.getColumn(i, 'quitmNo'));

		if (row != -1){
			this.dsTrnRltList.setColumn(0, 'quitm' + (i + 1) + 'RspnsValue' , this.dsRsltList.getColumn(row, 'rsltVal') + this.dsRsltList.getColumn(row, 'sbjctRsltVal'));
			
			// 문항에서 '없다'로 선택하면 목격경험여부(A11), 피해경험여부(B11), 가해경험여부(C11) 다 'N'으로 변경
			if (this.dsRsltList.getColumn(row, 'quitmRelmCd') == 'A11'){
				this.dsTrnRltList.setColumn(0, 'sighExprYn', this.dsRsltList.getColumn(row, 'rsltVal') == '01' ? 'N' : 'Y');
			}
			if (this.dsRsltList.getColumn(row, 'quitmRelmCd') == 'B11'){
				this.dsTrnRltList.setColumn(0, 'dmgExprYn', this.dsRsltList.getColumn(row, 'rsltVal') == '01' ? 'N' : 'Y');
			}
			if (this.dsRsltList.getColumn(row, 'quitmRelmCd') == 'C11'){
				this.dsTrnRltList.setColumn(0, 'wdgExprYn', this.dsRsltList.getColumn(row, 'rsltVal') == '01' ? 'N' : 'Y');
			}

		}else{
			var rsltVal = '';
			this.dsInsList.filter('quitmNo == ' + this.dsQuitmList.getColumn(i, 'quitmNo'));
			this.dsCurrentInsList.copyData(this.dsInsList, true);
			for(var j = 0; j < this.dsCurrentInsList.getRowCount(); j++){
				rsltVal += '0';
			}
			this.dsTrnRltList.setColumn(0, 'quitm' + (i + 1) + 'RspnsValue' , rsltVal);
		}
		if(this.dsQuitmList.getColumn(i, 'quitmNo') ==  this.dsRsltList.getColumn(this.dsRsltList.rowcount-1, 'quitmNo')) break;
	}
	
	// 목격경험여부(A11), 피해경험여부(B11), 가해경험여부(C11) null 체크
	this.dsTrnRltList.setColumn(0, 'sighExprYn', this.dsTrnRltList.getColumn(0, 'sighExprYn') || 'N');
	this.dsTrnRltList.setColumn(0, 'dmgExprYn', this.dsTrnRltList.getColumn(0, 'dmgExprYn') || 'N');
	this.dsTrnRltList.setColumn(0, 'wdgExprYn', this.dsTrnRltList.getColumn(0, 'wdgExprYn') || 'N');
	
	this.dsInsList.filter('quitmNo ==' + this.fvQuitmNo);
	this.dsCurrentInsList.copyData(this.dsInsList, true);
};

/**
 * 투명도 조절
 * @param  : posValue	- 투명도값
 * @return : N/A
 */
this.fnSetSurvOpacity = function(posValue)
{
	posValue = posValue || 0;
	this.divMain.form.div00.form.div01.form.staPrg.setOffsetLeft(285 * posValue / 100);
	this.divMain.form.div00.form.div01.form.staPrg.set_text((100 - posValue) + '%');
	this.divMain.form.div00.form.div01.form.pgb00.set_pos(posValue);
	this.divMain.form.div00.set_opacity((100 - posValue)/100);
	this.dsSearch.setColumn(0, 'posValue' , posValue);
};

/**
 * Top Menu에서 TTS버튼을 클릭시 발생
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.fnCallTTS = function()
{
	var qstnQuitmNo = this.dsQuitmList.getColumn(this.dsQuitmList.findRow('quitmNo', this.fvQuitmNo), 'qstnQuitmNo').replaceAll(' ', '');
	var qstnYr = this.dsSearch.getColumn(0, 'qstnYr');
	var qstnDgr = this.dsSearch.getColumn(0, 'qstnDgr');
	var qstnNo = "";
	var quitmNo = "";
	var	quitNo1 = "";

	quitmNo = qstnQuitmNo;
	quitNo1 = this.fvQuitmNo.substr(2, 1);
	qstnQuitmNo = qstnQuitmNo.slice(0, -1);
	qstnNo = qstnQuitmNo.substr(2, 3);
	
	this.ttsBtn == false ? this.ttsBtn = true : this.ttsBtn = false;
	
	if (!this.smfContainsStr(window.location.host, "local") &&
			  !this.smfContainsStr(window.location.host, "dev") &&
			  !this.smfContainsStr(window.location.host, "tst")){	// cdn (실제 운영 음성)
		if(this.prefixs == '_ele'){
			if(qstnQuitmNo.substr(0, 1) == '5'){
				return "https://cdn.neis.go.kr/sv/" + this.fvLang2[this.fvLangCd-1] + "/01_ele/02_basic-add/응답 결과에 따른 추가 질문_목격경험.mp3";
			}else if(quitmNo == '6'){
				return "https://cdn.neis.go.kr/sv/" + this.fvLang2[this.fvLangCd-1] + "/01_ele/02_basic-add/응답 결과에 따른 추가 질문_피해경험_0"+quitNo1+".mp3";
			}else if(qstnQuitmNo.substr(0, 1) == '7'){
				return "https://cdn.neis.go.kr/sv/" + this.fvLang2[this.fvLangCd-1] + "/01_ele/03_add/추가_문항"+qstnNo+".mp3";
			}else if(qstnQuitmNo.substr(0, 1) == '8'){
				return "https://cdn.neis.go.kr/sv/" + this.fvLang2[this.fvLangCd-1] + "/01_ele/04_back/문"+qstnNo+".mp3";
			}else{
				return "https://cdn.neis.go.kr/sv/" + this.fvLang2[this.fvLangCd-1] + "/01_ele/01_basic/문"+qstnQuitmNo.replace(/-/gi, '-')+".mp3";
			}
		}else if(this.prefixs == '_mid'){
			if(qstnQuitmNo.substr(0, 1) == '5'){
				return "https://cdn.neis.go.kr/sv/" + this.fvLang2[this.fvLangCd-1] + "/02_mid/02_basic-add/응답 결과에 따른 추가 질문_목격경험.mp3";
			}else if(quitmNo == '6'){
				return "https://cdn.neis.go.kr/sv/" + this.fvLang2[this.fvLangCd-1] + "/02_mid/02_basic-add/응답 결과에 따른 추가 질문_피해경험_0"+quitNo1+".mp3";
			}else if(qstnQuitmNo.substr(0, 1) == '7'){
				return "https://cdn.neis.go.kr/sv/" + this.fvLang2[this.fvLangCd-1] + "/02_mid/03_add/추가_문항"+qstnNo+".mp3";
			}else if(qstnQuitmNo.substr(0, 1) == '8'){
				return "https://cdn.neis.go.kr/sv/" + this.fvLang2[this.fvLangCd-1] + "/02_mid/04_back/문"+qstnNo+".mp3";
			}else{
				return "https://cdn.neis.go.kr/sv/" + this.fvLang2[this.fvLangCd-1] + "/02_mid/01_basic/문"+qstnQuitmNo.replace(/-/gi, '-')+".mp3";
			}
		}
	}else{	// tts (개발환경 음성)
		if(this.prefixs == '_ele'){
			if(qstnQuitmNo.substr(0, 1) == '5'){
