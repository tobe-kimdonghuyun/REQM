    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    샘플
*  @FileName 	eds_vffos02_m01.xfdl
*  @Creator 	정인혁
*  @CreateDate 	2022.11.1
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.11.1     	정인혁 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.eds_vffos02_m01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitForm(obj);
	
	this.smfResetScroll(this);
	
	// Top버튼의 언어선택등을 안보이게 한다.(보여줄때는 처리를 안해도 됨)
	this.divTop.form.fnSetTopFrameBtnVisible(false, false, false);
	
	this.fnSelectSurveyPeriod();
}; 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
};
/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 조회서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSelectSurveyPeriod = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("select")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.divTop.form.fnSetSurveyPeriod(this.dsInfo.saveXML());
	});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
//Top Menu에서 이전화면으로 가기 버튼을 클릭 시 발생
this.fnMoveBack = function(){
};

//Top Menu에서 TTS버튼을 클릭시 발생
this.fnCallTTS = function(){
};

//Top Menu에서 언어를 변경시 발생
this.fnSelectLang = function(sSelectLangCd){
	// sSelectLangCd -  "1": 한국어 "2":영어 ... "8": 아랍어 
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 시도교육청 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.Button_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sCddcCd = obj.cddcCd;
	var nFindRow = this.dsCddcList.findRow("cddcCd",sCddcCd);
	var sCddcName = this.dsCddcList.getColumn(nFindRow,"cddcNm");
	var sCddcInfo = this.dsCddcList.getColumn(nFindRow,"info"  );
	this._cddcCd = sCddcCd;
	
	this.divMain.form.divCddcList.form.staCddcName.set_text(sCddcName + " 문의전화");
	
	for(var i = 0; i < 17; i++){
		var num = (i < 10 ? '0' : '') + i;
		this.divMain.form.divCddcList.form['btnCddc' + num].set_cssclass('btn_WF_SurvMain01');
	}
	obj.set_cssclass('btn_WF_SurvMain01S');
	
	if (this.smfIsMobile()){
		this.divMain.form.divCddcList.form.staCddcName.set_cssclass("sta_WF_SurvCaution24B");
	}else{
		this.divMain.form.divCddcList.form.staCddcName.set_cssclass("sta_WF_SurvCautionS");
	}
	this.divMain.form.divCddcList.form.staCddcInfo.set_text(sCddcInfo);
	this.divMain.form.divCddcList.form.staCddcInfo.set_visible(true);
	this.divMain.form.divCddcList.form.resetScroll();
	this.divMain.form.btnSurveyStart.set_visible(true);
};

/**
 * 설문 참여하기 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.divMain_btnSurveyStart_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.getOwnerFrame().form._surveyInfo_cddcCd = this._cddcCd;
	this.smfSetCddcCode(this._cddcCd);
	var param = {dsInfo: this.dsInfo.saveXML()};
	this.smfSetWorkPage("pa_eds_vff_os::eds_vffos03_m01.xfdl",param,false);	
};]]></Script>
  </Form>
</FDL>
