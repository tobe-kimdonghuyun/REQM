            <Col id="data">Нет</Col>
            <Col id="langCd">7</Col>
            <Col id="neisUseYn">Y</Col>
          </Row>
          <Row>
            <Col id="data">Я отвечу позже</Col>
            <Col id="langCd">7</Col>
            <Col id="neisUseYn">N</Col>
            <Col id="code">2</Col>
          </Row>
          <Row>
            <Col id="code">1</Col>
            <Col id="data">ต้องการ</Col>
            <Col id="langCd">8</Col>
            <Col id="neisUseYn">Y</Col>
          </Row>
          <Row>
            <Col id="code">0</Col>
            <Col id="data">ไไม่ต้องการ</Col>
            <Col id="langCd">8</Col>
            <Col id="neisUseYn">Y</Col>
          </Row>
          <Row>
            <Col id="data">ฉันจะตอบในภายหลัง</Col>
            <Col id="langCd">8</Col>
            <Col id="neisUseYn">N</Col>
            <Col id="code">2</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsQuitmVoice">
        <ColumnInfo>
          <Column id="quitmVoiceM" type="STRING" size="256"/>
          <Column id="quitmVoiceW" type="STRING" size="256"/>
          <Column id="quitmVoiceEtcM" type="STRING" size="256"/>
          <Column id="quitmVoiceEtcW" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsApiResponseList" useclientlayout="true">
        <ColumnInfo>
          <Column id="code" type="STRING" size="256" description="연계상태값"/>
          <Column id="message" type="STRING" size="256" description="연계메시지"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 학교폭력실태조사 > 학교폭력(설문참여_주관식)
*  @FileName 	eds_vffos07_m01.xfdl 
*  @Creator 	김민성
*  @CreateDate 	2022.11.21
*  @Desction    학교폭력(설문참여_주관식)
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.11.21            김민성                   최초 생성
*******************************************************************************
*/
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvLangCd;
this.fvQuitmVoice = 'QuitmVoiceW';
this.fvLang = ['ko', 'en', 'zh', 'ja', 'vi', 'tl', 'ru', 'th'];
this.fvIsBtnDrag = false;
this.fvOpacityVal = 0;
this.fvpreClientxy = 0;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	// 필수
	this.smfResetScroll(this);
	this.pv_params = this.smfGetFormParams();
	this.dsSearch.loadXML(this.pv_params.dataset);
	this.dsTrnRltList.loadXML(this.pv_params.dataset2);
	this.fvLangCd = this.pv_params.langCd;
	this.divTop.form.fnSetTopFrameBtnVisible(false, false, true);
	this.divTop.form.fnSetTopFrameBtnHomeVisible(false);
	
	// PC 화면정렬
	this.fnSetcompSizeP();
	
	// 외국어 일때 이전문항, 다음문항 화살표 제거
	this.divMain.form.btnTitle04.set_cssclass(this.fvLangCd == 1 ? 'btn_WF_SurveyPre' : 'btn_WF_SurveyPreNo');
	
	// 주관식만 수정가능할 때, 이전문항 클릭 금지
	if (this.dsTrnRltList.getColumn(0, 'joinCd') == 2){
		this.divMain.form.btnTitle04.set_enable(false);
	}
	
	this.dsSearch.setColumn(0, 'qstnQuitmScCd', 'S');
	this.fnSelectLang(this.fvLangCd);
	
	var pvShlKndScCd = this.dsSearch.getColumn(0, 'shlKndScCd');
	var pvShlCrseScCd = this.dsSearch.getColumn(0, 'shlCrseScCd');
	var prefix = 2;
	
	// 투명도는 특수학교05, 각종학교26 이면 안보임
	if (pvShlKndScCd == '05' || pvShlKndScCd == '26'){
		this.divMain.form.div00.form.staTitle07.set_visible(false);
		this.divMain.form.div00.form.div00.set_visible(false);
	}
	
	if(pvShlKndScCd == '05' || pvShlKndScCd == '26'){
		if(pvShlCrseScCd == '2'){
			prefix = 1; // 특수초등
		}
	}else if (this.isNotNil(pvShlKndScCd) && (pvShlKndScCd == '02' || pvShlKndScCd == '06' || pvShlKndScCd == '14' || pvShlKndScCd == '19' || pvShlKndScCd == '20')) {
		prefix = 1; // 일반초등
	}
	
	this.fnSound();
	
	if (this.fvLangCd == 1){
		this.fvQuitmVoice = prefix == 2 ? 'quitmVoiceW' : 'quitmVoiceM';
	}else{
		this.fvQuitmVoice = prefix == 2 ? 'quitmVoiceEtcW' : 'quitmVoiceEtcM';
	}
	
	// 투명도 조절
	this.fvOpacityVal = this.dsSearch.getColumn(0, 'posValue') || 0;
	this.fnSetSurvOpacity(this.fvOpacityVal);
};
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 팝업의 콜백함수
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	this.dsTrnRltList.setColumn(0, 'invlPemRlsYn', e.row);
	this.smfConfirmEds([this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle13_1') + '\n' + this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle13_2')], this.fnQstnSaveCallback, null);
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){	
	var param = {langCd: this.fvLangCd,
		 dataset: this.dsSearch.saveXML(),
		 };
		 
	this.smfSetWorkPage("pa_eds_vff_os::eds_vffos08_m01.xfdl",param,false);
};

/**
 * 설문응답 제출하기 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnQstnSaveCallback = function(){
	if(!arguments[0].confirmResult) return;

	this.dsTrnRltList.setColumn(0, 'cddcScCd', this.dsSearch.getColumn(0, 'cddcScCd'));
	this.dsTrnRltList.setColumn(0, 'tmprStrgYn', 'N');
	this.dsTrnRltList.setColumn(0, 'sbmsnYn', 'Y');
	this.dsTrnRltList.setColumn(0, 'rspnsErrYn', 'N');
	if(this.divMain.form.div00.form.div01.form.rdo00.value == 0){ // 아니오
		for(var i = 0; i < 6; i++){
			this.dsTrnRltList.setColumn(0, 'dscrpQuitm' + (i + 1) + 'RspnsValue', null);
		}
		this.dsTrnRltList.setColumn(0, 'dclrYn', 'N');
		this.fnSaveSurvey(0);
	}else if(this.divMain.form.div00.form.div01.form.rdo00.value == 1){ // 예
		for(var i = 0; i < 6; i++){
			this.dsTrnRltList.setColumn(0, 'dscrpQuitm' + (i + 1) + 'RspnsValue', this.divMain.form.div00.form.divIns.form['edt0'+i].value);
		}
		this.dsTrnRltList.setColumn(0, 'dclrYn', 'Y');
		this.fnSaveSurvey(1);
	}else{ // 나중에 제출
		for(var i = 0; i < 6; i++){
			this.dsTrnRltList.setColumn(0, 'dscrpQuitm' + (i + 1) + 'RspnsValue', null);
		}
		this.dsTrnRltList.setColumn(0, 'dclrYn', null);
		this.fnSaveSurvey(2);
	}
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 저장서비스
 * @param : N/A
 * @param : N/A
 */
this.fnSaveSurvey = function(isSaveSc) // 1: 예, 0: 아니오, 2: 나중에제출
{
 	// 서비스 객체 생성
	this.smfSaveService("save")
		// 사용자에게 confirm메시지를 표시할지 여부
		.showConfirm(false)
		// (권장) 데이터 존재 필수
		.requireExistsData(this.dsTrnRltList)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors){
				this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle08') +
										+ this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle09')] );
				return;
			}
			
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){
				if(isSaveSc != 2){	// 나중 제출 아닐 때
					this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle06') + '\n'
												+ this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle07')], this.fnMessageCallback);
				}else{	// 나중 제출일 때
					this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle12_1') + '\n'
											+ this.dsLang.getColumn(this.fvLangCd - 1, 'alertTitle12_2')], this.fnMessageCallback);
				}
			}else{
				this.smfAlertEds('LI155', [this.dsApiResponseList.getColumn(0, 'message')], null );
			}
		});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * Top Menu에서 언어를 변경시 발생
 * @param  : sSelectLangCd	- 언어코드
 * @return : N/A
 */
this.fnSelectLang = function(sSelectLangCd)
{
	this.fvLangCd = sSelectLangCd--;
	var divMainCompList = this.svcfSortByTabOrder(this.divMain);
	
	for(var i in divMainCompList){
		if (divMainCompList[i] instanceof nexacro.Static){
			divMainCompList[i].set_text(this.dsLang.getColumn(sSelectLangCd, divMainCompList[i].name.substr(3).toLowerCase()));
			
			if (divMainCompList[i].name.indexOf('staCommonTitle') > -1){
				if (this.smfIsMobile()){
					divMainCompList[i].set_text(this.dsComLang.getColumn(sSelectLangCd, 'c' + divMainCompList[i].name.substr(4)+'m'));
				}else{
					divMainCompList[i].set_text(this.dsComLang.getColumn(sSelectLangCd, 'c' + divMainCompList[i].name.substr(4)));
				}
			}
			if (this.smfIsMobile()){
				if (divMainCompList[i].name != 'staTitle05_1' && divMainCompList[i].name != 'staTitle05_2' && divMainCompList[i].name != 'sta00' && divMainCompList[i].name != 'sta01'){
					divMainCompList[i].set_fittocontents("height");
				}
			}else{
				if (divMainCompList[i].name.indexOf('staIns') > -1){ // 입력문항
					divMainCompList[i].set_fittocontents("height");
				}
			}
		}
		if (divMainCompList[i] instanceof nexacro.Edit){
			divMainCompList[i].set_displaynulltext(this.dsLang.getColumn(sSelectLangCd, 'alertTitle04'));
		}
		if (divMainCompList[i] instanceof nexacro.Button){
			divMainCompList[i].set_text(this.dsLang.getColumn(sSelectLangCd, divMainCompList[i].name == 'btnTitle02_1' ? 'title02' : divMainCompList[i].name.substr(3).toLowerCase()));
		}
	}
	
	if (this.isNil(this.divMain.form.div00.form.div00.form.staPrg.text)){
		this.divMain.form.div00.form.div00.form.staPrg.set_text(0 + '%');
	}
	
	// 나이스 미사용학교는 '나중에 제출' 안보임
	if (this.dsSearch.getColumn(0, 'neisUseYn') == 'N'){
		this.dsRdoLang.filter("langCd == " + this.fvLangCd + " && neisUseYn == 'Y'");
	}else{
		this.dsRdoLang.filter('langCd == ' + this.fvLangCd);
	}
	
	this.dsSearch.setColumn(0, 'qstnExmnLangScCd', (this.fvLang[this.fvLangCd-1]).toUpperCase());
	this.fnSetcompSize();
}

/**
 * 투명도 조절
 * @param  : posValue	- 투명도값
 * @return : N/A
 */
this.fnSetSurvOpacity = function(posValue)
{
	posValue = posValue || 0;
	this.divMain.form.div00.form.div00.form.staPrg.setOffsetLeft(285 * posValue / 100);
	this.divMain.form.div00.form.div00.form.staPrg.set_text((100 - posValue) + '%');
	this.divMain.form.div00.form.div00.form.pgb00.set_pos(posValue);
	this.divMain.form.div00.set_opacity((100 - posValue)/100);
	this.dsSearch.setColumn(0, 'posValue' , posValue);
};

/**
 * 예/아니오/나중에 제출 라디오 값에 대한 세팅
 * @param  : posValue	- 투명도값
 * @return : N/A
 */
this.fnSetDivIns = function(scVal){
	if (scVal == 0){ // 아니요
		this.divMain.form.btnTitle02.set_enable(true);
	}else if(scVal == 1){ // 예
		this.divMain.form.div00.form.div01.set_visible(false);
		this.divMain.form.div00.form.divIns.set_visible(true);
		this.divMain.form.div00.form.staTitle12.set_visible(true);
		
		this.divMain.form.btnTitle04.set_visible(false);
		this.divMain.form.btnTitle02.set_visible(false);
		this.divMain.form.btnTitle15.set_visible(true);
		this.divMain.form.btnTitle02_1.set_visible(true);
	}else{ // 나중에 제출
		this.divMain.form.btnTitle02.set_enable(true);
	}
	this.fnSetcompSize();
};

/**
 * Top Menu에서 TTS버튼을 클릭시 발생
 * @param  : obj			- [object]Button
 * @param  : e				- [string]ClickEventInfo
 * @return : N/A
 */
this.fnCallTTS = function()
{
	if (!this.smfContainsStr(window.location.host, "local") &&
			  !this.smfContainsStr(window.location.host, "dev") &&
			  !this.smfContainsStr(window.location.host, "tst")){	// cdn (실제 운영 음성)
		return this.dsQuitmVoice.getColumn(0, this.fvQuitmVoice);
	}else{	// tts (개발환경 음성)
		if(this.fvLangCd == 1){	// 한국어
			return "/doc/edu/pa/eds/vff/os/video/ko/ele/report/report.wav"
		}else if(this.fvLangCd == 3){	// 중국어
			return "/doc/edu/pa/eds/vff/os/video/zh/ele/report/zh_ele_report.wav"
		}else{	// 영어 외 다국어
			return"/doc/edu/pa/eds/vff/os/video/en/ele/report/en_ele_report.wav"
		}
	}
};

/**
 * 문항 음성 function
 * @param  : N/A
 * @return : N/A
 */
this.fnSound = function(){	
	if (!this.smfContainsStr(window.location.host, "local") &&
			  !this.smfContainsStr(window.location.host, "dev") &&
			  !this.smfContainsStr(window.location.host, "tst")){	// 실제 운영 비디오 cdn
		// 문항 음성 설정
		var row = this.dsQuitmVoice.addRow();
		var qstnYr = this.dsSearch.getColumn(0, 'qstnYr');
		var qstnDgr = this.dsSearch.getColumn(0, 'qstnDgr');
		this.dsQuitmVoice.setColumn(row, this.fvQuitmVoice, 'https://cdn.sgacorp.kr/question/' + qstnYr + '_' + qstnDgr + '_' + this.fvLang[this.fvLangCd-1] + '_question01_ele.mp3');
		this.dsQuitmVoice.setColumn(row, this.fvQuitmVoice, 'https://cdn.sgacorp.kr/question/' + qstnYr + '_' + qstnDgr + '_' + this.fvLang[this.fvLangCd-1] + '_question01_mid.mp3');
	}
};

/**
 * 컴포넌트 사이즈 조절(Mobile)
 * @param  : N/A
 * @return : N/A
 */
this.fnSetcompSize = function(){	
	if (this.smfIsMobile()){
		this.smfResetScroll(this.divMain.form.div00.form.div00.form);
		if(this.divMain.form.div00.form.divIns.visible){ // 주관식이 보일때
			this.smfResetScroll(this.divMain.form.div00.form.divIns.form);
		}else{ // 주관식이 안보일때
			this.divMain.form.div00.form.div01.form.rdo00.set_height(150);
			this.smfResetScroll(this.divMain.form.div00.form.div01.form);
			this.divMain.form.div00.form.div01.form.sta00.set_height(this.divMain.form.div00.form.div01.form.sta02.getOffsetBottom());
			this.divMain.form.div00.form.div01.set_height(this.divMain.form.div00.form.div01.form.sta02.getOffsetBottom());
		}
		this.smfResetScroll(this.divMain.form.div00.form);
		this.smfResetScroll(this.divMain.form);
		this.divMain.set_height(this.divMain.form.btnTitle04.getOffsetBottom() + 71);
	}
	this.smfResetScroll(this);
};

/**
 * 컴포넌트 사이즈 조절(PC)
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnSetcompSizeP = function(){
	if (!this.smfIsMobile()){
		var nMaxWidth = 1200;
		var nFormWidth = this.getOffsetWidth();
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.divMain.form.sta00.setOffsetLeft(10 + nLeft);
			this.divMain.form.staCommonTitle05.setOffsetLeft(38 + nLeft);
			this.divMain.form.div00.setOffsetLeft(10 + nLeft);
		}else{
			var nLeft = 0;
			this.divMain.form.sta00.setOffsetLeft(nLeft);
			this.divMain.form.staCommonTitle05.setOffsetLeft(28);
			this.divMain.form.div00.setOffsetLeft(nLeft);
		}
		this.divMain.form.resetScroll();
	}
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 예/아니오/나중에 제출 라디오 값 변경 시
 * @param  : obj		   - [object]Radio
 * @param  : e		       - [string]ItemChangeEventInfo
 * @return : N/A
 */
this.rdo00_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	this.fnSetDivIns(e.postvalue);
};

/**
 * 이전문항 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.divMain_btnTitle04_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var param = {langCd: this.fvLangCd,
		dataset: this.dsSearch.saveXML(),
		dataset2: this.dsTrnRltList.saveXML(),
		};
		 
	this.smfSetWorkPage("pa_eds_vff_os::eds_vffos06_m01.xfdl",param,false);
};

/**
 * 제출하기 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.submisson_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var popupParams = {
			callback: this.fnPopupCallback,
			sender: obj, // sender 지정
			params: {
				procType : 'search'
				,langCd: this.fvLangCd
			},
			titlebar : false,
		};
	this.smfIsMobile() ? this.smfDialog("_auto", "pa_eds_vff_os::eds_vffos07_p02.xfdl", popupParams, null, null,  600, 840) : this.smfDialog("_auto", "pa_eds_vff_os::eds_vffos07_p02.xfdl", popupParams);
};

/**
 * 이전 버튼 클릭 시
 * @param  : obj		   - [object]Button
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.divMain_btnTitle15_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divMain.form.div00.form.div01.form.rdo00.set_value(null);
	this.divMain.form.div00.form.div01.set_visible(true);
	this.divMain.form.div00.form.divIns.set_visible(false);
	this.divMain.form.div00.form.staTitle12.set_visible(false);
	
	this.divMain.form.btnTitle04.set_visible(true);
	this.divMain.form.btnTitle02.set_visible(true);
	this.divMain.form.btnTitle02.set_enable(false);
	this.divMain.form.btnTitle15.set_visible(false);
	this.divMain.form.btnTitle02_1.set_visible(false);
	this.fnSetcompSize();
};

/**
 * 화면 사이즈 변경시
 * @param  : obj			- [object]Div
 * @param  : e				- [string]SizeEventInfo
 * @return : N/A
 */
this.divMain_staCommonTitle06_onsize = function(obj:nexacro.Static,e:nexacro.SizeEventInfo)
{
	this.fnSetcompSize();
};

/**
 * 마우스 왼쪽버튼 눌렀을 시
 * @param  : obj			- [object]Static
 * @param  : e				- [string]MouseEventInfo
 * @return : N/A
 */
this.divMain_div00_div00_staPrg_onlbuttondown = function(obj:nexacro.Static,e:nexacro.MouseEventInfo)
{
	this.fvIsBtnDrag = true;
};

/**
 * 마우스 왼쪽버튼 떼었을 시
 * @param  : obj			- [object]Static
 * @param  : e				- [string]MouseEventInfo
 * @return : N/A
 */
this.divMain_div00_div00_staPrg_onlbuttonup = function(obj:nexacro.Static,e:nexacro.MouseEventInfo)
{
	this.fvIsBtnDrag = false;
};

/**
 * 마우스 포인터가 움직일 시
 * @param  : obj			- [object]Div
 * @param  : e				- [string]MouseEventInfo
 * @return : N/A
 */
this.divMain_div00_div00_onmousemove = function(obj:nexacro.Div,e:nexacro.MouseEventInfo)
{
	if (this.fvIsBtnDrag){
		this.fvOpacityVal = Math.floor(e.canvasx * 100 / obj.getOffsetWidth());
		this.fnSetSurvOpacity(this.fvOpacityVal);
	}
};

/**
 * 투명도바 클릭 시
 * @param  : obj		   - [object]ProgressBar
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.divMain_div00_div00_pgb00_onclick = function(obj:nexacro.ProgressBar,e:nexacro.ClickEventInfo)
{
	var posValue = Math.floor(e.clientx/30) * 10;
	this.fvOpacityVal = posValue;
	this.fnSetSurvOpacity(posValue);
};

/**
 * Edit창 변화 (제출하기 버튼 활성화)
 * @param  : obj		   - [object]Edit
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.Edit_oninput = function(obj:nexacro.Edit,e:nexacro.InputEventInfo)
{
	var isEnable = true;
	for(var i = 0; i < 6; i++){
		if(this.isNil(obj.parent['edt0' + i].value)){
			isEnable = false;
		}
	}
	this.divMain.form.btnTitle02_1.set_enable(isEnable);
};

/**
 * form size 변화 (PC)
 * @param  : obj		   - [object]Edit
 * @param  : e		       - [string]ClickEventInfo
 * @return : N/A
 */
this.eds_vffos07_m01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	if(!this.smfIsMobile()){
		this.fnSetcompSizeP();
	}
};
]]></Script>
  </Form>
</FDL>
