    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 
*  @FileName 	eds_tados03_p02.xfdl 
*  @Creator 	kangjihye
*  @CreateDate 	2023.02.21
*  @Desction    교육설문 - 공지사항
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.02.21          Kangjihye                   최초 생성 
*******************************************************************************
*/ 
 this.fv_param;	// 파라메터 세팅
/************************************************************************************************
 * 변수 선언 영역
 ************************************************************************************************/
this.fnonload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	//폼 초기화
	this.smfInitPopup(obj);

	// 전달받은 파라메터 값 세팅
	this.fv_param = this.smfGetPopupParams();
	this._cddcCd = this.fv_param.cddcOrgCd;
	this.screenScCd = this.fv_param.screenScCd;
}; 

/**
 * form 닫히고 param 넘김
 * @param  : sSelectLangCd	- 언어코드
 * @return : N/A
 */
this.fnConfirm = function (){
	this.smfSendResponseToOpener({
		"urlName" : "gotoNext",
	});
	this.close(false);
}

/**
 * 참여하기 Btn 클릭
 * @param  : sSelectLangCd	- 언어코드
 * @return : N/A
 */
this.div00_btnNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnConfirm();
};

/**
 * 'X' 클릭
 * @param  : sSelectLangCd	- 언어코드
 * @return : N/A
 */
this.div00_btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};

/**
 * CheckBox 클릭
 * @param  : sSelectLangCd	- 언어코드
 * @return : N/A
 */
this.CheckBox_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	var ck = this.div00.form;
	if(ck.CheckBox00.value == true && ck.CheckBox01.value == true && ck.CheckBox02.value == true && ck.CheckBox03.value == true){
		this.div00.form.btnNext.set_enable(true);
	}else{
		this.div00.form.btnNext.set_enable(false);
	}
};

/**
 * Static 클릭
 * @param  : N/A
 * @return : N/A
 */
this.Static_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	if(obj == this.div00.form.sta00){
		this.div00.form.CheckBox00.value == false ? this.div00.form.CheckBox00.set_value(true) : this.div00.form.CheckBox00.set_value(false);
	}
	if(obj == this.div00.form.sta01){
		this.div00.form.CheckBox01.value == false ? this.div00.form.CheckBox01.set_value(true) : this.div00.form.CheckBox01.set_value(false);
	}
	if(obj == this.div00.form.sta02){
		this.div00.form.CheckBox02.value == false ? this.div00.form.CheckBox02.set_value(true) : this.div00.form.CheckBox02.set_value(false);
	}
	if(obj == this.div00.form.sta03){
		this.div00.form.CheckBox03.value == false ? this.div00.form.CheckBox03.set_value(true) : this.div00.form.CheckBox03.set_value(false);
	}
	
	var ck = this.div00.form;
	if(ck.CheckBox00.value == true && ck.CheckBox01.value == true && ck.CheckBox02.value == true && ck.CheckBox03.value == true){
		this.div00.form.btnNext.set_enable(true);
	}else{
		this.div00.form.btnNext.set_enable(false);
	}
};
]]></Script>
