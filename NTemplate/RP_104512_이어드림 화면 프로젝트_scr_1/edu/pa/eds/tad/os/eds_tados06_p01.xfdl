  <Form id="eds_tados03_p02" width="680" height="720" titletext="교육설문-교원능력(학생학적확인_팝업)" onload="fnonload" cssclass="frm_Pop_bgTrsprt">
    <Layouts>
      <Layout height="720" width="680" screenid="ScreenDeskTop">
        <Div id="div00" taborder="0" left="30" top="30" cssclass="div_WF_SurvPopLine" initvalueid="ivDivAccessibilityOff" width="619" height="650" text="div00">
          <Layouts>
            <Layout>
              <Static id="sta01_00_00" taborder="0" text="&lt;b v='true'&gt;꼭 읽어 보세요&lt;/b&gt;" left="227" top="30" height="39" cssclass="sta_WF_SurvCautionL" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" width="227" color="#ff3f3f" usedecorate="true"/>
              <Static id="sta00_00_01_00_00" taborder="1" left="30" top="99" height="50" cssclass="sta_WF_survGrayDot18" initvalueid="ivStcAccessibilityOn" usedecorate="true" text="&lt;b v='true'&gt;학부모님의 체크리스형 응답과 서술형 응답은 익명성이 보장되어 선생님께 제공됩니다. &lt;/b&gt;" width="555"/>
              <Static id="sta01_00" taborder="2" text="※ 다만, 서술형 문항 응답 시 본인 또는 자녀가 누구인지 유출할 수 있는 내용을 기술하지 않는 것이 적절합니다." left="40" top="sta00_00_01_00_00:2" height="45" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" width="533"/>
              <CheckBox id="CheckBox00" taborder="11" left="40" width="27" height="29" value="false" top="202" cssclass="chk_WF_SurveyT18" onclick="CheckBox_onclick"/>
              <Static id="sta00" taborder="10" text="확인하였음" left="CheckBox00:5" top="sta01_00:5" height="30" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" width="70" onclick="Static_onclick"/>
              <Static id="sta00_00_01_00_00_01" taborder="3" left="30" top="sta00:10" height="50" cssclass="sta_WF_survGrayDot18" initvalueid="ivStcAccessibilityOn" usedecorate="true" text="&lt;b v='true'&gt;선생님의 학습지도와 생활지도 등에 대한 문항을 잘 읽고, 학부모님의 의견을 진솔하게 응답하여 주시기 바랍니다.&lt;/b&gt;" width="555"/>
              <CheckBox id="CheckBox01" taborder="12" left="40" width="27" height="29" value="false" top="297" cssclass="chk_WF_SurveyT18" onclick="CheckBox_onclick"/>
              <Static id="sta01" taborder="13" text="확인하였음" left="CheckBox01:5" top="sta00_00_01_00_00_01:5" height="30" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" width="70" onclick="Static_onclick"/>
              <Static id="sta00_00_01_00_00_01_01" taborder="9" left="30" top="sta01:10" height="78" cssclass="sta_WF_survGrayDot18" initvalueid="ivStcAccessibilityOn" usedecorate="true" text="&lt;b v='true'&gt;교육활동과 관련이 없는 &lt;fc v='red'&gt;부적절한 답변(인신공격, 모욕, 성희롱 등)&lt;/fc&gt;을 제출하는 경우 &lt;fc v='red'&gt;관련 법령에 따라 처벌&lt;/fc&gt;받을 수 있고, &lt;fc v='red'&gt;교육활동 침해행위에 따른 조치&lt;/fc&gt;를 받을 수 있습니다.&lt;/b&gt;" width="555"/>
              <CheckBox id="CheckBox02" taborder="15" left="40" width="27" height="29" value="false" top="420" cssclass="chk_WF_SurveyT18" text="" onclick="CheckBox_onclick"/>
              <Static id="sta02" taborder="14" text="확인하였음" left="CheckBox02:5" top="sta00_00_01_00_00_01_01:5" height="30" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" letterSpacing="-1px" width="70" onclick="Static_onclick"/>
              <Static id="sta00_00_01_00_00_01_00" taborder="4" left="30" top="sta02:10" height="54" cssclass="sta_WF_survGrayDot18" initvalueid="ivStcAccessibilityOn" usedecorate="true" text="&lt;b v='true'&gt;제출 후에는 수정, 재 제출이 불가하니 제출 전 정확하게 응답하였는지 확인하고, 제출하여 주시기 바랍니다. &lt;/b&gt;" width="555"/>
