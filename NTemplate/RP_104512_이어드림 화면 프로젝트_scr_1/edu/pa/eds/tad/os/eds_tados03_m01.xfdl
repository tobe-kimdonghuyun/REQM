    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">check</Col>
            <Col id="inDatasets">dsSearch=dsSearch dsRaonKeyData=dsRaonKeyData</Col>
            <Col id="url">/eds_tad_os03_001.do</Col>
            <Col id="outDatasets">dsResult=dsResult dsApiResponseList=dsApiResponseList dsEvlYr=dsEvlYr dsSchEvlPrdInfo=dsSchEvlPrdInfo</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256" description="시도교육청코드"/>
          <Column id="evlYr" type="STRING" size="256" description="검사연도"/>
          <Column id="shlCd" type="STRING" size="256" description="학교코드"/>
          <Column id="shlNm" type="STRING" size="256" description="학교명"/>
          <Column id="cetNo" type="STRING" size="256" description="학생주소우편번호"/>
          <Column id="shlCrseScCd" type="STRING" size="256"/>
          <Column id="shlCrseScNm" type="STRING" size="256"/>
          <Column id="shlKndScCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="evlYr">2022</Col>
            <Col id="shlCrseScCd">1</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsResult" useclientlayout="true">
        <ColumnInfo>
          <Column id="tadStuInvlNo" type="STRING" size="256"/>
          <Column id="stuFlnm" type="STRING" size="256"/>
          <Column id="grd" type="STRING" size="256"/>
          <Column id="clsNm" type="STRING" size="256"/>
          <Column id="clsNo" type="STRING" size="256"/>
          <Column id="stuOflEvlYn" type="STRING" size="256"/>
          <Column id="exmplShlYn" type="STRING" size="256"/>
          <Column id="stuEduActPtptRspnsYn" type="STRING" size="256"/>
          <Column id="shlCrseScCd" type="STRING" size="256"/>
          <Column id="shlKndScCd" type="STRING" size="256"/>
          <Column id="stuOnlEvlYn" type="STRING" size="256"/>
          <Column id="stuEvlCmptnYn" type="STRING" size="256"/>
          <Column id="cddcNm" type="STRING" size="256"/>
          <Column id="evlPaptCnt" type="STRING" size="256"/>
          <Column id="dnPaptCnt" type="STRING" size="256" description="미참여수"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsApiResponseList" useclientlayout="true">
        <ColumnInfo>
          <Column id="code" type="STRING" size="256" description="연계상태값"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsEvlYr" useclientlayout="true">
        <ColumnInfo>
          <Column id="evlYr" type="STRING" size="256" description=""/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsSchEvlPrdInfo" useclientlayout="true">
        <ColumnInfo>
          <Column id="shlEvlPrdYn" type="STRING" size="256" description=""/>
          <Column id="evlBgngYmd" type="STRING" size="256"/>
          <Column id="evlEndYmd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsRaonKeyData">
        <ColumnInfo>
          <Column id="elemid" type="STRING" size="256"/>
          <Column id="transkeyUuid" type="STRING" size="256"/>
          <Column id="tk_col_check" type="STRING" size="256"/>
          <Column id="transkey" type="STRING" size="256"/>
          <Column id="transkey_HM" type="STRING" size="256"/>
          <Column id="hid_key_data" type="STRING" size="256"/>
          <Column id="e2e" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 
*  @FileName 	eds_tados03_m01.xfdl 
*  @Creator 	kangjihye
*  @CreateDate 	2023.01.12
*  @Desction    교육설문 - 교원평가 
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.01.12           Kangjihye                   최초 생성 
*******************************************************************************
*/
 
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요) 
 ************************************************************************************************/
  
/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 this.fv_param;	// 파라메터 
 this.fv_evlKndScCd="2";
 this.fvIsInfoOpen = false;
 this.fv_sta01Top = 0;
 this.fv_isQr = "";
 this.staKeyValue;
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnonload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.fnSetcompSizeP();
	// 폼 초기화
	this.smfInitForm(obj);
	var sDate = new Date();
	
	//검사연도 세팅
	var sYear  = sDate.getFullYear().toString();
	
	// 전달받은 파라메터 값 세팅
	this.fv_param = this.smfGetFormParams();
	this._cddcCd = this.fv_param.cddcCd;
	this._cddcNm = this.fv_param.cddcNm;
	this.dsSearch.setColumn(0, "cddcCd", this._cddcCd);
	this.dsSearch.setColumn(0, "evlYr" , sYear);
	//스크롤바 갱신
	this.smfResetScroll(this);
//	this.div00.form.btnIdnty.set_enable( false );
	this.div00.form.div01.form.btn999.set_enable(true);
	if (this.smfIsMobile()) {
		this.fvIsInfoOpen = false;
		this.fnSetcompSize();
		this.divTop.form.fnSetPtptPrd(this._cddcNm);
	}
	this.fv_sta01Top = this.div00.form.div00.form.sta01.top;
	
	// ---------------------------------------------------------------------------------------------
// 	// 테스트 값 Set
// 	this.dsSearch.setColumn(0, "shlCd", "K100000383");
// 	this.dsSearch.setColumn(0, "shlNm", "김화공업고등학교");	
// 	this.dsSearch.setColumn(0, "shlKndScCd", "04");
// 	this.dsSearch.setColumn(0, "shlCrseScCd", " ");
// 	this.dsSearch.setColumn(0, "cetNo", "LWXCWE");
	// ---------------------------------------------------------------------------------------------
	
	
	// ---------------------------------------------------------------------------------------------
	// QR코드로 진입시
	// 예) http://dev.eduro.go.kr/nxui/index.html?edstype=CA&edsdata=K100000001K100000383BADVRV
	// this.fv_param
	// "autoLogin": "Y",
	// "edsType": "CA",
	// "edsData": "K100000001K100000383BADVRV"
	// ---------------------------------------------------------------------------------------------
	// 	this.fv_param.autoLogin = "Y";
	// 	this.fv_param.edsType = "CA";
	// 	this.fv_param.edsData = "K100000001K100000383YVUA38";
	
	// 	아래 주석 삭제 해야함
//  	 	this.fv_param.subsys = "EDS";
//  		this.fv_param.edsType = "CB";
// 		this.fv_param.edsData = "K100000001K100000383YVUA38";
	if (this.smfIsNull(this.fv_param.edsType) == false && this.smfIsNull(this.fv_param.edsData) == false && this.fv_param.edsData.length != 10) 
	{
		this.divTop.form.fnSetPtptPrd("교육청");
		if (this.fv_param.edsType.length != 2 || this.fv_param.edsData.length != 26) 
		{
			this.smfAlertEds('잘못된 접근입니다.', [], function() {
				window.location.href = document.location.href.split("?")[0];
			});
			return;
		}

		// 전역변수
		this.fv_isQr = "Y";
		this._cddcCd = this.fv_param.edsData.substr(0, 10);	// 시도교육청코드
		
		// 조회조건
		this.dsSearch.setColumn(0, "cddcCd", this.fv_param.edsData.substr( 0, 10));	// 시도교육청코드
		this.dsSearch.setColumn(0, "evlYr" , this.smfToday().substr(0, 4));			// 평가연도
		this.dsSearch.setColumn(0, "shlCd" , this.fv_param.edsData.substr(10, 10));	// 학교코드
		this.dsSearch.setColumn(0, "cetNo" , this.fv_param.edsData.substr(20,  6));	// 인증번호
		
		// -----------------------------------------------------------------------------------------
		// 참여하기
		// -----------------------------------------------------------------------------------------
		this.div00_btnIdnty_onclick();
	}else{
		if ( this.smfIsNull(this.fv_param.edsType) == false && this.smfIsNull(this.fv_param.edsData) == false && this.fv_param.edsData.length == 10) {
			this._cddcCd = this.fv_param.edsData.substr(0, 10);
			this.dsSearch.setColumn(0, "cddcCd", this.fv_param.edsData.substr( 0, 10)	);	// 시도교육청코드
		} else if ( ( this.smfIsNull(this.fv_param.edsType) == false && this.smfIsNull(this.fv_param.edsData) == true ) || ( this.smfIsNull(this.fv_param.edsType) == false && this.smfIsNull(this.fv_param.edsData) == false && this.fv_param.edsData.length < 10) )  {
			this.smfAlertEds('잘못된 접근입니다.', [], function() {
				window.location.href = document.location.href.split("?")[0];
			});
			return;
		}
		//@KBR 가상키보드 사용
		var objOption1 = {
			target : this.div00.form.div00.form.edtCetNo, // 대상 Edit 컴포넌트 [필수]
			targetKey : this.div00.form.div00.form.staTransKey, // Edit와 쌍으로 있는 마우스입력 체크박스(static) [필수]
			dataType:"A",
 	 		maxLength : 6,
			bshow : true
			//maxLength(default 8)
			//kbdType(default "qwerty")
		}
		this.smfInitTranskey(objOption1);
	}
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnPopupCallback = function(e, sender)
{
	if(e.urlName == "searchShl"){			//학교찾기 팝업 콜백
		if(e.row){
			this.dsSearch.setColumn(0, "shlCd", e.row["orgCd"]);
			this.dsSearch.setColumn(0, "shlNm", e.row["kornOrgNm"]);	
			this.dsSearch.setColumn(0, "shlKndScCd", e.row["shlKndScCd"]);
			this.dsSearch.setColumn(0, "shlCrseScCd", "2");
		}
	}
// 	else if(e.urlName == "gotoNext"){
// 		var param = {
// 			cddcCd : this._cddcCd,
// 			cddcNm : this._cddcNm,
// 			evlKndScCd : this.fv_evlKndScCd,
// 			shlCrseScCd :  "2", // this.dsSearch.getColumn(0,"shlCrseScCd") ,
// 			dataset: this.dsResult.saveXML(),
// 			dataset1 : this.dsSearch.saveXML(),			
// 		};
// 		
// 		trace(this.dsResult.saveXML());
// 		trace("****************************************************************");
// 		trace(this.dsSearch.saveXML());		
// 		trace("****************************************************************");
// 		
// 		this.smfSetWorkPage("pa_eds_tad_os::eds_tados09_m01.xfdl", param, false);
// 	}
	else{
		if(e.row){
			for(var sKey in e.row){
				this.dsShlList.setColumn(0, sKey, e.row[sKey]);
			}
		}
		this.dsSearch.copyRow(0, this.dsShlList, 0);
		this.fnSetComp();
	}
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * 학생조회 service
 **/
this.fnStuChk = function () {
	this.smfSearchService("check")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return; 
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){ 	//본인확인 성공
				
				trace("■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■");
				trace(this.dsEvlYr.saveXML());
				trace(this.dsSearch.saveXML());
				trace(this.dsSchEvlPrdInfo.saveXML());
				trace(this.dsResult.saveXML());
				trace("■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■■");
				
				this.dsSearch.setColumn(0, "shlCrseScCd", this.dsResult.getColumn(0, "shlCrseScCd"));	// 학교과정구분코드
				this.dsSearch.setColumn(0, "shlKndScCd" , this.dsResult.getColumn(0, "shlKndScCd"));	// 학교종류구분코드
				this.dsSearch.setColumn(0, "evlYr" 		, this.dsEvlYr.getColumn(0, "evlYr"));			// 학년도
			    if ( this.dsResult.getColumn(0,"stuOflEvlYn") == null || this.dsResult.getColumn(0,"stuOflEvlYn") == "Y" || this.dsResult.getColumn(0,"evlPaptCnt") == 0 ) 
				{
				    this.smfAlertEds('학생만족도조사에 참여하실 수 없습니다.\n온라인 학생만족도조사 참여학생이 아닙니다.\n\n소속 학교에 문의 후 다시 시도해 주시기 바랍니다.\n감사합니다.',null,null,null,{align:'left'});
					return false;
				}
				// 학생온라인평가여부
				else if (this.dsResult.getColumn(0,"stuOnlEvlYn") != "Y" )
				{
					this.smfAlertEds('학생만족도/의견조사에 참여하실 수 없습니다.\n온라인 학생 의견/만족도조사 진행학교가 아닙니다.\n\n소속학교에 문의 후 다시 시도해주시기 바랍니다.\n감사합니다.',null,null,null,{align:'left'});
					return false;
				}
				// 학생만족도조사완료여부
				else if (this.dsResult.getColumn(0,"stuEvlCmptnYn") != "N")
				{
					this.smfAlertEds('학생 의견/만족도조사에 참여하실 수 없습니다.\n학생 의견/만족도조사가 종료되었습니다.\n\n소속학교에 문의 후 다시 시도해주시기 바랍니다.\n감사합니다.',null,null,null,{align:'left'});
					return false;
				}
				// 학교평가기간여부
				else if(this.dsSchEvlPrdInfo.getColumn(0, "shlEvlPrdYn") != "Y")
				{
					var msg = "학생 의견/만족도조사에 참여하실 수 없습니다.\n학생 의견/만족도조사 참여기간이 아닙니다.";
					if (this.isNil(this.dsSchEvlPrdInfo.getColumn(0, "evlBgngYmd")) == false && 
						this.isNil(this.dsSchEvlPrdInfo.getColumn(0, "evlEndYmd" )) == false)
					{
						msg += "\n참여기간(" + this.dsSchEvlPrdInfo.getColumn(0, "evlBgngYmd") + " ~ " + this.dsSchEvlPrdInfo.getColumn(0, "evlEndYmd" ) + ")";
					}
					msg += "\n\n소속학교에 문의 후 다시 시도해주시기 바랍니다.\n감사합니다.";
					this.smfAlertEds(msg,null,null,null,{align:'left'});
					return false;
				}
				else
				{
					this.div00.form.div00.form.sta01.set_text("학적이 확인되었습니다");
					this.div00.form.div00.form.sta01.set_color("#6b5dc0");
					
					if (this.smfIsMobile() == false) 
					{
						this.div00.form.div00.form.sta01.set_cssclass('sta_WF_Txt16R');
					}
					else 
					{
						this.div00.form.div00.form.sta01.set_cssclass('sta_WF_Txt28B');
						this.div00.form.div00.form.sta01.set_textAlign("center");
					}
				}
				if ( this.fv_isQr == "Y" ) {
					if ( this.dsResult.getColumn(0,"cddcNm") != null && this.dsResult.getColumn(0,"cddcNm") != "" ) {
						this._cddcNm = this.dsResult.getColumn(0,"cddcNm");
					}
				}
// ========================= 원래 팝업이었음 =========================				
// 				var popupParams = {
// 					callback: this.fnPopupCallback,		// 콜백함수 지정
// 					sender: obj, 						// sender 지정
// 					params: {							// 팝업 전달 파라메터 지정
// 						procType: "none",				// 처리타입 지정
// 						cddcOrgCd : this._cddcCd,			
// 						evlKndScCd : "2",
// 					},
// 					titlebar : false
// 				};
// 				this.smfDialog("_auto", "pa_eds_tad_os::eds_tados03_p02.xfdl" ,popupParams);
				// 교원능력평가소개 페이지로 바로 이동
				var param = {
					procType: "none",	
					cddcCd : this._cddcCd,
					cddcNm : this._cddcNm,
					evlKndScCd : "2",
					shlCrseScCd :"2", // this.dsSearch.getColumn(0,"shlCrseScCd"),
					dataset: this.dsResult.saveXML(),
					dataset1 : this.dsSearch.saveXML(),	
				};
				this.smfSetWorkPage("pa_eds_tad_os::eds_tados09_m01.xfdl", param, false);
			}
			else 
			{
			    //if(this.dsApiResponseList.getColumn(0, 'code') == "error-02" ) {
					this.smfAlertEds('입력한 정보가 정확하지 않습니다.\n필수입력항목(학교, 참여번호)을 확인 후 다시 시도해 주시기 바랍니다.\n\n소속 학교에 문의 후 다시 시도해 주시기 바랍니다.\n감사합니다.',null,null,null,{align:'left'});
				//}
				this.div00.form.div00.form.sta01.set_text("입력한 정보가 정확하지 않습니다.");				
			
				if (this.smfIsMobile() == false) 
				{
					this.div00.form.div00.form.sta01.set_cssclass('sta_WF_Txt16B,sta_WF_SurvRedTxt');
				}
				else 
				{
					this.div00.form.div00.form.sta01.set_cssclass('sta_WF_Txt28B,sta_WF_SurvRedTxt');
					this.div00.form.div00.form.sta01.set_color("#ff3f3f");
					this.div00.form.div00.form.sta01.set_textAlign("center");
				}
			}
		});
}

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 /**
 * 가상키패드
 * @param  : obj			- edit 컴포넌트
 * @return : N/A
 */
this.fnTransKey = function(obj)
{
	var arrComp = [obj];  //대상 Edit component List: array [필수]
	
	if(!this.smfIsMobile()){
		// 키보드보안 적용여부
		var sRtnVal = this.smfGetValueTranskey(obj);
	
		if(sRtnVal == "transkey"){	//선택
			var sVal = this.smfGetEncDataTranskey(arrComp);
			this.staKeyValue = true;
			this.dsSearch.setColumn(0, 'cetNo', null);
			
			//전달받은 파라미터 데이터셋에 담기
			this.smfConvRaonDataToDs(this.dsRaonKeyData,arrComp,sVal);
			this.dsRaonKeyData.setColumn(0, 'tk_col_check', "transkey");
		}else if(sRtnVal == "e2e"){ //미선택
			sVal= obj.value;
			this.staKeyValue = false;
			
			this.dsRaonKeyData.setColumn(0, 'transkey', null);
			this.dsRaonKeyData.setColumn(0, 'tk_col_check', 'e2e');
		}
	}else{	// 모바일
		if(this.div00.form.div00.form.chkKeyboardScrtyYn.value == true){
			var sVal = this.smfGetEncDataTranskey(arrComp);
			this.dsSearch.setColumn(0, 'cetNo', null);
			
			//전달받은 파라미터 데이터셋에 담기
			this.smfConvRaonDataToDs(this.dsRaonKeyData,arrComp,sVal);
			this.dsRaonKeyData.setColumn(0, 'tk_col_check', "transkey");
		}else{
			this.dsRaonKeyData.setColumn(0, 'transkey', null);
			this.dsRaonKeyData.setColumn(0, 'tk_col_check', 'e2e');
		}
	}
}
 
 /**
 * 컴포넌트 사이즈 조절
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnSetcompSize = function(){
	if (this.fvIsInfoOpen){ // 안내문 오픈 > 닫힘
		this.div00.form.div01.set_height(93);		
		this.div00.form.div01.form.btn999.set_cssclass('btn_WF_SurvDropUp');
		this.fvIsInfoOpen = false;
		this.smfResetScroll(this.div00.form);
	}else{ // 안내문 닫힘 > 오픈
		this.div00.form.div01.form.btn999.set_cssclass('btn_WF_SurvDropDown');
		this.fvIsInfoOpen = true;
		this.smfResetScroll(this.div00.form.div01.form);
		this.smfResetScroll(this.div00.form.div00.form);
		this.div00.form.div01.set_height(this.div00.form.div01.form.sta05.getOffsetBottom() + 20);
		this.smfResetScroll(this.div00.form);
	}
	this.div00.setOffsetHeight(this.div00.height + 60);
	this.smfResetScroll(this);
}

/**
 * 컴포넌트 사이즈 조절(PC)
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnSetcompSizeP = function(){
	if (!this.smfIsMobile()){
		var nMaxWidth = 1200 - nexacro.toNumber(this._getHScrollBarSize());
		var nFormWidth = this.getOffsetWidth();
		var vLeft = Math.floor((this.getOffsetWidth() - (this.div00.form.div00.getOffsetWidth()))/2);
		var bLeft = Math.floor((this.getOffsetWidth() - (this.div00.form.btnIdnty.getOffsetWidth()))/2);
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.div00.form.div01.setOffsetLeft(10 + nLeft);
			this.div00.form.div00.setOffsetLeft(10 + vLeft);
			this.div00.form.btnIdnty.setOffsetLeft(10 + bLeft);
		}else{
			var nLeft = 0;
			this.div00.form.div01.setOffsetLeft(nLeft);
			this.div00.form.div00.setOffsetLeft(vLeft);
			this.div00.form.btnIdnty.setOffsetLeft(bLeft);
		}
		this.div00.form.resetScroll();
	}
};


 /************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 /**
 * 학교찾기 버튼 Click
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.div00_div00_btnShlSrch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var shlNm  = "";
	
	if( this.div00.form.div00.form.edtShl.getLength() > 0  ){
		shlNm  = this.div00.form.div00.form.edtShl.text;
	}
	
	var popupParams = {
		callback: this.fnPopupCallback,		// 콜백함수 지정
		sender: obj, 						// sender 지정
		params: {							// 팝업 전달 파라메터 지정
			procType: "none",				// 처리타입 지정
			cddcOrgCd : this._cddcCd,
			shlNm : shlNm,
		},
		titlebar : false
	};
	
	if (this.smfIsMobile()) {
		this.smfDialog("_auto", "pa_eds_tad_os::eds_tados03_p01.xfdl", popupParams, null, null, 640, 980);
	} else {
		this.smfDialog("_auto", "pa_eds_tad_os::eds_tados03_p01.xfdl", popupParams);
	}
};

 /**
 * 학적확인 버튼 Click
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.div00_div00_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var shlCd = this.dsSearch.getColumn(0, "shlCd");
	if(this.isNil(shlCd)){
		this.smfAlertEds('CM006',['학교명']);
		return;
	}
	
	this.dsSearch.setColumn(0, "cetNo", this.div00.form.div00.form.edtCetNo.value);
	var cerNo = this.dsSearch.getColumn(0, "cetNo");
	if(this.isNil(cerNo)){
		this.smfAlertEds('CM006',['참여번호']);
		return;
	}
	
	this.fnStuChk();	// 학생 조회
};

 /**
 * 참여하기 버튼 Click
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.div00_btnIdnty_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var shlCd = this.dsSearch.getColumn(0, "shlCd");
	if(this.isNil(shlCd)){
		this.smfAlertEds('CM006',['학교명']);
		return;
	}
	
	if ( this.fv_isQr != "Y") 
	{
		var transKey = this.fnTransKey(this.div00.form.div00.form.edtCetNo);
	}
	this.dsSearch.setColumn(0, "cetNo", this.div00.form.div00.form.edtCetNo.value);
	
	if (this.smfIsNull(this.div00.form.div00.form.edtCetNo.text)){
		this.smfAlertEds('CM006',['참여번호']);
		this.div00.form.div00.form.edtCetNo.setFocus();
		return;
	}
	console.log(this.div00.form.div00.form.edtCetNo.text);
	this.fnStuChk();	// 학적확인
};

 /**
 * 학교찾기 edit onkeydown
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.div00_div00_edtShl_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(!this.smfIsMobile()){	// PC일 때만 적용
		if(e.keycode == "13" ){	// Enter키
			this.div00_div00_btnShlSrch_onclick(obj,e);
		}
	}
};

 /**
 * 학교찾기 edit onkeyup
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.div00_div00_edtShl_onkeyup = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode == "13" ){	// Enter키
		this.div00_div00_btnShlSrch_onclick(obj,e);
	}
};

 /**
 * 모바일 닫기 버튼
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.div00_div01_btn999_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.smfIsMobile()){	// mobile때만 보임
		this.fnSetcompSize();
	}
};

/**
 * QR코드로 진입시 'fnTransCallback' 함수가 없으면 ERROR
 */
this.fnTransCallback = function(trnNm)
{
	trace("trnNm : " + trnNm);
};

 /**
 * form size 조절
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.div00_div01_sta07_onsize = function(obj:nexacro.Static,e:nexacro.SizeEventInfo)
{
    this.fvIsInfoOpen = !this.fvIsInfoOpen;
	this.fnSetcompSize();
};

 /**
 * 참여번호 edit onkeyup
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.div00_div00_edtCetNo_onkeyup = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{	
	this.div00.form.div00.form.edtCetNo.updateToDataset();
};

 /**
 * ? 버튼 Click(가상 키패드 설명 팝업)
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.div00_div00_btnScrtyTooltip_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var popupParams = {
		callback: this.fnPopupCallback,
		sender: obj, // sender 지정
		params: {
			procType : 'search'
		},
		titlebar : false,
	};

	this.smfIsMobile() ? this.smfDialog("_auto", "pa_eds_tad_os::eds_tados03_p03.xfdl", popupParams, null, null, 600, 960) : this.smfDialog("_auto", "pa_eds_tad_os::eds_tados03_p03.xfdl", popupParams);
};

 /**
 * 가상키패드 선택/ 미선택 옵션
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.div00_div00_chkKeyboardScrtyYn_canchange = function(obj:nexacro.CheckBox,e:nexacro.ChangeEventInfo)
{
	if(this.smfIsMobile()){ // 모바일/테블릿
		document.getElementsByClassName("staTransKey")[0].children.item(0).click();
	}else{  // 데스크탑
		document.getElementsByClassName("staTransKey")[0].children.item(0).children.item(0).click();
	}
	this.smfClearTranskey(this.div00.form.div00.form.edtCetNo);
	this.div00.form.div00.form.edtCetNo.value = "";
};

 /**
 * form size 조절 (PC)
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.eds_tados03_m01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnSetcompSizeP();
};

/**
 * PC일 때 taborder시 가상키패드 노출
 * @param  : obj			- [object]Edit
 * @param  : e				- [string]SetFocusEventInfo
 * @return : N/A
 */
this.div00_div00_edtCetNo_onsetfocus = function(obj:nexacro.Edit,e:nexacro.SetFocusEventInfo)
{
	var orderTabCk = document.getElementsByClassName("staTransKey")[0].children.item(0).children.item(0);
	
	// if() PC이고 키패드가 켜져있을 때만
	if(!this.smfIsMobile() && orderTabCk.src.indexOf("on") > -1){
		orderTabCk.click();
		orderTabCk.click();
	}
};

/**
 * 가상키패드 결함 수동 제거(PC)
 * @param  : obj			- [object]Static
 * @param  : e
 * @return : N/A
 */
this.div00_div00_staTransKey_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	this.fnTransKey(this.div00.form.div00.form.edtCetNo);
	// PC
	if(!this.smfIsMobile() && this.staKeyValue == true){
		this.div00.form.div00.form.edtCetNo.set_value("");
	}
};

/**
 * 가상키패드 결함 수동 제거(모바일)
 * @param  : obj			- [object]CheckBox
 * @param  : e				- [string]SetFocusEventInfo
 * @return : N/A
 */
this.div00_div00_chkKeyboardScrtyYn_onclick = function(obj:nexacro.CheckBox,e:nexacro.ClickEventInfo)
{
	this.fnTransKey(this.div00.form.div00.form.edtCetNo);
	// mobile
	if(this.smfIsMobile()){
		this.smfClearTranskey(this.div00.form.div00.form.edtCetNo);
		this.this.div00.form.div00.form.edtCetNo.value = "";
	}
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="div00.form.div00.form.edtShl" propid="value" datasetid="dsSearch" columnid="shlNm"/>
      <BindItem id="item1" compid="div00.form.div00.form.edtCrseNm" propid="value" datasetid="dsSearch" columnid="shlCrseScNm"/>
      <BindItem id="item2" compid="div00.form.div00.form.edtCetNo" propid="value" datasetid="dsSearch" columnid="cetNo"/>
    </Bind>
  </Form>
