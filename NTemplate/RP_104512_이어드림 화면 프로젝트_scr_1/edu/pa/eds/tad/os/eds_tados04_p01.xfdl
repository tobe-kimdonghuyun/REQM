              <Button id="btnClose" taborder="5" top="30" width="36" height="36" cssclass="btn_WF_SurvPopClose" initvalueid="ivBtnAccessibilityButton" right="30" onclick="div00_btnClose_onclick" accessibilitylabel="팝업 닫기"/>
