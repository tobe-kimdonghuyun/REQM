              <Button id="btnCancel" taborder="3" text="취소" left="btnConfirm:20" width="160" height="50" cssclass="btn_WF_SurvCnfrm3_Gray" initvalueid="ivBtnAccessibilityButton" top="262" onclick="div00_btnCancel_onclick"/>
