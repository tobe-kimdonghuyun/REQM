    <Objects>
      <Dataset id="dsResult">
        <ColumnInfo>
          <Column id="avr" type="STRING" size="256"/>
          <Column id="ytk1" type="STRING" size="256"/>
          <Column id="ytk2" type="STRING" size="256"/>
          <Column id="ytk3" type="STRING" size="256"/>
          <Column id="ytk4" type="STRING" size="256"/>
          <Column id="ytk5" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="avr">3.0</Col>
            <Col id="ytk1">1</Col>
            <Col id="ytk2">1</Col>
            <Col id="ytk3">1</Col>
            <Col id="ytk4">1</Col>
            <Col id="ytk5">1</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsQtnYdstkCnt" useclientlayout="true">
        <ColumnInfo>
          <Column id="Avr" type="STRING" size="256"/>
          <Column id="Ydstk1" type="STRING" size="256"/>
          <Column id="Ydstk2" type="STRING" size="256"/>
          <Column id="Ydstk3" type="STRING" size="256"/>
          <Column id="Ydstk4" type="STRING" size="256"/>
          <Column id="Ydstk5" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsQstnRspns" useclientlayout="true">
        <ColumnInfo>
          <Column id="evlYr" type="STRING" size="256"/>
          <Column id="shlCd" type="STRING" size="256"/>
          <Column id="evlKndScCd" type="STRING" size="256"/>
          <Column id="evlPaptId" type="STRING" size="256"/>
          <Column id="quitmNo1RspnsCdValue" type="STRING" size="256"/>
          <Column id="quitmNo2RspnsCdValue" type="STRING" size="256"/>
          <Column id="quitmNo3RspnsCdValue" type="STRING" size="256"/>
          <Column id="quitmNo4RspnsCdValue" type="STRING" size="256"/>
          <Column id="quitmNo5RspnsCdValue" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsBasicQstnRspns" useclientlayout="true">
        <ColumnInfo>
          <Column id="evlYr" type="STRING" size="256"/>
          <Column id="instCd" type="STRING" size="256"/>
          <Column id="shlKndgrScCd" type="STRING" size="256"/>
          <Column id="evlKndScCd" type="STRING" size="256"/>
          <Column id="quitmSn" type="STRING" size="256"/>
          <Column id="qstnQuitmCn" type="STRING" size="256"/>
          <Column id="sorSn" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 
*  @FileName 	eds_tados03_p01.xfdl 
*  @Creator 	kangjihye
*  @CreateDate 	2023.01.12
*  @Desction    교육설문 - 교원평가 
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.01.12           Kangjihye                   최초 생성 
*******************************************************************************
*/ 

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 this.fv_param;	// 파라메터 세팅
 this.fn_name;
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 this.fnonload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	//폼 초기화
	this.smfInitPopup(obj);

	// 전달받은 파라메터 값 세팅
	this.fv_param = this.smfGetPopupParams();
	this._cddcCd = this.fv_param.cddcOrgCd;
	this.dsQtnYdstkCnt.loadXML(this.fv_param.dataset);
	this.dsQstnRspns.loadXML(this.fv_param.dataset1);
	this.dsBasicQstnRspns.loadXML(this.fv_param.dataset2);

	//this.dsSearch.setColumn(0, "cddcOrgCd", this._cddcCd);
	
	console.log("POPUP-CALL ");
	console.log(this.dsQstnRspns.saveXML());
	console.log(this.dsQtnYdstkCnt.getColumn(0, "Avr"));
	// ---------------------------------------------------------------------------------------------
	// PC
	// ---------------------------------------------------------------------------------------------
	if (this.smfIsMobile() == false) {
		if (this.dsQstnRspns.getRowCount() > 0) {
			this.div00.form.btnAddSvy.set_visible(false);
			this.div00.form.btnCancel.set_left(182+160+20);
			this.div00.form.btnConfirm.set_left(182);
		}
 		if(this.dsQtnYdstkCnt.getColumn(0, "Avr") == 0.0 || this.dsQtnYdstkCnt.getColumn(0, "Avr") == 0){
 			this.div00.form.grd00.set_visible(false);
			this.div00.form.sta00.set_visible(true);
 		}
		if ( this.dsBasicQstnRspns.getRowCount() == 0 ) {
			this.div00.form.btnAddSvy.set_visible(false);
			this.div00.form.btnCancel.set_left(182+160+20);
			this.div00.form.btnConfirm.set_left(182);
		}
	}
	// ---------------------------------------------------------------------------------------------
	// MOBILE
	// ---------------------------------------------------------------------------------------------
	else {
		// 평균점수(grid head에 표기, binding 안됨, script로 강제 세팅)
		this.div00.form.grd00.setCellProperty("head", 1, "text", this.dsQtnYdstkCnt.getColumn(0, "Avr"));
		
		// 교육부설문참여 완료일 경우 버튼 숨김 및 팝업창 사이즈 조절
		if (this.dsQstnRspns.getRowCount() > 0) {
			this.div00.form.btnAddSvy.set_visible(false);
			this.div00.set_height(this.div00.height - 110);
			this.set_height(this.smfCurScreenInfo()[1] - 110);
		}
		
		if(this.dsQtnYdstkCnt.getColumn(0, "Avr") == 0.0 || this.dsQtnYdstkCnt.getColumn(0, "Avr") == 0){
 			this.div00.form.grd00.set_visible(false);
			this.div00.form.sta00.set_visible(true);
			
			this.div00.set_height(this.div00.height - 110);
 			this.div00.form.grd00.set_height(this.div00.form.grd00.height - 110);
 			this.div00.form.sta00.set_height(this.div00.form.sta00.height - 110);
			this.div00.form.btnConfirm.set_top(this.div00.form.btnConfirm.top - 110);
			this.div00.form.btnCancel.set_top(this.div00.form.btnCancel.top - 110);
			this.div00.form.btnAddSvy.set_top(this.div00.form.btnAddSvy.top - 110);
			this.set_height(this.smfCurScreenInfo()[1] - 110);
 		}
		
		// 교육부 설문이 없을 경우
		if ( this.dsBasicQstnRspns.getRowCount() == 0 ) {
		    this.div00.form.btnAddSvy.set_visible(false);
			this.div00.set_height(this.div00.height - 110);
			this.set_height(this.smfCurScreenInfo()[1] - 110);
		}
	}
};
 
 
 /************************************************************************************************
 * CallBack 
 ************************************************************************************************/
 this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;   
 }

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 /**
 * @description 버튼 클릭시
 */
 this.fnBtnClick = function(){

	this.smfSendResponseToOpener({
		"urlName" : this.fn_name,
	});

	this.close(true);
};

this.div00_btnAddSvy_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	 this.fn_name = "addSearch";
	 this.fnBtnClick();
};

this.div00_btnConfirm_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fn_name = "confirm";
	this.fnBtnClick();
};

this.div00_btnCancel_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fn_name = "cancel";
	this.fnBtnClick();
};

this.div00_btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};

this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(true);
};
]]></Script>
  </Form>
</FDL>
