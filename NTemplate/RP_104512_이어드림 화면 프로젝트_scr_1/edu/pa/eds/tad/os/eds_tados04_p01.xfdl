              <Static id="sta98" taborder="7" left="0" top="0" cssclass="sta_WF_GDSize" text="30" visible="false" initvalueid="ivStcAccessibilityOff" width="30" bottom="0"/>
              <Static id="sta00" taborder="8" text="제출 하시겠습니까?" left="30" top="88" width="648" height="141" initvalueid="ivGrdAccessibilityOn" cssclass="sta_WF_S03Tit_B34" visible="false"/>
