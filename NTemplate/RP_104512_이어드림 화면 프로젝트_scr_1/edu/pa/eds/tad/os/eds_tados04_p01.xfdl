        <Button id="btnClose" taborder="2" top="0" width="30" height="30" cssclass="btn_Pop_close_W" initvalueid="ivBtnAccessibilityButton" right="-81" visible="false" onclick="btnClose_onclick" accessibilitylabel="팝업 닫기"/>
