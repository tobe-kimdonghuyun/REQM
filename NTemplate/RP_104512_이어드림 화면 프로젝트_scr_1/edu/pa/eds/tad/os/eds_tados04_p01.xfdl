              <Static id="sta99" left="0" top="0" height="50" right="0" text="50" taborder="5"/>
              <Static id="sta98" left="0" top="0" width="40" taborder="6" bottom="0" text="40"/>
              <Grid id="grd00" formatid="format00" left="40" top="111" height="397" right="40" cssclass="grd_WF_S03Data_M" taborder="1"/>
              <Button id="btnConfirm" left="40" top="558" width="255" height="100" cssclass="btn_WF_SurvCnfrm3_M" taborder="2"/>
              <Button id="btnCancel" top="558" width="254" height="100" cssclass="btn_WF_SurvCnfrm3_Gray_M" left="306" taborder="3"/>
              <Button id="btnAddSvy" left="40" top="668" height="100" cssclass="btn_WF_Survey3_M" right="40" taborder="4"/>
              <Static id="sta00" left="40" top="112" height="390" text="제출 하시겠습니까?" cssclass="sta_WF_Txt34B" textAlign="center" width="520"/>
