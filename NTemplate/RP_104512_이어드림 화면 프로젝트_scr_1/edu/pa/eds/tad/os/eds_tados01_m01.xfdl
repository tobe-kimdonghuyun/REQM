            <Col id="cddcNm">제주특별자치도교육청</Col>
            <Col id="info">02-399-9549, 02-1396 (월~금요일 / 공휴일 제외  09:00 ~ 18:00 ) </Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 교육설문 > 교원능력개발평가
*  @FileName 	eds_tados03_m01.xfdl 
*  @Creator 	kangjihye
*  @CreateDate 	2023.01.10
*  @Desction    교원능력개발평가-시도교육청 선택
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.01.10          Kangjihye                   최초 생성 
*******************************************************************************
*/
 
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	//스크롤바 갱신
	this.smfResetScroll(this);
};


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 /**
 * @description 시도교육청 버튼 css 변경
*/
 this.fnSetCddcCssclass = function(objBtn)
{
	var objComps = this.div00.form.divCddcList.form.components;
	for(var i in objComps){
		var objComp = objComps[i];
		if(objComp.cddcCd){
			objComp.set_cssclass("btn_WF_SurvMain03"); //clear
		}
	}
	objBtn.set_cssclass("btn_WF_SurvMain03S");  //select
}
 
 /************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description '시도교육청 버튼' 클릭 시
*/
this.cddcCdBtn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sCddcCd = obj.cddcCd;

	var findRow = this.dsCddcList.findRow("cddcCd",sCddcCd);
	
 	var cddcName = this.dsCddcList.getColumn(findRow,"cddcNm");
 	var cddcInfo = this.dsCddcList.getColumn(findRow,"info");

	//시도교육청 문의전화 안내글 세팅
	this.div00.form.divCddcList.form.staCddcNm.set_text(cddcName+" 문의전화");
	this.div00.form.divCddcList.form.stacddcInfo.set_text(cddcInfo);

	//버튼 css 변경
	this.fnSetCddcCssclass(obj);
	
	//'설문참여하기' 버튼 활성화
	this.div00.form.btnQstnPtpt.set_visible(true);
	
	//스크롤바 갱신
	this.div00.form.divCddcList.form.resetScroll();
	
	//시도교육청 정보 세팅
	this._cddcCd = obj.cddcCd;
	this._cddcNm = this.dsCddcList.getColumn(findRow,"cddcNm");
};

/**
 * @description '설문참여하기' 버튼 클릭 시
*/
this.div00_btnQstnPtpt_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.getOwnerFrame().form._surveyInfo_cddcCd = this._cddcCd;
	this.smfSetCddcCode(this._cddcCd);

	var param = {
		cddcCd : this._cddcCd,
		cddcNm : this._cddcNm
	};
	
	this.smfSetWorkPage("pa_eds_tad_os::eds_tados02_m01.xfdl", param, false);	
};

this.eds_tados01_m01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnSetcompSizeP();
};

/**
 * 컴포넌트 사이즈 조절(PC)
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnSetcompSizeP = function(){
	if (!this.smfIsMobile()){
		var nMaxWidth = 1200 - nexacro.toNumber(this._getHScrollBarSize());
		var nFormWidth = this.getOffsetWidth();
		var vLeft = Math.floor((this.getOffsetWidth() - (this.div00.form.divCddcList.getOffsetWidth()))/2);
		var bLeft = Math.floor((this.getOffsetWidth() - (this.div00.form.btnQstnPtpt.getOffsetWidth()))/2);
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			//this.div00.form.div01.setOffsetLeft(10 + nLeft);
			this.div00.form.divCddcList.setOffsetLeft(10 + vLeft);
			this.div00.form.btnQstnPtpt.setOffsetLeft(10 + bLeft);
		}else{
			var nLeft = 0;
			//this.div00.form.div01.setOffsetLeft(nLeft);
			this.div00.form.divCddcList.setOffsetLeft(nLeft);
			this.div00.form.btnQstnPtpt.setOffsetLeft(bLeft);
		}
		this.div00.form.resetScroll();
	}
};
]]></Script>
  </Form>
</FDL>
