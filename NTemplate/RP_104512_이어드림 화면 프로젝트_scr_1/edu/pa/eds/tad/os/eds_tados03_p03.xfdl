<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="eds_tados03_p03" width="620" height="510" titletext="교육설문-교원능력(참여번호로그인_팝업)" onload="fnOnload" cssclass="frm_Pop_bgTrsprt">
    <Layouts>
      <Layout height="510" width="620" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="divMain" taborder="1" left="0" top="0" cssclass="div_WF_SurvPopLine" initvalueid="ivDivAccessibilityOff" width="620" height="510" background="#ffffff">
          <Layouts>
            <Layout>
              <Static id="sta00" taborder="0" text="본인확인번호 입력 시 가상키패드를 적용하면 개인정보를 보다 안전하게 보호할 수 있습니다." left="20" top="20" width="464" height="55" cssclass="sta_WF_Txt20B" initvalueid="ivStcAccessibilityOn" usedecorate="false" fittocontents="height"/>
              <Static id="sta01" taborder="1" text="만약, 모바일 기기에서 가상키패드가 나타나지 않는 경우&#13;&#10;브라우저 쿠키 설정 등으로 발생하는 문제입니다.&#13;&#10;쿠키 차단 설정을 해제해 주시면 가상키패드가 활성화됩니다." left="20" top="sta00:4" height="73" cssclass="sta_WF_Txt18" initvalueid="ivStcAccessibilityOn" usedecorate="false" right="50" letterSpacing="-1px" fittocontents="height"/>
              <Static id="sta02" taborder="2" text="브라우저별 설정 방법" left="20" top="sta01:19" width="560" height="40" cssclass="sta_WF_SurvCautionS" initvalueid="ivStcAccessibilityOn" fittocontents="height" verticalAlign="top"/>
              <Static id="sta03" taborder="3" text="&lt;b v='true'&gt;Safari&lt;/b&gt; : 설정  &gt; Safari &gt; 모든 쿠키 차단 해제" left="20" top="sta02:10" width="560" height="40" cssclass="sta_WF_survGrayDot14" initvalueid="ivStcAccessibilityOn" usedecorate="true" fittocontents="height" verticalAlign="top" minheight="40" maxheight=""/>
              <Static id="sta04" taborder="4" text="&lt;b v='true'&gt;Chrome&lt;/b&gt; : 설정  &gt; 사이트 설정 &gt; 쿠키 &gt;모든 쿠키 차단 해체" left="20" top="sta03:0" width="560" height="40" cssclass="sta_WF_survGrayDot14" initvalueid="ivStcAccessibilityOn" usedecorate="true" fittocontents="height" verticalAlign="top" minheight="40" maxheight=""/>
              <Static id="sta05" taborder="5" text="&lt;b v='true'&gt;Edge&lt;/b&gt; : 설정  &gt; 사이트 사용 권한 &gt; 쿠키 &gt; 쿠키 허용" left="20" top="sta04:0" width="560" height="40" cssclass="sta_WF_survGrayDot14" initvalueid="ivStcAccessibilityOn" usedecorate="true" fittocontents="height" verticalAlign="top" minheight="40" maxheight=""/>
              <Static id="sta06" taborder="6" text="&lt;b v='true'&gt;삼성브러우저&lt;/b&gt; : 설정 &gt; 개인정보 보호 및 보안 &gt; 쿠키 허용" left="20" top="sta05:0" width="560" height="40" cssclass="sta_WF_survGrayDot14" initvalueid="ivStcAccessibilityOn" usedecorate="true" fittocontents="height" verticalAlign="top" minheight="40" maxheight=""/>
              <Static id="sta07" taborder="7" text="&lt;b v='true'&gt;Opera&lt;/b&gt; : 설정 &gt; 쿠키 &gt; 사용함" left="20" top="sta06:0" width="560" height="40" cssclass="sta_WF_survGrayDot14" initvalueid="ivStcAccessibilityOn" usedecorate="true" fittocontents="height" verticalAlign="top" minheight="40" maxheight=""/>
              <Static id="sta08" taborder="8" text="※ 광고차단 앱이 설치된 경우 앱 삭제 등 모바일 설정에 따라 추가 조치가 필요할 수 있습니다.&#13;&#10; 있습니다." left="20" top="sta07:10" width="560" height="40" cssclass="sta_WF_Txt14" initvalueid="ivStcAccessibilityOn" usedecorate="false" letterSpacing="-1px" fittocontents="height" verticalAlign="top"/>
              <Button id="btnClose" taborder="9" top="20" width="36" height="36" cssclass="btn_WF_SurvPopClose" initvalueid="ivBtnAccessibilityButton" right="20" onclick="div00_btnClose_onclick" accessibilitylabel="팝업닫기"/>
              <Static id="sta09" taborder="10" left="0" top="0" height="20" cssclass="sta_WF_GDSize" text="20" visible="false" initvalueid="ivStcAccessibilityOff" right="0"/>
              <Static id="sta10" taborder="11" left="0" top="20" cssclass="sta_WF_GDSize" text="20" visible="false" initvalueid="ivStcAccessibilityOff" width="20" bottom="0"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="sta00" cssclass="sta_WF_Txt26B" left="40" top="66" height="75" letterSpacing="-2px" maxwidth="" taborder="0" right="40" fittocontents="height"/>
              <Static id="sta01" left="40" top="sta00:10" height="144" cssclass="sta_WF_Txt24" letterSpacing="-1px" maxwidth="" taborder="1" fittocontents="height" text="만약, 모바일 기기에서 가상키패드가 나타나지 않는 경우 브라우저 쿠키 설정 등으로 발생하는 문제입니다.&#13;&#10;쿠키 차단 설정을 해제해 주시면 가상키패드가 활성화됩니다." width="514"/>
              <Static id="sta02" left="40" top="sta01:20" height="44" cssclass="sta_WF_SurvCaution28B" taborder="2" fittocontents="height" right="40"/>
              <Static id="sta03" left="40" top="sta02:10" height="74" cssclass="sta_WF_survDot24L" usedecorate="true" taborder="3" fittocontents="height" text="&lt;b v='true'&gt;Safari&lt;/b&gt;&#13;&#10;설정  &gt; Safari &gt; 모든 쿠키 차단 해제" width="514" minheight="74" maxheight=""/>
              <Static id="sta04" left="40" top="sta03:10" height="74" cssclass="sta_WF_survDot24L" taborder="4" fittocontents="height" text="&lt;b v='true'&gt;Chrome&lt;/b&gt;&#13;&#10;설정  &gt; 사이트 설정 &gt; 쿠키 &gt;모든 쿠키 차단 해체" width="514" minheight="74" maxheight=""/>
              <Static id="sta05" left="40" top="sta04:10" height="74" cssclass="sta_WF_survDot24L" taborder="5" fittocontents="height" right="34" text="&lt;b v='true'&gt;Edge&lt;/b&gt;&#13;&#10;설정  &gt; 사이트 사용 권한 &gt; 쿠키 &gt; 쿠키 허용" minheight="74" maxheight=""/>
              <Static id="sta06" left="40" top="sta05:10" height="74" cssclass="sta_WF_survDot24L" taborder="6" fittocontents="height" right="40" text="&lt;b v='true'&gt;삼성브러우저&lt;/b&gt;&#13;&#10;설정 &gt; 개인정보 보호 및 보안 &gt; 쿠키 허용" minheight="74" maxheight=""/>
              <Static id="sta07" left="40" top="sta06:10" height="74" cssclass="sta_WF_survDot24L" taborder="7" width="514" fittocontents="height" text="&lt;b v='true'&gt;Opera&lt;/b&gt;&#13;&#10;설정 &gt; 쿠키 &gt; 사용함" minheight="74" maxheight=""/>
              <Static id="sta08" height="84" left="40" top="sta07:40" width="514" fittocontents="height" verticalAlign="top" taborder="8" text="※ 광고차단 앱이 설치된 경우 앱 삭제 등 모바일 설정에 따라 추가 조치가 필요할 수 있습니다." cssclass="sta_WF_Txt24"/>
              <Static id="sta09" height="20" left="0" top="0" right="0" text="20" taborder="10"/>
              <Static id="sta10" text="20" width="20" left="0" top="20" height="100" taborder="11"/>
              <Button id="btnClose" top="20" width="36" height="36" right="30" taborder="9"/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
      <Layout name="Layout0" screenid="mobile,tablet" width="600" height="960" mobileorientation="portrait" type="default">
        <Div id="divMain" height="960" left="0" top="0" width="600"/>
      </Layout>
    </Layouts>
    <Objects/>
    <Script type="xscript5.1"><![CDATA[/**
* 
*  @MenuPath    교육설문 > 학교폭력실태조사 > 가상키보드 안내
