			dataset2 : this.dsNtcList.saveXML(),
		};
		this.smfSetWorkPage("pa_eds_tad_os::eds_tados04_t02.xfdl", param, false);
	}
	*/
};

this.div00_div00_div05_btnClean_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
		this.div00.form.div00.form.div05.form.cmbCondi.set_index(0);
		this.div00.form.div00.form.div05.form.edtSearch.set_value("");
};

// 목록 Btn클릭
this.div00_div00_btnList_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//초기화
	this.div00_div00_div05_btnClean_onclick();
		var param = {
			cddcCd : this._cddcCd,
			cddcNm : this._cddcNm,
			evlKndScCd : this.fv_evlKndScCd,
			shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd"),
			popCk : this.popCk,
			dataset: this.dsPreset.saveXML(),
			dataset1 : this.dsPreset1.saveXML(),
			dataset2 : this.dsChldList.saveXML(),
			schdataset :  this.dsSearch.saveXML(),		
		};
		this.smfSetWorkPage("pa_eds_tad_os::eds_tados04_t01.xfdl", param, false);
};

/****************************************************************
* 이전글, 다음글
****************************************************************/

//제목, id 셋팅
this.fnShowPreNxt = function ( val )
{
	//변수
	var preTitle;
	var nxtTitle;
	
	if( this.currow < this.dsNtcList.getRowCount()-1 ){
	
		this.preTitle = this.dsNtcList.getColumn(this.currow+1, "ntcMteTitlNm");
		this.preNtcMteId = this.dsNtcList.getColumn(this.currow+1, "ntcMteId");
		
	}else{
	
		this.preTitle = "이전 글이 없습니다.";
		this.preNtcMteId = null;
	}
	
	if( this.currow > 0 ){
	
		this.nxtTitle = this.dsNtcList.getColumn(this.currow-1, "ntcMteTitlNm");
		this.nxtNtcMteId = this.dsNtcList.getColumn(this.currow-1, "ntcMteId");
		
	}else{
	
		this.nxtTitle = "다음 글이 없습니다.";
		this.nxtNtcMteId = null;
		
	}
	
	//화면에 셋팅
	this.div00.form.div00.form.div00.form.edtPre.set_value(this.preTitle);	//이전글 제목
	this.div00.form.div00.form.div00.form.edtNext.set_value(this.nxtTitle);	//다음글 제목

};

//글 이동
this.fnMoveNtc = function( ntcMteId, rn )
{
	var param = {
		cddcCd 		: this._cddcCd,
		cddcNm      : this._cddcNm,
		shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd"),
		evlKndScCd  : this.fv_evlKndScCd,
		condi		: this.div00.form.div00.form.div05.form.cmbCondi.index,
		kwd			: this.div00.form.div00.form.div05.form.edtSearch.text,
		rn  		: rn,
		dataset		: this.dsPreset.saveXML(),
		dataset1 	: this.dsPreset1.saveXML(),
		dataset2 	: this.dsNtcList.saveXML(),
		datachild 	: this.dsChldList.saveXML(),
		ntcMteId 	: ntcMteId,
	};
	
	this.smfSetWorkPage("pa_eds_tad_os::eds_tados04_t02.xfdl", param, false);
}


//이전글 클릭
this.div00_div00_div00_btnPre_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
	if( this.isNotNil(this.preNtcMteId) ){
		
		//글 이동 함수 호출
		this.fnMoveNtc( this.preNtcMteId, this.fv_param.rn + 1 );
		
	}
};

//다음글(최신글) 클릭
this.div00_div00_div00_btnNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

	if( this.isNotNil(this.nxtNtcMteId) ){
		
		//글 이동 함수 호출
		this.fnMoveNtc( this.nxtNtcMteId, this.fv_param.rn - 1 );
		
	}
	
};

this.div00_div00_div00_edtTitle_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	
};

this.eds_tados04_t02_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnSetcompSizeP();
};

/**
 * 컴포넌트 사이즈 조절(PC)
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnSetcompSizeP = function(){
	if (!this.smfIsMobile()){
		var nMaxWidth = 1200 - nexacro.toNumber(this._getHScrollBarSize());
		var nFormWidth = this.getOffsetWidth();
		var vLeft = Math.floor((this.getOffsetWidth() - (this.div00.form.div00.getOffsetWidth()))/2);
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.div00.form.div01.setOffsetLeft(10 + nLeft);
			this.div00.form.div00.setOffsetLeft(10 + vLeft);
		}else{
			var nLeft = 0;
			this.div00.form.div01.setOffsetLeft(10);
			this.div00.form.div00.setOffsetLeft(10);
		}
		this.div00.form.resetScroll();
	}
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="div00.form.div00.form.div05.form.edtSearch" propid="value" datasetid="dsSearch" columnid="srchKw"/>
    </Bind>
  </Form>
