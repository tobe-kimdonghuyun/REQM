          <Column id="evlYr" type="STRING" size="256" description="검사연도"/>
          <Column id="shlCd" type="STRING" size="256" description="학교코드"/>
          <Column id="shlNm" type="STRING" size="256" description="학교명"/>
          <Column id="cetNo" type="STRING" size="256" description="학생주소우편번호"/>
          <Column id="shlCrseScCd" type="STRING" size="256"/>
          <Column id="shlCrseScNm" type="STRING" size="256"/>
          <Column id="shlKndScCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsApiResponseList" useclientlayout="true">
        <ColumnInfo>
          <Column id="code" type="STRING" size="256" description="연계상태값"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsChldList" useclientlayout="true">
        <ColumnInfo>
          <Column id="tadStuInvlNo" type="STRING" size="256"/>
          <Column id="stuFlnm" type="STRING" size="256"/>
          <Column id="grd" type="STRING" size="256"/>
          <Column id="clsNm" type="STRING" size="256"/>
          <Column id="clsNo" type="STRING" size="256"/>
          <Column id="schpaOflEvlYn" type="STRING" size="256"/>
          <Column id="schpaCetNo" type="STRING" size="256"/>
          <Column id="eduActPtptRspnsYn" type="STRING" size="256"/>
          <Column id="chldInfoScCd" type="STRING" size="256"/>
          <Column id="schorStuDpcnYn" type="STRING" size="256"/>
          <Column id="exmplShlYn" type="STRING" size="256"/>
          <Column id="chldInfoScCdNm" type="STRING" size="256"/>
          <Column id="shlCrseScCd" type="STRING" size="256"/>
          <Column id="shlKndScCd" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 
*  @FileName 	eds_tados04_t01.xfdl 
*  @Creator 	kangjihye
*  @CreateDate 	2023.02.08
*  @Desction    교육설문 - 공지사항
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.02.08          Kangjihye                   최초 생성 
*******************************************************************************
*/ 

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 this.fv_param;	// 파라메터 세팅
 this.fv_evlTrprId;
 this.btn_param;
 this.fv_index;
 this.fv_evlKndScCd="2";
 
 this.preNtcMteId;	//이전글 id
 this.nxtNtcMteId;	//다음글 id
 this.currow;		//dsNtcList에서 현재 게시물의 row
 this.popCk;
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnonload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.fnSetcompSizeP();
	// 폼 초기화
	this.smfInitForm(obj);
	var sDate = new Date();
	
	//검사연도 세팅
	var sYear  = sDate.getFullYear().toString();
	// 전달받은 파라메터 값 세팅
	this.fv_param = this.smfGetFormParams();
	
	
	this._cddcCd = this.fv_param.cddcCd;
	this._cddcNm = this.fv_param.cddcNm;
	if ( this.smfIsMobile() ) {
		this.divTop.form.fnSetPtptPrd(this._cddcNm);
	}
	this.fv_evlKndScCd = this.fv_param.evlKndScCd;
	this.popCk = this.fv_param.popCk;
	
	this.dsSearch.setColumn(0, "cddcCd", this._cddcCd);
	this.dsSearch.setColumn(0, "evlYr" , sYear);
	this.dsPreset.loadXML(this.fv_param.dataset);
	this.dsPreset1.loadXML(this.fv_param.dataset1);
	this.dsNtcList.loadXML(this.fv_param.dataset2);
	this.dsChldList.loadXML(this.fv_param.datachild);
	this.currow = this.fv_param.rn - 1;
	
	this.div00.form.div00.form.div05.form.cmbCondi.set_index(this.fv_param.condi);
	this.div00.form.div00.form.div05.form.edtSearch.set_value(this.fv_param.kwd);
	
	this.fv_index = this.fv_param.ntcMteId;
	//스크롤바 갱신
	this.smfResetScroll(this);
	
	//데이터 셋팅
	var j = this.dsNtcList.findRow("ntcMteId", this.fv_index);
	this.div00.form.div00.form.div00.form.edtIndex.set_value(this.fv_param.rn);									//번호
	this.div00.form.div00.form.div00.form.edtTitle.set_text(this.dsNtcList.getColumn(j, "ntcMteTitlNm"));		//제목
	this.div00.form.div00.form.div00.form.txtMain.set_value(this.dsNtcList.getColumn(j, "eduQstnNtcMteCn"));	//내용
	var regDt = this.dsNtcList.getColumn(j, "regDt");															//등록일자
	var edtDate = regDt.substr(0, 4) + "." + regDt.substr(4, 2) + "." + regDt.substr(6, 2);
	this.div00.form.div00.form.div00.form.edtDate.set_value(edtDate);				
	
	//이전글, 다음글 셋팅
	this.fnShowPreNxt(this.fv_index);

};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnPopupCallback = function(e, sender)
{
	this.popCk = "1";	// 1로 값 변경
	
	if(e.urlName == "gotoNext"){
		if( this.fv_evlKndScCd == "2"){	// 학생
			var param = {
				cddcCd : this._cddcCd,
				cddcNm : this._cddcNm,
				evlKndScCd : this.fv_evlKndScCd,
				shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd"), // 2,
				popCk : this.popCk,
				dataset: this.dsPreset.saveXML(),
				dataset1 : this.dsPreset1.saveXML(),			
			};
			this.smfSetWorkPage("pa_eds_tad_os::eds_tados04_m01.xfdl", param, false);
		}else{	// 학부모
			var param = {
				cddcCd : this._cddcCd,
				cddcNm : this._cddcNm,
				shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd"),
				popCk : this.popCk,
				evlKndScCd : this.fv_evlKndScCd,
				dataset: this.dsPreset.saveXML(),
				dataset1: this.dsPreset1.saveXML(),	
				dataset2 : this.dsChldList.saveXML(),
				schdataset :  this.dsSearch.saveXML(),
		};
		this.smfSetWorkPage("pa_eds_tad_os::eds_tados07_m01.xfdl", param, false);
		}
	}
}

/************************************************************************
 * 상단 tab 버튼 
 ************************************************************************/
/**
*	교원능력개발 소개 tab button Click
**/
this.div00_div01_btnSurvey_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if( this.fv_evlKndScCd == "2" ){
		var param = {
			cddcCd : this._cddcCd,
			cddcNm : this._cddcNm,
			evlKndScCd : this.fv_evlKndScCd,	
			shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd"),
			popCk : this.popCk,
			dataset: this.dsPreset.saveXML(),
			dataset1 : this.dsPreset1.saveXML(),
			schdataset :  this.dsSearch.saveXML(),
		};
		this.smfSetWorkPage("pa_eds_tad_os::eds_tados09_m01.xfdl", param, false);
	}else{
		var param = {
			cddcCd : this._cddcCd,
			cddcNm : this._cddcNm,
			shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd") ,
			evlKndScCd : this.fv_evlKndScCd,
			popCk : this.popCk,
			dataset: this.dsPreset.saveXML(),
			dataset1: this.dsPreset1.saveXML(),	
			dataset2 : this.dsChldList.saveXML(),
			schdataset :  this.dsSearch.saveXML(),
		};
		this.smfSetWorkPage("pa_eds_tad_os::eds_tados09_m01.xfdl", param, false);
	}	
};

/**
*	만족도조사참여 tab button Click
**/
this.div00_div01_btnInform_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.popCk == "1"){
		if( this.fv_evlKndScCd == "2" ){
			var param = {
				cddcCd : this._cddcCd,
				cddcNm : this._cddcNm,
				evlKndScCd : this.fv_evlKndScCd,
				shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd"),
				popCK : this.popCk,
				dataset: this.dsPreset.saveXML(),
				dataset1 : this.dsPreset1.saveXML(),
			};
			this.smfSetWorkPage("pa_eds_tad_os::eds_tados04_m01.xfdl", param, false);
		}else{
			var param = {
				cddcCd : this._cddcCd,
				cddcNm : this._cddcNm,
				evlKndScCd : this.fv_evlKndScCd,	
				shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd"),
				popCK : this.popCk,
				dataset: this.dsPreset.saveXML(),
				dataset1: this.dsPreset1.saveXML(),	
				dataset2 : this.dsChldList.saveXML(),
				schdataset :  this.dsSearch.saveXML(),
			};
			this.smfSetWorkPage("pa_eds_tad_os::eds_tados07_m01.xfdl", param, false);
		}
	}else{
		if( this.fv_evlKndScCd == "2" ){	// 학생 팝업 이동
			var popupParams = {
				callback: this.fnPopupCallback,		// 콜백함수 지정
				sender: obj, 						// sender 지정
					params: {							// 팝업 전달 파라메터 지정
					procType: "none",				// 처리타입 지정
					cddcOrgCd : this._cddcCd,			
					evlKndScCd : "2",
					},
				titlebar : false
			};
			this.smfDialog("_auto", "pa_eds_tad_os::eds_tados03_p02.xfdl" ,popupParams);
		}else{	// 학부모 팝업 이동
			var popupParams = {
				callback: this.fnPopupCallback,		// 콜백함수 지정
				sender: obj, 						// sender 지정
					params: {							// 팝업 전달 파라메터 지정
					procType: "none",				// 처리타입 지정
					cddcOrgCd : this._cddcCd,			
					evlKndScCd : this.fv_evlKndScCd,
					},
				titlebar : false
			};
			this.smfDialog("_auto", "pa_eds_tad_os::eds_tados06_p01.xfdl" ,popupParams);
		}
	}
// 	if( this.fv_evlKndScCd == "2" ){
// 		var param = {
// 			cddcCd : this._cddcCd,
// 			cddcNm : this._cddcNm,
// 			evlKndScCd : this.fv_evlKndScCd,
// 			shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd") ,
// 			dataset: this.dsPreset.saveXML(),
// 			dataset1 : this.dsPreset1.saveXML(),
// 			
// 		};
// 		
// 		this.smfSetWorkPage("pa_eds_tad_os::eds_tados04_m01.xfdl", param, false);
// 	}else{
// 		var param = {
// 			cddcCd : this._cddcCd,
// 			cddcNm : this._cddcNm,
// 			evlKndScCd : this.fv_evlKndScCd,	
// 			shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd") ,
// 			dataset: this.dsPreset.saveXML(),
// 			dataset1: this.dsPreset1.saveXML(),	
// 			dataset2 : this.dsChldList.saveXML(),
// 			schdataset :  this.dsSearch.saveXML(),
// 		};
// 		this.smfSetWorkPage("pa_eds_tad_os::eds_tados07_m01.xfdl", param, false);
// 	}
};

/************************************************************************
 * 검색
 ************************************************************************/
this.div00_div00_div05_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnListSelect();
};

this.fnListSelect = function () {
	this.dsSearch.setColumn(0,"instCd",this._cddcCd);
	
	//학교유치원구분코드 1:학교 2:유치원
	this.dsSearch.setColumn(0,"shlKndgrScCd","1");
	
	
	var tadStuInvlNo = this.dsPreset.getColumn(0,"tadStuInvlNo");
	if( this.isNotNil(tadStuInvlNo)){
		this.dsSearch.setColumn(0,"tadStuInvlNo",tadStuInvlNo);
		this.dsSearch.setColumn(0,"evlPaptId",tadStuInvlNo);
	}
	
	var shlCrseScCd =  this.dsPreset1.getColumn(0,"shlCrseScCd");
	if( this.isNotNil(shlCrseScCd)){
		this.dsSearch.setColumn(0,"shlCrseScCd",shlCrseScCd);
	}
	
	var shlCd =  this.dsPreset1.getColumn(0,"shlCd");
	if( this.isNotNil(shlCd)){
		this.dsSearch.setColumn(0,"shlCd",shlCd);
	}
	
	this.smfSearchService("list")
		// 페이징처리
		.paginator(this.grdList, this.divPaging, null, this.dsPageInfo, this.fnListSelect, e)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return; 
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){ //조회 성공
			}
		});
};

this.div00_div00_grdList_oncelldblclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	/*
	if( this.fv_evlKndScCd == "2" ){
