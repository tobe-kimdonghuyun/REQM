    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 
*  @FileName 	eds_tados04_t01.xfdl 
*  @Creator 	kangjihye
*  @CreateDate 	2023.02.08
*  @Desction    교육설문 - 공지사항
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.02.08          Kangjihye                   최초 생성 
*******************************************************************************
*/ 

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
 this.fv_param;	// 파라메터 세팅
 this.fv_evlTrprId;
 this.btn_param;
 this.fv_evlKndScCd="2";
 this.popCk;	// 팝업최초 확인 여부 1: 확인
 
 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnonload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.fnSetcompSizeP();
	// 폼 초기화
	this.smfInitForm(obj);
	
	// 전달받은 파라메터 값 세팅
	this.fv_param = this.smfGetFormParams();
	var sDate = new Date();
	
	//검사연도 세팅
	var sYear  = sDate.getFullYear().toString();
	
	this._cddcCd = this.fv_param.cddcCd;
	this._cddcNm = this.fv_param.cddcNm;
	if ( this.smfIsMobile() ) {
		this.divTop.form.fnSetPtptPrd(this._cddcNm);
	}
	this.fv_evlKndScCd = this.fv_param.evlKndScCd;
	this.dsSearch.setColumn(0, "cddcCd", this._cddcCd);
	this.dsPreset.loadXML(this.fv_param.dataset);
	this.dsPreset1.loadXML(this.fv_param.dataset1);	
	this.dsSearch.loadXML(this.fv_param.schdataset);
	this.dsSearch.setColumn(0, "evlYr" 		, sYear);
	if( this.fv_evlKndScCd == "3" ){
		this.dsChldList.loadXML(this.fv_param.dataset2);
	}
	this.popCk = this.fv_param.popCk;	// 확인/미확인 구분값
	
// 	console.log("~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~");
// 	console.log(this.dsSearch.saveXML() );
// 	console.log(this.dsPreset.saveXML() );
// 	console.log(this.dsPreset1.saveXML() );
// 	console.log(this.dsChldList.saveXML() );
// 	console.log(this.fv_param.dnPaptCnt);
// 	console.log("-------> evlKndScCd : this.fv_evlKndScCd -----> ::  " + this.fv_evlKndScCd );
// 	console.log("~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~");
	
	//스크롤바 갱신
	this.smfResetScroll(this);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnPopupCallback = function(e, sender)
{
	this.popCk = "1";	// 1로 값 변경
	
	if(e.urlName == "gotoNext"){
		if(this.fv_evlKndScCd == "2"){	// 학생
			var param = {
				cddcCd : this._cddcCd,
				cddcNm : this._cddcNm,
				evlKndScCd : this.fv_evlKndScCd,
				shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd"), // 2,
				popCk : this.popCk,
				dataset: this.dsPreset.saveXML(),
				dataset1 : this.dsPreset1.saveXML(),			
			};
			this.smfSetWorkPage("pa_eds_tad_os::eds_tados04_m01.xfdl", param, false);
		}else{	// 학부모
			var param = {
				cddcCd : this._cddcCd,
				cddcNm : this._cddcNm,
				shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd"),
				evlKndScCd : this.fv_evlKndScCd,
				popCk : this.popCk,
				dataset: this.dsPreset.saveXML(),
				dataset1: this.dsPreset1.saveXML(),	
				dataset2 : this.dsChldList.saveXML(),
				schdataset :  this.dsSearch.saveXML(),
		};
		this.smfSetWorkPage("pa_eds_tad_os::eds_tados07_m01.xfdl", param, false);
		}
	}
}

/************************************************************************
 * 상단 tab 버튼 
 ************************************************************************/
/**
*	만족도조사참여 tab button Click
**/
this.div00_div01_btnInform_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	// 최초 확인이 된 상태면 팝업 없이 만족도조사참여로 넘어감
	if(this.popCk == "1"){
		if( this.fv_evlKndScCd == "2" ){
	 		var param = {
	 			cddcCd : this._cddcCd,
	 			cddcNm : this._cddcNm,
	 			evlKndScCd : this.fv_evlKndScCd,
	 			shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd"),
				popCk : this.popCk,
	 			dataset: this.dsPreset.saveXML(),
	 			dataset1 : this.dsPreset1.saveXML(),	
	 		};
	 		this.smfSetWorkPage("pa_eds_tad_os::eds_tados04_m01.xfdl", param, false);
	 	}else{
	 		var param = {
	 			cddcCd : this._cddcCd,
	 			cddcNm : this._cddcNm,
	 			shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd"),
	 			evlKndScCd : this.fv_evlKndScCd,
				popCk : this.popCk,
	 			dataset: this.dsPreset.saveXML(),
	 			dataset1: this.dsPreset1.saveXML(),	
	 			dataset2 : this.dsChldList.saveXML(),
	 			schdataset :  this.dsSearch.saveXML(),
	 		};
	 		this.smfSetWorkPage("pa_eds_tad_os::eds_tados07_m01.xfdl", param, false);
	 	}
	}else{	// 아니면 팝업으로 이동
		if( this.fv_evlKndScCd == "2" ){	// 학생 팝업 이동
			var popupParams = {
				callback: this.fnPopupCallback,		// 콜백함수 지정
				sender: obj, 						// sender 지정
					params: {							// 팝업 전달 파라메터 지정
					procType: "none",				// 처리타입 지정
					cddcOrgCd : this._cddcCd,			
					evlKndScCd : "2",
					},
				titlebar : false
			};
			this.smfDialog("_auto", "pa_eds_tad_os::eds_tados03_p02.xfdl" ,popupParams);
		}else{	// 학부모 팝업 이동
			var popupParams = {
				callback: this.fnPopupCallback,		// 콜백함수 지정
				sender: obj, 						// sender 지정
					params: {							// 팝업 전달 파라메터 지정
					procType: "none",				// 처리타입 지정
					cddcOrgCd : this._cddcCd,			
					evlKndScCd : this.fv_evlKndScCd,
					},
				titlebar : false
			};
			this.smfDialog("_auto", "pa_eds_tad_os::eds_tados06_p01.xfdl" ,popupParams);
		}
	}
};

/**
*	공지사항 tab button Click
**/
this.div00_div01_btnNoti_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if( this.fv_evlKndScCd == "2" ){
		var param = {
			cddcCd : this._cddcCd,
			cddcNm : this._cddcNm,
			evlKndScCd : this.fv_evlKndScCd,
			shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd"),
			popCk : this.popCk,
			dataset: this.dsPreset.saveXML(),
			dataset1 : this.dsPreset1.saveXML(),
			schdataset :  this.dsSearch.saveXML(),
		};
		this.smfSetWorkPage("pa_eds_tad_os::eds_tados04_t01.xfdl", param, false);
	}else{
		var param = {
			cddcCd : this._cddcCd,
			cddcNm : this._cddcNm,
			evlKndScCd : this.fv_evlKndScCd,
			shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd"),
			popCk : this.popCk,
			dataset: this.dsPreset.saveXML(),
			dataset1 : this.dsPreset1.saveXML(),
			dataset2 : this.dsChldList.saveXML(),
			schdataset :  this.dsSearch.saveXML(),
		};
		this.smfSetWorkPage("pa_eds_tad_os::eds_tados04_t01.xfdl", param, false);
	}
};

this.div00_div00_div00_00_sta00_onsize = function(obj:nexacro.Static,e:nexacro.SizeEventInfo)
{
	this.smfResetScroll(this.div00.form.div00.form.div00_00.form);
};

this.eds_tados09_m01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnSetcompSizeP();
};


/**
 * 컴포넌트 사이즈 조절(PC)
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnSetcompSizeP = function(){
	if (!this.smfIsMobile()){
		var nMaxWidth = 1200 - nexacro.toNumber(this._getHScrollBarSize());
		var nFormWidth = this.getOffsetWidth();
		var vLeft = Math.floor((this.getOffsetWidth() - (this.div00.form.div00.getOffsetWidth()))/2);
		var bLeft = Math.floor((this.getOffsetWidth() - (this.div00.form.btnIn.getOffsetWidth()))/2);
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.div00.form.div01.setOffsetLeft(10 + nLeft);
			this.div00.form.div00.setOffsetLeft(10 + vLeft);
			this.div00.form.btnIn.setOffsetLeft(10 + bLeft);
		}else{
			var nLeft = 0;
			this.div00.form.div01.setOffsetLeft(10);
			this.div00.form.div00.setOffsetLeft(10);
			this.div00.form.btnIn.setOffsetLeft(10 + bLeft);
		}
		this.div00.form.resetScroll();
	}
};


/**
*	다음 탭 이동 Btn Click (공지사항으로 이동)
**/
this.div01_btnIn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if( this.fv_evlKndScCd == "2" ){
		var param = {
			cddcCd : this._cddcCd,
			cddcNm : this._cddcNm,
			evlKndScCd : this.fv_evlKndScCd,
			shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd") ,
			popCk : this.popCk,
			dataset: this.dsPreset.saveXML(),
			dataset1 : this.dsPreset1.saveXML(),
			schdataset :  this.dsSearch.saveXML(),	
		};
		this.smfSetWorkPage("pa_eds_tad_os::eds_tados04_t01.xfdl", param, false);
	}else{
		var param = {
			cddcCd : this._cddcCd,
			cddcNm : this._cddcNm,
			evlKndScCd : this.fv_evlKndScCd,
			shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd") ,
			popCk : this.popCk,
			dataset: this.dsPreset.saveXML(),
			dataset1 : this.dsPreset1.saveXML(),
			dataset2 : this.dsChldList.saveXML(),
			schdataset :  this.dsSearch.saveXML(),
		};
		this.smfSetWorkPage("pa_eds_tad_os::eds_tados04_t01.xfdl", param, false);
	}
};
]]></Script>
  </Form>
