 ************************************************************************************************/
this.fnShowDiv03 = function () {
	var bottomDiv02 = this.div00.form.div00.form.div02.getOffsetBottom();
	this.div00.form.div00.form.div03.set_top( bottomDiv02 + 30 );


	if( this.dsEvlprList.rowcount > 0 ){
	
	
	}
	var m_survey_term = "<fc v='#6b5dc0'>만족도조사기간</fc> : " ;
	var dscrpGdccCn = "";
	//if( this.isNotNil(this.fv_evlTrprId) ){
		//evlBgngYmd ~ evlEndYmd
	if( this.dsEvlprList.rowcount> 0 ){	
		//console.log(this.dsEvlprList.saveXML());
		
		var selRow = this.dsEvlprList.findRow("evlTrprId" , this.fv_evlTrprId);
			m_survey_term += this.dsEvlprList.getColumn(0 , "evlBgngYmd") + " ~ " + this.dsEvlprList.getColumn(0 , "evlEndYmd") ;
		dscrpGdccCn = this.dsEvlprList.getColumn(0,"dscrpGdccCn");
	}
	//}
	var sta00Text = "학생만족도조사";
	if ( this.dsEvlprList.getRowCount() > 0 ) {
	    sta00Text = this.dsEvlprList.getColumn(0,"evlprTitlNm");
		if ( this.dsEvlprList.getColumn(0,"evlYn") == "Y" ) {
			this.div00.form.btnTmpSave.set_visible(false);
			this.div00.form.btnSave.set_visible(false);
			this.div00.form.div00.form.div06.set_visible(true);
			this.div00.form.div00.form.grdSvy.set_visible(false);
			this.div00.form.div00.form.sta03.set_visible(false);
			this.div00.form.div00.form.grdTxtSvy.set_visible(false);
		} else {
		    this.div00.form.btnTmpSave.set_visible(true);
			this.div00.form.btnSave.set_visible(true);
			this.div00.form.div00.form.div06.set_visible(false);
			this.div00.form.div00.form.grdSvy.set_visible(true);
			this.div00.form.div00.form.sta03.set_visible(true);
			this.div00.form.div00.form.grdTxtSvy.set_visible(true);
		}
	} else {
		this.div00.form.div00.form.sta03.set_text("");
		this.div00.form.div00.form.sta03.set_visible(false);
	}
	this.div00.form.div00.form.div03.form.sta00.set_text(sta00Text);
	this.div00.form.div00.form.div03.form.sta01.set_text(m_survey_term);
	this.div00.form.div00.form.sta03.set_text(dscrpGdccCn);
};

/************************************************************************************************
 * 설문조회 서비스Call
 ************************************************************************************************/
this.fnListSelect = function () {
	this.dsSearch.setColumn(0,"instCd",this._cddcCd);
	
	//학교유치원구분코드 1:학교 2:유치원
	this.dsSearch.setColumn(0,"shlKndgrScCd","1");
	
	
	var tadStuInvlNo = this.dsPreset.getColumn(0,"tadStuInvlNo");
	if( this.isNotNil(tadStuInvlNo)){
		this.dsSearch.setColumn(0,"tadStuInvlNo",tadStuInvlNo);
		this.dsSearch.setColumn(0,"evlPaptId",tadStuInvlNo);
	}
	
	var shlCrseScCd =  this.dsPreset1.getColumn(0,"shlCrseScCd");
	if( this.isNotNil(shlCrseScCd)){
		this.dsSearch.setColumn(0,"shlCrseScCd",shlCrseScCd);
	}
	
	var shlCd =  this.dsPreset1.getColumn(0,"shlCd");
	if( this.isNotNil(shlCd)){
		this.dsSearch.setColumn(0,"shlCd",shlCd);
	}
	
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return; 
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){ //설문정보조회 성공
			    var chk = this.dsSearch.getColumn(0,"evlprId");
				if( typeof chk == "undefined") {
				    this.dsSearch.setColumn(0,"evlprId", this.dsEvlprList.getColumn(0 ,"evlprId"));
				}

				/**********************************************************/
				//설문 그리드 사이즈 조회된 갯수만큼 그려주기//
				/**********************************************************/
				this.fnGridSetting();
				/**********************************************************/
				//console.log(this.cmbIdxVal);
				this.fnShowList();//설문지 작성
// 				console.log("↔↔↔↔↔↔↔↔↔↔↔↔↔↔↔↔↔");
// 				console.log(this.dsStuList.saveXML());
// 				console.log("↔↔↔↔↔↔↔↔↔↔↔↔↔↔↔↔↔");
// 				console.log(this.dsEvlYdstkList.saveXML());
			}
		});
};


/************************************************************************
 * 설문지 조회 후 Save를 위한 Dataset 설정하기 
 ************************************************************************/
 this.fnAnsDataset = function () {
	
 	this.dsRltList.deleteAll();
	
	for( var i = 0 ; i <  this.dsEvlQuitmAnsList.getRowCount() ; i++ ){
		this.dsRltList.addRow();
		this.dsRltList.setColumn(i ,"rn" 			,  this.dsEvlQuitmAnsList.getColumn( i, "rn") );
		this.dsRltList.setColumn(i ,"quitmSn" 		,  this.dsEvlQuitmAnsList.getColumn( i, "quitmSn") );
		this.dsRltList.setColumn(i ,"quitmScCd" 	,  this.dsEvlQuitmAnsList.getColumn( i, "quitmScCd") );
	
	}
};

/************************************************************************
 * 저장하기 서비스 Call
 ************************************************************************/
this.fnSaveResult = function (val) {
	//답변정보 초기화 
	var sDate = new Date();
	//검사연도 세팅
	var sYear  = sDate.getFullYear().toString();
	this.dsRltInfo.deleteAll();
	this.dsRltInfo.addRow();
	this.dsRltInfo.setColumn(0,"cddcCd",this._cddcCd);
	this.dsRltInfo.setColumn(0,"instCd",this._cddcCd);
	this.dsRltInfo.setColumn(0,"evlYr", sYear );
	//학교유치원구분코드 1:학교 2:유치원
	this.dsRltInfo.setColumn(0,"shlKndgrScCd","1");
	this.dsRltInfo.setColumn(0,"shlKndScCd", this.dsPreset1.getColumn(0,"shlKndScCd"));
	
	var tadStuInvlNo = this.dsSearch.getColumn(0,"tadStuInvlNo");
	if( this.isNotNil(tadStuInvlNo)){
		this.dsRltInfo.setColumn(0,"tadStuInvlNo",tadStuInvlNo);
		this.dsRltInfo.setColumn(0,"evlPaptId",  this.dsEvlList.getColumn(0,"evlPaptId"));
		
	}
	
	var shlCrseScCd =  this.dsPreset1.getColumn(0,"shlCrseScCd");
	if( this.isNotNil(shlCrseScCd)){
		this.dsRltInfo.setColumn(0,"shlCrseScCd",shlCrseScCd);
	}
	
	var shlCd =  this.dsPreset1.getColumn(0,"shlCd");
	if( this.isNotNil(shlCd)){
		this.dsRltInfo.setColumn(0,"shlCd",shlCd);
	}
	//evlprId ::평가지 ID
	this.dsRltInfo.setColumn(0,"evlprId", this.dsSearch.getColumn(0,"evlprId"));
	//evlTrprId ::평가대상자ID
	this.dsRltInfo.setColumn(0,"evlTrprId",this.fv_evlTrprId);
	//tmprStrgYn :임시저장여부
	this.dsRltInfo.setColumn(0,"tmprStrgYn",val);
	
// 	console.log("저장하기전에 저장정보 확인" +  this.dsRltInfo.saveXML());
// 	console.log("저장하기전에 저장정보 확인" +  this.dsRltList.saveXML());
	
	this.smfSaveService("save")
		//
		.showConfirm(false)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return; 
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){ //저장성공
				this.fn_tmpYn = "";
				this.fv_first = this.fv_first+1; 
				 //this.fn_EnableYn = "N";
				 this.fv_dnPaptCnt= Number(this.fv_dnPaptCnt)-1;
				 this.fv_cmptnPtptCnt= Number(this.fv_cmptnPtptCnt)+1;
				 if ( this.smfIsMobile() ) {
					 this.div00.form.div00.form.div00.form.staDnPaptCnt.set_text("미참여 : <fc v='#6b5dc0'>"+this.fv_dnPaptCnt+"건</fc>");
					 this.div00.form.div00.form.div00.form.staCmptnPaptCnt.set_text("참여완료 : <fc v='#6b5dc0'>"+this.fv_cmptnPtptCnt+"건</fc>");
				 }else{
					 this.div00.form.div00.form.div00.form.staDnPaptCnt.set_text("미참여 만족도조사 : <fc v='#6b5dc0'>"+this.fv_dnPaptCnt+"건</fc>");
					 this.div00.form.div00.form.div00.form.staCmptnPaptCnt.set_text("완료한 만족도조사 : <fc v='#6b5dc0'>"+this.fv_cmptnPtptCnt+"건</fc>");
				 }
				if( this.fv_message == "addSearch" ) {
					this.fnAddSearchCall();
					//this.fnGotoAddSvy();
				} else {
					this.fnListSelect();
				}
			}
		});
};


 /************************************************************************************************
 * SHOW PAGE
 ************************************************************************************************/
this.fnShowList = function () {
	this.fv_dnPaptCnt= this.dsResult.getColumn(0,"dnPaptCnt");
	this.fv_cmptnPtptCnt= this.dsResult.getColumn(0,"cmptnPtptCnt");

	if( this.isNil(this.fv_dnPaptCnt) ){
		this.fv_dnPaptCnt = 0 ;
	}
	
	if( this.isNil(this.fv_cmptnPtptCnt) ){
		this.fv_cmptnPtptCnt = 0;
	}
	if ( this.smfIsMobile() ) {
		this.div00.form.div00.form.div00.form.staDnPaptCnt.set_text("미참여 : <fc v='#6b5dc0'>"+this.fv_dnPaptCnt+"건</fc>");
		this.div00.form.div00.form.div00.form.staCmptnPaptCnt.set_text("참여완료 : <fc v='#6b5dc0'>"+this.fv_cmptnPtptCnt+"건</fc>");
	}else{
		this.div00.form.div00.form.div00.form.staDnPaptCnt.set_text("미참여 만족도조사 : <fc v='#6b5dc0'>"+this.fv_dnPaptCnt+"건</fc>");
		this.div00.form.div00.form.div00.form.staCmptnPaptCnt.set_text("완료한 만족도조사 : <fc v='#6b5dc0'>"+this.fv_cmptnPtptCnt+"건</fc>");
	}
	if( this.dsTchList.rowcount > 0 ){
		var chkFirst = this.dsTchCmb.rowcount;
		for(var i=0 ; i < this.dsEvlList.rowcount ; i++ )
		{
			if ( chkFirst > 0 )  {
				var nRow = this.dsTchCmb.findRow("evlTrprEvlprId",this.dsEvlList.getColumn(i,"evlTrprId") + this.dsEvlList.getColumn(i,"evlprId"));
				this.dsTchCmb.setColumn(nRow, "evlYn", this.dsEvlList.getColumn(i,"evlYn"));
			} else {
				var nRow = this.dsTchCmb.addRow();	
				var evlprScNm = this.fnEvlprScNm(this.dsEvlList.getColumn(i,"evlprScCd"));
				var chrgeSbjtCdNm2 = "";
				if ( this.dsEvlList.getColumn(i,"leSbjtNm") != null && this.dsEvlList.getColumn(i,"leSbjtNm") != "" ) {
					if(this.dsEvlList.getColumn(i,"leSbjtNm").length < 8) {
						chrgeSbjtCdNm2 = "[" + this.dsEvlList.getColumn(i,"leSbjtNm") + "]"
					} else {
						chrgeSbjtCdNm2 = "[" + this.dsEvlList.getColumn(i,"leSbjtNm").substring(0,8)+"...]"
					}
				}
				var chrgeSbjtCdNm = this.dsEvlList.getColumn(i,"leSbjtNm") != null && this.dsEvlList.getColumn(i,"leSbjtNm") != "" ? "[" + this.dsEvlList.getColumn(i,"leSbjtNm") + "]" : "";
				var name = this.dsEvlList.getColumn(i,"tchFlnm")+" / "+evlprScNm+" " + chrgeSbjtCdNm;
				var name2 = this.dsEvlList.getColumn(i,"tchFlnm")+"/"+evlprScNm+" " + chrgeSbjtCdNm2;
				this.dsTchCmb.setColumn(nRow, "tchScCd", this.dsEvlList.getColumn(i,"tchScCd"));
				this.dsTchCmb.setColumn(nRow, "tchFlnm", this.dsEvlList.getColumn(i,"tchFlnm"));
				this.dsTchCmb.setColumn(nRow, "tchFullNm", name );
				this.dsTchCmb.setColumn(nRow, "tchFullNmCmb", name2 );
				this.dsTchCmb.setColumn(nRow, "tchInvlNo", this.dsEvlList.getColumn(i,"evlTrprId"));
				this.dsTchCmb.setColumn(nRow, "evlprId", this.dsEvlList.getColumn(i,"evlprId"));
				this.dsTchCmb.setColumn(nRow, "evlYn", this.dsEvlList.getColumn(i,"evlYn"));
				this.dsTchCmb.setColumn(nRow, "evlTrprEvlprId", this.dsEvlList.getColumn(i,"evlTrprId") + this.dsEvlList.getColumn(i,"evlprId"));
			}
			this.div00.form.div00.form.pdvEvlListCmb.form.grdEvlListCmb.setOffsetHeight(this.div00.form.div00.form.pdvEvlListCmb.form.grdEvlListCmb.getRealRowFullSize()+2);
		}
	}
	
	if( this.fv_first == 0){
		var nRow = 0;
		this.div00.form.div00.form.cboEvlList.set_index(nRow);
		this.fnTchSelectData(nRow);
		this.fnChkAnsAble(nRow);
		this.fv_evlTrprId = this.dsTchCmb.getColumn(nRow,"tchInvlNo");
		this.dsSearch.setColumn(0,"evlTrprId", this.fv_evlTrprId);
	}else{
		this.fnTchSelectData(this.cmbIdxVal == -1 ? 0 : this.cmbIdxVal);
		this.fv_evlTrprId = this.dsTchCmb.getColumn(this.cmbIdxVal == -1 ? 0 : this.cmbIdxVal,"tchInvlNo");
		this.dsSearch.setColumn(0,"evlTrprId", this.fv_evlTrprId);
	}
// 	console.log("[fnShowList].★★★★★★★★★★");
// 	
// 	console.log(this.fv_evlTrprId);
// 	console.log("★★★★★★★★★★");
	this.fnShowDiv();
};

this.fnChkAnsAble = function ( val ){

// 	if( this.dsTchCmb.getColumn( val,"evlYn") == "Y" ){
// 			this.fn_EnableYn = "N";
// 	}else{
// 			this.fn_EnableYn = "Y";
// 	}
};

/************************************************************************
 * 선생님정보 셋팅
 ************************************************************************/

this.fnTchSelectData =  function ( tmp ) {
	//console.log("[fnTchSelectData].★★★★★★★★★★");
	
// 	console.log(this.fv_evlTrprId);
// 	console.log("★★★★★★★★★★");
	var tchNm = this.dsTchCmb.getColumn(tmp , "tchFlnm"); //this.div00.form.div00.form.cboEvlList.getSelectedText(tmp); //this.dsTchList.getColumn(0, "tchFlnm" );
	this.fv_evlTrprId = this.dsTchCmb.getColumn(tmp ,"tchInvlNo");//this.dsTchList.getColumn(0, "tchInvlNo" ); 
	var tchDesc = "<fc v='#6b5dc0'>교원 기본정보</fc> ";
// 	console.log(this.dsEvlprList.saveXML());
// 	console.log(this.dsTchList.saveXML());
	var evlprScNm = "";
	var evlprScCd = this.dsEvlprList.getColumn(0,"evlprScCd");
	var evlCthrClsNm = this.dsEvlprList.getColumn(0,"evlCthrClsNm");
	var chgChrgeSbjtNm = this.dsEvlprList.getColumn(0,"chgChrgeSbjtNm");
	var leSbjtNm = this.dsTchList.getColumn(0,"leSbjtNm");
	var chgChrgeSbjtNm = this.dsTchList.getColumn(0,"chgChrgeSbjtNm");
    if( evlprScCd == "203" ) {
		evlprScNm = "[담임 만족도조사]";
	} else if ( evlprScCd == "204" ) {
		evlprScNm = "[교과(전담)교사 만족도조사]";
	} else if ( evlprScCd == "205" || evlprScCd == "206" || evlprScCd == "207" || evlprScCd == "208" || evlprScCd == "209" ) {
		evlprScNm = "[비교과교사 만족도조사]";
	}
	this.div00.form.div00.form.div02.form.staTchNm.set_text(tchNm + evlprScNm);
	var appntScCd = this.dsTchList.getColumn(0, "appntScCd");
	var appntScCdNm = this.dsTchList.getColumn(0, "appntScCdNm");
	this.div00.form.div00.form.staTchFlnm.set_text( tchDesc + "(" + tchNm +" "+( appntScCd == 1 || appntScCd == 2 ? appntScCdNm : "선생님" ) + ")" );
	
	this.div00.form.div00.form.div02.form.staTchScNm.set_text( this.dsTchList.getColumn(0, "tchScCdNm") ); //this.dsEvlList.getColumn(0,"tchScCdNm");

	this.div00.form.div00.form.div02.form.staGbn.set_text( evlCthrClsNm);
	this.div00.form.div00.form.div02.form.staSbj.set_text( ( chgChrgeSbjtNm == null || chgChrgeSbjtNm == "" ? leSbjtNm : chgChrgeSbjtNm ) );
	
	//교육활동 소개 
	var intro = this.dsTchList.getColumn(0, "stuEduActIntrdCn" );
	intro += this.dsTchList.getColumn(0, "hmpg1Addr" );
	intro += this.dsTchList.getColumn(0, "hmpg2Addr" );
	this.div00.form.div00.form.div02.form.staInfoDtl.set_text(this.dsTchList.getColumn(0, "stuEduActIntrdCn" ));
	var hmpg1Addr = this.dsTchList.getColumn(0, "hmpg1Addr" );
	var hmpg2Addr = this.dsTchList.getColumn(0, "hmpg2Addr" );
	this.div00.form.div00.form.div02.form.staHpg.set_text(( hmpg1Addr == "http://" ? '' : hmpg1Addr ));
	this.div00.form.div00.form.div02.form.staHpg2.set_text(( hmpg2Addr == "http://" ? '' : hmpg2Addr ));
	
};

