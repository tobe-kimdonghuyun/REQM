    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 
*  @FileName 	eds_tados04_m01.xfdl 
*  @Creator 	kangjihye
*  @CreateDate 	2023.01.12
*  @Desction    교육설문 - 교원평가 
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.01.12           Kangjihye                   최초 생성 
*******************************************************************************
*/
 
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_param;	// 파라메터 세팅
this.fv_evlTrprId ="" ;
this.btn_param; 
this.fvDivName = "";
this.fvDivLevel2Name = "";
this.fn_tmpYn="";
this.fn_suv_cnt=0;//객관식 문항갯수
this.fn_multi_cnt=0;//객관식 문항갯수
this.fn_sub_cnt=0;//주관식 문항갯수
this.cmbIdxVal= -1;
this.fn_EnableYn = "N";
this.fv_evlKndScCd="2";
this.fv_mobile = "";
if( this.smfIsMobile() ){		
	this.fv_mobile = "_M";
}
this.fv_btnCssNm =  "btn_WF_Choice2" + this.fv_mobile;
this.fv_btnChcCssNm =  "btn_WF_ChoiceS2" + this.fv_mobile;
this.fv_dnPaptCnt=0;	// 미참여
this.fv_cmptnPtptCnt=0;	// 참여완료
this.fv_first;
this.fv_message;
this.popCk;

 /************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnonload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.fnSetcompSizeP();
	this.dsEvlprList.clearData();
	this.dsTchCmb.clearData();
	// 폼 초기화
	this.smfInitForm(obj);
	var sDate = new Date();
	
	//검사연도 세팅
	var sYear  = sDate.getFullYear().toString();
	// 전달받은 파라메터 값 세팅
	this.fv_param = this.smfGetFormParams();
	this.popCk = this.fv_param.popCk;	// 확인/미확인 구분값
	
	this.btn_param = 0; //0=hide된상태, 1=show된상태
	
	this._cddcCd = this.fv_param.cddcCd;
	this._cddcNm = this.fv_param.cddcNm;
	if ( this.smfIsMobile() ) {
		this.divTop.form.fnSetPtptPrd(this._cddcNm);
	}
	this.fv_evlKndScCd = this.fv_param.evlKndScCd;
	this.dsSearch.setColumn(0, "cddcCd"		, this._cddcCd);
	this.dsSearch.setColumn(0, "evlKndScCd"	, this.fv_evlKndScCd);
	this.dsSearch.setColumn(0, "evlYr" 		, sYear);
	this.dsPreset.loadXML(this.fv_param.dataset);
	this.dsPreset1.loadXML(this.fv_param.dataset1);
	
	this.fv_first=0;
	//스크롤바 갱신
	this.smfResetScroll(this);
	
	this.fnStuInfoSetting();
	
	this.fnListSelect();
};


/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
	
};
 /************************************************************************************************
 * LOAD EVENT
 ************************************************************************************************/
this.fnStuInfoSetting = function () {
	// 이전화면에서 받은값으로 보여줌
	var grd = this.dsPreset.getColumn(0,"grd");
	var clsNo = this.dsPreset.getColumn(0,"clsNo");
	var clsNm = this.dsPreset.getColumn(0,"clsNm");
	var stuNm = this.dsPreset.getColumn(0,"stuFlnm");
	var shlCrseScNm = "";
	if(this.dsPreset1.getColumn(0,"shlKndScCd") == "05"){
		if(this.dsPreset1.getColumn(0,"shlCrseScCd") == "2"){
			shlCrseScNm = "(초) ";
		}
		if(this.dsPreset1.getColumn(0,"shlCrseScCd") == "3"){
			shlCrseScNm = "(중) ";
		}
		if(this.dsPreset1.getColumn(0,"shlCrseScCd") == "4"){
			shlCrseScNm = "(고) ";
		}
	}
	if(this.smfIsNull(grd)){
		grd = "";
	}else{
		grd = grd + "학년 ";
	}
	
	if(this.smfIsNull(clsNm)){
		clsNm = "";
	} else {
	    clsNm = clsNm+" ";
	}
	
	if(this.smfIsNull(clsNo)){
		clsNo = "";
	} else {
	    clsNo = clsNo + "번 ";
	}
	
	this._tmpStr = shlCrseScNm + grd  +clsNm + stuNm;
	
	this.div00.form.div00.form.div01.form.staStuNm.set_text(this._tmpStr);

	
};
 
 
this.fnShowDiv = function () {
	if( this.btn_param == 0 ){
		if( this.smfIsMobile() ){
			var bottom = this.div00.form.div00.form.div02.form.staTchNm.getOffsetBottom();
			this.div00.form.div00.form.div02.setOffsetHeight(220);			
			this.div00.form.div00.form.div02.form.btnShow.setOffsetTop(bottom+70);			
			this.div00.form.div00.form.div02.form.btnShow.set_cssclass("btn_WF_SurveyMore_M");
			this.div00.form.div00.form.div02.form.btnShow.set_text("더보기");
			this.smfResetScroll(this.div00.form.div00.form.div02.form);
			
		}else{
			this.div00.form.div00.form.div02.setOffsetHeight(100);
			this.div00.form.div00.form.div02.form.btnShow.set_cssclass("btn_WF_SurveyMore");
			this.div00.form.div00.form.div02.form.btnShow.set_text("더보기");
		}
	}
	if( this.btn_param == 0 ){
		this.fnInfoDiv(false);
	} else {
		this.fnInfoDiv(true);
	}
	this.fnShowDiv03();
	this.smfResetScroll(this.div00.form.div00.form);
};

/**
* 선생님 소개페이지 보여주기 TRUE/ FALSE 로 더보기 컨트롤
**/
this.fnInfoDiv = function ( val ) {
