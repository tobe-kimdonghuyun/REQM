/************************************************************************
 * 더보기 기능
 ************************************************************************/

this.div00_div00_div02_btnShow_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var tmp = this.div00.form.div00.form.div02.form.btnShow.getDisplayText();
	
	if( tmp == "더보기" || this.btn_param == 0 ){
		this.btn_param  = 1;
		if( this.smfIsMobile() ){
			
			var bottom = this.div00.form.div00.form.div02.form.staInfoDtl.getOffsetBottom();
			this.div00.form.div00.form.div02.setOffsetHeight(600);		
			this.div00.form.div00.form.div02.form.btnShow.setOffsetTop(bottom+10);
			this.div00.form.div00.form.div02.form.btnShow.set_cssclass("btn_WF_SurveyInfoClose_M");
			this.div00.form.div00.form.div02.form.btnShow.set_text("닫기");
			this.fnInfoDiv(true);	
			this.smfResetScroll(this.div00.form.div00.form.div02.form);
			this.fnShowDiv03();
			this.smfResetScroll(this.div00.form.div00.form);
		}else{
			
			this.div00.form.div00.form.div02.setOffsetHeight(600);		
			this.div00.form.div00.form.div02.form.btnShow.set_cssclass("btn_WF_SurveyInfoClose");
			this.div00.form.div00.form.div02.form.btnShow.set_text("닫기");
			this.fnInfoDiv(true);
			this.smfResetScroll(this.div00.form.div00.form.div02.form);
			this.fnShowDiv03();
			this.smfResetScroll(this.div00.form.div00.form);
		}
	}else{
		this.btn_param  = 0;
		if( this.smfIsMobile() ){
			
			var bottom = this.div00.form.div00.form.div02.form.staTchNm.getOffsetBottom();
			this.div00.form.div00.form.div02.setOffsetHeight(220);		
			this.div00.form.div00.form.div02.form.btnShow.setOffsetTop(bottom+70);
			this.div00.form.div00.form.div02.form.btnShow.set_cssclass("btn_WF_SurveyMore_M");
			this.div00.form.div00.form.div02.form.btnShow.set_text("더보기");
			this.fnInfoDiv(false);	
			this.smfResetScroll(this.div00.form.div00.form.div02.form);
			this.fnShowDiv03();
			this.smfResetScroll(this.div00.form.div00.form);
		}else{
		
			this.div00.form.div00.form.div02.setOffsetHeight(100);
			
			this.div00.form.div00.form.div02.form.btnShow.set_cssclass("btn_WF_SurveyMore");
			this.div00.form.div00.form.div02.form.btnShow.set_text("더보기");
			this.fnInfoDiv(false);
			this.smfResetScroll(this.div00.form.div00.form.div02.form);
			this.fnShowDiv03();
			this.smfResetScroll(this.div00.form.div00.form);
		}
	}
	
};

/************************************************************************
 * 선생님 선택시 재조회 
 ************************************************************************/

this.div00_div00_cboEvlList_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.fv_first= Number(this.fv_first)+1;
	this.cmbIdxVal = e.preindex;
	
	var chk = 0;
	for( var z=0; z < this.dsRltList.rowcount; z++ ){
		if( this.isNotNil(this.dsRltList.getColumn(z,"evlYtkScr"))){
			chk++;
		}
		if( this.isNotNil(this.dsRltList.getColumn(z,"dscrpAnsCn"))){
			chk++;
		}
		
	}
	if( chk > 0 && this.dsEvlprList.getColumn(0,"evlYn") =="Y" ){
		this.smfAlert("변경사항이 있습니다 저장 후 처리해주세요", function(){
				this.cmbIdxVal = e.preindex;
				this.div00.form.div00.form.cboEvlList.set_index(e.preindex);
				//return false;
		});
	}else{
		if( this.cmbIdxVal == e.postindex ){
			//console.log("변경이 없음으로 간주하고 제자리 ");
		}else{
			
			this.cmbIdxVal = e.postindex;
			if ( typeof this.dsTchCmb.getColumn(e.postindex ,"evlprId") == "undefined") {
			    this.dsSearch.setColumn(0,"evlprId", "");
				//evlTrprId ::평가대상자ID
				this.dsSearch.setColumn(0,"evlTrprId", "");
				this.dsSearch.setColumn(0,"evlPaptId", "");
			} else {
				//evlprId ::평가지 ID
				this.dsSearch.setColumn(0,"evlprId", this.dsTchCmb.getColumn(e.postindex ,"evlprId"));
				//evlTrprId ::평가대상자ID
				this.dsSearch.setColumn(0,"evlTrprId", this.dsTchCmb.getColumn(e.postindex ,"tchInvlNo"));
				this.dsSearch.setColumn(0,"evlPaptId", this.dsPreset.getColumn(0,"tadStuInvlNo") );
				this.fnChkAnsAble(e.postindex);
				this.fnListSelect();
			}
			
		}
	}
};

/************************************************************************
 * 저장하기 버튼 
 ************************************************************************/
this.div00_btnSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var cnt = this.dsEvlprQuitmListAll.findRow("ytkSn",undefined);
	if ( cnt > -1 ) {
		var objGrid = this.div00.form.div00.form.grdSvy;
		this.smfAlertEds((cnt+1) + '번 만족도 조사 문항에 응답하세요. ',null,()=>{this.smfSetGridScroll(objGrid,cnt);},null,{align:'center'});
		return false;
	}
	this.fn_tmpYn = "N";
	this.div00.form.div00.form.grdTxtSvy.updateToDataset();
	this.fnSettingQtnCnt();
	this.fnPopUPCall();
};
/************************************************************************
 * 임시저장 버튼
 ************************************************************************/
this.div00_btnTmpSave_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fn_tmpYn = "Y";
	this.fnSettingQtnCnt();
	this.div00.form.div00.form.grdTxtSvy.updateToDataset();
	this.fnSaveResult("Y");
};

/************************************************************************
 * 저장 시 문항 정보 보여주기 위한 dataset
 ************************************************************************/
this.fnSettingQtnCnt = function() {
	var Ydstk1=0;
	var Ydstk2=0;
	var Ydstk3=0;
	var Ydstk4=0;
	var Ydstk5=0;
	//필터 객관식 문항 필터적용
	this.dsEvlprQuitmListAll.filter("quitmScCd=='02' || quitmScCd=='09'");
	var cnt = this.dsEvlprQuitmListAll.getRowCount();
	
	var val = 0;
	for( var i = 0 ; i < cnt ; i++ ){
		var scCd =  this.dsEvlprQuitmListAll.getColumn( i , "quitmScCd" );
		if( scCd == "02" || scCd == "09" )
		{
			var tmp = this.dsEvlprQuitmListAll.getColumn( i , "ytkSn" );
			if( this.isNotNil(tmp) ){
				var fRow = this.dsEvlYdstkList.findRow("ytkSn", tmp);
				
				switch(tmp){
					case "1":
						Ydstk1 = Ydstk1+1;
					break;
					
					case "2":
						Ydstk2 = Ydstk2+1;
					break;
					
					case "3":
						Ydstk3 = Ydstk3+1;
					break;
					
					case "4":
						Ydstk4 = Ydstk4+1;
					break;
					
					case "5":
						Ydstk5 = Ydstk5+1;
					break;	
					
					default:
					break;
					
				}
				val += Number(this.dsEvlYdstkList.getColumn( fRow , "evlYtkScr" ));
			}
		}
	}
	
	var Average = (cnt != 0? val/cnt: 0);
	//필터 초기화
	this.dsEvlprQuitmListAll.filter("");
	this.dsQtnYdstkCnt.deleteAll();
	this.dsQtnYdstkCnt.addRow();
	this.dsQtnYdstkCnt.setColumn(0 , "Avr" , Average.toFixed(1) );
	this.dsQtnYdstkCnt.setColumn(0 , "Ydstk1" , Ydstk1 );
	this.dsQtnYdstkCnt.setColumn(0 , "Ydstk2" , Ydstk2 );
	this.dsQtnYdstkCnt.setColumn(0 , "Ydstk3" , Ydstk3 );
	this.dsQtnYdstkCnt.setColumn(0 , "Ydstk4" , Ydstk4 );
	this.dsQtnYdstkCnt.setColumn(0 , "Ydstk5" , Ydstk5 );
	//console.log(this.dsQtnYdstkCnt.saveXML());
};

/************************************************************************
 * 저장또는 임시저장시 답변갯수 표시 
 ************************************************************************/
this.fnPopUPCall = function (){
	//console.log(this.dsQtnYdstkCnt.saveXML());
	
	var popupParams = {
		callback: this.fnPopupCallback,		// 콜백함수 지정
		sender: obj, 						// sender 지정
		params: {							// 팝업 전달 파라메터 지정
			procType: "none",				// 처리타입 지정
			cddcOrgCd : this._cddcCd,
			dataset : this.dsQtnYdstkCnt.saveXML(),
			dataset1 : this.dsQstnRspns.saveXML(),
			dataset2 : this.dsBasicQstnRspns.saveXML()
		},
		titlebar : false
	};
	this.smfDialog("_auto", "pa_eds_tad_os::eds_tados04_p01.xfdl" ,popupParams);
};

this.fnPopupCallback = function(e, sender)
{
	
	if(e.urlName == "confirm"){			//학교찾기 팝업 콜백
		//console.log("SAVE BTN");
		this.fv_message="confirm";
		this.fnSaveResult(this.fn_tmpYn);
	
	}else if(e.urlName == "cancel"){
		
		//console.log("확인필요 ");
	
	}else if(e.urlName == "addSearch"){
		//console.log("SAVE BTN");
		this.fv_message="addSearch";
		//저장 후 추가설문으로 Call 
		this.fnSaveResult(this.fn_tmpYn);
	}else if(e.urlName == "0"){
		this.fnSaveResult(this.fn_tmpYn);
	}
	
};


this.fnAddSearchCall = function () 
{
	//listadd
	this.smfSearchService("listAdd")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return; 
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){ //성공
				 if( this.dsEvlprQuitmList00.getRowCount() >  0) {
					this.fnGotoAddSvy();
				 }else{
					this.smfAlert("추가설문 문항이 존재하지 않습니다");
				 
				 }
				 
			}
		});
};


/*추가 설문페이지로 이동*/
this.fnGotoAddSvy = function ()
{
	var param = {
			cddcCd : this._cddcCd,
			cddcNm : this._cddcNm,
			evlKndScCd : this.fv_evlKndScCd,
			shlCrseScCd : this.dsSearch.getColumn(0,"shlCrseScCd"),
			popCk : this.popCk,
			dataset: this.dsPreset.saveXML(),
			dataset1 : this.dsPreset1.saveXML(),
			schdataset :  this.dsSearch.saveXML(),		
	};
	this.smfSetWorkPage("pa_eds_tad_os::eds_tados05_m01.xfdl", param, false);
};

this.fnGridSetting = function () {
	var hp1 = 0;
	var hp2 = 0;
	if ( this.dsEvlprList.getColumn(0,"evlYn") == "N" ) {
		hp1 = this.div00.form.div00.form.grdSvy.getRealRowFullSize();
		hp2 = this.div00.form.div00.form.grdTxtSvy.getRealRowFullSize();
	}
	this.div00.form.div00.form.grdSvy.setOffsetHeight(hp1);	
	this.div00.form.div00.form.grdTxtSvy.setOffsetHeight(hp2);		
};

/**
* 평가지 구분 코드에 따른 명칭
*/
this.fnEvlprScNm = function(evlprScCd) {
    var evlprScNm = "";
	if ( evlprScCd == "201" || evlprScCd == "301" ) {
	    evlprScNm = "교장";
	} else if ( evlprScCd == "202" || evlprScCd == "302" ) {
	    evlprScNm = "교감";
	} else if ( evlprScCd == "203" || evlprScCd == "303" ) {
		evlprScNm = "담임";
	} else if ( evlprScCd == "204" || evlprScCd == "304" ) {
		evlprScNm = "교과";
	} else if ( evlprScCd == "205" || evlprScCd == "305" ) {
		evlprScNm = "특수";
	} else if ( evlprScCd == "206" || evlprScCd == "306" ) {
		evlprScNm = "보건";
	} else if ( evlprScCd == "207" || evlprScCd == "307" ) {
		evlprScNm = "영양";
	} else if ( evlprScCd == "208" || evlprScCd == "308" ) {
		evlprScNm = "사서";
	} else if ( evlprScCd == "209" || evlprScCd == "309" ) {
		evlprScNm = "전문상담";
	} else if ( evlprScCd == "210" || evlprScCd == "310" ) {
		evlprScNm = "기타";
	} else if ( evlprScCd == "211" || evlprScCd == "311" ) {
		evlprScNm = "수석";
	} 
    return evlprScNm;
}

this.div00_div00_cboEvlList_ondropdown = function(obj:nexacro.Combo,e:nexacro.EventInfo)
{
	var objPdv = this.div00.form.div00.form.pdvEvlListCmb;
	
	// 데이터에 맞추어 높이 조절(필요시 표시방향- 콤보의 상단에 표시)
	var nLeft = 0;
	var nTop = obj.getOffsetHeight();
	var nWidth = obj.getOffsetWidth();
	var nHeight = objPdv.form.grdEvlListCmb.getRealRowFullSize() + 2;
	
	objPdv.form.grdEvlListCmb.setOffsetHeight(nHeight);
	
	// 만약 높이가 긴 경우(지정된 값만 세팅 - 스크롤 생기게) - minheight/maxheight로 조절
	// 그리드의 row위치 이동
	var nPreValue = obj.text;
	if(!this.smfIsNull(nPreValue))
	{
		var objGrd = objPdv.form.grdEvlListCmb;
		var objDs  = objGrd.getBindDataset();
		var sComboDataColId = obj.datacolumn;
		
		var nFindIdx = objDs.findRow(sComboDataColId,nPreValue);	
		if(nFindIdx<0) nFindIdx = 0;
		
		objDs.set_rowposition(nFindIdx);
	}
		
	// 팝업을 표시한다.
	objPdv.trackPopupByComponent(obj,nLeft,nTop,nWidth,nHeight);
	return false;	
};

this.div00_div00_pdvEvlListCmb_grdEvlListCmb_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	// 해당 오브젝트를 구한다.
	var objCombo = this.div00.form.div00.form.cboEvlList;
	var objDs  = obj.getBindDataset();
	
	var sComboCodeColId = objCombo.codecolumn;
	var sComboDataColId = objCombo.datacolumn;
	
	// 그리드의 선택된 값을 구한다.(현재값)
	var post_index = e.row;
	var post_value = objDs.getColumn(post_index, sComboCodeColId);
	var post_text  = objDs.getColumn(post_index, sComboDataColId);	
	
	// 콤보의 값을 가져온다.(이전값)
	var pre_index = objCombo.index;	
	var pre_value = objCombo.value;
	var pre_text  = objCombo.text ;
	
	// 그리드에 현재 선택된 값으로 콤보값 설정
	objCombo.set_index(post_index);
	
	// 콤보의 이벤트 발생(값만을 세팅한 경우 onItemChanged이벤트가 발생을 하지 않으므로 강제로 발생)
	objCombo.on_fire_onitemchanged(this, pre_index, pre_text, pre_value, post_index, post_text, post_value);
	
	// 팝업DIV를 닫는다.
	obj.parent.parent.closePopup();	
};

this.div00_div00_grdSvy_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{ 
	var val = 0;
	if( this.smfIsMobile() ){
		var tmp = e.cell >= 1 && e.cell < 6 ? e.cell : e.cell-5 ;	
		if( this.dsEvlprList.getColumn(0,"evlYn") == "N" ){
		    if(e.cell >= 1 ) {
				this.dsEvlprQuitmListAll.setColumn(e.row, "ytkSn" , tmp );	
				var row = this.dsEvlYdstkList.findRow("ytkSn", tmp);
				this.dsEvlprQuitmListAll.setColumn(e.row, "evlYtkScr" , this.dsEvlYdstkList.getColumn(row,"evlYtkScr"));	
			}
		}else{
			this.smfAlert("이미 완료된 설문입니다.");
		}
	}else{
		val = Math.ceil(Number(e.cell/2));
		if( this.dsEvlprList.getColumn(0,"evlYn") == "N" ){
			this.dsEvlprQuitmListAll.setColumn(e.row, "ytkSn" , val );
			var row = this.dsEvlYdstkList.findRow("ytkSn", val);
			this.dsEvlprQuitmListAll.setColumn(e.row, "evlYtkScr" , this.dsEvlYdstkList.getColumn(row,"evlYtkScr"));	
		}else{
			this.smfAlert("이미 완료된 설문입니다.");
		}
	}
};

this.div00_div00_grdTxtSvy_oninput = function(obj:nexacro.Grid,e:nexacro.GridInputEventInfo)
{
 	var ansTxt = obj.getEditingText(); //textArea value
 	var txtLen = ansTxt.length + " / 300";
	var row = obj._currentCellRow;
 	this.dsEvlprDscrpQuitmList.setColumn(row, "txtLen", txtLen);
};

this.div00_div00_div02_staHpg_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	system.execBrowser(obj.text);
};

this.div00_div01_onsize = function(obj:nexacro.Div,e:nexacro.SizeEventInfo)
{
	var tmp = this.div00.form.div00.form.div02.form.btnShow.getDisplayText();
	
	if( tmp == "더보기" && this.btn_param == 0 ){
		if( this.smfIsMobile()){
			this.btn_param = 1;
			var bottom = this.div00.form.div00.form.div02.form.staInfoDtl.getOffsetBottom();
			this.div00.form.div00.form.div02.setOffsetHeight(600);		
			this.div00.form.div00.form.div02.form.btnShow.setOffsetTop(bottom+10);
			this.div00.form.div00.form.div02.form.btnShow.set_cssclass("btn_WF_SurveyInfoClose_M");
			this.div00.form.div00.form.div02.form.btnShow.set_text("닫기");
			this.fnInfoDiv(true);	
			this.smfResetScroll(this.div00.form.div00.form.div02.form);
			this.fnShowDiv03();
			this.smfResetScroll(this.div00.form.div00.form);
		}
	}else{
		if( this.smfIsMobile() ){
		    this.btn_param == 0;
			var bottom = this.div00.form.div00.form.div02.form.staTchNm.getOffsetBottom();
			this.div00.form.div00.form.div02.setOffsetHeight(220);		
			this.div00.form.div00.form.div02.form.btnShow.setOffsetTop(bottom+70);
			this.div00.form.div00.form.div02.form.btnShow.set_cssclass("btn_WF_SurveyMore_M");
			this.div00.form.div00.form.div02.form.btnShow.set_text("더보기");
			this.fnInfoDiv(false);	
			this.smfResetScroll(this.div00.form.div00.form.div02.form);
			this.fnShowDiv03();
			this.smfResetScroll(this.div00.form.div00.form);
		}
	}
};
this.eds_tados04_m01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	this.fnSetcompSizeP();
};

/**
 * 컴포넌트 사이즈 조절(PC)
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnSetcompSizeP = function(){
	if (!this.smfIsMobile()){
		var nMaxWidth = 1200 - nexacro.toNumber(this._getHScrollBarSize());
		var nFormWidth = this.getOffsetWidth();
		var vLeft = Math.floor((this.getOffsetWidth() - (this.div00.form.div00.getOffsetWidth()))/2);
		var tLeft = Math.floor((this.getOffsetWidth() - (this.div00.form.btnTmpSave.getOffsetWidth()))/2-((this.div00.form.btnTmpSave.getOffsetWidth())/2) - 2 );
		var sLeft = Math.floor((this.getOffsetWidth() - (this.div00.form.btnSave.getOffsetWidth()))/2+((this.div00.form.btnSave.getOffsetWidth())/2) + 2 );
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.div00.form.div01.setOffsetLeft(10 + nLeft);
			this.div00.form.div00.setOffsetLeft(10 + vLeft);
			this.div00.form.btnTmpSave.setOffsetLeft(10 + tLeft);
			this.div00.form.btnSave.setOffsetLeft(10 + sLeft);
		}else{
			var nLeft = 0;
			this.div00.form.div01.setOffsetLeft(10);
			this.div00.form.div00.setOffsetLeft(10);
			this.div00.form.btnTmpSave.setOffsetLeft(tLeft);
			this.div00.form.btnSave.setOffsetLeft(sLeft);
		}
		this.div00.form.resetScroll();
	}
};]]></Script>
    <Bind>
      <BindItem id="item0" compid="div00.form.div00.form.div02.form.staSbj" propid="text" datasetid="dsTchChrgeSbjtList" columnid="sbjtNm"/>
      <BindItem id="item1" compid="div00.form.div00.form.div02.form.staHpg" propid="text" datasetid="dsTchChrgeSbjtList" columnid="sbjtNm"/>
      <BindItem id="item2" compid="div00.form.div00.form.div02.form.staHpg2" propid="text" datasetid="dsTchChrgeSbjtList" columnid="sbjtNm"/>
    </Bind>
  </Form>
</FDL>
