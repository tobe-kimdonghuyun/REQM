    <Objects/>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 
*  @FileName 	eds_tados02_m01.xfdl 
*  @Creator 	kangjihye
*  @CreateDate 	2023.01.11
*  @Desction    교육설문 - 교원평가 
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.01.11           Kangjihye                   최초 생성 
*******************************************************************************
*/
 
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_param;	// 파라메터 세팅
this.fv_paptSc;	//참여자 구분

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.fnSetcompSizeP();
	// 폼 초기화
	this.smfInitForm(obj);
	var sDate = new Date();
	
	//검사연도 세팅
	var sYear  = sDate.getFullYear().toString();
	
	// 전달받은 파라메터 값 세팅
	this.fv_param = this.smfGetFormParams();
	this._cddcCd = this.fv_param.cddcCd;
	this._cddcNm = this.fv_param.cddcNm;
	
	//시도교육청명 세팅
	this.fnSetCddcNm();
	
	//스크롤바 갱신
	this.smfResetScroll(this);
};
 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnPopupCallback = function(e, sender)
{
	
};
 /************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 시도교육청 세팅
*/
this.fnSetCddcNm = function()
{
	var cddcNm = this._cddcNm;
	this.div00.form.div00.form.staCddcNm.set_text(cddcNm);
	if ( this.smfIsMobile() ) {
		this.divTop.form.fnSetPtptPrd(cddcNm);
	}
 	
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description '학생 참여하기' 버튼 클릭 시
*/
this.div01_divPtptStu_btnPtptStu_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.getOwnerFrame().form._surveyInfo_cddcCd = this._cddcCd;
	this.smfSetCddcCode(this._cddcCd);

	var param = {
		cddcCd : this._cddcCd,
		cddcNm : this._cddcNm
	};
	this.smfSetWorkPage("pa_eds_tad_os::eds_tados03_m01.xfdl", param, false);	
};
/**
 * @description '학부모 참여하기' 버튼 클릭 시
*/
this.div00_divPtptSchpa_btnPtptSchpa_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.getOwnerFrame().form._surveyInfo_cddcCd = this._cddcCd;
	this.smfSetCddcCode(this._cddcCd);

	var param = {
		cddcCd : this._cddcCd,
		cddcNm : this._cddcNm
	};
	this.smfSetWorkPage("pa_eds_tad_os::eds_tados06_m01.xfdl", param, false);	
};

/**
 * @description PC 화면 조절
*/
this.eds_tados02_m01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	if(!this.smfIsMobile()){
		this.fnSetcompSizeP();
	}
};

/**
 * 컴포넌트 사이즈 조절(PC)
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnSetcompSizeP = function(){
	if (!this.smfIsMobile()){
		var nMaxWidth = 1200 - nexacro.toNumber(this._getHScrollBarSize());
		var nFormWidth = this.getOffsetWidth();
		var stuLeft = Math.floor((this.getOffsetWidth() - (this.div00.form.divPtptStu.getOffsetWidth()))/2-((this.div00.form.divPtptStu.getOffsetWidth())/2) - 15);
		var schpaLeft = Math.floor((this.getOffsetWidth() - (this.div00.form.divPtptSchpa.getOffsetWidth()))/2+((this.div00.form.divPtptSchpa.getOffsetWidth())/2) + 15);
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.div00.form.div00.setOffsetLeft(10 + nLeft);
			this.div00.form.divPtptStu.setOffsetLeft(10 + stuLeft);
			this.div00.form.divPtptSchpa.setOffsetLeft(10 + schpaLeft);
		}else{
			var nLeft = 0;
			this.div00.form.div00.setOffsetLeft(nLeft);
			this.div00.form.divPtptStu.setOffsetLeft(stuLeft);
			this.div00.form.divPtptSchpa.setOffsetLeft(schpaLeft);
		}
		this.div00.form.resetScroll();
	}
};
]]></Script>
  </Form>
