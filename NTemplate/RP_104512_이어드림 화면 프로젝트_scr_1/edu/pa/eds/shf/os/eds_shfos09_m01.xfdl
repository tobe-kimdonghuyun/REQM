    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 특수교육대상자인권실태조사 > 특수교육(설문참여_끝내기)교육설문
*  @FileName 	eds_shfos09_m01.xfdl 
*  @Creator 	김지영
*  @CreateDate 	2023.02.23
*  @Desction    교육설문-특수교육(설문참여_끝내기)
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.02.23           김지영                   최초 생성
*******************************************************************************
*/
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_param;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);

	// PC 화면 정렬
	this.fnSetcompSizeP();
	
	// 필수
	this.smfResetScroll(this);
	this.fv_param = this.smfGetFormParams();
	this.fvLangNo = this.fv_param.langNo;
	this.cddcNm = this.fv_param.cddcNm;
	this.cddcCd = this.fv_param.cddcCd;
	this.dsMain.loadXML(this.fv_param.dataset);
	this.dsSearch.loadXML(this.fv_param.dataset);
	
	this.divTop.form.divMain.form.btnHome.set_visible(false);
	this.divTop.form.divMain.form.sta00.set_visible(false);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid, errcd, errmsg){
	if(errcd == -1) return;
};

/**
 * 팝업의 콜백함수
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
	// 특수 map화면으로 이동
	window.location.replace("https://human.eduro.go.kr");
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * 컴포넌트 사이즈 조절
 * @param  : N/A
 * @return : N/A
 */
this.fnSetcompSize = function(){
	this.resetScroll();
	this.smfResetScroll(this);
};

/**
 * 컴포넌트 사이즈 조절(PC)
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnSetcompSizeP = function(){
	if (!this.smfIsMobile()){
		var nMaxWidth = 1200;
		var nFormWidth = this.getOffsetWidth();
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.divMain.form.div00_00.setOffsetLeft(10 + nLeft);
			this.divMain.form.div00.setOffsetLeft(10 + nLeft);
		}else{
			var nLeft = 0;
			this.divMain.form.div00_00.setOffsetLeft(nLeft);
			this.divMain.form.div00.setOffsetLeft(nLeft);
		}
		this.divMain.form.resetScroll();
	}
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 끝내기 버튼 클릭 시
 * @param  : obj		   - [object]Edit
 * @param  : e		       - [string]ChangeEventInfo
 * @return : N/A
 */
this.divMain_btnTitle05_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfAlertEds('LI155', [this.dsLang.getColumn(this.fvLangNo, 'alertTitle01_1') + '\n' + this.dsLang.getColumn(this.fvLangNo, 'alertTitle01_3')], this.fnMessageCallback );
};

/**
 * form 사이즈 조절 시 (PC)
 * @param  : obj		   - [object]Edit
 * @param  : e		       - [string]ChangeEventInfo
 * @return : N/A
 */
this.eds_vffos08_m01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	if(!this.smfIsMobile()){
		// PC 화면 정렬
		this.fnSetcompSizeP();
	}
};
]]></Script>
  </Form>
</FDL>
