          <Column id="grd" type="STRING" size="256" description="학년"/>
          <Column id="sxdsScCd" type="STRING" size="256" description="성별구분코드"/>
          <Column id="brdt" type="STRING" size="256" description="생년월일"/>
          <Column id="neisUseYn" type="STRING" size="256" description="나이스사용여부"/>
          <Column id="eamScCd" type="STRING" size="256" description="초중등구분코드"/>
