              <Combo id="cboClf" taborder="7" text="" left="212" top="156" width="280" height="40" initvalueid="ivCmbNormal" cssclass="cmb_WF_SurvGrade" innerdataset="dsClfCd" codecolumn="unyCdValue" datacolumn="unyCdValueNm" value="" index="-1" displaynulltext="선택"/>
