    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 특수설문 > 보호자 참여 > QR 보호자 관계 선택
*  @FileName 	eds_shfos04_p01.xfdl 
*  @Creator 	김민성
*  @CreateDate 	2023.04.12
*  @Desction    특수설문(보호자참여(QR접속 시)_보호자 관계 선택 팝업)
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.04.12            김지영                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.clfCd;
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	// 필수
	this.fv_param = this.smfGetFormParams();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
}
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 확인 버튼 클릭 시
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
this.div00_btnPemOthbc07_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.clfCd = this.dsSearch.getColumn(0, "stuPtorRelCd");
	
	if(this.isNil(this.clfCd)){
		this.div00.form.cboClf.setFocus();
		this.smfAlertEds('CM006',['학생과의 관계']);
		return;
	};
	
	this.smfSendResponseToOpener({
		"result": this.clfCd
	});
	
	this.close(true);
};]]></Script>
    <Bind>
      <BindItem id="item0" compid="div00.form.cboClf" propid="value" datasetid="dsSearch" columnid="stuPtorRelCd"/>
    </Bind>
  </Form>
</FDL>
