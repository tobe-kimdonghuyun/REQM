          <Column id="qstnYr" type="STRING" size="256" description="설문연도"/>
          <Column id="shlCd" type="STRING" size="256" description="학교코드"/>
          <Column id="shlNm" type="STRING" size="256" description="학교명"/>
          <Column id="cetNo" type="STRING" size="256" description="학생주소우편번호"/>
          <Column id="shlCrseScCd" type="STRING" size="256" description="학교과정구분코드"/>
          <Column id="enfcTme" type="STRING" size="256" description="학기"/>
          <Column id="cddcNm" type="STRING" size="256" description="교육청명"/>
          <Column id="paptCd" type="STRING" size="256" description="참여자구분코드"/>
