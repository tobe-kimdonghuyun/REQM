          <Column id="eamScCd" type="STRING" size="256"/>
          <Column id="qstnPtptCnfmCdIssuSn" type="STRING" size="256" description="설문참여인가코드발급일련번호"/>
          <Column id="stuPtorRelCd" type="STRING" size="256"/>
          <Column id="edsData" type="STRING" size="256"/>
        </ColumnInfo>
