      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 특수교육대상자인권실태조사 > 특수교육-예방교육동영상
*  @FileName 	eds_shfos06_m01.xfdl 
*  @Creator 	kangchaeyoon
*  @CreateDate 	2023.02.07
*  @Desction    특수교육-예방교육동영상
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.02.07           Kangchaeyoon                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvAudvVdo = true;
this.pv_params;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	// 필수
	this.smfResetScroll(this);
	this.pv_params = this.smfGetFormParams();
	this.dsMain.loadXML(this.pv_params.dataset);
	this._paptCd = this.pv_params.paptCd;
	this.shlCd = this.pv_params.sShlCd;	// 학교급
	this.ptPtCnfmCd = this.pv_params.qstnPtPtCnfmCd;
	
	// PC 화면정렬
	this.fnSetcompSizeP();
	
	pvShlKndScCd = this.dsMain.getColumn(0, 'shlKndScCd');
	pvShlCrseScCd = this.dsMain.getColumn(0, 'shlCrseScCd');
	
	if(this.smfIsMobile()){
		this.fnSetcompSize();
	}
	
	var prefixs = "_mid";
					
	this.divMain.form.div01.form.VideoPlayer.set_url("/doc/edu/pa/eds/vff/os/video/ko/shfInfo.m4v");
	this.divMain.form.div01.form.VideoPlayer.play();

	this.setTimer(60, 60000);
	
	this.divTop.form.divMain.form.btnHome.set_visible(false);
	this.divTop.form.divMain.form.sta00.set_visible(false);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 팝업의 콜백함수
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
};

/**
 * 메세지 콜백함수
 * @param : N/A
 * @return : N/A
 */
this.fnMessageCallback = function(){
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * 컴포넌트 사이즈 조절
 * @param  : N/A
 * @return : N/A
 */
this.fnSetcompSize = function(){
	if (this.smfIsMobile()){
		this.smfResetScroll(this.divMain.form.div01.form);
		this.smfResetScroll(this.divMain.form);
		this.divMain.setOffsetHeight(this.divMain.form.sta00_00.getOffsetBottom());
		this.smfResetScroll(this);
		
		var left = Math.floor((this.divMain.form.div01.getOffsetWidth() - this.divMain.form.div01.form.VideoPlayer.getOffsetWidth()) / 2);
		this.divMain.form.div01.form.VideoPlayer.set_left(left);
	}
};

/**
 * 컴포넌트 사이즈 조절(PC)
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnSetcompSizeP = function(){
	if (!this.smfIsMobile()){
		var nMaxWidth = 1200;
		var nFormWidth = this.getOffsetWidth();
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.divMain.form.div00.setOffsetLeft(10 + nLeft);
			this.divMain.form.div01.setOffsetLeft(10 + nLeft);
		}else{
			var nLeft = 0;
			this.divMain.form.div00.setOffsetLeft(nLeft);
			this.divMain.form.div01.setOffsetLeft(nLeft);
		}
		this.divMain.form.resetScroll();
	}
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description '다음단계' 버튼 클릭 시
*/
this.div01_btnNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (this.fvAudvVdo){
		this.divMain.form.div01.form.VideoPlayer.set_volume(0);
		var param = {
			 dataset: this.dsMain.saveXML(),
			 paptCd: this._paptCd,	// 참여자 구분
			 qstnPtPtCnfmCd: this.ptPtCnfmCd,	// 참여코드
			 sShlCd: this.shlCd	// 학교급
			 };
		
		this.smfSetWorkPage("pa_eds_shf_os::eds_shfos07_m01.xfdl", param, false);	// 언어선택 페이지
	}
};

/**
 * ontimer 시
 * @param  : obj		   - [object]Form
 * @param  : e		       - [string]TimerEventInfo
 * @return : N/A
 */
this.eds_shfos06_m01_ontimer = function(obj:nexacro.Form,e:nexacro.TimerEventInfo)
{
	if (e.timerid == 60){
		this.fvAudvVdo = true;
		this.divMain.form.btnNext.set_enable(true);
	}
};

/**
 * 비디오 재생중일 시
 * @param  : obj		   - [object]VideoPlayer
 * @param  : e		       - [string]VideoCurrentTimeChangedEventInfo
 * @return : N/A
 */
// this.div01_div01_VideoPlayer_oncurrenttimechanged = function(obj:nexacro.VideoPlayer,e:nexacro.VideoCurrentTimeChangedEventInfo)
// {
// 	this.setTimer(30, 30000);
// };

/**
 * 화면 회전 시
 */
this.divBottom_onsize = function(obj:nexacro.Div,e:nexacro.SizeEventInfo)
{
	if(this.smfIsMobile()){
		this.fnSetcompSize();
	}else{
		this.fnSetcompSizeP();
	}
};
]]></Script>
  </Form>
</FDL>
