          <Column id="dscrpQuitm1RspnsValue" type="STRING" size="300" description="서술문항1응답값"/>
          <Column id="dscrpQuitm2RspnsValue" type="STRING" size="300" description="서술문항2응답값"/>
          <Column id="dscrpQuitm3RspnsValue" type="STRING" size="300" description="서술문항3응답값"/>
          <Column id="dscrpQuitm4RspnsValue" type="STRING" size="300" description="서술문항4응답값"/>
          <Column id="dscrpQuitm5RspnsValue" type="STRING" size="300" description="서술문항5응답값"/>
          <Column id="dscrpQuitm6RspnsValue" type="STRING" size="300" description="서술문항6응답값"/>
          <Column id="dscrpQuitm7RspnsValue" type="STRING" size="300" description="서술문항7응답값"/>
          <Column id="dscrpQuitm8RspnsValue" type="STRING" size="300" description="서술문항8응답값"/>
          <Column id="dscrpQuitm9RspnsValue" type="STRING" size="300" description="서술문항9응답값"/>
          <Column id="dscrpQuitm10RspnsValue" type="STRING" size="300" description="서술문항10응답값"/>
          <Column id="inspBgngYmd" type="STRING" size="256" description="검사 시작기간"/>
          <Column id="inspEndYmd" type="STRING" size="256" description="검사 종료기간"/>
          <Column id="inspRltInqBgngYmd" type="STRING" size="256" description="검사결과조회 시작기간"/>
          <Column id="inspRltInqEndYmd" type="STRING" size="256" description="검사결과조회 종료기간"/>
          <Column id="mdfcnNts" type="STRING" size="256" description="수정횟수(객관식)"/>
          <Column id="dscrpMdfcnNts" type="STRING" size="256" description="수정횟수(주관식)"/>
          <Column id="qstnPtptCnfmCdIssuSn" type="STRING" size="256" description="설문참여인가코드발급일련번호"/>
