    <Objects/>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 특수교육대상자인권실태조사 > 특수교육-참여자구분
*  @FileName 	eds_shfos02_m01.xfdl 
*  @Creator 	kangchaeyoon
*  @CreateDate 	2023.02.03
*  @Desction    특수교육-참여자구분
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.02.03           Kangchaeyoon                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_param;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	this.smfResetScroll(this);
	
	this.fv_param = this.smfGetFormParams();
	this.sCddcCd = this.fv_param.cddcCd;
	this.sCddcNm = this.fv_param.cddcNm;
	
	// PC화면 세팅
	this.fnSetcompSizeP();
	
	//시도교육청명 세팅
	this.fnSetCddcNm();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 시도교육청 세팅
*/
this.fnSetCddcNm = function()
{
	this.divMain.form.div00.form.staCddcNm.set_text(this.sCddcNm);
};

/**
 * @description 참여자정보확인 팝업 호출
*/
this.fnPaptIdnty = function(paptCd)
{
	var sUrl = '';
	
	if(paptCd == 'A'){			//학생
		sUrl = "pa_eds_shf_os::eds_shfos03_m01.xfdl";
	}else if(paptCd == 'B'){	//보호자
		sUrl = "pa_eds_shf_os::eds_shfos04_m01.xfdl";
	}else if(paptCd == 'C'){	//교원
		sUrl = "pa_eds_shf_os::eds_shfos05_m01.xfdl";
	}else{
		return false;
	}
	
	//참여자 정보확인 팝업 호출
	var param = {
		paptCd : paptCd,
		cddcCd : this.sCddcCd,
		cddcNm : this.sCddcNm
	};
	
	this.smfSetWorkPage(sUrl, param, false);
};

/**
 * 컴포넌트 사이즈 조절(PC)
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnSetcompSizeP = function(){
	if (!this.smfIsMobile()){
		var nMaxWidth = 1200;
		var nFormWidth = this.getOffsetWidth();
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.divMain.form.div00.setOffsetLeft(10 + nLeft);
			this.divMain.form.divPtptStu.setOffsetLeft(10 + nLeft);
		}else{
			var nLeft = 0;
			this.divMain.form.div00.setOffsetLeft(nLeft);
			this.divMain.form.divPtptStu.setOffsetLeft(nLeft);
		}
		this.divMain.form.resetScroll();
	}
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description '참여하기' 클릭 시
*/
this.Button_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//참여자정보확인 화면 호출
	this.fnPaptIdnty(obj.userSc);
};

/**
 * @description PC 화면 조절
*/
this.eds_shfos02_m01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	if(!this.smfIsMobile()){
		// PC화면 세팅
		this.fnSetcompSizeP();
	}
};
]]></Script>
  </Form>
</FDL>
