    <Objects/>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 특수교육대상자인권실태조사 > 객관식 예시 팝업
*  @FileName 	eds_shfos08_p01.xfdl 
*  @Creator 	김지영
*  @CreateDate 	2023.02.23
*  @Desction    교육설문-특수교육(객관식 예시 팝업)
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.02.23           김지영                   최초 생성
*******************************************************************************
*/
/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.pv_params;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	this.pv_params = this.smfGetPopupParams();
	// 필수
	this.resetScroll();

	this.div00.form.div99.form.staQstnAdiEpl.set_text(this.pv_params.staQstnAdiEplValue);
	this.div00.form.imgAtchFile.set_image(this.pv_params.imgAtchFileValue);
	
	switch(this.pv_params.langCd) {
	case 'EN' : this.div00.form.sta01.set_text("[Example]");
		break;
	case 'VI' : this.div00.form.sta01.set_text("[thì dụ]");
		break;
	case 'ZH' : this.div00.form.sta01.set_text("[例示]");
		break;
	default: this.div00.form.sta01.set_text("[예시]");
	}

	if(this.pv_params.ptptCd == 'B' && this.pv_params.quitmNo == '2401'){
		switch(this.pv_params.langCd){
			case 'EN' : this.div00.form.sta01.set_text("[Collection and consent of personal data]");
				break;
			case 'VI' : this.div00.form.sta01.set_text("[Thu thập và Đồng ý cung cấp thông tin cá nhân]");
				break;
			case 'ZH' : this.div00.form.sta01.set_text("[个人信息收集及同意]");
				break;
			default: this.div00.form.sta01.set_text("[개인정보 수집 및 이용 동의(선택)]");
		}
	}
	
	// 단어 공백기준 줄바꿈
	document.getElementsByClassName("Static sta_WF_Txt16").item(0).children.item(0).style.wordBreak = "keep-all";
	
 	this.fnSetCompSize(this.pv_params.imgAtchFileValue);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
this.fnSetCompSize = function(imgValue){
	if (this.smfIsNull(this.pv_params.imgAtchFileValue)){
		this.div00.form.imgAtchFile.set_visible(false);
		this.div00.form.imgAtchFile.set_height(0);
		this.div00.form.sta03.set_left(0);
	}
	if (this.smfIsMobile()){
		this.smfResetScroll(this.div00.form.div99.form);
		document.getElementsByClassName("Static sta_WF_Txt16").item(0).style.removeProperty("height");
		this.div00.form.div99.set_height(this.div00.form.div99.height + 30);
		this.smfResetScroll(this.div00.form);
		this.div00.set_height(this.div00.form.sta02.getOffsetBottom());
		
	}else{
		this.smfResetScroll(this.div00.form.div99.form);
		document.getElementsByClassName("Static sta_WF_Txt16").item(0).style.removeProperty("height");
		this.div00.form.div99.set_height(this.div00.form.div99.height + 20);
		this.smfResetScroll(this.div00.form);
		this.div00.set_height(this.div00.form.stabottom.getOffsetBottom());
		this.div00.set_maxheight(316);
		this.div00.set_minheight(316);
	}
	
	this.smfResetScroll(this);
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * X 버튼 클릭 시
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
 */
this.div00_btn01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};]]></Script>
  </Form>
