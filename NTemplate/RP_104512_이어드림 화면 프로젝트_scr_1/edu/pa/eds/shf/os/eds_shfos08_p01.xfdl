              <Static id="StaTop" taborder="7" left="312" height="10" cssclass="sta_GD_Size" text="24" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="100" bottom="248"/>
