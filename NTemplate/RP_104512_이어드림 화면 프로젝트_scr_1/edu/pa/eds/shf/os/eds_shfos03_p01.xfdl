<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="eds_segoi03_p02" width="780" height="608" titletext="특수교육-학교찾기 팝업" onload="fnOnload" cssclass="frm_Pop_bgTrsprt" background="transparent" validate="" onkeyup="div00_edtSearch_onkeyup">
    <Layouts>
      <Layout height="608" width="780" screenid="ScreenDeskTop">
        <Div id="div00" taborder="0" left="30" top="30" cssclass="div_WF_SurvPopLine" boxShadow="10px 10px 30px 0px rgba(20,20,20,0.35)" initvalueid="ivDivAccessibilityOff" width="720" height="546">
          <Layouts>
            <Layout>
              <Static id="staTitle" taborder="0" text="학교찾기" left="20" top="14" width="547" height="36" cssclass="sta_WF_Txt18B" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
              <Edit id="edtSearch" taborder="1" left="20" top="68" width="460" height="40" initvalueid="ivEdtNormal" cssclass="edi_WF_SurveySch" displaynulltext="학교명을 입력하세요" maxlength="100" onchanged="div00_edtSearch_onchanged" onkeydown="div00_edtSearch_onkeydown"/>
              <Button id="btnSearch" taborder="2" text="조회" top="68" width="130" height="40" cssclass="btn_WF_SurvSearch02" initvalueid="ivBtnAccessibilityButton" left="edtSearch:10" onclick="btnSearch_onclick"/>
              <Div id="div01" taborder="3" left="20" top="128" width="674" height="259" formscrollbartype="none default" border="1px solid #cccccc" borderRadius="5px" initvalueid="ivDivAccessibilityOff">
                <Layouts>
                  <Layout>
                    <Grid id="grdMain" taborder="0" left="0" top="0" cssclass="grd_WF_SchoolSch" initvalueid="ivGrdAccessibilityOn" binddataset="dsShlList" autofittype="col" right="0" border="0px none" borderRadius="0px" cellsizingtype="col" selecttype="row" oncellclick="grdMain_oncellclick" oncelldblclick="div00_div01_grdMain_oncelldblclick" autosizingtype="col" formatid="default" bottom="0">
                      <Formats>
                        <Format id="default">
                          <Columns>
                            <Column size="238"/>
                            <Column size="312"/>
                          </Columns>
                          <Rows>
                            <Row size="60"/>
                          </Rows>
                          <Band id="body">
                            <Cell text="bind:kornOrgNm" cssclass="TitB" autosizecol="default"/>
                            <Cell col="1" text="bind:roadNmAddr" cssclass="RNoLien"/>
                          </Band>
                        </Format>
                        <Format id="format00">
                          <Columns>
                            <Column size="551"/>
                          </Columns>
                          <Rows>
                            <Row size="60"/>
                            <Row size="60"/>
                          </Rows>
                          <Band id="body">
                            <Cell text="bind:kornOrgNm" cssclass="TitB" autosizecol="limitmin"/>
                            <Cell row="1" text="bind:roadNmAddr" border="1px solid #dddfe3,1px solid #f6f7f8,1px solid #dddfe3,1px solid #f6f7f8"/>
                          </Band>
                        </Format>
                      </Formats>
                    </Grid>
                  </Layout>
                  <Layout name="Layout0">
                    <Grid id="grdMain" autosizingtype="row"/>
                  </Layout>
                  <Layout name="Layout1">
                    <Grid id="grdMain" autosizingtype="row"/>
                  </Layout>
                </Layouts>
              </Div>
              <Button id="btnIdnty" taborder="4" text="확인" left="280" top="450" width="160" cssclass="btn_WF_SurvSearch02" height="50" initvalueid="ivBtnAccessibilityButton" onclick="div00_btnIdnty_onclick"/>
              <Button id="btnClose" taborder="5" top="14" width="36" height="36" cssclass="btn_WF_SurvPopClose" initvalueid="ivBtnAccessibilityButton" right="20" onclick="div00_btnClose_onclick" accessibilitylabel="팝업닫기"/>
              <Static id="sta01" taborder="6" left="0" top="0" height="20" cssclass="sta_WF_GDSize" text="20" visible="false" initvalueid="ivStcAccessibilityOff" width="720"/>
              <Static id="sta02" taborder="7" left="0" top="20" height="329" cssclass="sta_WF_GDSize" text="20" visible="false" initvalueid="ivStcAccessibilityOff" width="20"/>
            </Layout>
            <Layout name="default0">
              <Static id="staTitle" taborder="0" left="40" top="34" width="155" height="44" cssclass="sta_WF_Txt34B" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
              <Button id="btnClose" taborder="3" top="32" height="36" width="36" right="40"/>
              <Edit id="edtSearch" taborder="1" left="40" top="104" width="354" height="80" initvalueid="ivEdtNormal" cssclass="edi_WF_SurveySch" displaynulltext="학교명" maxlength="100"/>
              <Button id="btnSearch" taborder="2" text="조회" top="104" height="80" cssclass="btn_WF_SurvSearch02" initvalueid="ivBtnAccessibilityButton" left="edtSearch:10" width="130"/>
              <Button id="btnIdnty" left="220" top="740" width="200" height="80" cssclass="btn_WF_SurvSearch02"/>
              <Static id="sta01" height="40" left="0" top="0" text="40" right="0"/>
              <Static id="sta02" width="40" left="0" top="40" height="329" text="40"/>
              <Div id="div01" left="40" top="195" height="500" right="40" formscrollbarsize="1"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnClose" taborder="1" top="0" width="48" height="48" cssclass="btn_Pop_close_W" initvalueid="ivBtnAccessibilityButton" right="-214" visible="false" enable="false"/>
      </Layout>
      <Layout height="880" width="640" screenid="mobile,tablet" name="default0" mobileorientation="portrait">
        <Div id="div00" taborder="0" text="div03" left="0" top="0" cssclass="div_WF_SurvPopLine" initvalueid="ivDivAccessibilityOff" background="#ffffff" right="0" height="880"/>
        <Button id="btnClose" top="6" width="48" height="48" right="-118" cssclass="btn_Pop_close_W_M"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">list</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsShlList=resultList</Col>
            <Col id="package"/>
            <Col id="vo"/>
            <Col id="service"/>
            <Col id="method"/>
            <Col id="svctp">R</Col>
            <Col id="bindingControls"/>
            <Col id="url">/sac_cmm_cm00_001.do</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="state"/>
            <Col id="reason"/>
            <Col id="message"/>
            <Col id="asynctp"/>
            <Col id="bintp"/>
            <Col id="comtp"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcOrgCd" type="STRING" size="256" description="시도교육청코드"/>
          <Column id="shlCd" type="STRING" size="256" description="학교코드"/>
          <Column id="kornOrgNm" type="STRING" size="256" description="학교명"/>
          <Column id="shlKndScCd" type="STRING" size="256" description="학교종류구분코드"/>
          <Column id="shlBscAddr" type="STRING" size="256" description="학교기본주소"/>
          <Column id="orgUseYn" type="STRING" size="256" description="사용여부"/>
          <Column id="shlKndScCd" type="STRING" size="256" description="학교종류구분코드:학교찾기에서 유치원 빼기"/>
          <Column id="qstnPaptScCd" type="STRING" size="256" description="참여자구분코드"/>
          <Column id="ralPaptScNm" type="STRING" size="256"/>
          <Column id="cddcCd" type="STRING" size="256"/>
          <Column id="qstnDgr" type="STRING" size="256"/>
          <Column id="qstnYr" type="STRING" size="256"/>
          <Column id="shlNm" type="STRING" size="256"/>
          <Column id="cetNo" type="STRING" size="256"/>
          <Column id="shlCrseScCd" type="STRING" size="256"/>
          <Column id="enfcTme" type="STRING" size="256"/>
          <Column id="cddcNm" type="STRING" size="256"/>
          <Column id="paptCd" type="STRING" size="256"/>
          <Column id="qstnPtptCnfmCd" type="STRING" size="256"/>
          <Column id="qstnPtptCnfmCdIssuSn" type="STRING" size="256"/>
          <Column id="grd" type="STRING" size="256"/>
          <Column id="spyEduTrprQstnTypCd" type="STRING" size="256"/>
          <Column id="qstnPtPtCnfmCd" type="STRING" size="256"/>
          <Column id="eamScCd" type="STRING" size="256"/>
          <Column id="sxdsScCd" type="STRING" size="256"/>
          <Column id="roadNmAddr" type="STRING" size="256" description="도로명주소"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="orgUseYn">Y</Col>
            <Col id="shlKndScCd">01</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsShlList" useclientlayout="true">
        <ColumnInfo>
          <Column id="chk" type="STRING" size="256"/>
          <Column id="orgCd" type="STRING" size="256" description="학교코드"/>
          <Column id="kornOrgNm" type="STRING" size="256" description="학교명"/>
          <Column id="shlKndScCd" type="STRING" size="256" description="학교종류구분코드"/>
          <Column id="lotnoZip" type="STRING" size="256" description="지번우편번호"/>
          <Column id="lotnoAddr" type="STRING" size="256" description="지번주소"/>
          <Column id="lotnoDtlAddr" type="STRING" size="256" description="지번상세주소"/>
          <Column id="roadNmZip" type="STRING" size="256" description="도로명우편번호"/>
          <Column id="roadNmAddr" type="STRING" size="256" description="도로명주소"/>
          <Column id="roadNmDtlAddr" type="STRING" size="256" description="도로명상세주소"/>
          <Column id="shlCrseScCd" type="STRING" size="256" description="학교과정교육코드"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문  > 특수교육-학교찾기 팝업
*  @FileName 	eds_shfos03_p01.xfdl 
*  @Creator 	김지영
*  @CreateDate 	2022.02.17
*  @Desction    특수교육-학교찾기 팝업
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.02.17           김지영                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_param;			//파라미터 세팅

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	//폼 초기화
	this.smfInitPopup(obj);
	
	if(this.smfIsMobile()){
		this.div00.form.div01.form.grdMain.set_formatid("format00");
		this.div00.form.div01.form.grdMain.set_cssclass("grd_WF_SchoolSch_M");
	}
	
	// 전달받은 파라메터 값 세팅
	this.fv_param = this.smfGetPopupParams();
	this.dsSearch.setColumn(0, "cddcOrgCd", this.fv_param.cddcOrgCd);
	this.dsSearch.setColumn(0, "qstnPaptScCd", this.fv_param.paptCd);
	this.dsSearch.setColumn(0, "kornOrgNm", this.fv_param.sclNm);
	this.dsSearch.setColumn(0, "ralPaptScNm", "noKg");
	if (this.isNotNil(this.div00.form.edtSearch.value)){
 		this.fnSearchList();
 	}
	
	this.div00.form.edtSearch.setFocus();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 조회 Transaction
 */
this.fnSearchList = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			this.div00.form.div01.setOffsetHeight();
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 /**
 * @description 학교 선택
 */
 this.fnShlChc = function(){
	if(this.dsShlList.rowposition <= -1) return;
	
	var kndScCd = this.dsShlList.getColumn(0, "shlKndScCd");
	
	this.smfSendResponseToOpener({
		"urlName" : "searchShl",
		"row": this.smfRowToObject(this.dsShlList)
	});

	this.close(true);
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description '조회' 버튼 클릭 시 
 */
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//학교명 필수 입력
	this.dsSearch.setColumn(0, 'kornOrgNm', this.div00.form.edtSearch.value);
	var shlNm = this.dsSearch.getColumn(0, 'kornOrgNm');
	if(this.isNil(shlNm)){
		this.smfAlertEds('CM006',['학교명']);
		this.div00.form.edtSearch.setFocus();
		return;
	}
	
	this.fnSearchList();
};

/**
 * @description 그리드 클릭 시
 */
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
// 	//학교 선택
// 	this.fnShlChc();
};

/**
 * @description 그리드 더블 클릭 시
 */
this.div00_div01_grdMain_oncelldblclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	//학교 선택
	this.fnShlChc();
};

/**
 * @description '확인' 버튼 클릭 시
 */
this.div00_btnIdnty_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//학교명 필수 입력
	var shlNm = this.dsSearch.getColumn(0, 'kornOrgNm');
	if(this.isNil(shlNm)){
		this.smfAlertEds('CM006',['학교명']);
		this.div00.form.edtSearch.setFocus();
		return;
	}
	
	//학교 선택
	this.fnShlChc();
};

/**
 * @description 검색창에서 엔터키 클릭 시 
 */
this.div00_edtSearch_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode == "13"){
		this.btnSearch_onclick();
	}
};

/**
 * @description '닫기' 버튼 클릭 시 
 */
this.div00_btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};]]></Script>
    <Bind>
      <BindItem id="item0" compid="div00.form.edtSearch" propid="value" datasetid="dsSearch" columnid="kornOrgNm"/>
    </Bind>
  </Form>
</FDL>
