    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 특수교육대상자인권실태조사 > 특수교육-언어선택
*  @FileName 	eds_shfos07_m01.xfdl 
*  @Creator 	김지영
*  @CreateDate 	2023.02.20
*  @Desction    특수교육-언어선택
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2023.02.20           김지영                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_param;	// 파라미터 세팅
this.fvQstnExmnLangScCd;
this.fvLangNo;

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	this.smfResetScroll(this);

	// 전달받은 파라메터 값 세팅
	this.fv_param = this.smfGetFormParams();
	this.dsMain.loadXML(this.fv_param.dataset);
	this._paptCd = this.fv_param.paptCd;
	this.sShlCd = this.fv_param.sShlCd;
	this.ptPtCnfmCd = this.fv_param.qstnPtPtCnfmCd;	// 참여코드
	
	// PC 화면 정렬
	this.fnSetcompSizeP();
	
	// 언어코드 KO 기본값 세팅
	this.dsMain.setColumn(0, "qstnExmnLangScCd", "KO");
	this.fvQstnExmnLangScCd = "KO";
	if(this.smfIsMobile()){
		this.divMain.form.div01.form.div01.form.btnKo.set_cssclass("btn_WF_S04LanggChoiceS_M");
	}else{
		this.divMain.form.div01.form.div01.form.btnKo.set_cssclass("btn_WF_S04LanggChoiceS");
	}
	this.paptLangCd();
	
	this.divTop.form.divMain.form.btnHome.set_visible(false);
	this.divTop.form.divMain.form.sta00.set_visible(false);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 화면로드 시 한국어Btn 초기화
*/
this.paptLangCd = function(){
	switch(this._paptCd) {
	case 'A' : this.divMain.form.div01.form.div01.form.btnKo.set_enable(true);
		break;
	case 'B' :
			if(!this.smfIsMobile()){
				this.divMain.form.div01.form.div01.form.btnKo.set_enable(true);
				this.divMain.form.div01.form.div01.form.btnEn.set_enable(true);
				this.divMain.form.div01.form.div01.form.btnVi.set_enable(true);
				this.divMain.form.div01.form.div01.form.btnZh.set_enable(true);
			}
			if(this.smfIsMobile()){
				this.divMain.form.div01.form.div01.form.btnKo.set_enable(true);
				this.divMain.form.div01.form.div01.form.btnZh.set_enable(true);
				this.divMain.form.div01.form.div01.form.btnVi.set_enable(true);
				this.divMain.form.div01.form.div01.form.btnEn.set_enable(true);
			}
		break;
	case 'C' : this.divMain.form.div01.form.div01.form.btnKo.set_enable(true);
		break;
	default:
	}
};

/**
 * 컴포넌트 사이즈 조절(PC)
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnSetcompSizeP = function(){
	if (!this.smfIsMobile()){
		var nMaxWidth = 1200;
		var nFormWidth = this.getOffsetWidth();
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.divMain.form.div00.setOffsetLeft(10 + nLeft);
			this.divMain.form.div01.setOffsetLeft(10 + nLeft);
		}else{
			var nLeft = 0;
			this.divMain.form.div00.setOffsetLeft(nLeft);
			this.divMain.form.div01.setOffsetLeft(nLeft);
		}
		this.divMain.form.resetScroll();
	}
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 언어 선택 시 
*/
this.cddcCdBtn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var qstnExmnLangScCd = obj.qstnExmnLangScCd;
	var cssClassNm = "btn_WF_S04LanggChoice";	//미선택한 버튼
	var cssClassChcNm = "btn_WF_S04LanggChoiceS";	//선택한 버튼
	
	if(this.smfIsMobile()){
		cssClassNm = "btn_WF_S04LanggChoice_M";
		cssClassChcNm = "btn_WF_S04LanggChoiceS_M";
	}
	
	if (obj.cssclass == cssClassChcNm){
		obj.set_cssclass(cssClassNm);
		this.divMain.form.btnNext.set_enable(false);
	}else{
		var objComps = this.divMain.form.div01.form.div01.form.components;
		for(var i in objComps){
			if (objComps[i] instanceof nexacro.Button) {
				objComps[i].set_cssclass(cssClassNm);
			}
		}
		
		obj.set_cssclass(cssClassChcNm);
		this.divMain.form.btnNext.set_enable(true);
		
		//데이터 셋에 값 세팅
		this.dsMain.setColumn(0, "qstnExmnLangScCd", qstnExmnLangScCd);
		
		this.fvQstnExmnLangScCd = obj.qstnExmnLangScCd;
		this.fvLangNo = obj.LangNo;
	}
};


/**
 * @description '다음단계' 클릭 시
*/
this.div01_btnNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//언어선택 필수 체크
	var qstnExmnLangScCd = this.dsMain.getColumn(0, "qstnExmnLangScCd");
	if(this.isNil(qstnExmnLangScCd)){
		this.smfAlertEds('언어를 선택해주십시오');
		return;
	}
	
	this.dsSearch.setColumn(0, "qstnExmnLangScCd", qstnExmnLangScCd);
	
	//검사참여 화면 호출
	var param = {
		dataset: this.dsMain.saveXML(),
		langCd: this.fvQstnExmnLangScCd,
		langNo: this.fvLangNo,
		paptCd: this._paptCd,
		qstnPtPtCnfmCd: this.ptPtCnfmCd,
		sShlCd : this.sShlCd
	};
	var sUrl = "pa_eds_shf_os::eds_shfos08_m01.xfdl";
	this.smfSetWorkPage(sUrl, param, false);
};

/**
 * 화면 사이즈 조절 (PC)
 */
this.eds_shfos07_m01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	if(!this.smfIsMobile()){
		this.fnSetcompSizeP();
	}
};
]]></Script>
  </Form>
</FDL>
