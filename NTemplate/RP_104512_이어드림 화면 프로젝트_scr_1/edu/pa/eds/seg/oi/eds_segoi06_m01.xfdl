    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 학생정서행동특성검사 > 학생정서-언어선택
*  @FileName 	eds_segoi06_m01.xfdl 
*  @Creator 	kangchaeyoon
*  @CreateDate 	2022.12.02
*  @Desction    학생정서-언어선택
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.12.02           Kangchaeyoon                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_param;	// 파라메터 세팅

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	this.smfResetScroll(this);
	
	// PC 화면정렬
	this.fnDisplayP();
	
	// 전달받은 파라메터 값 세팅
	this.fv_param = this.smfGetFormParams();
	this.dsMain.loadXML(this.fv_param.dataset);
	
	//헤더 버튼 비활성화
	if(this.smfIsMobile()){	//모바일일때
		this.divTop.form.fnSetTopFrameBtnVisible(false, false);
	}else{
		this.divTop.form.divMain.form.div00.set_visible(false);
	}
	
	//한국어로 언어 기본 설정
	this.fvSetKo();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 한국어로 기본 세팅 
*/
this.fvSetKo = function(){
	//데이터 셋에 값 세팅
	this.dsMain.setColumn(0, "inspLangScCd", "KO");
}

/**
 * @description PC 화면 정렬
*/
this.fnDisplayP = function ()
{
	if (!this.smfIsMobile()){
		var nMaxWidth = 1200;
		var nFormWidth = this.getOffsetWidth();
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.div01.form.div00.setOffsetLeft(10 + nLeft);
			this.div01.form.div01.setOffsetLeft(10 + nLeft);
		}else{
			var nLeft = 0;
			this.div01.form.div00.setOffsetLeft(nLeft);
			this.div01.form.div01.setOffsetLeft(nLeft);
		}
		this.div01.form.resetScroll();
	}
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 언어 선택 시 
*/
this.cddcCdBtn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var inspLangScCd = obj.inspLangScCd;

	//버튼 css 변경
	var objComps = this.div01.form.div01.form.div01.form.components;
	var cssclassNm = "btn_WF_S02LanggChoice";
	var cssclassChcNm = "btn_WF_S02LanggChoiceS";
	if(this.smfIsMobile()){
		cssclassNm = cssclassNm +"_M";
		cssclassChcNm = cssclassChcNm +"_M";
	}
	
	for(var i in objComps){
		var objComp = objComps[i];
		
		if(objComp.inspLangScCd){
			objComp.set_cssclass(cssclassNm);	//미선택한 버튼
		}
	}
	obj.set_cssclass(cssclassChcNm);
	
	//데이터 셋에 값 세팅
	this.dsMain.setColumn(0, "inspLangScCd", inspLangScCd);
};

/**
 * @description '확인' 버튼 클릭 시 
*/
this.div00_btnIdnty_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//언어선택 필수 체크
	var inspLangScCd = this.dsMain.getColumn(0, "inspLangScCd");
	if(this.isNil(inspLangScCd)){
		this.smfAlertEds('언어를 선택해주십시오');
		return;
	}
	
	//검사참여 화면 호출
	var param = {
		dataset: this.dsMain.saveXML()
	};
	var sUrl = "pa_eds_seg_oi::eds_segoi07_m01.xfdl";
	this.smfSetWorkPage(sUrl,param, false);
};

/**
 * @description form 사이즈 조절 시 (PC)
*/
this.eds_segoi06_m01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	if(!this.smfIsMobile()){
		this.fnDisplayP();
	}
};
]]></Script>
  </Form>
</FDL>
