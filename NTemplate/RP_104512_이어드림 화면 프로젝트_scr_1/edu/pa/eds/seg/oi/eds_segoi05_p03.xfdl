    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 학생정서행동특성검사 > 학생정서- 주소 찾기 팝업
*  @FileName 	eds_segoi05_p03.xfdl 
*  @Creator 	kangchaeyoon
*  @CreateDate 	2022.12.16
*  @Desction    학생정서-주소 찾기 팝업
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.12.16           Kangchaeyoon                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.searchType;



/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);	
	
	// 서버단에서 설정한 유효성 검증 목록을 획득하여 설정
	this.smfValidateService("validateMain", {
		url : "/sac_cmm_cm00_000.do",
		})
		.mappingRulesetToForm(this.div00.form.divSearch, "searchListRdnAddrInfo")
		.callback(function(callbackParams) {
		})
		.run()
	;
	
 	// 전달받은 파라메터 값 세팅
 	this.fv_param = this.smfGetPopupParams();
 	this.dsSearch.setColumn(0, "edsSegOi", this.fv_param.edsSegOi);
	
	//서치 타입 세팅
	this.div00.form.divSearch.form.rdoRoadLotno.set_index(0);
	
	//모바일일때
	if(this.smfIsMobile()){
		var ownerFream = this.getOwnerFrame().form.getOffsetBottom();
		//this.div00.setOffsetBottom(ownerFream - 50);
		this.resetScroll(this.div00.form);
		this.resetScroll(this);
	}
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

/**
 * 메세지 콜백함수
 */
this.fnMessageCallback = function(){
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
 /**
 * 조회 서비스
 */
this.fnSearchList = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("select")
		// 데이터 검증
		.validateForm(this.div00.form.divSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * 조회 버튼 클릭 시
 */
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	//필수 입력 처리
	if(this.isNil(this.dsSearch.getColumn(0, "ctpvNm"))){
		this.div00.form.divSearch.form.cboCtpvNm.setFocus();
		this.smfAlertEds('CM006', ["시도명"], this.fnMessageCallback);
		return false;
	}
	
	if(this.div00.form.divSearch.form.cboCtpvNm.value != '세종특별자치시') {
		if(this.isNil(this.div00.form.divSearch.form.edtSggNm.value) || this.div00.form.divSearch.form.edtSggNm.value.trim() == "") {
			this.div00.form.divSearch.form.edtSggNm.setFocus();
			this.smfAlertEds('CM006', ["시군구명"], this.fnMessageCallback);
			return false;
		} else if(this.isNil(this.div00.form.divSearch.form.edtRoadNm.value) || this.div00.form.divSearch.form.edtRoadNm.value.trim() == "") {
			this.div00.form.divSearch.form.edtRoadNm.setFocus();
				if (this.dsSearch.getColumn(0, "searchType") == "02") {
					this.smfAlertEds('CM006', ["읍면동명"], this.fnMessageCallback);
				} else {
					this.smfAlertEds('CM006', ["도로명"], this.fnMessageCallback);
				}
			return false;
		}
	}
	this.fnSearchList();
};

/**
 * 도로명/지번 라디오버튼 변경 시
 */
this.div00_divSearch_rdoRoadLotno_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	this.searchType = this.dsSearch.getColumn(0, "searchType");
	
	this.dsMain.clearData();
	
	if(this.searchType == "01") {
	    this.div00.form.divSearch.form.staRoadNm.set_text("도로명")
	    this.div00.form.divSearch.form.edtRoadNm.set_displaynulltext("도로명을 입력하세요.");
		this.div00.form.sta00.set_text("도로명 주소 검색 결과");
		this.div00.form.sta02.set_text("도로명 주소 ");
		this.div00.form.divSearch.form.edtRoadNm.set_value(null);
		this.div00.form.divSearch.form.edtSggNm.set_value(null);
	} else if(this.searchType == "02") {
	    this.div00.form.divSearch.form.staRoadNm.set_text("읍면동명")
	    this.div00.form.divSearch.form.edtRoadNm.set_displaynulltext("읍면동명을 입력하세요.");
		this.div00.form.sta00.set_text("지번 주소 검색 결과");
		this.div00.form.sta02.set_text("지번 주소 ");
		this.div00.form.divSearch.form.edtRoadNm.set_value(null);
		this.div00.form.divSearch.form.edtSggNm.set_value(null);
	}
	
};

/**
 * 도로명 정보 입력 후 엔터키 클릭 시 
 */
this.edtRoadNm_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	if(e.keycode == "13"){
		this.btnSearch_onclick();
	}
};

/**
 * 입력창 입력 시
 */
this.div00_divSearch_edtSearchKeyword_onkeyup = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	// 엔터키 이벤트
	if(e.keycode == "13"){
		this.fnSearchList();
	}
};

/**
 * 적용 버튼 클릭 시
 */
this.div00_btnAplcn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.isNil(this.div00.form.edtRoadNmDtl.value)){
		this.div00.form.edtRoadNmDtl.setFocus();
		this.smfAlertEds('CM006', ["상세주소"], this.fnMessageCallback);
		return;
	}
	
	this.smfSendResponseToOpener({
		"row": this.smfRowToObject(this.dsMain)
	});
	
	this.close(true);
};

/**
 * @description '닫기' 버튼 클릭 시 
 */
this.div00_btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};

/**
 * 시도명 변경 시
 */
this.div00_divSearch_cboCtpvNm_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
 	if(this.div00.form.divSearch.form.cboCtpvNm.value != '세종특별자치시') {
		this.div00.form.divSearch.form.edtSggNm.set_value(null);
		this.div00.form.divSearch.form.edtRoadNm.set_value(null);
 		this.div00.form.divSearch.form.edtSggNm.set_enable(true);
		this.div00.form.divSearch.form.edtSggNm.set_displaynulltext("시군구명을 입력하세요.");
 	} else if(this.div00.form.divSearch.form.cboCtpvNm.value == '세종특별자치시') {
		this.div00.form.divSearch.form.edtSggNm.set_value(null);
		this.div00.form.divSearch.form.edtRoadNm.set_value(null);
 		this.div00.form.divSearch.form.edtSggNm.set_enable(false);
		this.div00.form.divSearch.form.edtSggNm.set_displaynulltext("");
 	}
};

]]></Script>
    <Bind>
      <BindItem id="item0" compid="div00.form.edtRoadNmAddr" propid="value" datasetid="dsMain" columnid="roadAddrNm"/>
      <BindItem id="item1" compid="div00.form.edtRoadNmDtl" propid="value" datasetid="dsMain" columnid="roadDtlNm"/>
      <BindItem id="item2" compid="div00.form.divSearch.form.rdoRoadLotno" propid="value" datasetid="dsSearch" columnid="searchType"/>
      <BindItem id="item3" compid="div00.form.divSearch.form.edtSggNm" propid="value" datasetid="dsSearch" columnid="sggNm"/>
      <BindItem id="item4" compid="div00.form.divSearch.form.cboCtpvNm" propid="value" datasetid="dsSearch" columnid="ctpvNm"/>
      <BindItem id="item5" compid="div00.form.divSearch.form.edtRoadNm" propid="value" datasetid="dsSearch" columnid="roadNm"/>
    </Bind>
  </Form>
</FDL>
