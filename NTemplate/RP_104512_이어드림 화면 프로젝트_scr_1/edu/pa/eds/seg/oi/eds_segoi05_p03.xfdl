    <Objects>
      <Dataset id="dsMain" useclientlayout="true">
        <ColumnInfo>
          <Column id="zipNo" type="STRING" size="256" description="기초구역번호 (새우편번호)"/>
          <Column id="roadAddrNm" type="STRING" size="256" description="도로명주소"/>
          <Column id="roadDtlNm" type="STRING" size="256" description="읍면동명"/>
          <Column id="lotnoAddr" type="STRING" size="256" description="지번주소"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="ctpvNm" size="120" type="STRING" description="시도명"/>
          <Column id="sggNm" type="STRING" size="256" description="시군구명"/>
          <Column id="roadNm" type="STRING" size="256" description="도로명"/>
          <Column id="sttyEmdNm" type="STRING" size="256" description="읍면동명"/>
          <Column id="bdrgBldgNm" type="STRING" size="256" description="건물명"/>
          <Column id="searchType" type="STRING" size="256" description="검색주소 타입"/>
          <Column id="edsSegOi" type="STRING" size="256" description="학생정서특성검사만사용"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">select</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsMain=resultList</Col>
            <Col id="callback">fnTransCallback</Col>
            <Col id="asynctp"/>
            <Col id="url">/sac_cmm_cm00_002.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsCtpvNmList" useclientlayout="true">
        <ColumnInfo>
          <Column id="ctpvNm" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="ctpvNm">서울특별시</Col>
          </Row>
          <Row>
            <Col id="ctpvNm">부산광역시</Col>
          </Row>
          <Row>
            <Col id="ctpvNm">대구광역시</Col>
          </Row>
          <Row>
            <Col id="ctpvNm">인천광역시</Col>
          </Row>
          <Row>
            <Col id="ctpvNm">광주광역시</Col>
          </Row>
          <Row>
            <Col id="ctpvNm">대전광역시</Col>
          </Row>
          <Row>
            <Col id="ctpvNm">울산광역시</Col>
          </Row>
          <Row>
            <Col id="ctpvNm">세종특별자치시</Col>
          </Row>
          <Row>
            <Col id="ctpvNm">경기도</Col>
          </Row>
          <Row>
            <Col id="ctpvNm">강원특별자치도</Col>
          </Row>
          <Row>
            <Col id="ctpvNm">충청북도</Col>
          </Row>
          <Row>
            <Col id="ctpvNm">충청남도</Col>
          </Row>
          <Row>
