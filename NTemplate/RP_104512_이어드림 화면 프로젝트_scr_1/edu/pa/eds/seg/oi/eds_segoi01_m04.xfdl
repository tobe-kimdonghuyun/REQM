    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">select</Col>
            <Col id="url">/eds_seg_oi01_001.do</Col>
            <Col id="inDatasets"/>
            <Col id="outDatasets">dsList=dsList</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsList" useclientlayout="true">
        <ColumnInfo>
          <Column id="inspYr" type="STRING" size="256" description="검사연도"/>
          <Column id="instCd" type="STRING" size="256" description="기관코드"/>
          <Column id="qestnCn" type="STRING" size="256" description="질문내용"/>
          <Column id="ansCn" type="STRING" size="256" description="답변내용"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 학생정서행동특성검사 > 학생정서-자주묻는질문
*  @FileName 	eds_segoi01_m04.xfdl 
*  @Creator 	kangchaeyoon
*  @CreateDate 	2022.12.07
*  @Desction    학생정서-자주묻는질문
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.12.07           Kangchaeyoon                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_param;				//파라메터 세팅
this.fv_cddcCd;				//시도교육청 코드
this.fv_cddcNm;				//시도교육청명
this.DivInfo = {};    	 	// Q & A 항목 정보
this.fvMinHeight = 68; 		// 디폴트 높이
this.fvTitleHeight = this.smfIsMobile()?130:79;	 
this.fvContentsHeight = this.smfIsMobile()?240:193; 
this.fvContentsWidth = this.smfIsMobile()?400:747; 
this.fv_prefixIdTitleDiv = "divTitle";
this.fv_prefixIdTitleButton = "btnTitle";
this.fv_prefixIdOpenButton = "btnOpen";
this.fv_prefixIdContentsDiv = "divContents";
this.fv_prefixIdContentsAnswer = "staAnswer";
this.fv_mobile = "";

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	//헤더의 '<-'버튼 활성화
	if(this.smfIsMobile()){	//모바일일때
		this.divTop.form.fnSetTopFrameBtnVisible(true, true);
	}else{
		this.divTop.form.divMain.form.btnBfr.set_visible(true);
	}
	
	// pc화면 정렬
	this.fnDisplayP();
	
	// 전달받은 파라메터 값 세팅
	this.fv_param = this.smfGetFormParams();
	this.fv_cddcCd = this.fv_param.cddcCd;
	this.fv_cddcNm = this.fv_param.cddcNm;
	
	//헤더에 시도교육청 정보 세팅
	this.divTop.form.fv_cddcCd = this.fv_cddcCd;
	this.divTop.form.fv_cddcNm = this.fv_cddcNm;
	
	//자주묻는질문 조회
	this.fnQnaList();
	
	//DIV 마진 값 세팅
	this.div01.form.div00.form.divFAQ.fv_DIV_MARGIN = 0;
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 자주묻는질문 조회 Transaction
 */ 
this.fnQnaList = function(obj, e)
{
	//기존 div 삭제
	this.fnDeleteDiv();
	
 	// 서비스 객체 생성
	this.smfSearchService("select")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			var objTargetDivForm =  this.div01.form.div00.form.divFAQ.form;	//자주묻는질문 div 영역
			
			//리스트 수만큼 반복
			for(var i = 0; i < this.dsList.rowcount; i++){
				this.fnAppendDiv(objTargetDivForm,this.dsList, i);			
			}
			this.smfResetScroll(objTargetDivForm);
		});	
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * 하나의 게시글을 추가
 * @param : {object}   scope  대상Form
 * @param : {object}   objDs  추가할 데이터셋
 * @param : {Number}   nRow   추가할 데이터셋의 row
 */
this.fnAppendDiv = function(scope,objDs,nRow)
{
	// 추가될 index를 구함(부모 Div에 있는 _count 유저프로퍼티 사용, 없으면 0으로 초기화)
	var nIdx = 0;
	
	if(this.smfIsNull(scope.parent._count)){  
		nIdx = 0;	//세팅이 안되어 있으면 0으로 세팅
		scope.parent._count = 0;
	}else{
		nIdx = scope.parent._count;
	}
	
	// 타이틀 Div 만들기
	var objTitleDiv = this.fnAddTitleDiv(scope,nIdx,objDs,nRow);
	
	// 상세 Div만들기
	var objContentsDiv = this.fnAddContentsDiv(scope,nIdx,objDs,nRow);

	// 카운트 개수를 증가
	scope.parent._count++;
}

/**
 * 타이틀 Div를 추가
 * @param : {object}   scope  대상Form
 * @param : {Number}   nIdx   추가할 div Index
 * @param : {object}   objDs  추가할 데이터셋
 * @param : {Number}   nRow   추가할 데이터셋의 row
 */
this.fnAddTitleDiv = function (scope,nIdx,objDs,nRow)
{
	var sDivId = this.fv_prefixIdTitleDiv + nIdx;
	var sFaqTitlNm = objDs.getColumn(nRow,"qestnCn");	//질문 컬럼 값
	
	// Div 생성
	var nHeight = this.fvTitleHeight;
	var sBeforeContentsId = "divContents"+(nIdx-1);
	var sChildId = "divContents"+nIdx;
	var sDivCssClass = "div_WF_S02FAQBox_Q03"+this.fv_mobile;	
	var sDivArrow = "btn_WF_FAQDrop"+this.fv_mobile;	//'v'버튼
	
	var objDiv = scope[sDivId];
	
	if(!objDiv){
		objDiv = new Div();
		if( nIdx == 0 ){	// 최초의 오브젝트는 위의 Div의 Top을 0으로 함
			objDiv.init(sDivId, 0, 0, null, nHeight, 0, null);		//마지막에 높이 재조정하기 때문에 크게 상관x 
			sDivCssClass = "div_WF_S02FAQBox_Q01"+this.fv_mobile;
		}else
		{   // 최초 Div이외의 것은 바로위의 오브젝트 바로아래에 생성
			objDiv.init(sDivId, 0, sBeforeContentsId +":"+ 0, null, nHeight, 0, null);
		}

		// 만들어진 Div를 부모에 추가
		scope.addChild(sDivId, objDiv); 
		
		// Div의 속성을 세팅
		objDiv.set_cssclass(sDivCssClass);
		objDiv.set_initvalueid("ivDivAccessibilityOff");
		objDiv.childId = sChildId;
		objDiv.dirArrow = sDivArrow;
		
		// Div를 보이게 설정(addChild()하면 반드시 show()를 해주어야 실제로 화면에 보임)  
		objDiv.show(); 
	}
	
	// 질문 버튼(Q) 넣기
	var questionButton = new Static();
	var sQuestionButtonId = "question"+nIdx;
	
	// PC일때랑 모바일일때 구분해서 생성
	if(this.smfIsMobile()){
		questionButton.init(sQuestionButtonId, 28, 31, 34, 34, null, 0);
	} else {
		questionButton.init(sQuestionButtonId, 20, 19, 35, 30, null, 0);
	}
	
	// 타이틀문장(Static) 생성
	var sStaticId = this.fv_prefixIdTitleButton+nIdx;
	
	// 질문영역(Question) 생성
	var objStatic = objDiv.form[sStaticId];
	if(!objStatic){
		objStatic = new Static();
		
		//right 값 btnOpen 에 참조할수 있도록 변경필요
		if(this.smfIsMobile()){
			objStatic.init(sStaticId, sQuestionButtonId + ":"+20, 0, null, null, 90, 0);
		}else {
			objStatic.init(sStaticId, sQuestionButtonId + ":"+0, 0, null, null, 55, 0);
		}
		
		// 만들어진 Static을 Div에 추가
		objDiv.form.addChild(sStaticId, objStatic); 
		
		// Static의 속성 설정
		objStatic.set_initvalueid("ivStcAccessibilityOn");
		objStatic.set_verticalAlign("middle");
		objStatic.set_cssclass("sta_WF_S02FAQ_Q"+this.fv_mobile);
		objStatic.dirArrow = sDivArrow;
		objStatic.childId = sChildId;
		
		// Static에 클릭이벤트 추가
		objStatic.addEventHandler("onclick",function(obj,e){
										this.fnReDraw(scope,obj,e,nIdx);
									}
									,this);
		objStatic.show();
	}
	objStatic.set_text(sFaqTitlNm);
	
	//입력값 높이 구하기
	var expandtextHeight = this.fnGetContentsHeight(objStatic);
	var plusHeight = this.smfIsMobile()?10:7;
	objDiv.setOffsetHeight(expandtextHeight+plusHeight);
	objDiv.set_visible(true);
	
	// 질문Div 우측에 'V' 버튼 추가
	this.fnCreateBtnOpen(objDiv.form,sChildId,nIdx);
	
	//모바일일 때 스테틱 크기 조정
	if(this.smfIsMobile()){
		var btnWidth = questionButton.getOffsetWidth();
		var staWidth = objStatic.getOffsetWidth();
		//objStatic.setOffsetRigth(staWidth-btnWidth);
	}
};

/**
 * Contents Div를 추가
 * @param : {object}   scope  대상Form
 * @param : {Number}   nIdx   추가할 div Index
 * @param : {object}   objDs  추가할 데이터셋
 * @param : {Number}   nRow   추가할 데이터셋의 row
 */
this.fnAddContentsDiv = function (scope,nIdx,objDs,nRow)
{
	var sDivId = this.fv_prefixIdContentsDiv + nIdx;
	var sFaqCn = objDs.getColumn(nRow,"ansCn");		// 답변 컬럼 값
	
	// Div 생성
	var nHeight = this.fvContentsHeight;
	var sBeforeContentsId = this.fv_prefixIdTitleDiv + nIdx;
	var sChildId = this.fv_prefixIdContentsDiv+nIdx;
	var sDivCssClass = "div_WF_S02FAQBox_A01"+this.fv_mobile;
	var sDivArrow = "btn_WF_FAQDrop"+this.fv_mobile;
	
	// Create Object  
	var objDiv = scope[sDivId];
	if(!objDiv)
	{
		objDiv = new Div();
		
		if(this.smfIsMobile()){
			objDiv.init(sDivId, 0, sBeforeContentsId +":"+ 0, null, nHeight, 0, null);
		} else {
			objDiv.init(sDivId, 0, sBeforeContentsId +":"+ 0, null, nHeight, 0, null);
		}
		
		// 만들어진 Div를 부모에 추가
		scope.addChild(sDivId, objDiv); 
		
		// Div의 속성을 세팅
		objDiv.set_cssclass(sDivCssClass);
		objDiv.set_initvalueid("ivDivAccessibilityOff");
		objDiv.childId = sChildId;
		objDiv.dirArrow = sDivArrow;
		
		// Div를 보이게 설정(addChild()하면 반드시 show()를 해주어야 실제로 화면에 보임)  
		objDiv.show(); 
	}
	
	// Contents문장(Static) 생성
	var sStaticCssClass = "sta_WF_S02FAQ_A"+this.fv_mobile; 
	
	// 1-1. 답변 버튼(A) 생성 
 	var sBtnQuestion = "labelQuestion"+nIdx;
 	var objButton = new Static();
 	
 	if(this.smfIsMobile()){
 		objButton.init(sBtnQuestion, 28, 20, 34, 34, null, null);
 	} else {
 		objButton.init(sBtnQuestion, 20, 19, 35, 30, null, null);
 	}
	
	// 1-2. 답변 내용 입력
	var sStaticAnswer = this.fv_prefixIdContentsAnswer+nIdx;
	var objStaticAnswer = objDiv.form[sStaticAnswer];
	if(!objStaticAnswer)
	{
		objStaticAnswer = new Static();  
		if(this.smfIsMobile()){
			objStaticAnswer.init(sStaticAnswer, sBtnQuestion + ":" + 0, 13, null, null, 20, 31);
		}else{
			objStaticAnswer.init(sStaticAnswer, sBtnQuestion + ":" + 30, 19, null, null, 53, 0);		
		}
		
		objDiv.form.addChild(sStaticAnswer, objStaticAnswer); 
		
		// Static의 속성 설정
		objStaticAnswer.set_initvalueid("ivStcAccessibilityOn");
		objStaticAnswer.dirArrow = sDivArrow;	
		objStaticAnswer.childId = "";
		objStaticAnswer.show();
	}
	objStaticAnswer.set_cssclass(sStaticCssClass);	
	objStaticAnswer.set_text(sFaqCn);

	// 답변(Answer)은 처음에는 안보이게 처리(높이를 0, visible=false)
	objDiv.setOffsetHeight(0);
	objDiv.set_visible(false);
}

/**
 * open 버튼 생성
 * @param : scope ( Div.form)
 * @param : divInfo 
 */
this.fnCreateBtnOpen = function(scope,sChildId,nIdx)
{
	var sBtnId = this.fv_prefixIdOpenButton+nIdx;
	var sDivArrow = "btn_WF_FAQDrop"+this.fv_mobile;
	
	// 버튼을 생성
	var objButton = scope[sBtnId];
	if(!objButton){
		objButton = new Button(); 
		if(this.smfIsMobile()){
			objButton.init(sBtnId, null, 0, 36, null, 30, 0);
		} else {
			objButton.init(sBtnId, null, 0, 30, null, 23, 0);
		}
		
		// 만들어진 Button을 Div에 추가
		scope.addChild(sBtnId, objButton);
		
		// 버튼의 속성을 설정
		objButton.set_initvalueid("ivBtnAccessibilityButton");	
		objButton.childId = sChildId;
		objButton.dirArrow = sDivArrow;
		
		// Button에 클릭이벤트 추가
		var sStaticId = this.fv_prefixIdTitleButton+nIdx;
		objButton.addEventHandler("onclick",function(obj,e){
			this.fnReDraw(scope.parent.parent, scope[sStaticId], e, nIdx);
		},this);
		
		// Button을 보이게 설정(addChild()하면 반드시 show()를 해주어야 실제로 화면에 보임)  
		objButton.show();  
	}
	objButton.set_cssclass("btn_WF_FAQDrop"+this.fv_mobile);
};

/**
 * 생성 컴포넌트 재 설정 및 reDraw 함
 * @param : obj - Static
 * @param : e   - Static eventInfo
 */
this.fnReDraw = function(scope,obj,e, nIdx)
{
	// 상태값 추가 
	var openFlag = true;
	if(obj.parent.parent.form[this.fv_prefixIdOpenButton+nIdx].cssclass == "btn_WF_FAQDropup"+this.fv_mobile){
		openFlag = false;
	}
	// class 초기화 
	for(var i = 0; i < scope.components.length; i++){	
		if(scope.components[i] instanceof nexacro.Div ){
			// titleDiv 초기화
			if(scope.components[i].id.substr(0,this.fv_prefixIdTitleDiv.length) == this.fv_prefixIdTitleDiv){
				scope.components[i].set_cssclass("div_WF_S02FAQBox_Q03"+this.fv_mobile);
				if( nIdx === 0 ){			
					scope.components[i].set_cssclass("div_WF_S02FAQBox_Q01"+this.fv_mobile);
				}
				
				scope.components[i].form[this.fv_prefixIdOpenButton+(scope.components[i].id.substr(this.fv_prefixIdTitleDiv.length))].set_cssclass("btn_WF_FAQDrop"+this.fv_mobile);
			}
			// contentsDiv 초기화
			if(scope.components[i].id.substr(0,this.fv_prefixIdContentsDiv.length) == this.fv_prefixIdContentsDiv){
				scope.components[i].setOffsetHeight(0);
				scope.components[i].set_visible(false);
			}
		}
	}
	
	//답변 열고 닫을 때, 화면 재조정
	this.smfResetScroll(this.div01.form.div00.form.divFAQ.form);
	
	var objTitleDiv = obj.parent.parent;
	var objTitleStatic = objTitleDiv.form[this.fv_prefixIdTitleButton+nIdx];
	var objTitleButton = objTitleDiv.form[this.fv_prefixIdOpenButton+nIdx];
	var objContentsDiv = scope[objTitleDiv.childId];
	var objContentsStatic = objContentsDiv.form[this.fv_prefixIdContentsAnswer+nIdx];
	
	// 자주묻는질문 정보를 서랍형으로 오픈 
	if(!this.smfIsNull(obj.childId) && openFlag){
		
		if(this.smfIsMobile()){
			objTitleDiv.set_cssclass("div_WF_S02FAQBox_Q03");
		}

		objTitleButton.set_cssclass("btn_WF_FAQDropup"+this.fv_mobile);
		objContentsDiv.set_visible(true);
		
		var expandtextHeight = this.fnGetContentsHeight(objContentsStatic);
		objContentsStatic.setOffsetHeight(expandtextHeight);
		this.smfResetScroll(objContentsDiv.form);
	}
	this.smfResetScroll(scope);
};

/**
 * 다시 조회할때, 미리 조회되어있는 값들을 지우는 함수
 */
this.fnDeleteDiv = function()
{
	var objComps = this.div01.form.div00.form.divFAQ.form.components;
	var nCount = objComps.length
	for(var i = nCount-1; i >= 0; i--)
	{
		var objComp = objComps[i];
		//objComp.set_visible(false);
		var objDelete = this.div01.form.div00.form.divFAQ.removeChild(objComp.id);
		if(objDelete){
			objDelete.destroy();
		}
	}
	this.div01.form.div00.form.divFAQ._count = 0;
}

/**
 * 높이 값 구하는 함수
 */
this.fnGetContentsHeight = function(objContentsStatic)
{
	var strFont = 'bold 16px/1.5 "NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic"';
	var strMFont = '28px/1.5 "NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic"';
	var Font = this.smfIsMobile()?strMFont:strFont;
	var nHeightPadding = 38;		//19 X 2 (템플릿에 19px)	
	
	var staText = objContentsStatic.text;
	var staWidth = objContentsStatic.getOffsetWidth();
	var nTextHeight = nexacro.getTextSize(staText,Font,staWidth,"char");
	
	return nTextHeight.ny+nHeightPadding ;
};

/**
 * 컴포넌트 사이즈 조절(PC)
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnDisplayP = function(){
	if (!this.smfIsMobile()){
		var nMaxWidth = 1200;
		var nFormWidth = this.getOffsetWidth();
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.div01.form.div00.setOffsetLeft(10 + nLeft);
		}else{
			var nLeft = 0;
			this.div01.form.div00.setOffsetLeft(nLeft);
		}
		this.div01.form.resetScroll();
	}
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description '검사 참여안내' 버튼 클릭 시(모바일)
*/
this.div01_div01_btnGudn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divTop.form.fnBtnGudn();
};

/**
 * @description '자주묻는질문' 버튼 클릭 시(모바일)
*/
this.div01_div01_btnQna_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divTop.form.fnBtnQna();
};

/**
 * @description form 사이즈 변경 시(PC)
*/
this.eds_segoi01_m04_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	if(!this.smfIsMobile()){
		this.fnDisplayP();	// pc화면 정렬
	}
};
]]></Script>
  </Form>
</FDL>
