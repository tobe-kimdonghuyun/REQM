    <Objects/>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 학생정서행동특성검사 > 학생정서-검사사후안내문
*  @FileName 	eds_segoi08_m01.xfdl
*  @Creator 	kangchaeyoon
*  @CreateDate 	2022.12.08
*  @Desction    학생정서-검사사후안내문
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.12.08           Kangchaeyoon                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
this.fv_param;	// 파라메터 세팅

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	this.smfResetScroll(this);
	
	// 전달받은 파라메터 값 세팅
	this.fv_param = this.smfGetFormParams();
    var shlNm = this.fv_param.shlNm;
	
	//헤더 버튼 비활성화
	if(this.smfIsMobile()){	//모바일일때
		this.divTop.form.fnSetTopFrameBtnVisible(false, false);
	}else{
		this.divTop.form.divMain.form.div00.set_visible(false);
	}
	
	// PC화면 정렬
	this.fnDisplayP();
	
	//학교명 세팅
	this.div01.form.div01.form.sta02.set_text(shlNm+"장");
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 화면 정렬 (PC)
*/
this.fnDisplayP = function (){
	if (!this.smfIsMobile()){
		var nMaxWidth = 1200;
		var nFormWidth = this.getOffsetWidth();
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.div01.form.div00.setOffsetLeft(10 + nLeft);
			this.div01.form.div01.setOffsetLeft(10 + nLeft);
		}else{
			var nLeft = 0;
			this.div01.form.div00.setOffsetLeft(nLeft);
			this.div01.form.div01.setOffsetLeft(nLeft);
		}
		this.div01.form.resetScroll();
	}
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description '끝내기' 버튼 클릭 시 
*/
this.div01_btnEnd_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfAlertEds("설문 참여가 완료되었습니다.", function ()
	{
		// 정서 map화면으로 이동
		window.location.replace("https://mom.eduro.go.kr");
	});
};


this.eds_segoi08_m01_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	if(!this.smfIsMobile()){
		// PC화면 정렬
		this.fnDisplayP();
	}
};
]]></Script>
  </Form>
</FDL>
