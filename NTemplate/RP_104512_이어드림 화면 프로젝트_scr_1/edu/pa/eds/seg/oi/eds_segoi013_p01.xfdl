*******************************************************************************
*/

this.chkVal == "";

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/





/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

this.frmTemp01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	this.pv_params = this.smfGetPopupParams();
	this.fvPaptSc = this.pv_params.paptSc;
};


/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

this.fnPopupCallback = function(e){	
	

}

this.fnPopupGo = function(e){	
	var popupParams = {
		callback: this.fnPopupCallback,		// 콜백함수 지정
		sender: obj, 						// sender 지정
		params: {							// 팝업 전달 파라메터 지정
				procType: "none",				// 처리타입 지정
			    chkVal : this.chkVal
				},
				titlebar : false
				};
	// 모바일일 때만 nLeft, nTop null로 주고 nWidth, nHeight는 모바일 사이즈 그대로 줌*** popup	
	
	this.smfDialog("_auto", "pa_eds_seg_oi::eds_segoi012_p01.xfdl" ,popupParams);
}

this.fnPopupGo2 = function(e){	
	var popupParams = {
		callback: this.fnPopupCallback,		// 콜백함수 지정
		sender: obj, 						// sender 지정
		params: {							// 팝업 전달 파라메터 지정
				procType: "none",				// 처리타입 지정
			    chkVal : this.chkVal
				},
				titlebar : false
				};
	// 모바일일 때만 nLeft, nTop null로 주고 nWidth, nHeight는 모바일 사이즈 그대로 줌*** popup	
	
	this.smfDialog("_auto", "pa_eds_seg_oi::eds_segoi012_p02.xfdl" ,popupParams);
}


