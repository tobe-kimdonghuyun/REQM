<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="eds_segoi012_p01" width="1920" height="930" titletext="학생정서-동영상시청팝업" onload="frmTemp01_onload" cssclass="frm_Pop_bgTrsprt">
    <Layouts>
      <Layout height="930" width="1920" screenid="ScreenDeskTop">
        <Static id="staPopupTitleAss" taborder="0" left="20" top="20" width="20" height="20" initvalueid="ivStcAccessibilityOn"/>
        <Div id="div00" taborder="1" left="10" top="5" cssclass="div_WF_SurvPopLine" initvalueid="ivDivAccessibilityOff" bottom="20" right="10">
          <Layouts>
            <Layout>
              <Static id="sta00_00" taborder="0" left="0" top="0" height="40" cssclass="sta_WF_GDSize" text="40" visible="false" initvalueid="ivStcAccessibilityOff" right="0"/>
              <WebView id="WebView00" taborder="2" left="0" top="sta00_00:0" right="0" bottom="17" onusernotify="div00_WebView00_onusernotify"/>
              <Static id="staTitle00" text=" 동영상 시청 후 닫기 버튼을 클릭하시기 바랍니다." left="19" top="8" height="26" cssclass="sta_WF_Txt18B" initvalueid="ivStcAccessibilityOn" usedecorate="true" width="478" onclick="div00_staTitle00_onclick" taborder="1"/>
              <Button id="btnClose" taborder="3" text="닫기" left="1822" top="7" width="60" height="30" background="#ffffffff" onclick="btnOk_onclick" font="bold 14pt/normal &quot;Arial&quot;" color="#000000" cssclass="sta_WF_Txt18B"/>
            </Layout>
            <Layout name="Layout0">
              <Static id="sta00_00" left="0" top="0" height="50" right="0" taborder="0" text="50"/>
              <WebView id="WebView00" top="sta00_00:10" bottom="10" left="10" right="10" taborder="2"/>
              <Static id="staTitle00" cssclass="sta_WF_Txt14B" top="13" left="19" width="531" height="40" taborder="1"/>
              <Button id="btnClose" left="546" top="13" width="69" height="40" font="normal 700 18pt/normal &quot;Arial&quot;" taborder="3"/>
            </Layout>
            <Layout name="Layout3">
              <Button id="btnClose" left="699" top="13" width="69" height="30" font="bold 18pt/normal &quot;Arial&quot;"/>
              <Static id="staTitle00" left="19" top="8" width="568" height="36" cssclass="sta_WF_Txt14B" enableevent="true"/>
              <Static id="sta00_00" height="55" left="0" top="0" right="0"/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
      <Layout name="Layout0" screenid="mobile" height="2700" mobileorientation="portrait" type="default" width="640">
        <Div id="div00" cssclass="div_Pop_SurvBox_C" taborder="0" text="" left="10" top="5" right="10" bottom="10"/>
        <Static id="staPopupTitleAss" taborder="1"/>
      </Layout>
      <Layout name="Layout3" width="800" height="1500" mobileorientation="landscape" type="default" flexcrossaxisalign="start" flexcrossaxiswrapalign="start" flexmainaxisalign="start" flexwrap="nowrap" tabledirection="horizontal" screenid="tablet">
        <Div id="div00" bottom="10" left="10" top="5" right="10"/>
      </Layout>
    </Layouts>
    <Objects/>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 학생정서행동특성검사 > 학생정서-동영상시청팝업
*  @FileName 	eds_segoi12_p01.xfdl 
*  @Creator 	youn
*  @CreateDate 	2025.03.01
*  @Desction    학생정서-설명동영상링크팝업
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2025.03.01           youn                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

this.frmTemp01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
	this.pv_params = this.smfGetPopupParams();
	this.fvPaptSc = this.pv_params.paptSc;
	this.fvChkVal = this.pv_params.chkVal; // 임시
	
	if(this.fvPaptSc == "02"){ // 초
		this.div00.form.WebView00.set_url("https://www.youtube.com/embed/2bBFtYbD51g");
	}else{	// 중고
		this.div00.form.WebView00.set_url("https://www.youtube.com/embed/rC8_xCP59_8");
	}
	
	// this.fnDisplayP();
	//this.div00.form.staTitle00.font.size(10);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/**
 * 컴포넌트 사이즈 조절(PC)
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnDisplayP = function(){
	if (!this.smfIsMobile()){
		var nMaxWidth = 1200;
		var nFormWidth = this.getOffsetWidth();
		var vLeft = Math.floor((this.getOffsetWidth() - (+this.div00.form.sta00_00.getOffsetWidth()))/2);
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.div00.form.WebView00.setOffsetLeft(10 + nLeft);
			this.div00.form.sta00_00.setOffsetLeft(10 + vLeft);
			this.div00.form.staTitle00.setOffsetLeft(10 + vLeft);
			
		}else{
			var nLeft = 0;
			this.div00.form.WebView00.setOffsetLeft(nLeft);
		}
		this.div00.resetScroll();
	}
};


/**
 * @description '닫기' 버튼 클릭 시 
 */
this.btnOk_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	this.smfSendResponseToOpener({
		"urlName": 	"url"
	});
	
	this.close(true);
};]]></Script>
  </Form>
</FDL>
