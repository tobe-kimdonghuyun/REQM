    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 학생정서행동특성검사 > 학생정서-시도별문의안내팝업
*  @FileName 	eds_segoi01_p01.xfdl 
*  @Creator 	kangchaeyoon
*  @CreateDate 	2022.11.28
*  @Desction    학생정서-시도별문의안내팝업
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.11.28           Kangchaeyoon                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description '닫기' 버튼 클릭 시 
 */
this.div00_btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};

/**
 * @description '닫기' 버튼 클릭 시 
 */
this.btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};



/**
 * @description '선택' 버튼 클릭 시 
 */
this.div00_cboOrgCd_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	if(this.div00.form.cboOrgCd.value == 'A10'){
		this.dsOrgCallNum.filter("");
	}else{
		this.dsOrgCallNum.filter("orgCd == '" + this.div00.form.cboOrgCd.value + "'");
	}
	
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="div00.form.cboOrgCd" propid="value" datasetid="dsShlList" columnid="shlCrseScCd"/>
    </Bind>
