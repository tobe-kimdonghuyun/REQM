    <Objects/>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 학생정서행동특성검사 > 학생정서-본인확인방법선택 팝업
*  @FileName 	eds_segoi02_p01.xfdl 
*  @Creator 	kangchaeyoon
*  @CreateDate 	2022.12.01
*  @Desction    학생정서-본인확인방법선택 팝업
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.12.01           Kangchaeyoon                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
this.fv_param;		// 파라메터 세팅
this.fv_LgnMthCd;	//로그인 방식

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);	
	
	// 전달받은 파라메터 값 세팅
	this.fv_param = this.smfGetPopupParams();
	this._cddcCd = this.fv_param.cddcCd;
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 로그인 화면 호출
*/
this.fnLgnOpen = function(){
	this.smfSendResponseToOpener({
		"LgnMth": 	this.fv_LgnMthCd
	});

	this.close(true);
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description '참여번호' 버튼 클릭 시
*/
this.div00_btnPtptSnLgn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fv_LgnMthCd = "01";
	this.fnLgnOpen();
};

/**
 * @description '교육디지털원패스' 버튼 클릭 시
*/
this.div00_btnOnePasslLgn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fv_LgnMthCd = "02";
	this.fnLgnOpen();
};

/**
 * @description '닫기' 버튼 클릭 시 
 */
this.div00_btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};]]></Script>
  </Form>
</FDL>
