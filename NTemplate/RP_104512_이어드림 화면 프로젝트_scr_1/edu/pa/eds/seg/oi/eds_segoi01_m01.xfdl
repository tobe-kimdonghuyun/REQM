    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 학생정서행동특성검사 > 학생정서-시도교육청 선택
*  @FileName 	eds_segoi01_m01.xfdl 
*  @Creator 	kangchaeyoon
*  @CreateDate 	2022.11.24
*  @Desction    학생정서-시도교육청 선택
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.11.24           Kangchaeyoon                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	//스크롤바 갱신
	this.smfResetScroll(this);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 /**
 * @description 시도교육청 버튼 css 변경
*/
 this.fnSetCddcCssclass = function(objBtn)
{
	var objComps = this.div00.form.divCddcList.form.components;
	var cssclassNm = "btn_WF_SurvMain02";
	var cssclassChcNm = "btn_WF_SurvMain02S";
	if(this.smfIsMobile()){
		cssclassNm = cssclassNm +"_M";
		cssclassChcNm = cssclassChcNm +"_M";
	}
	for(var i in objComps){
		var objComp = objComps[i];
		if(objComp.cddcCd){
			
			objComp.set_cssclass(cssclassNm); //clear
		}
	}
	objBtn.set_cssclass(cssclassChcNm);  //select
}

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description '시도교육청 버튼' 클릭 시
*/
this.cddcCdBtn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sCddcCd = obj.cddcCd;
	var findRow = this.dsCddcList.findRow("cddcCd",sCddcCd);
	
 	var cddcName = this.dsCddcList.getColumn(findRow,"cddcNm");
 	var cddcInfo = this.dsCddcList.getColumn(findRow,"info");
	
	//시도교육청 문의전화 안내글 세팅
	this.div00.form.divCddcList.form.staCddcNm.set_text(cddcName+" 문의전화");
	this.div00.form.divCddcList.form.stacddcInfo.set_text(cddcInfo);

	//버튼 css 변경
	this.fnSetCddcCssclass(obj);
	
	//'설문참여하기' 버튼 활성화
	this.div00.form.btnQstnPtpt.set_visible(true);
	
	//스크롤바 갱신
	this.div00.form.divCddcList.form.resetScroll();
	
	//시도교육청 정보 세팅
	this._cddcCd = obj.cddcCd;
	this._cddcNm = this.dsCddcList.getColumn(findRow,"cddcNm");
};

/**
 * @description '검사 참여하기' 버튼 클릭 시
*/
this.div00_btnQstnPtpt_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.getOwnerFrame().form._surveyInfo_cddcCd = this._cddcCd;
	this.smfSetCddcCode(this._cddcCd);

	var param = {
		cddcCd : this._cddcCd,
		cddcNm : this._cddcNm
	};
	this.smfSetWorkPage("pa_eds_seg_oi::eds_segoi02_m01.xfdl", param, false);	
};

/**
 * @description '검사 참여안내' 버튼 클릭 시(모바일)
*/
this.div00_div01_btnGudn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divTop.form.fnBtnGudn();
};

/**
 * @description '자주묻는질문' 버튼 클릭 시(모바일)
*/
this.div00_div01_btnQna_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divTop.form.fnBtnQna();
};
]]></Script>
  </Form>
</FDL>
