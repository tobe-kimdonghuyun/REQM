        <Button id="btnClose" taborder="2" top="0" width="48" height="48" cssclass="btn_Pop_close_W" initvalueid="ivBtnAccessibilityButton" right="-214" visible="false" enable="true" text="" onclick="btnClose_onclick" accessibilitylabel="팝업 닫기"/>
