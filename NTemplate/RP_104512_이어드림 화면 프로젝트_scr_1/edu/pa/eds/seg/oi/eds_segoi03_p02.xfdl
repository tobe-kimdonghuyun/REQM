            <Layout name="default0">
              <Static id="staTitle" taborder="0" text="학교찾기" left="40" top="40" width="155" height="44" cssclass="sta_WF_Txt34B" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
              <Button id="btnClose" taborder="7" left="729" top="42" width="36" height="36" cssclass="btn_WF_SurvPopClose" initvalueid="ivBtnAccessibilityButton" visible="false"/>
              <Edit id="edtSearch" taborder="1" left="40" top="104" width="354" height="80" initvalueid="ivEdtNormal" cssclass="edi_WF_SurveySch" displaynulltext="학교명" maxlength="100"/>
