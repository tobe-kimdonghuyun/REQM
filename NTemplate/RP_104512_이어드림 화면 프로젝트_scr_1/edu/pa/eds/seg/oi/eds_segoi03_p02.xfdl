              <Combo id="cboCrseSc" taborder="5" text="- 선택 -" left="86" top="397" width="280" height="40" initvalueid="ivCmbNormal" cssclass="cmb_WF_SurvGrade" codecolumn="codecolumn" datacolumn="datacolumn" value="" index="0" visible="false" innerdataset="innerdataset">
