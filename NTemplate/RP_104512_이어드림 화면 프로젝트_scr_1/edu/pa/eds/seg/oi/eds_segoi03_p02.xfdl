              <Static id="staTitle" taborder="0" text="학교찾기" left="20" top="14" width="547" height="36" cssclass="sta_WF_Txt18B" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
              <Edit id="edtSearch" taborder="1" left="20" top="68" width="460" height="40" initvalueid="ivEdtNormal" cssclass="edi_WF_SurveySch" displaynulltext="학교명을 입력하세요" maxlength="100" oninput="div00_edtSearch_oninput" onkeyup="div00_edtSearch_onkeyup" onchanged="div00_edtSearch_onchanged"/>
