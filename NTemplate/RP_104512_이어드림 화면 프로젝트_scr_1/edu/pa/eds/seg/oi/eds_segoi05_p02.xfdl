    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="package" type="STRING" size="256" sumtext="vo와 service에서 사용할 패치지명"/>
          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">save</Col>
            <Col id="url">/eds_seg_oi05_002.do</Col>
            <Col id="inDatasets">dsAddrInfo=dsAddrInfo</Col>
            <Col id="outDatasets">dsApiResponseList=dsApiResponseList</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsAddrInfo" useclientlayout="true" oncolumnchanged="dsAddrInfo_oncolumnchanged">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256" description="시도교육청코드"/>
          <Column id="inspYr" type="STRING" size="256" description="검사연도"/>
          <Column id="enfcTme" type="STRING" size="256" description="시행회차"/>
          <Column id="shlCd" type="STRING" size="256" description="학교코드"/>
          <Column id="segStuInvlNo" type="STRING" size="256" description="학생정서행동특성검사학생개인번호"/>
          <Column id="grd" type="STRING" size="256" description="학년"/>
          <Column id="clsCd" type="STRING" size="256" description="학급코드"/>
          <Column id="scnlAddr" type="STRING" size="256" description="가정통신문주소"/>
          <Column id="scnlDtlAddr" type="STRING" size="256" description="가정통신문상세주소"/>
          <Column id="scnlRcvrNm" type="STRING" size="256" description="가정통신문수신자명"/>
          <Column id="stuAddrZip" type="STRING" size="256" description="학생주소우편번호"/>
          <Column id="postNo" type="STRING" size="256" description="학생주소우편번호"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsApiResponseList" useclientlayout="true">
        <ColumnInfo>
          <Column id="code" type="STRING" size="256" description="연계상태값"/>
          <Column id="message" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 학생정서행동특성검사 > 학생정서-검사결과우편발송용주소 팝업
*  @FileName 	eds_segoi05_p02.xfdl 
*  @Creator 	kangchaeyoon
*  @CreateDate 	2022.12.01
*  @Desction    학생정서-검사결과우편발송용주소 팝업
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.12.01           Kangchaeyoon                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_param;	// 파라메터 세팅
this.fv_addrUpdateYn;	// 주소변경유무
this.fv_qrData;	// qr접속 시 구분값

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitPopup(obj);	
	
	// 전달받은 파라메터 값 세팅
	this.fv_param = this.smfGetPopupParams();
	this.dsAddrInfo.loadXML(this.fv_param.dataset);
	this.dsAddrInfo.setColumn(0, "stuAddrZip", this.dsAddrInfo.getColumn(0, "postNo"));
	this.fv_qrData = this.fv_param.qrData;
	console.log(this.fv_qrData);
	
	this.fv_addrUpdateYn = 'N';
	
	if(!this.smfIsNull(this.fv_qrData)){	// qr이면 창닫기 안 보이게 처리
		this.div00.form.btnClose.set_visible(false);
		this.btnClose.set_visible(false);
	}
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
/**
 * @description popup callback
 */
this.fnPopupCallback = function(e, sender){

	//도로명주소 찾기 팝업 콜백
	this.dsAddrInfo.setColumn(0, "stuAddrZip", e.row["zipNo"]);
	this.dsAddrInfo.setColumn(0, "scnlAddr", e.row["roadAddrNm"]);
	this.dsAddrInfo.setColumn(0, "scnlDtlAddr", e.row["roadDtlNm"]);
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 검사결과우편발송용 주소 저장 Transaction
 */
 this.fnSaveAddr = function () {
	// 서비스 객체 생성
	this.smfSaveService("save")
		// 실행
		.run()
		// 사용자에게 confirm메시지를 표시할지 여부
		.showConfirm(false)
		// (권장) 데이터 존재 필수
		.requireExistsData(this.dsAddrInfo)
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return; 
				this.addrPopupClose();
		});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 팝업 닫기(callback : true)
 */
this.addrPopupClose = function()
{
	this.smfSendResponseToOpener({
		"urlName" : "addrPopup"
	});
	this.close(true);
};

/**
 * 디바이스 구분
 * @param  : N/A
 * @return : deviceNm			- 디바이스 명칭
 */
this.fnDeviceKnd = function(){
	var mobileFlag = /Mobile|iP(hone|od)|Windows(CE|Phone)|Minimo|Opera M(obi|ini)|BlackBerry|Nokia/;

	if(navigator.userAgent.match(mobileFlag) && !navigator.userAgent.match(/iPad/)){
		return 'Mobile';
	}else if(navigator.userAgent.match(/iPad|Android/)){
		return 'Tablet';
	}else{
		return 'PC';
	}
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description '우편번호검색' 버튼 클릭 시 
 */
this.btnAddrSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//주소찾기 팝업 호출
	var popupParams = {
		callback: this.fnPopupCallback,		// 콜백함수 지정
		sender: obj, 						// sender 지정
		params: {							// 팝업 전달 파라메터 지정
			procType: "none",				// 처리타입 지정
			edsSegOi : 'edsSegOi05'
		},
		titlebar : false
	};
		// 모바일일 때만 nLeft, nTop null로 주고 nWidth, nHeight는 모바일 사이즈 그대로 줌*** popup
		if(this.fnDeviceKnd == 'Mobile'){
			this.smfDialog("_auto", "pa_eds_seg_oi::eds_segoi05_p03.xfdl", popupParams, null, null, 660, 1990);
		}if(this.fnDeviceKnd == 'Tablet'){
			this.smfDialog("_auto", "pa_eds_seg_oi::eds_segoi05_p03.xfdl", popupParams, null, null, 750, 1870);
		}else{
			this.smfDialog("_auto", "pa_eds_seg_oi::eds_segoi05_p03.xfdl", popupParams);
		}
};

/**
 * @description 주소정보가 변경되었는지 확인
 */
this.dsAddrInfo_oncolumnchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	//주소변경여부 변수 값 세팅
	this.fv_addrUpdateYn = "Y";
};

/**
 * @description '주소 저장 및 검사시작' 버튼 클릭 시 
 */
this.div00_btnSaveAddr_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//필수값 체크 추가
	var scnlAddr = this.dsAddrInfo.getColumn(0, "scnlAddr");
	if(this.isNil(scnlAddr)){
		this.smfAlertEds('CM006',['주소']);
		return;
	}
	
	var scnlDtlAddr = this.dsAddrInfo.getColumn(0, "scnlDtlAddr");
	if(this.isNil(scnlDtlAddr)){
		this.smfAlertEds('CM006',['상세주소']);
		return;
	}
	
	var scnlRcvrNm = this.dsAddrInfo.getColumn(0, "scnlRcvrNm");
	if(this.isNil(scnlRcvrNm)){
		this.smfAlertEds('CM006',['수취인명']);
		return;
	}
	
	var addrUpdateYn = this.fv_addrUpdateYn;
	if(addrUpdateYn === "Y"){	//주소변경 시 저장처리
		//주소 저장
		this.fnSaveAddr();
	}else{
		this.addrPopupClose();
	}

};

/**
 * @description '닫기' 버튼 클릭 시 
 */
this.div00_btnClose_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close(false);
};]]></Script>
    <Bind>
      <BindItem id="item0" compid="div00.form.edtPostNo" propid="value" datasetid="dsAddrInfo" columnid="stuAddrZip"/>
      <BindItem id="item1" compid="div00.form.edtScnlAddr" propid="value" datasetid="dsAddrInfo" columnid="scnlAddr"/>
      <BindItem id="item2" compid="div00.form.edtScnlDtlAddr" propid="value" datasetid="dsAddrInfo" columnid="scnlDtlAddr"/>
      <BindItem id="item3" compid="div00.form.edtScnlRcvrNm" propid="value" datasetid="dsAddrInfo" columnid="scnlRcvrNm"/>
    </Bind>
  </Form>
</FDL>
