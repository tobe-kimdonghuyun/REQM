 ************************************************************************************************/
this.fv_btnPage = 0;	//페이지 번호
this.fv_divObjIdx = 0;	//div 번호
this.fv_divObj = [];	//div 배열
this.fv_param;			//파라메터 세팅
this.fv_cddcCd;			//시도교육청 코드
this.fv_cddcNm;			//시도교육청명
/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	this.smfResetScroll(this);
	
	//헤더의 '<-'버튼 활성화
	if(this.smfIsMobile()){	//모바일일때
		this.divTop.form.fnSetTopFrameBtnVisible(true, true);
	}else{
		this.divTop.form.divMain.form.btnBfr.set_visible(true);
	}
	
	// pc화면 정렬
	this.fnDisplayP();
	
	// 전달받은 파라메터 값 세팅
	this.fv_param = this.smfGetFormParams();
	this.fv_cddcCd = this.fv_param.cddcCd;
	this.fv_cddcNm = this.fv_param.cddcNm;
	
	//헤더에 시도교육청 정보 세팅
	this.divTop.form.fv_cddcCd = this.fv_cddcCd;
	this.divTop.form.fv_cddcNm = this.fv_cddcNm;
	
	//div 배열 세팅
	this.fv_divObj = [
						 this.div01.form.div00.form.div00
					   , this.div01.form.div00.form.div01
					   , this.div01.form.div00.form.div02
					   , this.div01.form.div00.form.div03
					   , this.div01.form.div00.form.div04
					 ];
	
	//기존 화면 비활성화 세팅
	if(this.fnDeviceKnd() == 'Mobile'){	 	//모바일일 때
		this.fv_divObj[(this.fv_btnPage + 1)].set_visible(false);
	}
	
	this.fnDisplayM();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnPopupCallback = function(){
}

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 버튼 세팅
*/
this.btnSet = function(btnType)
{
	if(btnType === 'next'){
		this.div01.form.btnBfr.set_enable(true);
	}else{
		this.div01.form.btnNext.set_enable(true);
	}
	
	var btnPage = 2;
	if(this.fnDeviceKnd() == 'Mobile') btnPage = (this.fv_divObj.length - 1);
	
	if(this.fv_btnPage === 0){
		this.div01.form.btnBfr.set_enable(false);
	}else if(this.fv_btnPage === btnPage){
		this.div01.form.btnNext.set_enable(false);
	}
}

/**
 * 모바일 화면 정렬
 * @param  : N/A
 */
this.fnDisplayM = function(){
	if(this.fnDeviceKnd() == 'Mobile'){	// 모바일
		for(var j=0; j<5; j++){
			var left = Math.floor((this.div01.form.div00.getOffsetWidth() - this.div01.form.div00.form["div0" + j].getOffsetWidth()) / 2);
			this.div01.form.div00.form["div0"+j].set_left(left);
		}
	}
}

/**
 * 디바이스 구분
 * @param  : N/A
 * @return : deviceNm			- 디바이스 명칭
 */
this.fnDeviceKnd = function(){
	var mobileFlag = /Mobile|iP(hone|od)|Windows(CE|Phone)|Minimo|Opera M(obi|ini)|BlackBerry|Nokia/;

	if(navigator.userAgent.match(mobileFlag) && !navigator.userAgent.match(/iPad/)){
		return 'Mobile';
	}else if(navigator.userAgent.match(/iPad|Android/)){
		return 'Tablet';
	}else{
		return 'PC';
	}
};

/**
 * 컴포넌트 사이즈 조절(PC)
 * @param  : initVal			- 초기인지 아닌지 구분
 * @return : N/A
 */
this.fnDisplayP = function(){
	if (!this.smfIsMobile()){
		var nMaxWidth = 1200 - nexacro.toNumber(this._getHScrollBarSize());
		console.log(nMaxWidth);
		var nFormWidth = this.getOffsetWidth();
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.div01.form.div01.setOffsetLeft(10 + nLeft);
			this.div01.form.div00.setOffsetLeft(10 + nLeft);
		}else{
			var nLeft = 0;
			this.div01.form.div01.setOffsetLeft(nLeft);
			this.div01.form.div00.setOffsetLeft(nLeft);
		}
		this.div01.form.resetScroll();
	}
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description '학부모 참여방법' 버튼 클릭 시
*/
this.div01_div01_btnPaGudn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//학부모 참여방법 화면 호출
	var param = {
		cddcCd : this.fv_cddcCd,
		cddcNm : this.fv_cddcNm
	};
	var sUrl = "pa_eds_seg_oi::eds_segoi01_m03.xfdl";
	this.smfSetWorkPage(sUrl,param, false);
};

/**
 * @description '이전' 버튼 클릭 시
*/
this.div01_btnBfr_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(this.fnDeviceKnd() == 'Mobile'){		//모바일이면
	
		//기존 화면 비활성화 세팅
		this.fv_divObj[this.fv_btnPage].set_visible(false);
		
		this.fv_btnPage--;
		if(this.fv_btnPage <= 0) this.fv_btnPage == 0;
		
		//화면 활성화 세팅
		this.fv_divObj[this.fv_btnPage].set_visible(true);
	}else{
		//기존화면 비활성화 세팅
		for(var i = this.fv_divObjIdx; i <= this.fv_divObjIdx+1; i++){
			if(i >= this.fv_divObj.length){
				break;
			}
			this.fv_divObj[i].set_visible(false);
		}
		
		this.fv_btnPage--;
		if(this.fv_btnPage <= 0) this.fv_btnPage == 0;
		this.fv_divObjIdx -= 2;
		
		//화면 활성화 세팅
		for(var i = this.fv_divObjIdx; i <= this.fv_divObjIdx+1; i++){
			if(i < 0){
				break;
			}
			this.fv_divObj[i].set_visible(true);
		}
	}
	
	//버튼 세팅
	var btnType = 'bfr';
	this.btnSet(btnType);
};

/**
 * @description '다음' 버튼 클릭 시
*/
this.div01_btnNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	if(this.fnDeviceKnd() == 'Mobile'){		//모바일이면
		//기존 화면 비활성화 세팅
		this.fv_divObj[this.fv_btnPage].set_visible(false);
		
		this.fv_btnPage++;
		if(this.fv_btnPage >= (this.fv_divObj - 1)) this.fv_btnPage == (this.fv_divObj - 1);
		
		//화면 활성화 세팅
		this.fv_divObj[this.fv_btnPage].set_visible(true);
	}else{
		//기존 화면 비활성화 세팅
		for(var i = this.fv_divObjIdx; i <= this.fv_divObjIdx+1; i++){
			if(i < 0){
				break;
			}
			this.fv_divObj[i].set_visible(false);
		}
		
		this.fv_btnPage++;
		if(this.fv_btnPage >= 2) this.fv_btnPage == 2;
		
		this.fv_divObjIdx += 2;
		
		//화면 활성화 세팅
		for(var i = this.fv_divObjIdx; i <= this.fv_divObjIdx+1; i++){
			if(i >= this.fv_divObj.length){
				break;
			}
			this.fv_divObj[i].set_visible(true);
		}
	}
	
	//버튼 세팅
	var btnType = 'next';
	this.btnSet(btnType);
};

/**
 * @description '검사 참여안내' 버튼 클릭 시(모바일)
*/
this.div01_div01_00_btnGudn_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divTop.form.fnBtnGudn();
};

/**
 * @description '자주묻는질문' 버튼 클릭 시(모바일)
*/
this.div01_div01_00_btnQna_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.divTop.form.fnBtnQna();
};

/**
 * @description 사이즈 변경시 (모바일)
*/
this.divBottom_onsize = function(obj:nexacro.Div,e:nexacro.SizeEventInfo)
{
	if(this.fnDeviceKnd() == 'Tablet'){	// 태블릿
		for(var j=0; j<5; j++){
			this.smfResetScroll(this.div01.form.div00.form["div0"+j].form);
		}
		
		if (this.div01.form.div00.form.div04.visible){
			this.div01.form.div00.set_height(this.div01.form.div00.form.div04.height * 2 + 54);
			this.smfResetScroll(this.div01.form);
		}else{
			this.smfResetScroll(this.div01.form.div00.form);
		}
	}
	
	this.fnDisplayM();	// 모바일
	
	if(!this.smfIsMobile()){
		this.fnDisplayP();	// pc화면 정렬
	}
};]]></Script>
  </Form>
</FDL>
