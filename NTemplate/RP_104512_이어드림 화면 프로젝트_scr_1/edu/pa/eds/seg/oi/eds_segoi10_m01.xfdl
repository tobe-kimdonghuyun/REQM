          <Column id="vo" type="STRING" size="256" sumtext="vo class full name"/>
          <Column id="service" type="STRING" size="256" sumtext="service class full name"/>
          <Column id="method" type="STRING" size="256" sumtext="method name"/>
          <Column id="svctp" type="STRING" size="256" sumtext="Transaction Type 정의(Status 정보 표현:CRUD)"/>
          <Column id="bindingControls" type="STRING" size="256" sumtext="서비스가 성공적으로 호출되면 0번째 로우에 전체,선택,삭제 로우를 추가한다."/>
          <Column id="callback" type="STRING" size="256" sumtext="콜백함수 (Default:fnTransCallback)"/>
          <Column id="state" type="STRING" size="256" sumtext="(공통에서사용)서비스가 호출된 상태(ready:서비스호출준비,succ:서비스호출성공,fail:서비스에러)"/>
          <Column id="reason" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과코드"/>
          <Column id="message" type="STRING" size="256" sumtext="(공통시스템에서사용)서비스호출후 결과메시지"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
          <Column id="bintp" type="STRING" size="256" sumtext="Binary 처리 여부(Default:false)"/>
          <Column id="comtp" type="STRING" size="256" sumtext="Data 압축 여부(Default:false)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">list</Col>
            <Col id="url">/eds_seg_oi10_001.do</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsMain=dsMain</Col>
          </Row>
          <Row>
            <Col id="id">check</Col>
            <Col id="url">/eds_seg_oi10_002.do</Col>
            <Col id="inDatasets">dsSearch=dsSearch</Col>
            <Col id="outDatasets">dsApiResponseList=dsApiResponseList</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" useclientlayout="true">
        <ColumnInfo>
          <Column id="cddcCd" type="STRING" size="256" description="시도교육청코드"/>
          <Column id="cddcNm" type="STRING" size="256" description="시도교육청명"/>
          <Column id="inspYr" type="STRING" size="256" description="검사연도"/>
          <Column id="enfcTme" type="STRING" size="256" description="시행회차"/>
          <Column id="shlKndScCd" type="STRING" size="256" description="학교종류구분코드"/>
          <Column id="shlCd" type="STRING" size="256" description="학교코드"/>
          <Column id="shlCrseScCd" type="STRING" size="256" description="학교과정구분코드"/>
          <Column id="grd" type="STRING" size="256" description="학년"/>
          <Column id="inspPtptNo" type="STRING" size="256" description="검사참여번호"/>
          <Column id="segStuInvlNo" type="STRING" size="256" description="학생정서행동특성검사학생개인번호"/>
          <Column id="clsCd" type="STRING" size="256" description="학급코드"/>
          <Column id="inspRltIdntyYn" type="STRING" size="256" description="검사결과확인여부"/>
          <Column id="dghtCrseScCd" type="STRING" size="256" description="주야과정구분코드"/>
          <Column id="ordScCd" type="STRING" size="256" description="계열구분코드"/>
          <Column id="dddepCd" type="STRING" size="256" description="학과코드"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true">
        <ColumnInfo>
          <Column id="inspYr" type="STRING" size="256" description="검사연도"/>
          <Column id="enfcTme" type="STRING" size="256" description="시행회차"/>
          <Column id="evlprId" type="STRING" size="256" description="평가지ID"/>
          <Column id="shlCd" type="STRING" size="256" description="학교코드"/>
          <Column id="shlNm" type="STRING" size="256" description="학교명"/>
          <Column id="grd" type="STRING" size="256" description="학년"/>
          <Column id="clsCd" type="STRING" size="256" description="학급코드"/>
          <Column id="clsNm" type="STRING" size="256" description="학급명"/>
          <Column id="segStuInvlNo" type="STRING" size="256" description="학생정서행동특성검사학생개인번호"/>
          <Column id="shlCrseScCd" type="STRING" size="256" description="학교과정구분코드"/>
          <Column id="inspPtptNo" type="STRING" size="256" description="검사참여번호"/>
          <Column id="dghtScCd" type="STRING" size="256" description="주야구분코드"/>
          <Column id="OrdScCd" type="STRING" size="256" description="계열구분코드"/>
          <Column id="dddepCd" type="STRING" size="256" description="학과코드"/>
          <Column id="stuClsNo" type="STRING" size="256" description="학생학급번호"/>
          <Column id="sxdsScCd" type="STRING" size="256" description="성별구분코드"/>
          <Column id="stuFlnm" type="STRING" size="256" description="학생성명"/>
          <Column id="inspOprtnDd" type="STRING" size="256" description="검사실시일"/>
          <Column id="stuRprsPeyValue" type="STRING" size="256" description="학생대표성격검사값"/>
          <Column id="emtGhvrTtsr" type="STRING" size="256" description="정서행동총점"/>
          <Column id="emtGhvrTsc" type="STRING" size="256" description="정서행동T점수"/>
          <Column id="emtGhvrPcntCnt" type="STRING" size="256" description="정서행동백분위수"/>
          <Column id="emtGhvrMean" type="STRING" size="256" description="정서행동의미"/>
          <Column id="pblRelm1Orsc" type="STRING" size="256" description="문제영역1원점수"/>
          <Column id="pblRelm1Tsc" type="STRING" size="256" description="문제영역1T점수"/>
          <Column id="pblRelm1PcntCnt" type="STRING" size="256" description="문제영역1백분위수"/>
          <Column id="pblRelm1Mean" type="STRING" size="256" description="문제영역1의미"/>
          <Column id="pblRelm2Orsc" type="STRING" size="256" description="문제영역2원점수"/>
          <Column id="pblRelm2Tsc" type="STRING" size="256" description="문제영역2T점수"/>
          <Column id="pblRelm2PcntCnt" type="STRING" size="256" description="문제영역2백분위수"/>
          <Column id="pblRelm2Mean" type="STRING" size="256" description="문제영역2의미"/>
          <Column id="pblRelm3Orsc" type="STRING" size="256" description="문제영역3원점수"/>
          <Column id="pblRelm3Tsc" type="STRING" size="256" description="문제영역3T점수"/>
          <Column id="pblRelm3PcntCnt" type="STRING" size="256" description="문제영역3백분위수"/>
          <Column id="pblRelm3Mean" type="STRING" size="256" description="문제영역3의미"/>
          <Column id="pblRelm4Orsc" type="STRING" size="256" description="문제영역4원점수"/>
          <Column id="pblRelm4Tsc" type="STRING" size="256" description="문제영역4T점수"/>
          <Column id="pblRelm4PcntCnt" type="STRING" size="256" description="문제영역4백분위수"/>
          <Column id="pblRelm4Mean" type="STRING" size="256" description="문제영역4의미"/>
          <Column id="pblRelm5Orsc" type="STRING" size="256" description="문제영역5원점수"/>
          <Column id="pblRelm5Tsc" type="STRING" size="256" description="문제영역5T점수"/>
          <Column id="pblRelm5PcntCnt" type="STRING" size="256" description="문제영역5백분위수"/>
          <Column id="pblRelm5Mean" type="STRING" size="256" description="문제영역5의미"/>
          <Column id="tcrOpi" type="STRING" size="256" description="교사의견"/>
          <Column id="pblRelmTtsrEpl" type="STRING" size="256" description="문제영역총점설명"/>
          <Column id="pblRelm1Epl" type="STRING" size="256" description="문제영역1설명"/>
          <Column id="pblRelm2Epl" type="STRING" size="256" description="문제영역2설명"/>
          <Column id="pblRelm3Epl" type="STRING" size="256" description="문제영역3설명"/>
          <Column id="pblRelm4Epl" type="STRING" size="256" description="문제영역4설명"/>
          <Column id="pblRelm5Epl" type="STRING" size="256" description="문제영역5설명"/>
          <Column id="tchFlnm" type="STRING" size="256" description="문의처성명"/>
          <Column id="tchTelno" type="STRING" size="256" description="문의처전화번호"/>
          <Column id="tchDt" type="STRING" size="256" description="문의안내일자"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
      <Dataset id="dsApiResponseList" useclientlayout="true">
        <ColumnInfo>
          <Column id="code" type="STRING" size="256" description="연계상태값"/>
          <Column id="message" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    교육설문 > 학생정서행동특성검사 > 학생정서-검사결과조회(AMPQ)
*  @FileName 	eds_segoi09_m02.xfdl 
*  @Creator 	kangchaeyoon
*  @CreateDate 	2022.12.16
*  @Desction    학생정서-검사결과조회(AMPQ)
******************* 소스 수정 이력 ******************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.12.16           Kangchaeyoon                   최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fv_param;			// 파라메터 세팅
this.fv_btnPage = 0;	//페이지
this.fv_divObj = [];	//div 배열

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	this.smfResetScroll(this);
	
	// 전달받은 파라메터 값 세팅
	this.fv_param = this.smfGetFormParams();
	this.dsSearch.loadXML(this.fv_param.dataset);
	
	//헤더 버튼 비활성화
	if(this.smfIsMobile()){	//모바일일때
		this.divTop.form.fnSetTopFrameBtnVisible(false, false);
	}else{
		this.divTop.form.divMain.form.div00.set_visible(false);
	}

	// PC 화면 정렬
	this.fnDisplayP();
	
	//div 배열 세팅
	this.fv_divObj = [
						 this.div01.form.div00
					   , this.div01.form.div01
					   , this.div01.form.div02
					   , this.div01.form.div03
					   , this.div01.form.div04
					   , this.div01.form.div05
					   , this.div01.form.div06
					 ];
	
	//검사결과 조회
	this.fnSearch();
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
 
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/
/**
 * @description 검사결과 조회 Transaction
 */
this.fnSearch = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;

			//그리드 사이즈 동적 조절(모바일)
			if(this.smfIsMobile()){
				this.setGridSize();
			}
			
			//검사결과 내 문의정보 값 세팅 // 셋팅
			this.segRltStaValSet();
		});
};

/**
 * @description 검사결과확인 Transaction
 */
this.fnIdntyYn = function()
{
 	// 서비스 객체 생성
	this.smfSearchService("check")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if (this.dsApiResponseList.getColumn(0, 'code') == 'succ'){ 
				this.smfConfirmEds("검사결과 확인이 완료되었습니다. \n 설문 검사 결과를 종료하시겠습니까?",function(result){
					if(result.confirmResult){
						// 정서 map화면으로 이동
						window.location.replace("https://mom.eduro.go.kr");
					}
					else {
						return false;
					}
				});
			}else{
				this.smfAlertEds('LI155', [this.dsApiResponseList.getColumn(0, 'message')]);
			}
		});
};
/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 검사문의정보 값 세팅
 */
this.segRltStaValSet = function(){
	var shlNm = this.dsMain.getColumn(0, "shlNm");
	var tchFlnm = this.dsMain.getColumn(0, "tchFlnm");
	var tchTelno = this.dsMain.getColumn(0, "tchTelno");
	var tchDt = this.dsMain.getColumn(0, "tchDt");
	
	//학교장 값 세팅
	this.div01.form.div06.form.sta02.set_text(shlNm+"장");
	
	//문의 날짜 값 세팅
	var tchDate = (tchDt.substr(0, 2))+"월 "+(tchDt.substr(2, 3))+"일";
	var staText = this.div01.form.div06.form.sta03.text;
	var staAddText = "\n문의사항이 있으시면 당해 연도 "+tchDate+" 이전에 학교로 연락 주시기 바라며, 기한 내 문제가 없으시면 이견이 없는 것으로 알고 예정된 절차에 \n따라 검사 결과를삭제 처리하겠습니다.";
	this.div01.form.div06.form.sta03.set_text(staText+staAddText);
	
	//문의처 값 세팅
	this.div01.form.div06.form.sta01.set_text("문의처 : "+shlNm+" "+tchFlnm+"("+tchTelno+")");
	
	//버튼 위치 조절
	if(this.smfIsMobile()){
		this.btnTopSet();
	}
};

/**
 * @description 화면, 버튼 세팅
*/
this.btnSet = function(btnType)
{
	//기존 화면 비활성화 세팅
	this.fv_divObj[this.fv_btnPage].set_visible(false);
	
	//검사결과확인 버튼 비활성화 세팅
	this.div01.form.btnIdnty.set_visible(false);

	if(btnType == 'next'){
		this.fv_btnPage++;
		if(this.fv_btnPage >= 6) this.fv_btnPage == 6;
		this.div01.form.btnBfr.set_enable(true);
	}else{
		this.fv_btnPage--;
		if(this.fv_btnPage <= 0) this.fv_btnPage == 0;
		this.div01.form.btnNext.set_visible(true);
		this.div01.form.btnNext.set_enable(true);
	}
	
	//현재 화면 활성화
	this.fv_divObj[this.fv_btnPage].set_visible(true);
	
	if(this.fv_btnPage == 0){
		this.div01.form.btnBfr.set_enable(false);
	}else if(this.fv_btnPage == 6){
		this.div01.form.btnNext.set_visible(false);
		this.div01.form.btnIdnty.set_visible(true);	
	}
}

/**
 * @description 버튼 위치 조절, 리셋스크롤
*/
this.btnTopSet = function()
{
	//버튼 위치 조절, 리셋스크롤
	var divHeight = this._smfGetMaxBottomPos(this.fv_divObj[this.fv_btnPage].form);
	var divBlk = 40;
	if(this.fv_btnPage == 6){
		divHeight = this.div01.form.div06.getOffsetBottom();
	}
	this.div01.form.btnBfr.setOffsetTop(divHeight+divBlk);
	this.div01.form.btnNext.setOffsetTop(divHeight+divBlk);
	this.div01.form.btnIdnty.setOffsetTop(divHeight+divBlk);
	this.smfResetScroll(this.fv_divObj[this.fv_btnPage].form);
}

/**
 * @description 그리드 사이즈 동적 조절(모바일)
*/
this.setGridSize = function(){
	var div01Grd = this.div01.form.div00.form.grd01;
	var div05Grd = this.div01.form.div05.form.grd00;

	div01Grd.set_autosizingtype("row");
	div01Grd.set_extendsizetype("row");
	div05Grd.set_autosizingtype("row");
	div05Grd.set_extendsizetype("row");
	
	var div01GrdHeight = div01Grd.getRealRowFullSize();
	var div05GrdHeight = div05Grd.getRealRowFullSize();
	div01Grd.setOffsetHeight(div01GrdHeight);
	div05Grd.setOffsetHeight(div05GrdHeight);
	
	this.smfResetScroll(div01Grd);
	this.smfResetScroll(div05Grd);
}

/**
 * @description 화면 정렬 (PC)
*/
this.fnDisplayP = function (){
	if (!this.smfIsMobile()){
		var nMaxWidth = 1200;
		var nFormWidth = this.getOffsetWidth();
		
		if(nFormWidth>nMaxWidth){
			var nLeft = parseInt((nFormWidth-nMaxWidth)/2);
			this.div01.form.div00.setOffsetLeft(10 + nLeft);
			this.div01.form.div01.setOffsetLeft(10 + nLeft);
			this.div01.form.div02.setOffsetLeft(10 + nLeft);
			this.div01.form.div03.setOffsetLeft(10 + nLeft);
			this.div01.form.div04.setOffsetLeft(10 + nLeft);
			this.div01.form.div05.setOffsetLeft(10 + nLeft);
			this.div01.form.div06.setOffsetLeft(10 + nLeft);
		}else{
			var nLeft = 0;
			this.div01.form.div00.setOffsetLeft(nLeft);
			this.div01.form.div01.setOffsetLeft(nLeft);
			this.div01.form.div02.setOffsetLeft(nLeft);
			this.div01.form.div03.setOffsetLeft(nLeft);
			this.div01.form.div04.setOffsetLeft(nLeft);
			this.div01.form.div05.setOffsetLeft(nLeft);
			this.div01.form.div06.setOffsetLeft(nLeft);
		}
		this.div01.form.resetScroll();
	}
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description '이전' 버튼 클릭 시 
*/
this.div01_btnBfr_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//화면, 버튼 세팅
	var btnType = 'bfr';
	this.btnSet(btnType);
	if(this.smfIsMobile()){
		this.btnTopSet();
	}
};

/**
 * @description '다음' 버튼 클릭 시 
*/
this.div01_btnNext_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//화면, 버튼 세팅
	var btnType = 'next';
	this.btnSet(btnType);
	if(this.smfIsMobile()){
		this.btnTopSet();
	}
	
	//포커스 처리
	var divObjNm = this.fv_divObj[this.fv_btnPage];
	var divComp = divObjNm.id;
	this.div01.form[divComp].setFocus();
};

/**
 * @description '검사결과확인' 버튼 클릭 시 
*/
this.div01_btnIdnty_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	//검사결과 확인 처리
	this.dsSearch.setColumn(0, "inspRltIdntyYn", "Y");
	
	//검사결과 확인 처리
	this.fnIdntyYn();
};

/**
 * @description 화면 사이즈 변경 시
*/
this.divBottom_onsize = function(obj:nexacro.Div,e:nexacro.SizeEventInfo)
{
	if(this.smfIsMobile()){
		this.smfResetScroll(this.div01.form.div00.form);
		this.smfResetScroll(this.div01.form.div01.form);
		this.smfResetScroll(this.div01.form.div02.form);
		this.smfResetScroll(this.div01.form.div03.form);
		this.smfResetScroll(this.div01.form.div04.form);
