              <Div id="div02" taborder="4" text="div00" left="360" top="20" cssclass="div_WF_SurvLgnBox2" initvalueid="ivDivAccessibilityOff" width="1200" height="662" visible="false">
                <Layouts>
                  <Layout>
                    <Static id="sta00_00" taborder="0" left="50" top="0" height="40" cssclass="sta_WF_GDSize" text="40" visible="false" initvalueid="ivStcAccessibilityOff" width="60"/>
                    <Static id="sta00_01" taborder="1" left="0" top="0" cssclass="sta_WF_GDSize" text="50" visible="false" initvalueid="ivStcAccessibilityOff" width="50" height="100"/>
