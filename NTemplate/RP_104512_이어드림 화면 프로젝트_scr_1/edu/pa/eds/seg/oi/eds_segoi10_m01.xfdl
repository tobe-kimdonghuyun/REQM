                    <Grid id="grd00" taborder="3" left="50" top="40" initvalueid="ivGrdAccessibilityOn" scrollbartype="none none" autofittype="col" cssclass="grd_WF_S02Data" right="50" height="576" selecttype="cell" binddataset="dsMain">
                      <Formats>
                        <Format id="default">
                          <Columns>
                            <Column size="40"/>
                            <Column size="24"/>
                            <Column size="70"/>
                            <Column size="720"/>
                            <Column size="240"/>
                          </Columns>
                          <Rows>
                            <Row size="40" band="head"/>
                            <Row size="40"/>
                            <Row size="40"/>
                            <Row size="76"/>
                            <Row size="76"/>
                            <Row size="76"/>
                            <Row size="76"/>
                            <Row size="76"/>
                            <Row size="76"/>
                          </Rows>
                          <Band id="head">
                            <Cell colspan="2" text="03"/>
                            <Cell col="2" colspan="3" text="성격요인 계발 방안" textAlign="left" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                          </Band>
                          <Band id="body">
                            <Cell colspan="5" text="학교와 가정에서 실천할 수 있는 성격 요인의 계발 방안에 대해 생각해 봅시다." border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            <Cell row="1" colspan="3" text="성격요인" cssclass="TitB"/>
                            <Cell row="1" col="3" text="계발방안" cssclass="TitB"/>
                            <Cell row="1" col="4" text="나만의 계발 방안" cssclass="TitB" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            <Cell row="2" cssclass="TitB" text="1"/>
                            <Cell row="2" col="1" colspan="2" cssclass="TitB" text="성실성"/>
                            <Cell row="2" col="3" text="- 일기쓰기, 줄넘기 10분 이상하기, 신발정리하기 등 매일 실천할 수 있는 작은 습관을 만들어보세요.&#13;&#10;&#13;- 최근에 세원던 목표 중  실천하지 않은 항목이 있다면, 목표를 잘 실천하기 위해 어떤 노력이 필요한지 적어 보세요.    "/>
                            <Cell row="2" col="4" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            <Cell row="3" cssclass="TitB" text="2"/>
                            <Cell row="3" col="1" colspan="2" cssclass="TitB" text="자존감"/>
                            <Cell row="3" col="3" text="- 잠들기 전에 오늘 하루를 보내면서 자신이 잘 해낸 부분을 떠올려보고 스스로를 북돋아 주세요.&#13;&#13;&#10;- 친구나 가족들이 생각하는 나의 장점을 하나씩 적어보세요.     "/>
                            <Cell row="3" col="4" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            <Cell row="4" cssclass="TitB" text="3"/>
                            <Cell row="4" col="1" colspan="2" cssclass="TitB" text="개방성"/>
                            <Cell row="4" col="3" text="- 반에서 나와 가장 다르다고 생각하는 친구의 이야기를 들어보세요. &#13;&#13;&#10;- 새로운 분야의 책을 찾아서 읽어보세요."/>
                            <Cell row="4" col="4" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            <Cell row="5" cssclass="TitB" text="4"/>
                            <Cell row="5" col="1" colspan="2" cssclass="TitB" text="타인이해"/>
                            <Cell row="5" col="3" text="- 친구가 이야기할 때, “응, 그랬구나.”로 얘기해 보세요.&#13;&#13;&#10;- 친구를 만나기 전에 “오늘은 친구의 이야기를 많이 들어봐야지”라고 다짐해 보세요."/>
                            <Cell row="5" col="4" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            <Cell row="6" cssclass="TitB" text="5"/>
                            <Cell row="6" col="1" colspan="2" cssclass="TitB" text="공동체&#13;&#10;의식"/>
                            <Cell row="6" col="3" text="- 지역신문이나 학교 신문을 읽고 내가 속한 공동체에서 어떤 일들이 일어나고 있는지 알아보세요.&#13;&#13;&#10;- 우리 반을 위해 내가 할 수있는 봉사활동을 찾아서 실천해보세요.    "/>
                            <Cell row="6" col="4" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            <Cell row="7" cssclass="TitB" text="6"/>
                            <Cell row="7" col="1" colspan="2" cssclass="TitB" text="사회의&#13;&#10;주도성"/>
                            <Cell row="7" col="3" text="- 친구들과 함께해보고 싶은 일을 생각해 보고 “함께 해보자.&quot;라고 먼저 말해 보세요.&#13;&#13;&#10;- 친구들 사이에서 필요한 것을 생각해 보고, 그것을 내가 먼저 실천해 보세요."/>
                            <Cell row="7" col="4" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                          </Band>
                        </Format>
                        <Format id="format00">
                          <Columns>
                            <Column size="74"/>
                            <Column size="76"/>
                            <Column size="104"/>
                            <Column size="358"/>
                          </Columns>
                          <Rows>
                            <Row size="70" band="head"/>
                            <Row size="120"/>
                            <Row size="60"/>
                            <Row size="80"/>
                            <Row size="240"/>
                            <Row size="60"/>
                            <Row size="60"/>
                            <Row size="80"/>
                            <Row size="240"/>
                            <Row size="60"/>
                            <Row size="60"/>
                            <Row size="80"/>
                            <Row size="240"/>
                            <Row size="60"/>
                            <Row size="60"/>
                            <Row size="80"/>
                            <Row size="240"/>
                            <Row size="60"/>
                            <Row size="60"/>
                            <Row size="80"/>
                            <Row size="240"/>
                            <Row size="60"/>
                            <Row size="60"/>
                            <Row size="80"/>
                            <Row size="240"/>
                            <Row size="60"/>
                          </Rows>
                          <Band id="head">
                            <Cell text="03"/>
                            <Cell col="1" colspan="3" text="성격요인 계발 방안" textAlign="left" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                          </Band>
                          <Band id="body">
                            <Cell colspan="4" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9" text="학교와 가정에서 실천할 수 있는 성격 요인의 계발 방안에 대해 생각해 봅시다."/>
                            <Cell row="1" colspan="2" text="성격요인" cssclass="BgTitB"/>
                            <Cell row="1" col="2" colspan="2" text="1.성실성" cssclass="BgTitB" textAlign="left" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            <Cell row="2" rowspan="2" colspan="4" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9">
                              <Cell colspan="4" text="계발방안" cssclass="SBgTitB"/>
                              <Cell row="1" colspan="4" text="- 일기쓰기, 줄넘기 10분 이상하기, 신발정리하기 등 매일 실천할 수 있는 작은 습관을 만들어보세요.&#13;&#10;&#13;- 최근에 세원던 목표 중  실천하지 않은 항목이 있다면, 목표를 잘 실천하기 위해 어떤 노력이 필요한지 적어 보세요.  " border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            </Cell>
                            <Cell row="4" colspan="3" text="나만의 계발 방안" cssclass="BgTitB"/>
                            <Cell row="4" col="3" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            <Cell row="5" colspan="2" text="성격요인" cssclass="BgTitB"/>
                            <Cell row="5" col="2" colspan="2" text="2.자존감" cssclass="BgTitB" textAlign="left" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            <Cell row="6" rowspan="2" colspan="4" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9">
                              <Cell colspan="4" text="계발방안" cssclass="SBgTitB"/>
                              <Cell row="1" colspan="4" text="- 잠들기 전에 오늘 하루를 보내면서 자신이 잘 해낸 부분을 떠올려보고 스스로를 북돋아 주세요.&#13;&#13;&#10;- 친구나 가족들이 생각하는 나의 장점을 하나씩 적어보세요." border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            </Cell>
                            <Cell row="8" colspan="3" text="나만의 계발 방안" cssclass="BgTitB"/>
                            <Cell row="8" col="3" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            <Cell row="9" colspan="2" text="성격요인" cssclass="BgTitB"/>
                            <Cell row="9" col="2" colspan="2" text="3.개방성" cssclass="BgTitB" textAlign="left" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            <Cell row="10" rowspan="2" colspan="4" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9">
                              <Cell colspan="4" cssclass="SBgTitB" text="계발방안"/>
                              <Cell row="1" colspan="4" text="- 반에서 나와 가장 다르다고 생각하는 친구의 이야기를 들어보세요. &#13;&#13;&#10;- 새로운 분야의 책을 찾아서 읽어보세요." border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            </Cell>
                            <Cell row="12" colspan="3" text="나만의 계발 방안" cssclass="BgTitB"/>
                            <Cell row="12" col="3" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            <Cell row="13" colspan="2" text="성격요인" cssclass="BgTitB"/>
                            <Cell row="13" col="2" colspan="2" text="4.타인이해" cssclass="BgTitB" textAlign="left" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            <Cell row="14" rowspan="2" colspan="4" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9">
                              <Cell colspan="4" cssclass="SBgTitB" text="계발방안"/>
                              <Cell row="1" colspan="4" text="- 친구가 이야기할 때, “응, 그랬구나.”로 얘기해 보세요.&#13;&#13;&#10;- 친구를 만나기 전에 “오늘은 친구의 이야기를 많이 들어봐야지”라고 다짐해 보세요." border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            </Cell>
                            <Cell row="16" colspan="3" text="나만의 계발 방안" cssclass="BgTitB"/>
                            <Cell row="16" col="3" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            <Cell row="17" colspan="2" text="성격요인" cssclass="BgTitB"/>
                            <Cell row="17" col="2" colspan="2" text="5.공동체 의식" cssclass="BgTitB" textAlign="left" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            <Cell row="18" rowspan="2" colspan="4" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9">
                              <Cell colspan="4" cssclass="SBgTitB" text="계발방안"/>
                              <Cell row="1" colspan="4" text="- 지역신문이나 학교 신문을 읽고 내가 속한 공동체에서 어떤 일들이 일어나고 있는지 알아보세요.&#13;&#13;&#10;- 우리 반을 위해 내가 할 수있는 봉사활동을 찾아서 실천해보세요.    " border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            </Cell>
                            <Cell row="20" colspan="3" text="나만의 계발 방안" cssclass="BgTitB"/>
                            <Cell row="20" col="3" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            <Cell row="21" colspan="2" text="성격요인" cssclass="BgTitB"/>
                            <Cell row="21" col="2" colspan="2" text="6.사회의 주도성" cssclass="BgTitB" textAlign="left" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            <Cell row="22" rowspan="2" colspan="4" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9">
                              <Cell colspan="4" text="계발방안" cssclass="SBgTitB"/>
                              <Cell row="1" colspan="4" text="- 친구들과 함께해보고 싶은 일을 생각해 보고 “함께 해보자.&quot;라고 먼저 말해 보세요.&#13;&#13;&#10;- 친구들 사이에서 필요한 것을 생각해 보고, 그것을 내가 먼저 실천해 보세요." border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                            </Cell>
                            <Cell row="24" colspan="3" text="나만의 계발 방안" cssclass="BgTitB"/>
                            <Cell row="24" col="3" border="1px solid #d9d9d9, 0px none, 1px solid #d9d9d9, 1px solid #d9d9d9"/>
                          </Band>
                        </Format>
                      </Formats>
                    </Grid>
