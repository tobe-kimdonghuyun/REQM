        <Static id="Static99_00_00_00_00_00_00_00_00_00" taborder="16" left="0" top="1058" height="30" cssclass="sta_GD_Size" text="30" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" right="0" initvalueid="ivStcAccessibilityOff"/>
