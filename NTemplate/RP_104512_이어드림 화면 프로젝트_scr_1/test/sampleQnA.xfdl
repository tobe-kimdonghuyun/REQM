    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    QnA 샘플
*  @FileName 	sampleQnA
*  @Creator 	투비소프트
*  @CreateDate 	2022.06.14
*  @Desction    Div 열기 & 닫기 ,Static 텍스트 조회, 버튼 접기 펼치기 정보 표시
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.06.14     	투비소프트 	               최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

this.DivInfo = {};     // Q & A 항목 정보 
this.fvMinHeight = 70; // 디폴트 높이


/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.frmTemp01_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.fnInitDiv(this.tab00.Tabpage1.form);
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
 
/**
 * 영역(div) 생성  
 * fnCreateDiv 호출
 * @param : scope
 */
this.fnInitDiv = function(scope)
{	
	this.DivInfo.id = "id1"; // key
	this.DivInfo.cssclass = "div_WF_FAQBox_Q01"; // 최초 영역(라운드)
	this.DivInfo.visible = true;
	this.DivInfo.childId = "id2";
	this.DivInfo.dirArrow = "btn_WF_FAQDrop";
	
	this.fnCreateDiv(scope,this.DivInfo);
	
    this.DivInfo = {}; //초기화
	
	this.DivInfo.id = "id2";	// key
	this.DivInfo.nHeight = 70;
	this.DivInfo.cssclass = "div_WF_FAQBox_A01"; //
	this.DivInfo.visible = false;
	this.DivInfo.bef = "id1";
	this.DivInfo.childId = "";
	this.DivInfo.dirArrow = "btn_WF_FAQDrop";
	
	this.fnCreateDiv(scope,this.DivInfo);
	
    this.DivInfo = {}; //초기화
	 
	this.DivInfo.id = "id3";	 // key
	this.DivInfo.nHeight = 70;
	this.DivInfo.cssclass = "div_WF_FAQBox_Q02"; //중간 영역
	this.DivInfo.visible = true;
	this.DivInfo.bef = "id2";
	this.DivInfo.childId = "id4";
	this.DivInfo.dirArrow = "btn_WF_FAQDrop";	
	
	this.fnCreateDiv(scope,this.DivInfo);
	
    this.DivInfo = {}; //초기화
	 
	this.DivInfo.id = "id4";	 // key
	this.DivInfo.nHeight = 70;
	this.DivInfo.cssclass = "div_WF_FAQBox_A01";
	this.DivInfo.visible = false;
	this.DivInfo.bef = "id3";
	this.DivInfo.childId = "";	
	this.DivInfo.dirArrow = "btn_WF_FAQDrop";
	
	this.fnCreateDiv(scope,this.DivInfo);
	
    this.DivInfo = {}; //초기화
	 
	this.DivInfo.id = "id5";	 // key
	this.DivInfo.nHeight = 70;
	this.DivInfo.cssclass = "div_WF_FAQBox_Q03"; // 최종 영역(라운드)
	this.DivInfo.bef = "id4";	
	this.DivInfo.visible = true;
	this.DivInfo.childId = "id6";
	this.DivInfo.islasted = true;
	this.DivInfo.dirArrow = "btn_WF_FAQDrop";
	
	this.fnCreateDiv(scope,this.DivInfo);
	
    this.DivInfo = {}; //초기화
	 
	this.DivInfo.id = "id6";	 // key
	this.DivInfo.nHeight = 70;
	this.DivInfo.cssclass = "div_WF_FAQBox_A01";
	this.DivInfo.bef = "id5";	
	this.DivInfo.visible = false;
	this.DivInfo.childId = "";	
	this.DivInfo.dirArrow = "btn_WF_FAQDrop";
	
	this.fnCreateDiv(scope,this.DivInfo);
	
    this.DivInfo = {}; //초기화
};

/**
 * Div & Static 생성
 * @param : scope 컴포넌트 생성 범위
 * @param : pJson 생성 컴포넌트 정보
 */
this.fnCreateDiv = function(scope,pJson)
{
	//default
	if( !pJson.nHeight ) pJson.nHeight = this.fvMinHeight;
	
	// Create Object  
	var objDiv = new Div();
	if( pJson.bef )
	{
		objDiv.init(pJson.id, 0, pJson.bef +":"+ 0, null, pJson.nHeight, 0, null);
	}else
	{
		objDiv.init(pJson.id, 0, 40, null, pJson.nHeight, 0, null);		
	}


	// Add Object to Parent Form  
	scope.addChild(pJson.id, objDiv); 
	
	objDiv.set_cssclass(pJson.cssclass);
	//objDiv.set_accessibilityenable(false);
	objDiv.set_initvalueid("ivDivAccessibilityOff");
	objDiv.childId = pJson.childId;
	objDiv.islasted = pJson.islasted;
	objDiv.dirArrow = pJson.dirArrow;
	
	if( !pJson.visible ) 
	{
		objDiv.setOffsetHeight(0);
		objDiv.set_visible(pJson.visible);
	}	
	// Show Object  
	objDiv.show(); 
	
	// Create Object  
	var objStatic = new Static();  
	objStatic.init(pJson.id, 30, 3, null, null, 30, 3);
	 
	// Add Object to Parent Form  
	objDiv.form.addChild(pJson.id, objStatic); 
	//objStatic.set_accessibilityenable(true);	 
	objStatic.set_initvalueid("ivStcAccessibilityOn");
	
	objStatic.set_cssclass(pJson.cssclass);
	objStatic.set_wordWrap("char");
	objStatic.islasted = pJson.islasted;
	objStatic.dirArrow = pJson.dirArrow;	

	var rowIdx = nexacro.toNumber(pJson.id.substr(2,1));

	if ( rowIdx % 2 == 0 )
	{
		objStatic.set_cssclass("sta_WF_FAQ_A1");	
 		objStatic.set_fittocontents("height");
		objStatic.set_text(" id : " + pJson.id +" "+ this.dsComment.getColumn(rowIdx-1,"Column1"));		
	}else
	{
		objStatic.set_cssclass("sta_WF_FAQ_Q");
		objStatic.set_text(this.dsComment.getColumn(rowIdx-1,"Column0"));				
	}
	
	objStatic.childId = pJson.childId;
	objStatic.addEventHandler("onclick",function(obj,e){
		this.fnReDraw(scope,obj,e);
	}
	,this);
	
	// Show Object  
	objStatic.show();
	if ( rowIdx % 2 == 1 )
	{	
		this.fnCreateArrow(objDiv.form,pJson);	
	}
};

/**
 * Div 안 버튼 생성
 * @param : scope ( Div.form)
 * @param : divInfo 
 */
this.fnCreateArrow = function(scope,pJson)
{
	// Create Object  
	var objButton = new Button(); 
	objButton.init(pJson.id, null, 14, 40, 40, 20, null);

	// Add Object to Parent Form  
	//scope.addChild("btn"+pJson.id, objButton);
	scope.addChild("Button", objButton);
	objButton.set_cssclass("btn_WF_FAQDrop");
	objButton.set_initvalueid("ivBtnAccessibilityExpand");
	
	objButton.childId = pJson.childId;
	objButton.islasted = pJson.islasted;
	objButton.dirArrow = pJson.dirArrow;
	
	objButton.addEventHandler("onclick",function(obj,e){
		//scope[pJson.id].onclick;
		this.fnReDraw(scope.parent.parent,scope[pJson.id],e);
	},this);
	
	// Show Object  
	objButton.show(); 
};

/**
 * 생성 컴포넌트 재 설정 및 reDraw 함
 * @param : obj - Static
 * @param : e   - Static eventInfo
 */
this.fnReDraw = function(scope,obj,e)
{
	console.log(scope);
	//obj.status = "Collapse"; //Expand
	for(var i=0;i < scope.components.length;i++)
	{	
		if(scope.components[i] instanceof nexacro.Div )
		{
			if ( scope.components[i].form["Button"] )
			{
				scope.components[i].form["Button"].set_cssclass("btn_WF_FAQDrop");
			}

			if( nexacro.toNumber(scope.components[i].id.substr(2,1)) % 2 == 0 )
			{
				scope.components[i].setOffsetHeight(0);
				scope.components[i].set_visible(false);			
			}
			
			if ( scope.components[i].islasted )
			{
				scope.components[i].set_cssclass("div_WF_FAQBox_Q03");
				if (i%2 == 0 )
				{
					if( obj instanceof nexacro.Static )
					{
						obj.set_cssclass("sta_WF_FAQ_A1");
					}else if ( obj instanceof nexacro.Button )
					{
						obj.parent.form[obj.id].set_cssclass("sta_WF_FAQ_A1");
					}
				}

			}
		}
	}
	
	if( obj instanceof nexacro.Static )
	{
		if( obj.childId )
		{
			var expandtextHeight = this._fngetTextSize(scope,obj,e);		
			//expandtextHeight = ( expandtextHeightA + expandtextHeightB ) / 2;
			
			scope[obj.childId].setOffsetHeight(expandtextHeight);
			scope[obj.childId].set_verticalAlign("middle");
			//obj.parent["Button"].set_cssclass("btn_WF_FAQDropup");
			obj.parent["Button"].set_cssclass("btn_WF_FAQDropup");

			// 최종 영역 라운드 처리
			if ( scope[obj.id].islasted )
			{
				scope[obj.id].set_cssclass("div_WF_FAQBox_Q02");
				scope[obj.childId].set_cssclass("div_WF_FAQBoxEnd_A01");
			}
			
			if ( scope[obj.childId].form[obj.childId].text != null ) 
			{
				scope[obj.childId].set_visible(true);
			}else
			{
				scope[obj.childId].set_visible(false);
			}
		}		
	}
		
	//Div 영역 Redraw 
	for(var i=0;i < scope.components.length;i++)
	{	
		if(scope.components[i] instanceof nexacro.Div)
		{	
			scope.components[i].form.resetScroll();
		}
	}

	//폼 영역 Redraw
	scope.resetScroll();
};


this.fnReDraw2 = function(scope,obj,e)
{
	console.log(scope);
	
	//obj.status = "Collapse"; //Expand
	for(var i=0;i < scope.components.length;i++)
	{	
		if(scope.components[i] instanceof nexacro.Div )
		{
			if ( scope.components[i].form["Button"] )
			{
				scope.components[i].form["Button"].set_cssclass("btn_WF_FAQDrop");
			}

			if( nexacro.toNumber(scope.components[i].id.substr(2,1)) % 2 == 0 )
			{
				scope.components[i].setOffsetHeight(0);
				scope.components[i].set_visible(false);			
			}
			
			if ( scope.components[i].islasted )
			{
				scope.components[i].set_cssclass("div_WF_FAQBox_Q03");
				if (i%2 == 0 )
				{
					if( obj instanceof nexacro.Static )
					{
						obj.set_cssclass("sta_WF_FAQ_A1");
					}else if ( obj instanceof nexacro.Button )
					{
						obj.parent.form[obj.id].set_cssclass("sta_WF_FAQ_A1");
					}
				}

			}
		}
	}
	
	//Div 영역 Redraw 
	for(var i=0;i < scope.components.length;i++)
	{	
		if(scope.components[i] instanceof nexacro.Div)
		{	
			scope.components[i].form.resetScroll();
		}
	}

	//폼 영역 Redraw
	scope.resetScroll();	
	
};

/**
 * static 컴포넌트 text 사이즈(height ) 반환
 * @param : obj - Static
 * @param : e   - Static eventInfo
 */

this._fngetTextSize = function(scope,obj,e)
{
	var wordspace = this._getCurrentStyleInheritValue("wordSpacing");
	var letterspace = this._getCurrentStyleInheritValue("letterSpacing");
	console.log(" letterspace : " + letterspace);
	var expandDivHeight   = scope[obj.childId].getOffsetHeight();
	var expandtextHeightA  =  scope[obj.childId].form[obj.childId].getOffsetHeight();
	var Qdiv = scope[obj.childId];
	var objFont =  Qdiv.form[obj.childId]._getCurrentStyleInheritValue("font", this._status);
	
	var textHeightB = nexacro._getTextSize(Qdiv.form[obj.childId].text,objFont,true,Qdiv.getOffsetWidth(),"char",wordspace,letterspace)[1];
	var expandtextHeightB = nexacro.toNumber(textHeightB);
	
	var textWidthB = nexacro._getTextSize(Qdiv.form[obj.childId].text,objFont,true,Qdiv.getOffsetWidth(),"char",wordspace,letterspace)[0];
	var expandtextWidthB = nexacro.toNumber(textWidthB);
	
	console.log(expandDivHeight + " : " + expandtextHeightA + " : " + expandtextHeightB);
	console.log(expandtextWidthB);
	console.log(" this[obj.childId].getOffsetWidth() : " + scope[obj.childId].getOffsetWidth() );
	
	var expandtextHeight = 0;
	
	//동일한 height 가 아닌경우,더 작은 케이스를 찾는다.
	if ( expandtextHeightA > expandtextHeightB )
	{
		expandtextHeight = expandtextHeightA;
	}else if ( expandtextHeightA < expandtextHeightB )
	{
		expandtextHeight = expandtextHeightB;
	}else
	{
		expandtextHeight = expandtextHeightA;
	}
	
	return expandtextHeight;
}
this.tab00_onsize = function(obj:nexacro.Tab,e:nexacro.SizeEventInfo)
{
};]]></Script>
    <Objects>
      <Dataset id="dsComment">
        <ColumnInfo>
          <Column id="Column0" type="STRING" size="256"/>
          <Column id="Column1" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="Column0">센스리더최소 버전</Col>
            <Col id="Column1">제품에서 지원하는 센스리더 최소 버전은 없음.nexacro17은 IE11 + 센스리더 V6.x버전으로 QC 테스트 및 접근성 인증을 진행한 이력이 있습니다.
&#13;NexacroN은 인증을 진행한 사이트는 아직 없으나 QC 테스트는 센스리더 v7.X 센스리더 v6.x에서  radio 컴포넌트를 잘못 읽어주는 몬제가 있으나 그 외에는 센스리더 최신 버전이 아니더라도 심각한 문제는 발생하지는 않습니다.다만 센스리더 기능 오류로 인해 제품의 기능 오류로 등록되는 경우가 종종 있고 비정상적으로 읽는 경우에 대해 사용자가 정확하게 인지 못하는 경우를 최소ㅘ 하기 위해서 최신 버전을 사용하는것을 권장하고 있습니다.최근에는 크롬 + 센스리더로 접근성 심사를 진행하고 있어 센스리더 최신 버전에서 크롬 브라우저의 문제를 많이 수정한 것으로 알고 있습니다.크롬 브라우저의 경우에는  특히 센스리더 최신 버전을 사용하는것을 권장합니다.</Col>
          </Row>
          <Row>
            <Col id="Column0">combo Role 지침</Col>
            <Col id="Column1">aria의 기능과 웹 접근성 적용 지침에 따라 아래의 내용으로 답변 드립니다.1.웹 접근성 상태에서 설정 할 수 있는 role 중에 calendar를 지칭할 수 있는 role 은 존재하기 않습니다. single-line인지 multi-line인지에 대한 구분만을 제공하고 있습니다.2.입력 서식에는 대응하는 레이블(label)을 제공해야 합니다.-원칙 3.이해의 용이성에 명시된  내용으로 실제 구현에서도 다양한 입력에 대해 용도나 목적을 사용하는 사람이 이해할 수 있도록 대체 텍스트를 명시해 줘야 합니다</Col>
          </Row>
          <Row>
            <Col id="Column0">비정상종료</Col>
            <Col id="Column1">신규 프로젝트 생성시에도 동일하게 현상이 나오고 있으므로  보안 프로그램등 외부 요인에 의한 것으로 보입니다.안전모드로 부팅 후에도 현상이 동일한지 확인하여 주시고 현상이 지속된다면 비정상 종료 시점의 덤프를 수집하여 전달하여 주시기 바랍니다.</Col>
          </Row>
          <Row>
            <Col id="Column0">센스리더최소 버전</Col>
            <Col id="Column1">제품에서 지원하는 센스리더 최소 버전은 없음.nexacro17은 IE11 + 센스리더 V6.x버전으로 QC 테스트 및 접근성 인증을 진행한 이력이 있습니다.
&#13;NexacroN은 인증을 진행한 사이트는 아직 없으나 QC 테스트는 센스리더 v7.X 센스리더 v6.x에서  radio 컴포넌트를 잘못 읽어주는 몬제가 있으나 그 외에는 센스리더 최신 버전이 아니더라도 심각한 문제는 발생하지는 않습니다.다만 센스리더 기능 오류로 인해 제품의 기능 오류로 등록되는 경우가 종종 있고 비정상적으로 읽는 경우에 대해 사용자가 정확하게 인지 못하는 경우를 최소ㅘ 하기 위해서 최신 버전을 사용하는것을 권장하고 있습니다.최근에는 크롬 + 센스리더로 접근성 심사를 진행하고 있어 센스리더 최신 버전에서 크롬 브라우저의 문제를 많이 수정한 것으로 알고 있습니다.크롬 브라우저의 경우에는  특히 센스리더 최신 버전을 사용하는것을 권장합니다.</Col>
          </Row>
          <Row>
            <Col id="Column0">combo Role 지침</Col>
            <Col id="Column1">aria의 기능과 웹 접근성 적용 지침에 따라 아래의 내용으로 답변 드립니다.1.웹 접근성 상태에서 설정 할 수 있는 role 중에 calendar를 지칭할 수 있는 role 은 존재하기 않습니다. single-line인지 multi-line인지에 대한 구분만을 제공하고 있습니다.2.입력 서식에는 대응하는 레이블(label)을 제공해야 합니다.-원칙 3.이해의 용이성에 명시된  내용으로 실제 구현에서도 다양한 입력에 대해 용도나 목적을 사용하는 사람이 이해할 수 있도록 대체 텍스트를 명시해 줘야 합니다</Col>
