              <Static id="Static99_00_00_00_00_01_00_00_01_00" taborder="15" left="48" top="5" cssclass="sta_GD_Size" text="27" background="rgba(251,160,146,0.5)" textAlign="center" font="10px &quot;Tahoma&quot;" visible="false" initvalueid="ivStcAccessibilityOff" width="27" height="20"/>
