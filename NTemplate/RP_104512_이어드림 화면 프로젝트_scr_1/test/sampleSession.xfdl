    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    TEMPLATE
*  @FileName 	sampleSession.xfdl
*  @Creator 	홍길동
*  @CreateDate 	2021.3.29
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2021.3.29     	홍길동 	        최초 생성 
*******************************************************************************
*/

/*
=======================================================================
공통함수 리스트
=======================================================================
// 시도교육청코드(cddcCd)
this.smfGetCddcCode()
this.smfSetCddcCode(sCddcCode)

// 성명(kornFlnm)
this.smfGetKornFlnm()
this.smfSetKornFlnm(sKornFlnm)

// 주민등록번호(trprRrno)
this.smfGetTrprRrno()
this.smfSetTrprRrno(sTrprRrno)

// 휴대폰번호(mblTelno()
this.smfGetMblTelno()
this.smfSetMblTelno(sMblTelno)

// 성별(sxdsScCd)
this.smfGetSxdsScCd()
this.smfSetSxdsScCd(sSxdsScCd)

smfSetUserId	
smfGetUserId			
사용자ID(userId)

smfSetEMl_Addr	
smfGetEMl_Addr			
이메일주소(eMl_Addr)

smfSetBRdt	
smfGetBRdt			
생년월일(bRdt)

smfSetCddcCd	
smfGetCddcCd			
시도교육청코드(cddcCd)

smfSetFunrKornFlnm	
smfGetFunrKornFlnm			
설립자한글성명(funrKornFlnm)

smfSetFunrRrno	
smfGetFunrRrno			
설립자주민등록번호(funrRrno)

smfSetBrno	
smfGetBrno			
사업자등록번호(brno)

smfSetUvstOrgCd	
smfGetUvstOrgCd			
대학조직코드(uvstOrgCd)


*/



/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.sampleSession_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 최신의 정보로 그리드를 다시 그린다.
	this.grdSession.createFormat();
};
 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
// set함수 
this.ButtonSet_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sFuncName = obj.func;
	var sValue = this.edtValue.value;
	
	var sLog = sFuncName + '("'+sValue+'") 함수를 실행했습니다.';
	
	
	this[sFuncName].call(this,sValue);
	
	this.txtLog.set_value(sLog);	
};

// get함수 
this.ButtonGet_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sFuncName = obj.func;
	
	var sValue = this[sFuncName].call(this,sValue);
	
	var sLog = sFuncName + '() 함수를 실행했습니다.\n값은 ['+sValue+']입니다.';
	
	this.edtValue.set_value(sValue);	
	this.txtLog.set_value(sLog);	
};

this.btn01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sSessionId = this.edtSessionId.value;
	var sSessionValue = this.smfGetSesseionValue(sSessionId);
	
	this.edtSessionValue.set_value(sSessionValue);
};

this.btn01_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sSessionId = this.edtSessionId.value;
	var sSessionValue = this.edtSessionValue.value
	
	this.smfSetSesseionValue(sSessionId,sSessionValue);
};

this.btn02_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSetSessionDataset(this.dsSession);
	
};

this.btn03_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfClearSessionDataset();
};
]]></Script>
    <Objects>
