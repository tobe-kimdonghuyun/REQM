          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};

// 폼 닫기전 이벤트
this.fnOnBeforeClose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	// 변경내역이 발생한 경우 종료전 confirm수행
	return this.smfCloseFormConfirm(this.dsMain);
};

// 폼 로드
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitPopup(obj);

	// 파라메터 세팅
	this.pv_params = this.smfGetPopupParams();
	
	this.smfValidateService("validateMain", { 
			url: "/cmc_sam_pl11_000.do",
		})
  		.mappingRulesetToForm(this.divMain, "save")
		.callback(function(callbackParams){
		
		})
		.run()
	;
	
	
	
	// 타이틀 변경
	if("insert" == this.pv_params.procType){
		this.smfUpdatePopupTitle("조직정보 등록");		
	}else if("update" == this.pv_params.procType){
		this.smfUpdatePopupTitle("조직정보 수정");
	}	

	////////////////////////////////////////////
	// 샘플용 함수
	this.smfSetFirstCode(this.dsGenreScCd);
	this.smfSetFirstCode(this.dsGrade); 
	////////////////////////////////////////////

	// 데이터 초기화
	this.dsMain.clearData();
	this.dsMain.addRow();
	//row초기화 undefiend를 "" 변경
	this.smfInitRow(this.dsMain, 0);

	// opener로부터 받은 데이터를 복사
	if("update" == this.pv_params.procType){
		var dsMainOfOpener = this.pv_params.dataset;
		this.dsMain.clearData();
		this.dsMain.addRow();
		this.dsMain.copyRow(0, dsMainOfOpener, dsMainOfOpener.rowposition); 
	}

	// row의 상태를 normal변경
	// NORMAL로 변경하는 이유는 
	// 팝업을 열고 바로 닫을때 form onbeforeclose에 의해 
	// alert메시지를 표시하지 않게 하도록 처리
	this.dsMain.applyChange();	
};

// 닫기 버튼 클릭
this.btn_close_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 닫기 버튼을 이용한 팝업종료의 파라메터는 false를 전달
	this.close(false);
};

// 저장 버튼 클릭
this.btn_ok_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 서비스 객체 생성 
	this.smfSaveService("save")
		// 데이터 검증
		.validateForm(this.divMain)		
		// 데이터 변경 필수
		.requireModifredData(this.dsMain)
		// insert인 경우 rowtype 변경
		.command(function(next){
			// 변경하지 않으면 update로 취급된다
			// (onload에서 this.dsMain.applyChange를 호출했기때문에 row의 타입이 NORMAL상태이며
			//  사용자가 값을 입력하면 UPDATE로 변경되기 때문)
			if("insert" == this.pv_params.procType){
				this.smfSetDatasetRowType(this.dsMain, this.dsMain.rowposition, Dataset.ROWTYPE_INSERT);
			}
			next();
		})
		
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			var alerter = this.smfAlerter();
			alerter.message = this.smfAfterServiceMessage();
			alerter.onOk = function(){
 				// opener에 callback 호출
 				this.smfSendResponseToOpener({
 				});

				// 팝업 종료
 				this.close(true);
			};			
			alerter.run();			
		});
};]]></Script>
    <Bind>
      <BindItem id="item3" compid="divMain.form.edtId" propid="value" datasetid="dsMain" columnid="id"/>
      <BindItem id="item4" compid="divMain.form.edtName" propid="value" datasetid="dsMain" columnid="name"/>
      <BindItem id="item5" compid="divMain.form.edtArtist" propid="value" datasetid="dsMain" columnid="artist"/>
      <BindItem id="item6" compid="divMain.form.mskPrice" propid="value" datasetid="dsMain" columnid="price"/>
      <BindItem id="item7" compid="divMain.form.mskDownCnt" propid="value" datasetid="dsMain" columnid="downCnt"/>
      <BindItem id="item8" compid="divMain.form.mskListenCnt" propid="value" datasetid="dsMain" columnid="listenCnt"/>
      <BindItem id="item10" compid="divMain.form.cboGenreCode" propid="value" datasetid="dsMain" columnid="genreCode"/>
      <BindItem id="item11" compid="divMain.form.cboGrade" propid="value" datasetid="dsMain" columnid="grade"/>
      <BindItem id="item12" compid="divMain.form.calRelease" propid="value" datasetid="dsMain" columnid="release"/>
      <BindItem id="item9" compid="divMain.form.cboTypeCode" propid="value" datasetid="dsMain" columnid="typeCode"/>
    </Bind>
  </Form>
</FDL>
