<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sample_crudGridPopup" width="430" height="590" titletext="그리드 저장" onload="fnOnload" onbeforeclose="fnOnBeforeClose" background="white">
    <Layouts>
