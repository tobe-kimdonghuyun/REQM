<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sample_crudGridMasterDetail" width="1280" height="720" titletext="그리드 저장" onload="fnOnload" border="1px solid" onbeforeclose="sample_gridSave_onbeforeclose">
    <Layouts>
      <Layout height="720" width="1280">
        <Static id="staMain" taborder="1" text="사용자관리" left="10" cssclass="sta_Ctitle" top="6" right="90" height="40" font="bold 20px/normal &quot;Consolas&quot;"/>
        <Grid id="grdMain" taborder="2" top="110" height="240" binddataset="dsMain" autofittype="col" scrollbardecbuttonsize="0" scrollbarincbuttonsize="0" left="10" right="850" autoupdatetype="comboselect" autoenter="select" onheadclick="grdMain_onheadclick" oncellclick="grdMain_oncellclick" onkeyup="grdMain_onkeyup">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="48"/>
                <Column size="295"/>
              </Columns>
              <Rows>
                <Row size="34" band="head"/>
                <Row size="34"/>
              </Rows>
              <Band id="head">
                <Cell text="순번"/>
                <Cell col="1" text="성명"/>
              </Band>
              <Band id="body">
                <Cell text="expr:currow+1" textAlign="center"/>
                <Cell col="1" text="bind:name" editautoselect="false" textDecoration="underline"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Div id="divSearch" taborder="3" left="5" top="61" width="1265" height="69" text="">
          <Layouts>
            <Layout>
              <Static id="sta_01" taborder="2" left="88" top="6" cssclass="sta_WF_tablebg" width="265" height="34"/>
              <Static id="sta_02" taborder="0" text="사용자명" left="10" top="6" cssclass="sta_WF_tablelabel" width="80" height="34" font="16px/normal &quot;Consolas&quot;"/>
              <Edit id="edtName" taborder="1" text="-선택-" left="99" top="6" height="34" leftbase="" topbase="" bottombase="" rightbase="" widthbase="" heightbase="" innerdataset="@ds_dep" codecolumn="code" datacolumn="data" scrollbarbarminsize="20" value="" index="-1" scrollbarbaroutsize="20" scrollbarsize="10" scrollbartrackbarsize="25" itemheight="20" width="243"/>
              <Button id="btnSearch" taborder="3" text="검색" top="6" height="34" width="76" right="838" onclick="div_search_btn_search_onclick"/>
            </Layout>
          </Layouts>
        </Div>
        <Grid id="grdSub" taborder="4" top="359" height="280" binddataset="dsSub" autofittype="col" scrollbardecbuttonsize="0" scrollbarincbuttonsize="0" left="10" right="86" autoupdatetype="comboselect" autoenter="select" onheadclick="grd_main_onheadclick">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="48"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="34" band="head"/>
                <Row size="34"/>
              </Rows>
              <Band id="head">
                <Cell text="순번"/>
                <Cell col="1" text="아이디"/>
                <Cell col="2" text="성명"/>
                <Cell col="3" text="아티스트"/>
                <Cell col="4" text="음반릴리즈"/>
                <Cell col="5" text="앨범타입"/>
                <Cell col="6" text="장르"/>
                <Cell col="7" text="등급"/>
                <Cell col="8" text="가격"/>
                <Cell col="9" text="다운로드횟수"/>
                <Cell col="10" text="청취횟수"/>
              </Band>
              <Band id="body">
                <Cell text="expr:currow+1" textAlign="center"/>
                <Cell col="1" text="bind:id"/>
                <Cell col="2" text="bind:name" editautoselect="false"/>
                <Cell col="3" text="bind:artist" editautoselect="false"/>
                <Cell col="4" text="bind:release" editautoselect="true" displaytype="date" calendareditformat="yyyy.MM.dd" calendarautoselect="true" calendardisplayinvalidtype="none" calendardisplaynulltype="none" calendardateformat="yyyy.MM.dd"/>
                <Cell col="5" text="bind:typeCode" editautoselect="true" combodataset="dsTypeCode" combocodecol="cdcValue" combodatacol="cdcValueNm" displaytype="combotext"/>
                <Cell col="6" text="bind:genreCode" editautoselect="true" displaytype="combotext" combodataset="dsGenreScCd" combocodecol="cdcValue" combodatacol="cdcValueNm" combotype="filterlike"/>
                <Cell col="7" text="bind:grade" editautoselect="true" combodataset="dsGrade" combocodecol="cdcValue" combodatacol="cdcValueNm" displaytype="combotext" combotype="filterlike"/>
                <Cell col="8" text="bind:price" editautoselect="true" displaytype="number" maskeditformat="###,##0"/>
                <Cell col="9" text="bind:downCnt" editautoselect="true" maskeditformat="###,##0" displaytype="number"/>
                <Cell col="10" text="bind:listenCnt" editautoselect="true" maskeditformat="###,##0" displaytype="number"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256" sumtext="service id"/>
          <Column id="url" type="STRING" size="256" sumtext="service url"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="id">list</Col>
            <Col id="inDatasets">search=dsSearch</Col>
            <Col id="outDatasets">dsMain=main</Col>
            <Col id="asynctp"/>
            <Col id="url">cmc_sam_pl15_001.do</Col>
          </Row>
          <Row>
            <Col id="id">listSub</Col>
            <Col id="inDatasets">search=dsSearchSub</Col>
            <Col id="outDatasets">dsSub=sub</Col>
            <Col id="asynctp"/>
            <Col id="url">cmc_sam_pl15_002.do</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch" oncolumnchanged="dsSearch_oncolumnchanged">
        <ColumnInfo>
          <Column id="name" type="STRING" size="150"/>
          <Column id="genreCode" type="STRING" size="1"/>
          <Column id="artist" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="name"/>
            <Col id="genreCode"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsMain" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="keys" type="STRING" size="30" value="columnText:&quot;성명&quot;name"/>
          <Column id="_chk" type="STRING" size="1"/>
          <Column id="id" type="STRING" size="256"/>
          <Column id="name" type="STRING" size="256"/>
          <Column id="artist" type="STRING" size="256"/>
          <Column id="release" type="STRING" size="256"/>
          <Column id="typeCode" type="STRING" size="256"/>
          <Column id="genreCode" type="STRING" size="256"/>
          <Column id="grade" type="STRING" size="256"/>
          <Column id="price" type="STRING" size="256"/>
          <Column id="downCnt" type="STRING" size="256"/>
          <Column id="listenCnt" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsGenreScCd" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="firstCode" size="30" type="STRING" value="EMP"/>
          <ConstColumn id="filterExpr" size="30" type="STRING" value=""/>
          <ConstColumn id="clsfCode" size="30" type="STRING" value="GENRE_SC_CD"/>
          <ConstColumn id="userDfnSet" size="30" type="STRING" value=""/>
          <Column id="cdcValue" size="30" type="STRING"/>
          <Column id="cdcValueNm" size="120" type="STRING"/>
          <Column id="cdcValueAbrvNm" size="150" type="STRING"/>
          <Column id="cdcValueSn" size="10" type="BIGDECIMAL"/>
          <Column id="cmmnCdYn" type="STRING" size="256"/>
          <Column id="stnrdCdYn" type="STRING" size="256"/>
          <Column id="upperClsfCdValue" size="30" type="STRING"/>
          <Column id="upperCdcValue" size="30" type="STRING"/>
          <Column id="userDfnCdValue01" size="100" type="STRING"/>
          <Column id="userDfnCdValue02" size="100" type="STRING"/>
          <Column id="userDfnCdValue03" size="100" type="STRING"/>
          <Column id="userDfnCdValue04" size="100" type="STRING"/>
          <Column id="userDfnCdValue05" size="100" type="STRING"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="cdcValue">1</Col>
            <Col id="cdcValueNm">댄스</Col>
          </Row>
          <Row>
            <Col id="cdcValue">2</Col>
            <Col id="cdcValueNm">발라드</Col>
          </Row>
          <Row>
            <Col id="cdcValue">3</Col>
            <Col id="cdcValueNm">팝</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsGrade" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="firstCode" size="30" type="STRING" value="EMP"/>
          <ConstColumn id="filterExpr" size="30" type="STRING" value=""/>
          <ConstColumn id="clsfCode" size="30" type="STRING" value="GRADE"/>
          <ConstColumn id="userDfnSet" size="30" type="STRING" value=""/>
          <Column id="cdcValue" size="30" type="STRING"/>
          <Column id="cdcValueNm" size="120" type="STRING"/>
          <Column id="cdcValueAbrvNm" size="150" type="STRING"/>
          <Column id="cdcValueSn" size="10" type="BIGDECIMAL"/>
          <Column id="cmmnCdYn" type="STRING" size="256"/>
          <Column id="stnrdCdYn" type="STRING" size="256"/>
          <Column id="upperClsfCdValue" size="30" type="STRING"/>
          <Column id="upperCdcValue" size="30" type="STRING"/>
          <Column id="userDfnCdValue01" size="100" type="STRING"/>
          <Column id="userDfnCdValue02" size="100" type="STRING"/>
          <Column id="userDfnCdValue03" size="100" type="STRING"/>
          <Column id="userDfnCdValue04" size="100" type="STRING"/>
          <Column id="userDfnCdValue05" size="100" type="STRING"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="cdcValue">1</Col>
            <Col id="cdcValueNm">최정상</Col>
          </Row>
          <Row>
            <Col id="cdcValue">2</Col>
            <Col id="cdcValueNm">가능성있는</Col>
          </Row>
          <Row>
            <Col id="cdcValue">3</Col>
            <Col id="cdcValueNm">신입</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsTypeCode" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="firstCode" size="30" type="STRING" value="SEL"/>
          <ConstColumn id="filterExpr" size="30" type="STRING" value=""/>
          <ConstColumn id="clsfCode" size="30" type="STRING" value="TYPE_CODE"/>
          <ConstColumn id="userDfnSet" size="30" type="STRING" value=""/>
          <Column id="cdcValue" size="30" type="STRING"/>
          <Column id="cdcValueNm" size="120" type="STRING"/>
          <Column id="cdcValueAbrvNm" size="150" type="STRING"/>
          <Column id="cdcValueSn" size="10" type="BIGDECIMAL"/>
          <Column id="cmmnCdYn" type="STRING" size="256"/>
          <Column id="stnrdCdYn" type="STRING" size="256"/>
          <Column id="upperClsfCdValue" size="30" type="STRING"/>
          <Column id="upperCdcValue" size="30" type="STRING"/>
          <Column id="userDfnCdValue01" size="100" type="STRING"/>
          <Column id="userDfnCdValue02" size="100" type="STRING"/>
          <Column id="userDfnCdValue03" size="100" type="STRING"/>
          <Column id="userDfnCdValue04" size="100" type="STRING"/>
          <Column id="userDfnCdValue05" size="100" type="STRING"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="cdcValue">1</Col>
            <Col id="cdcValueNm">정규앨범</Col>
          </Row>
          <Row>
            <Col id="cdcValue">2</Col>
            <Col id="cdcValueNm">미니앨범</Col>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSub" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="keys" type="STRING" size="30" value="columnText:&quot;성명&quot;name"/>
          <Column id="_chk" type="STRING" size="1"/>
          <Column id="id" type="STRING" size="256"/>
          <Column id="name" type="STRING" size="256"/>
          <Column id="artist" type="STRING" size="256"/>
          <Column id="release" type="STRING" size="256"/>
          <Column id="typeCode" type="STRING" size="256"/>
          <Column id="genreCode" type="STRING" size="256"/>
          <Column id="grade" type="STRING" size="256"/>
          <Column id="price" type="STRING" size="256"/>
          <Column id="downCnt" type="STRING" size="256"/>
          <Column id="listenCnt" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSearchSub">
        <ColumnInfo>
          <Column id="name" type="STRING" size="150"/>
          <Column id="genreCode" type="STRING" size="1"/>
          <Column id="artist" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="name"/>
            <Col id="genreCode"/>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[// 서비스 콜백 함수
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

// 폼 로드
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);

	// 서비스 객체 생성 
	//this.smfSearchService("validateMain").run();
	
	////////////////////////////////////////////
	// 샘플용 함수
	this.smfSetFirstCode(this.dsGenreScCd); 
	this.smfSetFirstCode(this.dsGrade);
	////////////////////////////////////////////

	// 조회 입력창에서 'Ctrl' + 'Enter' 키 입력시 조회수행 이벤트 설정
	this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
};

// 조회 버튼 클릭
this.div_search_btn_search_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 서비스 객체 생성
	this.smfSearchService("list")
		// 변경이 발생한 경우 조회전 confirm수행
		.confirmIfModifiedGrid(this.grdMain)
		// 데이터 검증
		.validateForm(this.divSearch)
		// 서브 그리드 데이터 제거
		.command(function(next){
			this.smfClearGridData(this.grdSub);
			next();
		})
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errorCd == -1) return;
		})
	;
};

// 메인 그리드 헤더 클릭
this.grdMain_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
    var columnName = obj.getCellProperty("body",e.cell,"text");
	if ("bind:_chk" == columnName){
		// 체크박스 전체 선택/해제
		this.smfToggleChkHeader(obj, e, this.fnRenderGridCheckbox);
	}else{
		// 정렬
		this.smfCheckAndSort(obj, e);
	}
};

// 폼 닫기전 이벤트
this.sample_gridSave_onbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	// 변경내역이 발생한 경우 종료전 confirm수행
	return this.smfCloseFormConfirm(this.dsMain);
};

// 조회조건이 변경된 경우
this.dsSearch_oncolumnchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	// 조회결과를 제거
	this.smfClearGridData(this.grdMain);
	this.smfClearGridData(this.grdSub);
};

// 메인 그리드 셀클릭
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
    var columnName = obj.getCellProperty("body",e.cell,"text");
	if(columnName == "bind:name"){
		// 조회를 위한 데이터셋 복사
		this.smfAssignSelectedRow(this.dsSearchSub, this.dsMain);

		// 서비스 객체 생성
		this.smfSearchService("listSub")
			// 실행
			.run()
			// 콜백
			.callback(function(callbackParams){
				if(callbackParams.errors) return;
			})
		;
	}
};

// 메인 그리드에서 키 입력
this.grdMain_onkeyup = function(obj:nexacro.Grid,e:nexacro.KeyEventInfo)
{
	// 'Enter' 키 입력시 서브 그리드 조회
	if(e.keycode == 13){
		// name 클릭유도
		var clickInfo = new nexacro.GridClickEventInfo();
		clickInfo.cell = 1;
		this.grdMain_oncellclick(obj, clickInfo);
	}
};]]></Script>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.edtName" propid="value" datasetid="dsSearch" columnid="name"/>
    </Bind>
  </Form>
</FDL>
