        <Button id="btnSmfRight" taborder="30" text="smfRight 샘플" left="262" top="463" width="248" height="34" onclick="btnSmfRight_onclick"/>
        <Button id="btnSmfRPad" taborder="31" text="smfRPad 샘플" left="519" top="463" width="248" height="34" onclick="btnSmfRPad_onclick"/>
        <Button id="btnSmfRtrim" taborder="32" text="smfRtrim 샘플" left="773" top="463" width="248" height="34" onclick="btnSmfRtrim_onclick"/>
