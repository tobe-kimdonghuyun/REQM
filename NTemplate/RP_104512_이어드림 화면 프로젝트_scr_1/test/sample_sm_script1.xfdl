<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sample_sm_script1" width="1280" height="720" titletext="넥사크로 기능공통 모듈 샘플" onload="fnOnload">
    <Layouts>
      <Layout height="720" mobileorientation="landscape" width="1280">
        <Static id="staMain" taborder="0" text="넥사크로 기능공통 모듈 샘플" left="10" cssclass="sta_Ctitle" top="6" right="90" height="40" font="bold 20pt/normal &quot;Arial&quot;"/>
        <Static id="staDate" taborder="1" text="날짜" left="2" top="67" width="55" height="34" font="bold 16pt/normal &quot;Arial&quot;"/>
        <Button id="btnSmfAddDate" taborder="2" text="smfAddDate 샘플" left="2" top="124" width="248" height="34" onclick="btnSmfAddDate_onclick"/>
        <Button id="btnSmfAddMonth" taborder="3" text="smfAddMonth 샘플" left="259" top="124" width="248" height="34" onclick="btnSmfAddMonth_onclick"/>
        <Button id="btnSmfDiffDate" taborder="4" text="smfDiffDate 샘플" left="516" top="124" width="248" height="34" onclick="btnSmfDiffDate_onclick"/>
        <Button id="btnSmfDiffMonth" taborder="5" text="smfDiffMonth 샘플" left="773" top="124" width="248" height="34" onclick="btnSmfDiffMonth_onclick"/>
        <Button id="btnSmfIsDate" taborder="6" text="smfIsDate 샘플" left="1030" top="124" width="248" height="34" onclick="btnSmfIsDate_onclick"/>
        <Button id="btnSmfIsLeapYear" taborder="7" text="smfIsLeapYear 샘플" left="2" top="167" width="248" height="34" onclick="btnSmfIsLeapYear_onclick"/>
        <Button id="btnSmfLastDate" taborder="8" text="smfLastDate 샘플" left="262" top="167" width="248" height="34" onclick="btnSmfLastDate_onclick"/>
        <Button id="btnSmfLastDateNum" taborder="9" text="smfLastDateNum 샘플" left="519" top="167" width="248" height="34" onclick="btnSmfLastDateNum_onclick"/>
        <Button id="btnSmfMakeDate" taborder="10" text="smfMakeDate 샘플" left="773" top="167" width="248" height="34" onclick="btnSmfMakeDate_onclick"/>
        <Button id="btnSmfToday" taborder="11" text="smfToday 샘플" left="1030" top="167" width="248" height="34" onclick="btnSmfToday_onclick"/>
        <Button id="btnSmfTodayTime" taborder="12" text="smfTodayTime 샘플" left="2" top="210" width="248" height="34" onclick="btnSmfTodayTime_onclick"/>
        <Static id="staStr" taborder="13" text="문자열" left="2" top="283" width="68" height="34" font="bold 16pt/normal &quot;Arial&quot;"/>
        <Button id="btnDformat" taborder="14" text="dformat 샘플" left="2" top="334" width="248" height="34" onclick="btnDformat_onclick"/>
        <Button id="btnFormat" taborder="15" text="format 샘플" left="262" top="334" width="248" height="34" onclick="btnFormat_onclick"/>
        <Button id="btnLpad" taborder="16" text="lpad 샘플" left="519" top="334" width="248" height="34" onclick="btnLpad_onclick"/>
        <Button id="btnRpad" taborder="17" text="rpad 샘플" left="773" top="334" width="248" height="34" onclick="btnRpad_onclick"/>
        <Button id="btnSmfContainsStr" taborder="18" text="smfContainsStr 샘플" left="1030" top="334" width="248" height="34" onclick="btnSmfContainsStr_onclick"/>
        <Button id="btnSmfContainsText" taborder="19" text="smfContainsText 샘플" left="2" top="377" width="248" height="34" onclick="btnSmfContainsText_onclick"/>
        <Button id="btnSmfCount" taborder="20" text="smfCount 샘플" left="262" top="377" width="248" height="34" onclick="btnSmfCount_onclick"/>
        <Button id="btnSmfFormat" taborder="21" text="smfFormat 샘플" left="519" top="377" width="248" height="34" onclick="btnSmfFormat_onclick"/>
        <Button id="btnSmfFormatMoney" taborder="22" text="SmfFormatMoney 샘플" left="773" top="377" width="248" height="34" onclick="btnSmfFormatMoney_onclick"/>
        <Button id="btnSmfIsLike" taborder="23" text="smfIsLike 샘플" left="1030" top="377" width="248" height="34" onclick="btnSmfIsLike_onclick"/>
        <Button id="btnSmfLenB" taborder="24" text="smfLenB 샘플" left="2" top="420" width="248" height="34" onclick="btnSmfLenB_onclick"/>
        <Button id="btnSmfLPad" taborder="25" text="smfLPad 샘플" left="262" top="420" width="248" height="34" onclick="btnSmfLPad_onclick"/>
        <Button id="btnSmfLtrim" taborder="26" text="smfLtrim 샘플" left="519" top="420" width="248" height="34" onclick="btnSmfLtrim_onclick"/>
        <Button id="btnSmfMid" taborder="27" text="smfMid 샘플" left="773" top="420" width="248" height="34" onclick="btnSmfMid_onclick"/>
        <Button id="btnSmfPos" taborder="28" text="smfPos 샘플" left="1030" top="420" width="248" height="34" onclick="btnSmfPos_onclick"/>
