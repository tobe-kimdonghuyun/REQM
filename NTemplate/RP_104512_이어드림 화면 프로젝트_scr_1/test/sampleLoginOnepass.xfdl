        <Static id="staFinLogo" taborder="1" left="98" top="120" height="115" cssclass="sta_Login_PartyCert" text="" width="276" initvalueid="ivStcAccessibilityOn"/>
        <Button id="btnDoLogin" taborder="2" text="행안부 디지털원패스 로그인" left="62" top="263" width="348" height="60" cssclass="btn_Login_PartyCert" initvalueid="ivBtnAccessibilityButton" onclick="btnDoLogin_onclick"/>
        <Static id="sta01" taborder="3" text="실행결과 :" left="63" top="357" width="120" height="30"/>
        <TextArea id="txt00" taborder="4" left="57" top="397" width="453" height="230"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
