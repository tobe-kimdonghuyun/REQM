this.btnDoLogin_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 테스트를 위해 실행결과를 지운다.
	this.txt00.set_value("");

	var objParam = {objForm:this, popupcallback :this.fnPopupCallback};
	this.smfExecMoisDOAuth(objParam);
	
};

