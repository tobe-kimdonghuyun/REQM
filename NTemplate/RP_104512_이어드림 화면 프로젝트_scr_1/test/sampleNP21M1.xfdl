    <Script type="xscript5.1"><![CDATA[

this.Button_onsetfocus = function(obj:nexacro.Button,e:nexacro.SetFocusEventInfo)
{
	obj.bringToFront();
	obj.set_cssclass("btn_WF_area_S");
};

this.Button_onkillfocus = function(obj:nexacro.Button,e:nexacro.KillFocusEventInfo)
{
	obj.set_cssclass("btn_WF_area");	
};
