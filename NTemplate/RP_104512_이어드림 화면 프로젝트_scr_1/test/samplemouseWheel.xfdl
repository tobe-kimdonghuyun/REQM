<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="samplemouseWheel" width="1280" height="1200" titletext="마우스휠이벤트" onload="samplemouseWheel_onload" onmousewheel="samplemouseWheel_onmousewheel" ontimer="samplemouseWheel_ontimer" scrollbartype="none none" scrolltype="none" onbeforeclose="samplemouseWheel_onbeforeclose">
    <Layouts>
      <Layout height="1200" width="1280" screenid="ScreenDeskTopP">
        <Div id="div00" taborder="0" text="div00" left="0" top="0" height="348" right="0" url="templateP::Main_sub0.xfdl" formscrollbartype="none none" formscrolltype="none"/>
        <Div id="div00_00" taborder="1" text="div00" left="0" top="div00:0" height="348" right="10" url="templateP::Main_sub1.xfdl" formscrollbartype="none none" formscrolltype="none"/>
        <Div id="div00_00_00" taborder="2" text="div00" left="0" top="div00_00:0" height="104" right="0" url="templateP::Main_sub2.xfdl" formscrollbartype="none none" formscrolltype="none"/>
        <Div id="div00_00_00_00" taborder="3" text="div00" left="0" top="div00_00_00:0" height="104" right="0" url="templateP::Main_sub3.xfdl" formscrollbartype="none none" formscrolltype="none"/>
        <Div id="div00_00_00_00_00" taborder="4" text="div00" left="0" top="div00_00_00_00:0" height="104" right="0" url="templateP::Main_sub4.xfdl" formscrollbartype="none none" formscrolltype="none"/>
      </Layout>
      <Layout name="Layout0" screenid="mobile" width="640" height="1144" mobileorientation="portrait" type="default"/>
    </Layouts>
