    </Objects>
    <Script type="xscript5.1"><![CDATA[// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
};

// 폼 로드
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);

	// 서비스 객체 생성 
	this.smfValidateService("validateMain", {
			url: "/cmc_sam_pl13_000.do",
		})
  		.mappingRulesetToForm(this.divSearch, "search")
  		.mappingRulesetToDataset(this.dsMainValid, "save")
		.callback(function(callbackParams){
		})
		.run()
	;	
	

	////////////////////////////////////////////
	// 샘플을 위한  함수 호출
	// 장르 콤보에 "전체"를 추가한다
	this.smfSetFirstCode(this.dsGenreScCd);
	// 장르 콤보에 ""를 추가한다
	this.smfSetFirstCode(this.dsGenreScCd2);
	// 등급 콤보에 ""를 추가한다
	this.smfSetFirstCode(this.dsGrade);
	////////////////////////////////////////////

	// Grid Checkbox 활성화/활성화 제어
	this.smfUpdateRednerGridCheckbox(this.grdMain, 0, this.fnRenderGridCheckbox); 

	// 조회 입력창에서 'Ctrl' + 'Enter' 키 입력시 조회수행 이벤트 설정
	this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
};

// 그리드 체크박스 enable 처리
this.fnRenderGridCheckbox = function(ds, nRow){
	// '아이유' 데이터는 삭제 불가
    return this.dsMain.getColumn(nRow, "artist") != "아이유";
};

// 페이징검색-기본
this.div_search_btn_search_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 서비스 객체 생성
	this.smfSearchService("list")
		// 페이징처리
		.paginator(this.grdMain, this.divPaginator, this.divPageSummary, this.dsPageInfo, obj, e)
		// 데이터가 변경되었으면 확인메시지
		.confirmIfModifiedGrid(this.grdMain)
		// 데이터 검증
		.validateForm(this.divSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		})
	;
};



// 페이징검색-함수이용
this.divSearch_btnSearch00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearch(obj, e);
};

this.fnSearch = function(obj, e){
	// 서비스 객체 생성
	this.smfSearchService("list")
		// 페이징처리
		.paginator(this.grdMain, this.divPaginator, this.divPageSummary, this.dsPageInfo, this.fnSearch, e)
		// 데이터가 변경되었으면 확인메시지
		.confirmIfModifiedGrid(this.grdMain)
		// 데이터 검증
		.validateForm(this.divSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		})
	;
};



// 추가 버튼 클릭
this.btn_add_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 조회를 수행했는지 검증 후 그리드에 row를 추가
	var nRow = this.smfAddGridRow(this.grdMain, "list");
	if(nRow == -1) return;
};

// 저장 버튼 클릭 
this.btn_save_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 서비스 객체 생성 
	this.smfSaveService("save")
		// 데이터 검증
		// dsMainValid의 row는 2개가 있는데
		// 첫번째는 Dataset.ROWTYPE_INSERT에 해당하는 유효성검사 룰셋을 담당한다
		// 두번째는 Dataset.ROWTYPE_UPDATE에 해당하는 유효성검사 룰셋을 담당한다
		// 컬럼값에 = 은 INSERT와 동일한 룰셋을 사용한다는 의미이다
		.validateGrid(this.grdMain, this.dsMainValid)

		// 그리드 영역에서 중복검사
		.validateDuplicate({
			grid: this.grdMain,
			// gridText: "음반목록",
			columnNames: ["name", "artist", "release"], // 중복검사할 컬럼명
			columnText: "이름, 아티스트, 출시일자",
		})

		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			// 저장이 완료되었습니다.
			// 재조회
			this.smfAlert('CM002', [], this.div_search_btn_search_onclick);
		});
		
};

// 삭제 버튼 클릭
this.btn_delete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 삭제처리
	this.smfDeleteService("delete")
		.validateGridDelete(this.grdMain, this.dsMainValid)
		.run()
		// 콜백
		.callback(function(callbackParams){ 
			alert('[참고] 본 샘플에서 데이터 삭제는 서버에서 동작하지 않도록 처리하였습니다');
			if(callbackParams.errors) return;
			
			// 삭제하였습니다 알림 후 재조회
			this.smfAlert(this.smfAfterServiceMessage(), this.fnSearch);
		})
};

// 그리드 헤더 클릭
this.grdMain_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
    var columnName = obj.getCellProperty("body",e.cell,"text");
	if ("bind:_chk" == columnName){
		this.smfToggleChkHeader(obj, e, this.fnRenderGridCheckbox);
	}else{
		// 정렬
		this.smfCheckAndSort(obj, e);
	}
};

// 폼 닫기전 이벤트
this.sample_gridSave_onbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	// 변경내역이 발생한 경우 종료전 confirm수행
	return this.smfCloseFormConfirm(this.dsMain);
};

// 조회조건이 변경된 경우
this.dsSearch_oncolumnchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	// list에 관련된 데이터를 클리어 한다
	this.smfClearDataByService("list");
};

]]></Script>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.edtName" propid="value" datasetid="dsSearch" columnid="name"/>
      <BindItem id="item1" compid="divSearch.form.edtArtist" propid="value" datasetid="dsSearch" columnid="artist"/>
      <BindItem id="item2" compid="divSearch.form.cboGenreCode" propid="value" datasetid="dsSearch" columnid="genreCode"/>
    </Bind>
  </Form>
</FDL>
