<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sample_crudGridPage" width="1280" height="720" titletext="그리드 저장" onload="fnOnload" border="1px solid" onbeforeclose="sample_gridSave_onbeforeclose">
    <Layouts>
      <Layout height="720" width="1280">
        <Static id="staMain" taborder="0" text="사용자관리" left="10" cssclass="sta_Ctitle" top="6" right="90" height="40" font="bold 20px/normal &quot;Consolas&quot;"/>
        <Grid id="grdMain" taborder="1" top="230" height="400" binddataset="dsMain" autofittype="col" scrollbardecbuttonsize="0" scrollbarincbuttonsize="0" left="5" right="91" autoupdatetype="comboselect" autoenter="select" onheadclick="grdMain_onheadclick">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="27"/>
                <Column size="48"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="34" band="head"/>
                <Row size="34"/>
              </Rows>
              <Band id="head">
                <Cell displaytype="checkboxcontrol" edittype="checkbox"/>
                <Cell col="1" text="순번"/>
                <Cell col="2" text="아이디"/>
                <Cell col="3" text="성명"/>
                <Cell col="4" text="아티스트"/>
                <Cell col="5" text="음반릴리즈"/>
                <Cell col="6" text="앨범타입"/>
                <Cell col="7" text="장르"/>
                <Cell col="8" text="등급"/>
                <Cell col="9" text="가격"/>
                <Cell col="10" text="다운로드횟수"/>
                <Cell col="11" text="청취횟수"/>
              </Band>
              <Band id="body">
                <Cell text="bind:_chk" displaytype="checkboxcontrol" edittype="checkbox" checkboxfalsevalue="0" checkboxtruevalue="1"/>
                <Cell col="1" text="expr:currow+1" textAlign="center"/>
                <Cell col="2" text="bind:id" edittype="none"/>
                <Cell col="3" text="bind:name" edittype="text" editautoselect="false"/>
                <Cell col="4" text="bind:artist" edittype="text" editautoselect="false"/>
                <Cell col="5" text="bind:release" edittype="date" editautoselect="true" displaytype="date" calendareditformat="yyyy.MM.dd" calendarautoselect="true" calendardisplayinvalidtype="none" calendardisplaynulltype="none" calendardateformat="yyyy.MM.dd"/>
                <Cell col="6" text="bind:typeCode" edittype="combo" editautoselect="true" combodataset="dsTypeCode" combocodecol="cdcValue" combodatacol="cdcValueNm" displaytype="combocontrol"/>
                <Cell col="7" text="bind:genreCode" edittype="combo" editautoselect="true" displaytype="combocontrol" combodataset="dsGenreScCd2" combocodecol="cdcValue" combodatacol="cdcValueNm" combotype="filterlike"/>
                <Cell col="8" text="bind:grade" edittype="combo" editautoselect="true" combodataset="dsGrade" combocodecol="cdcValue" combodatacol="cdcValueNm" displaytype="combocontrol" combotype="filterlike"/>
                <Cell col="9" text="bind:price" edittype="text" editautoselect="true" displaytype="number" maskeditformat="###,##0"/>
                <Cell col="10" text="bind:downCnt" edittype="text" editautoselect="true" maskeditformat="###,##0" displaytype="number"/>
                <Cell col="11" text="bind:listenCnt" edittype="text" editautoselect="true" maskeditformat="###,##0" displaytype="number"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Div id="divSearch" taborder="2" left="5" top="61" width="1265" height="119" text="">
          <Layouts>
            <Layout>
              <Static id="sta_01" taborder="6" left="79" top="6" cssclass="sta_WF_tablebg" width="265" height="34"/>
              <Static id="sta_02" taborder="0" text="사용자명" left="0" top="6" cssclass="sta_WF_tablelabel" width="80" height="34"/>
              <Static id="sta_03" taborder="2" text="아티스트" left="353" top="6" cssclass="sta_WF_tablelabel" width="80" height="34"/>
              <Static id="sta_04" taborder="7" left="472" top="6" cssclass="sta_WF_tablebg" width="225" height="34"/>
              <Edit id="edtName" taborder="1" text="-선택-" left="90" top="6" height="34" leftbase="" topbase="" bottombase="" rightbase="" widthbase="" heightbase="" innerdataset="@ds_dep" codecolumn="code" datacolumn="data" scrollbarbarminsize="20" value="" index="-1" scrollbarbaroutsize="20" scrollbarsize="10" scrollbartrackbarsize="25" itemheight="20" width="243"/>
              <Static id="sta_06" taborder="4" text="장르" left="696" top="6" cssclass="sta_WF_tablelabel" width="80" height="34"/>
              <Static id="sta_16" taborder="8" left="845" top="6" cssclass="sta_WF_tablebg" width="225" height="34"/>
              <Combo id="cboGenreCode" taborder="5" top="6" height="34" leftbase="" topbase="" bottombase="" rightbase="" widthbase="" heightbase="" right="302" width="203" innerdataset="dsGenreScCd" codecolumn="cdcValue" datacolumn="cdcValueNm"/>
              <Edit id="edtArtist" taborder="3" text="-선택-" left="450" top="6" height="34" leftbase="" topbase="" rightbase="" widthbase="" heightbase="" innerdataset="@ds_dep" codecolumn="code" datacolumn="data" value="" index="-1" scrollbarbaroutsize="20" scrollbarsize="10" scrollbartrackbarsize="25" itemheight="20" width="203" validate="maxlength:20"/>
              <Button id="btnSearch" taborder="9" text="페이징검색-기본" top="6" height="34" width="196" right="84" onclick="div_search_btn_search_onclick"/>
              <Button id="btnSearch00" taborder="10" text="페이징검색-함수이용" top="46" height="34" width="196" right="84" onclick="divSearch_btnSearch00_onclick"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnSave" taborder="3" text="저장" top="185" height="34" width="76" right="172" onclick="btn_save_onclick"/>
        <Button id="btnDelete" taborder="4" text="삭제" top="185" height="34" width="76" right="95" onclick="btn_delete_onclick"/>
        <Button id="btnAdd" taborder="5" text="추가" top="185" height="34" width="76" right="249" onclick="btn_add_onclick"/>
        <Div id="divPaginator" taborder="6" left="5" top="640" width="1184" height="30" url="comm::comp_paginator.xfdl" visible="true" pageViewSize="100" dsPage="dsPage"/>
        <Div id="divPageSummary" taborder="7" left="7" top="190" width="331" height="30" url="comm::comp_pageSummary.xfdl" visible="true"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsOrdScCode" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="firstCode" type="STRING" size="30" value=""/>
          <ConstColumn id="filterExpr" type="STRING" size="30" value=""/>
          <ConstColumn id="clsfCode" type="STRING" size="30" value="ORD_SC_CODE"/>
          <ConstColumn id="userDfnSet" type="STRING" size="30" value=""/>
          <Column id="cdcValue" type="STRING" size="30"/>
          <Column id="cdcValueNm" type="STRING" size="120"/>
          <Column id="cdcValueAbrvNm" type="STRING" size="150"/>
          <Column id="codeValueSeq" type="BIGDECIMAL" size="10"/>
          <Column id="upperClsfCodeValue" type="STRING" size="30"/>
          <Column id="upperCdcValue" type="STRING" size="30"/>
          <Column id="userDfnCodeValue01" type="STRING" size="100"/>
          <Column id="userDfnCodeValue02" type="STRING" size="100"/>
