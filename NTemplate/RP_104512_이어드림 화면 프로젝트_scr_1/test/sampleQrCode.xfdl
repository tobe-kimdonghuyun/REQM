<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sampleQrCode" width="1280" height="745" titletext="QRCode샘플(jsQR사용)">
    <Layouts>
      <Layout height="745" width="1280">
        <Static id="sta00" taborder="0" text="jsQR을 이용한 샘플" left="38" top="18" width="410" height="30"/>
        <Button id="btnReadQr" taborder="1" text="카메라 연동" left="36" top="63" width="133" height="37" onclick="btnReadQr_onclick"/>
        <TextArea id="txtQrData" taborder="2" left="34" top="138" width="516" height="188" wordWrap="char"/>
        <Static id="sta01" taborder="3" text="읽은 값 : " left="38" top="105" width="120" height="30"/>
        <Static id="sta01_00" taborder="4" text="마스터정보" left="35" top="339" width="120" height="30" onclick="sta01_00_onclick"/>
        <Edit id="edt00" taborder="5" left="170" top="386" width="367" height="38"/>
        <Static id="sta01_00_00" taborder="6" text="masterNo" left="35" top="386" width="120" height="38" onclick="sta01_00_onclick"/>
        <Static id="sta01_00_00_00" taborder="7" text="masterName" left="35" top="436" width="120" height="38" onclick="sta01_00_onclick"/>
        <Edit id="edt00_00" taborder="8" left="170" top="436" width="367" height="38"/>
        <Static id="sta01_00_00_00_00" taborder="9" text="orderDate" left="35" top="486" width="120" height="38" onclick="sta01_00_onclick"/>
        <Edit id="edt00_00_00" taborder="10" left="170" top="486" width="367" height="38"/>
        <Static id="sta01_00_00_00_00_00" taborder="11" text="useDate" left="35" top="536" width="120" height="38" onclick="sta01_00_onclick"/>
        <Edit id="edt00_00_00_00" taborder="12" left="170" top="536" width="367" height="38"/>
        <Grid id="grd00" taborder="13" left="37" top="601" height="129" binddataset="dsDetail" width="500">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="24" band="head"/>
                <Row size="24"/>
              </Rows>
              <Band id="head">
                <Cell text="상품번호"/>
                <Cell col="1" text="상품명"/>
                <Cell col="2" text="수량"/>
                <Cell col="3" text="단위"/>
                <Cell col="4" text="품위일자"/>
              </Band>
              <Band id="body">
                <Cell text="bind:detailNo" textAlign="center"/>
                <Cell col="1" text="bind:detailName"/>
                <Cell col="2" text="bind:detailQty" textAlign="center"/>
                <Cell col="3" text="bind:detailUnit" textAlign="center" displaytype="combotext" combodataset="dsUnitCode" combocodecol="code" combodatacol="text"/>
                <Cell col="4" text="bind:orderDate" displaytype="mask" maskedittype="string" maskeditformat="@@@@/@@/@@" textAlign="center"/>
              </Band>
            </Format>
            <Format id="format00">
              <Columns>
                <Column size="95"/>
                <Column size="140"/>
                <Column size="117"/>
                <Column size="116"/>
                <Column size="117"/>
              </Columns>
              <Rows>
                <Row size="40" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="상품번호"/>
                <Cell col="1" text="상품명"/>
                <Cell col="2" text="수량"/>
                <Cell col="3" text="단위"/>
                <Cell col="4" text="품위일자"/>
              </Band>
              <Band id="body">
                <Cell text="bind:detailNo" textAlign="center"/>
                <Cell col="1" text="bind:detailName"/>
                <Cell col="2" text="bind:detailQty" textAlign="center"/>
                <Cell col="3" text="bind:detailUnit" textAlign="center"/>
                <Cell col="4" text="bind:orderDate" displaytype="mask" maskedittype="string" maskeditformat="@@@@/@@/@@" textAlign="center"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
      </Layout>
      <Layout name="Layout0" screenid="mobile" width="640" height="960" mobileorientation="portrait" type="default">
        <Button id="btnReadQr" left="34" top="93" width="193" height="47"/>
        <TextArea id="txtQrData" left="34" top="192" width="516" height="128"/>
        <Static id="sta01" left="34" top="149" width="140" height="40"/>
        <Static id="sta00" left="34" top="18" width="512" height="50"/>
        <Static id="sta01_00" left="35" top="340" width="120" height="30"/>
        <Edit id="edt00" left="210" top="387" width="341" height="38"/>
        <Static id="sta01_00_00" left="35" top="387" width="160" height="38"/>
        <Static id="sta01_00_00_00" left="35" top="437" width="160" height="38"/>
        <Edit id="edt00_00" left="210" top="437" width="341" height="38"/>
        <Static id="sta01_00_00_00_00" left="35" top="487" width="160" height="38"/>
        <Edit id="edt00_00_00" left="210" top="487" width="341" height="38"/>
        <Static id="sta01_00_00_00_00_00" left="35" top="537" width="160" height="38"/>
        <Edit id="edt00_00_00_00" left="210" top="537" width="341" height="38"/>
        <Grid id="grd00" left="17" top="602" width="603" height="309" formatid="format00"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    sample
*  @FileName 	sampleQrCode.xfdl
*  @Creator 	정인혁
*  @CreateDate 	2022.7.4
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.7.4     	정인혁 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 

this.btnReadQr_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (system.navigatorname.indexOf("nexacro")  > -1) 
	{
		alert("nexacro Runtime에서는 동작을 하지 않습니다.");
		return;
	}

	//데이터셋을 삭제한다.
	this.dsMaster.clearData();
	this.dsDetail.clearData();
	
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: this.fnPopupCallback, // 콜백함수 지정
		sender: obj, // sender 지정

		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: "none"
		},
	};

	// 모달팝업 실행
	this.smfDialog("_auto", "comm::comp_readQr.xfdl", popupParams);		
	
};

/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	// 업무콜백 처리
	var sQrData = e.qrData;
	var sCheckText = "NEISQR:";
	
	trace("e ==>"+sQrData);	
	this.txtQrData.set_value(sQrData);
	
	// 데이터가 없으면 처리를 안함.
	if(this.smfIsNull(sQrData))
	{
		return;
	}
	
	// 데이터부분만 추출
	var sJsonData = sQrData.substr(sCheckText.length,sQrData.length-sCheckText.length);
	trace("sJsonData=["+sJsonData+"]");
	
	// 데이터셋을 만든다.
	this.fnMakeDataset(sJsonData);		
};


this.fnMakeDataset = function(sQrData)
{
	// Json object로 만든다.
	var objJson = JSON.parse(sQrData	);
	
	// dsMaster생성
	var nAddRowMaster = this.dsMaster.addRow();

	this.dsMaster.setColumn(nAddRowMaster,"masterNo"   , objJson.masterNo   );
	this.dsMaster.setColumn(nAddRowMaster,"masterName" , objJson.masterName );
	this.dsMaster.setColumn(nAddRowMaster,"orderDate"  , objJson.orderDate  );
	this.dsMaster.setColumn(nAddRowMaster,"useDate"    , objJson.useDate    );
	
	// Detail정보를 추출
	var objJsonDetailInfo = objJson.detailInfo;

	// dsDetail생성
	if(objJsonDetailInfo)
	{
		for(var i=0;i<objJsonDetailInfo.length;i++)
		{
			var nAddRowDetail = this.dsDetail.addRow();
			
			this.dsDetail.setColumn(nAddRowDetail,"detailNo"   , objJsonDetailInfo[i].detailNo    );
			this.dsDetail.setColumn(nAddRowDetail,"detailName" , objJsonDetailInfo[i].detailName  );
			this.dsDetail.setColumn(nAddRowDetail,"detailQty"  , objJsonDetailInfo[i].detailQty   );
			this.dsDetail.setColumn(nAddRowDetail,"detailUnit" , objJsonDetailInfo[i].detailUnit  );
			this.dsDetail.setColumn(nAddRowDetail,"orderDate"  , objJsonDetailInfo[i].orderDate   );
		}
	}
}

]]></Script>
    <Objects>
      <Dataset id="dsMaster">
        <ColumnInfo>
          <Column id="masterNo" type="STRING" size="256"/>
          <Column id="masterName" type="STRING" size="256"/>
          <Column id="orderDate" type="STRING" size="256"/>
          <Column id="useDate" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsDetail">
        <ColumnInfo>
          <Column id="detailNo" type="STRING" size="256"/>
          <Column id="detailName" type="STRING" size="256"/>
          <Column id="detailQty" type="STRING" size="256"/>
          <Column id="detailUnit" type="STRING" size="256"/>
          <Column id="orderDate" type="STRING" size="256"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsUnitCode">
        <ColumnInfo>
          <Column id="code" type="STRING" size="256"/>
          <Column id="text" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="code">1</Col>
            <Col id="text">개</Col>
          </Row>
          <Row>
            <Col id="code">2</Col>
            <Col id="text">KG</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="edt00" propid="value" datasetid="dsMaster" columnid="masterNo"/>
      <BindItem id="item1" compid="edt00_00" propid="value" datasetid="dsMaster" columnid="masterName"/>
      <BindItem id="item2" compid="edt00_00_00" propid="value" datasetid="dsMaster" columnid="orderDate"/>
      <BindItem id="item3" compid="edt00_00_00_00" propid="value" datasetid="dsMaster" columnid="useDate"/>
    </Bind>
  </Form>
</FDL>
