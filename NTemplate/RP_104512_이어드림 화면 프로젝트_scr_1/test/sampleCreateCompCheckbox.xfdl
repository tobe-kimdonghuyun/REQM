          <Column id="qlflIdfCd" type="STRING" size="256" description="자격증식별코드"/>
          <Column id="qlflIdfValue" type="STRING" size="256" description="자격증식별값"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="qlflIdfCd">10</Col>
