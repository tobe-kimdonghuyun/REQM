<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sampleCreateCompCheckbox" width="1280" height="745" titletext="New Form">
    <Layouts>
      <Layout height="745" mobileorientation="landscape" width="1280">
        <Div id="div00" taborder="0" text="div00" left="40" top="81" width="721" height="269" border="1px solid black"/>
        <Button id="btn00" taborder="1" text="checkBox생성" left="41" top="42" width="151" height="34" onclick="btn00_onclick"/>
        <Button id="btn00_00" taborder="2" text="체크한 항목 리스트 가져오기" left="41" top="370" width="191" height="34" onclick="btn00_00_onclick"/>
        <TextArea id="txt00" taborder="3" left="42" top="417" width="720" height="166"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
