<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sampleTracer" width="1280" height="745" titletext="TTS 연동 샘플" onload="sampleTracer_onload">
    <Layouts>
      <Layout height="745" width="1280">
        <Static id="sta00" taborder="0" text="TTS 사용 샘플" left="6" top="3" width="514" height="50"/>
        <Edit id="edtTTS" taborder="1" left="118" top="128" width="567" height="38"/>
        <Button id="btnTTS" taborder="2" text="TTS 실행" left="123" top="182" width="146" height="45" onclick="btnTTS_onclick"/>
        <Div id="divTTS" taborder="3" left="126" top="246" width="303" height="46" url="comm::comp_tts.xfdl" text=""/>
        <Static id="sta01" taborder="4" text="TTS 데이터 : " left="16" top="132" width="100" height="30"/>
        <Static id="sta02" taborder="5" text="아래의 DIV ( divTTS )를 해당화면에 copy한후, TTS 데이터를 fnTTS()함수를 호출하여 실행한다." left="64" top="49" width="500" height="60"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    샘플
*  @FileName 	sampleTts.xfdl
*  @Creator 	정인혁
*  @CreateDate 	2022.8.9
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.8.9     	정인혁 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 
this.btnTTS_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 입력한 TTS 데이터를 읽는다
	var sTtsData = this.edtTTS.value;
	
	// 입력한 데이터가 없으면 처리를 중단.
	if(this.smfIsNull(sTtsData))
	{
		alert("데이터를 입력해 주세요");
		return;
	}
	
	// TTS실행
	this.divTTS.form.fnTTS(sTtsData);
	
};
]]></Script>
    <Objects/>
  </Form>
</FDL>
