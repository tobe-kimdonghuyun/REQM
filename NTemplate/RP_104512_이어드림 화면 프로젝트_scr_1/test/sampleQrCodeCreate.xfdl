<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sampleQrCodeCreate" width="1070" height="535" titletext="New Form" onload="sampleQrCodeCreate_onload">
    <Layouts>
      <Layout height="535" width="1070">
        <WebBrowser id="webQrCode" taborder="0" left="10" top="180" border="1px solid gray" bottom="5" right="660" onloadcompleted="webQrCode_onloadcompleted" onusernotify="webQrCode_onusernotify"/>
        <Static id="sta00" taborder="1" text="QrCode생성" left="18" top="18" width="410" height="30"/>
        <TextArea id="txtData" taborder="2" left="11" top="47" width="638" height="78"/>
        <Button id="btnCreate" taborder="3" text="생성" left="11" top="130" width="149" height="40" onclick="btnCreate_onclick"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    TEMPLATE
*  @FileName 	sampleQrCodeCreate.xfdl
*  @Creator 	홍길동
*  @CreateDate 	2022.7.5
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.7.5     	홍길동 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 this.sampleQrCodeCreate_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	var sUrlPath = window.location.protocol + "//" + window.location.host;
	var sUrl =  sUrlPath + "/html/QR/creator/nexacro_qrcode.html";
	
	// url클리어
	//this.webQrCode.set_url("");
	
	// Url세팅
	this.webQrCode.set_url(sUrl);	
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 
this.webQrCode_onloadcompleted = function(obj:nexacro.WebBrowser,e:nexacro.WebLoadCompEventInfo)
{
	
};

this.webQrCode_onusernotify = function(obj:nexacro.WebBrowser,e:nexacro.WebUserNotifyEventInfo)
{
	
};

this.btnCreate_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sUserData = this.txtData.value;
	
	this.webQrCode.callMethod("createQrCode",sUserData);
};

]]></Script>
  </Form>
</FDL>
