this.btnUpload_FileSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sFileSn = this.edtFileRefrnId.value;
	// 업로드 초기화
	this.divFileUpload.form.fnResetUpload();
	
	this.ds00.setColumn(0,"fileRefrnId",sFileSn);


	this.transaction("fn_filesearch" // serviceId
				,"baseUrl::/cm_cmc_file_upload_001.do" // url
				,"" // inDataset
				,"dsOutFileinfo=atchFileinfo" // outDataset
				//,"fileRefrnId='wERMhEHwrN7re8VIlylqrb8SJIU2nkZFMOu9EAa3Q3s='"
				,"fileRefrnId='"+sFileSn+"'"
				,this.btnUpload_FileSearch_callback // callbackFunction
				,false // true: 비동기, false:동기
   );
   /*
	this.transaction("fn_filesearch" // serviceId
				,"baseUrl::/cm_cmc_file_upload_001_1.do" // url
				,"ds00=ds00" // inDataset
				,"outFileinfo=atchFileinfo" // outDataset
				//,"fileRefrnId='wERMhEHwrN7re8VIlylqrb8SJIU2nkZFMOu9EAa3Q3s='"
				,""//"fileRefrnId='"+sFileSn+"'"
				,this.btnUpload_FileSearch_callback // callbackFunction
				,false // true: 비동기, false:동기
   );
   */
   for (var i = 0; i < this.dsOutFileinfo.rowcount; i++) {
			//trace("=== Sample : fnEventUploadComplete"+this.smfUploadInfoFileSn(jsonNew.responseCustomValue[i],0));	
			var responseCustomValue = "";
			var sDownloadUrl       = "";   // 
			var sPrivInfoFiltYn    = "";   // 항목 관리안함
			var sFileInfSaveYn     = "Y";  // 업무에 맞게 개발자가 세팅(Y/N)
			var sHandlerCode       = "PA.SAM.PLE";  //this.smfUploadInfoFileSn(jsonWebFile.customValue[i],0);
			//var fileSn           = "476";  //this.smfUploadInfoFileSn(jsonWebFile.customValue[i],1);
			var sFileSn            = this.dsOutFileinfo.getColumn(i,"fileRefrnId"   );
			var sFileSeq           = this.dsOutFileinfo.getColumn(i,"fileId"        );
			var sFileSize          = this.dsOutFileinfo.getColumn(i,"atchFileMg"    );
			var sBackendFilename   = this.dsOutFileinfo.getColumn(i,"atchFileGuid"  );
			var sForntendFilename  = this.dsOutFileinfo.getColumn(i,"atchFileNm"    );
			var sFileEncryptYn     = this.dsOutFileinfo.getColumn(i,"fileEncryptYn" );
			var sFileSaveStg       = this.dsOutFileinfo.getColumn(i,"fileSaveStg"   );
			
			this.divFileUpload.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sForntendFilename, sFileSeq, sDownloadUrl
													  ,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn );			
			
			//strLog += "[" + responseCustomValue + "] [" + sHandlerCode + "]  [" + sFileSn + "]  [" + sFileSeq + "]  [" + sBackendFilename + "]  [" + sForntendFilename+ "]  [" + sFileSize+"]\n";
	}
	   
};
this.btnUpload_FileSearch_callback = function()
{
	for (var i = 0; i < this.dsOutFileinfo.rowcount; i++) {
		        //trace("=== Sample : fnEventUploadComplete"+this.smfUploadInfoFileSn(jsonNew.responseCustomValue[i],0));	
				var responseCustomValue = "";
				var sDownloadUrl       = "";   // 
				var sHandlerCode       = "PA.SAM.PLE";  //this.smfUploadInfoFileSn(jsonWebFile.customValue[i],0);
				//var fileSn           = "476";  //this.smfUploadInfoFileSn(jsonWebFile.customValue[i],1);
				var sFileSn            = this.dsOutFileinfo.getColumn(i,"fileRefrnId"   );
				var sFileSeq           = this.dsOutFileinfo.getColumn(i,"fileId"        );
				var sFileSize          = this.dsOutFileinfo.getColumn(i,"atchFileMg"    );
				var sBackendFilename   = this.dsOutFileinfo.getColumn(i,"atchFileGuid"  );
				var sForntendFilename  = this.dsOutFileinfo.getColumn(i,"atchFileNm"    );
				var sFileEncryptYn     = this.dsOutFileinfo.getColumn(i,"fileEncryptYn" );
				var sPrivInfoFiltYn    = this.dsOutFileinfo.getColumn(i,"privInfoFiltYn");
				var sFileSaveStg       = this.dsOutFileinfo.getColumn(i,"fileSaveStg"   );
				var sFileInfSaveYn     = this.dsOutFileinfo.getColumn(i,"fileInfSaveYn" );
				
				this.divFileUpload.form.fnAddUploadedFile(sHandlerCode, sFileSn, sFileSize, sBackendFilename, sForntendFilename, sFileSeq, sDownloadUrl
				                                          ,sFileEncryptYn,sPrivInfoFiltYn,sFileSaveStg,sFileInfSaveYn );			
				
				//strLog += "[" + responseCustomValue + "] [" + sHandlerCode + "]  [" + sFileSn + "]  [" + sFileSeq + "]  [" + sBackendFilename + "]  [" + sForntendFilename+ "]  [" + sFileSize+"]\n";
		}
};

