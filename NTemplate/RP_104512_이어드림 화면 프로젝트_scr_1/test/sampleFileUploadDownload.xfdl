    <Script type="xscript5.1"><![CDATA[/**
*  파일업로드/다운로드 샘플
*  @MenuPath    Sample
*  @FileName 	sampleFileUploadDownload.xfdl
*  @Creator 	홍길동
*  @CreateDate 	2022.6.9
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.6.9     	홍길동 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
 this.sampleFileUploadDownload_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitForm(this);

	//=======================================
	// 업로드관련 초기설정을 한다.
	//=======================================
	// 업로드시 저장위치등을 판별할 정보 세팅(대문자 : 시스템코드(2)+"."+서브시스템코드(3)+"."+대분류코드(3))
	this.divFileUpload.UPLOAD_CreateComplete = this.fnEventUploadCreateComplete;  // 필요한 경우만 세팅
	this.divFileUpload.UPLOAD_UploadComplete = this.fnEventUploadComplete;        // 필요한 경우만 세팅(세팅권장)
	this.divFileUpload.UPLOAD_OnError        = this.fnEventUploadError;           // 필요한 경우만 세팅(세팅권장)
	this.divFileUpload.UPLOAD_AfterAddFile   = this.fnEventUploadAfterAddFile;     
	this.divFileUpload.UPLOAD_Form           = this;                              // 위의 함수가 존재하는 Form (보통은 this)
	
	//=======================================
	// 업로드관련 초기설정을 한다.
	//=======================================
	this.divFileUpload2.UPLOAD_CreateComplete = this.fnEventUploadCreateComplete2;  // 필요한 경우만 세팅
	this.divFileUpload2.UPLOAD_UploadComplete = this.fnEventUploadComplete2;        // 필요한 경우만 세팅(세팅권장)
	this.divFileUpload2.UPLOAD_OnError        = this.fnEventUploadError2;           // 필요한 경우만 세팅(세팅권장)
	this.divFileUpload2.UPLOAD_AfterAddFile   = this.fnEventUploadAfterAddFile2;     
	this.divFileUpload2.UPLOAD_BeforeOpenFile = this.fnEventUploadBeforeOpenFile2;     
	this.divFileUpload2.UPLOAD_Form           = this;                               // 위의 함수가 존재하는 Form (보통은 this)
	
	
	//=======================================
	// 다운로드관련 초기설정을 한다.
	//=======================================
	this.divFileDownload.UPLOAD_DownloadComplete = this.fnEventDownloadComplete;  // 필요한 경우만 세팅
	this.divFileDownload.UPLOAD_Form             = this;                          // 위의 함수가 존재하는 Form (보통은 this)
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

}

this.fnEventUploadCreateComplete = function(obj,paramObj)
{
	trace("=== Sample : fnEventUploadCreateComplete");
	
}

this.fnEventUploadComplete = function(obj,paramObj,objResultDataset)
{

	// 신규서비스
	trace("=== Sample : fnEventUploadComplete");	
	trace( "objResultDataset===========================\n" 
	     //+ objResultDataset.saveXML() 
		 + "\n==================================");
	
	// 업로드 성공 후, newfile에 있는 파일들을 webfile로 옮긴다.
	this.divFileUpload.form.fnSetUploadCompleteState(obj,paramObj);	
	
	// 업로드한 file을 가져오는 법(샘플 가이드)
	if(objResultDataset)
	{
		trace("====업로드한 결과 데이터셋 ========== \n"+objResultDataset.saveXML());
		
		var sFileRefrnId = objResultDataset.getColumn(0,"fileRefrnId");
		trace("업로드결과 데이터셋의 첫번째 row의 fileRefrnId=["+sFileRefrnId+"]");
		
		// 테스트를 위해 아래의 sFileRefrnId를 세팅
		if(!this.smfIsNull(sFileRefrnId))
		{
			this.edtFileRefrnId.set_value(sFileRefrnId)
		}		
	}
	return;
/*	
	// 업로드한 파일들의 정보를 가져옴.
	var listInfo = obj.GetListInfo("json")	    // 전송완료 후 새롭게 업로드 된 파일, 웹파일, 삭제된 파일 리스트 정보를 리턴해 주는 함수 입니다. ('array', 'json', 'xml', 'text')
	var jsonNew     = listInfo.newFile;			// 새로 업로드된 파일 정보
    var jsonDel     = listInfo.deleteFile;		// 삭제된 파일 정보
    var jsonWebFile = listInfo.webFile;			// 웹파일 정보(이미 업로드 된 파일을 추가한 경우(AddUploadedFile()로 추가한 것- 업로드 대상에서 제외))
	var jsonMerge   = listInfo.mergeFile;		// 신규추가된 파일과 웹파일을 함께 볼수 있는 정보
	
	var strLog = "...업로드완료\n";
	//========================================================
	// 업로드 된 데이터를 웹파일로 변경하는 코딩 예
	//========================================================
	// 기존에 추가되어 있는 webFile을 다시 추가하기 위한 로직.
	// 업로드를 초기화
	this.divFileUpload.form.fnResetUpload();
	
	if (jsonWebFile) {
		var jsonWebFileLength = jsonWebFile.uploadPath.length;

		strLog += " =====  기존웹파일 리스트 ===== 갯수 : "+jsonWebFileLength + "\n";
		for (var i = 0; i < jsonWebFileLength; i++) {
			var sCustomValue = jsonNew.customValue[i];
			var handlerCode      = this.smfUploadInfoFileSn(sCustomValue,0);
			var fileSn           = this.smfUploadInfoFileSn(sCustomValue,1);
			var fileSize         = jsonWebFile.size[i];
			var backendFilename  = jsonWebFile.uniqKey[i];
			var forntendFilename = jsonWebFile.originalName[i];
			
			this.divFileUpload.form.fnAddUploadedFile(handlerCode, fileSn, fileSize, backendFilename, forntendFilename);			
			
			strLog += "[" + handlerCode + "]  [" + fileSn + "]  [" + backendFilename + "]  [" + forntendFilename+ "]  [" + fileSize+"]\n";
		}
	}

	// 새로 업로드된 파일을 webFile로 새롭게 추가하기 위한 로직
	if (jsonNew) {
		var jsonNewLength = jsonNew.uploadPath.length;

		strLog += " =====  신규업로드파일 리스트 ===== 갯수 : "+jsonNewLength + "\n";
		for (var i = 0; i < jsonNewLength; i++) {
		        trace("=== Sample : fnEventUploadComplete"+this.smfUploadInfoFileSn(jsonNew.customValue[i],0));	
				var responseCustomValue = jsonNew.customValue[i];
				var handlerCode         = this.smfUploadInfoFileSn(responseCustomValue,0);
				var fileSn              = this.smfUploadInfoFileSn(responseCustomValue,1);
				var fileSize            = jsonNew.size[i];
				var backendFilename     = jsonNew.uploadName[i];
				var forntendFilename    = jsonNew.originalName[i];
				this.divFileUpload.form.fnAddUploadedFile(handlerCode, fileSn, fileSize, backendFilename, forntendFilename);			
				
				strLog += "[" + responseCustomValue + "] [" + handlerCode + "]  [" + fileSn + "]  [" + backendFilename + "]  [" + forntendFilename+ "]  [" + fileSize+"]\n";
		}
	}
	
	this.txtLog.set_value(strLog);
*/	
}

this.fnEventUploadError = function(obj,paramObj)
{
	trace("=== Sample : fnEventUploadError - " + JSON.stringify(paramObj));	
	
}

