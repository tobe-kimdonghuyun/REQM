        <Button id="btnUpload_SelectedDownload" taborder="14" text="선택된 파일 다운로드" left="172" top="522" width="138" height="28" onclick="btnUpload_SelectedDownload_onclick"/>
        <Button id="btnUpload2" taborder="15" text="파일 Upload" left="37" top="775" width="138" height="28" onclick="btnUpload2_onclick"/>
        <Static id="sta00_00" taborder="17" text="* Raon의 자체 property등을 추가하려면 div에 &#13;&#10;   userproperty(addProp)에 설정할 정보를 JSON으로&#13;&#10;   리턴할 함수명(샘플에서는 fnSetRaonProp)을 지정한다. " left="37" top="654" width="423" height="80"/>
        <Radio id="rdo00" taborder="18" left="148" top="174" width="352" height="30" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" columncount="-1" value="SV" text="공유폴더" index="0" rowcount="-1" onitemchanged="rdo00_onitemchanged">
          <Dataset id="innerdataset">
