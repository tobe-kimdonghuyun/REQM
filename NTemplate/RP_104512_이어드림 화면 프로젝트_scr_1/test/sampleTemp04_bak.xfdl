 * this.fnAdd 
 * @param : scope
 */
this.fnAdd = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var isMobile = this.smfIsMobile(true);

	//this.smfIsMobile() 모바일 체크 공통 함수
	if( isMobile )
	{
		this.smfDataAppend(this,this.grd01,this.ds_M);
		//divWork 부모 늘리기
		this._smfFrameResetScroll(parentH);	
