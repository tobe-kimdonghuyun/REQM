<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sampleSBChart" width="1280" height="745" titletext="SBChart샘플">
    <Layouts>
      <Layout height="745" width="1280">
        <Static id="sta00" taborder="0" text="SBChart사용 샘플" left="10" top="15" width="310" height="40"/>
        <Div id="div00" taborder="1" text="div00" left="24" top="126" width="816" height="354" url="comm::comp_chart.xfdl"/>
        <Button id="btn00" taborder="2" text="Chart 그리기" left="20" top="64" width="191" height="38" onclick="btn00_onclick"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
