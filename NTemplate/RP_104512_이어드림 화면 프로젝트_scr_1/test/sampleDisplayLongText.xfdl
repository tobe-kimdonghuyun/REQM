<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sampleDisplayLongText" width="1280" height="745" titletext="New Form" onload="sampleDisplayLongText_onload">
    <Layouts>
      <Layout height="745" mobileorientation="landscape" width="1280">
        <Static id="sta00" taborder="0" text="긴 문장에 ...을 붙이는 샘플" left="23" top="15" width="530" height="41"/>
        <Edit id="edt00" taborder="1" left="145" top="112" width="195" height="28"/>
        <Static id="sta01" taborder="2" text="sta01" left="149" top="161" width="195" height="28"/>
        <Button id="btn00" taborder="3" text="공통함수호출" left="58" top="66" width="144" height="32" onclick="btn00_onclick"/>
        <Grid id="grd00" taborder="4" left="59" top="279" width="511" height="298" binddataset="dsTest" onsize="grd00_onsize" oncolresized="grd00_oncolresized" autofittype="col">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="317"/>
                <Column size="67"/>
              </Columns>
              <Rows>
                <Row size="24" band="head"/>
                <Row size="24"/>
              </Rows>
              <Band id="head">
                <Cell text="DispText"/>
                <Cell col="1" text="OriginalText"/>
              </Band>
              <Band id="body">
                <Cell expr="expr:comp.parent.smfDispLongTextGrid(comp,0,currow,longTextCol)"/>
                <Cell col="1" text="bind:longTextCol"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Static id="sta02" taborder="5" text="Grid 적용 : expr참조" left="60" top="219" width="190" height="60"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
