this.btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sTextOrg = "123456789 123456789 123456789 123456789 123456789 12345";
	
	var sDispText =  this.smfDispLongText(this.edt00,sTextOrg);
	this.edt00.set_value(sDispText);
	
	var sDispText1 =  this.smfDispLongText(this.sta01,sTextOrg);
	this.sta01.set_text(sDispText1);
};
]]></Script>
    <Objects>
      <Dataset id="dsTest">
        <ColumnInfo>
          <Column id="longTextCol" type="STRING" size="256" description="메뉴명"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="longTextCol">123456789012345678901234567890123456789012345678901234567890</Col>
          </Row>
          <Row>
            <Col id="longTextCol">123456789012345678901234567890123456789012345678901234567890</Col>
