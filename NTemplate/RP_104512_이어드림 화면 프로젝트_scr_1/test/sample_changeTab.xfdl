<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sample_changeTab" width="1280" height="720" titletext="탭을 변경시 수정된 데이터를 처리하는 예제" onload="fnOnload" border="1px solid" onbeforeclose="sample_gridSave_onbeforeclose">
    <Layouts>
      <Layout height="720" width="1280">
        <Tab id="tab00" taborder="0" tabindex="0" left="25" top="99" width="700" height="141" canchange="tab00_canchange">
          <Tabpages>
            <Tabpage id="Tabpage1" text="Tabpage1">
              <Layouts>
                <Layout>
                  <Static id="sta_02_00" taborder="0" text="성명" left="18" top="16" cssclass="sta_WF_tablelabel" width="45" height="34"/>
                  <Edit id="edtName" taborder="1" text="-선택-" left="72" top="17" height="34" leftbase="" topbase="" bottombase="" rightbase="" widthbase="" heightbase="" innerdataset="@ds_dep" codecolumn="code" datacolumn="data" scrollbarbarminsize="20" value="" index="-1" scrollbarbaroutsize="20" scrollbarsize="10" scrollbartrackbarsize="25" itemheight="20" width="243"/>
                </Layout>
              </Layouts>
            </Tabpage>
            <Tabpage id="Tabpage2" text="Tabpage2">
              <Layouts>
                <Layout>
                  <Edit id="edtName" taborder="0" text="-선택-" left="72" top="17" height="34" leftbase="" topbase="" bottombase="" rightbase="" widthbase="" heightbase="" innerdataset="@ds_dep" codecolumn="code" datacolumn="data" scrollbarbarminsize="20" value="" index="-1" scrollbarbaroutsize="20" scrollbarsize="10" scrollbartrackbarsize="25" itemheight="20" width="243"/>
                  <Static id="sta_02_00" taborder="1" text="성명" left="18" top="16" cssclass="sta_WF_tablelabel" width="45" height="34"/>
                </Layout>
              </Layouts>
            </Tabpage>
          </Tabpages>
        </Tab>
        <Static id="sta00_01_00" taborder="1" text="데이터가 변경이 일어나면 탭을 이동할때 Confirm을 발생시킨다" left="20" top="64" width="600" height="30" cssclass="sta_WF_Tit18"/>
        <Tab id="tab00_00" taborder="2" tabindex="0" left="25" top="559" width="700" height="141" canchange="tab00_00_canchange">
          <Tabpages>
            <Tabpage id="Tabpage1" text="Tabpage1">
              <Layouts>
                <Layout>
                  <Static id="sta_02_00" taborder="0" text="성명" left="18" top="16" cssclass="sta_WF_tablelabel" width="45" height="34"/>
                  <Edit id="edtName" taborder="1" text="-선택-" left="72" top="17" height="34" leftbase="" topbase="" bottombase="" rightbase="" widthbase="" heightbase="" innerdataset="@ds_dep" codecolumn="code" datacolumn="data" scrollbarbarminsize="20" value="" index="-1" scrollbarbaroutsize="20" scrollbarsize="10" scrollbartrackbarsize="25" itemheight="20" width="243"/>
                </Layout>
              </Layouts>
            </Tabpage>
            <Tabpage id="Tabpage2" text="Tabpage2">
              <Layouts>
                <Layout>
                  <Edit id="edtName" taborder="0" text="-선택-" left="72" top="17" height="34" leftbase="" topbase="" bottombase="" rightbase="" widthbase="" heightbase="" innerdataset="@ds_dep" codecolumn="code" datacolumn="data" scrollbarbarminsize="20" value="" index="-1" scrollbarbaroutsize="20" scrollbarsize="10" scrollbartrackbarsize="25" itemheight="20" width="243"/>
                  <Static id="sta_02_00" taborder="1" text="성명" left="18" top="16" cssclass="sta_WF_tablelabel" width="45" height="34"/>
                </Layout>
              </Layouts>
            </Tabpage>
          </Tabpages>
        </Tab>
        <Static id="sta00_01_00_00" taborder="3" text="데이터가 변경이 일어나면 탭을 이동할때 Tab을 변경하지 못한다" left="20" top="524" width="650" height="30" cssclass="sta_WF_Tit18"/>
        <Tab id="tab00_01" taborder="4" tabindex="0" left="25" top="309" width="700" height="141" canchange="tab00_01_canchange">
          <Tabpages>
            <Tabpage id="Tabpage1" text="Tabpage1">
              <Layouts>
                <Layout>
                  <Static id="sta_02_00" taborder="0" text="성명" left="18" top="16" cssclass="sta_WF_tablelabel" width="45" height="34"/>
                  <Edit id="edtName" taborder="1" text="-선택-" left="72" top="17" height="34" leftbase="" topbase="" bottombase="" rightbase="" widthbase="" heightbase="" innerdataset="@ds_dep" codecolumn="code" datacolumn="data" scrollbarbarminsize="20" value="" index="-1" scrollbarbaroutsize="20" scrollbarsize="10" scrollbartrackbarsize="25" itemheight="20" width="243"/>
                </Layout>
              </Layouts>
            </Tabpage>
            <Tabpage id="Tabpage2" text="Tabpage2">
              <Layouts>
                <Layout>
                  <Edit id="edtName" taborder="0" text="-선택-" left="72" top="17" height="34" leftbase="" topbase="" bottombase="" rightbase="" widthbase="" heightbase="" innerdataset="@ds_dep" codecolumn="code" datacolumn="data" scrollbarbarminsize="20" value="" index="-1" scrollbarbaroutsize="20" scrollbarsize="10" scrollbartrackbarsize="25" itemheight="20" width="243"/>
                  <Static id="sta_02_00" taborder="1" text="성명" left="18" top="16" cssclass="sta_WF_tablelabel" width="45" height="34"/>
                </Layout>
              </Layouts>
            </Tabpage>
          </Tabpages>
        </Tab>
        <Static id="sta00_01_00_01" taborder="5" text="데이터가 변경이 일어나면 탭을 이동할때 Confirm하며, 취소시 데이터의 원복한다" left="20" top="274" width="670" height="30" cssclass="sta_WF_Tit18"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsService" useclientlayout="false" updatecontrol="true" enableevent="true" loadkeymode="keep" loadfiltermode="keep" reversesubsum="false">
        <ColumnInfo>
          <Column id="id" type="STRING" size="256"/>
          <Column id="url" type="STRING" size="256"/>
          <Column id="inDatasets" type="STRING" size="256" sumtext="파라메터가 될 Dataset list(공백으로 구분)"/>
          <Column id="outDatasets" type="STRING" size="256" sumtext="받아올 Dataset list(공백으로 구분)"/>
          <Column id="asynctp" type="STRING" size="256" sumtext="동기/비동기 설정(Default:true)"/>
        </ColumnInfo>
      </Dataset>
      <Dataset id="dsSearch" oncolumnchanged="dsSearch_oncolumnchanged">
        <ColumnInfo>
          <Column id="name" type="STRING" size="150"/>
          <Column id="genreCode" type="STRING" size="1"/>
          <Column id="artist" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="name"/>
            <Col id="genreCode"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSearch00" oncolumnchanged="dsSearch_oncolumnchanged">
        <ColumnInfo>
          <Column id="name" type="STRING" size="150"/>
          <Column id="genreCode" type="STRING" size="1"/>
          <Column id="artist" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="name"/>
            <Col id="genreCode"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsMain" oncolumnchanged="dsSearch_oncolumnchanged">
        <ColumnInfo>
          <Column id="name" type="STRING" size="150"/>
          <Column id="genreCode" type="STRING" size="1"/>
          <Column id="artist" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="name"/>
            <Col id="genreCode"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsMain2" oncolumnchanged="dsSearch_oncolumnchanged">
        <ColumnInfo>
          <Column id="name" type="STRING" size="150"/>
          <Column id="genreCode" type="STRING" size="1"/>
          <Column id="artist" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="name"/>
            <Col id="genreCode"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSub" oncolumnchanged="dsSearch_oncolumnchanged">
        <ColumnInfo>
          <Column id="name" type="STRING" size="150"/>
          <Column id="genreCode" type="STRING" size="1"/>
          <Column id="artist" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="name"/>
            <Col id="genreCode"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSub2" oncolumnchanged="dsSearch_oncolumnchanged">
        <ColumnInfo>
          <Column id="name" type="STRING" size="150"/>
          <Column id="genreCode" type="STRING" size="1"/>
          <Column id="artist" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="name"/>
            <Col id="genreCode"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSub3" oncolumnchanged="dsSearch_oncolumnchanged">
        <ColumnInfo>
          <Column id="name" type="STRING" size="150"/>
          <Column id="genreCode" type="STRING" size="1"/>
          <Column id="artist" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="name"/>
            <Col id="genreCode"/>
          </Row>
        </Rows>
      </Dataset>
      <Dataset id="dsSub4" oncolumnchanged="dsSearch_oncolumnchanged">
        <ColumnInfo>
          <Column id="name" type="STRING" size="150"/>
          <Column id="genreCode" type="STRING" size="1"/>
          <Column id="artist" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="name"/>
            <Col id="genreCode"/>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};

// 폼 로드
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitForm(obj);
	
	
	
	this.dsMain.setColumn(0, "name", "탭을 이동해보세요");
	
	this.dsSub.setColumn(0, "name", "탭을 이동해보세요");
	
	this.dsSub3.setColumn(0, "name", "탭을 이동해보세요");
};

// 폼 닫기전 이벤트
this.sample_gridSave_onbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	// 변경내역이 발생한 경우 종료전 confirm수행
	return this.smfCloseFormConfirm([this.dsMain, this.dsMain, 
	                                 this.dsSub, this.dsSub2, 
	                                 this.dsSub3, this.dsSub4]);
};

this.tab00_canchange = function(obj:nexacro.Tab,e:nexacro.TabIndexChangeEventInfo)
{
	// Tab에 변경이 일어나면 Confirm을 발생시킨다
	if(obj.tabindex == 0){
		var canChange = this.smfChangingTabConfirm(obj, e, [this.dsMain]);
		
		// 필요시 dsMain을 초기화해야 한다
		
		return canChange;
	}else if(obj.tabindex == 1){
		var canChange = this.smfChangingTabConfirm(obj, e, this.dsMain2, "탭변경?");
		return canChange;
	}
}; 

// Tab에 변경이 일어나면 Confirm하며, 취소시 데이터의 원복한다
this.tab00_01_canchange = function(obj:nexacro.Tab,e:nexacro.TabIndexChangeEventInfo)
{
	// Tab에 변경이 일어나면 Confirm하며, 취소시 데이터의 원복한다
	if(obj.tabindex == 0){
		// 4번째 파라메터를 전달하지 않으면
		// 3번째 파라메터가 원복 대상이 된다
		return this.smfChangingTabConfirmWithResetDatas(obj, e, [this.dsSub3]);
	}else if(obj.tabindex == 1){
		// 4번째 파라메터는 원복할 데이터셋 array
		return this.smfChangingTabConfirmWithResetDatas(obj, e, [this.dsSub4], [this.dsSub3, this.dsSub4]);
	}
};



this.tab00_00_canchange = function(obj:nexacro.Tab,e:nexacro.TabIndexChangeEventInfo)
{
	// Tab에 변경이 일어나면 Tab을 변경하지 못한다
	if(obj.tabindex == 0){
		return this.smfDoNotChangeTabNotice(obj, e, this.dsSub);
	}else if(obj.tabindex == 1){
		return this.smfDoNotChangeTabNotice(obj, e, this.dsSub2);
	}	
};

var prForm = this;




]]></Script>
    <Bind>
      <BindItem id="item0" compid="tab00.Tabpage1.form.edtName" propid="value" datasetid="dsMain" columnid="name"/>
      <BindItem id="item1" compid="tab00.Tabpage2.form.edtName" propid="value" datasetid="dsMain2" columnid="name"/>
      <BindItem id="item2" compid="tab00_00.Tabpage1.form.edtName" propid="value" datasetid="dsSub" columnid="name"/>
      <BindItem id="item3" compid="tab00_00.Tabpage2.form.edtName" propid="value" datasetid="dsSub2" columnid="name"/>
      <BindItem id="item4" compid="tab00_01.Tabpage1.form.edtName" propid="value" datasetid="dsSub3" columnid="name"/>
      <BindItem id="item5" compid="tab00_01.Tabpage2.form.edtName" propid="value" datasetid="dsSub4" columnid="name"/>
    </Bind>
  </Form>
</FDL>
