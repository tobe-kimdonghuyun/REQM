      <BindItem id="item12" compid="divMain.form.mskListenCnt" propid="value" datasetid="dsMain" columnid="listenCnt"/>
      <BindItem id="item4" compid="divMain.form.cboTypeCode" propid="value" datasetid="dsMain" columnid="typeCode"/>
