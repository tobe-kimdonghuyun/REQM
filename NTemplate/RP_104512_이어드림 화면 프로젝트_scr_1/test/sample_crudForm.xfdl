    </Objects>
    <Script type="xscript5.1"><![CDATA[
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};

// 폼 로드
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);

	// 화면초기화 서비스 호출
	this.smfValidateService("validateMain", { 
			url: "/cmc_sam_pl10_100.do",
		})
		.mappingRulesetToForm(this.divSearch, "search")
		.mappingRulesetToForm(this.divMain, "save")
		.run()
		.callback(function(callbackParams){
		})
	;
	
	this.smfSetFirstCode(this.dsGenreScCd);
	this.smfSetFirstCode(this.dsTypeCode); 
	this.smfSetFirstCode(this.dsGrade); 
	
	
	
	this.smfSetEnable(this.btnDelete, false);	
	
};

// 그리드 체크박스 enable 처리
this.fnRenderGridCheckbox = function(ds, nRow){
	// 아이유는 삭제 못함
    return this.dsMain.getColumn(nRow, "artist") != "아이유";
};



// 조회 버튼 클릭
this.div_search_btn_search_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 서비스 객체 생성
	this.smfSearchService("select")
		// 데이터 검증
		.validateForm(this.divSearch)

		// 데이터가 변경되었으면 확인메시지
		.confirmIfModifiedDataset(this.dsMain)
	
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			

			this.smfSetEnable(this.btnDelete, true);
			if(this.dsMain.rowcount == 0){
				this.btnDelete.set_enable(false);
				this.smfLiteralAlert("해당 가수를 찾을 수 없습니다");
			}
		})
		

	;
	
	
};

// 버튼 추가 이벤트
this.btn_add_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 데이터 클리어
	this.dsMain.clearData();
	// row추가
	this.dsMain.addRow();	
	// 컬럼 초기화
	this.smfInitRow(this.dsMain, 0); 
	
	
	// id항목 disable
	this.divMain.form.edtId.set_enable(false);
	this.btnDelete.set_enable(false);
};


// 저장버튼 클릭 
this.btn_save_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 서비스 객체 생성 
	this.smfSaveService("save")
		// 데이터 존재 필수
		.requireExistsData(this.dsMain) 
		// 데이터 검증
		.validateForm(this.divMain)
		// 데이터 변경 필수
		.requireModifredData(this.dsMain) 
 
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;

			// 저장이 완료되었습니다.
			// 재조회
			this.smfAlert('CM002', [],  function(){
				// 조회 수행
				this.divSearch.form.btnSearch.click();
			});
		});
};

// 삭제 버튼 클릭
this.btn_delete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 삭제처리
	this.smfDeleteService("delete")
		// 데이터 존재 필수
		.requireExistsData(this.dsMain) 
		// 삭제를 위한 검증수행
		.validateFormDelete(this.divMain)
		.run()
		// 콜백
		.callback(function(callbackParams){ 
			if(callbackParams.errors) return;
			var alerter = this.smfAlerter();
			alerter.message = this.smfAfterServiceMessage();
			alerter.onOk = function(){
				this.dsMain.clearData();
				alert('[참고] 본 샘플에서 데이터 삭제는 서버에서 동작하지 않도록 처리하였습니다');
				
				// 조회 수행
				this.divSearch.form.btnSearch.click();
			};
			alerter.run();
		})
		;
};
 

// 폼 닫기전 이벤트
this.sample_gridSave_onbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	// 변경내역이 발생한 경우 종료전 confirm수행
	return this.smfCloseFormConfirm(this.dsMain);
};

// 조회조건이 변경된 경우
this.dsSearch_oncolumnchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo){

};

this.divSearch_sta00_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	this.divSearch.form.edtId.set_value( obj.text );
};

this.divMain_btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfRequired(this.divMain.form.edtName, true);
};

this.divMain_btn00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfRequired(this.divMain.form.edtName, false);
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.edtId" propid="value" datasetid="dsSearch" columnid="id"/>
      <BindItem id="item3" compid="divMain.form.edtId" propid="value" datasetid="dsMain" columnid="id"/>
      <BindItem id="item1" compid="divMain.form.edtName" propid="value" datasetid="dsMain" columnid="name"/>
