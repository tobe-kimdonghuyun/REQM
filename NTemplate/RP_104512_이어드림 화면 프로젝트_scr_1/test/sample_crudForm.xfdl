<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sample_crudForm" width="1280" height="720" titletext="그리드 저장" onload="fnOnload" border="1px solid" onbeforeclose="sample_gridSave_onbeforeclose">
    <Layouts>
      <Layout height="720" width="1280">
