    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    더보기 Div 샘플 
*  @FileName 	sampleTemp07.xfdl
*  @Creator 	투비소프트
*  @CreateDate 	2022.06.22
*  @Desction    모바일 폴더 더보기
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.06.22     	투비소프트 	               최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::cm_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

this.DivInfo = {};     // Q & A 항목 정보 
this.fvMinHeight = nexacro.getEnvironmentVariable("ev_isMobile") == "Y"?90:70; // 디폴트 높이
this.fv_DIV_MARGIN = 0;
this.fv_staticLeft = [30,20];
this.fv_MstaticRight   = [100,20];
this.fv_staticRight   = [100,20];
//top, right, bottom, left	
this.fv_QstaticPadding = [23,0,23,29];
this.fv_AstaticPadding = [27,0,27,29];

this.fv_mQstaticPadding = [25,0,25,50];
this.fv_mAstaticPadding = [67,0,67,50];


this.fv_prefixIdTitleDiv = "divTitle";
this.fv_prefixIdTitleStatic = "staTitle";
this.fv_prefixIdTitleButton = "btnArrow";

this.fv_prefixIdContentsDiv = "divContents";
this.fv_prefixIdContentsStatic = "staContents";

this.sampleTemp07_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	//this.fnInitDiv(this.div03.form);
};

/**
 * Div 안 버튼 생성
 * @param : scope ( Div.form)
 * @param : divInfo 
 */
this.fnCreateArrow = function(scope,sChildId,bLast)
{
	var sBtnId = this.fv_prefixIdTitleButton;
	var sDivArrow = "btn_WF_FAQDrop";
	// 버튼을 생성
	// Create Object  
	var objButton = scope[sBtnId];
	if(!objButton)
	{
		objButton = new Button(); 
		//objButton.init(pJson.id, null, 14, 40, 40, 20, null);
		objButton.init(sBtnId, null, 0, 80, null, 0, 0);
		
		// 만들어진 Button을 Div에 추가
		scope.addChild(sBtnId, objButton);
		
		// 버튼의 속성을 설정
		objButton.set_initvalueid("ivBtnAccessibilityExpand");	
		objButton.childId = sChildId;
		objButton.islasted = bLast;
		objButton.dirArrow = sDivArrow;
		
		// Button에 클릭이벤트 추가
		var sStaticId = this.fv_prefixIdTitleStatic;
		objButton.addEventHandler("onclick",function(obj,e){
			//scope[pJson.id].onclick;
			
			this.fnReDraw(scope.parent.parent,scope[sStaticId],e);
		},this);
		
		// Button을 보이게 설정(addChild()하면 반드시 show()를 해주어야 실제로 화면에 보임)  
		objButton.show();  
	}
	objButton.set_cssclass("btn_WF_FAQDrop");
};

/**
 * 생성 컴포넌트 재 설정 및 reDraw 함
 * @param : obj - Static
 * @param : e   - Static eventInfo
 */
this.fnReDraw = function(scope,obj,e)
{
	//obj.status = "Collapse"; //Expand
	for(var i=0;i < scope.components.length;i++)
	{	
		if(scope.components[i] instanceof nexacro.Div )
		{
			if ( scope.components[i].form[this.fv_prefixIdTitleButton] )
			{
				scope.components[i].form[this.fv_prefixIdTitleButton].set_cssclass("btn_WF_FAQDrop");
			}

			// contentsDiv이면
			//if( nexacro.toNumber(scope.components[i].id.substr(2,1)) % 2 == 0 )
			if(scope.components[i].id.substr(0,this.fv_prefixIdContentsDiv.length) == this.fv_prefixIdContentsDiv)
			{
				scope.components[i].setOffsetHeight(0);
				scope.components[i].set_visible(false);			
			}
			
			if ( scope.components[i].islasted )
			{
				scope.components[i].set_cssclass("div_WF_FAQBox_Q03");
				/*
				if (i%2 == 0 )
				{
					if( obj instanceof nexacro.Static )
					{
						//obj.set_cssclass("sta_WF_FAQ_A");
					}else if ( obj instanceof nexacro.Button )
					{
						obj.parent.form[obj.id].set_cssclass("btn_WF_FAQDrop");
					}
				}
				*/
			}
		}
	}
	
	if( obj instanceof nexacro.Static )
	{
		if( !this.smfIsNull(obj.childId))
		{

			var objTitleDiv = obj.parent.parent;
			var objTitleButton = objTitleDiv.form[this.fv_prefixIdTitleButton];
			var objContentsDiv = scope[objTitleDiv.childId];
			var objContentStatic = objContentsDiv.form[this.fv_prefixIdContentsStatic];
			
			var expandtextHeight = this.fnGetContentsHeight(scope,objContentStatic);	
			
			objContentsDiv.setOffsetHeight(expandtextHeight);
			
			objTitleButton.set_cssclass("btn_WF_FAQDropup");


			// 최종 영역 라운드 처리를 위한 오브젝트를 정리
			
			// 마지막 Question인 경우 라운드 처리를 없앤다(아래에 Contents기 있으므로)
			if ( objTitleDiv.islasted )
			{
				var objTitleDiv = obj.parent.parent;
				objTitleDiv.set_cssclass("div_WF_FAQBox_Q02");
				objContentsDiv.set_cssclass("div_WF_FAQBoxEnd_A01");
			}
			
			// 혹시 Contents가 없으면 divContents를 안보이게 한다.
			if ( objContentStatic.text != null ) 
			{
				objContentsDiv.set_visible(true);
			}else
			{
				objContentsDiv.set_visible(false);
			}
		}		
	}

	this.smfResetScroll(scope);
	//this.smfResetScroll(this.div03.form);
};

/**
 * 더보기
 * @param : obj
 * @param : e
 */
this.fnSearch = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
}

/**
 * 하나의 FAQ를 추가한다.
 * @param : {object}   scope  대상Form
 * @param : {object}   objDs  추가할 데이터셋
 * @param : {Number}   nRow   추가할 데이터셋의 row
 * @param : {boolean}  bLast  마지막여부(true/false)
 */
this.fnAppendDiv = function(scope,objDs,nRow,bLast)
{
	// 추가될 index를 구한다.
	// (기본적으로는 부모 Div에 있는 _count 유저프로퍼티 사용. 없으면 0으로 초기화)
	var nIdx = 0;
	if(this.smfIsNull(scope.parent._count))
	{  // 세팅이 안되어 있으면 0으로 세팅
		nIdx = 0;
		scope.parent._count = 0;
	}
	else
	{
		nIdx = scope.parent._count;
	}
	
	// 타이틀 Div 만들기
	var objTitleDiv = this.fnAddTitleDiv(scope,nIdx,objDs,nRow,bLast);
	// 상세 Div만들기
	var objContentsDiv = this.fnAddContentsDiv(scope,nIdx,objDs,nRow,bLast);
	
	// 카운트 갯수를 증가시킨다.
	scope.parent._count++;
}

/**
 * FAQDiv를 삭제한다(비활성화)
 * @param : {object}   scope  대상Form
 * @param : {boolean}  bRefresh  삭제 후 resetScroll을 실행할 지 여부(여러번 사용시 최후에만 사용하려고...)
 */
this.fnClearAllDiv = function(scope,bRefresh)
{
	var nCount = scope.parent._count;
	for(var i=0;i<nCount;i++)
	{
		var objTitleDiv       = scope[this.fv_prefixIdTitleDiv+i];
		var objTitleButton    = objTitleDiv.form[this.fv_prefixIdTitleButton];
		var objTitleStatic    = objTitleDiv.form[this.fv_prefixIdTitleStatic];
		
		var objContentsDiv    = scope[this.fv_prefixIdContentsDiv+i];
		var objContentsStatic = objContentsDiv.form[this.fv_prefixIdContentsStatic];
		
		// 대상 DIV를 안보이게 한다.
		objTitleDiv.set_visible(false);
		objContentsDiv.set_visible(false);
		
		// 데이터를 클리어한다.
		objTitleStatic.set_text("");
		objContentsStatic.set_text("");
		
		// cssclass를 초기화한다
		objTitleButton.set_cssclass("btn_WF_FAQDrop");
		objTitleDiv.set_cssclass("div_WF_FAQBox_Q02");
		objContentsDiv.set_cssclass("div_WF_FAQBox_A01");		
		
		// 맨마지막 DIV인지를 초기화한다.
		objTitleDiv.isLasted = false;
		
	}
	
	// 카운트숫자를 초기화한다.
	scope.parent._count = 0;
	
	if(bRefresh)
	{
		this.smfResetScroll(scope);
	}
}

/**
 * TitleDiv를 추가한다.
 * @param : {object}   scope  대상Form
 * @param : {Number}   nIdx   추가할 div Index
 * @param : {object}   objDs  추가할 데이터셋
 * @param : {Number}   nRow   추가할 데이터셋의 row
 * @param : {boolean}  bLast  마지막여부(true/false)
 */
this.fnAddTitleDiv = function (scope,nIdx,objDs,nRow,bLast)
{
	var sDivId = this.fv_prefixIdTitleDiv + nIdx;
	var sText = objDs.getColumn(nRow,"sTit");
	/*
    this.DivInfo = {}; //초기화

	Id = this.dsComment.getColumn(1,"sId");
	befId = this.dsComment.getColumn(0,"sId");
	
	this.DivInfo.id = Id; // key
	this.DivInfo.nHeight = this.fvMinHeight;
	this.DivInfo.cssclass = "div_WF_FAQBox_A01"; //
	this.DivInfo.visible = false;
	this.DivInfo.bef = befId;
	this.DivInfo.childId = "";
	this.DivInfo.dirArrow = "btn_WF_FAQDrop";
	
	//this.fnCreateDiv(scope,this.DivInfo);
	//default - 높이가 세팅되어 있지 않으면 디폴트값(this.fvMinHeight)을 설정
	if( !pJson.nHeight ) pJson.nHeight = this.fvMinHeight;
	*/
	//===================================================================
	// Div 생성
	//===================================================================
	var nHeight = this.fvMinHeight;
	var sBeforeContentsId = "divContents"+(nIdx-1);
	var sChildId = "divContents"+nIdx;
	var sDivCssClass = "div_WF_FAQBox_Q01";	
	var sDivArrow = "btn_WF_FAQDrop";
	
	if(nIdx==0)
	{
		sDivCssClass = "div_WF_FAQBox_Q01";	
	}
	else if(bLast)
	{
		sDivCssClass = "div_WF_FAQBox_Q03";	
	}
	else
	{
		sDivCssClass = "div_WF_FAQBox_Q02";	
	}
	
	var objDiv = scope[sDivId];
	
	if(!objDiv)
	{
		objDiv = new Div();
		if( nIdx==0 )
		{	// 최초의 오브젝트는 위의 Div의 Top을 0으로 한다
			objDiv.init(sDivId, 0, 0, null, nHeight, 0, null);	
		}else
		{   // 최초 Div이외의 것은 바로위의 오브젝트 바로아래에 생성한다. 
			objDiv.init(sDivId, 0, sBeforeContentsId +":"+ 0, null, nHeight, 0, null);
			//objDiv.init(sDivId, 0, (nIdx*nHeight), null, nHeight, 0, null);
		}

		// 만들어진 Div를 부모에 추가
		// Add Object to Parent Form  
		scope.addChild(sDivId, objDiv); 
		
		// Div의 속성을 세팅
		objDiv.set_cssclass(sDivCssClass);
		objDiv.set_initvalueid("ivDivAccessibilityOff");
		objDiv.childId = sChildId;
		objDiv.dirArrow = sDivArrow;
		
		// Div를 보이게 설정(addChild()하면 반드시 show()를 해주어야 실제로 화면에 보임)  
		objDiv.show(); 
	}
	objDiv.islasted = bLast;
	
	//===================================================================
	// 타이틀문장(Static) 생성
	//===================================================================
	// =======문장을 표시하는 Static을 생성
	var sStaticId = this.fv_prefixIdTitleStatic;
	var nLeft = this.smfIsMobile()?this.fv_staticLeft[1]:this.fv_staticLeft[0];  // 모바일인 경우 Left값이 다르므로 틀리게 세팅
	var nRight = this.smfIsMobile()?this.fv_MstaticRight[0]:this.fv_staticRight[0];

	// 질문영역(Question) 생성
	var objStatic = objDiv.form[sStaticId];
	if(!objStatic)
	{
		objStatic = new Static();  
		objStatic.init(sStaticId,nLeft, 0, null, null,nRight, 0);		
		
		// 만들어진 Static을 Div에 추가
		objDiv.form.addChild(sStaticId, objStatic); 
		
		// Static의 속성 설정
		//objStatic.set_accessibilityenable(true);	 
		objStatic.set_initvalueid("ivStcAccessibilityOn");
		
		objStatic.set_wordWrap("char");
		objStatic.set_verticalAlign("middle");	
		objStatic.set_cssclass("sta_WF_FAQ_Q");
		objStatic.islasted = bLast;
		objStatic.dirArrow = sDivArrow;
		objStatic.childId = sChildId;
		
		
		// Static에 클릭이벤트 추가
		objStatic.addEventHandler("onclick",function(obj,e){
										this.fnReDraw(scope,obj,e);
									}
									,this);
		
		// Static을 보이게 설정(addChild()하면 반드시 show()를 해주어야 실제로 화면에 보임)  
		objStatic.show();
	}
	objStatic.set_text(sText);
	
	// 글자길이(갯수)에 따라 표시할높이를 계산한다.
	var strFont = 'bold 14px/1.5 "NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic"';
	var strMFont = '24px/1.5 "NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic"';
	var Font = this.smfIsMobile()?strMFont:strFont;
	var nTextHeight = nexacro.getTextSize(objStatic.text,Font,objStatic.getOffsetWidth()-50,"char");
	
	
	// 
	var nWPadding = this.smfIsMobile()?( nexacro.toNumber(this.fv_mQstaticPadding[1]) + nexacro.toNumber(this.fv_mQstaticPadding[3]) ):
									   ( nexacro.toNumber(this.fv_QstaticPadding[1]) + nexacro.toNumber(this.fv_QstaticPadding[3]) );

	var nHPadding = this.smfIsMobile()?( nexacro.toNumber(this.fv_mQstaticPadding[0]) + nexacro.toNumber(this.fv_mQstaticPadding[2]) ):
									   ( nexacro.toNumber(this.fv_QstaticPadding[0]) + nexacro.toNumber(this.fv_QstaticPadding[2]) );

	nTextHeight = nexacro.getTextSize(objStatic.text,Font,objStatic.getOffsetWidth()-nWPadding,"char");	
	
	objDiv.setOffsetHeight(nTextHeight.ny+nHPadding);
	objDiv.set_visible(true);
	
	// 질문Div에 오측 화살표버튼을 추가한다.
	this.fnCreateArrow(objDiv.form,sChildId,bLast);	
}

/**
 * Contents Div를 추가한다.
 * @param : {object}   scope  대상Form
 * @param : {Number}   nIdx   추가할 div Index
 * @param : {object}   objDs  추가할 데이터셋
 * @param : {Number}   nRow   추가할 데이터셋의 row
 * @param : {boolean}  bLast  마지막여부(true/false)
 */
this.fnAddContentsDiv = function (scope,nIdx,objDs,nRow,bLast)
{
	var sDivId = this.fv_prefixIdContentsDiv + nIdx;
	var sText = objDs.getColumn(nRow,"sCon")
	
	//===================================================================
	// Div 생성
	//===================================================================
	var nHeight = this.fvMinHeight;
	var sBeforeContentsId = this.fv_prefixIdTitleDiv+nIdx;
	var sChildId = this.fv_prefixIdContentsDiv+nIdx;
	var sDivCssClass = "div_WF_FAQBox_A01";	
	var sDivArrow = "btn_WF_FAQDrop";

	// Create Object  
	var objDiv = scope[sDivId];
	if(!objDiv)
	{
		objDiv = new Div();
		objDiv.init(sDivId, 0, sBeforeContentsId +":"+ 0, null, nHeight, 0, null);

		// 만들어진 Div를 부모에 추가
		// Add Object to Parent Form  
		scope.addChild(sDivId, objDiv); 
		
		// Div의 속성을 세팅
		objDiv.set_cssclass(sDivCssClass);
		objDiv.set_initvalueid("ivDivAccessibilityOff");
		objDiv.childId = sChildId;
		objDiv.dirArrow = sDivArrow;
		
		// Div를 보이게 설정(addChild()하면 반드시 show()를 해주어야 실제로 화면에 보임)  
		objDiv.show(); 
	}
	
	objDiv.islasted = bLast;
	
	//===================================================================
	// Contents문장(Static) 생성
	//===================================================================
	var sStaticId = this.fv_prefixIdContentsStatic;
	var sStaticCssClass = "sta_WF_FAQ_A";

	// =======문장을 표시하는 Static을 생성
	var objStatic = objDiv.form[sStaticId];
	if(!objStatic)
	{
		objStatic = new Static();  
		var nLeft = this.smfIsMobile()?this.fv_staticLeft[1]:this.fv_staticLeft[0];  // 모바일인 경우 Left값이 다르므로 틀리게 세팅
		var nRight = this.smfIsMobile()?this.fv_MstaticRight[1]:this.fv_staticRight[1];	

		// 답변영역(Answer) 생성
		objStatic.init(sStaticId,nLeft, 0, null, null, nRight, 0);
		
		// 만들어진 Static을 Div에 추가
		objDiv.form.addChild(sStaticId, objStatic); 
		
		// Static의 속성 설정
		objStatic.set_initvalueid("ivStcAccessibilityOn");
		objStatic.set_wordWrap("char");
		objStatic.set_verticalAlign("middle");	
		objStatic.dirArrow = sDivArrow;	
		objStatic.childId = "";
		
		// Static을 보이게 설정(addChild()하면 반드시 show()를 해주어야 실제로 화면에 보임)  
		objStatic.show();
	}
	objStatic.set_cssclass(sStaticCssClass);	
	objStatic.set_text(sText);
	objStatic.islasted = bLast;
	
	// 글자길이(갯수)에 따라 표시할높이를 계산한다.
	var strFont = 'bold 14px/1.5 "NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic"';
	var strMFont = '24px/1.5 "NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic"';
	var Font = this.smfIsMobile()?strMFont:strFont;
	var nTextHeight = nexacro.getTextSize(objStatic.text,Font,objStatic.getOffsetWidth()-50,"char");
	
	// 답변(Answer)은 처음에는 안보이게 처리(높이를 0, visible=false)
	objDiv.setOffsetHeight(0);
	objDiv.set_visible(false);
	
}

this.fnGetContentsHeight = function(scope,objContentsStatic)
{
	var strFont = 'bold 14px/1.5 "NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic"';
	var strMFont = '24px/1.5 "NotoSansKR-Regular","Malgun Gothic","Arial","MS PGothic"';
	var Font = this.smfIsMobile()?strMFont:strFont;
				
	var nWPadding = this.smfIsMobile()?( nexacro.toNumber(this.fv_mAstaticPadding[1]) + nexacro.toNumber(this.fv_mAstaticPadding[3]) ):
									   ( nexacro.toNumber(this.fv_AstaticPadding[1]) + nexacro.toNumber(this.fv_AstaticPadding[3]) );

	var nHPadding = this.smfIsMobile()?( nexacro.toNumber(this.fv_mAstaticPadding[0]) + nexacro.toNumber(this.fv_mAstaticPadding[2]) ):
									   ( nexacro.toNumber(this.fv_AstaticPadding[0]) + nexacro.toNumber(this.fv_AstaticPadding[2]) );
	
	var staText = objContentsStatic.text;
	var staWidth =objContentsStatic.getOffsetWidth()-nWPadding;
	var nTextHeight = nexacro.getTextSize(staText,Font,staWidth,"char");
	
	return nTextHeight.ny + nHPadding;
};



this.btn01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objTargetDivForm =  this.div03.form;
	for(var i=0;i<this.dsComment.rowcount;i++)
	{
		var bLast = (i==(this.dsComment.rowcount-1))?true:false;
		this.fnAppendDiv(objTargetDivForm,this.dsComment, i, bLast);
	}
	this.smfResetScroll(this.div03.form);
};

this.btn02_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objTargetDivForm =  this.div03.form;
	for(var i=0;i<this.dsCommentTemp.rowcount;i++)
	{
		var bLast = (i==(this.dsCommentTemp.rowcount-1))?true:false;
		this.fnAppendDiv(objTargetDivForm,this.dsCommentTemp, i, bLast);
	}
	this.smfResetScroll(this.div03.form);
};

this.btn03_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnClearAllDiv(this.div03.form,true);
};
]]></Script>
