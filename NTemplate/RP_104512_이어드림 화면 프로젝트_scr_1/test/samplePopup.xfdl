<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="samplePopup" width="1050" height="818" titletext="popup" onload="Form_onload" onsize="samplePopup_onsize">
    <Layouts>
      <Layout height="818" mobileorientation="landscape" width="1050">
        <Button id="btnPopup" taborder="0" text="모달팝업" left="21" top="965" width="119" height="50" onclick="btnPopup_onclick" uWord="popup.modal"/>
        <Static id="sta02" taborder="1" text="팝업" left="20" top="17" width="221" height="33"/>
        <Static id="sta03" taborder="2" text="1. 호출 방법&#13;&#10;&#9;var procType = &quot;&quot;;&#13;&#10;&#9;&#13;&#10;&#9;if(obj == this.btnPopup){ // 등록버튼클릭&#13;&#10;&#9;&#9;procType = &quot;insert&quot;;&#13;&#10;&#9;}&#13;&#10;&#9;&#13;&#10;&#9;// 팝업을 동작에 필요한 파라메터 지정&#13;&#10;&#9;var popupParams = {&#13;&#10;&#9;&#9;callback: this.fnPopupCallback, // 콜백함수 지정&#13;&#10;&#9;&#9;sender: obj, // sender 지정&#13;&#10;&#13;&#10;&#9;&#9;// 팝업 전달 파라메터 지정&#13;&#10;&#9;&#9;params: {&#13;&#10;&#9;&#9;&#9;// 처리타입 지정&#13;&#10;&#9;&#9;&#9;procType: procType,&#13;&#10;&#9;&#9;&#9;// 파라메터 전달&#13;&#10;&#9;&#9;&#9;dataset: this.dsSample1,&#13;&#10;&#9;&#9;&#9;param1: &quot;aaaa&quot;,&#13;&#10;&#9;&#9;&#9;param2: 1111&#13;&#10;&#9;&#9;},&#13;&#10;&#9;};&#13;&#10;&#13;&#10;&#9;// 모달팝업 실행&#13;&#10;&#9;* Modal Dialog 처리&#13;&#10;&#9;* @param : popupId&#9;&#9;&#9;- Dialog의 ID&#13;&#10;&#9;* @param : popupUrl &#9;&#9;- Popup 화면 URL&#13;&#10;&#9;* @param : popupParams &#9;&#9;- Dialog Form으로 전달될 Argument&#13;&#10;&#9;* @param : nLeft &#9;&#9;- Dialog의 Left Position&#13;&#10;&#9;* @param : nTop &#9;&#9;- Dialog의 Top Position&#13;&#10;&#9;* @param : nWidth &#9;- Dialog 창의 Width&#13;&#10;&#9;* @param : nHeight&#9;- Dialog 창의 Height&#13;&#10;&#9;this.smfDialog(&quot;_auto&quot;, &quot;test::samplePopupForm.xfdl&quot;, popupParams);&#13;&#10;&#13;&#10;2. callback&#13;&#10;&#9;/**&#13;&#10;&#9; * 팝업의 콜백함수 지정한다&#13;&#10;&#9; * @param : e - 팝업에서 전달한 파라메터&#13;&#10;&#9; * @param : sender - 팝업호출시 전달한 팝업호출객체&#13;&#10;&#9; */&#13;&#10;&#9;this.fnPopupCallback = function(e, sender){&#13;&#10;&#9;&#9;// 업무콜백 처리&#13;&#10;&#9;&#9;&#13;&#10;&#9;&#9;trace(&quot;e ==&gt;&quot;+e.row.Column0+&quot;, &quot;+e.row.Column1+&quot;, &quot;+e.row.Column2+&quot;, &quot;+e.row.Column3);&#13;&#10;&#9;};" left="20" top="60" height="880" background="cornsilk" right="20" verticalAlign="top" onclick="sta03_onclick" usedecorate="true"/>
        <Button id="btnPopup0Modeless" taborder="3" text="모달리스팝업" left="21" top="1030" width="119" height="50" uWord="popup.modal" onclick="btnPopup0Modeless_onclick"/>
        <Button id="btnPopup1" taborder="4" text="모달팝업-size 설정" left="201" top="965" width="169" height="50" onclick="btnPopup1_onclick" uWord="popup.modal"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  컨설팅 표준화 작업
*  @MenuPath    샘플 > popup
*  @FileName 	samplePopup.xfdl 
*  @Creator 	consulting
*  @CreateDate 	2022.01.04
*  @Desction    popup 샘플
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.01.04     	consulting 	                최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/
include "lib::cm_script.xjs" 

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.Form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	//this.smfInitForm(obj);
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	// 업무콜백 처리
	
	trace("e ==>"+e.row.Column0+", "+e.row.Column1+", "+e.row.Column2+", "+e.row.Column3);
};
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
* btnPopup_onclick : modal popup open
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
*/
this.btnPopup_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var procType = "";
	
	if(obj == this.btnPopup){ // 등록버튼클릭
		procType = "insert";
	}
	
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: this.fnPopupCallback, // 콜백함수 지정
		sender: obj, // sender 지정

		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: procType,
			// 파라메터 전달
			dataset: this.dsSample1,
			param1: "aaaa",
			param2: 1111
		},
	};

	// 모달팝업 실행
	this.smfDialog("_auto", "test::samplePopupForm.xfdl", popupParams);		
};

this.btnPopup0Modeless_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var procType = "none";
	
	if(obj == this.btnPopup){ // 등록버튼클릭
		procType = "insert";
	}
	
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: this.fnPopupCallback, // 콜백함수 지정
		sender: obj, // sender 지정

		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: procType,
			// 파라메터 전달
			dataset: this.dsSample1,
			param1: "aaaa",
			param2: 1111
		},
	};

	// 모달팝업 실행
	this.smfOpen("_auto", "test::samplePopupForm.xfdl", popupParams);
};


this.btnPopup1_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: this.fnPopupCallback, // 콜백함수 지정
		sender: obj, // sender 지정

		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: "insert",
			// 파라메터 전달
			dataset: this.dsSample1,
			param1: "aaaa",
			param2: 1111
		},
	};
	
	//var srcInfo = this.smfCurScreenInfo(0,50);
	var srcInfo = this.smfCurScreenInfo();
	var compHeight = 800;	//parseInt(srcInfo[1],10)-450;

	var nWidth = 520;	//parseInt(srcInfo[0],10)-60;
	var nLeft = parseInt((srcInfo[0] -nWidth)/2);
	var nTop = parseInt((srcInfo[1] - compHeight)/2);

	
	// 모달팝업 실행
	//this.smfDialog("_popForm", "test::samplePopupForm.xfdl", popupParams, 0,0, this.width, compHeight);
	this.smfDialog("_popForm", "test::samplePopupForm.xfdl", popupParams, nLeft,nTop, nWidth, compHeight);
};

// 모바일 - 회전시 팝업의 크기 변경
this.samplePopup_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	if ( this.smfIsMobile() ) {	
		
		var objPopFrame = this.smfGetPopupFrame("_popForm");
		if (objPopFrame) {

			//*
			//방법1. 공통함수 호출
			var nWidth	;	// = 800;	//가로회전시 특정 사이즈를 설정할 경우
			var nHeight ;	//= 500;	//세로회전시 특정 사이즈를 설정할 경우
			this.smfMovePopupFrame(objPopFrame, nWidth,nHeight, e);
			//*/
			
			/*
			방법2. 가로회전할때 특정 사이즈를 설정해줄 경우
			
			var nWidth,nHeight;
			if (String(e.orientation) =="landscape") {
				nWidth = 1000;
				nHeight = objPopFrame.height * 0.8;
				
			}else {
				nWidth = objPopFrame.orgPopWidth;
				nHeight = objPopFrame.orgPopHeight;
			}

			var srcInfo = this.smfCurScreenInfo();
			var nLeft = parseInt((srcInfo[0] - nWidth)/2);
			var nTop = parseInt((srcInfo[1] - nHeight)/2);
			
			objPopFrame.move(nLeft,nTop,nWidth,nHeight);
			*/
			
		
			/*
			방법3. this.smfMovePopupFrame() 함수 사용하지 않고 직접 설정시
			var srcInfo = this.smfCurScreenInfo();
			var srcInfoW = srcInfo[0];
			var srcInfoH = srcInfo[1];
			var nWidth = objPopFrame.orgPopWidth;
			var nHeight = objPopFrame.orgPopHeight;
			
			//trace("  화면 Height : "+srcInfoH , nHeight , srcInfoW , nWidth );
		
			if (srcInfoH < nHeight){
				nHeight = parseInt(srcInfoH *0.9, 10);
			}
			if (srcInfoW < nWidth){
				nWidth = parseInt(srcInfoW *0.9, 10);
			}
			
			var nLeft = parseInt((srcInfoW - nWidth)/2);
			var nTop = parseInt((srcInfoH - nHeight)/2);
			trace( "nWidth >> "+ nWidth , "  nHeight >> "+ nHeight);
		
			objPopFrame.move(nLeft,nTop,nWidth,nHeight);
			*/
		}
	}
};
]]></Script>
    <Objects>
