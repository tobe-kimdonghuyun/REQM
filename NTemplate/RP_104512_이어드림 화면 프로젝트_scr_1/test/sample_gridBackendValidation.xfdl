              <Button id="btnPrev" taborder="82" text="-" cssclass="btn_cal_prev" left="20" top="15" width="20" height="20" onclick="popdiv_Button00_onclick"/>
              <Button id="btnNext" taborder="83" text="+" cssclass="btn_cal_next" left="155" top="15" width="20" height="20" onclick="popdiv_Button01_onclick"/>
            </Layout>
          </Layouts>
        </PopupDiv>
        <Static id="main_title" taborder="6" text="그리드 유효성검사" left="18" top="17" width="215" height="33"/>
        <Grid id="grdSub" taborder="5" left="15" top="313" width="1095" height="147" binddataset="dsSub" autoenter="select" autofittype="col" onexpandup="grd_valid_onexpandup">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="48"/>
                <Column size="215"/>
                <Column size="142"/>
                <Column size="127"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="50" band="head"/>
                <Row size="34"/>
              </Rows>
              <Band id="head">
                <Cell text="순번"/>
                <Cell col="1" text="decimal&#13;&#10;(digits:3자리, 소수:2자리 허용)"/>
                <Cell col="2" text="digits&#13;&#10;(0-9 숫자만 허용)"/>
                <Cell col="3" text="integer(정수 허용)"/>
                <Cell col="4" text="min"/>
                <Cell col="5" text="max"/>
                <Cell col="6" text="between"/>
              </Band>
              <Band id="body">
                <Cell text="expr:currow+1"/>
                <Cell col="1" text="bind:decimal" edittype="text"/>
                <Cell col="2" text="bind:digits" edittype="text"/>
                <Cell col="3" text="bind:integer" edittype="text"/>
                <Cell col="4" text="bind:min" edittype="text"/>
                <Cell col="5" text="bind:max" edittype="text"/>
                <Cell col="6" text="bind:between" edittype="text"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="btnValidChk00" taborder="6" text="정합성 체크" left="1014" top="272" width="96" height="34" onclick="btn_validChk00_onclick"/>
        <Button id="btnAddrow00" taborder="7" text="행추가" left="909" top="272" width="96" height="34" onclick="btn_addrow00_onclick"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/*
 * 프로그램명	: Validation_Grid.xfdl
 * 작 성 자   	: 문호상
 * 작 성 일	: 2022-04-27
 * 설    명	: 
 * 수정일		:
 * 수정자		:
 * 수정내용	:
 */

/* Callback */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd != 0) return;

};

/* form onload */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitForm(obj); 
	
	
	//onload
	this.fnPrepareValidationTest();
	
	this.smfValidateService("validateMain", {
			url: "/cmc_sam_pl11_101.do",
		})
		// 서버의 search룰셋을 divMain에 매핑한다
		.mappingRulesetToDataset(this.dsMainValid, "search") 
		.mappingRulesetToDataset(this.dsSubValid, "numbers")
		.run()
		.callback(function(callbackParams){
		})
	; 		
};

/* Dataset의 Row Status를 변경한다(insert,update인 경우에만 체크 */
this.fnPrepareValidationTest = function() {
 	//테스트 데이타가 이미 입력되어 있으므로 강제로 Row status를 변경.
 	for (var i=0,size=this.dsMain.rowcount; i<size;i++) {
 		this.dsMain.setColumn(i, "Column0", "x");
 	}
	this.dsMain.insertRow(0);

	 
 	for (var i=0,size=this.dsMain.rowcount; i<size;i++) {
 		this.dsSub.setColumn(i, "dummy", "x");
 	}	
	this.dsSub.insertRow(0);
};



/* 정합성 체크 */
this.btn_validChk_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 서비스 객체 생성 
	this.smfSaveService("save")
		// 데이터 검증
		.validateGrid(this.grdValid, this.dsMainValid)		
		// 중복검사
		.validateDuplicate({
			grid: this.grdValid,
			gridText: "사원정보",
			columnNames: ["empno"], // 중복검사할 컬럼명
			columnText: "사원번호",
		})

		// 검증 및 confirm메시지 처리
		// 서비스를 실행하기 전에 호출된다
		// next()를 호출하지 않으면 서비스가 호출되지 않는다
		.beforeService(function(next){
			this.smfAlert("CM001");
			// next();
		})
		
		// 실행
		.run()
		
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.reason == -1) return; 
		});

};

this.btn_addrow_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//로우를 추가하고 초기화 시킨다.
	this.smfInitRow(this.dsMain, this.dsMain.addRow());
};


this.btn_addrow00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//로우를 추가하고 초기화 시킨다.
	this.smfInitRow(this.dsSub, this.dsSub.addRow());
};

this.btn_validChk00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

// 서비스 객체 생성 
	this.smfSaveService("saveSub")
		// 데이터 검증
		.validateGrid(this.grdSub, this.dsSubValid)		

		// 검증 및 confirm메시지 처리
		// 서비스를 실행하기 전에 호출된다
		// next()를 호출하지 않으면 서비스가 호출되지 않는다
		.beforeService(function(next){
			this.smfAlert("CM001");
			// next();
		})
		
		// 실행
		.run()
		
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return; 
		});
};


this.smfGridMonthCalendar = function(obj:nexacro.Grid,e:nexacro.GridMouseEventInfo){

};

//년월달력 팝업 호출
this.grd_valid_onexpandup = function(obj:nexacro.Grid,e:nexacro.GridMouseEventInfo) {
	var objDs = obj.binddataset;
	var a 		= obj.getCellRect(e.row, e.cell);
	var nLeft 	= a.left + system.clientToScreenX(obj,0);
	var nTop 	= a.bottom + system.clientToScreenY(obj,0);
	//trace(nLeft + " : " + nTop);
	//모니터 해상도
	var monitorX = system.getScreenWidth();
	var monitorY = system.getScreenHeight();

///////////////////////////////////////////////////////////////////////////
	//var dVal = eval(objDs).getColumn(e.row, e.cell);
	var dVal = obj.getCellValue(e.row, e.cell);

	this.fnClearMonthImg();

	if (!this.smfIsNull(dVal)) {
		this.pdvYm.form.staYear.set_text(dVal.substring(0,4));
		this.smfFindComponentInThisContext("this.pdvYm.img_month" + nexacro.toNumber(dVal.substring(4,6))).set_image("theme://images\\cal_num" + nexacro.toNumber(dVal.substring(4,6)) + "R.png");
	} else {
		//현재일자 가져와서 세팅
		var strToday  = this.smfToday();
		this.pdvYm.form.staYear.set_text(strToday.substring(0,4));
		var nMonth = nexacro.toNumber(strToday.substring(4,6));
		var strImgNm = "theme://images\\cal_num" + nMonth.toString() + "R.png";
		this.smfFindComponentInThisContext("this.pdvYm.img_month" + nMonth).set_image(strImgNm);
	}
///////////////////////////////////////////////////////////////////////////

	//팝업위치 조정(모니터 우측으로 넘어가지 않도록 처리)
	if ((nLeft+this.pdvYm.getOffsetWidth()) > monitorX) {
		nLeft = monitorX - this.pdvYm.getOffsetWidth();
	}
	//팝업위치 조정(모니터 아래+로 넘어가지 않도록 처리)
	if ((nTop+this.pdvYm.getOffsetHeight()) > monitorY) {
		nTop = nTop - this.pdvYm.getOffsetHeight() - (a.bottom-a.top);
	}
	
	this["fnTrackPopupCallbackFunction"] = function(popupDivObj, paramNewValue){
		this["fnTrackPopupCallbackFunction"] = null;

		if (!this.smfIsNull(paramNewValue)) {
			var strColNm = obj.getCellProperty("body",e.cell,"text");
			this.smfFindComponentInThisContext(objDs).setColumn(e.row,nexacro.replaceAll(strColNm,"bind:",""), paramNewValue);
		}
	};

	var rtnvalue = this.pdvYm.trackPopup(nLeft, nTop, null, null, "fnTrackPopupCallbackFunction");
};

this.fnClearMonthImg = function() {
	return;
	for (var i=1; i<13; i++) {
		this.svcfFindComponentInThisContext("this.pdvYm.img_month" + i).set_image("theme://images\\cal_num" + i + ".png");
	}
};

/* 년월선택 팝업창 선택값 돌려주기 */
this.fnCalendarPopdivClick = function(obj:nexacro.ImageViewer,e:nexacro.ClickEventInfo) {
	this.pdvYm.closePopup(this.pdvYm.form.staYear.text + obj.text);
};

//입력 제어
this.grd_valid_onchar = function(obj, e)
{
	//trace("mask:: "+obj.getCellProperty("body",e.cell,"mask"));
	var strCellProperty = obj.getCellProperty("body",e.cell,"mask");
	if (strCellProperty == "@@@@.@@") {
		//trace("input value: "+e.posttext);
		if (/* [X-LOG] posttext은 지원되지 않는 속성입니다.*/ e.posttext.length > 4) {
			/* [X-LOG] posttext은 지원되지 않는 속성입니다.*/var nVal = parseInt(e.posttext.substr(4,1));
			/* [X-LOG] posttext은 지원되지 않는 속성입니다.*/var nVal2 = parseInt(e.posttext.substr(4,2));

				//trace(nVal + " :: "+ nVal2);
				if (nVal > 1) {
					return false;
				}

				if (nVal2 > 12) {
					return false;
				}

		}

	}
};

//년도계산
this.popdiv_Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.pdvYm.form.staYear.set_text(parseInt(this.pdvYm.form.staYear.text) + 1);
};

//년도계산
this.popdiv_Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.pdvYm.form.staYear.set_text(parseInt(this.pdvYm.form.staYear.text) - 1);
};
