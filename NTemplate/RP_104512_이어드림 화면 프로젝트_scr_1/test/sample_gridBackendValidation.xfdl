    <Layouts>
      <Layout>
        <Grid id="grdValid" taborder="0" left="15" top="83" width="1095" height="177" binddataset="dsMain" autoenter="select" autofittype="col" onexpandup="grd_valid_onexpandup">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="40"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="60"/>
                <Column size="60"/>
                <Column size="115"/>
                <Column size="80"/>
                <Column size="120"/>
                <Column size="80"/>
                <Column size="80"/>
