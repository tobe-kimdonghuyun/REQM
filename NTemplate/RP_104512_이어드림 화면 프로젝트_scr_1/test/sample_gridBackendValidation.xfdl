                <Column size="80"/>
                <Column size="60"/>
                <Column size="80"/>
                <Column size="85"/>
                <Column size="65"/>
              </Columns>
              <Rows>
                <Row size="34" band="head"/>
                <Row size="34"/>
              </Rows>
              <Band id="head">
                <Cell text="순번" displaytype="normal"/>
                <Cell col="1" text="아이디" displaytype="normal"/>
                <Cell col="2" text="사원번호" displaytype="normal"/>
                <Cell col="3" text="성별" displaytype="normal"/>
                <Cell col="4" text="여부" displaytype="normal"/>
                <Cell col="5" text="시작일" displaytype="normal"/>
                <Cell col="6" text="금액1" displaytype="normal"/>
                <Cell col="7" text="종료일" displaytype="normal"/>
                <Cell col="8" text="금액2" displaytype="normal"/>
                <Cell col="9" text="점수" displaytype="normal"/>
                <Cell col="10" text="날짜" displaytype="normal"/>
                <Cell col="11" text="자리수" displaytype="normal"/>
                <Cell col="12" text="코드" displaytype="normal"/>
                <Cell col="13" text="년월" displaytype="normal"/>
                <Cell col="14" text="우편번호" displaytype="normal"/>
                <Cell col="15" text="사용여부"/>
              </Band>
              <Band id="body">
                <Cell text="expr:currow+1" displaytype="normal"/>
                <Cell col="1" edittype="text" text="bind:userid" editlimit="7" displaytype="normal"/>
                <Cell col="2" edittype="normal" text="bind:empno" displaytype="normal"/>
                <Cell col="3" displaytype="combotext" edittype="combo" text="bind:sex" combodataset="dsSex" combocodecol="cd" combodatacol="nm"/>
                <Cell col="4" displaytype="checkboxcontrol" edittype="checkbox" text="bind:Column3"/>
                <Cell col="5" displaytype="date" edittype="date" text="bind:Column4" maskeditformat="yyyy.MM.dd" maskedittype="string" calendardateformat="yyyy.MM.dd ddd" calendareditformat="yyyy.MM.dd" calendardisplaynulltype="none"/>
                <Cell col="6" displaytype="number" edittype="normal" text="bind:Column5"/>
                <Cell col="7" displaytype="date" edittype="date" text="bind:Column6" maskeditformat="yyyy.MM.dd" calendareditformat="yyyy.MM.dd" calendardateformat="yyyy.MM.dd ddd" maskedittype="string" calendardisplaynulltype="none"/>
                <Cell col="8" displaytype="number" edittype="normal" text="bind:Column7"/>
                <Cell col="9" displaytype="number" edittype="normal" text="bind:Column8"/>
                <Cell col="10" edittype="date" text="bind:Column9" displaytype="date" calendardateformat="yyyy.MM.dd" calendareditformat="yyyyMM.dd" maskedittype="string" calendardisplaynulltype="none"/>
                <Cell col="11" edittype="normal" text="bind:colLimit" displaytype="normal"/>
                <Cell col="12" edittype="normal" text="bind:colcode" displaytype="normal"/>
                <Cell col="13" displaytype="mask" edittype="mask" text="bind:calYM" maskeditformat="####.##" maskchar=" " editlimit="6" expandshow="hide" calendardisplay="edit" calendardisplaynulltype="none" maskeditclipmode="excludespace" maskedittype="string" maskeditlimitbymask="none" textAlign="center"/>
                <Cell col="14" edittype="normal" text="bind:zipcode" editdisplay="display" displaytype="editcontrol" textAlign="center"/>
                <Cell col="15" displaytype="checkboxcontrol" edittype="checkbox" text="bind:uon" checkboxfalsevalue="N" checkboxtruevalue="Y" checkboxsize="10" textAlign="center"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="btnValidChk" taborder="1" text="정합성 체크" left="1014" top="44" width="96" height="34" onclick="btn_validChk_onclick"/>
