<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="test001" width="1280" height="860" titletext="그리드에서 라디오 선택하는 샘플" onload="test001_onload">
    <Layouts>
      <Layout height="860" width="1280" screenid="ScreenDeskTop">
        <Static id="sta01" taborder="0" text="그리드에서 라디오 선택하는 샘플" left="18" top="12" width="364" height="36"/>
        <Grid id="grd00" taborder="1" left="18" top="58" width="802" height="460" binddataset="ds01" selecttype="cell" autofittype="col" oncellclick="grd00_oncellclick">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="41"/>
                <Column size="81"/>
                <Column size="66"/>
                <Column size="241"/>
                <Column size="367"/>
              </Columns>
              <Rows>
                <Row size="24"/>
                <Row size="24"/>
                <Row size="24"/>
                <Row size="54"/>
                <Row size="24"/>
                <Row size="24"/>
                <Row size="24"/>
                <Row size="73"/>
                <Row size="24"/>
                <Row size="42"/>
                <Row size="24"/>
                <Row size="24"/>
                <Row size="24"/>
                <Row size="24"/>
                <Row size="24"/>
              </Rows>
              <Band id="body">
                <Cell rowspan="4" wordWrap="char" background="lightgray" border="1px solid #dddfe3,0px solid #f6f7f8,1px solid #dddfe3,1px solid #f6f7f8" displaytype="checkboxcontrol" edittype="checkbox" aa="0" text="bind:Column0"/>
                <Cell col="1" rowspan="4" text="출연자" textAlign="center" wordWrap="char" background="lightgray" aa="0"/>
                <Cell col="2" colspan="2" text="출연자가 자연인" wordWrap="char"/>
                <Cell col="4" text="출연자" wordWrap="char"/>
                <Cell row="1" col="2" colspan="2" text="출연자가 민법 제32조의 법인" wordWrap="char"/>
                <Cell row="1" col="4" text="당해 법인에 대한 출연자를 포함" wordWrap="char"/>
                <Cell row="2" col="2" colspan="2" text="출연자가 기타의 법인" wordWrap="char"/>
                <Cell row="2" col="4" wordWrap="char"/>
                <Cell row="3" col="2" colspan="3" text="* 이하에서 출연자는 위의 모든자를 포함함&#13;&#10;* 다만, 재산출연일 현재 해당 공익법인의 총출연재산가액의 100분의 1에 해당하는 금액과 2천만원 중 적은 금액을 출연하는 자는 제외" wordWrap="char"/>
                <Cell row="4" rowspan="4" wordWrap="char" background="lightgray" border="1px solid #dddfe3,0px solid #f6f7f8,1px solid #dddfe3,1px solid #f6f7f8" displaytype="checkboxcontrol" edittype="checkbox" _radiovalue="1" text="bind:Column1"/>
                <Cell row="4" col="1" rowspan="4" text="출연자 &#13;&#10;또는 &#13;&#10;이사의 &#13;&#10;친족" textAlign="center" wordWrap="char" background="lightgray"/>
                <Cell row="4" col="2" rowspan="4" wordWrap="char" text="부계" textAlign="center"/>
                <Cell row="4" col="3" wordWrap="char" text="6촌이내의 혈족"/>
                <Cell row="4" col="4" rowspan="4" text="출연자 또는 이사가 추가녀인 경우에는 남편과의 관계에 의함" wordWrap="char"/>
                <Cell row="5" col="3" wordWrap="char" text="4촌이내의 인척"/>
                <Cell row="6" col="3" wordWrap="char" text="배우자(사실혼 관계 포함)"/>
                <Cell row="7" col="3" wordWrap="char" text="친생자(친생자)로서 다른사람에게 친양자(친양자)로 입양된 사람과 그 배우자/직계비속(직계비속)"/>
                <Cell row="8" rowspan="2" wordWrap="char" background="lightgray" border="1px solid #dddfe3,0px solid #f6f7f8,1px solid #dddfe3,1px solid #f6f7f8" edittype="checkbox" displaytype="checkboxcontrol" text="bind:Column2"/>
                <Cell row="8" col="1" rowspan="2" wordWrap="char" textAlign="center" text="사용인" background="lightgray"/>
                <Cell row="8" col="2" colspan="3" wordWrap="char" text="출연자 또는 이사의 사용인 기타 고용 관계자"/>
                <Cell row="9" col="2" colspan="3" wordWrap="char" text="출연자 또는 이사가 출자에 의하여 사실상 지배하고 있는 법인의 사용인&#13;&#10;기타 고용관계자"/>
                <Cell row="10" rowspan="2" wordWrap="char" background="lightgray" border="1px solid #dddfe3,0px solid #f6f7f8,1px solid #dddfe3,1px solid #f6f7f8" edittype="checkbox" displaytype="checkboxcontrol" text="bind:Column3"/>
                <Cell row="10" col="1" rowspan="2" wordWrap="char" textAlign="center" text="생계의존" background="lightgray"/>
                <Cell row="10" col="2" colspan="3" wordWrap="char" text="출연자 또는 이사의 금전 기타의 재산에 의하여 생계를 유지하는자"/>
                <Cell row="11" col="2" colspan="3" wordWrap="char" text="출연자 또는 이사가 생계를 함께 하는 자"/>
                <Cell row="12" wordWrap="char" background="lightgray" border="1px solid #dddfe3,0px solid #f6f7f8,1px solid #dddfe3,1px solid #f6f7f8" edittype="checkbox" displaytype="checkboxcontrol" text="bind:Column4"/>
                <Cell row="12" col="1" wordWrap="char" textAlign="center" text="기타" background="lightgray"/>
                <Cell row="12" col="2" colspan="3" wordWrap="char" text="출연자가 재산을 출연한 다른 공익사업을 영위하는 법인의 이사"/>
                <Cell row="13" rowspan="2" wordWrap="char" background="lightgray" border="1px solid #dddfe3,0px solid #f6f7f8,1px solid #dddfe3,1px solid #f6f7f8" edittype="checkbox" displaytype="checkboxcontrol" text="bind:Column5"/>
                <Cell row="13" col="1" rowspan="2" wordWrap="char" text="해당&#13;&#10;없음" textAlign="center" background="lightgray"/>
                <Cell row="13" col="2" rowspan="2" colspan="3" wordWrap="char" text="해당없음"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="btn00" taborder="2" text="선택된 값 읽기" left="281" top="547" width="167" height="30" onclick="btn00_onclick"/>
      </Layout>
      <Layout name="Layout0" width="640" height="720" mobileorientation="landscape" type="default" screenid="mobile"/>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    샘플
*  @FileName 	sampleKoreaMap.xfdl
*  @Creator 	홍길동
*  @CreateDate 	2022.6.14
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.6.14     	홍길동 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.test001_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

}; 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/


/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/


this.btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
};

this.grd00_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	if(e.col==0)
	{
		var sSelColId = obj.getCellProperty("body",e.cell,"text");
		sSelColId = nexacro.replaceAll(sSelColId,"bind:","");
		var objBindDs = obj.getBindDataset();
		for(var i=0;i<objBindDs.colcount;i++)
		{
			var sColId = objBindDs.getColID(i);
			trace("sColId=["+sColId+"]")
			if(sColId==sSelColId)
			{
				objBindDs.setColumn(e.row,sColId,true);
			}
			else
			{
				objBindDs.setColumn(e.row,sColId,false);
			}
		}
	}
	
};


]]></Script>
    <Objects>
      <Dataset id="ds01">
        <ColumnInfo>
          <Column id="Column0" type="STRING" size="256"/>
          <Column id="Column1" type="STRING" size="256"/>
          <Column id="Column2" type="STRING" size="256"/>
          <Column id="Column3" type="STRING" size="256"/>
          <Column id="Column4" type="STRING" size="256"/>
          <Column id="Column5" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row/>
        </Rows>
      </Dataset>
    </Objects>
  </Form>
</FDL>
