<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sample_formValidation" left="0" top="0" width="831" height="1000" titletext="UI 인풋 유효성검사" onload="fnOnload">
    <Script type="xscript5.1"><![CDATA[// 콜백함수
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
};

// 폼 초기화 이벤트
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
}


// 조회버튼 클릭
this.Div00_btn_search_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	// 서비스 객체 생성 
	this.smfSearchService("select")
		// 데이터 검증
		.validateForm(this.divMain) 
		// 검증 및 confirm메시지 처리
		// 서비스를 실행하기 전에 호출된다
		// next()를 호출하지 않으면 서비스가 호출되지 않는다
		.beforeService(function(next){
			this.smfAlert("CM001");
			// next();
		})		
 
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			
			this.smfAlert(this.smfAfterServiceMessage(), this.div_search_btn_search_onclick);
		});
};


// function을 활용한 유효성검사 
// return이 true면 검증성공
// return이 String이면 검증실패및 메시지리턴
this.fnMyfunction = function(obj){
	if("400" == obj.value) return true;

	return "myfunction 항목은 400이어야 합니다";
};

// 검증버튼 클릭
this.div_validateNumbers_btn_search_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 서비스 객체 생성 
	this.smfSearchService("select")
		// 데이터 검증
		.validateForm(this.divValidateNumbers) 
		// 서비스를 실행하기 전에 호출된다
		// next()를 호출하지 않으면 서비스가 호출되지 않는다
		.beforeService(function(next){
			this.smfAlert("CM001");
			// next();
		})		
 
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			alert("callback");
		});
};

]]></Script>
