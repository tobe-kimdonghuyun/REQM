<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Main_sub1" width="1920" height="980" titletext="검색" background="#ffffff" onload="samplePortalResize" onsize="samplePortalResize_onsize">
    <Layouts>
      <Layout height="980" screenid="ScreenDeskTopP" width="1920">
        <Static id="staBG_left" taborder="0" left="0" top="0" width="489" height="430" cssclass="sta_main_sub1_BgLeft" initvalueid="ivStcAccessibilityOff"/>
        <Static id="staBG_right" taborder="1" width="509" height="822" cssclass="sta_main_sub1_BgRight" initvalueid="ivStcAccessibilityOff" right="0" bottom="0"/>
        <Div id="div00" taborder="2" left="360" top="242" width="1200" height="520" formscrolltype="none">
          <Layouts>
            <Layout>
              <Static id="staT1" taborder="0" text="안녕하세요. 나는" left="0" top="47" width="772" height="150" cssclass="font110B" verticalAlign="middle" padding="0px" initvalueid="ivStcAccessibilityOn"/>
              <Edit id="edtSearch" taborder="1" left="5" top="208" width="558" height="149" cssclass="edt_main_sub1_edt" text="안녕하세요" initvalueid="ivEdtNormal"/>
              <Static id="staT2" taborder="2" text="에 대해" left="edtSearch:0" top="197" width="337" height="160" cssclass="font110B" verticalAlign="middle" padding="0px" initvalueid="ivStcAccessibilityOn"/>
              <Static id="staT3" taborder="3" text="궁금해요." left="0" top="370" width="426" height="150" cssclass="font110B" verticalAlign="middle" padding="0px" initvalueid="ivStcAccessibilityOn"/>
              <Button id="btn00" taborder="4" text="#검정고시 안내" left="649" top="473" width="125" height="30" cssclass="btn_main_sub1_txtLink" initvalueid="ivBtnAccessibilityLink"/>
              <Button id="btn01" taborder="5" text="#2022 채용공고" left="774" top="473" width="131" height="30" cssclass="btn_main_sub1_txtLink" initvalueid="ivBtnAccessibilityLink"/>
              <Button id="btn02" taborder="6" text="#수업지원플랫폼" left="905" top="473" width="136" height="30" cssclass="btn_main_sub1_txtLink" initvalueid="ivBtnAccessibilityLink"/>
              <Button id="btn03" taborder="7" text="#유치원생 안내사항" left="1045" top="473" width="155" height="30" cssclass="btn_main_sub1_txtLink" initvalueid="ivBtnAccessibilityLink"/>
              <Static id="staTitle_small" taborder="8" text="NEIS Search" left="3" top="0" width="120" height="28" cssclass="font20M,color2b72" initvalueid="ivStcAccessibilityOn"/>
              <Static id="staGuide00" taborder="9" text="h60" left="20" top="22" width="70" height="60" cssclass="sta_WF_Size" visible="false" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staGuide01" taborder="10" text="h50" left="155" top="355" width="70" height="50" cssclass="sta_WF_Size" visible="false" initvalueid="ivStcAccessibilityOff"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="staGuide03" taborder="3" text="edtSearch에 검색어입력 내용에 따라 width가 늘어납니다.&#13;&#10;- staT2는 right에 연결되어 따라서 이동하며 1200영역에서 벗어나지는 않게 해 주세요.&#13;&#10;- 입력한 후 &quot;enter&quot;버튼을 치면 검색합니다.(※결과내용화면은 아직 나오지 않음)" left="788" top="797" width="346" height="85" cssclass="sta_WF_Size" visible="false" initvalueid="ivStcAccessibilityOff" padding="10px" textAlign="left" verticalAlign="top"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[]]></Script>
