    <Script type="xscript5.1"><![CDATA[/**
 *	대입전형자료원격업무신청서비스
 *	@MenuPath	대입전형-전형자료원격업무신청서비스-전형자료원격업무신청서비스신청
 *	@FileName 	uds_ueuum00_p00.xfdl
 *	@Creator 	김정민
 *	@CreateDate	2023.05.03
 *	@Desction	
 ************** 소스 수정 이력 ***********************************************
 *	date			Modifier			Description
 *******************************************************************************
 *	2023.05.03		김정민				최초 생성
 *******************************************************************************
 */

/************************************************************************************************
 * include 영역
 ************************************************************************************************/
include "lib::uds_script.xjs";

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/
this.fvIsCoaSvcAplyPsl = 'N';
this.fvPswdOld = '';

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/

/**
 * @description 화면 onload시 처리
 */
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// Div 초기화
	this.smfInitForm(obj);
	
	// 초기화
	this.fnInit(obj); 
	
	// 공통코드 조회
	this.smfCodeList("code", [this.dsRcritScCd])
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			//수시, 정시 순서로 sort
			this.dsRcritScCd.set_keystring('S:-unyCdValue');
			
			//전체 추가
			var nRow = this.dsRcritScCd.addRow();
			this.dsRcritScCd.setColumn(nRow, 'unyCdValue', 0);
			this.dsRcritScCd.setColumn(nRow, 'unyCdValueNm', '전체');
			this.dsRcritScCd.applyChange();
			
			// 조회
			this.fnSearch(); 
		});
	
	// 조회 입력창에서 'Ctrl' + 'Enter' 키 입력시 조회수행 이벤트 설정
	this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
};

/**
 * @description 폼 닫기전 이벤트
 */
this.fnOnbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	// 변경내역이 발생한 경우 종료전 confirm수행
	return this.smfCloseFormConfirm([this.dsMain]);
};

/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg) {
	if(errcd <= -1) return;
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/**
 * @description 조회
 */
this.fnSearch = function()
{

};

/**
 * @description 대입기준 기본조회
 */
this.fnSelectCoaCtr = function(callback)
{
	this.smfSearchService('selectCoaCtr')
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			if(this.smfIsFunc(callback)) callback.call(this);
		});
};

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/**
 * @description 초기화 FUNCTION
 */
this.fnInit = function(obj){
	this.dsSearch.setColumn(0, "coaAyr", this.udsv_coaAyr);
	this.dsSearch.setColumn(0, "coaRcritScCd", this.udsv_coaRcritScCd);
	this.dsSearch.setColumn(0, "coaRcritScNm", this.udsv_coaRcritScNm);
	this.dsSearch.setColumn(0, "uvstOrgCd", this.udsv_instCd);
	
	this.fnSelectCoaCtr(function(){
		if(this.dsCoaCtr.getRowCount() > 0){
			var coaSvcAplyBgngYmd = this.fnYmdWithDot(this.dsCoaCtr.getColumn(0, 'coaSvcAplyBgngYmd'));
			var coaSvcAplyEndYmd = this.fnYmdWithDot(this.dsCoaCtr.getColumn(0, 'coaSvcAplyEndYmd'));
			
			if(coaSvcAplyBgngYmd && coaSvcAplyBgngYmd){
				this.fvIsCoaSvcAplyPsl = this.dsCoaCtr.getColumn(0, 'coaSvcAplyPslYn') == 'Y';
				
				var coaRcritScCd = this.dsCoaCtr.getColumn(0, 'coaRcritScCd');
				if(coaRcritScCd == '1' || coaRcritScCd == '2' || coaRcritScCd == '4'){
				
					//TODO 테스트 대학이면 신청가능
					//if(테스트대학) this.fvIsCoaSvcAplyPsl = 'Y'
					
					this.staAplyPrd.set_text('신청기간 : ' + coaSvcAplyBgngYmd + ' ~ ' + coaSvcAplyEndYmd);
					
				}else{
					this.fvIsCoaSvcAplyPsl = false;
					this.staAplyPrd.set_text('사전운영기간');
				}
			}else{
				this.smfLiteralAlert('원격업무신청서비스(대학사용자)를 사용할 수 없습니다.');
			}
		}
	});
}

/**
 * @description Ymd에 점추가
 * @param : sYmd			- 년원일 ( ex. 20230504 )
 * @return 	: String        - YYYY.MM.DD (ex. 2023.05.04. )
 */
this.fnYmdWithDot = function(sYmd){
    sYmd = this.smfStr(sYmd)
	if(!this.smfIsNull(sYmd) && sYmd.length >= 8){
		return [sYmd.substr(0, 4), sYmd.substr(4, 2), sYmd.substr(6, 2)].join(".") + ".";
	}
}

/**
 * @description 비밀번호 패턴 확인
 * @param : password			- 비밀번호
 * @param : bNoShowMessage		- 오류 메시지 출력 여부
 * @return : boolean
 */
this.fnCheckPasswordPattern = function(password, bNoShowMessage){
	password = this.smfStr(password);
	if(this.smfIsNull(bNoShowMessage)) bNoShowMessage = false;
	
	message = "비밀번호는 숫자,영문자,특수문자 조합하여 입력하세요.";

	if(!this.fnPswdFilter(password, bNoShowMessage)){
		return false;
	}
	
	//영문자찾기
	if(!password.match(/[a-z]|[A-Z]/g)){
		if(bNoShowMessage == false){
			this.smfLiteralAlert(message);
		}
		return false;
	}

	//숫자찾기
	if(!password.match(/[0-9]/g)){
		if(bNoShowMessage == false){
			this.smfLiteralAlert(message);
		}
		return false;
	}

	//특수문자 찾기
	if(!password.match(/[^\w]/g)){
		if(bNoShowMessage == false){
			this.smfLiteralAlert(message);
		}
		return false;
	}

	return true;
}

/**
 * @description 비밀번호 필터
 * @param : password			- 비밀번호
 * @param : bNoShowMessage		- 오류 메시지 출력 여부
 * @return : boolean
 */
this.fnPswdFilter = function(password, bNoShowMessage){
	password = this.smfStr(password);
	if(this.smfIsNull(bNoShowMessage)) bNoShowMessage = false;
	
	if(password.indexOf("%") != -1){
		if(bNoShowMessage == false){
			this.smfLiteralAlert('비밀번호에 "%" 문자는 사용할 수 없습니다.');
		}
		return false;
	}
	
	if(password.indexOf('\'') != -1 || password.indexOf('\"') != -1){
		if(bNoShowMessage == false){
			this.smfLiteralAlert('비밀번호에 작은따옴표 [\'] 또는 큰따옴표 [\"]는 사용할 수 없습니다.');
		}
		return false;
	}
	
	return true;
}
/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
 * @description 그리드 헤더 클릭
*/
this.grdMain_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	var columnName = obj.getCellProperty("body",e.cell,"text");
	if ("bind:_chk" == columnName){
		this.smfToggleChkHeader(obj, e, this.fnRenderGridCheckbox);
	}else{
		// 정렬
		this.smfCheckAndSort(obj, e);
	}
};

/**
 * @description 조회
 */
this.divSearch_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.fnSearch();
};

/**
 * @description User Properties의 validate maxlengthB 적용
 */
this.maxLengthB_oninput = function(obj:nexacro.Edit,e:nexacro.InputEventInfo)
{
	this.udsfCutMaxlengthB(obj);
	
	if(obj.id == 'edtVpnPswd'){
		if(obj.value && obj.value.length > 0){
			var lastChr = this.smfRight(obj.value, 1);
			if(this.fnCheckPasswordPattern(obj.value, true)){
				this.divCoaPrge.form.staVpnPswd01.set_text('적합');
			}else{
 				if(!this.fnPswdFilter(obj.value)) obj.set_value(this.fvPswdOld);
				this.divCoaPrge.form.staVpnPswd01.set_text('부적합');
			}
			this.divCoaPrge.form.edtVpnPswd00.set_value(lastChr);
		}else{
			this.divCoaPrge.form.edtVpnPswd00.set_value('');
		}
	}else if(obj.id == 'edtVpnPswdIdnty'){
		if(obj.value && obj.value.length > 0){
			if(this.divCoaPrge.form.edtVpnPswd.value == obj.value){
				this.divCoaPrge.form.staVpnPswdIdnty01.set_text('일치');
			}else{
				this.divCoaPrge.form.staVpnPswdIdnty01.set_text('불일치');
			}
			this.divCoaPrge.form.edtVpnPswdIdnty00.set_value(this.smfRight(obj.value, 1));
		}else{
			this.divCoaPrge.form.edtVpnPswdIdnty00.set_value('');
		}
	}
};

/**
 * @description 비밀번호 확인값 초기화
 */
this.editVpnPswd_onkillfocus = function(obj:nexacro.Edit,e:nexacro.KillFocusEventInfo)
{
	if(obj.id == 'edtVpnPswd'){
		this.divCoaPrge.form.edtVpnPswd00.set_value('');
	}else if(obj.id == 'edtVpnPswdIdnty'){
		this.divCoaPrge.form.edtVpnPswdIdnty00.set_value('');
	}
};

/**
 * @description 비밀번호 이전값 저장
 */
this.divCoaPrge_edtVpnPswd_onkeydown = function(obj:nexacro.Edit,e:nexacro.KeyEventInfo)
{
	this.fvPswdOld = obj.value;
};

