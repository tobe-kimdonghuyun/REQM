				                       ,  signKey   : this.edtCancelSignKey.value   // 각 시도별 signKey(java로직에서 로컬,개발,테스트에서는 테스트용 값이 자동으로 들어가도록 설정 되있음)
				                       ,  mid       : this.edtCancelMid.value       // 각 시도별 mid(java로직에서 로컬,개발,테스트에서는 테스트용 값이 자동으로 들어가도록 설정 되있음)
				                       ,  clientIp  : this.edtCancelCleintIp.value  // 취소요청을하는 서버 IP(공백으로 넣을 경우 서버 IP를 java에서 파싱하여 넣도록 되어 있음)
				                       ,  msg       : this.edtCancelMsg.value       // 취소요청 사유(default : 취소)
						   
				                     }
	               };
	this.smfExecPayCancelKGINI(objParam);

};


//====================이 아래 부분은 공통함수로 이동예정 =======

/**
 * @class 결제취소연동(KCP)을 실행한다.	
 * @example
 */
this.smfExecPayCancelKCP = function(objParam)
{
	var objForm = objParam.objForm;
	var oServiceDs = objForm["dsService"];
	
	// 서비스정의 데이터셋이 있는 지 확인 (없으면 에러가 남.)
	if(!oServiceDs)
	{
		oServiceDs = new Dataset();
		objForm.addChild("dsService",oServiceDs);
		// 컬럼도 만들어야 하는 지 확인 필요
		oServiceDs.addColumn("id"               ,"string");
		oServiceDs.addColumn("url"              ,"string");
		oServiceDs.addColumn("inDatasets"       ,"string");
		oServiceDs.addColumn("outDatasets"      ,"string");
		oServiceDs.addColumn("bindingControls"  ,"string");
		oServiceDs.addColumn("asynctp"          ,"string");
	}
	
	// input 데이터셋 생성(있으면 재활용)
	var sDsIn = "dsInPayCancelKcp";
	var oInDs =  objForm[sDsIn];

	if(!oInDs)
	{
		oInDs = new Dataset();
		objForm.addChild(sDsIn,oInDs);
		// 컬럼생성
		
		oInDs.addColumn("siteCd"   ,"string"); // 가맹점ID (default : T0000)
		oInDs.addColumn("tno"      ,"string"); // 거래번호 (default : 공백)
		oInDs.addColumn("payMehtod","string"); // 거래방식 (default : STSC)
		oInDs.addColumn("desc"     ,"string"); // 설명 (default : 취소)
	}
	
	// inputData clear 및 row 생성
	oInDs.clearData();
	oInDs.addRow();

   var sSiteCd    = this.smfNvl(objParam.cancel_info.siteCd   ,"");
   var sTno       = this.smfNvl(objParam.cancel_info.tno      ,"");
   var sPayMehtod = this.smfNvl(objParam.cancel_info.payMehtod,"");
   var sDesc      = this.smfNvl(objParam.cancel_info.desc     ,"");


	oInDs.setColumn(0,"siteCd"   ,sSiteCd   );
	oInDs.setColumn(0,"tno"      ,sTno      );
	oInDs.setColumn(0,"payMehtod",sPayMehtod);
	oInDs.setColumn(0,"desc"     ,sDesc     );
	
	var sServiceId = "selectCancelKcp";
	this.smfDynService(sServiceId,{
		id: sServiceId, 
		url: "cmc_fcm_pg_kcp_cancle.do",
		inDatasets: sDsIn+"="+sDsIn,
		outDatasets: "dsResult=result"
	})
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		// 저장이 완료되었습니다.
		if(objParam.callback)
		{
			objParam.callback.call(objForm,sServiceId,0,"SUCC");
		}
	});
}	

//this.fnTransCallback = function(svcid,errcd,errmsg){


/**
 * @class 결제취소연동(KCP)을 실행한다.	
 * @example
 */
this.smfExecPayCancelKGINI = function(objParam)
{
	var objForm = objParam.objForm;
	var oServiceDs = objForm["dsService"];
	
	// 서비스정의 데이터셋이 있는 지 확인 (없으면 에러가 남.)
	if(!oServiceDs)
	{
		oServiceDs = new Dataset();
		objForm.addChild("dsService",oServiceDs);
		// 컬럼도 만들어야 하는 지 확인 필요
		oServiceDs.addColumn("id"               ,"string");
		oServiceDs.addColumn("url"              ,"string");
		oServiceDs.addColumn("inDatasets"       ,"string");
		oServiceDs.addColumn("outDatasets"      ,"string");
		oServiceDs.addColumn("bindingControls"  ,"string");
		oServiceDs.addColumn("asynctp"          ,"string");
	}
	
	// input 데이터셋 생성(있으면 재활용)
	var sDsIn = "dsInPayCancelKgini";
	var oInDs =  objForm[sDsIn];

	if(!oInDs)
	{
		oInDs = new Dataset();
		objForm.addChild(sDsIn,oInDs);
		// 컬럼생성
		
		oInDs.addColumn("payMethod"   ,"string"); // 지불수단 코드
		oInDs.addColumn("tid"         ,"string"); // 결제 후 리턴되는 승인TID(결제후 리턴받는 tid값)
		oInDs.addColumn("signKey"     ,"string"); // 각 시도별 signKey(java로직에서 로컬,개발,테스트에서는 테스트용 값이 자동으로 들어가도록 설정 되있음)
		oInDs.addColumn("mid"         ,"string"); // 각 시도별 mid(java로직에서 로컬,개발,테스트에서는 테스트용 값이 자동으로 들어가도록 설정 되있음)
		oInDs.addColumn("clientIp"    ,"string"); // 취소요청을하는 서버 IP(공백으로 넣을 경우 서버 IP를 java에서 파싱하여 넣도록 되어 있음)
		oInDs.addColumn("msg"         ,"string"); // 취소요청 사유(default : 취소)
		
		
	}
	
	// inputData clear 및 row 생성
	oInDs.clearData();
	oInDs.addRow();

   var sPayMethod = this.smfNvl(objParam.cancel_info.payMethod,"");
   var sTid       = this.smfNvl(objParam.cancel_info.tid      ,"");
   var sSignKey   = this.smfNvl(objParam.cancel_info.signKey  ,"");
   var sMid       = this.smfNvl(objParam.cancel_info.mid      ,"");
   var sClientIp  = this.smfNvl(objParam.cancel_info.clientIp ,"");
   var sMsg       = this.smfNvl(objParam.cancel_info.msg      ,"");


	oInDs.setColumn(0,"payMethod" ,sPayMethod);
	oInDs.setColumn(0,"tid"       ,sTid      );
	oInDs.setColumn(0,"signKey"   ,sSignKey  );
	oInDs.setColumn(0,"mid"       ,sMid      );
	oInDs.setColumn(0,"clientIp"  ,sClientIp );
	oInDs.setColumn(0,"msg"       ,sMsg      );

	
	var sServiceId = "selectCancelKgini";
	this.smfDynService(sServiceId,{
		id: sServiceId, 
		url: "cmc_fcm_pg_kg_cancle.do",
		inDatasets: sDsIn+"="+sDsIn,
		outDatasets: "dsResult=result"
	})
	.run()
	.callback(function(callbackParams){
		if(callbackParams.errors) return;
		// 저장이 완료되었습니다.
		if(objParam.callback)
		{
			objParam.callback.call(objForm,sServiceId,0,"SUCC");
		}
	});
	
	
}	

this.smfExecPayKGINIOpen1 = function(objParam)
{
	var objFuncCallback   = objParam.popupcallback;
	var objForm = objParam.objForm;
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: objFuncCallback, // 콜백함수 지정
		sender: objForm, // sender 지정
		titlebar:false,  // 타이틀바를 표시하지 않는다.
		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정(필수)
			procType : "none",  // "none","search","insert","update","delete"
		    order_info : objParam.order_info   //  주문정보
		}
	};

	// 모달팝업 실행
	//this.smfDialog("_auto", "comm::comp_pay_kgini.xfdl", popupParams);

	// 모달팝업 실행
	this.smfOpen("_auto", "comm::comp_pay_kgini.xfdl", popupParams);
	
}

this.btnPayKgini00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objParam = {  objForm      : this
	               , popupcallback : this.fnPopupCallbackKgini
	               ,  order_info   : {
				                          oid         : this.edtOid.value          // 주문번호
				                       ,  goodname    : this.edtGoodname.value     // 상품명
				                       ,  price       : this.edtPrice.value        // 결제금액
				                       ,  buyername   : this.edtBuyername.value    // 주문자명
				                       ,  buyertel    : this.edtBuyertel.value     // 휴대폰번호
				                       ,  buyr_mail   : this.edtBuyeremail.value   // 주문자 E-mail
									   ,  gopaymethod : this.cboGopaymethod.value  // 결제수단
									   
									   // 아래의 값은 서비스를 통해 받은 값임
				                       ,  mid         : this.edtMid.value          
				                       ,  signKey     : this.edtSignKey.value          
				                       ,  mKey        : this.edtMKey.value         
				                       ,  timestamp   : this.edtTimestamp.value          
				                       ,  orderNumber : this.edtOrderNumber.value          
				                       ,  signature   : this.edtSignature.value          
						   
				                     }
	               };
	this.smfExecPayKGINI(objParam);
	//this.smfExecPayKGINIOpen(objParam);
};
]]></Script>
