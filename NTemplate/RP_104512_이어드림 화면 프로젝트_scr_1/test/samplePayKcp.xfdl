/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.samplePayKcp_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

}; 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	// 실패한 경우
	if(errcd<0)
	{
	}
	
	// 성공한 경우
	if(svcid=="selectCancelKcp")  // KCP 경제취소
	{
		if(this.dsResult)
		{
			var sDsData = this.dsResult.saveXML();
			this.txtResult.set_value(sDsData);
		}
	}
	else if(svcid=="selectCancelKgini") // Kgini 결제취소
	{
		if(this.dsResult)
		{
			var sDsData = this.dsResult.saveXML();
			this.txtResult00.set_value(sDsData);
		}
	}
}
/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	trace("===>this.fnPopupCallback : popup callback");
	var sLog = "";
	if(e.result)
	{
		var sData = e.data;
		var objData = JSON.parse(sData);  // 데이터를 JSON으로 변경한 것
		
		sLog += "처리결과 : [성공]\n";
		sLog += "data : ["+sData+"]";
		
		this.txtResult.set_value(sData);
	}
	else
	{
		var sData = e.data;
		var objData = JSON.parse(sData);  // 데이터를 JSON으로 변경한 것
		
		if(objData.res_cd=="3001")
		{  // 유저가 팝업을 강제 종료한 경우
			sLog += "처리결과 : [에러(유저강제종료)]\n";
			sLog += "data : ["+sData+"]";
			
			this.txtResult.set_value(sLog);			
		}
		else
		{
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+sData+"]";
			
			this.txtResult.set_value(sLog);			
		}
		
	}
};

/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallbackKgini = function(e, sender){
	trace("===>this.fnPopupCallbackKgini : popup callback");
	var sLog = "";
	if(e.result)
	{
		var sData = e.data;
		var objData = JSON.parse(sData);  // 데이터를 JSON으로 변경한 것
		
		sLog += "처리결과 : [성공]\n";
		sLog += "data : ["+sData+"]";
		
		this.txtResult00.set_value(sData);
	}
	else
	{
		var sData = e.data;
		var objData = JSON.parse(sData);  // 데이터를 JSON으로 변경한 것
		
		if(objData.res_cd=="1000")
		{  // 유저가 팝업을 강제 종료한 경우
			sLog += "처리결과 : [에러(유저강제종료)]\n";
			sLog += "data : ["+sData+"]";
			
			this.txtResult00.set_value(sLog);			
		}
		else
		{
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+sData+"]";
			
			this.txtResult00.set_value(sLog);			
		}
		
	}
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 
this.btnPayKcp_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objParam = {  objForm      : this
	               , popupcallback : this.fnPopupCallback
	               ,  order_info   : {
				                          ordr_idxx  : this.edtOrdr_idxx.value  // 주문번호
				                       ,  good_name  : this.edtGood_name.value  // 상품명
				                       ,  good_mny   : this.edtGood_mny.value   // 결제금액
				                       ,  buyr_name  : this.edtBuyr_name.value  // 주문자명
				                       ,  buyr_tel1  : this.edtBuyr_tel1.value  // 주문자 연락처1
				                       ,  buyr_tel2  : this.edtBuyr_tel2.value  // 휴대폰번호
				                       ,  buyr_mail  : this.edtBuyr_mail.value  // 주문자 E-mail
									   
				                       ,  site_cd    : this.edtSite_cd.value    // 가맹점CD
				                       ,  site_name  : this.edtSite_name.value  // 가맹점명
									   
				                       ,  payMethod  : this.cboPay_method.value  // 결제수단
				                     }
	               };
	this.smfExecPayKCP(objParam);
};


this.btnPayKgini_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objParam = {  objForm      : this
	               , popupcallback : this.fnPopupCallbackKgini
	               ,  order_info   : {
				                          oid         : this.edtOid.value          // 주문번호
				                       ,  goodname    : this.edtGoodname.value     // 상품명
				                       ,  price       : this.edtPrice.value        // 결제금액
				                       ,  buyername   : this.edtBuyername.value    // 주문자명
				                       ,  buyertel    : this.edtBuyertel.value     // 휴대폰번호
				                       ,  buyr_mail   : this.edtBuyeremail.value   // 주문자 E-mail
									   ,  gopaymethod : this.cboGopaymethod.value  // 결제수단
									   
									   // 아래의 값은 서비스를 통해 받은 값임
				                       ,  mid         : this.edtMid.value          
				                       ,  signKey     : this.edtSignKey.value          
				                       ,  mKey        : this.edtMKey.value         
				                       ,  timestamp   : this.edtTimestamp.value          
				                       ,  orderNumber : this.edtOrderNumber.value          
				                       ,  signature   : this.edtSignature.value          
						   
				                     }
	               };
	//this.smfExecPayKGINI(objParam);
	this.smfExecPayKGINIOpen(objParam);
	
};

this.btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSearchService("selectKGINI")
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.edtMKey.set_value       (this.dsInicisStlmInfo.getColumn(0,"mKey"        ));
			this.edtOrderNumber.set_value(this.dsInicisStlmInfo.getColumn(0,"orderNumber" ));
			this.edtSignature.set_value  (this.dsInicisStlmInfo.getColumn(0,"signature"   ));
			this.edtPrice.set_value      (this.dsInicisStlmInfo.getColumn(0,"price"       ));
			this.edtMid.set_value        (this.dsInicisStlmInfo.getColumn(0,"mid"         ));
			this.edtSignKey.set_value    (this.dsInicisStlmInfo.getColumn(0,"signKey"     ));
			this.edtTimestamp.set_value  (this.dsInicisStlmInfo.getColumn(0,"timestamp"   ));
		})
	
	
	
};



