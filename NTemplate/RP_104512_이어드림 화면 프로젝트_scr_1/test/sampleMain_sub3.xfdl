<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Main_sub3" width="1920" height="980" titletext="NEIS Story" background="#f5f5f5" onload="samplePortalResize" onsize="samplePortalResize_onsize">
    <Layouts>
      <Layout height="980" screenid="ScreenDeskTopP" width="1920">
        <Div id="div00" taborder="0" left="360" top="140" formscrolltype="none" width="1200" height="700" text="">
          <Layouts>
            <Layout>
              <ImageViewer id="img01" taborder="0" left="4" top="515" width="391" height="174" cssclass="display" image="url('imagerc::main/main_sub3_niceIntro_bg.png')" initvalueid="ivImgAccessibilityOn"/>
              <Static id="sta02" taborder="1" text="대한민국 교육의&#13;&#10;내일을 연결하다" left="0" top="528" width="570" height="110" cssclass="font42B" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta01" taborder="2" text="NEIS Story" left="0" top="475" width="120" height="30" cssclass="font20M,color2b72" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta03" taborder="3" text="고품질 교육서비스로 여는 스마트한 교육세상 나이스!" left="429" top="620" width="348" height="30" cssclass="font16B,color2b72" initvalueid="ivStcAccessibilityOn"/>
              <Static id="sta04" taborder="4" text="나이스 대국민서비스를 통해 학생은 스스로 성적과 학사일정을 확인할 수 있고 부모는 또, 누구나 쉽게 학교생활기록부,&#13;&#10;교육제증명을 발급받을 수 있습니다. 학교에서는 학생성적관리와 생활기록부, 교무업무를 편리하게, 교육청에서는 인사,&#13;&#10;급여 등 일반행정업무를 스마트하게 수행할 수 있습니다." left="429" top="520" width="738" height="90" cssclass="font16R" font="normal 400 16px/1.5 &quot;Noto Sans KR&quot;,&quot;NotoSansKR-Regular&quot;,&quot;Malgun Gothic&quot;,&quot;Arial&quot;,&quot;MS PGothic&quot;" initvalueid="ivStcAccessibilityOn"/>
              <ImageViewer id="img00" taborder="5" left="0" top="0" height="430" cssclass="Roundbox20" image="url('imagerc::main/main_sub2_intro.png')" width="1200" initvalueid="ivImgAccessibilityOn"/>
              <Static id="staGuide00" taborder="6" text="h53" left="7" top="430" width="30" height="53" cssclass="sta_WF_Size" visible="false" initvalueid="ivStcAccessibilityOff"/>
              <Static id="staGuide01" taborder="7" text="h39" left="7" top="498" width="40" height="39" cssclass="sta_WF_Size" visible="false" initvalueid="ivStcAccessibilityOff"/>
