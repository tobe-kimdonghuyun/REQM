            </Layout>
          </Layouts>
        </Div>
        <Static id="main_title" taborder="1" text="폼 유효성검사 룰셋 동적 변경" left="10" top="10" width="270" height="26"/>
        <Grid id="grdValidationRulesetManage" taborder="2" left="10" top="50" width="815" height="190" showselection="true" cellsizingtype="both">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="105"/>
                <Column size="97"/>
                <Column size="108"/>
                <Column size="381"/>
                <Column size="110"/>
              </Columns>
              <Rows>
                <Row size="32" band="head"/>
                <Row size="32"/>
              </Rows>
              <Band id="head">
                <Cell text="rulesetName"/>
                <Cell col="1" text="rulesets"/>
                <Cell col="2" text="component"/>
                <Cell col="3" text="expression"/>
                <Cell col="4" text="serviceId"/>
              </Band>
              <Band id="body">
                <Cell text="bind:rulesetName" edittype="normal"/>
                <Cell col="1" text="bind:rulesets" edittype="normal"/>
                <Cell col="2" text="bind:component" edittype="normal"/>
                <Cell col="3" text="bind:expression" edittype="normal"/>
                <Cell col="4" text="bind:serviceId" edittype="normal"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Button id="btnSearch" taborder="3" text="searchNoRequired 룰셋 반영" left="141" top="246" width="195" height="34" onclick="btnSearch_onclick"/>
