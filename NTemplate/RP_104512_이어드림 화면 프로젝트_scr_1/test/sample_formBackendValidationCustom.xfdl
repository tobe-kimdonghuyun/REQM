<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sample_formBackendValidation" left="0" top="0" width="1240" height="930" titletext="유효성검사(다양한 옵션 확인)" onload="fnOnload">
    <Script type="xscript5.1"><![CDATA[// 콜백함수
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
};

// 폼 초기화 이벤트
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	
	// 폼 초기화
	this.smfInitForm(obj);
	
	this.dsSearch.addRow();
	this.dsMain.addRow();
	
	// 메뉴 초기화
	this.smfValidateService("validateMain", {
			url: "/cmc_sam_pl11_100.do",
		})
		// 서버의 search룰셋을 divMain에 매핑한다
		.mappingRulesetToForm(this.divMain, "search") 
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;

			// 서버로부터 받은 룰셋정보를 그리드에 표시한다
			// _dsValidationRulesetManage는 smfValidateService가 호출에 성공하면 내부적으로 자동생성된다
			this.grdValidationRulesetManage.set_binddataset(this._dsValidationRulesetManage.name);
		})
	;
}

// 룰셋반영 클릭
this.btnSearch00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfMappingRulesetToForm(this.divMain, "search", "validateMain");
};

// 룰셋반영 클릭
this.btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfMappingRulesetToForm(this.divMain, "searchNoRequired", "validateMain");
};



// function을 활용한 유효성검사 
// return이 true면 검증성공
// return이 String이면 검증실패및 메시지리턴
this.fnMyfunction = function(obj){
	if("400" == obj.value) return true;

	return "myfunction 항목은 400이어야 합니다";
};

this.divMain_btnSearch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSearchService("selectSearch")
		.validateForm(this.divMain)
		.beforeService(function(next){
			// next(); // 서버 통신 하지 않음
			alert("완료");
		})
		.run()
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.smfAlert("완료");
		})
		;
};

this.btnSearch00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 주민번호 컴포넌트에 search.rrn  룰셋을 적용한다
	this.smfMappingRulesetToComponent(this.divMain.form.mskRrn, "rrn", "search", "validateMain");
	alert("mskRrn.validate=" + this.divMain.form.mskRrn.validate);
};

this.btnSearch00_00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 주민번호 컴포넌트에 룰셋을 제거한다
	this.smfClearRulesetToComponent(this.divMain.form.mskRrn);
	alert("mskRrn.validate=" + this.divMain.form.mskRrn.validate);
};

this.btnSearch00_00_00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 유효성검사 룰셋을 설정한다
	this.smfUpdateValidateToComponent("title:분류코드명,required,maxlength:1", this.divMain.form.edtClsfCodeName);
	/*
	// 아래는 하나씩 설정하는 방법이며
	// 동작상 동일하다

	// 룰셋 제거
	this.smfClearRulesetToComponent(this.divMain.form.edtClsfCodeName);
	// 룰 추가
	this.smfInsertRuleToComponent("title:분류코드명", this.divMain.form.edtClsfCodeName);
	// 룰 추가
	this.smfInsertRuleToComponent("required", this.divMain.form.edtClsfCodeName);
	// 룰 추가
	this.smfInsertRuleToComponent("maxlength:1", this.divMain.form.edtClsfCodeName);
	*/
	alert("this.divMain.form.edtClsfCodeName.validate = " + this.divMain.form.edtClsfCodeName.validate);
};

this.btnSearch00_00_00_00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 유효성검사 룰셋을 제거한다
	this.smfClearRulesetToComponent(this.divMain.form.edtClsfCodeName);
};

this.btnSearch00_00_00_00_01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// required가 있는지 확인
	var isRequired = this.smfHasRuleInComponent("required", this.divMain.form.mskRrn);
	// required 추가/제거
	this.smfToggleRuleToComponent(! isRequired, "required", this.divMain.form.mskRrn);
	alert("this.divMain.form.mskRrn.validate = " + this.divMain.form.mskRrn.validate);
};

this.btnSearch00_00_00_00_01_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// required 추가
	this.smfInsertRuleToComponent("required", this.divMain.form.mskRrn);
	// maxlength 추가
	this.smfInsertRuleToComponent("maxlength:13", this.divMain.form.mskRrn);

	alert("this.divMain.form.mskRrn.validate = " + this.divMain.form.mskRrn.validate);
};

this.btnSearch00_00_00_00_01_00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// required 제거
	this.smfRemoveRuleFromComponent("required", this.divMain.form.mskRrn);
	// maxlength 제거
	this.smfRemoveRuleFromComponent("maxlength", this.divMain.form.mskRrn);
	
	alert("this.divMain.form.mskRrn.validate = " + this.divMain.form.mskRrn.validate);
};

this.btnSearch01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 룰셋클리어
	this.smfClearRulesetToForm(this.divMain);
};
]]></Script>
    <Layouts>
