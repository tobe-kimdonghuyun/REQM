<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sample_formBackendValidation" left="0" top="0" width="831" height="1000" titletext="UI 인풋 유효성검사" onload="fnOnload">
    <Script type="xscript5.1"><![CDATA[// 콜백함수
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
};

// 폼 초기화 이벤트
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼 초기화
	this.smfInitForm(obj);
	
	this.dsSearch.addRow();
	this.dsMain.addRow();
	
	this.smfValidateService("validateMain", {
			url: "/cmc_sam_pl11_100.do",
		})
		// 서버의 search룰셋을 divMain에 매핑한다
		.mappingRulesetToForm(this.divMain, "search") 
		.mappingRulesetToForm(this.divValidateNumbers, "numbers")
		.run()
		.callback(function(callbackParams){
		})
	; 	
}


// 조회버튼 클릭
this.Div00_btn_search_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{	
	// 서비스 객체 생성 
	this.smfSearchService("selectSearch")
		// 데이터 검증
		.validateForm(this.divMain) 
 
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			this.smfAlert("CM001");
		});
};


// function을 활용한 유효성검사 
// return이 true면 검증성공
// return이 String이면 검증실패및 메시지리턴
this.fnMyfunction = function(obj){
	if("400" == obj.value) return true;

	return "myfunction 항목은 400이어야 합니다";
};

// 검증버튼 클릭
this.div_validateNumbers_btn_search_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 서비스 객체 생성 
	this.smfSearchService("selectNumbers")
		// 데이터 검증
		.validateForm(this.divValidateNumbers) 
 
		// 실행
		.run()

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;

			this.smfAlert("CM001");
		});
};
]]></Script>
