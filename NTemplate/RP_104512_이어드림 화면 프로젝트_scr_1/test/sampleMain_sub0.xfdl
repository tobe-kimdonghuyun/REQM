<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Main_sub0" width="1920" height="1080" titletext="Main_sub0" scrolltype="none" scrollbartype="none none" onsize="Main_sub0_onsize">
    <Layouts>
      <Layout height="1080" width="1920" screenid="ScreenDeskTopP">
        <Div id="divSub" taborder="0" left="0" top="0" height="727" right="0" url="test::sampleMain_sub0_d1.xfdl" formscrolltype="none" initvalueid="ivDivAccessibilityOn" formscrollbartype="none none"/>
        <Div id="divContents" taborder="1" left="0" top="727" height="353" right="0" url="test::sampleMain_sub0_contents.xfdl" formscrolltype="none" text=""/>
        <Div id="div00" taborder="2" left="360" top="676" width="1200" height="100" url="test::sampleMain_sub0_btnGroup.xfdl" cssclass="div_main_shadowBox_C"/>
        <Button id="btnMysetting" taborder="3" text="나의 서비스 설정" left="div00:-158" top="632" width="150" height="30" cssclass="btn_main_sub0_mySetting" icon="url('imagerc::main/main_mySetting.png')" initvalueid="ivBtnAccessibilityButton"/>
        <Static id="staTooltip" taborder="4" text="나의 관심 서비스를 먼저 표시할 수 있어요!" left="btnMysetting:-196" top="579" width="241" height="47" cssclass="sta_main_sub0_tooltip" background="url('imagerc::main/main_sub0_tootipTail.png') no-repeat center bottom transparent" initvalueid="ivStcAccessibilityOn"/>
        <Static id="Static01_00" taborder="5" text="btnMysetting, staTooltip 도 &#13;&#10;div00의 Right에 붙어서 &#13;&#10;원할하게 붙어다녔으면 좋겠습니다." left="1384" top="499" width="213" height="70" cssclass="sta_WF_Size" padding="10px" textAlign="left" verticalAlign="top" initvalueid="ivStcAccessibilityOff" visible="false"/>
        <ImageViewer id="imgMouse" taborder="6" left="917" top="580" width="86" height="73" cssclass="display" stretch="fixaspectratio" image="url('imagerc::main/mouse.gif')"/>
        <Static id="staGuide00" taborder="7" text="imgMouse를 센터정렬 시켜주세요" left="973" top="484" width="213" height="70" cssclass="sta_WF_Size" padding="10px" textAlign="left" verticalAlign="top" initvalueid="ivStcAccessibilityOff" visible="false"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
/**
 * @description 사이즈 변경시 위치변경(컴포넌트 아이디 변경 시 수정)
*/
this.Main_sub0_onsize = function(obj:nexacro.Form,e:nexacro.SizeEventInfo)
{
	var nAllWidth = this.width;  // 전체 form의 사이즈
	var nMaxWidth = this.div00.getOffsetWidth();
	var nLeft,nLeft2,nWidth;
		
	nLeft = parseInt((nAllWidth - nMaxWidth) / 2);	
	nLeft2 = parseInt((nAllWidth - this.imgMouse.getOffsetWidth()) / 2);
	
	this.div00.setOffsetLeft(nLeft);
	
	this.imgMouse.setOffsetLeft(nLeft2);
};
]]></Script>
  </Form>
</FDL>
