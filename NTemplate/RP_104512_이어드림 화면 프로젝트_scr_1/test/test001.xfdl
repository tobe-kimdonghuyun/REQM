	var sParam = "svcId='' voId='' method=''";
	this.transaction("test",sUrl,inds,outds,sParam,"fnTransCallback",true,"0","false");
};

this.btn03_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSetHttpTimeOut(1000);
	var sUrl = 'baseUrl::/pas_mms_cm00_002.do';
	//var sUrl = 'baseUrl::nxui/local2.xml';
