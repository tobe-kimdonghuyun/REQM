/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.test001_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.smfInitForm(this);
	
	
	
}; 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{
	//trace("@@ this.dsEvlprList.rowcount="+this.dsEvlprList.rowcount);
	this.smfSetDefaultHttpTimeOut();
}
/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
trace("=====>");
};
/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/

this.btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.smfSearchService("list")
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams) {
			if(callbackParams.errors) return; 
			
			trace(" $$ this.dsEvlprList.rowcount="+this.dsEvlprList.rowcount);
		});
};

this.btn01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var sUrl = 'baseUrl::/eds_tad_os04_003.do';
	var inds = 'dsSearch=dsSearch';
	//var outds = 'dsResult=dsResult dsApiResponseList=dsApiResponseList dsStuList=dsStuList dsEvlList=dsEvlList dsEvlRndList=dsEvlRndList dsTchChrgeSbjtList=dsTchChrgeSbjtList dsTchList=dsTchList dsEvlprList=dsEvlprList dsEvlprQuitmList=dsEvlprQuitmList dsEaipDscrpEvlprQuitmList=dsEaipDscrpEvlprQuitmList dsEvlprDscrpQuitmList=dsEvlprDscrpQuitmList dsEvlYdstkList=dsEvlYdstkList dsTmprStrgAnsList=dsTmprStrgAnsList dsTmprStrgDscrpAnsList=dsTmprStrgDscrpAnsList dsTmprStrgDscrpAnsList=dsTmprStrgDscrpAnsList dsTmprTchIduQuitmList=dsTmprTchIduQuitmList dsEvlQuitmAnsList=dsEvlQuitmAnsList dsQstnRspns=dsQstnRspns dsBasicQstnRspns=dsBasicQstnRspns dsEvlprQuitmListAll=dsEvlprQuitmListAll _dsBusinessMessage=businessMessage'
	var outds = 'dsEvlprList=dsEvlprList'
	var sParam = "svcId='' voId='' method=''";
	this.transaction("test",sUrl,inds,outds,sParam,"fnTransCallback",true,"0","false");
};

this.btn02_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
