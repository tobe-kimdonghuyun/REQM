<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sample_callService" width="1280" height="720" titletext="서버통신 샘플" onload="fnOnload" border="1px solid" onbeforeclose="sample_gridSave_onbeforeclose">
    <Layouts>
      <Layout height="720" width="1280">
        <Static id="staMain" taborder="0" text="사용자관리" left="10" cssclass="sta_Ctitle" top="-664" right="90" height="40"/>
        <Grid id="grdMain" taborder="1" top="170" height="540" binddataset="dsMain" autofittype="col" scrollbardecbuttonsize="0" scrollbarincbuttonsize="0" left="5" right="91" autoupdatetype="comboselect" autoenter="select" onheadclick="grdMain_onheadclick" oncellclick="grdMain_oncellclick">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="27"/>
                <Column size="48"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="34" band="head"/>
                <Row size="34"/>
              </Rows>
              <Band id="head">
                <Cell displaytype="checkboxcontrol" edittype="checkbox"/>
                <Cell col="1" text="순번"/>
                <Cell col="2" text="아이디"/>
                <Cell col="3" text="성명"/>
                <Cell col="4" text="아티스트"/>
                <Cell col="5" text="음반릴리즈"/>
                <Cell col="6" text="앨범타입"/>
                <Cell col="7" text="장르"/>
                <Cell col="8" text="등급"/>
                <Cell col="9" text="가격"/>
                <Cell col="10" text="다운로드횟수"/>
                <Cell col="11" text="청취횟수"/>
              </Band>
              <Band id="body">
                <Cell text="bind:_chk" displaytype="checkboxcontrol" edittype="checkbox" checkboxfalsevalue="0" checkboxtruevalue="1"/>
                <Cell col="1" text="expr:currow+1" textAlign="center"/>
                <Cell col="2" text="bind:id" edittype="none"/>
                <Cell col="3" text="bind:name" edittype="text" editautoselect="false"/>
                <Cell col="4" text="bind:artist" edittype="text" editautoselect="false"/>
                <Cell col="5" text="bind:release" edittype="date" editautoselect="true" displaytype="date" calendareditformat="yyyy.MM.dd" calendarautoselect="true" calendardisplayinvalidtype="none" calendardisplaynulltype="none" calendardateformat="yyyy.MM.dd"/>
                <Cell col="6" text="bind:typeCode" edittype="text" editautoselect="true" combodataset="dsTypeCode" combocodecol="cdcValue" combodatacol="cdcValueNm"/>
                <Cell col="7" text="bind:genreCode" edittype="combo" editautoselect="true" displaytype="combocontrol" combodataset="dsGenreScCd2" combocodecol="cdcValue" combodatacol="cdcValueNm" combotype="filterlike"/>
                <Cell col="8" text="bind:grade" edittype="combo" editautoselect="true" combodataset="dsGrade" combocodecol="cdcValue" combodatacol="cdcValueNm" displaytype="combocontrol" combotype="filterlike"/>
                <Cell col="9" text="bind:price" edittype="text" editautoselect="true" displaytype="number" maskeditformat="###,##0"/>
                <Cell col="10" text="bind:downCnt" edittype="text" editautoselect="true" maskeditformat="###,##0" displaytype="number"/>
                <Cell col="11" text="bind:listenCnt" edittype="text" editautoselect="true" maskeditformat="###,##0" displaytype="number"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Div id="divSearch" taborder="2" left="5" top="61" width="1265" height="69">
          <Layouts>
            <Layout>
              <Static id="sta_01" taborder="7" left="129" top="6" cssclass="sta_WF_tablebg" width="265" height="34"/>
              <Static id="sta_02" taborder="0" text="사용자명" left="0" top="6" cssclass="sta_WF_tablelabel" width="130" height="34"/>
              <Static id="sta_03" taborder="2" text="아티스트" left="393" top="6" cssclass="sta_WF_tablelabel" width="130" height="34"/>
              <Static id="sta_04" taborder="8" left="522" top="6" cssclass="sta_WF_tablebg" width="225" height="34"/>
              <Edit id="edtName" taborder="1" text="-선택-" left="140" top="6" height="34" leftbase="" topbase="" bottombase="" rightbase="" widthbase="" heightbase="" innerdataset="@ds_dep" codecolumn="code" datacolumn="data" scrollbarbarminsize="20" value="" index="-1" scrollbarbaroutsize="20" scrollbarsize="10" scrollbartrackbarsize="25" itemheight="20" width="243"/>
              <Static id="sta_06" taborder="4" text="장르" left="746" top="6" cssclass="sta_WF_tablelabel" width="130" height="34"/>
              <Static id="sta_16" taborder="9" left="875" top="6" cssclass="sta_WF_tablebg" width="225" height="34"/>
              <Combo id="cboGenreCode" taborder="5" top="6" height="34" leftbase="" topbase="" bottombase="" rightbase="" widthbase="" heightbase="" right="172" width="203" innerdataset="dsGenreScCd" codecolumn="cdcValue" datacolumn="cdcValueNm"/>
              <Edit id="edtArtist" taborder="3" text="-선택-" left="530" top="6" height="34" leftbase="" topbase="" rightbase="" widthbase="" heightbase="" innerdataset="@ds_dep" codecolumn="code" datacolumn="data" value="" index="-1" scrollbarbaroutsize="20" scrollbarsize="10" scrollbartrackbarsize="25" itemheight="20" width="203" validate="maxlength:20"/>
              <Button id="btnSearch" taborder="6" text="검색" top="6" height="34" width="76" right="84" onclick="div_search_btn_search_onclick"/>
            </Layout>
          </Layouts>
        </Div>
        <Button id="btnSave" taborder="3" text="저장" top="125" height="34" width="76" right="496" onclick="btn_save_onclick"/>
        <Button id="btnDelete" taborder="4" text="삭제" top="125" height="34" width="76" right="95" onclick="btn_delete_onclick"/>
        <Button id="btnAdd" taborder="5" text="추가" top="125" height="34" width="76" right="576" onclick="btn_add_onclick" authActionType="C"/>
        <Button id="btn00" taborder="6" text="조회(command 예제)" left="1010" top="26" width="176" height="31" onclick="btn00_onclick"/>
        <Button id="btnExecute" taborder="7" text="처리(저장)" top="125" height="34" width="96" right="172" onclick="btnExecute_onclick"/>
        <Button id="btnSaveWithModifiedMessage" taborder="8" text="저장 메시지 변경된 저장" top="125" height="34" width="222" right="271" onclick="btnSaveWithModifiedMessage_onclick"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="dsOrdScCode" useclientlayout="true">
        <ColumnInfo>
          <ConstColumn id="firstCode" type="STRING" size="30" value=""/>
