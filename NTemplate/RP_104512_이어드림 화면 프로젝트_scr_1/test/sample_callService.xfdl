    <Script type="xscript5.1"><![CDATA[/**
*  @MenuPath    서버통신 샘플
*  @FileName 	sample_callService
*  @Creator 	문호상
*  @CreateDate 	2022.01.02
*  @Desction    서버통신 예제
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
*  2022.01.02     	문호상 	               최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/


/***********************************************************************************************
* FORM EVENT 영역(onload)
/***********************************************************************************************/
/**
 * @description 화면 onload시 처리내역(필수)
*/
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);
};

/************************************************************************************************
* TRANSACTION 서비스 호출 처리
************************************************************************************************/

/**
 * @description 조회 버튼 클릭
*/
this.div_search_btn_search_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 아래 주석처리된 메소드는 
	// 필요에 따라 주석 해제하여 사용하면 된다

	// 서비스 객체 생성
	this.smfSearchService("list")
		// 메시지 prefix 지정
		//         기본적으로 serviceId의 prefix에 따라 결정된다(여기서는 "list")
		//         "validate": "검증", 
		//         "check": "조건확인", 
		//         "insert": "등록", 
		//         "select": "조회", 
		//         "list": "조회", 
		//         "update": "수정", 
		//         "delete": "삭제", 
		//         "save": "저장", 
		//         "execute": "실행", 
		//         "preview": "미리보기", 
		//         "print": "출력", 
		//         "code": "코드조회"		
		// .messagePrefix("조회")
		
		
		
		// 사용자에게 confirm메시지를 표시할지 여부
		//         호출하지 않으면 함수에 따라 기본설정이 적용된다
		//         기본 false ->  smfSearchService, smfPrintService, smfDynService
		//         기본 true -> smfSaveService, smfExecuteService, smfDeleteService
		// .showConfirm(true)
		
		

		// 페이징처리
		// .paginator(this.grdMain, this.divPaginator, this.divPageSummary, this.dsPageInfo, obj, e)
		
		
	
		// (권장) 데이터가 변경되었으면 확인메시지
		.confirmIfModifiedGrid(this.grdMain) // 그리드 감지
		
		

		// 데이터가 변경되었으면 확인메시지
		// .confirmIfModifiedDataset(this.dsMain) // 데이터셋 감지
		
		

		// (필수) 폼 유효성검사
		.validateForm(this.divSearch)
		
		

		// (필수) 그리드 유효성검사
		// 데이터 검증
		// dsMainValid의 row는 2개가 있는데
		// 첫번째는 Dataset.ROWTYPE_INSERT에 해당하는 유효성검사 룰셋을 담당한다
		// 두번째는 Dataset.ROWTYPE_UPDATE에 해당하는 유효성검사 룰셋을 담당한다
		// 컬럼값에 = 은 INSERT와 동일한 룰셋을 사용한다는 의미이다
		// .validateGrid(this.grdMain, this.dsMainValid)


		// (필수) 실행
		.run()

		// (필수) 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		})
	;
};

/**
 * @description 저장버튼 클릭 
*/
this.btn_save_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 아래 주석처리된 메소드는 
	// 필요에 따라 주석 해제하여 사용하면 된다

	// 서비스 객체 생성 
	this.smfSaveService("save")
		// 메시지 prefix 지정
		//         기본적으로 serviceId의 prefix에 따라 결정된다(여기서는 "save")
		//         "validate": "검증", 
		//         "check": "조건확인", 
		//         "insert": "등록", 
		//         "select": "조회", 
		//         "list": "조회", 
		//         "update": "수정", 
		//         "delete": "삭제", 
		//         "save": "저장", 
		//         "execute": "실행", 
		//         "preview": "미리보기", 
		//         "print": "출력", 
		//         "code": "코드조회"		
		// 메시지 prefix 지정
		// .messagePrefix("저장")
		
		
		
		// 사용자에게 confirm메시지를 표시할지 여부
		//         호출하지 않으면 함수에 따라 기본설정이 적용된다
		//         기본 false ->  smfSearchService, smfPrintService, smfDynService
		//         기본 true -> smfSaveService, smfExecuteService, smfDeleteService
		// .showConfirm(true)  
		
		

		// (권장) 데이터 존재 필수
		//         저장할 데이터가 있는지 검증한다
		.requireExistsData(this.dsMain) 

		// 데이터 변경 필수
		.requireModifredData(this.dsMain)


		// (필수) 폼 유효성검사
		// .validateForm(this.divSearch)

		// (필수) 그리드 유효성검사
		//         dsMainValid의 row는 2개가 있는데
		//         첫번째는 Dataset.ROWTYPE_INSERT에 해당하는 유효성검사 룰셋을 담당한다
		//         두번째는 Dataset.ROWTYPE_UPDATE에 해당하는 유효성검사 룰셋을 담당한다
		//         컬럼값에 = 은 INSERT와 동일한 룰셋을 사용한다는 의미이다
		// .validateGrid(this.grdMain, this.dsMainValid)

		// 그리드 영역에서 중복검사
		.validateDuplicate({
			grid: this.grdMain,
			// gridText: "음반목록",
			columnNames: ["name", "artist", "release"], // 중복검사할 컬럼명
			columnText: "이름, 아티스트, 출시일자",
		})

		// (필수) 실행
		.run()

		// (필수) 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			// 저장이 완료되었습니다.
			this.smfAlert('CM002', [], this.div_search_btn_search_onclick);
		})
	;

};

/**
 * @description 삭제 버튼 클릭
*/
this.btn_delete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 아래 주석처리된 메소드는 
	// 필요에 따라 주석 해제하여 사용하면 된다

	// 삭제처리
	this.smfDeleteService("delete")
		// 메시지 prefix 지정
		//         기본적으로 serviceId의 prefix에 따라 결정된다(여기서는 "delete")
		//         "validate": "검증", 
		//         "check": "조건확인", 
		//         "insert": "등록", 
		//         "select": "조회", 
		//         "list": "조회", 
		//         "update": "수정", 
		//         "delete": "삭제", 
		//         "save": "저장", 
		//         "execute": "실행", 
		//         "preview": "미리보기", 
		//         "print": "출력", 
		//         "code": "코드조회"		
		// 메시지 prefix 지정
		// .messagePrefix("삭제")
		
		
		
		// 사용자에게 confirm메시지를 표시할지 여부
		//         호출하지 않으면 함수에 따라 기본설정이 적용된다
		//         기본 false ->  smfSearchService, smfPrintService, smfDynService
		//         기본 true -> smfSaveService, smfExecuteService, smfDeleteService
		// .showConfirm(true)
		
		
		
		// (필수) 데이터 존재 필수
		.requireExistsData(this.dsMain) 
		
		// 업무규칙에 따라 한건씩만 삭제할 수 있도록 처리
		.command(function(next){
			var checkedRowCount = this.dsMain.getCaseCount("_chk == '1'");
			if(checkedRowCount > 1){
				this.smfAlert("1건씩 삭제할 수 있습니다");
				return;
			}
			// next를 호출하여 진행
			next();
		})

		// (필수) 그리드 삭제 유효성검사
		.validateGridDelete(this.grdMain, this.dsMainValid)
		

		// (필수) 폼 삭제 유효성검사		
		// .validateFormDelete(this.divMain)
		

		// (필수) 실행
		.run()

		// (필수) 콜백
		.callback(function(callbackParams){ 
			if(callbackParams.errors) return;
			
			// 삭제하였습니다 알림 후 재조회
			this.smfLiteralAlert(this.smfAfterServiceMessage(), this.div_search_btn_search_onclick);
			alert('[참고] 본 샘플에서 데이터 삭제는 서버에서 동작하지 않도록 처리하였습니다');
		})
	;
};


/**
 * @description 처리(저장)
*/
this.btnExecute_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 아래 주석처리된 메소드는 
	// 필요에 따라 주석 해제하여 사용하면 된다


	// 일괄처리, 수행, 처리를 이용하려면 
	// smfExecuteService를 사용한다	
	
	// 서비스 객체 생성 	
	this.smfExecuteService("execute")
		// 메시지 prefix 지정
		//         기본적으로 serviceId의 prefix에 따라 결정된다(여기서는 "save")
		//         "validate": "검증", 
		//         "check": "조건확인", 
		//         "insert": "등록", 
		//         "select": "조회", 
		//         "list": "조회", 
		//         "update": "수정", 
		//         "delete": "삭제", 
		//         "save": "저장", 
		//         "execute": "실행", 
		//         "preview": "미리보기", 
		//         "print": "출력", 
		//         "code": "코드조회"		
		// 메시지 prefix 지정
		.messagePrefix("사용자 일괄 등록처리")

		
		
		
		// 사용자에게 confirm메시지를 표시할지 여부
		//         호출하지 않으면 함수에 따라 기본설정이 적용된다
		//         기본 false ->  smfSearchService, smfPrintService, smfDynService
		//         기본 true -> smfSaveService, smfExecuteService, smfDeleteService
		// .showConfirm(true)
		
		
		// (권장) 폼 유효성검사
		// .validateForm(this.divSearch)

		// (권장) 그리드 유효성검사
		//         dsMainValid의 row는 2개가 있는데
		//         첫번째는 Dataset.ROWTYPE_INSERT에 해당하는 유효성검사 룰셋을 담당한다
		//         두번째는 Dataset.ROWTYPE_UPDATE에 해당하는 유효성검사 룰셋을 담당한다
		//         컬럼값에 = 은 INSERT와 동일한 룰셋을 사용한다는 의미이다
		// .validateGrid(this.grdMain, this.dsMainValid)

		// 데이터 변경 필수
		.requireModifredData(this.dsMain)
		 
		// 서버통신 직전 호출된다. next를 호출하면 서버통신을 진행한다
		.beforeService(function(next){
			this.smfAlert('처리완료'); 
			// next();
		})

		// (필수) 실행
		.run() 

		// (필수) 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			// 저장이 완료되었습니다.
			this.smfAlert('CM002', [], this.div_search_btn_search_onclick);
		})
	;
};

/**
 * @description command 예제
*/
this.btn00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// command의 활용
	// smfSearchService이외의 호출에도 사용가능
	
	// 서비스 객체 생성
	this.smfSearchService("list")	
		// 데이터가 변경되었으면 확인메시지
		.confirmIfModifiedGrid(this.grdMain) // 그리드 감지

		// 폼 유효성검사
		.validateForm(this.divSearch)
		
		// 업무처리 함수
		// 주로 추가적인 유효성검사를 수행하는데 사용한다
		// next() 함수를 호출해야 다음 단계가 진행된다		
		.command(function(next){
			if(this.isNil(this.divSearch.form.edtName.value) && this.isNil(this.divSearch.form.edtArtist.value)){
				this.smfAlert("사용자 명 또는 아티스트를 입력하세요");
				return;
			}

			next();
		})

		// 업무처리 함수
		// 주로 추가적인 유효성검사를 수행하는데 사용한다
		// next() 함수를 호출해야 다음 단계가 진행된다		
		.command(function(next){
		
		
			this.smfConfirm("진행하시겠습니까?", function(confirmParams){
				if(confirmParams.confirmResult){
					next();
				}
			});
		})
		
		// 업무처리 함수
		// 주로 추가적인 유효성검사를 수행하는데 사용한다
		// next() 함수를 호출해야 다음 단계가 진행된다		
		.command(function(next){
			this.smfConfirm("정말 고?", function(confirmParams){
				if(confirmParams.confirmResult){
					next();
				}
			});
		})

		// (필수) 실행
		.run()

		// (필수) 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		})
	;	
};


/**
 * @description 저장클릭
*/
this.btnSaveWithModifiedMessage_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 서비스 객체 생성 
	this.smfSaveService("save")
		// 메시지 prefix 지정
		.messagePrefix("내 가수 정보를 갱신") // -> requireExistsData -> 내 가수 정보를 갱신할 데이터가 없습니다
		
		
		// 사용자에게 confirm메시지를 표시할지 여부
		// 아래 command를 이용하여 메시지를 지정한다
		.showConfirm(false)  

		// (권장) 데이터 존재 필수
		//         저장할 데이터가 있는지 검증한다
		.requireExistsData(this.dsMain) 
		
		// 데이터 변경 필수
		.requireModifredData(this.dsMain)


		// (필수) 폼 유효성검사
		// .validateForm(this.divSearch)

		// (필수) 그리드 유효성검사
		//         dsMainValid의 row는 2개가 있는데
		//         첫번째는 Dataset.ROWTYPE_INSERT에 해당하는 유효성검사 룰셋을 담당한다
		//         두번째는 Dataset.ROWTYPE_UPDATE에 해당하는 유효성검사 룰셋을 담당한다
		//         컬럼값에 = 은 INSERT와 동일한 룰셋을 사용한다는 의미이다
		// .validateGrid(this.grdMain, this.dsMainValid)

		// 그리드 영역에서 중복검사
		.validateDuplicate({
			grid: this.grdMain,
			// gridText: "음반목록",
			columnNames: ["name", "artist", "release"], // 중복검사할 컬럼명
			columnText: "이름, 아티스트, 출시일자",
		})
		
		// 사용자에게 confirm메시지 표시
		.command(function(next){
			this.smfConfirm("내 가수의 정보를 갱신하시겠습니까?", function(confirmParams){
				if(confirmParams.confirmResult){
					// 진행
					next();
				}
			});
		})

		// (필수) 실행
		.run()

		// (필수) 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			// 저장이 완료되었습니다.
			this.smfAlert('CM002', [], this.div_search_btn_search_onclick);
		})
	;	
};



/************************************************************************************************
 * CALLBACK 콜백 처리부분
 ************************************************************************************************/

/**
 * @description 서비스 콜백
 * @param : svcid - 서비스ID
 * @param : errcd - 에러코드
 * @param : errmsg - 에러메시지
 */
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd <= -1) return;
	
};

 /************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/**
 * 그리드 체크박스 enable 처리
 * @param : ds - 데이터셋
 * @param : nRow - rowposition
 */
this.fnRenderGridCheckbox = function(ds, nRow){
	// 아이유는 삭제 못함
    return this.dsMain.getColumn(nRow, "artist") != "아이유";
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/



/**
 * @description 버튼 추가 이벤트
*/
this.btn_add_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 조회를 수행했는지 검증후 그리드에 row를 추가한다
	var nRow = this.smfAddGridRow(this.grdMain, "list");
	if(nRow == -1) return;
};



/**
 * @description 그리드 헤더 클릭
*/
this.grdMain_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
    var columnName = obj.getCellProperty("body",e.cell,"text");
	if ("bind:_chk" == columnName){
		this.smfToggleChkHeader(obj, e, this.fnRenderGridCheckbox);
	}else{
		// 정렬
		this.smfCheckAndSort(obj, e);
	}
};

/**
 * @description 폼 닫기전 이벤트
*/
this.sample_gridSave_onbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	// 변경내역이 발생한 경우 종료전 confirm수행
	return this.smfCloseFormConfirm(this.dsMain);
};

/**
 * @description 조회조건이 변경된 경우
*/
this.dsSearch_oncolumnchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	// 조회결과를 제거한다
	this.smfClearDataByService("list");
};


/**
 * @description 그리드 셀 클릭
*/
this.grdMain_oncellclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
	obj.dropdownCombo();
};

]]></Script>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.edtName" propid="value" datasetid="dsSearch" columnid="name"/>
      <BindItem id="item1" compid="divSearch.form.edtArtist" propid="value" datasetid="dsSearch" columnid="artist"/>
      <BindItem id="item2" compid="divSearch.form.cboGenreCode" propid="value" datasetid="dsSearch" columnid="genreCode"/>
    </Bind>
  </Form>
</FDL>
