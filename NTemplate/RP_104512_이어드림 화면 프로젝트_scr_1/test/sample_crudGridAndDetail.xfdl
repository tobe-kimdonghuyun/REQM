<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sample_crudGridAndDetail" width="1280" height="720" titletext="그리드 저장" onload="fnOnload" border="1px solid" onbeforeclose="sample_gridSave_onbeforeclose">
    <Layouts>
      <Layout height="720" width="1280">
        <Static id="sta_main" taborder="0" text="사용자관리" left="10" cssclass="sta_Ctitle" top="6" right="90" height="40"/>
        <Grid id="grdMain" taborder="1" top="170" height="240" binddataset="dsMain" autofittype="col" scrollbardecbuttonsize="0" scrollbarincbuttonsize="0" left="5" right="91" autoupdatetype="comboselect" autoenter="select" onheadclick="grd_main_onheadclick" readonly="false">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="27"/>
                <Column size="48"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
                <Column size="80"/>
              </Columns>
              <Rows>
                <Row size="34" band="head"/>
                <Row size="34"/>
              </Rows>
              <Band id="head">
                <Cell displaytype="checkboxcontrol" edittype="checkbox"/>
                <Cell col="1" text="순번"/>
                <Cell col="2" text="id"/>
                <Cell col="3" text="name"/>
                <Cell col="4" text="artist"/>
                <Cell col="5" text="release"/>
                <Cell col="6" text="typeCode"/>
                <Cell col="7" text="genreCode"/>
                <Cell col="8" text="grade"/>
                <Cell col="9" text="price"/>
                <Cell col="10" text="downCnt"/>
                <Cell col="11" text="listenCnt"/>
              </Band>
              <Band id="body">
                <Cell text="bind:_chk" displaytype="checkboxcontrol" edittype="checkbox" checkboxfalsevalue="0" checkboxtruevalue="1"/>
                <Cell col="1" text="expr:currow+1" textAlign="center" edittype="none"/>
                <Cell col="2" text="bind:id" edittype="none"/>
                <Cell col="3" text="bind:name" edittype="none" editautoselect="false"/>
                <Cell col="4" text="bind:artist" edittype="none" editautoselect="false"/>
                <Cell col="5" text="bind:release" edittype="none" editautoselect="true" displaytype="date" calendardateformat="yyyy.MM.dd" calendareditformat="yyyy.MM.dd" calendarautoselect="true" calendardisplayinvalidtype="none" calendardisplaynulltype="none"/>
                <Cell col="6" text="bind:typeCode" edittype="none" editautoselect="true" combodataset="dsTypeCode" combocodecol="cdcValue" combodatacol="cdcValueNm" displaytype="combotext"/>
                <Cell col="7" text="bind:genreCode" edittype="none" editautoselect="true" displaytype="combotext" combodataset="dsGenreScCd2" combocodecol="cdcValue" combodatacol="cdcValueNm" combotype="filterlike"/>
                <Cell col="8" text="bind:grade" edittype="none" editautoselect="true" combodataset="dsGrade" combocodecol="cdcValue" combodatacol="cdcValueNm" displaytype="combotext" combotype="filterlike"/>
                <Cell col="9" text="bind:price" edittype="none" editautoselect="true" displaytype="number" maskeditformat="###,##0"/>
                <Cell col="10" text="bind:downCnt" edittype="none" editautoselect="true" maskeditformat="###,##0" displaytype="number"/>
                <Cell col="11" text="bind:listenCnt" edittype="none" editautoselect="true" maskeditformat="###,##0" displaytype="number"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
