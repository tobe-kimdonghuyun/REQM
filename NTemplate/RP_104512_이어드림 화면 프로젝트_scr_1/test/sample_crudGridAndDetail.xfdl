    <Script type="xscript5.1"><![CDATA[// 서비스 콜백
this.fnTransCallback = function(svcid,errcd,errmsg){
	if(errcd == -1) return;
	
};

// 폼 로드
this.fnOnload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	this.smfInitForm(obj);

	// 서비스 객체 생성 
	this.smfValidateService("validateMain", { 
			url: "/cmc_sam_pl12_000.do",
		})
  		.mappingRulesetToForm(this.divSearch, "search")
  		.mappingRulesetToForm(this.divMain, "save")
		// [옵션] 룰셋정보를 커스텀하게 적용할수 있다
 		//.mappingRulesetCustom(function(rulesets, rulesetBinder){
			// 컴포넌트에 룰셋정보를 바인드
 			// rulesetBinder.bindComponent('search', 'artist', this.divSearch.form.edtName);			
			
			// 데이터셋 컬럼에 룰셋정보를 바인드
 			// rulesetBinder.bindColumn('save', 'name', this.dsMainValid, "name");
 		//}) 
		.callback(function(callbackParams){ 
		})
		.run()
	;
	
	
	////////////////////////////////////////////
	// 샘플용 함수
	this.smfSetFirstCode(this.dsGenreScCd);
	this.smfSetFirstCode(this.dsGenreScCd2); 
	this.smfSetFirstCode(this.dsGrade); 
	////////////////////////////////////////////
	
	// Grid Checkbox 활성화/활성화 제어
	this.smfUpdateRednerGridCheckbox(this.grdMain, 0, this.fnRenderGridCheckbox);
	
	// 조회 입력창에서 'Ctrl' + 'Enter' 키 입력시 조회수행 이벤트 설정
	this.smfBindEnterKeyToSearch(this.divSearch, this.divSearch.form.btnSearch);
	
	// 데이터 입력 창에서 'Ctrl' + 'Enter' 키 입력시 저장수행 이벤트 설정
	this.smfBindEnterKeyToSearch(this.divMain, this.btnSave);
};

// 그리드 체크박스 enable 처리
this.fnRenderGridCheckbox = function(ds, nRow){
	// 아이유는 삭제 못함
    return this.dsMain.getColumn(nRow, "artist") != "아이유";
};

// 조회 버튼 클릭
this.div_search_btn_search_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 서비스 객체 생성
	this.smfSearchService("list")
		// 변경이 발생한 경우 조회전 confirm수행
		.confirmIfModifiedGrid(this.grdMain)
		// 데이터 검증
		.validateForm(this.divSearch)
		// 실행
		.run()
		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
		})
	;
};

// 버튼 추가 이벤트
this.btn_add_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 조회를 먼저 했는지 검증
	// 유효성검사를 수행후에 그리드에 row를 추가한다
	var nRow = this.smfValidAndAddRow(this.grdMain, this.divMain, "list");
	if(nRow == -1) return;
};

// 저장버튼 클릭 
this.btn_save_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 서비스 객체 생성 
	this.smfSaveService("save")
		// 데이터 존재 필수
		.requireExistsData(this.dsMain)
		// 데이터 검증
		.validateForm(this.divMain)		
		// 데이터 변경 필수
		.requireModifredData(this.dsMain)

		// 중복검사
		.validateDuplicate({
			grid: this.grdMain,
			// gridText: "음반목록",
			columnNames: ["name", "artist", "release"], // 중복검사할 컬럼명
			columnText: "이름, 아티스트, 출시일자",
		})

		// 실행
		.run() 

		// 콜백
		.callback(function(callbackParams){
			if(callbackParams.errors) return;
			
			// 저장이 완료되었습니다.
			// 재조회
			this.smfAlert('CM002', [], this.div_search_btn_search_onclick);
		});
		
};

// 삭제 버튼 클릭
this.btn_delete_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 삭제처리
	this.smfDeleteService("delete")
		// 데이터 존재 필수
		.requireExistsData(this.dsMain)
		// 그리드삭제처리
		.validateGridDelete(this.grdMain)
		.run()
		// 콜백
		.callback(function(callbackParams){ 
			alert('[참고] 본 샘플에서 데이터 삭제는 서버에서 동작하지 않도록 처리하였습니다');
			if(callbackParams.errors) return;

			// 삭제하였습니다 알림 후 재조회
			this.smfLiteralAlert(this.smfAfterServiceMessage(), this.div_search_btn_search_onclick);
		})
};

// 그리드 헤더 클릭
this.grd_main_onheadclick = function(obj:nexacro.Grid,e:nexacro.GridClickEventInfo)
{
    var columnName = obj.getCellProperty("body",e.cell,"text");
	if ("bind:_chk" == columnName){
		this.smfToggleChkHeader(obj, e, this.fnRenderGridCheckbox);
	}else{
		// 정렬
		this.smfCheckAndSort(obj, e);
	}
};

// 폼 닫기전 이벤트
this.sample_gridSave_onbeforeclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	// 변경내역이 발생한 경우 종료전 confirm수행
	return this.smfCloseFormConfirm(this.dsMain);
};

// 조회조건이 변경된 경우
this.dsSearch_oncolumnchanged = function(obj:nexacro.NormalDataset,e:nexacro.DSColChangeEventInfo)
{
	// 조회결과를 제거한다
	this.smfClearGridData(this.grdMain);
};

// dsMain의 데이터 row 값이 변경될 경우
this.dsMain_canrowposchange = function(obj:nexacro.NormalDataset,e:nexacro.DSRowPosChangeEventInfo)
{
	return this.smfValidateRowChange(obj, e, this.divMain);
};
]]></Script>
    <Bind>
      <BindItem id="item0" compid="divSearch.form.edtName" propid="value" datasetid="dsSearch" columnid="name"/>
      <BindItem id="item1" compid="divSearch.form.edtArtist" propid="value" datasetid="dsSearch" columnid="artist"/>
      <BindItem id="item2" compid="divSearch.form.cboGenreCode" propid="value" datasetid="dsSearch" columnid="genreCode"/>
      <BindItem id="item3" compid="divMain.form.edtId" propid="value" datasetid="dsMain" columnid="id"/>
      <BindItem id="item4" compid="divMain.form.edtName" propid="value" datasetid="dsMain" columnid="name"/>
      <BindItem id="item5" compid="divMain.form.edtArtist" propid="value" datasetid="dsMain" columnid="artist"/>
      <BindItem id="item6" compid="divMain.form.mskPrice" propid="value" datasetid="dsMain" columnid="price"/>
      <BindItem id="item7" compid="divMain.form.mskDownCnt" propid="value" datasetid="dsMain" columnid="downCnt"/>
      <BindItem id="item8" compid="divMain.form.mskListenCnt" propid="value" datasetid="dsMain" columnid="listenCnt"/>
