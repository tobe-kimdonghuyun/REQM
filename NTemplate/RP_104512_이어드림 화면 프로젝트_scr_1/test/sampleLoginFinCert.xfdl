<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sampleLoginFinCert" width="1280" height="745" titletext="금융인증서를 통한 로그인 샘플" onload="sampleLoginFinCert_onload">
    <Layouts>
      <Layout height="745" width="1280">
        <Static id="sta00" taborder="0" text="금융인증서를 통한 로그인 샘플" left="29" top="28" width="611" height="60"/>
        <Button id="btnFinLogin" taborder="1" text="공동인증서 로그인" left="62" top="263" width="348" height="60" cssclass="btn_Login_PartyCert" initvalueid="ivBtnAccessibilityButton" onclick="btnFinLogin_onclick"/>
        <TextArea id="txt00" taborder="2" left="57" top="397" width="453" height="230"/>
        <Static id="sta01" taborder="3" text="실행결과 :" left="63" top="357" width="120" height="30"/>
        <Edit id="edt00_00" taborder="4" left="67" top="164" width="160" height="50" text="앞 6자리" initvalueid="ivEdtNormal" cssclass="edi_Login_Normal" displaynulltext="앞 6자리"/>
        <Static id="sta01_00" taborder="5" left="236" top="189" width="9" height="6" border="1px solid #afafaf, 0px none, 0px none, 0px none" initvalueid="ivStcAccessibilityOn"/>
        <Edit id="edt00_00_00" taborder="6" left="254" top="164" width="160" height="50" text="뒤 7자리" initvalueid="ivEdtNormal" cssclass="edi_Login_Normal" displaynulltext="뒤 7자리"/>
        <Static id="sta02_00" taborder="7" text="주민등록번호(외국인 등록번호)를 입력해주세요." left="67" top="218" width="333" height="26" cssclass="sta_Login_MemberNotice" initvalueid="ivStcAccessibilityOn" usedecorate="true"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  나이스 - 대국민
*  @MenuPath    샘플
*  @FileName 	sampleLoginFinCert.xfdl
*  @Creator 	정인혁
*  @CreateDate 	2022.12.2
*  @Desction    
************** 소스 수정 이력 ***********************************************
*  date          	Modifier            Description
*******************************************************************************
*  2022.12.2     	정인혁 	        최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.sampleLoginFinCert_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
}; 
/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/
this.fnTransCallback = function(svcid,errcd,errmsg)
{

}
/**
 * 팝업의 콜백함수 지정한다
 * @param : e - 팝업에서 전달한 파라메터
 * @param : sender - 팝업호출시 전달한 팝업호출객체
 */
this.fnPopupCallback = function(e, sender){
	trace("===>this.fnPopupCallback : popup callback");
	var sLog = "";
	if(e.result)
	{
		var sData = e.data;
		
		sLog += "처리결과 : [성공]\n";
		sLog += "data : ["+sData+"]";
		
		this.txt00.set_value(sLog);
	}
	else
	{
		var sData = e.data;
		var arrData = sData.split(":");
		
		if(arrData[0].trim()=="800000")
		{  // 유저가 팝업을 강제 종료한 경우
			sLog += "처리결과 : [에러(유저강제종료)]\n";
			sLog += "data : ["+sData+"]";
			
			this.txt00.set_value(sLog);			
		}
		else
		{
			sLog += "처리결과 : [에러]\n";
			sLog += "data : ["+sData+"]";
			
			this.txt00.set_value(sLog);			
		}
		
	}
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
 
this.btnFinLogin_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	// 테스트를 위해 실행결과를 지운다.
	this.txt00.set_value("");

	// 주민등록번호
	var sRrno = this.edt00_00.value + this.edt00_00_00.value;
	
	// 필요시, 주민등록필수여부 체크는 이부분에서 실시해주세요.(팝업에서는 실시하고 있지 않음.)
	
	// 팝업을 띄운다.
	var objParam = {objForm:this, popupcallback :this.fnPopupCallback, rrno : sRrno};
	this.smfExecFinAuth(objParam);
};
]]></Script>
  </Form>
</FDL>
