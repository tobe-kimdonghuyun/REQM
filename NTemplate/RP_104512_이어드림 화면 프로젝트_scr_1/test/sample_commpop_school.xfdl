<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sample_commpop_school" width="1050" height="818" titletext="학교찾기 팝업" onload="Form_onload">
    <Layouts>
      <Layout height="818" mobileorientation="landscape" width="1050">
        <Static id="sta02" taborder="0" text="학교찾기 팝업" left="20" top="17" width="221" height="33"/>
        <Static id="Static07" taborder="1" left="20" height="42" cssclass="sta_WF_Input02" top="138" right="275" text=""/>
        <Static id="Static10" taborder="2" left="20" width="140" height="42" cssclass="sta_WF_Input01, sta_WF_Red14" text="학교명" top="138"/>
        <Edit id="edtKornOrgNm" taborder="3" left="246" top="144" height="30" text="우리날" cssclass="essential" right="280" initvalueid="ivEdtReadOnly" readonly="false"/>
        <Static id="Static07_00" taborder="4" left="20" height="42" cssclass="sta_WF_Input02" top="188" right="275" text=""/>
        <Static id="Static10_00" taborder="5" left="20" width="140" height="42" cssclass="sta_WF_Input01, sta_WF_Red14" text="학교명" top="188"/>
        <Button id="btnFdSch2" taborder="6" text="학교찾기" left="165" top="193" width="76" height="30" cssclass="btn_WF_Custom" initvalueid="ivBtnAccessibilityLink" accessibilitylabel="신청자주소찾기" onclick="btnFdSch_onclick"/>
        <Edit id="edtKornOrgNm2" taborder="7" left="246" top="194" height="30" text="우리날" cssclass="essential" right="280" accessibilitylabel="신청자주소" initvalueid="ivEdtReadOnly" readonly="false"/>
        <Button id="btnFdSch" taborder="8" text="학교찾기" top="144" height="30" width="76" fittocontents="width" cssclass="btn_WF_Custom" visible="true" initvalueid="ivBtnAccessibilityLink" accessibilitylabel="학교찾기 (레이어팝업)" onclick="btnFdSch_onclick" left="164"/>
        <TextArea id="txtResultLog" taborder="9" left="21" top="306" width="753" height="260" readonly="true"/>
        <Static id="sta00" taborder="10" text="공통팝업에서 받은 데이터" left="22" top="267" width="218" height="39"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[/**
*  컨설팅 표준화 작업
*  @MenuPath    샘플 > test
*  @FileName 	sample_rdn_zip.xfdl 
*  @Creator 	
*  @CreateDate 	2022.06.14
*  @Desction    학교찾기팝업 샘플
************** 소스 수정 이력 ***********************************************
*  date          		Modifier                Description
*******************************************************************************
* 2022.01.04     	consulting 	                최초 생성 
*******************************************************************************
*/

/************************************************************************************************
 * include 영역(업무화면에서 꼭 필요한 경우에만 사용하세요)
 ************************************************************************************************/

/************************************************************************************************
 * FORM 변수 선언 영역
 ************************************************************************************************/

/************************************************************************************************
 * FORM EVENT 영역(onload, onbeforeclose)
 ************************************************************************************************/
this.Form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// 폼을 초기화
	//this.smfInitForm(obj);
};

/************************************************************************************************
 * CRUD 및 TRANSACTION 서비스 호출 처리
 ************************************************************************************************/


/************************************************************************************************
 * CALLBACK 콜백 처리부분(Transaction, Popup)
 ************************************************************************************************/

/************************************************************************************************
 * 사용자 FUNCTION 영역
 ************************************************************************************************/
/**
 * @description 학교찾기 콜백
 */
this.fnCommpopSchool = function(e, sender){
	//this.trace(this.smfDescComponent(e.row));

	var nRow = this.dsMain.rowposition;

	if(sender == this.btnFdSch){
		this.dsMain.setColumn(nRow, "kornOrgNm", e.row.kornOrgNm + " " + e.row.orgCd);
	}else if(sender == this.btnFdSch2){
		this.dsMain.setColumn(nRow, "kornOrgNm2", e.row.kornOrgNm + " " + e.row.orgCd);
	}
	
	// 그외 다른 정보를 trace()로 표시(개발용)
	var sLog = "";
	if(e.row)
	{
		for(var sKey in e.row)
		{
			var sValue = e.row[sKey];
			sLog += sKey + ":["+sValue+"]\n";
		}
	}
	this.txtResultLog.set_value(sLog);	
};

/************************************************************************************************
 * 각 COMPONENT 별 EVENT 영역
 ************************************************************************************************/
/**
* btnPopup_onclick : modal popup open
* @param  : obj		   - [object]Button
* @param  : e		   - [string]ClickEventInfo
* @return : N/A
*/
this.btnFdSch_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if(obj == this.btnFdSch){
		var kornOrgNm = this.edtKornOrgNm.value;
	}else if(obj == this.btnFdSch2){
		var kornOrgNm = this.edtKornOrgNm2.value;
	}
	
	// 팝업을 동작에 필요한 파라메터 지정
	var popupParams = {
		callback: this.fnCommpopSchool, // 콜백함수 지정
		sender: obj, // sender 지정

		// 팝업 전달 파라메터 지정
		params: {
			// 처리타입 지정
			procType: 'search',

			// 파라메터 전달 
			kornOrgNm: kornOrgNm,
		},
	};

	// 모달팝업 실행
	this.smfDialog("_auto", "commpop::commpop_school.xfdl", popupParams);
};
]]></Script>
    <Objects>
      <Dataset id="dsMain" onrowposchanged="dsMain_onrowposchanged" useclientlayout="true">
        <ColumnInfo>
          <Column id="kornOrgNm" type="STRING" size="256"/>
          <Column id="kornOrgNm2" type="STRING" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="kornOrgNm">경일고</Col>
            <Col id="kornOrgNm2"/>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Bind>
      <BindItem id="item0" compid="edtKornOrgNm" propid="value" datasetid="dsMain" columnid="kornOrgNm"/>
      <BindItem id="item1" compid="edtKornOrgNm2" propid="value" datasetid="dsMain" columnid="kornOrgNm2"/>
    </Bind>
  </Form>
</FDL>
