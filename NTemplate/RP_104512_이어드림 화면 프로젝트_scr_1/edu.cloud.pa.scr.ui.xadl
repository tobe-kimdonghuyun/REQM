<?xml version="1.0" encoding="utf-8"?>
<ADL version="2.0">
  <Application id="NEIS" screenid="desktopScr,mobileScr,tabletScr" onload="Application_onload" onerror="Application_onerror" licenseurl="license\NexacroN_client_license.xml">
    <Layout>
      <MainFrame id="mainframe" showtitlebar="false" showstatusbar="false" width="1436" height="950" titletext="학부모소통서비스(이어드림)" showtitleicon="false" showcascadetitletext="false" titlebarheight="40">
        <VFrameSet id="VFrameSet" separatesize="*" showtitlebar="false" showtitleicon="false">
          <Frames>
            <ChildFrame id="frameMain" showtitlebar="false" showstatusbar="false" showtitleicon="false" dragmovetype="none" formurl="frame::scr/frameMain.xfdl"/>
          </Frames>
        </VFrameSet>
      </MainFrame>
    </Layout>
  </Application>
