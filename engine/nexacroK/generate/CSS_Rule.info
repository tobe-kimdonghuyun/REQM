  --nexaicontext-text-align:center;																										
}																							
																																																																																													
.Sketch .nexacontentsbox																									
{																									
   text-align:center;																									
}																									
																									
.MainFrame, .VScrollBarControl, .HScrollBarControl																									
{																									
  cursor:default;																									
}																									
																									
