}																									

.FileDownload, .FileDownloadControl																									
{																									
  text-align:center;																									
  --nexaicontext-text-align:center;																								
}																																																																			

.IconTextControl, .IconControl																								
{																									
  text-align:center;																									
  --nexaicontext-text-align:center;																										
}

.DatePickerDayItemControl, .DatePickerWeekItemControl, .DatepickerYearItemControl, .TitleBarButtonControl																									
{																									
