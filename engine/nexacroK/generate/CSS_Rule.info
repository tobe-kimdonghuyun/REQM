      <Define name="HTML">																									
        <![CDATA[																									
.htmlhtml, .htmlbody
{
  position:absolute;
  width:100%;
  height:100%;
  font:12pt Verdana;

  -moz-user-select:none;
  -webkit-user-select:none;
  -ms-user-select:none;
}

.htmlcontrol
{
  position:absolute;
  box-sizing:border-box;
  overflow:hidden;
  background-origin:padding-box;
  background-repeat:no-repeat;
  white-space : pre;
  -moz-user-select:-moz-none;
  -webkit-user-select:none;
  -webkit-touch-callout:none;
  -webkit-appearance:none;
  -webkit-tap-highlight-color:rgba(0,0,0,0);
  outline:none;
}

.htmltable
{
  position:absolute;
  box-sizing:border-box;
  overflow:hidden;
}

.htmlinput
{
  position:absolute;
  box-sizing:border-box;
  overflow:hidden;
}

.htmlinput[type='number'] {																									
  -moz-appearance: textfield;																									
}		
.htmlinput::-webkit-inner-spin-button 
{
  appearance: none;
  -moz-appearance: none;
  -webkit-appearance: none;
}

.htmlimg
{
  position:absolute;
  box-sizing:border-box;
}

.htmllabel
{
  position:absolute;
  text-align:center;
  justify-content:center;
  overflow:hidden;
}

.htmli
{
  background-repeat:no-repeat;
  background-position:center center;
}

.shake {
  animation: shake 0.2s;
}

@keyframes shake {
  0% { transform: translateX(0); }
  25% { transform: translateX(-4px); }
  75% { transform: translateX(4px); }
  100% { transform: translateX(0); }
}

.htmltextarea::-webkit-scrollbar { display: none; }	

:dir(ltr)
{
	--nexa-dir-sign: 1;
	--nexa-dir-left: left;
	--nexa-dir-right: right;
}

:dir(rtl)
{
	--nexa-dir-sign: -1;
	--nexa-dir-left: right;
	--nexa-dir-right: left;
}																							
																									
]]>																									
      </Define>																									
      <Define name="ELEMENT">																									
        <![CDATA[																									
.nexacontainer																									
{																									
  position:absolute;																									
  inset-inline-start:0px;																									
  top:0px;																									
  width:100%;																									
  height:100%;																									
}																									
.nexacontainer.withvscroll																									
{																								
  inset-inline-end:14px;
}																									
.nexacontainer.withhscroll																									
{																									
  bottom:14px;																									
}																									
.nexacontainer.withbothscroll																									
{																									
  inset-inline-end:14px;																									
  bottom:14px;																									
}																									
																									
.nexalefttop																									
{																									
  inset-inline-start:0px;																									
  top:0px;																									
  background-repeat:no-repeat;																									
  background-position:calc(50% - 50% * var(--nexa-dir-sign)) top;																									
  font-size:1px;																									
}																									
.nexaleftbottom																									
{																									
  inset-inline-start:0px;																									
  bottom:0px;																									
  background-repeat:no-repeat;																									
  background-position:calc(50% - 50% * var(--nexa-dir-sign)) bottom;																									
  font-size:1px;																									
}																									
.nexarightbottom																									
{																									
  inset-inline-end:0px;																									
  bottom:0px;																									
  background-repeat:no-repeat;																									
  background-position:calc(50% + 50% * var(--nexa-dir-sign)) bottom;																									
  font-size:1px;																									
}																									
.nexarighttop																									
{																									
  inset-inline-end:0px;																									
  top:0px;																									
  background-repeat:no-repeat;																									
  background-position:calc(50% + 50% * var(--nexa-dir-sign)) top;																									
}																									
.nexaedge																									
{
  inset-inline-start:0px;
  top:0px;  
  width:100%;																									
  height:100%;																									
}																									
.nexamodaloverlay																									
{																									
  width:100%;																									
  height:100%;																									
}																																																																			
.nexacontentsbox																									
{																									
  position:relative;																									
  display:table-cell;																									
  background-position:calc(50% - 50% * var(--nexa-dir-sign)) center;																									
  background-repeat:no-repeat;																									
  vertical-align:middle;																									
}
																									
.nexacontentsboxflex																									
{																																																
  display: flex;																									
  background-position:calc(50% - 50% * var(--nexa-dir-sign)) center;																									
  background-repeat:no-repeat;																									
  align-items : center;					
  box-sizing:border-box;																									  
}
																									
.nexaflexitem			
{
  display:flex;
  position:relative;
  align-items:center;			
  justify-content:inherit;			
  flex-direction:inherit;
  white-space:inherit;
  word-wrap:inherit;
  word-break:inherit;
  min-width:0;
  max-width:100%;
  min-height:0;
  max-height:100%;
}

.nexatextitem[data-textoverflow="ellipsis"]
{
	white-space: no-wrap;
	text-overflow: ellipsis;
}

.nexaflexitem.column			
{			
  align-items:inherit;			
  justify-content:center;					
}		
			
.nexaicontext					
{					
  display:flex;					
  align-items:var(--nexaicontext-vertical-align, center);					
  justify-content:var(--nexaicontext-text-align, start);					
}					
					
.nexaicontext.reverse					
{					
  flex-direction:row-reverse;					
}					
					
.nexaicontext.column					
{
  flex-direction:column;					
  align-items:var(--nexaicontext-text-align, start);					
  justify-content:var(--nexaicontext-vertical-align, center);					
}					
					
.nexaicontext.column.reverse					
{					
  flex-direction:column-reverse;					
}					

.nexatextitem
{
  min-width:0;
  max-width:100%;
  min-height:0;
  max-height:100%;
  flex-shrink:1;
  flex-grow:0;
  overflow:hidden;
  box-sizing:border-box;
  position:relative;
  vertical-align:middle;
  white-space:inherit;
  word-wrap:inherit;
  word-break:inherit;
  text-decoration:inherit;
}
.nexaiconitem
{
  min-width:0;
  max-width:none;
  min-height:0;
  max-height:none;
  flex-shrink:0;
  flex-grow:0;
  position:relative;
  vertical-align:middle;
  background-position:center center;
  background-repeat:no-repeat;
}																				
																									
.nexainput																									
{																									
  font:inherit;																									
  color:inherit;																									
  cursor:inherit;																									
  letter-spacing:inherit;																									
  word-spacing:inherit;																									
  border:none;																									
  outline:none;																									
  background:transparent;																									
  padding : 0px;  																									
}																									
																									
.nexainput:-webkit-autofill 																									
{																									
	animation-name: nexainput_autofill;																								
}																									
																									
.nexainput:not(:-webkit-autofill) 																									
{																									
	animation-name: nexainput_notautofill;																								
}																									
																									
@keyframes nexainput_autofill { }																									
																									
@keyframes nexainput_notautofill { }																									
																									
.nexasimplecontainer:has([popover]) [popover],																									
.Form:has([popover]) [popover] {																									
	margin: unset;																								
	padding: unset;																								
	border: unset;
	background: unset;
}																									
																									
.WaitControl {																									
  background : transparent;																									
}																									
																									
.nexatextarea																									
{																									
  font:inherit;																									
  color:inherit;																									
  cursor:inherit;																									
  line-height : inherit;																									
  letter-spacing:inherit;																									
  word-spacing:inherit;																									
  white-space:pre;																									
  word-wrap:normal;																									
  border:none;																									
  outline:none;																									
  resize:none;																									
  background:transparent;																									
  padding : 0px;																									
  box-sizing:border-box;																									
}																									
																									
.nexaleftalign																									
{																									
  text-align:start;																									
  justify-content:flex-start;																									
}																									
																									
.nexarightalign																									
{																									
  text-align:end;																									
  justify-content:flex-end;																									
}																									
																									
.nexacenteralign																									
{																									
  text-align:center;																									
  justify-content:center;																									
}

.nexanativescroll
{
	scrollbar-width: none;
	overflow : scroll;
}

.nexasteprootcontainer 
{            
  overflow-x: scroll;
  overflow-y: hidden;
  scroll-snap-type: x mandatory;
  display: flex;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
  touch-action: manipulation;
}																						

.nexastepcontainer 
{
  overflow-x: hidden;
  overflow-y: auto;
  flex: 0 0 100%;  
  scroll-snap-align: start;
  scroll-snap-stop: always;
  position: relative;
}

.nexamap div *																									
{																									
  overflow:visible;																									
}																										
																									
.celltreeline																									
{																									
  border : 1px dotted #999999;																									
}																									
																									
.Edit, .MaskEdit, .TextArea, .EditControl, .MaskEditControl, .TextAreaControl																									
{																									
  cursor:text;																									
}

.Button, .ButtonControl																									
{																									
