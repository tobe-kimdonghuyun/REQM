        <Button id="Button09" taborder="38" text="setWheelZoom&#13;&#10;200%" left="1055" top="400" width="120" height="35" onclick="Button09_onclick"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[var app = nexacro.getApplication();
var env = nexacro.getEnvironment();

var objFrame = this.getOwnerFrame();

this.toggleRTL = function(obj)
{
	var rtl = obj.rtl;
	
	if(rtl == undefined)
		rtl = "rtl";
	else if(rtl == true)
		rtl = "ltr";
	else
		rtl = undefined;
	
	obj.rtl = rtl ? (rtl == "rtl" ? true : false) : undefined;
	
	this.TextArea01.insertText('### ' + obj.id + '.rtl = ' + obj.rtl + ' ###\n');
};

this.btnClear_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.TextArea01.value = "";
};


this.Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	nexacro.open('popup_A', 'FrameBase::Form_Work.xfdl');
};

this.Button02_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	nexacro.open('popup_B', 'FrameBase::Form_Work.xfdl');
};

this.doSomething = function()
{
	// window.document.title = "변경" + Date.now();
};

this.Form_Work_onactivate = function(obj:nexacro.Form,e:nexacro.ActivateEventInfo)
{
	// window.document.title = "활성화" + Date.now();
};

this.Form_Work_onrootcssclasschange = function(obj:nexacro.Form,e:nexacro.RootCssClassChangeEventInfo)
{
	this.TextArea01.insertText('### Form_Work_onrootcssclasschange ###\n' + '- precssclass: ' + e.precssclass + '\n- postcssclass: ' + e.postcssclass + '\n');
};

this.mcbo00_onitemchanged = function(obj:nexacro.MultiCombo,e:nexacro.ItemChangeEventInfo)
{
	app.xcssgroupfilter = this.mcbo00.value;
};

this.mcbo01_onitemchanged = function(obj:nexacro.MultiCombo,e:nexacro.ItemChangeEventInfo)
{
	app.xcssgroup = this.mcbo01.value;
};


this.Button03_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	app.xcssgroupfilter = "viewport,resolution,colorscheme,contrast";
};

this.Button04_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	app.xcssgroupfilter = "viewport,resolution,colorscheme,contrast,screen";
};

this.Button05_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	app.xcssgroupfilter = "";
};

this.Button06_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.toggleRTL(this);
};

this.Button07_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	nexacro.setWheelZoom(objFrame, 50);
};

this.Button08_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	nexacro.setWheelZoom(objFrame, 100)
};

this.Button09_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	nexacro.setWheelZoom(objFrame, 200)
};

this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	app.xcssgroup = 'Test';
};
]]></Script>
