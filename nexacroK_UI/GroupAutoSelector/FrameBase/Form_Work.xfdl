        <Button id="Button04" taborder="31" text="xcssgroupfilter&#13;&#10;= &quot;viewport,resolution,colorscheme,contrast,screen&quot;" left="745" top="155" width="373" height="50" onclick="Button04_onclick"/>
        <Button id="Button05" taborder="32" text="xcssgroupfilter&#13;&#10;= &quot;&quot;" left="1123" top="155" width="134" height="50" onclick="Button05_onclick"/>
