<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Static_Selectable_Sample00" width="1280" height="760" titletext="New Form">
    <Layouts>
      <Layout height="760" mobileorientation="landscape" width="1280">
        <Button id="Button00" taborder="1" text="px설정" left="1050" top="25" width="130" height="57" onclick="Button00_onclick"/>
        <Button id="Button07" taborder="7" text="%설정" left="875" top="25" width="130" height="57" onclick="Button07_onclick"/>
        <TextArea id="TextArea00" taborder="8" left="855" top="126" width="368" height="328"/>
        <Div id="Div00" taborder="7" text="Div00" left="30" top="30" width="unset" height="unset" cssclass="divCss00" onsize="Div00_onsize">
          <Layouts>
            <Layout>
              <Button id="Button00" taborder="0" text="Button00" left="0" top="0" width="unset" height="unset" cssclass="btnCss06" onsize="Div00_Button00_onsize"/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[this.Div00_onsize = function(obj:nexacro.Div,e:nexacro.SizeEventInfo)
{
	this.TextArea00.deleteText();
	this.TextArea00.value= " this.Div00 getOffsetWidth getOffsetHeight 정보"
							+ "\n this.Div00.width = "+this.Div00.width
		                      + "\n this.Div00.height = "+this.Div00.height
                          + "\n this.Div00.getOffsetWidth() = "+this.Div00.getOffsetWidth()
                          + "\n this.Div00.getOffsetHeight() = "+this.Div00.getOffsetHeight();
	trace(this.TextArea00.value);
};

this.Div00_Button00_onsize = function(obj:nexacro.Button,e:nexacro.SizeEventInfo)
{
	this.TextArea00.deleteText();
	this.TextArea00.value= " this.Div00_Button00 getOffsetWidth getOffsetHeight 정보"
							+ "\n this.Div00.form.Button00.width = "+this.Div00.form.Button00.width
		                      + "\n this.Div00.form.Button00.height = "+this.Div00.form.Button00.height
                          + "\n this.Div00.form.Button00.getOffsetWidth() = "+this.Div00.form.Button00.getOffsetWidth()
                          + "\n this.Div00.form.Button00.getOffsetHeight() = "+this.Div00.form.Button00.getOffsetHeight();
	trace(this.TextArea00.value);
};

this.Button07_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.Div00.form.Button00.width ="100%";
	this.Div00.form.Button00.height ="100%";
};

this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.Div00.form.Button00.width ="120px";
	this.Div00.form.Button00.height ="70px";
};
]]></Script>
  </Form>
</FDL>
