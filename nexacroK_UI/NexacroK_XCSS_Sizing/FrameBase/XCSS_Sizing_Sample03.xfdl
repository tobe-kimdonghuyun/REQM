<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Static_Selectable_Sample00" width="1280" height="720" titletext="New Form">
    <Layouts>
      <Layout height="720" mobileorientation="landscape" width="1280">
        <Button id="btn00" taborder="" text="default 생성 px" left="100" top="75" width="120" height="50"/>
        <Button id="btn01" taborder="1" text="properties에서 width height 값변경" left="100" top="140" width="150" height="100" wordWrap="english"/>
        <Button id="btn03" taborder="2" text="unset설정 후 cssclass로 지정된  값을 확인" left="400" top="140" width="150" height="100" wordWrap="english" cssclass="btnCss03"/>
        <Button id="btn02" taborder="3" text="default 생성 unset" left="400" top="75" width="120" height="50"/>
        <TextArea id="TextArea00" taborder="4" left="100" top="330" width="453" height="380" flexshrink="0"/>
        <Combo id="Combo00" taborder="5" text="Combo00" left="100" top="270" width="450" height="41" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" onitemchanged="Combo00_onitemchanged">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row>
                <Col id="codecolumn">0</Col>
                <Col id="datacolumn">default 생성 px</Col>
              </Row>
              <Row>
                <Col id="codecolumn">1</Col>
                <Col id="datacolumn">properties에서 width height 값변경</Col>
              </Row>
              <Row>
                <Col id="codecolumn">2</Col>
                <Col id="datacolumn">default 생성 unset</Col>
              </Row>
              <Row>
                <Col id="codecolumn">3</Col>
                <Col id="datacolumn">unset설정 후 cssclass로 지정된  값을 확인</Col>
              </Row>
            </Rows>
          </Dataset>
        </Combo>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.TextArea00.value = "["+this.btn01.text+".]"
};

this.Button00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

};

this.Button00_00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

};

this.Combo00_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.TextArea00.deleteText();
	switch(e.postindex) {
	case 0 :
		this.TextArea00.value= this.btn00.text+"버튼 width height 정보\n"
		                      + "this.btn00.width = "+this.btn00.width+"\n"
		                      + "this.btn00.height = "+this.btn00.height;
		break;
	case 1 :
		this.TextArea00.value= this.btn01.text+"버튼 width height 정보\n"
		                      + "this.btn01.width = "+this.btn01.width+"\n"
		                      + "this.btn01.height = "+this.btn01.height;
		break;
	case 2 :
		this.TextArea00.value= this.btn02.text+"버튼 width height 정보\n"
		                      + "this.btn02.width = "+this.btn02.width+"\n"
		                      + "this.btn02.height = "+this.btn02.height;
		break;
	case 3 :
		this.TextArea00.value= this.btn03.text+"버튼 width height 정보\n"
		                      + "this.btn03.width = "+this.btn03.width+"\n"
		                      + "this.btn03.height = "+this.btn03.height;
		break;
	default:
	}
};
]]></Script>
  </Form>
</FDL>
