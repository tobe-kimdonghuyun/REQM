<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sub_form" width="1280" height="720" titletext="New Form" onclose="sub_form_onclose">
    <Layouts>
      <Layout height="720" width="1280">
        <Button id="Button00" taborder="0" text="this.close" left="47" top="177" width="307" height="106" onclick="Button00_onclick"/>
        <Static id="Static00" taborder="1" text="nexacroK_mfe_sub3" left="36" top="35" width="334" height="70" font="36px/normal &quot;Malgun Gothic&quot;"/>
        <CheckBox id="CheckBox00" taborder="2" text="CheckBox00" left="420" top="188" width="319" height="80"/>
        <Button id="Button01" taborder="3" text="nexacro.setWheelZoom( objFrame, 80 );" left="39" top="299" width="231" height="81" onclick="Button01_onclick"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close("sub_form close");
};

this.sub_form_onclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	
};

this.Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objFrame = this.getOwnerFrame();
	nexacro.setWheelZoom( objFrame, 80 );
};
]]></Script>
  </Form>
</FDL>
