<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Static_Selectable_Sample00" width="1280" height="720" titletext="New Form" onload="Static_Selectable_Sample00_onload">
    <Layouts>
      <Layout height="720" mobileorientation="landscape" width="1280">
        <TextArea id="TextArea00" taborder="0" left="100" top="420" width="453" height="380" flexshrink="0"/>
        <Combo id="Combo00" taborder="1" text="Combo00" left="100" top="360" width="450" height="41" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" onitemchanged="Combo00_onitemchanged">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row>
                <Col id="codecolumn">0</Col>
                <Col id="datacolumn">default 생성 px</Col>
              </Row>
              <Row>
                <Col id="codecolumn">1</Col>
                <Col id="datacolumn">properties에서 width height 값변경</Col>
              </Row>
              <Row>
                <Col id="codecolumn">2</Col>
                <Col id="datacolumn">default 생성 unset</Col>
              </Row>
              <Row>
                <Col id="codecolumn">3</Col>
                <Col id="datacolumn">unset설정 후 cssclass로 지정된  값을 확인</Col>
              </Row>
            </Rows>
          </Dataset>
        </Combo>
        <Static id="Static00" taborder="2" text="&lt;Group id=&quot;root&quot; type=&quot;root-cssvariable&quot;&gt;&#13;&#10;&#9;  &lt;Define id=&quot;ButtonWidth&quot; value=&quot;100px&quot;/&gt;&#13;&#10;&#9;  &lt;Define id=&quot;ButtonHeight&quot; value=&quot;50px&quot;/&gt;&#13;&#10;&#9;  &lt;Define id=&quot;ButtonMinWidth&quot; value=&quot;70px&quot;/&gt;&#13;&#10;&#9;  &lt;Define id=&quot;ButtonMaxWidth&quot; value=&quot;200px&quot;/&gt;&#13;&#10;&#9;  &lt;Define id=&quot;ButtonMinHeight&quot; value=&quot;40px&quot;/&gt;&#13;&#10;&#9;  &lt;Define id=&quot;ButtonMaxHeight&quot; value=&quot;100px&quot;/&gt;&#13;&#10;    &lt;/Group&gt;&#13;&#10;    &lt;Group id=&quot;Large&quot; type=&quot;root-class-cssvariable&quot;&gt;&#13;&#10;      &lt;Define id=&quot;ButtonWidth&quot; value=&quot;200px&quot;/&gt;&#13;&#10;&#9;  &lt;Define id=&quot;ButtonHeight&quot; value=&quot;100px&quot;/&gt;&#13;&#10;&#9;  &lt;Define id=&quot;ButtonMinWidth&quot; value=&quot;100px&quot;/&gt;&#13;&#10;&#9;  &lt;Define id=&quot;ButtonMaxWidth&quot; value=&quot;300px&quot;/&gt;&#13;&#10;&#9;  &lt;Define id=&quot;ButtonMinHeight&quot; value=&quot;70px&quot;/&gt;&#13;&#10;&#9;  &lt;Define id=&quot;ButtonMaxHeight&quot; value=&quot;150px&quot;/&gt;&#13;&#10;    &lt;/Group&gt;" left="589" top="368" width="441" height="442"/>
        <Button id="Button00" taborder="3" text="min size 조정" left="100" top="24" width="119" height="51" onclick="Button00_onclick"/>
        <Button id="Button01" taborder="4" text="max size 조정" left="400" top="25" width="120" height="50" onclick="Button01_onclick"/>
        <Div id="Div00" taborder="5" text="Div00" left="100" top="85" width="537" height="237" border="1px solid red">
          <Layouts>
            <Layout>
              <Button id="btn01" taborder="0" text="properties에서 width height 값변경" left="10" top="96" width="150" height="100" wordWrap="english"/>
              <Button id="btn02" taborder="1" text="default 생성 unset" left="10" top="300" width="unset" height="unset"/>
              <Button id="btn00" taborder="2" text="default 생성 px" left="10" top="31" width="120" height="50"/>
            </Layout>
          </Layouts>
        </Div>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.Div00.form.btn03.width = "60px";
	this.Div00.form.btn03.height = "30px";
};
this.Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.Div00.form.btn03.width = "210px";
	this.Div00.form.btn03.height = "110px";
};

this.Button00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

};

this.Button00_00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{

};

this.Combo00_onitemchanged = function(obj:nexacro.Combo,e:nexacro.ItemChangeEventInfo)
{
	this.TextArea00.deleteText();
	switch(e.postindex) {
	case 0 :
		this.TextArea00.value= " "+this.Div00.form.btn00.text+"버튼 width height 정보"
		                      + "\n this.Div00.form.btn00.width = "+this.Div00.form.btn00.width
		                      + "\n this.Div00.form.btn00.height = "+this.Div00.form.btn00.height
                          + "\n this.Div00.form.btn00.getOffsetWidth() = "+this.Div00.form.btn00.getOffsetWidth()
                          + "\n this.Div00.form.btn00.getOffsetHeight() = "+this.Div00.form.btn00.getOffsetHeight()
                          ;
		break;
	case 1 :
		this.TextArea00.value= " "+this.Div00.form.btn01.text+"버튼 width height 정보"
		                      + "\n this.Div00.form.btn01.width = "+this.Div00.form.btn01.width
		                      + "\n this.Div00.form.btn01.height = "+this.Div00.form.btn01.height
                          + "\n this.Div00.form.btn01.getOffsetWidth() = "+this.Div00.form.btn01.getOffsetWidth()
                          + "\n this.Div00.form.btn01.getOffsetHeight() = "+this.Div00.form.btn01.getOffsetHeight()
                          ;
		break;
	case 2 :
		this.TextArea00.value= " "+this.Div00.form.btn02.text+"버튼 width height 정보"
		                      + "\n this.Div00.form.btn02.width = "+this.Div00.form.btn02.width
		                      + "\n this.Div00.form.btn02.height = "+this.Div00.form.btn02.height
                          + "\n this.Div00.form.btn02.getOffsetWidth() = "+this.Div00.form.btn02.getOffsetWidth()
                          + "\n this.Div00.form.btn02.getOffsetHeight() = "+this.Div00.form.btn02.getOffsetHeight();
		break;
	case 3 :
		this.TextArea00.value= " "+this.Div00.form.btn03.text+"버튼 width height 정보"
		                      + "\n this.Div00.form.btn03.width = "+this.Div00.form.btn03.width
		                      + "\n this.Div00.form.btn03.height = "+this.Div00.form.btn03.height
                          + "\n this.Div00.form.btn03.getOffsetWidth() = "+this.Div00.form.btn03.getOffsetWidth()
                          + "\n this.Div00.form.btn03.getOffsetHeight() = "+this.Div00.form.btn03.getOffsetHeight();
		break;
	case4 :
		this.TextArea00.value= " "+this.Div00.form.btn04.text+"버튼 width height 정보"
		                      + "\n this.Div00.form.btn04.width = "+this.Div00.form.btn04.width
		                      + "\n this.Div00.form.btn04.height = "+this.Div00.form.btn04.height
                          + "\n this.Div00.form.btn04.getOffsetWidth() = "+this.Div00.form.btn04.getOffsetWidth()
                          + "\n this.Div00.form.btn04.getOffsetHeight() = "+this.Div00.form.btn04.getOffsetHeight();
		break;
	default:
	}
};


this.Static_Selectable_Sample00_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	
	var objButton = new Button("Button", 10, 435, "unset", "unset", null, null);
	this.Div00.addChild("btn03", objButton); 
	objButton.show(); 
	objButton.text= "동적생성 테스트";
	objButton.cssclass = "btnCss03";
	
	
	objButton.minwidth = "unset";
	objButton.minheight = "unset";
	objButton.maxwidth = "unset";
	objButton.maxheight = "unset";
	

};
]]></Script>
  </Form>
</FDL>
