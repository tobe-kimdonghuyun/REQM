<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Static_Selectable_Sample00" width="1280" height="760" titletext="New Form">
    <Layouts>
      <Layout height="760" mobileorientation="landscape" width="1280">
        <TextArea id="TextArea00" taborder="0" left="90" top="445" width="400" height="310" flexshrink="0"/>
        <Static id="Static00" taborder="2" text=".Edit.edtCss00&#13;&#10;{&#13;&#10;&#9;background : green;&#13;&#10;&#9;width:70px;&#13;&#10;&#9;height:50px;&#13;&#10;}&#13;&#10;&#13;&#10;.Edit.edtCss00[status=readonly]&#13;&#10;{&#13;&#10;&#9;background : blue;&#13;&#10;&#9;width:100px;&#13;&#10;&#9;height:100px;&#13;&#10;}&#13;&#10;&#13;&#10;.Edit.edtCss00[userstatus=nulltext]&#13;&#10;{&#13;&#10;&#9;background : red;&#13;&#10;&#9;width:150px;&#13;&#10;&#9;height:150px;&#13;&#10;}" left="630" top="30" width="260" height="350"/>
        <Radio id="Radio00" taborder="3" left="111" top="370" width="135" height="50" direction="vertical" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row>
                <Col id="codecolumn">0</Col>
                <Col id="datacolumn">false</Col>
              </Row>
              <Row>
                <Col id="codecolumn">1</Col>
                <Col id="datacolumn">true</Col>
              </Row>
            </Rows>
          </Dataset>
        </Radio>
        <Edit id="edt00" taborder="4" left="100" top="51" width="unset" height="unset" cssclass="edtCss00" value="abcd" onsize="Edit_onsize"/>
        <Edit id="edt01" taborder="5" left="400" top="51" width="unset" height="unset" cssclass="edtCss00" displaynulltext="nulltext" onsize="Edit_onsize" border="1px solid red"/>
        <Button id="Button00" taborder="6" text="edit readonly " left="259" top="369" width="155" height="55" onclick="Button00_onclick"/>
        <Edit id="Edit00" taborder="6" left="110" top="245" width="unset" height="unset" onsize="Edit_onsize" cssclass="edtCss00" value="abcd"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
this.btn00_onsize = function(obj:nexacro.Button,e:nexacro.SizeEventInfo)
{
	this.TextArea00.deleteText()
	this.TextArea00.value= " "+this.btn00.text+"버튼 onsize이벤트 발생 width height 정보"
		                      + "\n this.btn00.width = "+this.btn00.width
		                      + "\n this.btn00.height = "+this.btn00.height
                          + "\n this.btn00.getOffsetWidth() = "+this.btn00.getOffsetWidth()
                          + "\n this.btn00.getOffsetHeight() = "+this.btn00.getOffsetHeight()
};

this.btn01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.btn00.setSelectStatus(true);
};
this.btn04_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.btn00.setSelectStatus(false);
};


this.btn02_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//this.btn00.setFocus();
	this.btn00.enable = this.Radio00.text;
};

this.btn03_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.btn00.setFocus();
};

this.btn04_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.btn00.setSelectStatus(false);
};

this.Edit_onsize = function(obj:nexacro.Edit,e:nexacro.SizeEventInfo)
{
		this.TextArea00.deleteText();
	this.TextArea00.value= " "+obj.text+" edit onsize이벤트 발생 width height 정보"
		                      + "\n obj.width = "+obj.width
		                      + "\n obj.height = "+obj.height
                          + "\n obj.getOffsetWidth() = "+obj.getOffsetWidth()
                          + "\n obj.getOffsetHeight() = "+obj.getOffsetHeight()
};

this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.edt00.readonly = this.Radio00.text;
};
]]></Script>
  </Form>
</FDL>
