<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Static_Selectable_Sample00" width="1280" height="760" titletext="New Form">
    <Layouts>
      <Layout height="760" mobileorientation="landscape" width="1280">
        <Button id="Button07" taborder="2" text="setWheelZoom" left="830" top="30" width="130" height="57" onclick="Button07_onclick"/>
        <TextArea id="TextArea00" taborder="4" left="610" top="126" width="368" height="328"/>
        <Button id="Button01" taborder="0" text="Button01" left="72" top="33" width="unset" height="unset" cssclass="EmRemCss00" onclick="Button01_onclick"/>
        <Div id="Div00" taborder="1" text="Div00" left="81" top="390" width="479" height="206" background="yellow">
          <Layouts>
            <Layout>
              <Button id="Button01" taborder="0" text="Button02" left="50" top="35" width="unset" height="unset" cssclass="EmRemCss00" onclick="Div00_Button01_onclick"/>
            </Layout>
            <Layout name="Layout0"/>
            <Layout name="Layout1"/>
            <Layout name="Layout2"/>
          </Layouts>
        </Div>
        <Combo id="Combo00" taborder="3" text="Combo00" left="610" top="40" width="209" height="33" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row>
                <Col id="datacolumn">70</Col>
                <Col id="codecolumn">1</Col>
              </Row>
              <Row>
                <Col id="datacolumn">80</Col>
                <Col id="codecolumn">2</Col>
              </Row>
              <Row>
                <Col id="datacolumn">90</Col>
                <Col id="codecolumn">3</Col>
              </Row>
              <Row>
                <Col id="datacolumn">100</Col>
                <Col id="codecolumn">4</Col>
              </Row>
              <Row>
                <Col id="datacolumn">110</Col>
                <Col id="codecolumn">5</Col>
              </Row>
              <Row>
                <Col id="datacolumn">120</Col>
                <Col id="codecolumn">6</Col>
              </Row>
            </Rows>
          </Dataset>
        </Combo>
        <Button id="Button00" taborder="5" text="div button  cssclass변경" left="970" top="31" width="144" height="54" onclick="Button00_onclick"/>
        <Div id="Div00_00" taborder="6" text="Div00" left="84" top="618" width="479" height="206" background="green">
          <Layouts>
            <Layout>
              <Button id="Button01" taborder="0" text="Button03" left="50" top="35" width="unset" height="unset" cssclass="EmRemCss01" onclick="Div00_Button01_onclick"/>
            </Layout>
            <Layout name="Layout0"/>
            <Layout name="Layout1"/>
            <Layout name="Layout2"/>
          </Layouts>
        </Div>
      </Layout>
      <Layout height="500" mobileorientation="Landscape" name="Layout0" type="default" width="480">
        <Button id="Button07" left="335" top="30" width="130" height="57"/>
        <TextArea id="TextArea00" left="100" top="160" width="368" height="328"/>
        <Button id="Button01" left="16" top="10" width="128" height="55"/>
      </Layout>
      <Layout height="760" mobileorientation="Landscape" name="Layout1" type="default" width="960">
        <Button id="Button07" left="560" top="30" width="130" height="57"/>
        <TextArea id="TextArea00" left="530" top="126" width="368" height="328"/>
      </Layout>
      <Layout height="760" mobileorientation="Landscape" name="Layout2" type="default" width="1280">
        <TextArea id="TextArea00" left="580" top="132" width="368" height="328"/>
        <Button id="Button07" left="765" top="40" width="130" height="57"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
this.btn00_onsize = function(obj:nexacro.Button,e:nexacro.SizeEventInfo)
{
	this.TextArea00.deleteText()
	this.TextArea00.value= " "+this.btn00.text+"버튼 onsize이벤트 발생 width height 정보"
		                      + "\n this.btn00.width = "+this.btn00.width
		                      + "\n this.btn00.height = "+this.btn00.height
                          + "\n this.btn00.getOffsetWidth() = "+this.btn00.getOffsetWidth()
                          + "\n this.btn00.getOffsetHeight() = "+this.btn00.getOffsetHeight()
};

this.btn01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.btn00.setSelectStatus(true);
};
this.btn04_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.btn00.setSelectStatus(false);
};


this.btn02_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	//this.btn00.setFocus();
	this.btn00.enable = this.Radio00.text;
};

this.btn03_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.btn00.setFocus();
};

this.btn04_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.btn00.setSelectStatus(false);
};

this.Edit_onsize = function(obj:nexacro.Edit,e:nexacro.SizeEventInfo)
{
		this.TextArea00.deleteText();
	this.TextArea00.value= " "+obj.text+" edit onsize이벤트 발생 width height 정보"
		                      + "\n obj.width = "+obj.width
		                      + "\n obj.height = "+obj.height
                          + "\n obj.getOffsetWidth() = "+obj.getOffsetWidth()
                          + "\n obj.getOffsetHeight() = "+obj.getOffsetHeight()
};

this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.Div00.form.Button01.cssclass = "RemEmCss00";
	this.Div00.form.Button01.text = "function(obj:nexacro.Button,e:nexacro.ClickEventInfo)";
	this.Div00_00.form.Button01.cssclass = "RemEmCss01";

};

this.Button07_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objFrame = this.getOwnerFrame();
	switch(this.Combo00.value) {
	case "1":
		nexacro.setWheelZoom(objFrame,70);
		break;
	case "2":
		nexacro.setWheelZoom(objFrame,80);
		break;
	case "3":
		nexacro.setWheelZoom(objFrame,90);
		break;
	case "4":
		nexacro.setWheelZoom(objFrame,100);
		break;
	case "5":
		nexacro.setWheelZoom(objFrame,110);
		break;
	case "6":
		nexacro.setWheelZoom(objFrame,120);
		break;
	default:
	}
	
};


this.Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objSize = nexacro.getTextSize( obj.text, 'bold 1rem/normal "Arial"');
	this.TextArea00.deleteText();
	this.TextArea00.deleteText();
	this.TextArea00.value= " "+obj.text+" butotn 사이즈 확인 width height 정보"
		                      + "\n this.Button01.width = "+obj.width
		                      + "\n this.Button01.height = "+obj.height
							  + "\n this.Button01 getTextSize.nx = "+objSize.nx
							  + "\n this.Button01 getTextSize.ny = "+objSize.ny
                          + "\n this.Button01.getOffsetWidth() = "+obj.getOffsetWidth()
                          + "\n this.Button01.getOffsetHeight() = "+obj.getOffsetHeight();
	
};

this.Div00_Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objSize = nexacro.getTextSize( obj.text, 'bold 1rem/normal "Arial"' );
	this.TextArea00.deleteText();
	this.TextArea00.value= " "+obj.text+" Div00_Button01 사이즈 확인 width height 정보"
		                      + "\n this.Div00_Button01.width = "+obj.width
		                      + "\n this.Div00_Button01.height = "+obj.height
							  + "\n this.Div00_Button01 getTextSize.nx = "+objSize.nx
							  + "\n this.Div00_Button01 getTextSize.ny = "+objSize.ny
                          + "\n this.Div00_Button01.getOffsetWidth() = "+obj.getOffsetWidth()
                          + "\n this.Div00_Button01.getOffsetHeight() = "+obj.getOffsetHeight();
};
]]></Script>
  </Form>
</FDL>
