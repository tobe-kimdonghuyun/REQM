<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sub_form" width="1280" height="720" titletext="New Form" onclose="sub_form_onclose" onload="sub_form_onload">
    <Layouts>
      <Layout height="720" width="1280">
        <Button id="Button00" taborder="0" text="this.close" left="37" top="150" width="307" height="106" onclick="Button00_onclick"/>
        <Static id="Static00" taborder="1" text="nexacroK_mfe_sub4" left="37" top="20" width="334" height="70" font="36px/normal &quot;Malgun Gothic&quot;"/>
        <Combo id="Combo00" taborder="2" text="Combo00" left="377" top="144" width="378" height="115"/>
        <Button id="Button01" taborder="3" text="nexacro.setWheelZoom( objFrame, 50 );" left="39" top="280" width="323" height="102" onclick="Button01_onclick"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close("sub_form close");
};

this.sub_form_onclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	
};

this.sub_form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	
};

this.Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objFrame = this.getOwnerFrame();
	nexacro.setWheelZoom( objFrame, 50 );
};
]]></Script>
  </Form>
</FDL>
