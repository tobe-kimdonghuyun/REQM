        <Button id="Button00" taborder="0" text="Button00" left="98" top="73" width="unset" height="unset" cssclass="userA" font="26pt &quot;Arial&quot;"/>
        <Button id="Button01" taborder="1" text="Button01" left="Button00:5" top="85" width="Button00:30%" height="86"/>
