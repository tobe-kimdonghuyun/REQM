        <Button id="Button041" taborder="5" text="패널 버튼 1 (XCSS)" cssclass="userA" left="507" top="414" flexshrink="0" width="unset" height="47"/>
        <Combo id="Combo00" taborder="6" text="Combo00" left="354" top="335" width="30%" height="44" minwidth="100" maxwidth="400"/>
        <Combo id="Combo00_00" taborder="7" text="Combo00" left="354" top="396" width="unset" height="unset"/>
        <Combo id="Combo00_01" taborder="8" text="Combo00" left="354" top="500" width="30%" height="44"/>
        <Combo id="Combo00_02" taborder="9" text="Combo00" left="354" top="560" width="unset" height="unset" minwidth="100" maxwidth="400"/>
        <PopupDiv id="PopupDiv00" text="PopupDiv00" visible="false" left="790" top="273" width="unset" height="unset" background="purple">
