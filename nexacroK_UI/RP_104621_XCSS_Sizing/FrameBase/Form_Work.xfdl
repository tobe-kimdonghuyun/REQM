        <Button id="Button06" taborder="16" text="패널 버튼 (Fit)" left="553" top="126" width="unset" height="unset" flexshrink="0" cssclass="userFit" onclick="Button06_onclick"/>
        <Button id="Button061" taborder="16" text="패널 버튼 (Fit)" left="553" top="126" width="unset" height="unset" flexshrink="0" cssclass="userFit" onclick="Button06_onclick"/>
        <Div id="Div01" taborder="14" text="Div01" left="37" top="394" width="15%" height="303" background="chocolate">
