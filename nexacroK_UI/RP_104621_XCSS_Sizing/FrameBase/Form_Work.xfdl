          </Contents>
        </Panel>
        <Panel id="Panel01" taborder="3" left="645.00" top="49" type="vertical" width="unset" height="unset" fittocontents="both" background="lightgray" border="3px solid yellow">
          <Contents>
            <PanelItem id="PanelItem02" componentid="Button041"/>
            <PanelItem id="PanelItem00" componentid="Button031"/>
            <PanelItem id="PanelItem03" componentid="Button061"/>
          </Contents>
        </Panel>
        <Button id="Button03" taborder="4" text="패널 버튼 2 (JS)" left="424" top="265" width="100" height="20" flexshrink="0" onclick="Button03_onclick"/>
        <Button id="Button04" taborder="5" text="패널 버튼 1 (XCSS)" cssclass="userA" left="507" top="414" flexshrink="0" width="unset" height="47"/>
