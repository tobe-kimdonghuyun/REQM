<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Menu_Work" width="1280" height="720" titletext="New Form">
    <Layouts>
      <Layout height="720" width="1280">
        <Button id="Button00" taborder="0" text="스타일 방식" left="30" top="85" width="120" height="50" onclick="Button00_onclick"/>
        <Button id="Button01" taborder="1" text="Position 방식" left="30" top="145" width="120" height="50" onclick="Button01_onclick"/>
        <Button id="Button00_00" taborder="2" text="HOME" left="30.00" top="25" width="120" height="50" onclick="Button00_00_onclick"/>
        <Button id="Button01_00" taborder="3" text="XCSS Group 변경" left="30.00" top="205" width="120" height="50" onclick="Button01_00_onclick"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
this.Button00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.getOwnerFrame().getOwnerFrame().ChildFrame01.formurl = "FrameBase::Form_Work.xfdl";
};

this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.getOwnerFrame().getOwnerFrame().ChildFrame01.formurl = "FrameBase::Perf_Work.xfdl";
};

this.Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.getOwnerFrame().getOwnerFrame().ChildFrame01.formurl = "FrameBase::Perf_Work_JS.xfdl";
};

this.Button01_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var objApp = nexacro.getApplication();
	
	if(objApp.xcssgroup == "")
		objApp.xcssgroup = "Large";
	else
		objApp.xcssgroup = "";
};
]]></Script>
  </Form>
</FDL>
