<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="EmRemSample05" width="1280" height="720" titletext="[TC-F] FrameSet TabBar em/rem 검증" font="30px/normal &quot;Malgun Gothic&quot;" onload="EmRemSample05_onload">
    <Layouts>
      <Layout height="720" width="1280">
        <!-- MF font 변경 버튼 — rem 일괄 재계산 확인 -->
        <Button id="btnMF12" taborder="0" text="MF=12px" left="10" top="8" width="62" height="30" onclick="btnMF12_onclick" font="11px &quot;Malgun Gothic&quot;" border="2px solid #555"/>
        <Button id="btnMF16" taborder="1" text="MF=16px" left="77" top="8" width="62" height="30" onclick="btnMF16_onclick" font="11px &quot;Malgun Gothic&quot;" border="2px solid #555"/>
        <Button id="btnMF20" taborder="2" text="MF=20px" left="144" top="8" width="62" height="30" onclick="btnMF20_onclick" font="11px &quot;Malgun Gothic&quot;" border="2px solid #555"/>
        <Button id="btnMF24" taborder="3" text="MF=24px" left="211" top="8" width="62" height="30" onclick="btnMF24_onclick" font="11px &quot;Malgun Gothic&quot;" border="2px solid #555"/>
        <Static id="lbl_mf" taborder="4" text="↑ MF font 변경 → rem 탭바 속성 일괄 재계산  |  [TC-F] FrameSet TabBar em / rem / em+rem복합 검증" left="285" top="11" width="680" height="18" font="10px Malgun Gothic"/>
        <Static id="lbl_typeinfo" taborder="99" text="[테스트유형] 동적설정 — Form_onload 스크립트에서 em/rem 설정  |  [사용 컴포넌트] FrameSet · ChildFrame · Button · Static · TextArea" left="10" top="29" width="1260" height="14" font="9px Malgun Gothic" forecolor="#7D4E0A" background="#FFF4E5"/>
        <!-- FrameSet — TabBar 포함, ChildFrame 3개 -->
        <FrameSet id="FrameSet00" taborder="5" left="10" top="44" width="678" height="629" showtabbar="true" tabbarposition="top" tabbaritemusepinbutton="true" font="12px/normal &quot;Malgun Gothic&quot;">
          <Layouts>
            <Layout>
              <ChildFrame id="ChildFrame00" titletext="프레임 1" formurl="TestCase::EmRemChild.xfdl" allowtabbaritempinbutton="true"/>
              <ChildFrame id="ChildFrame01" titletext="프레임 2" formurl="TestCase::EmRemChild.xfdl" allowtabbaritempinbutton="true"/>
              <ChildFrame id="ChildFrame02" titletext="프레임 3" formurl="TestCase::EmRemChild.xfdl" allowtabbaritempinbutton="true"/>
            </Layout>
          </Layouts>
        </FrameSet>
        <!-- 일괄 적용 버튼 (TC 시나리오) -->
        <Button id="btn_tc_em" taborder="6" text="[TC-F-01]&#13;&#10;em 전체 적용" left="698" top="44" width="128" height="40" onclick="btn_tc_em_onclick" font="11px &quot;Malgun Gothic&quot;" border="2px solid #3498db" background="#EBF5FB"/>
        <Button id="btn_tc_rem" taborder="7" text="[TC-F-02]&#13;&#10;rem 전체 적용" left="831" top="44" width="128" height="40" onclick="btn_tc_rem_onclick" font="11px &quot;Malgun Gothic&quot;" border="2px solid #e74c3c" background="#FDEDEC"/>
        <Button id="btn_tc_mix" taborder="8" text="[TC-F-03]&#13;&#10;em+rem 복합" left="964" top="44" width="128" height="40" onclick="btn_tc_mix_onclick" font="11px &quot;Malgun Gothic&quot;" border="2px solid #27ae60" background="#EAFAF1"/>
        <Button id="btn_reset" taborder="9" text="초기화" left="1097" top="44" width="68" height="40" onclick="btn_reset_onclick" font="11px &quot;Malgun Gothic&quot;" border="1px solid #888"/>
        <!-- 개별 속성 설정 헤더 -->
        <Static id="lbl_col_em" taborder="10" text="em 단독 설정" left="698" top="90" width="128" height="14" font="9px Malgun Gothic"/>
        <Static id="lbl_col_rem" taborder="11" text="rem 단독 설정" left="831" top="90" width="128" height="14" font="9px Malgun Gothic"/>
        <Static id="lbl_col_mix" taborder="12" text="em+rem 복합" left="964" top="90" width="128" height="14" font="9px Malgun Gothic"/>
        <!-- tabbarsize -->
        <Static id="lbl_p01" taborder="13" text="tabbarsize" left="698" top="108" width="128" height="12" font="8px Malgun Gothic"/>
        <Button id="btn_p01_em" taborder="14" text="3em" left="698" top="122" width="128" height="26" onclick="btn_p01_em_onclick" font="10px &quot;Malgun Gothic&quot;" border="1px solid #3498db"/>
        <Button id="btn_p01_rem" taborder="15" text="3rem" left="831" top="122" width="128" height="26" onclick="btn_p01_rem_onclick" font="10px &quot;Malgun Gothic&quot;" border="1px solid #e74c3c"/>
        <!-- tabbaritemheight -->
        <Static id="lbl_p02" taborder="16" text="tabbaritemheight" left="698" top="152" width="128" height="12" font="8px Malgun Gothic"/>
        <Button id="btn_p02_em" taborder="17" text="2.5em" left="698" top="166" width="128" height="26" onclick="btn_p02_em_onclick" font="10px &quot;Malgun Gothic&quot;" border="1px solid #3498db"/>
        <Button id="btn_p02_rem" taborder="18" text="2.5rem" left="831" top="166" width="128" height="26" onclick="btn_p02_rem_onclick" font="10px &quot;Malgun Gothic&quot;" border="1px solid #e74c3c"/>
        <!-- tabbaritemminheight / tabbaritemmaxheight -->
        <Static id="lbl_p03" taborder="19" text="tabbaritemminheight / maxheight" left="698" top="196" width="260" height="12" font="8px Malgun Gothic"/>
        <Button id="btn_p03a_em" taborder="20" text="min=2em" left="698" top="210" width="60" height="26" onclick="btn_p03a_em_onclick" font="10px &quot;Malgun Gothic&quot;" border="1px solid #3498db"/>
        <Button id="btn_p03b_em" taborder="21" text="max=4em" left="763" top="210" width="60" height="26" onclick="btn_p03b_em_onclick" font="10px &quot;Malgun Gothic&quot;" border="1px solid #3498db"/>
        <Button id="btn_p03a_rem" taborder="22" text="min=2rem" left="831" top="210" width="60" height="26" onclick="btn_p03a_rem_onclick" font="10px &quot;Malgun Gothic&quot;" border="1px solid #e74c3c"/>
        <Button id="btn_p03b_rem" taborder="23" text="max=4rem" left="896" top="210" width="60" height="26" onclick="btn_p03b_rem_onclick" font="10px &quot;Malgun Gothic&quot;" border="1px solid #e74c3c"/>
        <!-- tabbaritemwidth -->
        <Static id="lbl_p04" taborder="24" text="tabbaritemwidth" left="698" top="240" width="128" height="12" font="8px Malgun Gothic"/>
        <Button id="btn_p04_em" taborder="25" text="8em" left="698" top="254" width="128" height="26" onclick="btn_p04_em_onclick" font="10px &quot;Malgun Gothic&quot;" border="1px solid #3498db"/>
        <Button id="btn_p04_rem" taborder="26" text="8rem" left="831" top="254" width="128" height="26" onclick="btn_p04_rem_onclick" font="10px &quot;Malgun Gothic&quot;" border="1px solid #e74c3c"/>
        <!-- tabbaritemgap -->
        <Static id="lbl_p05" taborder="27" text="tabbaritemgap" left="698" top="284" width="128" height="12" font="8px Malgun Gothic"/>
        <Button id="btn_p05_em" taborder="28" text="0.25em" left="698" top="298" width="128" height="26" onclick="btn_p05_em_onclick" font="10px &quot;Malgun Gothic&quot;" border="1px solid #3498db"/>
        <Button id="btn_p05_rem" taborder="29" text="0.25rem" left="831" top="298" width="128" height="26" onclick="btn_p05_rem_onclick" font="10px &quot;Malgun Gothic&quot;" border="1px solid #e74c3c"/>
        <!-- tabbarbuttongap -->
        <Static id="lbl_p06" taborder="30" text="tabbarbuttongap" left="698" top="328" width="128" height="12" font="8px Malgun Gothic"/>
        <Button id="btn_p06_em" taborder="31" text="0.5em" left="698" top="342" width="128" height="26" onclick="btn_p06_em_onclick" font="10px &quot;Malgun Gothic&quot;" border="1px solid #3498db"/>
        <Button id="btn_p06_rem" taborder="32" text="0.5rem" left="831" top="342" width="128" height="26" onclick="btn_p06_rem_onclick" font="10px &quot;Malgun Gothic&quot;" border="1px solid #e74c3c"/>
        <!-- tabbaritempinbuttonsize (Number2 — em/rem/복합) -->
        <Static id="lbl_p07" taborder="33" text="tabbaritempinbuttonsize  (Number2 형식)" left="698" top="372" width="360" height="12" font="8px Malgun Gothic"/>
        <Button id="btn_p07_em" taborder="34" text="1em 1em" left="698" top="386" width="84" height="26" onclick="btn_p07_em_onclick" font="10px &quot;Malgun Gothic&quot;" border="1px solid #3498db"/>
        <Button id="btn_p07_rem" taborder="35" text="1rem 1rem" left="787" top="386" width="84" height="26" onclick="btn_p07_rem_onclick" font="10px &quot;Malgun Gothic&quot;" border="1px solid #e74c3c"/>
        <Button id="btn_p07_mix" taborder="36" text="1em 1rem" left="876" top="386" width="84" height="26" onclick="btn_p07_mix_onclick" font="10px &quot;Malgun Gothic&quot;" border="1px solid #27ae60"/>
        <!-- tabbaritemclosebuttonsize (Number2) -->
        <Static id="lbl_p08" taborder="37" text="tabbaritemclosebuttonsize  (Number2 형식)" left="698" top="416" width="360" height="12" font="8px Malgun Gothic"/>
        <Button id="btn_p08_em" taborder="38" text="1em 1em" left="698" top="430" width="84" height="26" onclick="btn_p08_em_onclick" font="10px &quot;Malgun Gothic&quot;" border="1px solid #3498db"/>
        <Button id="btn_p08_rem" taborder="39" text="1rem 1rem" left="787" top="430" width="84" height="26" onclick="btn_p08_rem_onclick" font="10px &quot;Malgun Gothic&quot;" border="1px solid #e74c3c"/>
        <Button id="btn_p08_mix" taborder="40" text="1em 1rem" left="876" top="430" width="84" height="26" onclick="btn_p08_mix_onclick" font="10px &quot;Malgun Gothic&quot;" border="1px solid #27ae60"/>
        <!-- 결과 확인 영역 -->
        <Button id="btn_show" taborder="41" text="현재 속성값 확인" left="698" top="462" width="180" height="34" onclick="btn_show_onclick" font="12px &quot;Malgun Gothic&quot;" border="1px solid #555"/>
        <TextArea id="TextArea00" taborder="42" left="698" top="502" width="575" height="210" font="12px &quot;Malgun Gothic&quot;"/>
        <Button id="btn_reload" taborder="43" text="[초기화]" left="1165" top="8" width="100" height="30" onclick="btn_reload_onclick" font="11px &quot;Malgun Gothic&quot;" border="1px solid #CC0000"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
/* --- MF font 변경 --- */
this.btnMF12_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this._getMainFrame().font = "normal 12px/normal \"Malgun Gothic\"";
	this.TextArea00.deleteText();
	this.TextArea00.value = "MainFrame font = 12px (1rem = 12px)\nrem 속성들이 재계산됩니다.\n\n";
	this.showTabBarProps();
};

this.btnMF16_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this._getMainFrame().font = "normal 16px/normal \"Malgun Gothic\"";
	this.TextArea00.deleteText();
	this.TextArea00.value = "MainFrame font = 16px (1rem = 16px)\nrem 속성들이 재계산됩니다.\n\n";
	this.showTabBarProps();
};

this.btnMF20_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this._getMainFrame().font = "normal 20px/normal \"Malgun Gothic\"";
	this.TextArea00.deleteText();
	this.TextArea00.value = "MainFrame font = 20px (1rem = 20px)\nrem 속성들이 재계산됩니다.\n\n";
	this.showTabBarProps();
};

this.btnMF24_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this._getMainFrame().font = "normal 24px/normal \"Malgun Gothic\"";
	this.TextArea00.deleteText();
	this.TextArea00.value = "MainFrame font = 24px (1rem = 24px)\nrem 속성들이 재계산됩니다.\n\n";
	this.showTabBarProps();
};

/* --- TC 시나리오 일괄 적용 --- */

// [TC-F-01] em 전체 적용 — FrameSet font(12px) 기준
this.btn_tc_em_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var fs = this.FrameSet00;
	fs.tabbarsize               = "3em";
	fs.tabbaritemheight         = "2.5em";
	fs.tabbaritemminheight      = "2em";
	fs.tabbaritemmaxheight      = "4em";
	fs.tabbaritemwidth          = "8em";
	fs.tabbaritemgap            = "0.25em";
	fs.tabbarbuttongap          = "0.5em";
	fs.tabbaritempinbuttonsize  = "1em 1em";
	fs.tabbaritemclosebuttonsize = "1em 1em";
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-F-01] em 전체 적용\n"
	    + "기준: FrameSet font-size(12px)\n"
	    + "MF font 변경해도 em 값은 FrameSet self font 기준 유지\n\n";
	this.showTabBarProps();
};

// [TC-F-02] rem 전체 적용 — MainFrame font 기준
this.btn_tc_rem_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var fs = this.FrameSet00;
	fs.tabbarsize               = "3rem";
	fs.tabbaritemheight         = "2.5rem";
	fs.tabbaritemminheight      = "2rem";
	fs.tabbaritemmaxheight      = "4rem";
	fs.tabbaritemwidth          = "8rem";
	fs.tabbaritemgap            = "0.25rem";
	fs.tabbarbuttongap          = "0.5rem";
	fs.tabbaritempinbuttonsize  = "1rem 1rem";
	fs.tabbaritemclosebuttonsize = "1rem 1rem";
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-F-02] rem 전체 적용\n"
	    + "기준: MainFrame font-size\n"
	    + "MF font 변경 버튼 클릭 시 탭바 전체 크기가 재계산됨\n"
	    + "Pass: MF 16px → tabbarsize=48px, itemheight=40px\n"
	    + "Pass: MF 20px → tabbarsize=60px, itemheight=50px\n\n";
	this.showTabBarProps();
};

// [TC-F-03] em+rem 복합 적용
this.btn_tc_mix_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var fs = this.FrameSet00;
	fs.tabbarsize               = "3rem";       // rem — MF 기준 (전체 탭바 크기)
	fs.tabbaritemheight         = "2.5em";      // em — FrameSet font 기준 (아이템 높이)
	fs.tabbaritemminheight      = "2rem";       // rem
	fs.tabbaritemmaxheight      = "4rem";       // rem
	fs.tabbaritemwidth          = "8rem";       // rem
	fs.tabbaritemgap            = "0.25rem";    // rem
	fs.tabbarbuttongap          = "0.5em";      // em — font 기준 버튼 간격
	fs.tabbaritempinbuttonsize  = "1em 1rem";   // 복합: 가로=em, 세로=rem (Number2)
	fs.tabbaritemclosebuttonsize = "1rem 1rem"; // rem
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-F-03] em+rem 복합 적용\n"
	    + "tabbarsize/itemwidth/gap: rem (MF 기준)\n"
	    + "tabbaritemheight/buttongap: em (FrameSet font 기준)\n"
	    + "tabbaritempinbuttonsize: '1em 1rem' (Number2 복합)\n\n"
	    + "Pass: pinbuttonsize '1em 1rem' — 단위 독립 보존\n"
	    + "NG  : '1em 1rem' → '12px 16px' (단위 손실)\n\n";
	this.showTabBarProps();
};

// 초기화
this.btn_reset_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var fs = this.FrameSet00;
	fs.tabbarsize               = undefined;
	fs.tabbaritemheight         = undefined;
	fs.tabbaritemminheight      = undefined;
	fs.tabbaritemmaxheight      = undefined;
	fs.tabbaritemwidth          = undefined;
	fs.tabbaritemgap            = undefined;
	fs.tabbarbuttongap          = undefined;
	fs.tabbaritempinbuttonsize  = undefined;
	fs.tabbaritemclosebuttonsize = undefined;
	this.TextArea00.deleteText();
	this.TextArea00.value = "초기화 완료 — 모든 탭바 속성이 기본값으로 복원됨\n\n";
	this.showTabBarProps();
};

/* --- 개별 속성 설정 버튼 --- */

// tabbarsize
this.btn_p01_em_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.FrameSet00.tabbarsize = "3em";
	this.TextArea00.deleteText();
	this.TextArea00.value = "tabbarsize = 3em (FrameSet font 기준)\n";
	this.showTabBarProps();
};
this.btn_p01_rem_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.FrameSet00.tabbarsize = "3rem";
	this.TextArea00.deleteText();
	this.TextArea00.value = "tabbarsize = 3rem (MF font 기준)\nMF font 변경 시 탭바 높이 재계산\n";
	this.showTabBarProps();
};

// tabbaritemheight
this.btn_p02_em_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.FrameSet00.tabbaritemheight = "2.5em";
	this.TextArea00.deleteText();
	this.TextArea00.value = "tabbaritemheight = 2.5em\n";
	this.showTabBarProps();
};
this.btn_p02_rem_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.FrameSet00.tabbaritemheight = "2.5rem";
	this.TextArea00.deleteText();
	this.TextArea00.value = "tabbaritemheight = 2.5rem\n";
	this.showTabBarProps();
};

// tabbaritemminheight
this.btn_p03a_em_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.FrameSet00.tabbaritemminheight = "2em";
	this.TextArea00.deleteText();
	this.TextArea00.value = "tabbaritemminheight = 2em\n";
	this.showTabBarProps();
};
this.btn_p03b_em_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.FrameSet00.tabbaritemmaxheight = "4em";
	this.TextArea00.deleteText();
	this.TextArea00.value = "tabbaritemmaxheight = 4em\n";
	this.showTabBarProps();
};
this.btn_p03a_rem_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.FrameSet00.tabbaritemminheight = "2rem";
	this.TextArea00.deleteText();
	this.TextArea00.value = "tabbaritemminheight = 2rem\n";
	this.showTabBarProps();
};
this.btn_p03b_rem_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.FrameSet00.tabbaritemmaxheight = "4rem";
	this.TextArea00.deleteText();
	this.TextArea00.value = "tabbaritemmaxheight = 4rem\n";
	this.showTabBarProps();
};

// tabbaritemwidth
this.btn_p04_em_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.FrameSet00.tabbaritemwidth = "8em";
	this.TextArea00.deleteText();
	this.TextArea00.value = "tabbaritemwidth = 8em\n";
	this.showTabBarProps();
};
this.btn_p04_rem_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.FrameSet00.tabbaritemwidth = "8rem";
	this.TextArea00.deleteText();
	this.TextArea00.value = "tabbaritemwidth = 8rem\n";
	this.showTabBarProps();
};

// tabbaritemgap
this.btn_p05_em_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.FrameSet00.tabbaritemgap = "0.25em";
	this.TextArea00.deleteText();
	this.TextArea00.value = "tabbaritemgap = 0.25em\n";
	this.showTabBarProps();
};
this.btn_p05_rem_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.FrameSet00.tabbaritemgap = "0.25rem";
	this.TextArea00.deleteText();
	this.TextArea00.value = "tabbaritemgap = 0.25rem\n";
	this.showTabBarProps();
};

// tabbarbuttongap
this.btn_p06_em_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.FrameSet00.tabbarbuttongap = "0.5em";
	this.TextArea00.deleteText();
	this.TextArea00.value = "tabbarbuttongap = 0.5em\n";
	this.showTabBarProps();
};
this.btn_p06_rem_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.FrameSet00.tabbarbuttongap = "0.5rem";
	this.TextArea00.deleteText();
	this.TextArea00.value = "tabbarbuttongap = 0.5rem\n";
	this.showTabBarProps();
};

// tabbaritempinbuttonsize (Number2)
this.btn_p07_em_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.FrameSet00.tabbaritempinbuttonsize = "1em 1em";
	this.TextArea00.deleteText();
	this.TextArea00.value = "tabbaritempinbuttonsize = '1em 1em' (em 단독)\n";
	this.showTabBarProps();
};
this.btn_p07_rem_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.FrameSet00.tabbaritempinbuttonsize = "1rem 1rem";
	this.TextArea00.deleteText();
	this.TextArea00.value = "tabbaritempinbuttonsize = '1rem 1rem' (rem 단독)\n";
	this.showTabBarProps();
};
this.btn_p07_mix_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.FrameSet00.tabbaritempinbuttonsize = "1em 1rem";
	this.TextArea00.deleteText();
	this.TextArea00.value = "tabbaritempinbuttonsize = '1em 1rem' (em+rem 복합)\n"
	    + "Pass: '1em 1rem' 문자열 그대로 보존\n"
	    + "NG  : '12px 16px' 숫자 변환 (단위 손실)\n";
	this.showTabBarProps();
};

// tabbaritemclosebuttonsize (Number2)
this.btn_p08_em_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.FrameSet00.tabbaritemclosebuttonsize = "1em 1em";
	this.TextArea00.deleteText();
	this.TextArea00.value = "tabbaritemclosebuttonsize = '1em 1em' (em 단독)\n";
	this.showTabBarProps();
};
this.btn_p08_rem_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.FrameSet00.tabbaritemclosebuttonsize = "1rem 1rem";
	this.TextArea00.deleteText();
	this.TextArea00.value = "tabbaritemclosebuttonsize = '1rem 1rem' (rem 단독)\n";
	this.showTabBarProps();
};
this.btn_p08_mix_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.FrameSet00.tabbaritemclosebuttonsize = "1em 1rem";
	this.TextArea00.deleteText();
	this.TextArea00.value = "tabbaritemclosebuttonsize = '1em 1rem' (em+rem 복합)\n";
	this.showTabBarProps();
};

// 현재 속성값 확인
this.btn_show_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.TextArea00.deleteText();
	this.showTabBarProps();
};

this.showTabBarProps = function()
{
	var fs = this.FrameSet00;
	this.TextArea00.value +=
	    "─── FrameSet00 TabBar 현재 속성값 ───\n"
	    + "tabbarsize               = " + fs.tabbarsize               + "\n"
	    + "tabbaritemheight         = " + fs.tabbaritemheight          + "\n"
	    + "tabbaritemminheight      = " + fs.tabbaritemminheight       + "\n"
	    + "tabbaritemmaxheight      = " + fs.tabbaritemmaxheight       + "\n"
	    + "tabbaritemwidth          = " + fs.tabbaritemwidth           + "\n"
	    + "tabbaritemgap            = " + fs.tabbaritemgap             + "\n"
	    + "tabbarbuttongap          = " + fs.tabbarbuttongap           + "\n"
	    + "tabbaritempinbuttonsize  = " + fs.tabbaritempinbuttonsize   + "\n"
	    + "tabbaritemclosebuttonsize= " + fs.tabbaritemclosebuttonsize;
};
this.btn_reload_onclick = function(obj:nexacro.Button, e:nexacro.ClickEventInfo)
{
	this.reload();
};

this.EmRemSample05_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	
};
]]></Script>
  </Form>
