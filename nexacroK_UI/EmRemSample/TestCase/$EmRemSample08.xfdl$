	this.ta_result.deleteText();
};

/* ----------------------------------------------------------------
   TC-CHK-DYN-01: xcss em + comp em + script em (font 3단계 변경)
---------------------------------------------------------------- */
this.btnDyn01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var xcss = ".CheckBox.chkCssOv01 { font:20px; -nexa-text-padding:0px 0px 0px 1em; }";

	var comp = "font=\"14px/normal \\\"Malgun Gothic\\\"\"   (초기: xcss font=20px → 14px 오버라이드)";

	var script = "this.chk_dyn01.set_font(\"22px/normal \\\"Malgun Gothic\\\"\");";

	var exp = "초기(xcss+comp): textPad left = 1em × ?px (14px or 20px?)\n\n";
	exp += "스크립트 적용 후 (font=22px):\n";
	exp += "  Pass:  textPad = 1em × 22px = 22px  (resolved font 추적)\n";
	exp += "  Check: textPad = 1em × 20px = 20px  (xcss font 고정)\n\n";
	exp += "→ [▶ 스크립트 적용] 후 [DOM 확인]으로 변화 확인\n";
	exp += "  복원: [↩ 직접설정으로 복원] 클릭 → font=14px 복귀";

	this._showInfo(
		"TC-CHK-DYN-01  chkCssOv01  [ xcss em + comp em + script em (font 3단계 변경) ]",
		xcss, comp, script, exp, "chk_dyn01", ["paddingLeft","borderTopWidth"], 1);
};

/* ----------------------------------------------------------------
   TC-CHK-DYN-02: xcss em + comp rem + script rem (letterSpacing override)
---------------------------------------------------------------- */
this.btnDyn02_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var xcss = ".CheckBox.chkCssOv02 { font:18px; -nexa-text-padding:0px 0px 0px 1em; -nexa-border:0.125em; }";

	var comp = "letterSpacing=\"0.1rem\"   (초기 comp rem)";

	var script = "this.chk_dyn02.set_letterSpacing(\"0.2rem\");  // 0.1rem → 0.2rem 으로 2배";

	var exp = "초기(xcss+comp): letterSpacing = 0.1rem × MF\n";
	exp += "  MF=12px: 1.2px  MF=16px: 1.6px  MF=20px: 2.0px\n\n";
	exp += "스크립트 적용 후 (letterSpacing=0.2rem):\n";
	exp += "  MF=12px: 2.4px  MF=16px: 3.2px  MF=20px: 4.0px  (2배)\n\n";
	exp += "xcss em 속성(textPad, border): 변화 없이 고정\n";
	exp += "→ script set_letterSpacing이 comp XML 값을 덮어쓰는지 확인";

	this._showInfo(
		"TC-CHK-DYN-02  chkCssOv02  [ xcss em + comp rem + script rem(override) ]",
		xcss, comp, script, exp, "chk_dyn02", ["paddingLeft","borderTopWidth","letterSpacing"], 2);
};

/* ----------------------------------------------------------------
   TC-CHK-DYN-03: xcss rem + comp em + script em (font+letterSpacing 변경)
---------------------------------------------------------------- */
this.btnDyn03_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var xcss = ".CheckBox.chkCssOv03 { -nexa-text-padding:0px 0px 0px 0.5rem; -nexa-border:0.125rem; }";

	var comp = "font=\"16px\" letterSpacing=\"0.1em\"   (comp em base=16px)";

	var script = "this.chk_dyn03.set_font(\"20px/normal \\\"Malgun Gothic\\\"\");\n";
	script += "this.chk_dyn03.set_letterSpacing(\"0.15em\");";

	var exp = "초기(xcss+comp): letterSpacing = 0.1em × 16px = 1.6px(고정)\n\n";
	exp += "스크립트 적용 후 (font=20px, letterSpacing=0.15em):\n";
	exp += "  Pass:  0.15em × 20px = 3px  (script font=20px 기준)\n";
	exp += "  Check: 0.15em × 16px = 2.4px  (comp XML font 유지)\n\n";
	exp += "xcss rem(textPad, border): MF 기준 유지 — 변화 없음\n";
	exp += "→ script font 변경이 em 재계산에 반영되는지가 핵심";

	this._showInfo(
		"TC-CHK-DYN-03  chkCssOv03  [ xcss rem + comp em + script em(font변경) ]",
		xcss, comp, script, exp, "chk_dyn03", ["paddingLeft","borderTopWidth","letterSpacing"], 3);
};

/* ----------------------------------------------------------------
   TC-CHK-DYN-04: xcss rem + comp rem + script em (rem→em 전환)
---------------------------------------------------------------- */
this.btnDyn04_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var xcss = ".CheckBox.chkCssOv04 { -nexa-text-padding:0px 0px 0px 0.5rem; -nexa-border:0.125rem; }";

	var comp = "letterSpacing=\"0.1rem\" wordSpacing=\"0.5rem\"   (all rem 초기)";

	var script = "this.chk_dyn04.set_wordSpacing(\"1em\");  // rem → em 으로 단위 전환";

	var exp = "초기(xcss+comp): all rem → 모두 MF 기준\n";
	exp += "  MF=16px: textPad=8px, border=2px, ls=1.6px, ws=8px\n\n";
	exp += "스크립트 적용 후 (wordSpacing=1em):\n";
	exp += "  wordSpacing: rem → em 전환\n";
	exp += "  Pass:  1em × resolved_font = ? (comp font 미설정 → MF/xcss 기준)\n";
	exp += "  MF 변경 후: wordSpacing이 rem처럼 재계산되는지 확인\n\n";
	exp += "→ 단위를 rem에서 em으로 script 교체 시 동작 확인";

	this._showInfo(
		"TC-CHK-DYN-04  chkCssOv04  [ xcss rem + comp rem + script em(단위전환) ]",
		xcss, comp, script, exp, "chk_dyn04", ["paddingLeft","borderTopWidth","letterSpacing","wordSpacing"], 4);
};

/* ----------------------------------------------------------------
   TC-CHK-DYN-05: xcss em+rem + comp em+rem + script em+rem (복합 3단계)
---------------------------------------------------------------- */
this.btnDyn05_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var xcss = ".CheckBox.chkCssOv05 { font:16px; -nexa-text-padding:0px 0px 0px 0.5em; letter-spacing:0.1rem; }";

	var comp = "font=\"12px\" wordSpacing=\"0.5em\"   (comp: xcss font 오버라이드 + em wordSp)";

	var script = "this.chk_dyn05.set_font(\"18px/normal \\\"Malgun Gothic\\\"\");\n";
	script += "this.chk_dyn05.set_letterSpacing(\"0.2rem\");  // xcss rem 값 교체";

	var exp = "초기(xcss+comp):\n";
	exp += "  textPad: 0.5em × ? (xcss=16px vs comp=12px)\n";
	exp += "  letterSp(xcss): 0.1rem × MF\n";
	exp += "  wordSp(comp em): 0.5em × 12px = 6px\n\n";
	exp += "스크립트 적용 후 (font=18px, letterSpacing=0.2rem):\n";
	exp += "  textPad: 0.5em × 18px = 9px  (script font 반영 시)\n";
	exp += "  letterSp: 0.2rem × MF  (2배)\n";
	exp += "  wordSp: 0.5em × 18px = 9px  (script font 반영 시)\n\n";
	exp += "→ 3단계 em 기준 추적이 핵심 검증 포인트";

	this._showInfo(
		"TC-CHK-DYN-05  chkCssOv05  [ xcss em+rem + comp em+rem + script em+rem 복합 3단계 ]",
		xcss, comp, script, exp, "chk_dyn05", ["paddingLeft","letterSpacing","wordSpacing"], 5);
};

/* ----------------------------------------------------------------
   스크립트 적용 버튼
---------------------------------------------------------------- */
this.btn_apply_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (this._curTcNum === 0) {
		this.lbl_actual.set_text("먼저 좌측 TC 버튼을 클릭하여 케이스를 선택하세요.");
		return;
	}
	var msg = "";
	if (this._curTcNum === 1) {
		this.chk_dyn01.set_font("22px/normal \"Malgun Gothic\"");
		msg = "[DYN-01] script 적용: font = 22px\n→ textPadding em 재계산 여부 확인";
	} else if (this._curTcNum === 2) {
		this.chk_dyn02.set_letterSpacing("0.2rem");
		msg = "[DYN-02] script 적용: letterSpacing = 0.2rem\n→ 기존 0.1rem의 2배로 변경";
	} else if (this._curTcNum === 3) {
		this.chk_dyn03.set_font("20px/normal \"Malgun Gothic\"");
		this.chk_dyn03.set_letterSpacing("0.15em");
		msg = "[DYN-03] script 적용: font=20px, letterSpacing=0.15em\n→ 0.15em × 20px = 3px (Pass)";
	} else if (this._curTcNum === 4) {
		this.chk_dyn04.set_wordSpacing("1em");
		msg = "[DYN-04] script 적용: wordSpacing = 1em (rem → em 전환)\n→ em 기준 확인";
	} else if (this._curTcNum === 5) {
		this.chk_dyn05.set_font("18px/normal \"Malgun Gothic\"");
		this.chk_dyn05.set_letterSpacing("0.2rem");
		msg = "[DYN-05] script 적용: font=18px, letterSpacing=0.2rem\n→ textPad·wordSp em 재계산 + letterSp rem 2배";
	}
	this.lbl_actual.set_text(msg + "\n\n[DOM 확인] 버튼으로 실측값을 확인하세요.");
};

/* ----------------------------------------------------------------
   직접설정 복원 버튼 (XML 직접 설정 값으로 되돌리기)
---------------------------------------------------------------- */
this.btn_restore_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (this._curTcNum === 0) {
		this.lbl_actual.set_text("먼저 좌측 TC 버튼을 클릭하여 케이스를 선택하세요.");
		return;
	}
	var msg = "";
	if (this._curTcNum === 1) {
		this.chk_dyn01.set_font("14px/normal \"Malgun Gothic\"");
		msg = "[DYN-01] 복원: font = 14px (XML 직접 설정 값)";
	} else if (this._curTcNum === 2) {
		this.chk_dyn02.set_letterSpacing("0.1rem");
		msg = "[DYN-02] 복원: letterSpacing = 0.1rem (XML 직접 설정 값)";
	} else if (this._curTcNum === 3) {
		this.chk_dyn03.set_font("16px/normal \"Malgun Gothic\"");
		this.chk_dyn03.set_letterSpacing("0.1em");
		msg = "[DYN-03] 복원: font=16px, letterSpacing=0.1em (XML 직접 설정 값)";
	} else if (this._curTcNum === 4) {
		this.chk_dyn04.set_wordSpacing("0.5rem");
		msg = "[DYN-04] 복원: wordSpacing = 0.5rem (XML 직접 설정 값)";
	} else if (this._curTcNum === 5) {
		this.chk_dyn05.set_font("12px/normal \"Malgun Gothic\"");
		this.chk_dyn05.set_letterSpacing("0.1rem");
		msg = "[DYN-05] 복원: font=12px, letterSpacing=0.1rem (XML 직접 설정 값)";
	}
	this.lbl_actual.set_text(msg + "\n\n[DOM 확인] 버튼으로 실측값을 확인하세요.");
};

/* ----------------------------------------------------------------
   DOM computed style 확인
---------------------------------------------------------------- */
this.btn_dom_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	if (!this._curDomId) {
		this.lbl_actual.set_text("먼저 좌측 TC 버튼을 클릭하여 케이스를 선택하세요.");
		return;
	}
	try {
		var el = window.document.getElementById(this._curDomId);
		if (!el) {
			this.lbl_actual.set_text("DOM 요소를 찾을 수 없습니다.\n경로: " + this._curDomId);
			return;
		}
		var cs = window.getComputedStyle(el);
		var out = "DOM 경로: " + this._curDomId + "\n\n";
		for (var i = 0; i < this._curProps.length; i++) {
			var prop = this._curProps[i];
			out += "  " + prop + " : " + cs[prop] + "\n";
		}
		out += "\n※ textPadding이 paddingLeft에 없으면 DevTools에서 하위 요소를 확인하세요.";
		this.lbl_actual.set_text(out);
	} catch(ex) {
		this.lbl_actual.set_text("오류: " + ex.message);
	}
};

/* ----------------------------------------------------------------
   전체 CheckBox DOM 실측값 일괄 확인
---------------------------------------------------------------- */
this.btn_all_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var base = "mainframe.WorkFrame.form.Div00.form.";
	var getSt = function(id, prop) {
		try {
			var el = window.document.getElementById(base + id);
			return el ? window.getComputedStyle(el)[prop] : "(없음)";
		} catch(ex) { return "(오류)"; }
	};
	var out = "=== 전체 CheckBox DOM 실측값 ===\n";
	out += "DYN-01: paddingLeft=" + getSt("chk_dyn01","paddingLeft") +
	       "  borderTop=" + getSt("chk_dyn01","borderTopWidth") + "\n";
	out += "DYN-02: paddingLeft=" + getSt("chk_dyn02","paddingLeft") +
	       "  borderTop=" + getSt("chk_dyn02","borderTopWidth") +
	       "  letterSp=" + getSt("chk_dyn02","letterSpacing") + "\n";
	out += "DYN-03: paddingLeft=" + getSt("chk_dyn03","paddingLeft") +
	       "  borderTop=" + getSt("chk_dyn03","borderTopWidth") +
	       "  letterSp=" + getSt("chk_dyn03","letterSpacing") + "\n";
	out += "DYN-04: paddingLeft=" + getSt("chk_dyn04","paddingLeft") +
	       "  borderTop=" + getSt("chk_dyn04","borderTopWidth") +
	       "  letterSp=" + getSt("chk_dyn04","letterSpacing") +
	       "  wordSp=" + getSt("chk_dyn04","wordSpacing") + "\n";
	out += "DYN-05: paddingLeft=" + getSt("chk_dyn05","paddingLeft") +
	       "  letterSp=" + getSt("chk_dyn05","letterSpacing") +
	       "  wordSp=" + getSt("chk_dyn05","wordSpacing");
	this.ta_result.deleteText();
	this.ta_result.value = out;
};

/* ----------------------------------------------------------------
   전체 초기화 (MF + 모든 CheckBox 복원)
---------------------------------------------------------------- */
this.btn_reset_all_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this._getMainFrame().font = "normal 30px/normal \"Malgun Gothic\"";
	this.chk_dyn01.set_font("14px/normal \"Malgun Gothic\"");
	this.chk_dyn02.set_letterSpacing("0.1rem");
	this.chk_dyn03.set_font("16px/normal \"Malgun Gothic\"");
	this.chk_dyn03.set_letterSpacing("0.1em");
	this.chk_dyn04.set_wordSpacing("0.5rem");
	this.chk_dyn05.set_font("12px/normal \"Malgun Gothic\"");
	this.chk_dyn05.set_letterSpacing("0.1rem");
	this._curTcNum = 0;
	this._curDomId = "";
	this._curProps = [];
	this.lbl_cls_name.set_text("← 좌측 TC 버튼을 클릭하세요");
	this.lbl_xcss.set_text("TC 버튼 클릭 → xcss 코드 표시");
	this.lbl_comp.set_text("TC 버튼 클릭 → 컴포넌트 직접 설정 코드 표시");
	this.lbl_script.set_text("TC 버튼 클릭 → script 동적 설정 코드 표시");
	this.lbl_expect.set_text("기대값이 여기 표시됩니다.");
	this.lbl_actual.set_text("← [DOM 확인] 버튼을 클릭하면 실측값이 표시됩니다.");
	this.ta_result.deleteText();
};
this.btn_reload_onclick = function(obj:nexacro.Button, e:nexacro.ClickEventInfo)
{
	this.reload();
};
