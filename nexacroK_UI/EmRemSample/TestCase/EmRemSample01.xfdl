<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="EmRemSample01" width="1280" height="720" titletext="[TC-C/EM] Combo itemheight em + em 중첩 검증" font="30px/normal &quot;Malgun Gothic&quot;">
    <Layouts>
      <Layout height="720" width="1280">
        <Static id="Static00" taborder="0" text="[TC-C] Combo/ListBox itemheight em  |  [TC-EM] em 중첩 구조 누적 방지 검증" left="10" top="20" width="700" height="40" font="13px &quot;Malgun Gothic&quot;"/>
        <Radio id="Radio00" taborder="1" left="10" top="66" width="680" height="68" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" direction="vertical" rowcount="2" onitemchanged="Radio00_onitemchanged" font="12px &quot;Malgun Gothic&quot;">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row><Col id="datacolumn">5px/normal "Malgun Gothic"</Col></Row>
              <Row><Col id="datacolumn">10px/normal "Malgun Gothic"</Col></Row>
              <Row><Col id="datacolumn">14px/normal "Malgun Gothic"</Col></Row>
              <Row><Col id="datacolumn">20px/normal "Malgun Gothic"</Col></Row>
            </Rows>
          </Dataset>
        </Radio>

        <!-- 열1: TC-C-01 Combo 3종 (left=10) -->
        <Static id="lbl_c01a" taborder="2" text="[TC-C-01] Combo itemheight=2em / font=10px → 기대:20px" left="10" top="152" width="215" height="14" font="9px Malgun Gothic"/>
        <Combo id="comp00" taborder="3" left="10" top="168" width="215" height="56" font="10px/normal &quot;Malgun Gothic&quot;" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" itemheight="2em">
          <Dataset id="innerdataset">
            <ColumnInfo><Column id="codecolumn" size="256"/><Column id="datacolumn" size="256"/></ColumnInfo>
            <Rows>
              <Row><Col id="codecolumn">1</Col><Col id="datacolumn">항목 1</Col></Row>
              <Row><Col id="codecolumn">2</Col><Col id="datacolumn">항목 2</Col></Row>
              <Row><Col id="codecolumn">3</Col><Col id="datacolumn">항목 3</Col></Row>
              <Row><Col id="codecolumn">4</Col><Col id="datacolumn">항목 4</Col></Row>
            </Rows>
          </Dataset>
        </Combo>

        <Static id="lbl_c01b" taborder="4" text="[TC-C-01] Combo itemheight=2em / font=14px → 기대:28px" left="10" top="242" width="215" height="14" font="9px Malgun Gothic"/>
        <Combo id="comp01" taborder="5" left="10" top="258" width="215" height="56" font="14px/normal &quot;Malgun Gothic&quot;" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" itemheight="2em">
          <Dataset id="innerdataset">
            <ColumnInfo><Column id="codecolumn" size="256"/><Column id="datacolumn" size="256"/></ColumnInfo>
            <Rows>
              <Row><Col id="codecolumn">1</Col><Col id="datacolumn">항목 1</Col></Row>
              <Row><Col id="codecolumn">2</Col><Col id="datacolumn">항목 2</Col></Row>
              <Row><Col id="codecolumn">3</Col><Col id="datacolumn">항목 3</Col></Row>
              <Row><Col id="codecolumn">4</Col><Col id="datacolumn">항목 4</Col></Row>
            </Rows>
          </Dataset>
        </Combo>

        <Static id="lbl_c01c" taborder="6" text="[TC-C-01] Combo itemheight=2em / font=20px → 기대:40px" left="10" top="332" width="215" height="14" font="9px Malgun Gothic"/>
        <Combo id="comp02" taborder="7" left="10" top="348" width="215" height="56" font="20px/normal &quot;Malgun Gothic&quot;" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" itemheight="2em">
          <Dataset id="innerdataset">
            <ColumnInfo><Column id="codecolumn" size="256"/><Column id="datacolumn" size="256"/></ColumnInfo>
            <Rows>
              <Row><Col id="codecolumn">1</Col><Col id="datacolumn">항목 1</Col></Row>
              <Row><Col id="codecolumn">2</Col><Col id="datacolumn">항목 2</Col></Row>
              <Row><Col id="codecolumn">3</Col><Col id="datacolumn">항목 3</Col></Row>
              <Row><Col id="codecolumn">4</Col><Col id="datacolumn">항목 4</Col></Row>
            </Rows>
          </Dataset>
        </Combo>

        <!-- 열2: ListBox + MultiCombo (left=240) -->
        <Static id="lbl_c01d" taborder="8" text="[TC-C-01] ListBox itemheight=2.5em / font=10px → 기대:25px" left="240" top="152" width="220" height="14" font="9px Malgun Gothic"/>
        <ListBox id="comp03" taborder="9" left="240" top="168" width="220" height="180" font="10px/normal &quot;Malgun Gothic&quot;" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" itemheight="2.5em">
          <Dataset id="innerdataset">
            <ColumnInfo><Column id="codecolumn" size="256"/><Column id="datacolumn" size="256"/></ColumnInfo>
            <Rows>
              <Row><Col id="codecolumn">1</Col><Col id="datacolumn">항목 1</Col></Row>
              <Row><Col id="codecolumn">2</Col><Col id="datacolumn">항목 2</Col></Row>
              <Row><Col id="codecolumn">3</Col><Col id="datacolumn">항목 3</Col></Row>
              <Row><Col id="codecolumn">4</Col><Col id="datacolumn">항목 4</Col></Row>
            </Rows>
          </Dataset>
        </ListBox>

        <Static id="lbl_c02" taborder="10" text="[TC-C-02] MultiCombo tagbox gap em  (hgap=0.5em, vgap=0.25em)" left="240" top="364" width="220" height="14" font="9px Malgun Gothic"/>
        <MultiCombo id="comp04" taborder="11" left="240" top="380" width="220" height="90" font="10px/normal &quot;Malgun Gothic&quot;" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" tagboxitemhorizontalgap="0.5em" tagboxitemverticalgap="0.25em" index="0,1,2">
          <Dataset id="innerdataset">
            <ColumnInfo><Column id="codecolumn" size="256"/><Column id="datacolumn" size="256"/></ColumnInfo>
            <Rows>
              <Row><Col id="codecolumn">1</Col><Col id="datacolumn">태그A</Col></Row>
              <Row><Col id="codecolumn">2</Col><Col id="datacolumn">태그B</Col></Row>
              <Row><Col id="codecolumn">3</Col><Col id="datacolumn">태그C</Col></Row>
            </Rows>
          </Dataset>
        </MultiCombo>

        <!-- 열3: TC-EM (left=480) -->
        <Static id="lbl_em01" taborder="12" text="[TC-EM-01] em 중첩 — Div font=20px > Button font=0.5em(=10px) > width=2em" left="478" top="152" width="230" height="28" font="9px Malgun Gothic"/>
        <Div id="Div_em01" taborder="13" left="478" top="184" width="230" height="100" font="20px/normal &quot;Malgun Gothic&quot;" border="1px dashed #666">
          <Layouts>
            <Layout width="230" height="100">
              <Static id="lbl_div_font" taborder="0" text="Div font=20px" left="5" top="5" width="220" height="16" font="9px Malgun Gothic"/>
              <Button id="btn_nested" taborder="1" text="width=2em / font=0.5em" left="5" top="28" height="58" width="2em" onclick="btn_nested_onclick" font="0.5em/normal &quot;Malgun Gothic&quot;" border="1px solid #e74c3c"/>
            </Layout>
          </Layouts>
        </Div>
        <Static id="lbl_em01_expect" taborder="14" text="Pass: Button width=20px (자신 10px×2)  NG: 40px (부모 20px×2 누적)" left="478" top="292" width="230" height="28" font="9px Malgun Gothic"/>

        <Static id="lbl_em02" taborder="15" text="[TC-EM-02] XML 저장 무결성 — setter 후 단위 문자열 보존" left="478" top="336" width="230" height="14" font="9px Malgun Gothic"/>
        <Button id="btn_em02_set" taborder="16" text="setter 적용" left="478" top="354" width="110" height="44" onclick="btn_em02_set_onclick" font="12px &quot;Malgun Gothic&quot;"/>
        <Button id="btn_em02_chk" taborder="17" text="값 확인" left="596" top="354" width="110" height="44" onclick="btn_em02_chk_onclick" font="12px &quot;Malgun Gothic&quot;"/>
        <Button id="btn_em02_target" taborder="18" text="setter 대상 버튼" left="478" top="408" width="230" height="64" font="10px/normal &quot;Malgun Gothic&quot;" border="1px solid #999"/>

        <!-- 결과 영역 (우측) -->
        <Combo id="Combo01" taborder="19" left="724" top="152" width="370" height="50" innerdataset="Dataset00" datacolumn="datacolumn" codecolumn="codecolumn" font="12px &quot;Malgun Gothic&quot;"/>
        <Button id="Button01" taborder="20" text="값 확인" left="1104" top="152" width="80" height="50" onclick="Button01_onclick" font="12px &quot;Malgun Gothic&quot;"/>
        <TextArea id="TextArea00" taborder="21" left="724" top="214" width="546" height="490" font="12px &quot;Malgun Gothic&quot;"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="Dataset00">
        <ColumnInfo>
          <Column id="codecolumn" size="256"/>
          <Column id="datacolumn" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row><Col id="codecolumn">0</Col><Col id="datacolumn">TC-C-01 Combo itemheight em (font=10px)</Col></Row>
          <Row><Col id="codecolumn">1</Col><Col id="datacolumn">TC-C-01 Combo itemheight em (font=14px)</Col></Row>
          <Row><Col id="codecolumn">2</Col><Col id="datacolumn">TC-C-01 Combo itemheight em (font=20px)</Col></Row>
          <Row><Col id="codecolumn">3</Col><Col id="datacolumn">TC-C-01 ListBox itemheight em</Col></Row>
          <Row><Col id="codecolumn">4</Col><Col id="datacolumn">TC-C-02 MultiCombo tagbox gap em</Col></Row>
          <Row><Col id="codecolumn">5</Col><Col id="datacolumn">TC-EM-01 em 중첩 구조 누적 방지</Col></Row>
          <Row><Col id="codecolumn">6</Col><Col id="datacolumn">TC-EM-02 XML 저장 무결성</Col></Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[
this.Radio00_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	["comp00", "comp01", "comp02", "comp03", "comp04"].forEach(key => {
		if(this.all[key]) this.all[key].font = obj.text;
	});
	this.resetScroll();
};

this.Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var msg;
	switch(this.Combo01.index) {
	case 0:
		msg = "[TC-C-01] Combo itemheight em — font=10px\n"
		    + "설정: itemheight=2em, font=10px\n"
		    + "Pass: 드롭다운 각 행 높이 = 20px\n"
		    + "NG  : 2px 처리 또는 MainFrame 12px×2=24px 고정\n\n"
		    + "속성값:\n"
		    + "itemheight = " + this.comp00.itemheight + "\n"
		    + "font       = " + this.comp00.font;
		break;
	case 1:
		msg = "[TC-C-01] Combo itemheight em — font=14px\n"
		    + "설정: itemheight=2em, font=14px\n"
		    + "Pass: 드롭다운 각 행 높이 = 28px\n\n"
		    + "속성값:\n"
		    + "itemheight = " + this.comp01.itemheight + "\n"
		    + "font       = " + this.comp01.font;
		break;
	case 2:
		msg = "[TC-C-01] Combo itemheight em — font=20px\n"
		    + "설정: itemheight=2em, font=20px\n"
		    + "Pass: 드롭다운 각 행 높이 = 40px\n\n"
		    + "속성값:\n"
		    + "itemheight = " + this.comp02.itemheight + "\n"
		    + "font       = " + this.comp02.font;
		break;
	case 3:
		msg = "[TC-C-01] ListBox itemheight em — font=10px\n"
		    + "설정: itemheight=2.5em, font=10px\n"
		    + "Pass: 각 행 높이 = 25px\n\n"
		    + "속성값:\n"
		    + "itemheight = " + this.comp03.itemheight + "\n"
		    + "font       = " + this.comp03.font;
		break;
	case 4:
		msg = "[TC-C-02] MultiCombo tagbox gap em\n"
		    + "설정: hgap=0.5em, vgap=0.25em\n\n"
		    + "속성값:\n"
		    + "tagboxitemhorizontalgap = " + this.comp04.tagboxitemhorizontalgap + "\n"
		    + "tagboxitemverticalgap   = " + this.comp04.tagboxitemverticalgap;
		break;
	case 5:
		msg = "[TC-EM-01] em 중첩 구조 — 누적 방지\n"
		    + "구조: Div(font=20px) > Button(font=0.5em, width=2em)\n"
		    + "Button computed font: 0.5em × 20px = 10px\n"
		    + "Pass: Button getOffsetWidth = 20px (자신 10px × 2)\n"
		    + "NG  : Button getOffsetWidth = 40px (부모 20px × 2 누적)\n\n"
		    + "btn_nested.font           = " + this.Div_em01.btn_nested.font + "\n"
		    + "btn_nested.width          = " + this.Div_em01.btn_nested.width + "\n"
		    + "btn_nested.getOffsetWidth = " + this.Div_em01.btn_nested.getOffsetWidth();
		break;
	case 6:
		msg = "[TC-EM-02] XML 저장 무결성\n"
		    + "[setter 적용] 버튼으로 동적 속성 설정 후\n"
		    + "[값 확인] 버튼으로 단위 문자열 보존 여부 확인\n\n"
		    + "Pass: '8rem', '0.5em 1rem', '0.05em' 문자열 그대로 보존\n"
		    + "NG  : '8', '0.5 1', '0.05' — 숫자만 저장 (단위 손실)";
		break;
	default:
		msg = "Combo에서 항목을 선택한 후 [값 확인]을 클릭하세요.";
	}
	this.TextArea00.deleteText();
	this.TextArea00.value = msg;
};

this.btn_nested_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-EM-01] em 중첩 구조\n"
	    + "Div font=20px > Button font=0.5em\n"
	    + "Button computed font = 10px (0.5 × 20)\n"
	    + "Button width=2em → 기대: 20px (자신 10px 기준)\n\n"
	    + "btn_nested.getOffsetWidth  = " + this.Div_em01.btn_nested.getOffsetWidth() + "\n"
	    + "btn_nested.getOffsetHeight = " + this.Div_em01.btn_nested.getOffsetHeight();
};

this.btn_em02_set_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.btn_em02_target.set_width("8rem");
	this.btn_em02_target.set_padding("0.5em 1rem");
	this.btn_em02_target.set_letterSpacing("0.05em");
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-EM-02] setter 적용 완료\n"
	    + "btn_em02_target에 다음 값 설정:\n"
	    + "  width         = 8rem\n"
	    + "  padding       = 0.5em 1rem\n"
	    + "  letterSpacing = 0.05em\n\n"
	    + "[값 확인] 버튼을 클릭하여 단위 보존 여부 확인";
};

this.btn_em02_chk_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var el = document.getElementById("mainframe.WorkFrame.form.Div00.form.btn_em02_target");
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-EM-02] XML 저장 무결성 확인\n\n"
	    + "속성값 (단위 보존 여부):\n"
	    + "width         = " + this.btn_em02_target.width + "\n"
	    + "padding       = " + this.btn_em02_target.padding + "\n"
	    + "letterSpacing = " + this.btn_em02_target.letterSpacing + "\n\n"
	    + "DOM computed:\n"
	    + "width         = " + window.getComputedStyle(el).width + "\n"
	    + "padding       = " + window.getComputedStyle(el).padding + "\n"
	    + "letterSpacing = " + window.getComputedStyle(el).letterSpacing;
};
]]></Script>
  </Form>
</FDL>
