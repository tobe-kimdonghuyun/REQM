<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="EmRemSample00" width="1280" height="720" titletext="[TC-B] Button em/rem 속성 검증" font="30px/normal &quot;Malgun Gothic&quot;">
    <Layouts>
      <Layout height="720" width="1280">
        <Static id="lbl_typeinfo" taborder="6" text="[테스트유형] 정적설정 — XML 속성에 em 직접 지정  |  [사용 컴포넌트] Button · Static · Radio · Combo · TextArea" left="10" top="4" width="1260" height="14" font="9px Malgun Gothic" forecolor="#1A3A5C" background="url('') #EBF3FF"/>
        <Static id="Static00" taborder="0" text="[TC-B] Button 계열 em/rem 핵심 속성 검증  (기본 font = 10px/normal Malgun Gothic)" left="10" top="20" width="700" height="40" font="13px &quot;Malgun Gothic&quot;"/>
        <Radio id="Radio00" taborder="1" left="10" top="66" width="680" height="68" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" direction="vertical" rowcount="2" onitemchanged="Radio00_onitemchanged" font="12px &quot;Malgun Gothic&quot;">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row>
                <Col id="datacolumn">5px/normal "Malgun Gothic"</Col>
              </Row>
              <Row>
                <Col id="datacolumn">10px/normal "Malgun Gothic"</Col>
              </Row>
              <Row>
                <Col id="datacolumn">16px/normal "Malgun Gothic"</Col>
              </Row>
              <Row>
                <Col id="datacolumn">20px/normal "Malgun Gothic"</Col>
              </Row>
            </Rows>
          </Dataset>
        </Radio>
        <!-- 행1: TC-B-01~03 -->
        <!-- 행2: TC-B-04~06 -->
        <!-- 행3: TC-B-07~09 -->
        <!-- 결과 영역 (우측) -->
        <Combo id="Combo01" taborder="2" left="15" top="834" width="380" height="40" innerdataset="Dataset00" datacolumn="datacolumn" codecolumn="codecolumn" font="12px &quot;Malgun Gothic&quot;"/>
        <Button id="Button01" taborder="3" text="값 확인" left="410" top="825" width="80" height="50" onclick="Button01_onclick" font="12px &quot;Malgun Gothic&quot;"/>
        <TextArea id="TextArea00" taborder="4" left="15" top="885" width="470" height="150" font="12px &quot;Malgun Gothic&quot;"/>
        <Button id="btn_reload" taborder="5" text="[초기화]" left="1165" top="8" width="100" height="30" onclick="btn_reload_onclick" font="11px &quot;Malgun Gothic&quot;" border="1px solid #CC0000"/>
        <Grid id="Grid00" taborder="7" left="10" top="140" width="1250" height="200" binddataset="Dataset01">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="130"/>
                <Column size="130"/>
                <Column size="130"/>
                <Column size="79"/>
                <Column size="118"/>
                <Column size="130"/>
                <Column size="130"/>
                <Column size="130"/>
                <Column size="130"/>
                <Column size="79"/>
              </Columns>
              <Rows>
                <Row size="24" band="head"/>
                <Row size="40"/>
              </Rows>
              <Band id="head">
                <Cell text="text"/>
                <Cell col="1" text="combo"/>
                <Cell col="2" text="calendar"/>
                <Cell col="3" text="checkbox"/>
                <Cell col="4" text="maskedit"/>
                <Cell col="5" text="multicombo-single"/>
                <Cell col="6" text="multicombo-multi"/>
                <Cell col="7" text="expandbutton"/>
                <Cell col="8" text="progressbar"/>
                <Cell col="9" text="radio"/>
              </Band>
              <Band id="body">
                <Cell text="bind:Column0" displaytype="editcontrol" edittype="text" font="normal 10px/normal &quot;Malgun Gothic&quot;"/>
                <Cell col="1" text="bind:Column1" displaytype="combocontrol" edittype="combo" combodataset="Dataset02" combodatacol="datacolumn" combocodecol="codecolumn" combobuttonsize="40 40" combopopupsize="100 100" font="normal 10px/normal &quot;Malgun Gothic&quot;"/>
                <Cell col="2" text="bind:Column2" displaytype="calendarcontrol" edittype="date" calendartype="normal" font="normal 10px/normal &quot;Malgun Gothic&quot;" calendarbuttonsize="20 20" calendardaysize="30 30" calendarpopupsize="40 40"/>
                <Cell col="3" text="bind:Column3" displaytype="checkboxcontrol" edittype="checkbox" checkboxtruevalue="1" checkboxfalsevalue="0" font="normal 10px/normal &quot;Malgun Gothic&quot;" checkboxsize="100"/>
                <Cell col="4" text="bind:Column4" font="normal 10px/normal &quot;Malgun Gothic&quot;"/>
                <Cell col="5" text="bind:Column5" multicombotype="search" displaytype="multicombocontrol" edittype="multicombo" multicombodataset="Dataset00" multicombodatacol="datacolumn" multicombocodecol="codecolumn" multicomboedittype="singletag" font="normal 10px/normal &quot;Malgun Gothic&quot;" combobuttonsize="30 30" combopopupsize="40 40" comboitemheight="40"/>
                <Cell col="6" text="bind:Column5" multicombotype="search" displaytype="multicombocontrol" edittype="multicombo" multicombodataset="Dataset00" multicombodatacol="datacolumn" multicombocodecol="codecolumn" multicomboedittype="multitag" font="normal 10px/normal &quot;Malgun Gothic&quot;" combopopupsize="40 40" combobuttonsize="40 40" comboitemheight="40"/>
                <Cell col="7" text="bind:Column6" edittype="text" displaytype="text" expandshow="show" expandsize="30" font="normal 10px/normal &quot;Malgun Gothic&quot;"/>
                <Cell col="8" text="bind:Column7" displaytype="progressbarcontrol" edittype="normal" progressbarsmooth="true" font="normal 10px/normal &quot;Malgun Gothic&quot;"/>
                <Cell col="9" text="bind:Column8" displaytype="radioitemcontrol" edittype="radioitem" radioitemcodevalue="bind:Column8" font="normal 10px/normal &quot;Malgun Gothic&quot;"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
        <Grid id="Grid00_00" taborder="8" left="10" top="345" width="1250" height="470" binddataset="Dataset01">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="600"/>
                <Column size="600"/>
              </Columns>
              <Rows>
                <Row size="24" band="head"/>
                <Row size="100"/>
              </Rows>
              <Band id="head">
                <Cell text="multicombo-single"/>
                <Cell col="1" text="multicombo-multi"/>
              </Band>
              <Band id="body">
                <Cell text="bind:Column5" multicombotype="search" displaytype="multicombocontrol" edittype="multicombo" multicombodataset="Dataset02" multicombodatacol="datacolumn" multicombocodecol="codecolumn" multicomboedittype="singletag"/>
                <Cell col="1" text="bind:Column5" multicombotype="search" displaytype="multicombocontrol" edittype="multicombo" multicombodataset="Dataset02" multicombodatacol="datacolumn" multicombocodecol="codecolumn" multicomboedittype="multitag"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
      </Layout>
    </Layouts>
