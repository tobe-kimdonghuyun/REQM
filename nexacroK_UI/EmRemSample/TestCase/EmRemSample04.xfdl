<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="EmRemSample04" width="1280" height="720" titletext="[TC-CAL] Calendar em/rem 속성 검증 — headheight/daysize/buttonsize/popupsize" font="30px/normal &quot;Malgun Gothic&quot;">
    <Layouts>
      <Layout height="720" width="1280">
        <Static id="Static00" taborder="0" text="[TC-CAL] Calendar — headheight/daysize/buttonsize/popupsize  em vs rem  |  XML 정적 vs Script 동적(onload) 동일값 비교" left="10" top="20" width="950" height="36" font="13px &quot;Malgun Gothic&quot;"/>

        <!-- MainFrame font 변경 버튼 -->
        <Button id="btnMF12" taborder="1" text="MF=12px" left="10" top="62" width="72" height="34" onclick="btnMF12_onclick" font="12px &quot;Malgun Gothic&quot;" border="2px solid #555"/>
        <Button id="btnMF16" taborder="2" text="MF=16px" left="90" top="62" width="72" height="34" onclick="btnMF16_onclick" font="12px &quot;Malgun Gothic&quot;" border="2px solid #555"/>
        <Button id="btnMF20" taborder="3" text="MF=20px" left="170" top="62" width="72" height="34" onclick="btnMF20_onclick" font="12px &quot;Malgun Gothic&quot;" border="2px solid #555"/>
        <Button id="btnMF24" taborder="4" text="MF=24px" left="250" top="62" width="72" height="34" onclick="btnMF24_onclick" font="12px &quot;Malgun Gothic&quot;" border="2px solid #555"/>
        <Static id="lbl_mf" taborder="5" text="↑ MF font 변경 → rem 캘린더만 재계산 / em 캘린더는 calendar font(12px) 기준 불변" left="335" top="71" width="530" height="15" font="9px Malgun Gothic"/>

        <!-- 섹션 헤더 -->
        <Static id="lbl_xml_title" taborder="6" text="【 XML 정적 설정 】" left="10" top="104" width="574" height="16" font="11px &quot;Malgun Gothic&quot;" forecolor="#1A5276"/>
        <Static id="lbl_scr_title" taborder="7" text="【 Script 동적 설정 (Form_onload) 】" left="610" top="104" width="560" height="16" font="11px &quot;Malgun Gothic&quot;" forecolor="#922B21"/>

        <!-- 섹션 구분선 -->
        <Static id="lbl_sec_div" taborder="8" text="" left="593" top="104" width="4" height="282" border="1px solid #AAAAAA"/>

        <!-- em/rem 서브 헤더 -->
        <Static id="lbl_em_xml_hdr" taborder="9" text="[em 방식]  calendar font=12px 기준" left="10" top="122" width="280" height="14" font="9px Malgun Gothic" forecolor="#1A5276"/>
        <Static id="lbl_rem_xml_hdr" taborder="10" text="[rem 방식]  MainFrame font 기준" left="300" top="122" width="280" height="14" font="9px Malgun Gothic" forecolor="#922B21"/>
        <Static id="lbl_em_scr_hdr" taborder="11" text="[em 방식]  calendar font=12px 기준" left="610" top="122" width="280" height="14" font="9px Malgun Gothic" forecolor="#1A5276"/>
        <Static id="lbl_rem_scr_hdr" taborder="12" text="[rem 방식]  MainFrame font 기준" left="900" top="122" width="280" height="14" font="9px Malgun Gothic" forecolor="#922B21"/>

        <!-- 속성값 안내 라벨 -->
        <Static id="lbl_em_xml_p1" taborder="13" text="headheight=2em  daysize=2em  buttonsize=1.5em 1.5em  popupsize=22em 20em" left="10" top="138" width="280" height="26" font="8px Malgun Gothic"/>
        <Static id="lbl_rem_xml_p1" taborder="14" text="headheight=2rem  daysize=2rem  buttonsize=1.5rem 1.5rem  popupsize=22rem 20rem" left="300" top="138" width="280" height="26" font="8px Malgun Gothic"/>
        <Static id="lbl_em_scr_p1" taborder="15" text="headheight=2em  daysize=2em  buttonsize=1.5em 1.5em  popupsize=22em 20em" left="610" top="138" width="280" height="26" font="8px Malgun Gothic"/>
        <Static id="lbl_rem_scr_p1" taborder="16" text="headheight=2rem  daysize=2rem  buttonsize=1.5rem 1.5rem  popupsize=22rem 20rem" left="900" top="138" width="280" height="26" font="8px Malgun Gothic"/>

        <!-- Calendar: XML 정적 em (속성 XML에 직접 선언) -->
        <Calendar id="cal_em_xml" taborder="17" left="10" top="166" width="280" height="218"
          font="12px/normal &quot;Malgun Gothic&quot;"
          headheight="2em" daysize="2em" buttonsize="1.5em 1.5em" popupsize="22em 20em"/>

        <!-- Calendar: XML 정적 rem (속성 XML에 직접 선언) -->
        <Calendar id="cal_rem_xml" taborder="18" left="300" top="166" width="280" height="218"
          font="12px/normal &quot;Malgun Gothic&quot;"
          headheight="2rem" daysize="2rem" buttonsize="1.5rem 1.5rem" popupsize="22rem 20rem"/>

        <!-- Calendar: Script 동적 em (Form_onload에서 설정 — 위 cal_em_xml과 동일값) -->
        <Calendar id="cal_em_scr" taborder="19" left="610" top="166" width="280" height="218"
          font="12px/normal &quot;Malgun Gothic&quot;"/>

        <!-- Calendar: Script 동적 rem (Form_onload에서 설정 — 위 cal_rem_xml과 동일값) -->
        <Calendar id="cal_rem_scr" taborder="20" left="900" top="166" width="280" height="218"
          font="12px/normal &quot;Malgun Gothic&quot;"/>

        <!-- 결과 영역 -->
        <Combo id="Combo01" taborder="21" left="10" top="396" width="350" height="40" innerdataset="Dataset00" datacolumn="datacolumn" codecolumn="codecolumn" font="12px &quot;Malgun Gothic&quot;"/>
        <Button id="Button01" taborder="22" text="값 확인" left="370" top="396" width="80" height="40" onclick="Button01_onclick" font="12px &quot;Malgun Gothic&quot;"/>
        <TextArea id="TextArea00" taborder="23" left="10" top="446" width="1250" height="256" font="12px &quot;Malgun Gothic&quot;"/>
        <Button id="btn_reload" taborder="24" text="[초기화]" left="1165" top="8" width="100" height="30" onclick="btn_reload_onclick" font="11px &quot;Malgun Gothic&quot;" border="1px solid #CC0000"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="Dataset00">
        <ColumnInfo>
          <Column id="codecolumn" size="256"/>
          <Column id="datacolumn" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row><Col id="codecolumn">0</Col><Col id="datacolumn">cal_em_xml — XML 정적 em 속성값</Col></Row>
          <Row><Col id="codecolumn">1</Col><Col id="datacolumn">cal_rem_xml — XML 정적 rem 속성값</Col></Row>
          <Row><Col id="codecolumn">2</Col><Col id="datacolumn">cal_em_scr — Script 동적 em 속성값</Col></Row>
          <Row><Col id="codecolumn">3</Col><Col id="datacolumn">cal_rem_scr — Script 동적 rem 속성값</Col></Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[
/* em/rem 속성을 Script 동적으로 설정 (cal_em_xml / cal_rem_xml의 XML 선언값과 동일) */
this.Form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// cal_em_scr: em 방식 동적 설정 — cal_em_xml과 동일한 값
	this.cal_em_scr.headheight = "2em";
	this.cal_em_scr.daysize    = "2em";
	this.cal_em_scr.buttonsize = "1.5em 1.5em";
	this.cal_em_scr.popupsize  = "22em 20em";

	// cal_rem_scr: rem 방식 동적 설정 — cal_rem_xml과 동일한 값
	this.cal_rem_scr.headheight = "2rem";
	this.cal_rem_scr.daysize    = "2rem";
	this.cal_rem_scr.buttonsize = "1.5rem 1.5rem";
	this.cal_rem_scr.popupsize  = "22rem 20rem";
};

this.btnMF12_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this._getMainFrame().font = "normal 12px/normal \"Malgun Gothic\"";
	this.resetScroll();
	this.TextArea00.deleteText();
	this.TextArea00.value = "MF font = 12px  (1rem = 12px)\n\n"
	    + "[em 캘린더]  calendar font=12px 고정 — MF 변경 무관\n"
	    + "  headheight=2em   → 24px  (12 × 2)\n"
	    + "  daysize=2em      → 24px\n"
	    + "  buttonsize=1.5em → 18px\n\n"
	    + "[rem 캘린더]  MF=12px 기준으로 계산\n"
	    + "  headheight=2rem   → 24px  (12 × 2)\n"
	    + "  daysize=2rem      → 24px\n"
	    + "  buttonsize=1.5rem → 18px\n\n"
	    + "※ MF font = calendar font = 12px 이므로 em ≈ rem (동일 결과)";
};

this.btnMF16_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this._getMainFrame().font = "normal 16px/normal \"Malgun Gothic\"";
	this.resetScroll();
	this.TextArea00.deleteText();
	this.TextArea00.value = "MF font = 16px  (1rem = 16px)\n\n"
	    + "[em 캘린더]  calendar font=12px 고정 — 변화 없음\n"
	    + "  headheight=2em   → 여전히 24px\n"
	    + "  daysize=2em      → 여전히 24px\n"
	    + "  buttonsize=1.5em → 여전히 18px\n\n"
	    + "[rem 캘린더]  MF=16px → rem 재계산됨\n"
	    + "  headheight=2rem   → 32px  (16 × 2)\n"
	    + "  daysize=2rem      → 32px\n"
	    + "  buttonsize=1.5rem → 24px  (16 × 1.5)";
};

this.btnMF20_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this._getMainFrame().font = "normal 20px/normal \"Malgun Gothic\"";
	this.resetScroll();
	this.TextArea00.deleteText();
	this.TextArea00.value = "MF font = 20px  (1rem = 20px)\n\n"
	    + "[em 캘린더]  calendar font=12px 고정 — 변화 없음\n"
	    + "  headheight=2em   → 여전히 24px\n"
	    + "  daysize=2em      → 여전히 24px\n"
	    + "  buttonsize=1.5em → 여전히 18px\n\n"
	    + "[rem 캘린더]  MF=20px → rem 재계산됨\n"
	    + "  headheight=2rem   → 40px  (20 × 2)\n"
	    + "  daysize=2rem      → 40px\n"
	    + "  buttonsize=1.5rem → 30px  (20 × 1.5)";
};

this.btnMF24_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this._getMainFrame().font = "normal 24px/normal \"Malgun Gothic\"";
	this.resetScroll();
	this.TextArea00.deleteText();
	this.TextArea00.value = "MF font = 24px  (1rem = 24px)\n\n"
	    + "[em 캘린더]  calendar font=12px 고정 — 변화 없음\n"
	    + "  headheight=2em   → 여전히 24px\n"
	    + "  daysize=2em      → 여전히 24px\n"
	    + "  buttonsize=1.5em → 여전히 18px\n\n"
	    + "[rem 캘린더]  MF=24px → rem 재계산됨\n"
	    + "  headheight=2rem   → 48px  (24 × 2)\n"
	    + "  daysize=2rem      → 48px\n"
	    + "  buttonsize=1.5rem → 36px  (24 × 1.5)";
};

this.Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var cal, label;
	switch(this.Combo01.index) {
	case 0:  cal = this.cal_em_xml;  label = "[cal_em_xml]  XML 정적 em";    break;
	case 1:  cal = this.cal_rem_xml; label = "[cal_rem_xml]  XML 정적 rem";   break;
	case 2:  cal = this.cal_em_scr;  label = "[cal_em_scr]  Script 동적 em";  break;
	case 3:  cal = this.cal_rem_scr; label = "[cal_rem_scr]  Script 동적 rem"; break;
	default:
		this.TextArea00.deleteText();
		this.TextArea00.value = "Combo에서 캘린더를 선택한 후 [값 확인]을 클릭하세요.";
		return;
	}
	this.TextArea00.deleteText();
	this.TextArea00.value = label + "\n\n"
	    + "headheight = " + cal.headheight + "\n"
	    + "daysize    = " + cal.daysize + "\n"
	    + "buttonsize = " + cal.buttonsize + "\n"
	    + "popupsize  = " + cal.popupsize + "\n\n"
	    + "Pass 기준:\n"
	    + "  em 계열 → 단위 문자열(em) 그대로 보존 확인\n"
	    + "  rem 계열 → 단위 문자열(rem) 그대로 보존 확인\n"
	    + "  XML 정적값 == Script 동적값 (동일 문자열)";
};
this.btn_reload_onclick = function(obj:nexacro.Button, e:nexacro.ClickEventInfo)
{
	this.reload();
};
]]></Script>
  </Form>
</FDL>
