<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="EmRemSample02" width="1280" height="720" titletext="[TC-R] Button rem 속성 검증" font="30px/normal &quot;Malgun Gothic&quot;">
    <Layouts>
      <Layout height="720" width="1280">
        <Static id="Static00" taborder="0" text="[TC-R] Button rem 속성 검증 — rem 기준: MainFrame font-size  ↓ MF font 변경 버튼으로 rem 일괄 재계산 확인" left="10" top="20" width="700" height="36" font="13px &quot;Malgun Gothic&quot;"/>

        <!-- MainFrame font 변경 버튼 -->
        <Button id="btnMF12" taborder="1" text="MF=12px" left="10" top="62" width="72" height="34" onclick="btnMF12_onclick" font="12px &quot;Malgun Gothic&quot;" border="2px solid #555"/>
        <Button id="btnMF16" taborder="2" text="MF=16px" left="90" top="62" width="72" height="34" onclick="btnMF16_onclick" font="12px &quot;Malgun Gothic&quot;" border="2px solid #555"/>
        <Button id="btnMF20" taborder="3" text="MF=20px" left="170" top="62" width="72" height="34" onclick="btnMF20_onclick" font="12px &quot;Malgun Gothic&quot;" border="2px solid #555"/>
        <Button id="btnMF24" taborder="4" text="MF=24px" left="250" top="62" width="72" height="34" onclick="btnMF24_onclick" font="12px &quot;Malgun Gothic&quot;" border="2px solid #555"/>
        <Static id="lbl_mf" taborder="5" text="↑ MF font 변경 → rem 버튼들 크기/여백 일괄 재계산  (rem = MF font-size × 배수)" left="335" top="71" width="380" height="15" font="9px Malgun Gothic"/>

        <!-- 행1: TC-R-01 / TC-R-02 / TC-R-03 -->
        <Static id="lbl_r01" taborder="6" text="[TC-R-01] width=8rem / height=3rem  (MF16px기준:128px/48px)" left="10" top="112" width="185" height="14" font="9px Malgun Gothic"/>
        <Button id="btn_r01" taborder="7" text="8rem × 3rem" left="10" top="128" height="3rem" width="8rem" onclick="btn_r01_onclick" font="10px/normal &quot;Malgun Gothic&quot;" border="1px solid #3498db"/>

        <Static id="lbl_r02" taborder="8" text="[TC-R-02] padding=0.5rem 1rem 0.75rem 1.5rem" left="210" top="112" width="185" height="14" font="9px Malgun Gothic"/>
        <Button id="btn_r02" taborder="9" text="padding rem 4방향" left="210" top="128" height="72" width="185" onclick="btn_r02_onclick" font="10px/normal &quot;Malgun Gothic&quot;" padding="0.5rem 1rem 0.75rem 1.5rem" border="1px solid #999"/>

        <Static id="lbl_r03" taborder="10" text="[TC-R-03] border=0.125rem solid red" left="410" top="112" width="185" height="14" font="9px Malgun Gothic"/>
        <Button id="btn_r03" taborder="11" text="border 0.125rem" left="410" top="128" height="72" width="185" onclick="btn_r03_onclick" font="10px/normal &quot;Malgun Gothic&quot;" border="0.125rem solid #e74c3c"/>

        <!-- 행2: TC-R-04 / TC-R-05 / TC-R-06 -->
        <Static id="lbl_r04" taborder="12" text="[TC-R-04] borderRadius=0.5rem 1rem" left="10" top="222" width="185" height="14" font="9px Malgun Gothic"/>
        <Button id="btn_r04" taborder="13" text="borderRadius rem" left="10" top="238" height="72" width="185" onclick="btn_r04_onclick" font="10px/normal &quot;Malgun Gothic&quot;" borderRadius="0.5rem 1rem" border="1px solid #999"/>

        <Static id="lbl_r05" taborder="14" text="[TC-R-05] minwidth=4rem / maxwidth=12rem (신규)" left="210" top="222" width="185" height="14" font="9px Malgun Gothic"/>
        <Button id="btn_r05" taborder="15" text="min=4rem max=12rem" left="210" top="238" height="72" width="55" onclick="btn_r05_onclick" font="10px/normal &quot;Malgun Gothic&quot;" minwidth="4rem" maxwidth="12rem" minheight="2rem" maxheight="5rem" border="1px solid #999"/>

        <Static id="lbl_r06" taborder="16" text="[TC-R-06] letterSpacing=0.05rem" left="410" top="222" width="185" height="14" font="9px Malgun Gothic"/>
        <Button id="btn_r06" taborder="17" text="letterSpacing 0.05rem" left="410" top="238" height="72" width="185" onclick="btn_r06_onclick" font="10px/normal &quot;Malgun Gothic&quot;" letterSpacing="0.05rem" border="1px solid #999"/>

        <!-- 행3: TC-R-07 / TC-R-08 / TC-R-09 -->
        <Static id="lbl_r07" taborder="18" text="[TC-R-07] wordSpacing=0.2rem" left="10" top="332" width="185" height="14" font="9px Malgun Gothic"/>
        <Button id="btn_r07" taborder="19" text="word space 0.2rem" left="10" top="348" height="72" width="185" onclick="btn_r07_onclick" font="10px/normal &quot;Malgun Gothic&quot;" wordSpacing="0.2rem" border="1px solid #999"/>

        <Static id="lbl_r08" taborder="20" text="[TC-R-08] boxShadow=0.3rem 0.3rem 0.8rem" left="210" top="332" width="185" height="14" font="9px Malgun Gothic"/>
        <Button id="btn_r08" taborder="21" text="boxShadow rem" left="210" top="348" height="72" width="185" onclick="btn_r08_onclick" font="10px/normal &quot;Malgun Gothic&quot;" boxShadow="0.3rem 0.3rem 0.8rem rgba(0,0,0,0.35)" border="1px solid #999"/>

        <Static id="lbl_r09" taborder="22" text="[TC-R-09] background-size=4rem 4rem" left="410" top="332" width="185" height="14" font="9px Malgun Gothic"/>
        <Button id="btn_r09" taborder="23" text="bg-size 4rem" left="410" top="348" height="72" width="185" onclick="btn_r09_onclick" font="10px/normal &quot;Malgun Gothic&quot;" background="url('theme://images/btn_TF_Max_O.png') no-repeat center center /4rem 4rem" border="1px solid red"/>

        <!-- 행4: TC-R-10 -->
        <Static id="lbl_r10" taborder="24" text="[TC-R-10] textPadding=0.5rem 1rem" left="10" top="442" width="185" height="14" font="9px Malgun Gothic"/>
        <Button id="btn_r10" taborder="25" text="textPadding 0.5rem 1rem" left="10" top="458" height="72" width="185" onclick="btn_r10_onclick" font="10px/normal &quot;Malgun Gothic&quot;" textPadding="0.5rem 1rem" border="1px solid #999" icon="url('theme://images/btn_TF_Close_O.png')"/>

        <!-- 결과 영역 (우측) -->
        <Combo id="Combo01" taborder="26" left="610" top="152" width="390" height="50" innerdataset="Dataset00" datacolumn="datacolumn" codecolumn="codecolumn" font="12px &quot;Malgun Gothic&quot;"/>
        <Button id="Button01" taborder="27" text="값 확인" left="1010" top="152" width="80" height="50" onclick="Button01_onclick" font="12px &quot;Malgun Gothic&quot;"/>
        <TextArea id="TextArea00" taborder="28" left="610" top="214" width="660" height="490" font="12px &quot;Malgun Gothic&quot;"/>
        <Button id="btn_reload" taborder="29" text="[초기화]" left="1165" top="8" width="100" height="30" onclick="btn_reload_onclick" font="11px &quot;Malgun Gothic&quot;" border="1px solid #CC0000"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="Dataset00">
        <ColumnInfo>
          <Column id="codecolumn" size="256"/>
          <Column id="datacolumn" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row><Col id="codecolumn">0</Col><Col id="datacolumn">TC-R-01 width/height rem</Col></Row>
          <Row><Col id="codecolumn">1</Col><Col id="datacolumn">TC-R-02 padding rem 4방향</Col></Row>
          <Row><Col id="codecolumn">2</Col><Col id="datacolumn">TC-R-03 border rem</Col></Row>
          <Row><Col id="codecolumn">3</Col><Col id="datacolumn">TC-R-04 borderRadius rem</Col></Row>
          <Row><Col id="codecolumn">4</Col><Col id="datacolumn">TC-R-05 minwidth/maxwidth rem(신규)</Col></Row>
          <Row><Col id="codecolumn">5</Col><Col id="datacolumn">TC-R-06 letterSpacing rem</Col></Row>
          <Row><Col id="codecolumn">6</Col><Col id="datacolumn">TC-R-07 wordSpacing rem</Col></Row>
          <Row><Col id="codecolumn">7</Col><Col id="datacolumn">TC-R-08 boxShadow rem</Col></Row>
          <Row><Col id="codecolumn">8</Col><Col id="datacolumn">TC-R-09 background-size rem</Col></Row>
          <Row><Col id="codecolumn">9</Col><Col id="datacolumn">TC-R-10 textPadding rem</Col></Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[
this.btnMF12_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this._getMainFrame().font = "normal 12px/normal \"Malgun Gothic\"";
	this.resetScroll();
	this.TextArea00.deleteText();
	this.TextArea00.value = "MainFrame font = 12px\n1rem = 12px 기준으로 재계산\n\n"
	    + "btn_r01 확인:\n"
	    + "  width=8rem → 기대: 96px\n"
	    + "  height=3rem → 기대: 36px\n"
	    + "  getOffsetWidth  = " + this.btn_r01.getOffsetWidth() + "\n"
	    + "  getOffsetHeight = " + this.btn_r01.getOffsetHeight();
};

this.btnMF16_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this._getMainFrame().font = "normal 16px/normal \"Malgun Gothic\"";
	this.resetScroll();
	this.TextArea00.deleteText();
	this.TextArea00.value = "MainFrame font = 16px\n1rem = 16px 기준으로 재계산\n\n"
	    + "btn_r01 확인:\n"
	    + "  width=8rem → 기대: 128px\n"
	    + "  height=3rem → 기대: 48px\n"
	    + "  getOffsetWidth  = " + this.btn_r01.getOffsetWidth() + "\n"
	    + "  getOffsetHeight = " + this.btn_r01.getOffsetHeight();
};

this.btnMF20_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this._getMainFrame().font = "normal 20px/normal \"Malgun Gothic\"";
	this.resetScroll();
	this.TextArea00.deleteText();
	this.TextArea00.value = "MainFrame font = 20px\n1rem = 20px 기준으로 재계산\n\n"
	    + "btn_r01 확인:\n"
	    + "  width=8rem → 기대: 160px\n"
	    + "  height=3rem → 기대: 60px\n"
	    + "  getOffsetWidth  = " + this.btn_r01.getOffsetWidth() + "\n"
	    + "  getOffsetHeight = " + this.btn_r01.getOffsetHeight();
};

this.btnMF24_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this._getMainFrame().font = "normal 24px/normal \"Malgun Gothic\"";
	this.resetScroll();
	this.TextArea00.deleteText();
	this.TextArea00.value = "MainFrame font = 24px\n1rem = 24px 기준으로 재계산\n\n"
	    + "btn_r01 확인:\n"
	    + "  width=8rem → 기대: 192px\n"
	    + "  height=3rem → 기대: 72px\n"
	    + "  getOffsetWidth  = " + this.btn_r01.getOffsetWidth() + "\n"
	    + "  getOffsetHeight = " + this.btn_r01.getOffsetHeight();
};

this.Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var base = "mainframe.WorkFrame.form.Div00.form.";
	var el, msg;
	var mfEl = document.getElementById("mainframe");
	var mfFs = mfEl ? window.getComputedStyle(mfEl).fontSize : "알수없음";
	switch(this.Combo01.index) {
	case 0:
		msg = "[TC-R-01] width/height rem\n"
		    + "설정: width=8rem, height=3rem\n"
		    + "Pass: computed = MF font-size × rem배수\n"
		    + "현재 MF fontSize = " + mfFs + "\n\n"
		    + "getOffsetWidth  = " + this.btn_r01.getOffsetWidth() + "\n"
		    + "getOffsetHeight = " + this.btn_r01.getOffsetHeight();
		break;
	case 1:
		el = document.getElementById(base + "btn_r02");
		msg = "[TC-R-02] padding rem 4방향\n"
		    + "설정: padding=0.5rem 1rem 0.75rem 1.5rem\n"
		    + "현재 MF fontSize = " + mfFs + "\n\n"
		    + "DOM computed:\n"
		    + "top    = " + window.getComputedStyle(el).paddingTop + "\n"
		    + "right  = " + window.getComputedStyle(el).paddingRight + "\n"
		    + "bottom = " + window.getComputedStyle(el).paddingBottom + "\n"
		    + "left   = " + window.getComputedStyle(el).paddingLeft;
		break;
	case 2:
		el = document.getElementById(base + "btn_r03");
		msg = "[TC-R-03] border rem\n"
		    + "설정: border=0.125rem solid red\n"
		    + "Pass: borderTopWidth = MF font-size × 0.125\n"
		    + "현재 MF fontSize = " + mfFs + "\n\n"
		    + "DOM computed:\n"
		    + "borderTopWidth = " + window.getComputedStyle(el).borderTopWidth;
		break;
	case 3:
		el = document.getElementById(base + "btn_r04");
		msg = "[TC-R-04] borderRadius rem\n"
		    + "설정: borderRadius=0.5rem 1rem\n"
		    + "현재 MF fontSize = " + mfFs + "\n\n"
		    + "DOM computed:\n"
		    + "borderStartStartRadius = " + window.getComputedStyle(el).borderStartStartRadius + "\n"
		    + "borderStartEndRadius   = " + window.getComputedStyle(el).borderStartEndRadius + "\n"
		    + "borderEndStartRadius   = " + window.getComputedStyle(el).borderEndStartRadius + "\n"
		    + "borderEndEndRadius     = " + window.getComputedStyle(el).borderEndEndRadius;
		break;
	case 4:
		msg = "[TC-R-05] minwidth/maxwidth rem — 신규 지원\n"
		    + "설정: width=50px, minwidth=4rem, maxwidth=12rem\n"
		    + "Pass: rem × MF font-size로 레이아웃 반영\n"
		    + "NG  : 0 처리 또는 무시됨 (NexacroN 동작)\n"
		    + "현재 MF fontSize = " + mfFs + "\n\n"
		    + "속성값:\n"
		    + "minwidth      = " + this.btn_r05.minwidth + "\n"
		    + "maxwidth      = " + this.btn_r05.maxwidth + "\n"
		    + "minheight     = " + this.btn_r05.minheight + "\n"
		    + "maxheight     = " + this.btn_r05.maxheight + "\n"
		    + "getOffsetWidth  = " + this.btn_r05.getOffsetWidth() + "\n"
		    + "getOffsetHeight = " + this.btn_r05.getOffsetHeight();
		break;
	case 5:
		el = document.getElementById(base + "btn_r06");
		msg = "[TC-R-06] letterSpacing rem\n"
		    + "설정: letterSpacing=0.05rem\n"
		    + "현재 MF fontSize = " + mfFs + "\n\n"
		    + "DOM computed:\n"
		    + "letterSpacing = " + window.getComputedStyle(el).letterSpacing;
		break;
	case 6:
		el = document.getElementById(base + "btn_r07");
		msg = "[TC-R-07] wordSpacing rem\n"
		    + "설정: wordSpacing=0.2rem\n"
		    + "현재 MF fontSize = " + mfFs + "\n\n"
		    + "DOM computed:\n"
		    + "wordSpacing = " + window.getComputedStyle(el).wordSpacing;
		break;
	case 7:
		el = document.getElementById(base + "btn_r08");
		msg = "[TC-R-08] boxShadow rem\n"
		    + "설정: boxShadow=0.3rem 0.3rem 0.8rem rgba(0,0,0,0.35)\n"
		    + "현재 MF fontSize = " + mfFs + "\n\n"
		    + "DOM computed:\n"
		    + "boxShadow = " + window.getComputedStyle(el).boxShadow;
		break;
	case 8:
		el = document.getElementById(base + "btn_r09");
		msg = "[TC-R-09] background-size rem\n"
		    + "설정: background-size=4rem 4rem\n"
		    + "현재 MF fontSize = " + mfFs + "\n\n"
		    + "DOM computed:\n"
		    + "backgroundSize = " + window.getComputedStyle(el).backgroundSize;
		break;
	case 9:
		el = document.getElementById(base + "btn_r10:text");
		msg = "[TC-R-10] textPadding rem\n"
		    + "설정: textPadding=0.5rem 1rem\n"
		    + "현재 MF fontSize = " + mfFs + "\n\n"
		    + "DOM computed (:text 영역):\n"
		    + "paddingBlock  = " + window.getComputedStyle(el).paddingBlock + "\n"
		    + "paddingInline = " + window.getComputedStyle(el).paddingInline;
		break;
	default:
		msg = "Combo에서 항목을 선택한 후 [값 확인]을 클릭하세요.";
	}
	this.TextArea00.deleteText();
	this.TextArea00.value = msg;
};

this.btn_r01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-R-01] width/height rem\n"
	    + "설정: width=8rem, height=3rem\n"
	    + "MF font 변경 버튼으로 rem 기준 변경 후 크기 변화 확인\n\n"
	    + "getOffsetWidth  = " + this.btn_r01.getOffsetWidth() + "\n"
	    + "getOffsetHeight = " + this.btn_r01.getOffsetHeight();
};

this.btn_r02_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var el = document.getElementById("mainframe.WorkFrame.form.Div00.form.btn_r02");
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-R-02] padding rem 4방향\n"
	    + "top    = " + window.getComputedStyle(el).paddingTop + "\n"
	    + "right  = " + window.getComputedStyle(el).paddingRight + "\n"
	    + "bottom = " + window.getComputedStyle(el).paddingBottom + "\n"
	    + "left   = " + window.getComputedStyle(el).paddingLeft;
};

this.btn_r03_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var el = document.getElementById("mainframe.WorkFrame.form.Div00.form.btn_r03");
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-R-03] border rem\n"
	    + "DOM borderTopWidth = " + window.getComputedStyle(el).borderTopWidth;
};

this.btn_r04_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var el = document.getElementById("mainframe.WorkFrame.form.Div00.form.btn_r04");
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-R-04] borderRadius rem\n"
	    + "borderStartStartRadius = " + window.getComputedStyle(el).borderStartStartRadius + "\n"
	    + "borderStartEndRadius   = " + window.getComputedStyle(el).borderStartEndRadius + "\n"
	    + "borderEndStartRadius   = " + window.getComputedStyle(el).borderEndStartRadius + "\n"
	    + "borderEndEndRadius     = " + window.getComputedStyle(el).borderEndEndRadius;
};

this.btn_r05_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-R-05] minwidth/maxwidth rem\n"
	    + "minwidth      = " + this.btn_r05.minwidth + "\n"
	    + "maxwidth      = " + this.btn_r05.maxwidth + "\n"
	    + "getOffsetWidth  = " + this.btn_r05.getOffsetWidth() + "\n"
	    + "getOffsetHeight = " + this.btn_r05.getOffsetHeight();
};

this.btn_r06_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var el = document.getElementById("mainframe.WorkFrame.form.Div00.form.btn_r06");
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-R-06] letterSpacing rem\n"
	    + "DOM: " + window.getComputedStyle(el).letterSpacing;
};

this.btn_r07_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var el = document.getElementById("mainframe.WorkFrame.form.Div00.form.btn_r07");
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-R-07] wordSpacing rem\n"
	    + "DOM: " + window.getComputedStyle(el).wordSpacing;
};

this.btn_r08_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var el = document.getElementById("mainframe.WorkFrame.form.Div00.form.btn_r08");
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-R-08] boxShadow rem\n"
	    + "DOM: " + window.getComputedStyle(el).boxShadow;
};

this.btn_r09_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var el = document.getElementById("mainframe.WorkFrame.form.Div00.form.btn_r09");
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-R-09] background-size rem\n"
	    + "DOM: " + window.getComputedStyle(el).backgroundSize;
};

this.btn_r10_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var el = document.getElementById("mainframe.WorkFrame.form.Div00.form.btn_r10:text");
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-R-10] textPadding rem\n"
	    + "paddingBlock  = " + window.getComputedStyle(el).paddingBlock + "\n"
	    + "paddingInline = " + window.getComputedStyle(el).paddingInline;
};
this.btn_reload_onclick = function(obj:nexacro.Button, e:nexacro.ClickEventInfo)
{
	this.reload();
};
]]></Script>
  </Form>
</FDL>
