    <Script type="xscript5.1"><![CDATA[
this.Radio00_onitemchanged = function(obj:nexacro.Radio, e:nexacro.ItemChangeEventInfo)
{
	["cmb_10","cmb_14","cmb_20",
	 "lst_10","lst_14","lst_20",
	 "mco_10","mco_14","mco_20",
	 "mco_st_10","mco_st_14","mco_st_20",
	 "div_10","div_14","div_20"].forEach(function(key) {
		if (this.all[key]) this.all[key].font = obj.text;
	}.bind(this));
	this.resetScroll();
};

this.Button01_onclick = function(obj:nexacro.Button, e:nexacro.ClickEventInfo)
{
	var msg;
	switch (this.Combo01.index) {
	case 0:
		msg = "[TC-C-01] Combo itemheight em — font=10px\n"
		    + "설정: itemheight=2em, font=10px\n"
		    + "Pass: 드롭다운 각 행 높이 = 20px\n\n"
		    + "itemheight = " + this.cmb_10.itemheight + "\n"
		    + "font       = " + this.cmb_10.font;
		break;
	case 1:
		msg = "[TC-C-01] Combo itemheight em — font=14px\n"
		    + "설정: itemheight=2em, font=14px\n"
		    + "Pass: 드롭다운 각 행 높이 = 28px\n\n"
		    + "itemheight = " + this.cmb_14.itemheight + "\n"
		    + "font       = " + this.cmb_14.font;
		break;
	case 2:
		msg = "[TC-C-01] Combo itemheight em — font=20px\n"
		    + "설정: itemheight=2em, font=20px\n"
		    + "Pass: 드롭다운 각 행 높이 = 40px\n\n"
		    + "itemheight = " + this.cmb_20.itemheight + "\n"
		    + "font       = " + this.cmb_20.font;
		break;
	case 3:
		msg = "[TC-C-02] ListBox itemheight em — font=10px\n"
		    + "설정: itemheight=2em, font=10px\n"
		    + "Pass: 각 행 높이 = 20px\n\n"
		    + "itemheight = " + this.lst_10.itemheight + "\n"
		    + "font       = " + this.lst_10.font;
		break;
	case 4:
		msg = "[TC-C-02] ListBox itemheight em — font=14px\n"
		    + "설정: itemheight=2em, font=14px\n"
		    + "Pass: 각 행 높이 = 28px\n\n"
		    + "itemheight = " + this.lst_14.itemheight + "\n"
		    + "font       = " + this.lst_14.font;
		break;
	case 5:
		msg = "[TC-C-02] ListBox itemheight em — font=20px\n"
		    + "설정: itemheight=2em, font=20px\n"
		    + "Pass: 각 행 높이 = 40px\n\n"
		    + "itemheight = " + this.lst_20.itemheight + "\n"
		    + "font       = " + this.lst_20.font;
		break;
	case 6:
		msg = "[TC-C-03] MultiCombo multitag gap em — font=10px\n"
		    + "설정: hgap=2em(=20px), vgap=2em(=20px), edittype=multitag\n\n"
		    + "tagboxitemhorizontalgap = " + this.mco_10.tagboxitemhorizontalgap + "\n"
		    + "tagboxitemverticalgap   = " + this.mco_10.tagboxitemverticalgap + "\n"
		    + "font                    = " + this.mco_10.font + "\n"
		    + "edittype                = " + this.mco_10.edittype;
		break;
	case 7:
		msg = "[TC-C-03] MultiCombo multitag gap em — font=14px\n"
		    + "설정: hgap=2em(=28px), vgap=2em(=28px), edittype=multitag\n\n"
		    + "tagboxitemhorizontalgap = " + this.mco_14.tagboxitemhorizontalgap + "\n"
		    + "tagboxitemverticalgap   = " + this.mco_14.tagboxitemverticalgap + "\n"
		    + "font                    = " + this.mco_14.font + "\n"
		    + "edittype                = " + this.mco_14.edittype;
		break;
	case 8:
		msg = "[TC-C-03] MultiCombo multitag gap em — font=20px\n"
		    + "설정: hgap=2em(=40px), vgap=2em(=40px), edittype=multitag\n\n"
		    + "tagboxitemhorizontalgap = " + this.mco_20.tagboxitemhorizontalgap + "\n"
		    + "tagboxitemverticalgap   = " + this.mco_20.tagboxitemverticalgap + "\n"
		    + "font                    = " + this.mco_20.font + "\n"
		    + "edittype                = " + this.mco_20.edittype;
		break;
	case 9:
		msg = "[TC-C-04] Div padding em — font=10px\n"
		    + "설정: padding=1em, font=10px\n"
		    + "Pass: padding=10px / 내부 btn 20px×20px\n\n"
		    + "padding                  = " + this.div_10.padding + "\n"
		    + "font                     = " + this.div_10.font + "\n"
		    + "btn_div10.width          = " + this.div_10.btn_div10.width + "\n"
		    + "btn_div10.getOffsetWidth = " + this.div_10.btn_div10.getOffsetWidth();
		break;
	case 10:
		msg = "[TC-C-04] Div padding em — font=14px\n"
		    + "설정: padding=1em, font=14px\n"
		    + "Pass: padding=14px / 내부 btn 28px×28px\n\n"
		    + "padding                  = " + this.div_14.padding + "\n"
		    + "font                     = " + this.div_14.font + "\n"
		    + "btn_div14.width          = " + this.div_14.btn_div14.width + "\n"
		    + "btn_div14.getOffsetWidth = " + this.div_14.btn_div14.getOffsetWidth();
		break;
	case 11:
		msg = "[TC-C-04] Div padding em — font=20px\n"
		    + "설정: padding=1em, font=20px\n"
		    + "Pass: padding=20px / 내부 btn 40px×40px\n\n"
		    + "padding                  = " + this.div_20.padding + "\n"
		    + "font                     = " + this.div_20.font + "\n"
		    + "btn_div20.width          = " + this.div_20.btn_div20.width + "\n"
		    + "btn_div20.getOffsetWidth = " + this.div_20.btn_div20.getOffsetWidth();
		break;
	case 12:
		msg = "[TC-EM-01] em 중첩 구조 — 누적 방지\n"
		    + "구조: Div(font=20px) > Button(font=0.5em, width=2em)\n"
		    + "Button computed font: 0.5em × 20px = 10px\n"
		    + "Pass: Button getOffsetWidth = 20px (자신 10px × 2)\n"
		    + "NG  : Button getOffsetWidth = 40px (부모 20px × 2 누적)\n\n"
		    + "btn_nested.font           = " + this.Div_em01.btn_nested.font + "\n"
		    + "btn_nested.width          = " + this.Div_em01.btn_nested.width + "\n"
		    + "btn_nested.getOffsetWidth = " + this.Div_em01.btn_nested.getOffsetWidth();
		break;
	case 13:
		msg = "[TC-EM-02] XML 저장 무결성\n"
		    + "[setter 적용] 버튼으로 동적 속성 설정 후\n"
		    + "[값 확인] 버튼으로 단위 문자열 보존 여부 확인\n\n"
		    + "Pass: '8rem', '0.5em 1rem', '0.05em' 문자열 그대로 보존\n"
		    + "NG  : '8', '0.5 1', '0.05' — 숫자만 저장 (단위 손실)";
		break;
	case 14:
		msg = fn_checkButtonsize(this, this.cmb_bs_10, "TC-C-05-A", "10px", "30");
		break;
	case 15:
		msg = fn_checkButtonsize(this, this.cmb_bs_14, "TC-C-05-B", "14px", "42");
		break;
	case 16:
		msg = fn_checkButtonsize(this, this.cmb_bs_20, "TC-C-05-C", "20px", "60");
		break;
	case 17:
		msg = fn_checkPopupsize(this, this.cmb_ps_10, "TC-C-06-A", "10px", "80");
		break;
	case 18:
		msg = fn_checkPopupsize(this, this.cmb_ps_14, "TC-C-06-B", "14px", "112");
		break;
	case 19:
		msg = fn_checkPopupsize(this, this.cmb_ps_20, "TC-C-06-C", "20px", "160");
		break;
	case 20:
		msg = "[TC-C-03] MultiCombo singletag gap em — font=10px\n"
		    + "설정: hgap=2em(=20px), vgap=2em(=20px), edittype=singletag\n\n"
		    + "tagboxitemhorizontalgap = " + this.mco_st_10.tagboxitemhorizontalgap + "\n"
		    + "tagboxitemverticalgap   = " + this.mco_st_10.tagboxitemverticalgap + "\n"
		    + "font                    = " + this.mco_st_10.font + "\n"
		    + "edittype                = " + this.mco_st_10.edittype;
		break;
	case 21:
		msg = "[TC-C-03] MultiCombo singletag gap em — font=14px\n"
		    + "설정: hgap=2em(=28px), vgap=2em(=28px), edittype=singletag\n\n"
		    + "tagboxitemhorizontalgap = " + this.mco_st_14.tagboxitemhorizontalgap + "\n"
		    + "tagboxitemverticalgap   = " + this.mco_st_14.tagboxitemverticalgap + "\n"
		    + "font                    = " + this.mco_st_14.font + "\n"
		    + "edittype                = " + this.mco_st_14.edittype;
		break;
	case 22:
		msg = "[TC-C-03] MultiCombo singletag gap em — font=20px\n"
		    + "설정: hgap=2em(=40px), vgap=2em(=40px), edittype=singletag\n\n"
		    + "tagboxitemhorizontalgap = " + this.mco_st_20.tagboxitemhorizontalgap + "\n"
		    + "tagboxitemverticalgap   = " + this.mco_st_20.tagboxitemverticalgap + "\n"
		    + "font                    = " + this.mco_st_20.font + "\n"
		    + "edittype                = " + this.mco_st_20.edittype;
		break;
	default:
		msg = "Combo에서 항목을 선택한 후 [값 확인]을 클릭하세요.";
	}
	this.TextArea00.deleteText();
	this.TextArea00.value = msg;
};

/* buttonsize em 검증 — nexacro 속성값 + DOM computed style */
function fn_checkButtonsize(oForm, comp, tcId, fontPx, expectPx)
{
	var propVal   = comp.buttonsize;
	var compW     = comp.getOffsetWidth();
	var compH     = comp.getOffsetHeight();
	var domResult = fn_getDomInfo(comp, true);

	return "[" + tcId + "] Combo buttonsize em — font=" + fontPx + "\n"
	     + "설정: buttonsize=3em, font=" + fontPx + "\n"
	     + "Pass: 드롭다운 버튼 너비 = " + expectPx + "px\n"
	     + "─────────────────────────────────\n"
	     + "nexacro 속성값\n"
	     + "  buttonsize     = " + propVal + "\n"
	     + "  font           = " + comp.font + "\n"
	     + "  getOffsetWidth = " + compW + "px  (컴포넌트 전체)\n"
	     + "  getOffsetHeight= " + compH + "px\n"
	     + "─────────────────────────────────\n"
	     + "DOM computed style\n"
	     + domResult + "\n"
	     + "─────────────────────────────────\n"
	     + "판정 기준: buttonsize 속성이 em 문자열로 저장되면 지원 확인\n"
	     + "버튼 내부 너비는 DevTools > 요소 탐색기에서 직접 확인";
}

/* popupsize em 검증 — nexacro 속성값 + DOM computed style */
function fn_checkPopupsize(oForm, comp, tcId, fontPx, expectPx)
{
	var propVal   = comp.popupsize;
	var compW     = comp.getOffsetWidth();
	var compH     = comp.getOffsetHeight();
	var domResult = fn_getDomInfo(comp, false);

	return "[" + tcId + "] Combo popupsize em — font=" + fontPx + "\n"
	     + "설정: popupsize=8em, font=" + fontPx + "\n"
	     + "Pass: 팝업 높이 = " + expectPx + "px  (클릭해서 육안 확인)\n"
	     + "─────────────────────────────────\n"
	     + "nexacro 속성값\n"
	     + "  popupsize      = " + propVal + "\n"
	     + "  font           = " + comp.font + "\n"
	     + "  getOffsetWidth = " + compW + "px  (컴포넌트 전체)\n"
	     + "  getOffsetHeight= " + compH + "px\n"
	     + "─────────────────────────────────\n"
	     + "DOM computed style\n"
	     + domResult + "\n"
	     + "─────────────────────────────────\n"
	     + "판정 기준: popupsize 속성이 em 문자열로 저장되면 지원 확인\n"
	     + "팝업 높이는 Combo 클릭 후 DevTools에서 직접 확인";
}

/* DOM 요소 접근 — _element 경유 (공식 API 아님, 런타임에서 확인) */
function fn_getDomInfo(comp, isButtonsize)
{
	try {
		var el = comp._element;
		if (!el) return "  (DOM 요소 미발견: _element 없음)";

		var cs   = window.getComputedStyle(el);
		var info = "  [컴포넌트 루트 DOM]\n"
		         + "  width   = " + cs.width + "\n"
		         + "  height  = " + cs.height + "\n"
		         + "  font    = " + cs.fontSize;

		if (isButtonsize) {
			/* 버튼 하위 요소 탐색 (우측 드롭다운 버튼 영역) */
			var btnEl = el.querySelector("[class*='combobtn']")
			         || el.querySelector("[class*='button']")
			         || el.lastElementChild;
			if (btnEl) {
				var bcs = window.getComputedStyle(btnEl);
				info += "\n  [버튼 하위 DOM]\n"
				      + "  width   = " + bcs.width + "\n"
				      + "  height  = " + bcs.height;
			} else {
				info += "\n  [버튼 하위 DOM] 탐색 실패 → DevTools 직접 확인";
			}
		}
		return info;
	} catch(e) {
		return "  DOM 접근 오류: " + e.message;
	}
}

this.btn_nested_onclick = function(obj:nexacro.Button, e:nexacro.ClickEventInfo)
{
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-EM-01] em 중첩 구조\n"
	    + "Div font=20px > Button font=0.5em\n"
	    + "Button computed font = 10px (0.5 × 20)\n"
	    + "Button width=2em → 기대: 20px (자신 10px 기준)\n\n"
	    + "btn_nested.getOffsetWidth  = " + this.Div_em01.btn_nested.getOffsetWidth() + "\n"
	    + "btn_nested.getOffsetHeight = " + this.Div_em01.btn_nested.getOffsetHeight();
};

this.btn_em02_set_onclick = function(obj:nexacro.Button, e:nexacro.ClickEventInfo)
{
	this.btn_em02_target.set_width("8rem");
	this.btn_em02_target.set_padding("0.5em 1rem");
	this.btn_em02_target.set_letterSpacing("0.05em");
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-EM-02] setter 적용 완료\n"
	    + "btn_em02_target에 다음 값 설정:\n"
	    + "  width         = 8rem\n"
	    + "  padding       = 0.5em 1rem\n"
	    + "  letterSpacing = 0.05em\n\n"
	    + "[값 확인] 버튼을 클릭하여 단위 보존 여부 확인";
};

this.btn_em02_chk_onclick = function(obj:nexacro.Button, e:nexacro.ClickEventInfo)
{
	var el = document.getElementById("mainframe.WorkFrame.form.Div00.form.btn_em02_target");
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-EM-02] XML 저장 무결성 확인\n\n"
	    + "속성값 (단위 보존 여부):\n"
	    + "width         = " + this.btn_em02_target.width + "\n"
	    + "padding       = " + this.btn_em02_target.padding + "\n"
	    + "letterSpacing = " + this.btn_em02_target.letterSpacing + "\n\n"
	    + "DOM computed:\n"
	    + "width         = " + window.getComputedStyle(el).width + "\n"
	    + "padding       = " + window.getComputedStyle(el).padding + "\n"
	    + "letterSpacing = " + window.getComputedStyle(el).letterSpacing;
};

this.btn_reload_onclick = function(obj:nexacro.Button, e:nexacro.ClickEventInfo)
{
	this.reload();
};

this.hdr_mco_onclick = function(obj:nexacro.Static,e:nexacro.ClickEventInfo)
{
	
};

this.mco_14_onitemchanged = function(obj:nexacro.MultiCombo,e:nexacro.ItemChangeEventInfo)
{
	
};
