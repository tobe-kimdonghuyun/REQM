};

this.btn08_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	const u_id="mainframe.WorkFrame.form.Div00.form.btn08";
	const el = document.getElementById(u_id);
	console.log(window.getComputedStyle(el).border);
	this.TextArea00.deleteText();
	this.TextArea00.value = "btn08 border-radius(1개설정) Dom상 실제값 \nborderStartStartRadius = "+window.getComputedStyle(el).borderStartStartRadius
	                        +"\nborderStartEndRadius = "+window.getComputedStyle(el).borderStartEndRadius
							+"\nborderEndStartRadius = "+window.getComputedStyle(el).borderStartEndRadius
							+"\nborderEndEndRadius = "+window.getComputedStyle(el).borderEndEndRadius;
};

this.btn09_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
