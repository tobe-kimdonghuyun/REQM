        <Button id="btn14" taborder="16" text="textPadding(1개설정)-em" left="370" top="186" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" icon="url('theme://images/btn_TF_Close_O.png')" onclick="btn14_onclick" textPadding="0.5em"/>
        <Button id="btn16" taborder="21" text="backgroud-size" left="370" top="266" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" background="url('imagerc::20.png') no-repeat center center /4em 4em" onclick="btn16_onclick" border="1px solid red"/>
        <Button id="btn17" taborder="22" text="background-position - em" left="553" top="266" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" onclick="btn17_onclick" background="url('imagerc::20.png') no-repeat 8em 8em" border="1px solid red"/>
        <Button id="btn18" taborder="23" text="boxShadow테스트1-em" left="370" top="337" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" onclick="btn18_onclick" boxShadow="inset 0.7em 0.7em 1.5em chocolate"/>
        <Button id="btn19" taborder="24" text="boxShadow테스트2-em" left="553" top="337" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" onclick="btn19_onclick" boxShadow="inset 0.5em 0.5em 0px 1.2em chocolate"/>
        <Button id="btn20" taborder="25" text="boxShadow테스트3-em" left="370" top="418" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" onclick="btn20_onclick" boxShadow="0.7em 0.7em 1.5em chocolate"/>
