<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="TestCase00" width="1280" height="720" titletext="New Form" font="30px/normal &quot;Malgun Gothic&quot;">
    <Layouts>
      <Layout height="720" width="1280">
        <Static id="Static00" taborder="0" text="EM  properies에 설정 - basic component font  = 10px/normal &quot;Malgun Gothic&quot;" left="39" top="24" width="668" height="59" font="12px &quot;Malgun Gothic&quot;"/>
        <Button id="btn00" taborder="2" text="width - em" left="52" top="186" height="62" width="15em" onclick="Button00_onclick" font="10px/normal &quot;Malgun Gothic&quot;"/>
        <Button id="btn01" taborder="3" text="height - em" left="235" top="186" height="6.2em" width="150" font="10px/normal &quot;Malgun Gothic&quot;"/>
        <Button id="Button01" taborder="21" text="값 확인" left="891" top="190" width="159" height="47" onclick="Button01_onclick" font="12px &quot;Malgun Gothic&quot;"/>
        <Combo id="Combo01" taborder="19" text="Combo01" left="559" top="190" width="321" height="47" innerdataset="Dataset00" datacolumn="datacolumn" codecolumn="codecolumn" font="12px &quot;Malgun Gothic&quot;"/>
        <TextArea id="TextArea00" taborder="18" left="564" top="256" width="486" height="259" font="12px &quot;Malgun Gothic&quot;"/>
        <Button id="btn03" taborder="5" text="max width&amp;height - em" left="235" top="260" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" maxwidth="300" minwidth="" maxheight="90" minheight="" onclick="btn03_onclick"/>
        <Button id="btn02" taborder="4" text="min width&amp;height - em" left="52" top="260" height="62" width="150" onclick="Button00_01_onclick" font="10px/normal &quot;Malgun Gothic&quot;" minwidth="100" maxwidth="" minheight="50" maxheight=""/>
        <Button id="btn05" taborder="7" text="padding(4방향) - em" left="235" top="338" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" padding="1em 2em 3em 4em" onclick="btn05_onclick"/>
        <Button id="btn04" taborder="6" text="padding(2개설정) - em" left="52" top="338" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" padding="2em 3em" onclick="btn04_onclick"/>
        <Button id="btn07" taborder="9" text="border(2개설정) - em" left="235" top="418" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" border="0.5em solid red, 1em solid blue" onclick="btn07_onclick"/>
        <Button id="btn06" taborder="8" text="border(1개설정) - em" left="52" top="418" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" border="1em solid red" onclick="btn06_onclick"/>
        <Radio id="Radio00" taborder="1" left="40" top="83" width="660" height="77" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" direction="vertical" rowcount="2" onitemchanged="Radio00_onitemchanged" font="12px &quot;Malgun Gothic&quot;">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row>
                <Col id="datacolumn">5px/normal "Malgun Gothic"</Col>
              </Row>
              <Row>
                <Col id="datacolumn">10px/normal "Malgun Gothic"</Col>
              </Row>
              <Row>
                <Col id="datacolumn">15px/normal "Malgun Gothic"</Col>
              </Row>
              <Row>
                <Col id="datacolumn">20px/normal "Malgun Gothic"</Col>
              </Row>
            </Rows>
          </Dataset>
        </Radio>
        <Button id="btn09" taborder="11" text="border-radius(2개설정) - em" left="235" top="490" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" onclick="btn09_onclick" borderRadius="2em 4em"/>
        <Button id="btn08" taborder="10" text="border-radius(1개설정) - em" left="52" top="490" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" borderRadius="2em" onclick="btn08_onclick"/>
        <Button id="btn10" taborder="12" text="font-size - em" left="52" top="569" height="62" width="150" font="0.5em/normal &quot;Malgun Gothic&quot;" onclick="btn10_onclick"/>
        <Button id="btn11" taborder="13" text="letterSpacing(양수) - em" left="235" top="569" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" letterSpacing="0.2em" onclick="btn11_onclick"/>
        <Button id="btn12" taborder="14" text="letterSpacing(음수) - em" left="52" top="640" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" letterSpacing="-0.2em" onclick="btn12_onclick"/>
        <Button id="btn13" taborder="15" text="wordSpacing - em" left="235" top="640" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" wordSpacing="2em" onclick="btn13_onclick"/>
        <Button id="btn15" taborder="17" text="textPadding(2개) - em" left="235" top="719" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" icon="url('theme://images/btn_TF_Max_O.png')"/>
        <Button id="btn14" taborder="16" text="textPadding(1개설정)-em" left="52" top="719" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" icon="url('theme://images/btn_TF_Close_O.png')"/>
        <TextArea id="TextArea01" taborder="20" left="57" top="812" width="335" height="107"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="Dataset00">
        <ColumnInfo>
          <Column id="codecolumn" size="256"/>
          <Column id="datacolumn" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="codecolumn">0</Col>
            <Col id="datacolumn">width</Col>
          </Row>
          <Row>
            <Col id="datacolumn">height</Col>
            <Col id="codecolumn">1</Col>
          </Row>
          <Row>
            <Col id="datacolumn">min width&amp;height</Col>
            <Col id="codecolumn">2</Col>
          </Row>
          <Row>
            <Col id="datacolumn">max width&amp;height</Col>
            <Col id="codecolumn">3</Col>
          </Row>
          <Row>
            <Col id="datacolumn">padding(2개설정)</Col>
            <Col id="codecolumn">4</Col>
          </Row>
          <Row>
            <Col id="datacolumn">padding(4개설정)</Col>
            <Col id="codecolumn">5</Col>
          </Row>
          <Row>
            <Col id="datacolumn">border(1개설정)</Col>
            <Col id="codecolumn">6</Col>
          </Row>
          <Row>
            <Col id="datacolumn">border(2개설정)</Col>
            <Col id="codecolumn">7</Col>
          </Row>
          <Row>
            <Col id="datacolumn">border-radius(1개설정)</Col>
            <Col id="codecolumn">8</Col>
          </Row>
          <Row>
            <Col id="datacolumn">border-radius(2개설정)</Col>
            <Col id="codecolumn">9</Col>
          </Row>
          <Row>
            <Col id="datacolumn">font-size</Col>
            <Col id="codecolumn">10</Col>
          </Row>
          <Row>
            <Col id="datacolumn">letterSpacing(양수)</Col>
            <Col id="codecolumn">11</Col>
          </Row>
          <Row>
            <Col id="datacolumn">letterSpacing(음수)</Col>
            <Col id="codecolumn">12</Col>
          </Row>
          <Row>
            <Col id="datacolumn">wordSpacing</Col>
            <Col id="codecolumn">13</Col>
          </Row>
          <Row>
            <Col id="datacolumn">line-spacing</Col>
            <Col id="codecolumn">14</Col>
          </Row>
          <Row>
            <Col id="datacolumn">background-size</Col>
            <Col id="codecolumn">15</Col>
          </Row>
          <Row>
            <Col id="datacolumn">background-position</Col>
            <Col id="codecolumn">16</Col>
          </Row>
          <Row>
            <Col id="datacolumn">boxShadow</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[
this.Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	switch(this.Combo01.index ) {
	case 0 :
		this.TextArea00.deleteText();
		this.TextArea00.value = "width = "+this.btn00.width+"\ngetOffsetWidth = "+this.btn00.getOffsetWidth();
		break;
	case 1:
		this.TextArea00.deleteText();
		this.TextArea00.value = "height = "+this.btn01.height+"\ngetOffsetHeight = "+this.btn01.getOffsetHeight();
		break;
	case 2 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "minwidth = "+this.btn02.minwidth+"\ngetOffsetWidth = "+this.btn02.getOffsetWidth()
		                        +"\nminheight = "+this.btn02.minheight+"\ngetOffsetHeight = "+this.btn02.getOffsetHeight();
		break;
	case 3 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "maxwidth = "+this.btn03.maxwidth+"\ngetOffsetWidth = "+this.btn03.getOffsetWidth()
		                        +"\nmaxheight = "+this.btn03.maxheight+"\ngetOffsetHeight = "+this.btn03.getOffsetHeight();
		break;
	case 4 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "padding = "+this.btn04.padding;
		break;
	case 5 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "padding = "+this.btn05.padding;
		break;
	case 6 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "border = "+this.btn06.border;
		break;
	case 7 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "border = "+this.btn07.border;
		break;
	case 8 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "borderRadius = "+this.btn08.borderRadius;
		break;
	case 9 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "borderRadius = "+this.btn09.borderRadius;
		break;
	case 10 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "font-size = "+this.btn10.font;
		break;
	case 11 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "letterSpacing = "+this.btn11.letterSpacing;
		break;
	case 12 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "letterSpacing = "+this.btn12.letterSpacing;
		break;
	case 13 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "wordSpacing = "+this.btn13.wordSpacing;
		break;
	default:
	}
	
};

this.Button00_01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	obj.width = "90px";
	obj.height= "45px";
	this.resetScroll();
};

this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
};

this.Radio00_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	Object.keys(this.all)
    .filter(key => key.startsWith('btn'))
    .sort() 
    .forEach(key => {
        this.all[key].font = obj.text;
        console.log(`${key}: ${this.all[key].fon}`);
    });
	this.resetScroll();
};

this.btn03_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	obj.width = "310px";
	obj.height= "100px";
	this.resetScroll();
};


this.btn12_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	const el = document.getElementById("mainframe.WorkFrame.form.Div00.form.btn12");
	console.log(window.getComputedStyle(el).letterSpacing);
	this.TextArea00.deleteText();
	this.TextArea00.value = "btn12 letterSpacing Dom상 실제값 letterSpacing = "+window.getComputedStyle(el).letterSpacing;
};

this.btn04_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	const u_id="mainframe.WorkFrame.form.Div00.form.btn04";
