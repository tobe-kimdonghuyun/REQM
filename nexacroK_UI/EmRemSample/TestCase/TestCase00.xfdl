    <Script type="xscript5.1"><![CDATA[
this.Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	switch(this.Combo01.index ) {
	case 0 :
		this.TextArea00.deleteText();
		this.TextArea00.value = "width = "+this.btn00.width+"\ngetOffsetWidth = "+this.btn00.getOffsetWidth();
		break;
	case 1:
		this.TextArea00.deleteText();
		this.TextArea00.value = "height = "+this.btn01.height+"\ngetOffsetHeight = "+this.btn01.getOffsetHeight();
		break;
	case 2 : 
		this.btn02.width = "90px";
		this.btn02.height= "45px";
		this.resetScroll();
		this.TextArea00.deleteText();
		this.TextArea00.value = "minwidth = "+this.btn02.minwidth+"\ngetOffsetWidth = "+this.btn02.getOffsetWidth()
		                        +"\nminheight = "+this.btn02.minheight+"\ngetOffsetHeight = "+this.btn02.getOffsetHeight();
		break;
	case 3 : 
		this.btn03.width = "310px";
		this.btn03.height= "100px";
		this.resetScroll();
		this.TextArea00.deleteText();
		this.TextArea00.value = "maxwidth = "+this.btn03.maxwidth+"\ngetOffsetWidth = "+this.btn03.getOffsetWidth()
		                        +"\nmaxheight = "+this.btn03.maxheight+"\ngetOffsetHeight = "+this.btn03.getOffsetHeight();
		break;
	case 4 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "padding = "+this.btn04.padding;
		break;
	case 5 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "padding = "+this.btn05.padding;
		break;
	case 6 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "border = "+this.btn06.border;
		break;
	case 7 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "border = "+this.btn07.border;
		break;
	case 8 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "borderRadius = "+this.btn08.borderRadius;
		break;
	case 9 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "borderRadius = "+this.btn09.borderRadius;
		break;
	case 10 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "font-size = "+this.btn10.font;
		break;
	case 11 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "letterSpacing = "+this.btn11.letterSpacing;
		break;
	case 12 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "letterSpacing = "+this.btn12.letterSpacing;
		break;
	case 13 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "wordSpacing = "+this.btn13.wordSpacing;
		break;
	case 14 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "textPadding(1개설정) = "+this.btn14.textPadding;
		break;
	case 15 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "textPadding(2개설정) = "+this.btn15.textPadding;
		break;
	case 16 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "backgroud-size(1개설정) = "+this.btn16.textPadding;
		break;
	case 17 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "background-position = "+this.btn17.background;
		break;
	case 18 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "boxShadow 테스트1 = "+this.btn18.boxShadow;
		break;
	case 19 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "boxShadow 테스트2 = "+this.btn19.boxShadow;
		break;
	case 20 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "boxShadow 테스트3 = "+this.btn20.boxShadow;
		break;
	case 19 : 
		this.TextArea00.deleteText();
		this.TextArea00.value = "boxShadow 테스트4 = "+this.btn21.boxShadow;
		break;
	default:
	}
	
};

this.Radio00_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	Object.keys(this.all)
    .filter(key => key.startsWith('btn'))
    .sort() 
    .forEach(key => {
        this.all[key].font = obj.text;
        console.log(`${key}: ${this.all[key].fon}`);
    });
	this.resetScroll();
};

