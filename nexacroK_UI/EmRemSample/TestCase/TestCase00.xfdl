	this.TextArea00.value = "btn10 font-size Dom상 실제값 \nfontSize = "+window.getComputedStyle(el).fontSize;
	                     
};

this.btn11_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	const u_id="mainframe.WorkFrame.form.Div00.form.btn11";
