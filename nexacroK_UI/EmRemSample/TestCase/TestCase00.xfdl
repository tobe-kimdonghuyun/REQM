        <Button id="btn04" taborder="6" text="padding(2개설정) - em" left="12" top="338" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" padding="2em 3em" onclick="btn04_onclick"/>
        <Button id="btn07" taborder="9" text="border(2개설정) - em" left="195" top="418" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" border="0.5em solid red, 1em solid blue" onclick="btn07_onclick"/>
        <Button id="btn06" taborder="8" text="border(1개설정) - em" left="12" top="418" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" border="1em solid red" onclick="btn06_onclick"/>
        <Radio id="Radio00" taborder="1" left="40" top="83" width="660" height="77" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" direction="vertical" rowcount="2" onitemchanged="Radio00_onitemchanged" font="12px &quot;Malgun Gothic&quot;">
