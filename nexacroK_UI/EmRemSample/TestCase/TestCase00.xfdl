        <Button id="btn10" taborder="12" text="font-size - em" left="12" top="569" height="62" width="150" font="0.5em/normal &quot;Malgun Gothic&quot;" onclick="btn10_onclick"/>
        <Button id="btn11" taborder="13" text="letterSpacing(양수) - em" left="195" top="569" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" letterSpacing="0.2em" onclick="btn11_onclick"/>
        <Button id="btn12" taborder="14" text="letterSpacing(음수) - em" left="12" top="640" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" letterSpacing="-0.2em" onclick="btn12_onclick"/>
        <Button id="btn13" taborder="15" text="wordSpacing - em" left="195" top="640" height="62" width="150" font="10px/normal &quot;Malgun Gothic&quot;" wordSpacing="2em" onclick="btn13_onclick"/>
