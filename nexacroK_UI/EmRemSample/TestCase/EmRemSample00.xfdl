<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="EmRemSample00" width="1280" height="720" titletext="[TC-B] Button em/rem 속성 검증" font="30px/normal &quot;Malgun Gothic&quot;">
    <Layouts>
      <Layout height="720" width="1280">
        <Static id="lbl_typeinfo" taborder="99" text="[테스트유형] 정적설정 — XML 속성에 em 직접 지정  |  [사용 컴포넌트] Button · Static · Radio · Combo · TextArea" left="10" top="4" width="1260" height="14" font="9px Malgun Gothic" forecolor="#1A3A5C" background="url('') #EBF3FF"/>
        <Static id="Static00" taborder="0" text="[TC-B] Button 계열 em/rem 핵심 속성 검증  (기본 font = 10px/normal Malgun Gothic)" left="10" top="20" width="700" height="40" font="13px &quot;Malgun Gothic&quot;"/>
        <Radio id="Radio00" taborder="1" left="10" top="66" width="680" height="68" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" direction="vertical" rowcount="2" onitemchanged="Radio00_onitemchanged" font="12px &quot;Malgun Gothic&quot;">
          <Dataset id="innerdataset">
            <ColumnInfo>
              <Column id="codecolumn" size="256"/>
              <Column id="datacolumn" size="256"/>
            </ColumnInfo>
            <Rows>
              <Row>
                <Col id="datacolumn">5px/normal "Malgun Gothic"</Col>
              </Row>
              <Row>
                <Col id="datacolumn">10px/normal "Malgun Gothic"</Col>
              </Row>
              <Row>
                <Col id="datacolumn">16px/normal "Malgun Gothic"</Col>
              </Row>
              <Row>
                <Col id="datacolumn">20px/normal "Malgun Gothic"</Col>
              </Row>
            </Rows>
          </Dataset>
        </Radio>
        <!-- 행1: TC-B-01~03 -->
        <Static id="lbl_b01" taborder="2" text="[TC-B-01] padding em (self font 연동)" left="10" top="152" width="185" height="14" font="9px Malgun Gothic"/>
        <Button id="btn_b01" taborder="3" text="padding=1em / font=20px" left="10" top="168" height="72" width="185" onclick="btn_b01_onclick" font="20px/normal &quot;Malgun Gothic&quot;" padding="1em" border="1px solid #999"/>
        <Static id="lbl_b02" taborder="4" text="[TC-B-02] padding 4방향 혼합 단위" left="205" top="152" width="185" height="14" font="9px Malgun Gothic"/>
        <Button id="btn_b02" taborder="5" text="1em 2rem 0.5em 1rem" left="205" top="168" height="72" width="185" onclick="btn_b02_onclick" font="10px/normal &quot;Malgun Gothic&quot;" padding="1em 2rem 0.5em 1rem" border="1px solid #999"/>
        <Static id="lbl_b03" taborder="6" text="[TC-B-03] border em (font=16px)" left="400" top="152" width="185" height="14" font="9px Malgun Gothic"/>
        <Button id="btn_b03" taborder="7" text="border=0.5em solid blue" left="400" top="168" height="72" width="185" onclick="btn_b03_onclick" font="16px/normal &quot;Malgun Gothic&quot;" border="0.5em solid #3B82F6"/>
        <!-- 행2: TC-B-04~06 -->
        <Static id="lbl_b04" taborder="8" text="[TC-B-04] textPadding em" left="10" top="262" width="185" height="14" font="9px Malgun Gothic"/>
        <Button id="btn_b04" taborder="9" text="textPadding=0.5em 1rem" left="10" top="278" height="72" width="185" onclick="btn_b04_onclick" font="10px/normal &quot;Malgun Gothic&quot;" textPadding="0.5em 1rem" border="1px solid #999" icon="url('theme://images/btn_TF_Close_O.png')"/>
        <Static id="lbl_b05" taborder="10" text="[TC-B-05] minwidth/maxwidth em(신규)" left="205" top="262" width="185" height="14" font="9px Malgun Gothic"/>
        <Button id="btn_b05" taborder="11" text="min=6rem max=16rem" left="205" top="278" height="72" width="90" onclick="btn_b05_onclick" font="10px/normal &quot;Malgun Gothic&quot;" minwidth="6rem" maxwidth="16rem" minheight="2rem" maxheight="4rem" border="1px solid #999"/>
        <Static id="lbl_b06" taborder="12" text="[TC-B-06] letterSpacing 양수 em" left="400" top="262" width="185" height="14" font="9px Malgun Gothic"/>
        <Button id="btn_b06" taborder="13" text="letterSpacing=0.05em" left="400" top="278" height="72" width="185" onclick="btn_b06_onclick" font="10px/normal &quot;Malgun Gothic&quot;" letterSpacing="0.05em" border="1px solid #999"/>
        <!-- 행3: TC-B-07~09 -->
        <Static id="lbl_b07" taborder="14" text="[TC-B-07] letterSpacing 음수 em(허용)" left="10" top="372" width="185" height="14" font="9px Malgun Gothic"/>
        <Button id="btn_b07" taborder="15" text="letterSpacing=-0.02em" left="10" top="388" height="72" width="185" onclick="btn_b07_onclick" font="10px/normal &quot;Malgun Gothic&quot;" letterSpacing="-0.02em" border="1px solid #999"/>
        <Static id="lbl_b08" taborder="16" text="[TC-B-08] wordSpacing em" left="205" top="372" width="185" height="14" font="9px Malgun Gothic"/>
        <Button id="btn_b08" taborder="17" text="word spacing 0.1em" left="205" top="388" height="72" width="185" onclick="btn_b08_onclick" font="10px/normal &quot;Malgun Gothic&quot;" wordSpacing="0.1em" border="1px solid #999"/>
        <Static id="lbl_b09" taborder="18" text="[TC-B-09] boxShadow em/rem(신규)" left="400" top="372" width="185" height="14" font="9px Malgun Gothic"/>
        <Button id="btn_b09" taborder="19" text="0.2em 0.2em 0.5rem rgba" left="400" top="388" height="72" width="185" onclick="btn_b09_onclick" font="10px/normal &quot;Malgun Gothic&quot;" boxShadow="0.2em 0.2em 0.5rem rgba(0,0,0,0.3)" border="1px solid #999"/>
        <!-- 결과 영역 (우측) -->
        <Combo id="Combo01" taborder="20" left="600" top="152" width="380" height="50" innerdataset="Dataset00" datacolumn="datacolumn" codecolumn="codecolumn" font="12px &quot;Malgun Gothic&quot;"/>
        <Button id="Button01" taborder="21" text="값 확인" left="990" top="152" width="80" height="50" onclick="Button01_onclick" font="12px &quot;Malgun Gothic&quot;"/>
        <TextArea id="TextArea00" taborder="22" left="600" top="214" width="670" height="490" font="12px &quot;Malgun Gothic&quot;"/>
        <Button id="btn_reload" taborder="23" text="[초기화]" left="1165" top="8" width="100" height="30" onclick="btn_reload_onclick" font="11px &quot;Malgun Gothic&quot;" border="1px solid #CC0000"/>
      </Layout>
    </Layouts>
    <Objects>
      <Dataset id="Dataset00">
        <ColumnInfo>
          <Column id="codecolumn" size="256"/>
          <Column id="datacolumn" size="256"/>
        </ColumnInfo>
        <Rows>
          <Row>
            <Col id="codecolumn">0</Col>
            <Col id="datacolumn">TC-B-01 padding em (self font 연동)</Col>
          </Row>
          <Row>
            <Col id="codecolumn">1</Col>
            <Col id="datacolumn">TC-B-02 padding 4방향 혼합</Col>
          </Row>
          <Row>
            <Col id="codecolumn">2</Col>
            <Col id="datacolumn">TC-B-03 border em</Col>
          </Row>
          <Row>
            <Col id="codecolumn">3</Col>
            <Col id="datacolumn">TC-B-04 textPadding em</Col>
          </Row>
          <Row>
            <Col id="codecolumn">4</Col>
            <Col id="datacolumn">TC-B-05 minwidth/maxwidth em(신규)</Col>
          </Row>
          <Row>
            <Col id="codecolumn">5</Col>
            <Col id="datacolumn">TC-B-06 letterSpacing 양수 em</Col>
          </Row>
          <Row>
            <Col id="codecolumn">6</Col>
            <Col id="datacolumn">TC-B-07 letterSpacing 음수 em</Col>
          </Row>
          <Row>
            <Col id="codecolumn">7</Col>
            <Col id="datacolumn">TC-B-08 wordSpacing em</Col>
          </Row>
          <Row>
            <Col id="codecolumn">8</Col>
            <Col id="datacolumn">TC-B-09 boxShadow em/rem(신규)</Col>
          </Row>
        </Rows>
      </Dataset>
    </Objects>
    <Script type="xscript5.1"><![CDATA[
this.Radio00_onitemchanged = function(obj:nexacro.Radio,e:nexacro.ItemChangeEventInfo)
{
	Object.keys(this.all)
	.filter(key => key.startsWith('btn_b'))
	.sort()
	.forEach(key => {
		this.all[key].font = obj.text;
	});
	this.resetScroll();
};

this.Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var base = "mainframe.WorkFrame.form.Div00.form.";
	var el, msg;
	switch(this.Combo01.index) {
	case 0:
		el = document.getElementById(base + "btn_b01");
		msg = "[TC-B-01] padding em — self font-size 연동 핵심\n"
		    + "설정: padding=1em, font=20px\n"
		    + "Pass: computed padding = 20px (self font 기준)\n"
		    + "NG  : computed padding = 12px (MainFrame 고정 버그)\n\n"
		    + "DOM computed:\n"
		    + "padding = " + window.getComputedStyle(el).padding;
		break;
	case 1:
		el = document.getElementById(base + "btn_b02");
		msg = "[TC-B-02] padding 4방향 혼합 단위\n"
		    + "설정: padding=1em 2rem 0.5em 1rem\n"
		    + "Pass: 각 방향 단위 독립 유지\n"
		    + "NG  : 한 방향 변경 시 전체 px 변환\n\n"
		    + "DOM computed:\n"
		    + "top    = " + window.getComputedStyle(el).paddingTop + "\n"
		    + "right  = " + window.getComputedStyle(el).paddingRight + "\n"
		    + "bottom = " + window.getComputedStyle(el).paddingBottom + "\n"
		    + "left   = " + window.getComputedStyle(el).paddingLeft;
		break;
	case 2:
		el = document.getElementById(base + "btn_b03");
		msg = "[TC-B-03] border em\n"
		    + "설정: border=0.125em solid #3B82F6, font=16px\n"
		    + "Pass: borderTopWidth = 2px (16px × 0.125)\n\n"
		    + "DOM computed:\n"
		    + "borderTopWidth = " + window.getComputedStyle(el).borderTopWidth;
		break;
	case 3:
		el = document.getElementById(base + "btn_b04:text");
		msg = "[TC-B-04] textPadding em\n"
		    + "설정: textPadding=0.5em 1rem\n\n"
		    + "DOM computed (:text 영역):\n"
		    + "paddingBlock   = " + window.getComputedStyle(el).paddingBlock + "\n"
		    + "paddingInline  = " + window.getComputedStyle(el).paddingInline;
		break;
	case 4:
		msg = "[TC-B-05] minwidth/maxwidth em/rem — 신규 지원\n"
		    + "설정: width=80px, minwidth=6rem, maxwidth=16rem\n"
		    + "설정: minheight=2rem, maxheight=4rem\n"
		    + "Pass: rem × MainFrame font-size로 레이아웃 반영\n"
		    + "NG  : 0 처리 또는 무시됨 (NexacroN 동작)\n\n"
		    + "속성값:\n"
		    + "minwidth      = " + this.btn_b05.minwidth + "\n"
		    + "maxwidth      = " + this.btn_b05.maxwidth + "\n"
		    + "minheight     = " + this.btn_b05.minheight + "\n"
		    + "maxheight     = " + this.btn_b05.maxheight + "\n"
		    + "getOffsetWidth  = " + this.btn_b05.getOffsetWidth() + "\n"
		    + "getOffsetHeight = " + this.btn_b05.getOffsetHeight();
		break;
	case 5:
		el = document.getElementById(base + "btn_b06");
		msg = "[TC-B-06] letterSpacing 양수 em\n"
		    + "설정: letterSpacing=0.05em\n"
		    + "Pass: XML에 '0.05em' 문자열 그대로 보존\n"
		    + "NG  : '0.05' 숫자만 저장 (edittype=Number 미변경 시)\n\n"
		    + "DOM computed:\n"
		    + "letterSpacing = " + window.getComputedStyle(el).letterSpacing;
		break;
	case 6:
		el = document.getElementById(base + "btn_b07");
		msg = "[TC-B-07] letterSpacing 음수 em — 허용 확인\n"
		    + "설정: letterSpacing=-0.02em\n"
		    + "Pass: 음수 em 값 적용 (PixelNegativeBase 변경 확인)\n\n"
		    + "DOM computed:\n"
		    + "letterSpacing = " + window.getComputedStyle(el).letterSpacing;
		break;
	case 7:
		el = document.getElementById(base + "btn_b08");
		msg = "[TC-B-08] wordSpacing em\n"
		    + "설정: wordSpacing=0.1em\n\n"
		    + "DOM computed:\n"
		    + "wordSpacing = " + window.getComputedStyle(el).wordSpacing;
		break;
	case 8:
		el = document.getElementById(base + "btn_b09");
		msg = "[TC-B-09] boxShadow em/rem — 신규 지원\n"
		    + "설정: boxShadow=0.2em 0.2em 0.5rem rgba(0,0,0,0.3)\n"
		    + "offset-x/y: em(self font 기준), blur: rem(MainFrame 기준)\n\n"
		    + "DOM computed:\n"
		    + "boxShadow = " + window.getComputedStyle(el).boxShadow;
		break;
	default:
		msg = "Combo에서 항목을 선택한 후 [값 확인]을 클릭하세요.";
	}
	this.TextArea00.deleteText();
	this.TextArea00.value = msg;
};

this.btn_b01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var el = document.getElementById("mainframe.WorkFrame.form.Div00.form.btn_b01");
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-B-01] padding em — self font-size 연동\n"
	    + "설정: padding=1em, font=20px\n"
	    + "Pass: 20px / NG: 12px (MainFrame 12px 고정)\n\n"
	    + "DOM: " + window.getComputedStyle(el).padding;
};

this.btn_b02_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var el = document.getElementById("mainframe.WorkFrame.form.Div00.form.btn_b02");
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-B-02] padding 4방향 혼합\n"
	    + "top    = " + window.getComputedStyle(el).paddingTop + "\n"
	    + "right  = " + window.getComputedStyle(el).paddingRight + "\n"
	    + "bottom = " + window.getComputedStyle(el).paddingBottom + "\n"
	    + "left   = " + window.getComputedStyle(el).paddingLeft;
};

this.btn_b03_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var el = document.getElementById("mainframe.WorkFrame.form.Div00.form.btn_b03");
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-B-03] border em\n"
	    + "font=16px, border=0.125em → 기대: 2px\n"
	    + "DOM borderTopWidth: " + window.getComputedStyle(el).borderTopWidth;
};

this.btn_b04_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var el = document.getElementById("mainframe.WorkFrame.form.Div00.form.btn_b04:text");
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-B-04] textPadding em\n"
	    + "paddingBlock   = " + window.getComputedStyle(el).paddingBlock + "\n"
	    + "paddingInline  = " + window.getComputedStyle(el).paddingInline;
};

this.btn_b05_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-B-05] minwidth/maxwidth em\n"
	    + "minwidth      = " + this.btn_b05.minwidth + "\n"
	    + "maxwidth      = " + this.btn_b05.maxwidth + "\n"
	    + "minheight     = " + this.btn_b05.minheight + "\n"
	    + "maxheight     = " + this.btn_b05.maxheight + "\n"
	    + "getOffsetWidth  = " + this.btn_b05.getOffsetWidth() + "\n"
	    + "getOffsetHeight = " + this.btn_b05.getOffsetHeight();
};

this.btn_b06_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var el = document.getElementById("mainframe.WorkFrame.form.Div00.form.btn_b06");
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-B-06] letterSpacing 양수 em\n"
	    + "DOM: " + window.getComputedStyle(el).letterSpacing;
};

this.btn_b07_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var el = document.getElementById("mainframe.WorkFrame.form.Div00.form.btn_b07");
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-B-07] letterSpacing 음수 em\n"
	    + "DOM: " + window.getComputedStyle(el).letterSpacing;
};

this.btn_b08_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var el = document.getElementById("mainframe.WorkFrame.form.Div00.form.btn_b08");
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-B-08] wordSpacing em\n"
	    + "DOM: " + window.getComputedStyle(el).wordSpacing;
};

this.btn_b09_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var el = document.getElementById("mainframe.WorkFrame.form.Div00.form.btn_b09");
	this.TextArea00.deleteText();
	this.TextArea00.value = "[TC-B-09] boxShadow em/rem\n"
	    + "DOM: " + window.getComputedStyle(el).boxShadow;
};
this.btn_reload_onclick = function(obj:nexacro.Button, e:nexacro.ClickEventInfo)
{
	this.reload();
};

this.EmRemSample00_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{

};
]]></Script>
  </Form>
</FDL>
