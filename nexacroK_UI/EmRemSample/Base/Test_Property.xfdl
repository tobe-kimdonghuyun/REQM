    <Script type="xscript5.1"><![CDATA[// font resize
this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
  this._getMainFrame().font = "normal 0.5rem/normal \"Arial\"";
  this.resetScroll();
};

this.Button00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
  this._getMainFrame().font = "normal 1rem/normal \"Arial\"";
  this.resetScroll();
};

this.Button00_00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
  this._getMainFrame().font = "normal 1.5rem/normal \"Arial\"";
  this.resetScroll();
};

this.Button00_00_00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
  this._getMainFrame().font = "normal 2rem/normal \"Arial\"";
  this.resetScroll();
};

// init properties
this.Test_Rem_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	// letterSpacing
	this.Button01_01_00_00_00.letterSpacing = "0.5rem";
	this.Button01_00_01_00_00_00.letterSpacing = "0.5rem";
	this.Button01_00_00_00_00_00_00.letterSpacing = "0.5rem";
	
	// wordSpacing	
	this.Button01_01_00_00_00_00.wordSpacing = "0.5rem";
	this.Button01_00_01_00_00_00_00.wordSpacing = "0.5rem";
	this.Button01_00_00_00_00_00_00_00.wordSpacing = "0.5rem";	
	
	// itemheight - rem
	this.Combo00.itemheight = "1rem";
	this.ListBox00.itemheight = "1rem";
	this.MultiCombo00.itemheight = "1rem";	
	
	// itemheight - em
	this.Combo00_00.itemheight = "2em";
	this.ListBox00_00.itemheight = "2em";
	this.MultiCombo00_00.itemheight = "2em";
	
	// titlegap
	this.GroupBox00.titlegap = "2rem";	
};
]]></Script>
