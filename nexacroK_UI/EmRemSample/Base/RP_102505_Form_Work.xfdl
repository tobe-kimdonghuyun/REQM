<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Form_Work" width="1280" height="970" titletext="Form_Work" onload="Form_Work_onload" ontimer="Form_Work_ontimer">
    <Layouts>
      <Layout width="1280" height="970" screenid="Desktop_screen">
        <Button id="Button01" taborder="0" text="그리드 - 콤보 cell" left="26" top="18" width="579" height="72"/>
        <Grid id="Grid01" taborder="1" left="30" autofittype="col" top="170" height="283" binddataset="dc_grd" right="230" autoenter="select" createrowstype="all" cellclickbound="cell" selecttype="cell" onheadclick="Grid01_onheadclick" onkeydown="Grid01_onkeydown" accessibilitylabel="NO, combocontrol, combotext 그리드표">
          <Formats>
            <Format id="default">
              <Columns>
                <Column size="40"/>
                <Column size="100"/>
                <Column size="140"/>
              </Columns>
              <Rows>
                <Row size="35" band="head"/>
                <Row size="35"/>
              </Rows>
              <Band id="head">
                <Cell text="NO"/>
                <Cell col="1" text="combocontrol"/>
                <Cell col="2" text="combotext"/>
              </Band>
              <Band id="body">
                <Cell text="bind:NO" displaytype="text"/>
                <Cell col="1" text="bind:Combo" displaytype="combocontrol" edittype="combo" combodataset="dsCombo" combocodecol="cd" combodatacol="data"/>
                <Cell col="2" text="bind:Combo2" displaytype="combotext" edittype="combo" combodataset="dsCombo2" combocodecol="cd" combodatacol="data"/>
              </Band>
            </Format>
          </Formats>
        </Grid>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[]]></Script>
    <Objects>
      <Dataset id="dc_grd">
        <ColumnInfo>
          <Column id="NO" type="STRING" size="256"/>
