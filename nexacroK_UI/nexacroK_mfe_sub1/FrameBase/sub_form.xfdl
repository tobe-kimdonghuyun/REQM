<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="sub_form" width="1280" height="720" titletext="New Form" onclose="sub_form_onclose">
    <Layouts>
      <Layout height="720" width="1280">
        <Button id="Button00" taborder="0" text="this.close" left="47" top="40" width="307" height="106" onclick="Button00_onclick"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.close("sub_form close");
};

this.sub_form_onclose = function(obj:nexacro.Form,e:nexacro.CloseEventInfo)
{
	
};
]]></Script>
  </Form>
</FDL>
