<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Form_Work" width="1280" height="720" titletext="Form_Work">
    <Layouts>
      <Layout width="1280" height="720" screenid="Desktop_screen">
        <Button id="btn_open" taborder="0" text="nexacro.open" left="24" top="92" width="178" height="75" onclick="Button00_onclick"/>
        <Button id="btn_alert" taborder="1" text="this.alert" left="212" top="92" width="178" height="75" onclick="Button00_onclick"/>
        <Button id="btn_transaction" taborder="2" text="this.transaction" left="410" top="92" width="178" height="75" onclick="Button00_onclick"/>
        <Static id="Static00" taborder="3" text="nexacroK_mfe_sub1" left="36" top="4" width="518" height="70" font="36px/normal &quot;Malgun Gothic&quot;"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	nexacro.open("modeless", "FrameBase::sub_form.xfdl",  this.getOwnerFrame(), {a:'aaa', b:	'bbb'}, "titletext=TEST", 0, 0, null, null, this, "noactivate=true", "promise").then((result) => {
	trace("Closed popup"); 
	 }).catch((err) => {
	   trace("Failed to open popup: " + err.message);
	 });
};
]]></Script>
  </Form>
</FDL>
