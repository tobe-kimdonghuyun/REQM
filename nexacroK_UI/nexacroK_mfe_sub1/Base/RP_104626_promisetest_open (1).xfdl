	});
	trace("ret - "+ret);
	
	let ret3 = nexacro.open("promise_open_test3","FrameBase::Form_Work3.xfdl", this.getOwnerFrame(), { user:"이몽룡" }, "resizable=false showstatusbar=true", 150, 500, 500, 400, "promise").then((result) => {
