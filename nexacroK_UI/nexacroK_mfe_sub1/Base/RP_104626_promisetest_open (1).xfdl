	});
	trace("ret - "+ret);
	
	let ret2 = nexacro.open("promise_open_test2","FrameBase::Form_Work2.xfdl", this.getOwnerFrame(), { user:"이몽룡" }, "resizable=false showstatusbar=true", 150, 300, 500,"promise").then((result) => {
