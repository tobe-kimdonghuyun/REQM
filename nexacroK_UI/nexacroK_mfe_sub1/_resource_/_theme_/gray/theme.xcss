<?xml version="1.0" encoding="utf-8"?>
<XCSS version="1.1">
  <Predefines>
    <Group id="Default_gray">
      <Define id="maincolor" value="#BBAAFF"/>
      <Define id="subcolor" value="#EEEBFF"/>
    </Group>
    <Group id="Default_font">
      <Define id="Malgungothic11px" value="11px &quot;Malgun Gothic&quot;"/>
      <Define id="Malgungothic12px" value="12px &quot;Malgun Gothic&quot;"/>
      <Define id="BoldMalgungothic12px" value="bold 12px &quot;Malgun Gothic&quot;"/>
      <Define id="BoldMalgungothic13px" value="bold 13px &quot;Malgun Gothic&quot;"/>
      <Define id="BoldMalgungothic14px" value="bold 14px &quot;Malgun Gothic&quot;"/>
      <Define id="BoldMalgungothic15px" value="bold 15px &quot;Malgun Gothic&quot;"/>
      <Define id="BoldMalgungothic17px" value="bold 17px &quot;Malgun Gothic&quot;"/>
    </Group>
  </Predefines>
  <CSSData><![CDATA[
/* 
  nexacro Application Theme
  Name		   : gray.xtheme
  Published        : 2020-04-06
  Last-modified    : 2025-10-28
*/
/* 
  UI 컬러 가이드
  Predefine 그룹 : Default_gray
  maincolor: -nexa-define(--maincolor) subcolor: -nexa-define(--subcolor) 에서 
  포인트 컬러 변경 할 수 있습니다. 
  포인트 컬러 블루(Pointcolor_Blue) 변경 예시 
  maincolor:#3E86FF subcolor:#DEF1FE
*/
/* Form */
.Form
{
	-nexa-border : 0px none;
	background : #FBFBFC;
	font :  -nexa-define(--Malgungothic11px);
	color : #272B37;
}
.Form[userstatus=contents]
{
	background : transparent;
}
/* MainFrame */
.MainFrame
{
	-nexa-border : 1px solid #646982;
}
/* FrameSet */
.ChildFrame,.FrameSet,.VFrameSet,.HFrameSet,.TileFrameSet
{
	/* No style applied */
}
/* TitleBarControl */
.TitleBarControl,.TitleBarControl[status=deactivate],.TitleBarControl[status=disabled]
{
	background : #E3E5EB;
}
.TitleBarControl .titleicon,
.TitleBarControl .titleicon[status=mouseover],.TitleBarControl .titleicon[status=deactivate],
.TitleBarControl .titleicon[status=disabled]
{
	-nexa-icon : URL('theme://images/titlebar_icon.png');
	-nexa-padding : 0px 10px 0px 10px;
	-nexa-text-padding : 0px 0px 0px 10px;
	color : #5B5E6A;
	font :  -nexa-define(--BoldMalgungothic14px);
}
.TitleBarControl .minbutton,
.TitleBarControl .minbutton[status=focused],.TitleBarControl .minbutton[userstatus=selected],
.TitleBarControl .minbutton[status=deactivate]
{
	-nexa-icon : URL("theme://images/btn_min_N.png");
}
.TitleBarControl .minbutton[status=mouseover],.TitleBarControl .minbutton[userstatus=pushed]
{
	background : #B3BACC;
}
.TitleBarControl .minbutton[status=disabled]
{
	-nexa-icon : URL("theme://images/btn_min_D.png");
}
.TitleBarControl .maxbutton,
.TitleBarControl .maxbutton[status=focused],.TitleBarControl .maxbutton[userstatus=selected],
.TitleBarControl .maxbutton[status=deactivate]
{
	-nexa-icon : URL("theme://images/btn_max_N.png");
}
.TitleBarControl .maxbutton[status=mouseover],.TitleBarControl .maxbutton[userstatus=pushed]
{
	background : #B3BACC;
}
.TitleBarControl .maxbutton[status=disabled]
{
	-nexa-icon : URL("theme://images/btn_max_D.png");
}
.TitleBarControl .normalbutton,
.TitleBarControl .normalbutton[status=focused],.TitleBarControl .normalbutton[userstatus=selected],
.TitleBarControl .normalbutton[status=deactivate]
{
	-nexa-icon : URL("theme://images/btn_normal_N.png");
}
.TitleBarControl .normalbutton[status=mouseover],.TitleBarControl .normalbutton[userstatus=pushed]
{
	background : #B3BACC;
}
.TitleBarControl .normalbutton[status=disabled]
{
	-nexa-icon : URL("theme://images/btn_normal_D.png");
}
.TitleBarControl .closebutton,
.TitleBarControl .closebutton[status=focused],.TitleBarControl .closebutton[userstatus=selected],
.TitleBarControl .closebutton[status=deactivate]
{
	-nexa-icon : URL("theme://images/btn_close_N.png");
}
.TitleBarControl .closebutton[status=mouseover],.TitleBarControl .closebutton[userstatus=pushed]
{
	-nexa-icon : URL("theme://images/btn_close_O.png");
	background : #FF4444;
}
.TitleBarControl .closebutton[status=disabled]
{
	-nexa-icon : URL("theme://images/btn_close_D.png");
}
/* Edit *//* EditControl */
.Edit,
.EditControl
{
	-nexa-border : 1px solid #CCCCCC;
	-nexa-padding : 0px 0px 0px 5px;
	background : #FFFFFF;
}
.Edit[status=mouseover],.Edit[status=focused],
.EditControl[status=mouseover],.EditControl[status=focused]
{
	-nexa-border : 1px solid #272B37;
}
.Edit[status=disabled],
.EditControl[status=disabled]
{
	-nexa-border : 1px solid #E0E6EA;
	background : #F7F9FA;
	color : #A9B4BF;
}
.Edit[status=readonly],
.EditControl[status=readonly]
{
	-nexa-border : 1px solid #E0E6EA;
	background : #F7F9FA;
}
/* MaskEdit *//* MaskEditControl */
.MaskEdit,
.MaskEditControl
{
	-nexa-border : 1px solid #CCCCCC;
	-nexa-padding : 0px 5px 0px 0px;
	background : #FFFFFF;
}
.MaskEdit[status=mouseover],.MaskEdit[status=focused],
.MaskEditControl[status=mouseover],.MaskEditControl[status=focused]
{
	-nexa-border : 1px solid #272B37;
}
.MaskEdit[status=disabled],
.MaskEditControl[status=disabled]
{
	-nexa-border : 1px solid #E0E6EA;
	background : #F7F9FA;
	color : #A9B4BF;
}
.MaskEdit[status=readonly],
.MaskEditControl[status=readonly]
{
	-nexa-border : 1px solid #E0E6EA;
	background : #F7F9FA;
}
/* TextArea *//* TextAreaControl */
.TextArea,.TextAreaControl
{
	background : #FFFFFF;
	-nexa-border : 1px solid #CCCCCC;
	-nexa-padding : 5px;
	-nexa-text-align : left;
}
.TextArea[status=focused],.TextArea[status=mouseover],
.TextAreaControl[status=focused],.TextAreaControl[status=mouseover]
{
	-nexa-border : 1px solid #272B37;
}
.TextArea[status=disabled],.TextAreaControl[status=disabled]
{
	-nexa-border : 1px solid #E0E6EA;
	background : #F7F9FA;
	color : #A9B4BF;
}
.TextArea[status=readonly],.TextAreaControl[status=readonly]
{
	-nexa-border : 1px solid #E0E6EA;
	background : #F7F9FA;
}
/* nulltext *//* invalidtext */
.Edit[userstatus=nulltext],.EditControl[userstatus=nulltext],.MaskEdit[userstatus=nulltext],
.MaskEditControl[userstatus=nulltext],.TextArea[userstatus=nulltext],.TextAreaControl[userstatus=nulltext]
{
	color : #A9B4BF;
}
.Calendar[userstatus=invalidtext],.CalendarControl[userstatus=invalidtext],.MaskEdit[userstatus=invalidtext],
.MaskEditControl[userstatus=invalidtext],.Spin[userstatus=invalidtext],.SpinControl[userstatus=invalidtext]
{
	color : #A9B4BF;
}
/* Spin */
.Spin,.SpinControl
{
	-nexa-border : 1px solid #CCCCCC;
	background : #FFFFFF;
}
.Spin[status=mouseover],.Spin[status=focused],.SpinControl[status=mouseover],.SpinControl[status=focused]
{
	-nexa-border : 1px solid #272B37;
}
.Spin[status=disabled],.SpinControl[status=disabled]
{
	-nexa-border : 1px solid #E0E6EA;
	background : #F7F9FA;
	color : #A9B4BF;
}
.Spin[status=readonly],.SpinControl[status=readonly]
{
	-nexa-border : 1px solid #E0E6EA;
	background : #F7F9FA;
}
.Spin .spinedit,.Spin .spinedit[status=focused],.Spin .spinedit[status=disabled],
.Spin .spinedit[status=readonly],.Spin .spinedit[status=mouseover],
.SpinControl .spinedit,.SpinControl .spinedit[status=focused],.SpinControl .spinedit[status=disabled],
.SpinControl .spinedit[status=readonly],.SpinControl .spinedit[status=mouseover]
{
	-nexa-padding : 0px 5px 0px 0px;
	-nexa-border : 0px none;
}
.Spin .spinupbutton,.Spin .spinupbutton[status=focused],.SpinControl .spinupbutton,.SpinControl .spinupbutton[status=focused]
{
	-nexa-icon : url("theme://images/btn_SpinUp_N.png");
	-nexa-padding : 0px;
}
.Spin .spinupbutton[status=mouseover],.Spin .spinupbutton[userstatus=pushed],
.SpinControl .spinupbutton[status=mouseover],.SpinControl .spinupbutton[userstatus=pushed]
{
	-nexa-icon : url("theme://images/btn_SpinUp_O.png");
	-nexa-padding : 0px;
}
.Spin .spinupbutton[status=disabled],.SpinControl .spinupbutton[status=disabled]
{
	-nexa-icon : url("theme://images/btn_SpinUp_D.png");
	-nexa-padding : 0px;
}
.Spin .spindownbutton,.Spin .spindownbutton[status=focused],
.SpinControl .spindownbutton,.SpinControl .spindownbutton[status=focused]
{
	-nexa-icon : url("theme://images/btn_SpinDown_N.png");
	-nexa-padding : 0px;
}
.Spin .spindownbutton[status=mouseover],.Spin .spindownbutton[userstatus=pushed],
.SpinControl .spindownbutton[status=mouseover],.SpinControl .spindownbutton[userstatus=pushed]
{
	-nexa-icon : url("theme://images/btn_SpinDown_O.png");
	-nexa-padding : 0px;
}
.Spin .spindownbutton[status=disabled],.SpinControl .spindownbutton[status=disabled]
{
	-nexa-icon : url("theme://images/btn_SpinDown_D.png");
	-nexa-padding : 0px;
}
/* Combo *//* ComboControl */
.Combo,
.ComboControl
{
	-nexa-border : 1px solid #CCCCCC;
	background : #FFFFFF;
}
.Combo[status=mouseover],.Combo[status=focused],
.ComboControl[status=mouseover],.ComboControl[status=focused]
{
	-nexa-border : 1px solid #272B37;
}
.Combo[status=disabled],
.ComboControl[status=disabled]
{
	-nexa-border : 1px solid #E0E6EA;
	background : #F7F9FA;
	color : #A9B4BF;
}
.Combo[status=readonly],
.ComboControl[status=readonly]
{
	-nexa-border : 1px solid #E0E6EA;
	background : #F7F9FA;
}
.Combo .comboedit,
.Combo .comboedit[status=mouseover],.Combo .comboedit[status=focused],
.ComboControl .comboedit,
.ComboControl .comboedit[status=mouseover],.ComboControl .comboedit[status=focused]
{
	-nexa-padding : 0px 0px 0px 5px;
	-nexa-border : 0px none;
}
.Combo .comboedit[status=disabled],
.ComboControl .comboedit[status=disabled]
{
	-nexa-border : 0px none;
}
.Combo .comboedit[status=readonly],
.ComboControl .comboedit[status=readonly]
{
	-nexa-border : 0px none;
}
.Combo .dropbutton,
.ComboControl .dropbutton
{
	-nexa-icon : url("theme://images/btn_drop_N.png");
}
.Combo .dropbutton[status=mouseover],.Combo .dropbutton[status=focused],
.Combo .dropbutton[userstatus=pushed],
.ComboControl .dropbutton[status=mouseover],.ComboControl .dropbutton[status=focused],
.ComboControl .dropbutton[userstatus=pushed]
{
	-nexa-icon : url("theme://images/btn_drop_O.png");
}
.Combo .dropbutton[status=disabled],
.ComboControl .dropbutton[status=disabled]
{
	-nexa-icon : url("theme://images/btn_drop_D.png");
}
.Combo .combolist,
.ComboControl .combolist
{
	-nexa-border : 1px solid ;
	background : #FFFFFF;
}
.Combo .combolist .listboxitem,
.ComboControl .combolist .listboxitem
{
	-nexa-padding : 5px 0px 5px 5px;
}
.Combo .combolist .listboxitem[status=mouseover],.Combo .combolist .listboxitem[status=focused],
.ComboControl .combolist .listboxitem[status=mouseover],.ComboControl .combolist .listboxitem[status=focused]
{
	background : #ECECEF;
}
.Combo .combolist .listboxitem[userstatus=selected],
.ComboControl .combolist .listboxitem[userstatus=selected]
{
	background : #E1E3EB;
}
/* CheckBox *//* CheckBoxControl */
.CheckBox,.CheckBox[status=focused],
.CheckBoxControl,.CheckBoxControl[status=focused]
{
	-nexa-icon : url("theme://images/img_check_NN.png");
	-nexa-text-padding : 5px;
}
.CheckBox[status=mouseover],
.CheckBoxControl[status=mouseover]
{
	-nexa-icon : url("theme://images/img_check_ON.png");
}
.CheckBox[status=disabled],
.CheckBoxControl[status=disabled]
{
	-nexa-icon : url("theme://images/img_check_DN.png");
}
.CheckBox[userstatus=selected][status=mouseover],.CheckBox[userstatus=selected],
.CheckBox[userstatus=selected][status=focused],
.CheckBoxControl[userstatus=selected][status=mouseover],.CheckBoxControl[userstatus=selected],
.CheckBoxControl[userstatus=selected][status=focused]
{
	-nexa-icon : url("theme://images/img_check_NS.png");
}
.CheckBox[userstatus=selected][status=disabled],
.CheckBoxControl[userstatus=selected][status=disabled]
{
	-nexa-icon : url("theme://images/img_check_DS.png");
}
/* Radio */
.Radio .radioitem
{
	-nexa-icon : url("theme://images/img_radio_NN.png");
	-nexa-text-padding : 5px;
}
.Radio .radioitem[status=mouseover]
{
	-nexa-icon : url("theme://images/img_radio_ON.png");
}
.Radio .radioitem[status=disabled]
{
	-nexa-icon : url("theme://images/img_radio_DN.png");
}
.Radio .radioitem[userstatus=selected],.Radio .radioitem[userstatus=selected][status=mouseover]
{
	-nexa-icon : url("theme://images/img_radio_NS.png");
}
.Radio .radioitem[userstatus=selected][status=disabled]
{
	-nexa-icon : url("theme://images/img_radio_DS.png");
}
.RadioItemControl
{
	-nexa-icon : url("theme://images/img_radio_NN.png");
	-nexa-text-padding : 0px 0px 0px 5px;
}
.RadioItemControl[status=mouseover]
{
	-nexa-icon : URL('theme://images/img_radio_ON.png');
}
.RadioItemControl[status=disabled]
{
	-nexa-icon : URL('theme://images/img_radio_DN.png');
}
.RadioItemControl[userstatus=selected]
{
	-nexa-icon : URL('theme://images/img_radio_NS.png');
}
.RadioItemControl[userstatus=selected][status=mouseover]
{
	-nexa-icon : URL('theme://images/img_radio_NS.png');
}
.RadioItemControl[userstatus=selected][status=disabled]
{
	-nexa-icon : URL('theme://images/img_radio_DS.png');
}
/* Button */
.Button,.Button[status=focused],.Button[userstatus=selected]
{
	-nexa-border : 1px solid #CCCCCC;
	-nexa-padding : 0px 10px 0px 10px;
	background : #FBFBFB;
	font :  -nexa-define(--BoldMalgungothic12px);
	color : #646982;
	cursor : pointer;
}
.Button[status=mouseover],.Button[userstatus=pushed]
{
	-nexa-border : 1px solid #272B37;
	color : #646982;
}
.Button[status=disabled]
{
	-nexa-border : 1px solid #E0E6EA;
	background : #F7F9FA;
	color : #A9B4BF;
	cursor : default;
}
/* FileUpload */
.FileUpload,
.FileUpload[status=mouseover],.FileUpload[status=focused],
.FileUpload[userstatus=selected],
.FileUpload[status=disabled]
{
	-nexa-border : 0px none;
}
.FileUpload .fileuploaditem,
.FileUpload .fileuploaditem[status=focused]
{
	-nexa-border : 0px none;
}
.FileUpload .fileuploaditem .fileuploaditemedit,
.FileUpload .fileuploaditem .fileuploaditemedit[status=mouseover],.FileUpload .fileuploaditem .fileuploaditemedit[status=focused],
.FileUpload .fileuploaditem .fileuploaditemedit[status=readonly]
{
	background : #FFFFFF;
}
.FileUpload .fileuploaditem .fileuploaditembutton,
.FileUpload .fileuploaditem .fileuploaditembutton[status=focused],
.FileUpload .fileuploaditem .fileuploaditembutton[userstatus=selected]
{
	-nexa-border : 1px solid #CCCCCC;
	-nexa-padding : 0px 12px 0px 12px;
	background : #FBFBFB;
	font :  -nexa-define(--BoldMalgungothic12px);
	color : #646982;
	cursor : pointer;
}
.FileUpload .fileuploaditem .fileuploaditembutton[status=mouseover],
.FileUpload .fileuploaditem .fileuploaditembutton[userstatus=pushed]
{
	-nexa-border : 1px solid #272B37;
	color : #646982;
	background : #FFFFFF;
}
.FileUpload .fileuploaditem .fileuploaditembutton[status=disabled]
{
	-nexa-border : 1px solid #E0E6EA;
	background : #F7F9FA;
	color : #A9B4BF;
	cursor : default;
}
/* FileDownload */
.FileDownload,.FileDownload[status=focused]
{
	-nexa-border : 1px solid #CCCCCC;
	-nexa-padding : 0px 12px 0px 12px;
	background : #FBFBFB;
	font :  -nexa-define(--BoldMalgungothic12px);
	color : #646982;
	cursor : pointer;
}
.FileDownload[status=mouseover],.FileDownload[userstatus=pushed]
{
	-nexa-border : 1px solid #272B37;
	color : #646982;
	background : #FFFFFF;
}
.FileDownload[status=disabled]
{
	-nexa-border : 1px solid #E0E6EA;
	background : #F7F9FA;
	color : #A9B4BF;
	cursor : default;
}
/* ProgressBar *//* ProgressBarControl */
.ProgressBar,.ProgressBarControl
{
	-nexa-border : 1px solid #CCCCCC;
	-nexa-padding : 2px;
	background : #FFFFFF;
	color : #424557;
}
.ProgressBar[status=disabled],.ProgressBarControl[status=disabled]
{
	-nexa-border : 1px solid #E0E6EA;
	background : #F7F9FA;
}
.ProgressBar .progressbaritem,.ProgressBarControl .progressbaritem
{
	background : -nexa-define(--maincolor);
}
.ProgressBar .progressbaritem[status=disabled],.ProgressBarControl .progressbaritem[status=disabled]
{
	background : #E0E6EA;
}
.ProgressBar .progressbartext,.ProgressBarControl .progressbartext
{
	-nexa-padding : 0px 0px 0px 5px;
	-nexa-text-align : center;
	font :  -nexa-define(--Malgungothic11px);
}
/* GroupBox */
.GroupBox
{
	/* No style applied */
}
.GroupBox .groupboxcontents
{
	-nexa-border : 1px solid #CCCCCC;
}
.GroupBox .groupboxcontents[status=disabled]
{
	-nexa-border : 1px solid #E0E6EA;
	color : #A9B4BF;
}
.GroupBox .groupboxtitle
{
	-nexa-text-padding : 0px 5px 0px 5px;
	background : #FFFFFF;
}
.GroupBox .groupboxtitle[status=disabled]
{
	color : #A9B4BF;
}
/* Div *//*PopupDiv */
.Div,.PopupDiv
{
	background : transparent;
}
/* View */
.View
{
	/* No style applied */
}
/* Tab */
.Tab
{
	background : transparent;
}
.Tab .nextbutton
{
	-nexa-icon : url("theme://images/btn_tabNext_N.png");
	-nexa-padding : 5px 5px 5px 3px;
}
.Tab .nextbutton[status=mouseover],.Tab .nextbutton[status=focused],.Tab .nextbutton[userstatus=pushed]
{
	-nexa-icon : url("theme://images/btn_tabNext_O.png");
}
.Tab .prevbutton
{
	-nexa-icon : url("theme://images/btn_tabPrev_N.png");
	-nexa-padding : 5px 3px 5px 5px;
}
.Tab .prevbutton[status=mouseover],.Tab .prevbutton[status=focused],.Tab .prevbutton[userstatus=pushed]
{
	-nexa-icon : url("theme://images/btn_tabPrev_O.png");
}
.Tab .tabbuttonitem .extrabutton
{
	-nexa-icon : url("theme://images/btn_tabExtra_N.png");
	-nexa-padding : 0px 10px 0px 0px;
}
.Tab .tabbuttonitem .extrabutton[status=mouseover],
.Tab .tabbuttonitem .extrabutton[status=focused],.Tab .tabbuttonitem .extrabutton[userstatus=pushed]
{
	-nexa-icon : url("theme://images/btn_tabExtra_O.png");
	-nexa-padding : 0px 10px 0px 0px;
}
.Tab .tabbuttonitem .extrabutton[status=disabled]
{
	-nexa-icon : url("theme://images/btn_tabExtra_D.png");
	-nexa-padding : 0px 10px 0px 0px;
}
.Tab .tabbuttonitem
{
	-nexa-border : 1px solid transparent, 1px solid #CCCCCC, 1px solid transparent, 1px solid transparent;
	background : #F2F4F9;
	color : #2F333E;
}
.Tab .tabbuttonitem[status=focused],.Tab .tabbuttonitem[userstatus=selected]
{
	-nexa-border : 1px solid transparent, 1px solid #CCCCCC, 1px solid transparent, 1px solid transparent;
	background : #FFFFFF;
	color : #24272E;
}
.Tab .tabbuttonitem[status=disabled]
{
	background : #F2F4F9;
	color : #B7C0C9;
}
.Tab .tabbuttonitem .tabbuttonitemtext
{
	-nexa-padding : 0px 20px 0px 20px;
	-nexa-text-align : center;
	font :  -nexa-define(--BoldMalgungothic13px);
}
.Tab .tabbuttonitem .tabbuttonitemtext[status=mouseover]
{
	-nexa-text-decoration : underline;
}
.Tab .tabbuttonitem .tabbuttonitemtext[status=disabled]
{
	color : #3F4354;
}
.Tab .tabpage,
.Tab .tabpage[status=mouseover],.Tab .tabpage[status=focused],
.Tab .tabpage[status=disabled]
{
	-nexa-border : 1px solid #CCCCCC, 0px none, 0px none, 0px none;
	background : #FFFFFF;
}
/* Calendar *//* CalendarControl */
.Calendar,
.CalendarControl
{
	-nexa-border : 1px solid #CCCCCC;
	background : #FFFFFF;
}
.Calendar[status=mouseover],.Calendar[status=focused],
.CalendarControl[status=mouseover],.CalendarControl[status=focused]
{
	-nexa-border : 1px solid #272B37;
}
.Calendar[status=disabled],
.CalendarControl[status=disabled]
{
	-nexa-border : 1px solid #E0E6EA;
	background : #F7F9FA;
	color : #A9B4BF;
}
.Calendar[status=readonly],
.CalendarControl[status=readonly]
{
	-nexa-border : 1px solid #E0E6EA;
	background : #F7F9FA;
}
.Calendar .dropbutton,
.CalendarControl .dropbutton
{
	-nexa-icon : url("theme://images/btn_CalDrop_N.png");
}
.Calendar .dropbutton[status=mouseover],.Calendar .dropbutton[status=focused],.Calendar .dropbutton[userstatus=pushed],
.CalendarControl .dropbutton[status=mouseover],.CalendarControl .dropbutton[status=focused],.CalendarControl .dropbutton[userstatus=pushed]
{
	-nexa-icon : url("theme://images/btn_CalDrop_O.png");
}
.Calendar .dropbutton[status=disabled],
.CalendarControl .dropbutton[status=disabled]
{
	-nexa-icon : url("theme://images/btn_CalDrop_D.png");
}
.Calendar .calendaredit,.Calendar .calendaredit[status=mouseover],.Calendar .calendaredit[status=focused],
.Calendar .calendaredit[status=disabled],.Calendar .calendaredit[status=readonly],
.CalendarControl .calendaredit,.CalendarControl .calendaredit[status=mouseover],.CalendarControl .calendaredit[status=focused],
