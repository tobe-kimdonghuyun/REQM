/* Grid */
.Grid
{
	-nexa-border : 1px solid #DADCE1;
	background : #FFFFFF;
}
/* Grid/head */
.Grid .head
{
	background : #E7E9EF;
	font :  -nexa-define(--BoldMalgungothic13px);
	color : #272B37;
}
.Grid .head .row .cell
{
	-nexa-border : 0px none,1px solid #DADCE1,1px solid #DADCE1,0px none;
	-nexa-text-align : center;
}
/* Grid/body */
.Grid .body .row .cell
{
	-nexa-border : 0px none,1px solid #DADCE1,1px solid #DADCE1,0px none;
	-nexa-padding : 2px;
	-nexa-background-odd : #F6F7FB;
}
