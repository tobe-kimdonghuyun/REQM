        <Static id="Static00_00_00_01_00" taborder="20" text="1. usehelpertext = false&#13;&#10;footerheight = 15px&#13;&#10;height = 100px&#13;&#10;&#13;&#10;2. usehelpertext = true &lt;- 동작(설계문서)&#13;&#10;footerheight = 15px&#13;&#10;height = 115px = 100(usehelpertext 변경 전 height) + 15(helpertextcontrol height = footerheight 설정값) &#13;&#10;&#13;&#10;3. usehelpertext = true  &lt;- 메뉴얼&#13;&#10;footerheight = 15px = helpertext height&#13;&#10;height = 100px (labelcontrol height + boxcontrol height 유지)" left="382" top="26" width="549" height="154" verticalAlign="top"/>
