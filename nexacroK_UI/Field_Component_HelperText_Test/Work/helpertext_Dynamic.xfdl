        <Static id="Static00_00_00_00" taborder="31" text="Static00" left="7" top="210" width="9" height="2" border="1px solid blue"/>
        <Radio id="Radio00" taborder="8" left="755" top="28" width="140" height="30" innerdataset="innerdataset" codecolumn="codecolumn" datacolumn="datacolumn" direction="vertical" index="" text="false" value="0">
