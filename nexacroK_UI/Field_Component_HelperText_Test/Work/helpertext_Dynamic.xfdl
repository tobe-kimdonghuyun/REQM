      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
this.helpertext_basic_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
	this.TextArea00.deleteText();
	this.TextArea00.value = "usehelpertext = "+this.txf_Default00.usehelpertext
	                        + "\nusecharcount = "+this.txf_Default00.usecharcount
							+ "\ncontentheight = "+this.txf_Default00.contentheight
							+ "\nfooterheight= "+this.txf_Default00.footerheight
							+ "\nheaderheight= "+this.txf_Default00.headerheight
							+ "\nheight= "+this.txf_Default00.height;
	this.Static02.text ="";
	this.Static02.text= "usehelpertext = true\nusecharcount = true\ncontentheight = 80px\nheight = "+this.txf_Default00_00.height;
};

this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.TextArea00.deleteText();
	this.txf_Default00.usehelpertext = this.Radio00.text;
	this.txf_Default00.usecharcount = this.Radio00_00.text;
	if(this.StringCheck(this.Edit00.value))
		this.txf_Default00.contentheight= this.Edit00.value;
	if(this.StringCheck(this.Edit00_00.value))
		this.txf_Default00.footerheight= this.Edit00_00.value;
	if(this.StringCheck(this.Edit00_00_00.value))
		this.txf_Default00.headerheight= this.Edit00_00_00.value
	if(this.StringCheck(this.Edit00_00_00_00.value))
		this.txf_Default00.height= this.Edit00_00_00_00.value
	this.TextArea00.value = "usehelpertext = "+this.txf_Default00.usehelpertext
	                        + "\nusecharcount = "+this.txf_Default00.usecharcount
							+ "\ncontentheight = "+this.txf_Default00.contentheight
							+ "\nfooterheight= "+this.txf_Default00.footerheight
							+ "\nheaderheight= "+this.txf_Default00.headerheight
							+ "\nheight= "+this.txf_Default00.height;
};

this.StringCheck = function(strValue)
{
    // 1. null, undefined 체크
    if (strValue == null || strValue == undefined) {
        return false;
    }
    
    // 2. 문자열로 변환 (숫자 등이 들어와도 처리 가능)
    var str = String(strValue);
    
    // 3. 빈 값 체크
    if (str.length == 0) {
        return false;
    }
    
    // 4. 공백만 있는 값 체크 (스페이스, 탭, 줄바꿈 등)
    if (str.replace(/\s/g, "").length == 0) {
        return false;
    }
    
    // 5. 특수문자 포함 여부 체크
    // 영문(a-z, A-Z), 숫자(0-9), 한글, 공백 외의 문자가 있으면 false
    var specialCharPattern = /[`~!@#$%^&*()\-_=+\[\]{}\\|;:'",.<>\/?]/;
    if (specialCharPattern.test(str)) {
        return false;
    }
    
    return true;
};
this.Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.reload();
};
]]></Script>
  </Form>
</FDL>
