<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Static_Selectable_Sample00" width="1280" height="720" titletext="New Form">
    <Layouts>
      <Layout height="720" mobileorientation="landscape" width="1280">
        <Static id="sta_all00_00" taborder="" text="첫번째 [static.selectable = none ]" left="40" top="32" width="260" height="56" selectable="none" border="1px solid blue" textAlign="center"/>
        <Static id="sta_text00_00" taborder="1" text="두번째 [static.selectable = none ]" left="320" top="32" width="260" height="56" selectable="none" border="1px solid blue" textAlign="center"/>
        <Static id="sta_none00_00" taborder="2" text="세번째 [static.selectable = none ]" left="600" top="32" width="260" height="56" selectable="none" border="1px solid blue" textAlign="center"/>
        <TextArea id="TextArea00_00_00" taborder="3" left="40" top="100" width="820" height="57"/>
        <Edit id="Edit00" taborder="4" left="40" top="170" width="819" height="48"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.TextArea00.deleteText();
	this.TextArea00.insertText("1.selectable = all 설정 전 값 확인 : "+this.sta_all.selectable);
	this.sta_all.selectable = "all";
	this.TextArea00.insertText("2.selectable = all 설정 후 값 확인 : "+this.sta_all.selectable);
};

this.Button00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.TextArea00.deleteText();
	this.TextArea00.insertText("1.selectable = text 설정 전 값 확인 : "+this.sta_text.selectable);
	this.sta_text.selectable = "text";
	this.TextArea00.insertText("2.selectable = text 설정 후 값 확인 : "+this.sta_text.selectable);
};

this.Button00_00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.TextArea00.deleteText();
	this.TextArea00.insertText("1.selectable = none 설정 전 값 확인 : "+this.sta_none.selectable);
	this.sta_none.selectable = "none";
	this.TextArea00.insertText("2.selectable = none 설정 후 값 확인 : "+this.sta_none.selectable);
};
]]></Script>
  </Form>
</FDL>
