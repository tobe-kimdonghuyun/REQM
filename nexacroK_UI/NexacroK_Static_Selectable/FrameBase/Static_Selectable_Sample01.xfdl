<?xml version="1.0" encoding="utf-8"?>
<FDL version="2.1">
  <Form id="Static_Selectable_Sample00" width="1280" height="720" titletext="New Form">
    <Layouts>
      <Layout height="720" mobileorientation="landscape" width="1280">
        <Static id="sta_all" taborder="" text="script에서 selectable = all 동적으로 설정" left="40" top="44" width="260" height="56" border="1px solid green" textAlign="center"/>
        <Static id="sta_text" taborder="1" text="script에서 selectable = text 동적적으로 설정" left="320" top="44" width="260" height="56" border="1px solid green" textAlign="center"/>
        <Static id="sta_none" taborder="2" text="script에서 selectable = none정적으로 설정" left="600" top="44" width="260" height="56" border="1px solid green" selectable="all" textAlign="center"/>
        <Button id="Button00" taborder="3" text="selectable = all 확인" left="44" top="120" width="256" height="60" onclick="Button00_onclick"/>
        <Button id="Button00_00" taborder="4" text="selectable = text 확인" left="324" top="120" width="256" height="60" onclick="Button00_00_onclick"/>
        <Button id="Button00_00_00" taborder="5" text="selectable = none 확인" left="604" top="120" width="256" height="60" onclick="Button00_00_00_onclick"/>
        <Button id="Button00_01" taborder="6" text="set_selectable(&quot;all&quot;) 확인" left="44" top="190" width="256" height="60" onclick="Button00_01_onclick"/>
        <Button id="Button00_00_01" taborder="7" text="set_selectable(&quot;text&quot;)확인" left="324" top="190" width="256" height="60" onclick="Button00_00_01_onclick"/>
        <Button id="Button00_00_00_00" taborder="8" text="set_selectable(&quot;none&quot;)확인" left="604" top="190" width="256" height="60" onclick="Button00_00_00_00_onclick"/>
        <TextArea id="TextArea00" taborder="9" left="50" top="260" width="530" height="221"/>
      </Layout>
    </Layouts>
    <Script type="xscript5.1"><![CDATA[
this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.TextArea00.deleteText();
	this.TextArea00.insertText("1.selectable = all 설정 전 값 확인 : "+this.sta_all.selectable+"\n");
	this.sta_all.selectable = "all";
	this.TextArea00.insertText("2.selectable = all 설정 후 값 확인 : "+this.sta_all.selectable+"\n");
};

this.Button00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.TextArea00.deleteText();
	this.TextArea00.insertText("1.selectable = text 설정 전 값 확인 : "+this.sta_text.selectable+"\n");
	this.sta_text.selectable = "text";
	this.TextArea00.insertText("2.selectable = text 설정 후 값 확인 : "+this.sta_text.selectable+"\n");
};

this.Button00_00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.TextArea00.deleteText();
	this.TextArea00.insertText("1.selectable = none 설정 전 값 확인 : "+this.sta_none.selectable+"\n");
	this.sta_none.selectable = "none";
	this.TextArea00.insertText("2.selectable = none 설정 후 값 확인 : "+this.sta_none.selectable+"\n");
};

this.Button00_01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.TextArea00.deleteText();
	this.TextArea00.insertText('1.set_selectable("all") 설정 전 값 확인 : '+this.sta_all.get_selectable()+'\n');
	this.sta_all.set_selectable("all");
	this.TextArea00.insertText('2.set_selectable("all") 설정 후 값 확인 : '+this.sta_all.get_selectable()+'\n');
};

this.Button00_00_01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	
	this.TextArea00.deleteText();
	this.TextArea00.insertText("1.set_selectable('text') 설정 전 값 확인 : "+this.sta_text.get_selectable()+"\n");
	this.sta_text.set_selectable("text");
	this.TextArea00.insertText("2.set_selectable('text') 설정 후 값 확인 : "+this.sta_text.get_selectable()+"\n");
};

this.Button00_00_00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	this.TextArea00.deleteText();
	this.TextArea00.insertText("1.set_selectable('none') 설정 전 값 확인 : "+this.sta_none.get_selectable()+"\n");
	this.sta_none.set_selectable("none");
	this.TextArea00.insertText("2.set_selectable('none') 설정 후 값 확인 : "+this.sta_none.get_selectable()+"\n");
};

]]></Script>
  </Form>
</FDL>
