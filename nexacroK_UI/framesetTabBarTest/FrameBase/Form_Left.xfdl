};

this.Button12_00_00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	frameset.tabbaritemgap = 0;
};

this.Button07_00_00_00_00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
