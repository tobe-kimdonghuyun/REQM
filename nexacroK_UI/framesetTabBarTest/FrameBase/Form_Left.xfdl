};

this.Button11_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	frameset.tabbaritempinbuttonposition = (frameset.tabbaritempinbuttonposition == 'start' ? 'beforeclosebutton' : 'start');
};

this.Button14_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	frameset.setTabBarExtraButtonVisible(1,4,false);
};

this.Button14_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	frameset.setTabBarExtraButtonVisible(1,3,true);
};

this.Button14_00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	alert(frameset.getTabBarExtraButtonVisible(2));
};

this.Button14_01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	frameset.setTabBarHeadButtonVisible(1,4,false);
};

this.Button14_00_01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
