    <Script type="xscript5.1"><![CDATA[var frameid = 100;
var frameset = this.getOwnerFrame().getOwnerFrame().FrameSet00;

this.Button00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	frameset.ChildFrame01.visible = !frameset.ChildFrame01.visible;
};

this.Button01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var frame = new ChildFrame();
	
	frame.init( "ChildFrame" + frameid++);
	frame.enable = "true";
	frame.titletext = "Append Test";
	frame.showtitleicon = "true";
	frame.resizable = "true";
	frame.formurl = "FrameBase::Form_Child_Append.xfdl";
	frameset.addChild(frame.name, frame);
	
	frame.show();
};

this.Button02_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	frameset.ChildFrame01.enable = false;
	frameset.ChildFrame02.enable = false;
};

this.Button03_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	frameset.ChildFrame00.titletext = this.Edit00.value;
};

this.Button05_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var showtabbar = frameset.showtabbar;
	
	frameset.showtabbar = !showtabbar;
};

this.Button06_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var tabbarpos = frameset.tabbarposition;
	
	if(tabbarpos == 'left')
		frameset.tabbarposition = "bottom";
	else if(tabbarpos == 'top')
		frameset.tabbarposition = "left";
	else if(tabbarpos == 'right')
		frameset.tabbarposition = "top";
	else if(tabbarpos == 'bottom')
		frameset.tabbarposition = "right";
};

this.Button04_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	var frame = frameset.ChildFrame00;
	var allowpinbutton = frame.allowtabbaritempinbutton;
	frame.allowtabbaritempinbutton = !allowpinbutton;
};

this.Button07_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	frameset.tabbarextrabuttoncount = this.Edit01.value;
};

this.Button08_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	frameset.tabbarextrabuttontooltiptext = "a,b,c,d,e";
};

this.Button09_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	frameset.tabbarbuttonseparatorsize = this.Edit02.value;
};

this.Button10_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	frameset.tabbaritemjustify = !frameset.tabbaritemjustify;
};

this.Button11_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	frameset.tabbaritemusepinbutton = !frameset.tabbaritemusepinbutton;
};

this.Button07_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	frameset.tabbarsize = this.Edit03.value;
};

this.Button12_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	frameset.tabbarsize = undefined;
};

this.Button07_00_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	frameset.tabbaritemheight = this.Edit04.value;
};

this.Button12_00_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
	frameset.tabbaritemheight = undefined;
};

this.Button07_00_01_onclick = function(obj:nexacro.Button,e:nexacro.ClickEventInfo)
{
